ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to begin (first day of work, rehearsal, or availability). | Column engagement_start_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivitySummary rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Summary' ;
    rdfs:comment 'High-level summary of exclusivity terms (e.g., exclusive to network during production, non-exclusive, first-look, holdback period). Detailed clauses are in the long-form contract. | Column exclusivity_summary (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionTerms rdf:type rdf:Property ;
    rdfs:label 'Option Terms' ;
    rdfs:comment 'Summary of any option clauses (e.g., network option for additional seasons, talent option to extend, mutual option). Null if no options are included. | Column option_terms (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFunction rdf:type rdf:Property ;
    rdfs:label 'Role Function' ;
    rdfs:comment 'The specific role or function the talent will perform (e.g., Lead Actor, Director, Writer, Executive Producer, Host, Correspondent, Camera Operator). | Column role_function (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which the deal memo was superseded by the execution of a long-form contract. Null if not yet superseded. | Column superseded_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aboveTheLineFlag rdf:type rdf:Property ;
    rdfs:label 'Above The Line Flag' ;
    rdfs:comment 'Indicates whether this role is classified as above-the-line (creative principals: actors, directors, writers, producers) or below-the-line (technical crew and support staff). Impacts budget allocation and residual calculations. | Column above_the_line_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Total number of episodes, segments, or appearances in which this talent role is featured. Used for episodic and recurring roles. | Column appearance_count (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for residual payments based on subsequent distribution, reuse, or syndication of the content. Determined by guild agreements and contract terms. | Column residual_eligible_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRateCode rdf:type rdf:Property ;
    rdfs:label 'Residual Rate Code' ;
    rdfs:comment 'Code identifying the residual payment rate schedule applicable to this role based on guild agreements, role category, and distribution windows. | Column residual_rate_code (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Screen Time Minutes' ;
    rdfs:comment 'Total on-screen time in minutes for this talent role across all appearances. Used for on-screen talent to measure prominence and for residual calculations. | Column screen_time_minutes (DECIMAL(8,2)) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stuntDoubleFlag rdf:type rdf:Property ;
    rdfs:label 'Stunt Double Flag' ;
    rdfs:comment 'Indicates whether this role involves stunt work or if a stunt double is used for this character. Impacts insurance, safety protocols, and credit attribution. | Column stunt_double_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsDurationYears rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Duration Years' ;
    rdfs:comment 'Number of years for which usage rights are granted. Null indicates perpetual rights. | Column usage_rights_duration_years (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightsMedia rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Media' ;
    rdfs:comment 'Media platforms and formats for which usage rights are granted (e.g., \'Theatrical, Home Video, Streaming, Broadcast TV\'). | Column usage_rights_media (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Territory' ;
    rdfs:comment 'Geographic territories in which the content featuring this talent role may be distributed and exploited (e.g., \'Worldwide\', \'North America\', \'USA and Canada\'). | Column usage_rights_territory (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Voice Only Flag' ;
    rdfs:comment 'Indicates whether this is a voice-only role (voice-over, narration, animation, ADR) with no on-screen physical appearance by the talent. | Column voice_only_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the representation entity: talent agency (licensed to procure employment), literary agency (represents writers), management company (career guidance), law firm (legal representation), publicity firm (public relations), or hybrid (multiple services). | Column agency_type (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name under which the agency operates, if different from the legal name. | Column dba_name (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'The date on which the talent agency was originally established or incorporated. | Column established_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The fax number for the agency, used for contract transmission and official correspondence in jurisdictions where fax is still required. | Column fax_number (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Effective Date' ;
    rdfs:comment 'The date on which the SAG-AFTRA franchise agreement became effective for this agency. | Column franchise_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'The date on which the current SAG-AFTRA franchise agreement expires and must be renewed. | Column franchise_expiration_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Number' ;
    rdfs:comment 'The unique franchise identification number issued by SAG-AFTRA to franchised talent agencies. | Column franchise_number (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Indicates whether the agency holds a valid SAG-AFTRA franchise agreement, which authorizes the agency to represent union talent. Franchised agencies agree to standard commission rates and contract terms. | Column franchise_status (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'License Effective Date' ;
    rdfs:comment 'The date on which the state talent agency license became effective. | Column license_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'The date on which the state talent agency license expires and must be renewed. | Column license_expiration_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'The state or province that issued the talent agency license. Use standard two-letter state/province codes. | Column license_state (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'The job title or role of the primary contact person (e.g., President, Partner, Agent, Business Affairs Manager). | Column primary_contact_title (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for official correspondence, contract delivery, and residual payment notifications. | Column primary_email (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for the agency, including country and area codes. | Column primary_phone (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'The approximate number of talent clients currently represented by the agency. Used for agency scale assessment and negotiation context. | Column roster_size (INT) in talent.talent_agency' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'The primary area of talent specialization or focus for the agency (e.g., film and television actors, commercial talent, voice-over artists, writers, directors, below-the-line crew, music artists). Free-text field to accommodate multiple specializations. | Column specialization (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The standard commission rate percentage that the agency charges for talent representation, typically 10% for franchised agencies under SAG-AFTRA rules. Expressed as a percentage (e.g., 10.00 for 10%). | Column standard_commission_rate (DECIMAL(5,2)) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date on which the current status became effective. | Column status_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Status' ;
    rdfs:comment 'The current operational status of the talent agency: active (currently representing talent), inactive (not currently operating), suspended (temporarily not authorized), pending_verification (under review), or dissolved (permanently closed). | Column talent_agency_status (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The tax identification number (EIN in the US, VAT number in EU) for the agency, used for tax reporting and residual payment processing. | Column tax_identifier (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL for the talent agency, used for public information and talent roster visibility. | Column website_url (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Id' ;
    rdfs:comment 'Unique identifier for the representation agreement record. Primary key. | Column representation_agreement_id (BIGINT) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionCapAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Cap Amount' ;
    rdfs:comment 'Maximum commission amount per engagement or per year, if a cap is specified in the agreement. Null if no cap applies. | Column commission_cap_amount (DECIMAL(15,2)) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Percentage of talent earnings paid to the representative as commission (typically 10% for agents, 15% for managers per industry standards). | Column commission_percentage (DECIMAL(5,2)) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Contract Document Uri' ;
    rdfs:comment 'URI or file path to the signed representation agreement contract document stored in the Media Asset Management (MAM) system or document repository. | Column contract_document_uri (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Franchise Flag' ;
    rdfs:comment 'Indicates whether the agency or representative is franchised by a talent guild (SAG-AFTRA, WGA, DGA). Franchised agents must comply with guild-mandated commission caps and contract terms. | Column guild_franchise_flag (BOOLEAN) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the representation agreement: active (in force), expired (end date reached), terminated (ended early by either party), suspended (temporarily inactive), or pending (signed but not yet effective). | Column representation_agreement_status (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationType rdf:type rdf:Property ;
    rdfs:label 'Representation Type' ;
    rdfs:comment 'Classification of the representation relationship: exclusive agent (sole representation), co-agent (shared representation), manager (career management), entertainment attorney (legal counsel), business manager (financial management), or publicist (public relations). | Column representation_type (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Routing Flag' ;
    rdfs:comment 'Indicates whether residual payments for work performed during this representation period should be routed through this representative for commission deduction. | Column residual_routing_flag (BOOLEAN) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of services the representative will provide: deal negotiation, career guidance, audition scheduling, contract review, brand partnerships, etc. | Column scope_of_services (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date when the representation agreement was signed by both parties. | Column signing_date (DATE) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the representation agreement (commonly 30, 60, or 90 days). | Column termination_notice_period_days (INT) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightId rdf:type rdf:Property ;
    rdfs:label 'Usage Right Id' ;
    rdfs:comment 'Unique identifier for the usage right record. Primary key. | Column usage_right_id (BIGINT) in talent.usage_right' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageRight .

ind:licensedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Licensed Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Usage rights vary by asset version (master vs proxy, theatrical vs broadcast, original vs dubbed). Specific assets have different distribution rights, platforms, and territorial restrictions. Required | Column licensed_media_asset_id (BIGINT) in mediaasset.usage_right' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:clearanceGrantedBy rdf:type rdf:Property ;
    rdfs:label 'Clearance Granted By' ;
    rdfs:comment 'Name or identifier of the person or system that granted clearance for this usage right. | Column clearance_granted_by (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Granted Date' ;
    rdfs:comment 'Date when clearance was granted for this usage right. Null if not yet cleared. | Column clearance_granted_date (DATE) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'Date when talent consent was obtained for this usage right. Null if consent not obtained or not required. | Column consent_obtained_date (DATE) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether required consent has been obtained from the talent (True) or not (False). Null if consent not required. | Column consent_obtained_flag (BOOLEAN) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit talent consent is required for each use under this right (True) or if blanket consent was granted (False). | Column consent_required_flag (BOOLEAN) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAttributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Required Flag' ;
    rdfs:comment 'Indicates whether talent credit attribution is contractually required when this usage right is exercised (True) or not (False). | Column credit_attribution_required_flag (BOOLEAN) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAttributionText rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Text' ;
    rdfs:comment 'Specific credit text that must be displayed when this usage right is exercised (e.g., \'Starring John Doe\'). Null if not required. | Column credit_attribution_text (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRateType rdf:type rdf:Property ;
    rdfs:label 'Residual Rate Type' ;
    rdfs:comment 'Type of residual payment structure for this usage right (e.g., flat fee, percentage of revenue, per-use rate, tiered schedule, or none). | Column residual_rate_type (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitType rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Type' ;
    rdfs:comment 'Type of usage limitation applied to this right (e.g., unlimited, limited by number of runs, time duration, impressions, or revenue cap). | Column usage_limit_type (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Unit' ;
    rdfs:comment 'Unit of measure for the usage limit value (e.g., runs, days, impressions, currency code). Null if unlimited. | Column usage_limit_unit (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitValue rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Value' ;
    rdfs:comment 'Numeric value of the usage limit (e.g., 10 runs, 365 days, 1000000 impressions, 50000 USD revenue cap). Null if unlimited. | Column usage_limit_value (DECIMAL(18,2)) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Detailed description of what the usage right covers (e.g., likeness, voice, name, performance, image). | Column usage_scope (STRING) in talent.usage_right' ;
    rdfs:domain ind:UsageRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEndDate rdf:type rdf:Property ;
    rdfs:label 'Window End Date' ;
    rdfs:comment 'End date of the usage rights window. Defines when the right expires. Nullable for perpetual rights. | Column window_end_date (DATE) in talent.usage_right' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowStartDate rdf:type rdf:Property ;
    rdfs:label 'Window Start Date' ;
    rdfs:comment 'Start date of the usage rights window. Defines when the right becomes effective. | Column window_start_date (DATE) in talent.usage_right' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractOptionId rdf:type rdf:Property ;
    rdfs:label 'Contract Option Id' ;
    rdfs:comment 'Unique identifier for the contract option record. Primary key. | Column contract_option_id (BIGINT) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAffairsContact rdf:type rdf:Property ;
    rdfs:label 'Business Affairs Contact' ;
    rdfs:comment 'Name or identifier of the business affairs executive or legal representative responsible for managing this option and coordinating exercise decisions. | Column business_affairs_contact (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStepUpPercentage rdf:type rdf:Property ;
    rdfs:label 'Compensation Step Up Percentage' ;
    rdfs:comment 'Percentage increase in base compensation upon exercise of the option, relative to the prior contract period or base rate. Common in multi-season series deals where talent compensation escalates with each renewal. | Column compensation_step_up_percentage (DECIMAL(5,2)) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exerciseApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Approval Date' ;
    rdfs:comment 'The date on which the option exercise was formally approved by the authorized business affairs or executive authority. May differ from notification date in organizations requiring multi-level approval. | Column exercise_approval_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Exercise Compensation Amount' ;
    rdfs:comment 'The base compensation amount payable to the talent if the option is exercised. Represents the step-up or incremental payment beyond the option fee for the additional work commitment. | Column exercise_compensation_amount (DECIMAL(15,2)) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exerciseCompensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Exercise Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the exercise compensation (e.g., USD, GBP, EUR, CAD). | Column exercise_compensation_currency (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Notification Date' ;
    rdfs:comment 'The date on which the production company formally notified the talent (or their representative) of the decision to exercise the option. Triggers contractual obligations and payment schedules. | Column exercise_notification_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Exercise Notification Method' ;
    rdfs:comment 'The communication channel or mechanism used to deliver the option exercise notification, as required by the contract terms. Important for legal compliance and dispute resolution. | Column exercise_notification_method (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Exercise Status' ;
    rdfs:comment 'Current state of the option: unexercised (option window open, not yet acted upon), exercised (option formally invoked by production company), lapsed (option window closed without exercise), waived (option voluntarily released by production company), pending approval (exercise submitted awaiting legal or executive approval), or conditionally exercised (exercise subject to specific conditions being met). | Column exercise_status (STRING) in talent.contract_option' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Date' ;
    rdfs:comment 'The date on which the option exercise was reported to the applicable guild. Required for compliance audit trails when guild_notification_required_flag is True. | Column guild_notification_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required Flag' ;
    rdfs:comment 'Indicates whether the option exercise must be reported to the talents guild (SAG-AFTRA, WGA, DGA) for compliance and residual tracking purposes. True if guild notification is required, False otherwise. | Column guild_notification_required_flag (BOOLEAN) in talent.contract_option' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lapseDate rdf:type rdf:Property ;
    rdfs:label 'Lapse Date' ;
    rdfs:comment 'The actual date on which the option lapsed due to non-exercise within the option window. Recorded for audit and contract history purposes. | Column lapse_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lapseReason rdf:type rdf:Property ;
    rdfs:label 'Lapse Reason' ;
    rdfs:comment 'Business rationale or explanation for why the option was allowed to lapse without exercise. May include creative decisions, budget constraints, performance issues, or strategic pivots. | Column lapse_reason (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionDescription rdf:type rdf:Property ;
    rdfs:label 'Option Description' ;
    rdfs:comment 'Detailed narrative description of the option terms, scope, and conditions. May include specific deliverables, performance triggers, or creative commitments associated with the option. | Column option_description (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Option Fee Amount' ;
    rdfs:comment 'The monetary consideration paid to the talent to secure the option right, regardless of whether the option is ultimately exercised. Typically non-refundable and may be applied against future compensation if exercised. | Column option_fee_amount (DECIMAL(15,2)) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Option Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the option fee (e.g., USD, GBP, EUR, CAD). | Column option_fee_currency (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionNumber rdf:type rdf:Property ;
    rdfs:label 'Option Number' ;
    rdfs:comment 'Sequential number of this option within the contract (e.g., 1 for first option, 2 for second option). Used to track multi-year or multi-project option sequences. | Column option_number (INT) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Classification of the option based on its business purpose: series pickup option for additional seasons, sequel option for follow-on films, spin-off option for derivative content, overall deal extension for multi-project agreements, season renewal for episodic content, or project continuation for phased productions. | Column option_type (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Option Window End Date' ;
    rdfs:comment 'The final date by which the option must be exercised or it will lapse. Critical deadline for business affairs teams to track to avoid inadvertent loss of talent commitments. | Column option_window_end_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Option Window Start Date' ;
    rdfs:comment 'The earliest date on which the option can be exercised by the production company or network. Marks the beginning of the exercise window. | Column option_window_start_date (DATE) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Trigger Description' ;
    rdfs:comment 'Description of any performance-based conditions or milestones that must be met before the option can be exercised (e.g., minimum ratings thresholds, box office targets, critical acclaim metrics, audience engagement benchmarks). | Column performance_trigger_description (STRING) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTriggerMetFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Trigger Met Flag' ;
    rdfs:comment 'Indicates whether all performance-based conditions have been satisfied, enabling the option to be exercised. True if triggers are met or not applicable, False if triggers exist but are not yet satisfied. | Column performance_trigger_met_flag (BOOLEAN) in talent.contract_option' ;
    rdfs:domain ind:ContractOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availabilityId rdf:type rdf:Property ;
    rdfs:label 'Availability Id' ;
    rdfs:comment 'Unique identifier for the talent availability record. Primary key. | Column availability_id (BIGINT) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Classification of the availability status: available (talent is free), hold (production has placed a hold), first_refusal (talent has granted first right to book), confirmed_booking (talent is booked), personal_unavailability (talent is unavailable for personal reasons), conflicting_production (talent is committed to another production). | Column availability_type (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Booking Confirmed Date' ;
    rdfs:comment 'The date when the booking was confirmed and the talent was officially committed to the production. Null if not yet confirmed. | Column booking_confirmed_date (DATE) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictProductionNetwork rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Network' ;
    rdfs:comment 'Network or studio associated with the conflicting production. Used to identify potential exclusivity clause violations. | Column conflict_production_network (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictProductionTitle rdf:type rdf:Property ;
    rdfs:label 'Conflict Production Title' ;
    rdfs:comment 'Title of the conflicting production when availability_type is conflicting_production. Null if not applicable. | Column conflict_production_title (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Date' ;
    rdfs:comment 'The date by which the production must confirm the booking or the hold will expire. Null if not applicable. | Column hold_expiration_date (DATE) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPlacedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Date' ;
    rdfs:comment 'The date when the hold was initially placed on the talent. Null if availability_type is not hold or first_refusal. | Column hold_placed_date (DATE) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Email' ;
    rdfs:comment 'Email address of the production contact who placed the availability request. | Column requesting_contact_email (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Phone' ;
    rdfs:comment 'Phone number of the production contact who placed the availability request. | Column requesting_contact_phone (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingProducerName rdf:type rdf:Property ;
    rdfs:label 'Requesting Producer Name' ;
    rdfs:comment 'Name of the producer or production manager who requested the availability hold or booking. | Column requesting_producer_name (STRING) in talent.availability' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionHealthContributionId rdf:type rdf:Property ;
    rdfs:label 'Pension Health Contribution Id' ;
    rdfs:comment 'Unique identifier for the pension and health contribution record. | Column pension_health_contribution_id (BIGINT) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Explanation for any adjustment made to the contribution amount, including reference to prior period corrections or rate changes. | Column adjustment_reason (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Period End Date' ;
    rdfs:comment 'The end date of the earnings period for which this pension and health contribution is calculated. | Column contribution_period_end_date (DATE) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Period Start Date' ;
    rdfs:comment 'The start date of the earnings period for which this pension and health contribution is calculated. | Column contribution_period_start_date (DATE) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contribution Reference Number' ;
    rdfs:comment 'External reference number assigned by the guild benefit fund for tracking and reconciliation purposes. | Column contribution_reference_number (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Classification of the contribution based on the nature of the underlying compensation (initial work, residual payment, reuse, etc.). | Column contribution_type (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The dollar amount withheld from the talent\'s compensation and contributed to the guild benefit fund, if applicable. | Column employee_contribution_amount (DECIMAL(18,2)) in talent.pension_health_contribution' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the gross compensation base to calculate the employee\'s (talent\'s) pension and health contribution, if applicable. | Column employee_contribution_rate (DECIMAL(5,4)) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The dollar amount contributed by the employer to the guild benefit fund on behalf of the talent. | Column employer_contribution_amount (DECIMAL(18,2)) in talent.pension_health_contribution' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the gross compensation base to calculate the employer\'s pension and health contribution obligation. | Column employer_contribution_rate (DECIMAL(5,4)) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCompensationBase rdf:type rdf:Property ;
    rdfs:label 'Gross Compensation Base' ;
    rdfs:comment 'The gross earnings amount upon which the pension and health contribution is calculated, before any deductions or adjustments. | Column gross_compensation_base (DECIMAL(18,2)) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guildAcknowledgmentNumber rdf:type rdf:Property ;
    rdfs:label 'Guild Acknowledgment Number' ;
    rdfs:comment 'Confirmation or acknowledgment number provided by the guild benefit fund upon receipt and processing of the contribution. | Column guild_acknowledgment_number (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFundCode rdf:type rdf:Property ;
    rdfs:label 'Guild Fund Code' ;
    rdfs:comment 'Code identifying the specific guild benefit fund to which the contribution is remitted (e.g., SAG-AFTRA Health Plan, SAG-Producers Pension Plan, DGA-Producer Pension and Health Plan, WGA Pension Plan). [ENUM-REF-CANDIDATE: SAG_HEALTH|SAG_PENSION|DGA_PENSION_HEALTH|WGA_PENSION|WGA_HEALTH|IATSE_PENSION|IATSE_HEALTH|AFM_PENSION|AFM_HEALTH — 9 candidates stripped; promote to reference product] | Column guild_fund_code (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFundName rdf:type rdf:Property ;
    rdfs:label 'Guild Fund Name' ;
    rdfs:comment 'Full name of the guild benefit fund receiving the contribution. | Column guild_fund_name (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Amount' ;
    rdfs:comment 'Penalty amount assessed by the guild benefit fund for late remittance of the contribution, if applicable. | Column late_payment_penalty_amount (DECIMAL(18,2)) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'The date on which the contribution payment was remitted to the guild benefit fund. | Column remittance_date (DATE) in talent.pension_health_contribution' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Date' ;
    rdfs:comment 'The contractual due date by which the contribution must be remitted to the guild benefit fund to avoid penalties. | Column remittance_due_date (DATE) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Contribution Amount' ;
    rdfs:comment 'The combined total of employer and employee contributions remitted to the guild benefit fund for this contribution record. | Column total_contribution_amount (DECIMAL(18,2)) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'The type of work performed by the talent that generated the compensation base for this contribution. | Column work_type (STRING) in talent.pension_health_contribution' ;
    rdfs:domain ind:PensionHealthContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Talent Clearance Id' ;
    rdfs:comment 'Unique identifier for the talent clearance record. Primary key. | Column talent_clearance_id (BIGINT) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_sales_order. Business justification: Talent clearance required before using talent likeness/performance in advertiser-sponsored content or integrated sponsorships. Real business process: advertiser purchases branded content requiring tal | Column ad_sales_order_id (BIGINT) in sales.talent_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSalesOrder .

ind:clearedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Cleared Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Talent clearances are often asset-specific (theatrical cut vs TV edit, domestic vs international versions, trailer vs feature). Different assets may require separate clearances based on usage rights,  | Column cleared_media_asset_id (BIGINT) in mediaasset.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:requestedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Production or legal employees request talent clearances. Supports clearance workflow tracking, workload analysis, compliance audits, and accountability. Column requested_by_user is denormalized employ' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:talentContentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Talent Content Clearance Id' ;
    rdfs:comment 'Foreign key to SSOT content.content_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentClearance .

ind:talentContentContentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Talent Content Content Clearance Id' ;
    rdfs:comment 'FK to SSOT content.content_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentClearance .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the underlying talent contract that governs the usage rights being cleared. | Column contract_reference_number (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedBy rdf:type rdf:Property ;
    rdfs:label 'Granted By' ;
    rdfs:comment 'Name or identifier of the individual or department who authorized the clearance. | Column granted_by (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Required Flag' ;
    rdfs:comment 'Indicates whether guild or union clearance is required based on collective bargaining agreement terms. | Column guild_clearance_required_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Status' ;
    rdfs:comment 'Current status of guild or union clearance verification for this usage. | Column guild_clearance_status (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Guild Reference Number' ;
    rdfs:comment 'Reference or tracking number provided by the guild or union for this clearance request. | Column guild_reference_number (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likenessUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Likeness Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s physical likeness or image. | Column likeness_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nameUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Name Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s name in promotional or marketing materials. | Column name_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s recorded performance or voice. | Column performance_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualPaymentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Triggered Flag' ;
    rdfs:comment 'Indicates whether this clearance triggers residual payment obligations under guild agreements. | Column residual_payment_triggered_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedByLegalFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Legal Flag' ;
    rdfs:comment 'Indicates whether the clearance request has been reviewed and approved by the legal department. | Column reviewed_by_legal_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Date' ;
    rdfs:comment 'Date when the talent provided their explicit approval or consent for the specified usage. | Column talent_approval_date (DATE) in talent.talent_clearance' ;
    rdfs:domain ind:TalentClearance ;
    rdf:type owl:DatatypeProperty ;
