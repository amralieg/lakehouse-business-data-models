    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestContentType rdf:type rdf:Property ;
    rdfs:label 'Request Content Type' ;
    rdfs:comment 'The expected content type for the request body (e.g., application/json for JSON payloads, application/xml for XML). Null for endpoints that do not accept a request body (e.g., GET requests). | Column request_content_type (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseContentType rdf:type rdf:Property ;
    rdfs:label 'Response Content Type' ;
    rdfs:comment 'The content type returned by this endpoint in the response body (e.g., application/json for JSON responses, application/xml for XML). Defines the format of the data returned to the client. | Column response_content_type (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Ms' ;
    rdfs:comment 'The target response time in milliseconds for this endpoint under normal load conditions (e.g., 200ms for p95, 500ms for p99). Used for performance monitoring and alerting. | Column sla_response_time_ms (INT) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The service level agreement tier for this endpoint, defining uptime guarantees, response time targets, and support priority (e.g., mission_critical requires 99.99% uptime, gold requires 99.9%). | Column sla_tier (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percentage' ;
    rdfs:comment 'The guaranteed uptime percentage for this endpoint as defined in the SLA (e.g., 99.99 for four nines, 99.9 for three nines). Measured monthly. | Column sla_uptime_percentage (DECIMAL(5,2)) in distribution.api_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsFiltering rdf:type rdf:Property ;
    rdfs:label 'Supports Filtering' ;
    rdfs:comment 'Indicates whether this endpoint supports query parameter filtering to narrow down results (true) or returns a fixed result set (false). Filtering allows clients to request specific subsets of data. | Column supports_filtering (BOOLEAN) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPagination rdf:type rdf:Property ;
    rdfs:label 'Supports Pagination' ;
    rdfs:comment 'Indicates whether this endpoint supports pagination for large result sets (true) or returns all results in a single response (false). Paginated endpoints typically accept page and page_size query parameters. | Column supports_pagination (BOOLEAN) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSorting rdf:type rdf:Property ;
    rdfs:label 'Supports Sorting' ;
    rdfs:comment 'Indicates whether this endpoint supports query parameter sorting to order results (true) or returns results in a default order (false). Sorting allows clients to control result ordering. | Column supports_sorting (BOOLEAN) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEngineId rdf:type rdf:Property ;
    rdfs:label 'Personalization Engine Id' ;
    rdfs:comment 'Unique identifier for the personalization engine instance. Primary key for the personalization engine configuration record. | Column personalization_engine_id (BIGINT) in distribution.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PersonalizationEngine .

ind:fallbackEnginePersonalizationEngineId rdf:type rdf:Property ;
    rdfs:label 'Fallback Engine Personalization Engine Id' ;
    rdfs:comment 'Reference to an alternative personalization engine to use if this engine fails or returns insufficient recommendations. Ensures continuous user experience during engine failures or maintenance. | Column fallback_engine_personalization_engine_id (BIGINT) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PersonalizationEngine .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.audience_segment. Business justification: Modern personalization relies on behavioral segments for recommendation accuracy and engagement optimization. Supports genre affinity modeling, viewing pattern analysis, and cross-platform content dis | Column segment_id (BIGINT) in audience.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'A/B test variant identifier if this engine is part of an experimentation framework (e.g., \'control\', \'variant_a\', \'variant_b\'). Null if not part of active testing. | Column ab_test_variant (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'The machine learning algorithm type used by the personalization engine. Collaborative filtering uses user behavior patterns, content-based uses content attributes, hybrid combines both approaches, matrix factorization decomposes user-item interactions, deep learning uses neural networks, and contextual bandit balances exploration and exploitation. | Column algorithm_type (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) of the Application Programming Interface (API) endpoint that serves recommendations from this engine. Used by client applications to request personalized content. | Column api_endpoint_url (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale and expected outcomes for deploying this personalization engine (e.g., \'Increase Average Revenue Per User (ARPU) by 15%\', \'Reduce churn rate by improving content discovery\', \'Support new FAST channel launch\'). | Column business_justification (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether this personalization engine complies with California Consumer Privacy Act (CCPA) requirements, including opt-out mechanisms and data sale restrictions. | Column ccpa_compliant_flag (BOOLEAN) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldStartStrategy rdf:type rdf:Property ;
    rdfs:label 'Cold Start Strategy' ;
    rdfs:comment 'Strategy used to generate recommendations for new users or content with insufficient interaction history. Popularity-based shows trending content, content similarity uses metadata matching, demographic default uses segment averages, hybrid fallback combines multiple approaches, and random exploration introduces serendipity. | Column cold_start_strategy (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Minimum confidence score (0.00 to 1.00) required for a recommendation to be surfaced to users. Lower thresholds increase recommendation volume but may reduce relevance. | Column confidence_threshold (DECIMAL(5,2)) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentFilterRules rdf:type rdf:Property ;
    rdfs:label 'Content Filter Rules' ;
    rdfs:comment 'Business rules defining content eligibility for recommendations (e.g., exclude expired rights, enforce parental controls, respect geographic blackouts, honor windowing restrictions). Stored as structured text or JSON. | Column content_filter_rules (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date when this personalization engine instance was first deployed to production. Used for tracking engine age and performance trends over time. | Column deployment_date (DATE) in distribution.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityThreshold rdf:type rdf:Property ;
    rdfs:label 'Diversity Threshold' ;
    rdfs:comment 'Minimum diversity score (0.00 to 1.00) enforced in recommendation sets to prevent filter bubbles. Higher values ensure greater variety in content genres, formats, and themes. | Column diversity_threshold (DECIMAL(5,2)) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineCode rdf:type rdf:Property ;
    rdfs:label 'Engine Code' ;
    rdfs:comment 'Unique business identifier code for the personalization engine (e.g., \'HOME_REC_01\', \'CONT_DISC_02\'). Used for system integration and API references. | Column engine_code (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineName rdf:type rdf:Property ;
    rdfs:label 'Engine Name' ;
    rdfs:comment 'Human-readable name of the personalization engine instance (e.g., \'Homepage Recommender\', \'Content Discovery Engine\', \'Next Episode Predictor\'). Used for operational identification and reporting. | Column engine_name (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSetConfiguration rdf:type rdf:Property ;
    rdfs:label 'Feature Set Configuration' ;
    rdfs:comment 'JSON or structured text describing the feature set used by the model (e.g., viewing history, genre preferences, time-of-day patterns, device type, engagement metrics). Defines the input variables for the recommendation algorithm. | Column feature_set_configuration (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether this personalization engine complies with General Data Protection Regulation (GDPR) requirements for audience data processing, including consent management, data minimization, and right to erasure. | Column gdpr_compliant_flag (BOOLEAN) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTrainingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Training Timestamp' ;
    rdfs:comment 'Timestamp of the most recent model training execution. Critical for monitoring model freshness and ensuring recommendations reflect current user behavior patterns. | Column last_training_timestamp (TIMESTAMP) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Semantic version number of the deployed machine learning model (e.g., \'v1.2.3\'). Follows semantic versioning convention for model lifecycle management and rollback capability. | Column model_version (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Target' ;
    rdfs:comment 'Primary business metric this personalization engine is optimized to maximize. Click-through rate measures initial engagement, watch time measures sustained viewing, completion rate measures content finish rate, engagement score is a composite metric, and revenue per user measures monetization impact. | Column performance_metric_target (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationScope rdf:type rdf:Property ;
    rdfs:label 'Personalization Scope' ;
    rdfs:comment 'Granularity level at which personalization is applied. User-level provides individual recommendations, segment-level groups similar users, household-level considers shared viewing, and device-level adapts to device context. | Column personalization_scope (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationCountLimit rdf:type rdf:Property ;
    rdfs:label 'Recommendation Count Limit' ;
    rdfs:comment 'Maximum number of recommendations this engine will return per request. Typical values range from 10 to 100 depending on user interface requirements and performance constraints. | Column recommendation_count_limit (INT) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'Frequency at which the personalization model is retrained or recommendations are regenerated. Real-time engines update continuously, while batch engines refresh on schedule. | Column refresh_cadence (STRING) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSlaMs rdf:type rdf:Property ;
    rdfs:label 'Response Time Sla Ms' ;
    rdfs:comment 'Maximum acceptable response time in milliseconds for recommendation requests as defined in the Service Level Agreement (SLA). Typical values range from 100ms to 500ms for real-time engines. | Column response_time_sla_ms (INT) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDataWindowDays rdf:type rdf:Property ;
    rdfs:label 'Training Data Window Days' ;
    rdfs:comment 'Number of days of historical data used to train the personalization model. Typical values range from 30 to 365 days depending on content velocity and user behavior patterns. | Column training_data_window_days (INT) in distribution.personalization_engine' ;
    rdfs:domain ind:PersonalizationEngine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Configuration Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DAI configurations control ad insertion logic and revenue streams, requiring ownership for approval workflows, fill rate troubleshooting, blackout override decisions, and ad server contract compliance | Column configuration_owner_employee_id (BIGINT) in workforce.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrProfileCompatibility rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Compatibility' ;
    rdfs:comment 'Comma-separated list of ABR streaming profiles this DAI configuration is compatible with (e.g., HLS, MPEG-DASH, Smooth Streaming). | Column abr_profile_compatibility (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adDecisionServerUrl rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Server Url' ;
    rdfs:comment 'Endpoint URL for the Ad Decision Server that determines which ads to serve based on targeting criteria and inventory availability. | Column ad_decision_server_url (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFormatSupport rdf:type rdf:Property ;
    rdfs:label 'Ad Format Support' ;
    rdfs:comment 'Comma-separated list of supported ad formats for this configuration (e.g., VAST, VMAP, VPAID, SIMID). | Column ad_format_support (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodPlacementRules rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Placement Rules' ;
    rdfs:comment 'Business rules defining where ad pods (groups of ads in a break) can be inserted within the content, including pre-roll, mid-roll, and post-roll positions. | Column ad_pod_placement_rules (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adServerTimeoutMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Ad Server Timeout Milliseconds' ;
    rdfs:comment 'Maximum time in milliseconds to wait for a response from the ad decision server before triggering fallback logic. | Column ad_server_timeout_milliseconds (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupAdServerUrl rdf:type rdf:Property ;
    rdfs:label 'Backup Ad Server Url' ;
    rdfs:comment 'Failover endpoint URL for ad decision requests when the primary ad server is unavailable or times out. | Column backup_ad_server_url (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutOverrideEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Override Enabled' ;
    rdfs:comment 'Indicates whether this DAI configuration can override geographic blackout restrictions for ad insertion purposes. | Column blackout_override_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnIntegrationMode rdf:type rdf:Property ;
    rdfs:label 'Cdn Integration Mode' ;
    rdfs:comment 'How the DAI system integrates with the CDN: direct (CDN serves pre-stitched streams), proxied (DAI proxies through CDN), or edge decisioning (ad decisions at CDN edge). | Column cdn_integration_mode (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companionAdsEnabled rdf:type rdf:Property ;
    rdfs:label 'Companion Ads Enabled' ;
    rdfs:comment 'Indicates whether companion banner ads are displayed alongside video ads to enhance engagement and click-through rates. | Column companion_ads_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this DAI configuration across systems and platforms. | Column configuration_code (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name for this DAI configuration, used for identification and reference by operations teams. | Column configuration_name (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this DAI configuration: active (in production use), inactive (not in use), testing (under validation), or deprecated (scheduled for removal). | Column configuration_status (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationVersion rdf:type rdf:Property ;
    rdfs:label 'Configuration Version' ;
    rdfs:comment 'Version number of this configuration, incremented with each modification to support change tracking and rollback capabilities. | Column configuration_version (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Targeting Enabled' ;
    rdfs:comment 'Indicates whether device-specific targeting is enabled to serve ads optimized for the viewers device type (mobile, tablet, TV, desktop). | Column device_targeting_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmEnforcementMode rdf:type rdf:Property ;
    rdfs:label 'Drm Enforcement Mode' ;
    rdfs:comment 'Level of DRM enforcement applied to ad content: strict (full encryption), lenient (selective protection), or disabled (no DRM on ads). | Column drm_enforcement_mode (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackCreativeStrategy rdf:type rdf:Property ;
    rdfs:label 'Fallback Creative Strategy' ;
    rdfs:comment 'Strategy for handling unfilled ad inventory: display house ads, show slate/filler, continue content, or repeat the last served ad. | Column fallback_creative_strategy (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRateTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percentage' ;
    rdfs:comment 'Target percentage of available ad inventory that should be filled with paid advertisements, used to measure monetization effectiveness. | Column fill_rate_target_percentage (DECIMAL(5,2)) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCapEnabled rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Enabled' ;
    rdfs:comment 'Indicates whether frequency capping is enforced to limit the number of times a viewer sees the same ad within a session or time period. | Column frequency_cap_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoTargetingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting Enabled' ;
    rdfs:comment 'Indicates whether geographic targeting is enabled to serve location-specific ads based on viewer IP address or device location. | Column geo_targeting_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Ad Pod Duration Seconds' ;
    rdfs:comment 'Maximum allowed duration in seconds for a single ad pod insertion, ensuring viewer experience and regulatory compliance. | Column max_ad_pod_duration_seconds (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Hour' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a one-hour period when frequency capping is enabled. | Column max_impressions_per_hour (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImpressionsPerSession rdf:type rdf:Property ;
    rdfs:label 'Max Impressions Per Session' ;
    rdfs:comment 'Maximum number of times the same ad creative can be shown to a viewer within a single viewing session when frequency capping is enabled. | Column max_impressions_per_session (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAdPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Min Ad Pod Duration Seconds' ;
    rdfs:comment 'Minimum required duration in seconds for an ad pod to be considered valid for insertion. | Column min_ad_pod_duration_seconds (INT) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this DAI configuration record. | Column modified_by_user (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35SignalHandling rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Handling' ;
    rdfs:comment 'How SCTE-35 cue markers embedded in the content stream are processed: enabled (parse and act), disabled (ignore), or passthrough (forward without processing). | Column scte35_signal_handling (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stitchingMode rdf:type rdf:Property ;
    rdfs:label 'Stitching Mode' ;
    rdfs:comment 'Method used to insert ads into the content stream: server-side stitching (SSAI), client-side stitching (CSAI), or hybrid approach combining both. | Column stitching_mode (STRING) in distribution.dai_configuration' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingEventsEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Events Enabled' ;
    rdfs:comment 'Indicates whether ad tracking events (impressions, quartiles, completions, clicks) are captured and reported to measurement systems. | Column tracking_events_enabled (BOOLEAN) in distribution.dai_configuration' ;
    rdfs:domain ind:DaiConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureFlagId rdf:type rdf:Property ;
    rdfs:label 'Feature Flag Id' ;
    rdfs:comment 'Unique identifier for the feature flag configuration record. | Column feature_flag_id (BIGINT) in distribution.feature_flag' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeatureFlag .

ind:appVersionMax rdf:type rdf:Property ;
    rdfs:label 'App Version Max' ;
    rdfs:comment 'Maximum Over-The-Top (OTT) application version for which this feature flag is active (semantic versioning format: major.minor.patch). Null if no upper bound. | Column app_version_max (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersionMin rdf:type rdf:Property ;
    rdfs:label 'App Version Min' ;
    rdfs:comment 'Minimum Over-The-Top (OTT) application version required for this feature flag to be active (semantic versioning format: major.minor.patch). | Column app_version_min (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyFlags rdf:type rdf:Property ;
    rdfs:label 'Dependency Flags' ;
    rdfs:comment 'Comma-separated list of other feature flag keys that must be enabled for this flag to function correctly. Captures flag interdependencies. | Column dependency_flags (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlagDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Flag Description' ;
    rdfs:comment 'Detailed business description of the feature controlled by this flag, including purpose, expected behavior, and rollout strategy. | Column feature_flag_description (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enabledFlag rdf:type rdf:Property ;
    rdfs:label 'Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether the feature flag is currently enabled (True) or disabled (False) for the target audience. | Column enabled_flag (BOOLEAN) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationCount rdf:type rdf:Property ;
    rdfs:label 'Evaluation Count' ;
    rdfs:comment 'Total number of times this feature flag has been evaluated by application code since activation. Used for usage analytics and cleanup decisions. | Column evaluation_count (BIGINT) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experimentHypothesis rdf:type rdf:Property ;
    rdfs:label 'Experiment Hypothesis' ;
    rdfs:comment 'Business hypothesis being tested when flag_type is \'experiment\' (e.g., \'Personalized content rail will increase engagement by 15%\'). Null for non-experiment flags. | Column experiment_hypothesis (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagKey rdf:type rdf:Property ;
    rdfs:label 'Flag Key' ;
    rdfs:comment 'Unique programmatic identifier for the feature flag used in application code (e.g., \'new_player_ui\', \'personalized_rail_v2\'). Must be unique across the platform. | Column flag_key (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagName rdf:type rdf:Property ;
    rdfs:label 'Flag Name' ;
    rdfs:comment 'Human-readable display name for the feature flag shown in management dashboards and reporting interfaces. | Column flag_name (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagStatus rdf:type rdf:Property ;
    rdfs:label 'Flag Status' ;
    rdfs:comment 'Current lifecycle status of the feature flag: active (in use), inactive (temporarily disabled), archived (no longer needed but retained for audit), deprecated (scheduled for removal). | Column flag_status (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flagType rdf:type rdf:Property ;
    rdfs:label 'Flag Type' ;
    rdfs:comment 'Classification of the feature flag purpose: release_toggle (gradual feature rollout), experiment (A/B test variant), ops_toggle (operational control), permission_toggle (access control), ux_variant (user experience configuration), kill_switch (emergency disable capability). | Column flag_type (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:killSwitchEnabled rdf:type rdf:Property ;
    rdfs:label 'Kill Switch Enabled' ;
    rdfs:comment 'Boolean indicator of whether this flag can be used as an emergency kill switch to rapidly disable a feature without application redeployment. | Column kill_switch_enabled (BOOLEAN) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent evaluation of this feature flag by any application instance. Used to identify stale or unused flags. | Column last_evaluation_timestamp (TIMESTAMP) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:owningProductTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Product Team' ;
    rdfs:comment 'Name of the product team responsible for managing this feature flag and making rollout decisions (e.g., \'Player Experience Team\', \'Personalization Team\'). | Column owning_product_team (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of tags for categorization and filtering (e.g., \'personalization\', \'monetization\', \'compliance\', \'performance\'). Enables flag discovery and governance. | Column tags (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Audience segment or cohort identifier to which this feature flag applies (e.g., \'premium_subscribers\', \'beta_testers\', \'geo_usa_west\'). References audience segmentation taxonomy. | Column target_audience_segment (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Split Percentage' ;
    rdfs:comment 'Percentage of traffic allocated to variant B in A/B experiments (0.00 to 100.00). Remaining traffic goes to variant A. Null for non-experiment flags. | Column traffic_split_percentage (DECIMAL(5,2)) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uxConfigurationJson rdf:type rdf:Property ;
    rdfs:label 'Ux Configuration Json' ;
    rdfs:comment 'JSON-encoded configuration parameters for user experience variants including rail ordering, theme selection, layout variant, navigation structure, and other UX-specific settings controlled by this flag. | Column ux_configuration_json (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAConfig rdf:type rdf:Property ;
    rdfs:label 'Variant A Config' ;
    rdfs:comment 'Configuration parameters for variant A in A/B test experiments (typically the control group). JSON-encoded or plain text depending on complexity. | Column variant_a_config (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantBConfig rdf:type rdf:Property ;
    rdfs:label 'Variant B Config' ;
    rdfs:comment 'Configuration parameters for variant B in A/B test experiments (typically the treatment group). JSON-encoded or plain text depending on complexity. | Column variant_b_config (STRING) in distribution.feature_flag' ;
    rdfs:domain ind:FeatureFlag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Distribution partners (MVPDs, cable operators, streaming aggregators) are assigned to sales territories for account management. Supports territory-based partner relationship management, quota allocati | Column assigned_sales_territory_id (BIGINT) in sales.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Distribution partnerships require dedicated relationship managers for contract negotiations, SLA dispute resolution, carriage fee negotiations, and technical integration oversight. Essential for escal | Column relationship_manager_employee_id (BIGINT) in workforce.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrProfileSupport rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Support' ;
    rdfs:comment 'Description of Adaptive Bitrate streaming profiles and quality tiers supported by the distribution partner for OTT and streaming delivery. Includes resolution ranges, bitrate ladders, and codec support. | Column abr_profile_support (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Capability Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has technical capability to enforce geographic broadcast restrictions and content blackouts based on licensing and rights windows. | Column blackout_capability_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageCapacityChannels rdf:type rdf:Property ;
    rdfs:label 'Carriage Capacity Channels' ;
    rdfs:comment 'Number of linear channels or content streams that the distribution partner has capacity to carry simultaneously. Relevant for MVPD, vMVPD, and cable operators. | Column carriage_capacity_channels (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageFeeModel rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Model' ;
    rdfs:comment 'Commercial model for carriage fees paid by or to the distribution partner. Per Subscriber indicates fees based on subscriber count, Flat Rate indicates fixed periodic payment, Revenue Share indicates percentage of advertising or subscription revenue, Hybrid indicates combination of models. | Column carriage_fee_model (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract renewal or termination as specified in the distribution agreement. | Column contract_renewal_notice_days (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daiSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Support Flag' ;
    rdfs:comment 'Indicates whether the distribution partner supports Dynamic Ad Insertion technology for server-side ad stitching in streaming content. | Column dai_support_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmCapability rdf:type rdf:Property ;
    rdfs:label 'Drm Capability' ;
    rdfs:comment 'Digital Rights Management systems and encryption standards supported by the distribution partner. May include Widevine, FairPlay, PlayReady, and other DRM technologies. | Column drm_capability (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Description of the geographic markets, regions, or territories served by this distribution partner. May include country codes, DMA (Designated Market Area) codes, or regional descriptors. | Column geographic_footprint (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the distribution partner\'s corporate headquarters or primary business location. | Column headquarters_address (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the distribution partner\'s headquarters is located. | Column headquarters_city (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the distribution partner\'s headquarters is located. | Column headquarters_country_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the distribution partner\'s headquarters location. | Column headquarters_postal_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the distribution partner\'s headquarters is located. | Column headquarters_state_province (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has a must-carry obligation requiring mandatory inclusion of certain broadcast channels under FCC regulations. | Column must_carry_obligation_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Strategic classification of the partner based on reach, revenue contribution, and business importance. Tier 1 represents largest national/international partners, Tier 2 represents regional significant partners, Tier 3 represents local or niche partners. | Column partner_tier (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the distribution partner based on delivery model. MVPD (Multichannel Video Programming Distributor) includes traditional cable, satellite, and telco providers. vMVPD (Virtual MVPD) includes internet-based multichannel services. OTT Platform includes direct-to-consumer streaming services. FAST Aggregator includes Free Ad-Supported Streaming Television channel aggregators. Syndication Outlet includes broadcast stations and regional networks. | Column partner_type (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days for invoices related to carriage fees, revenue share, or other financial transactions with the distribution partner. | Column payment_terms_days (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Web URL for the distribution partner\'s business portal, technical documentation, or partner management system. | Column portal_url (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for financial transactions and reporting with this distribution partner. | Column preferred_currency_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact for distribution operations, technical coordination, and business communications. | Column primary_contact_email (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the distribution partner organization for operational coordination and escalation. | Column primary_contact_name (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the distribution partner contact for urgent operational matters and coordination. | Column primary_contact_phone (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Qos Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether active Quality of Service monitoring and reporting is enabled for content delivery through this distribution partner. | Column qos_monitoring_enabled_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Status' ;
    rdfs:comment 'Status of retransmission consent authorization allowing the distribution partner to rebroadcast content. Relevant for MVPD and cable operators under FCC regulations. | Column retransmission_consent_status (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Maximum acceptable latency in milliseconds for content delivery as defined in the distribution Service Level Agreement. Critical for live streaming and low-latency applications. | Column sla_latency_target_ms (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Reach Estimate' ;
    rdfs:comment 'Estimated number of subscribers, households, or unique users that can access content through this distribution partner. Used for reach analysis and revenue forecasting. | Column subscriber_reach_estimate (BIGINT) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDeliveryStandards rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Standards' ;
    rdfs:comment 'Comma-separated list of technical broadcast and streaming standards supported by the partner. May include DVB (Digital Video Broadcasting), ATSC (Advanced Television Systems Committee), QAM (Quadrature Amplitude Modulation), HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), and other delivery protocols. | Column technical_delivery_standards (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:DistributionPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carriage Agreement Id' ;
    rdfs:comment 'Unique identifier for the carriage agreement record. Primary key. | Column carriage_agreement_id (BIGINT) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageAgreement .

ind:assignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage agreements are managed by assigned sales reps who negotiate terms and maintain partner relationships. Critical for rep commission calculation on carriage fees, account ownership tracking, and | Column assigned_sales_rep_id (BIGINT) in sales.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Carriage agreements are high-value contracts requiring business/legal owner for amendments, renewal negotiations, retransmission consent disputes, and must-carry elections. Essential for approval work | Column contract_owner_employee_id (BIGINT) in workforce.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:masterInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Master Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Carriage agreements generate master invoices for services beyond specialized carriage fee invoices (setup fees, equipment, technical services). Real business process: comprehensive agreement billing,  | Column master_invoice_id (BIGINT) in billing.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carriage agreement: retransmission consent (FCC-regulated authorization for MVPDs to rebroadcast OTA signals), must-carry (mandatory carriage under FCC rules), voluntary carriage (negotiated carriage without must-carry obligation), or platform carriage (OTT/vMVPD distribution agreement). | Column agreement_type (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at the end of the term unless either party provides termination notice. | Column auto_renewal_flag (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutProvisions rdf:type rdf:Property ;
    rdfs:label 'Blackout Provisions' ;
    rdfs:comment 'Geographic or temporal restrictions on content availability, such as sports blackout rules, local market exclusions, or event-specific restrictions required by rights holders or league rules. | Column blackout_provisions (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Amount' ;
    rdfs:comment 'Monetary compensation paid by the distribution partner to the content provider for the right to carry the channel or content package. May be per-subscriber, flat fee, or tiered based on subscriber count. | Column carriage_fee_amount (DECIMAL(15,2)) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriageFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee amount (e.g., USD, GBP, EUR). | Column carriage_fee_currency (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Structure' ;
    rdfs:comment 'Pricing model for the carriage fee: per-subscriber (fee per active subscriber), flat monthly (fixed monthly payment), tiered (rate varies by subscriber volume), revenue share (percentage of ad or subscription revenue), or barter (non-cash compensation such as promotional commitments or channel positioning). | Column carriage_fee_structure (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumberAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Number Assignment' ;
    rdfs:comment 'The channel number or dial position assigned to the channel on the distribution platform. May vary by market or headend. | Column channel_number_assignment (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositioningTier rdf:type rdf:Property ;
    rdfs:label 'Channel Positioning Tier' ;
    rdfs:comment 'The service tier or package in which the channel is positioned (e.g., basic, expanded basic, premium, sports tier). Affects channel visibility and subscriber reach. | Column channel_positioning_tier (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationTerms rdf:type rdf:Property ;
    rdfs:label 'Compensation Terms' ;
    rdfs:comment 'Detailed description of all compensation provided under the agreement, including cash payments, barter arrangements (e.g., promotional commitments, ad inventory exchange), channel carriage reciprocity, or other non-monetary considerations. | Column compensation_terms (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed method for resolving disputes arising under the agreement: arbitration (binding third-party decision), mediation (facilitated negotiation), litigation (court proceedings), or negotiation (direct party-to-party resolution). | Column dispute_resolution_mechanism (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirements rdf:type rdf:Property ;
    rdfs:label 'Drm Requirements' ;
    rdfs:comment 'DRM and content protection requirements mandated under the agreement, such as encryption standards, conditional access systems, watermarking, and anti-piracy measures. | Column drm_requirements (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindow rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window' ;
    rdfs:comment 'Period during which the distribution partner has exclusive carriage rights within a defined geographic territory or platform category (e.g., exclusive MVPD rights in a DMA, exclusive vMVPD rights nationally). | Column exclusivity_window (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the carriage agreement, typically expressed as authorized DMAs (Designated Market Areas), states, regions, or national coverage. Defines where the distribution partner is authorized to carry the content. | Column geographic_coverage (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to the agreement (e.g., State of New York, England and Wales). Determines which courts and laws apply in case of dispute. | Column governing_law_jurisdiction (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestrictions rdf:type rdf:Property ;
    rdfs:label 'Holdback Restrictions' ;
    rdfs:comment 'Restrictions on when or where content may be made available on other platforms or windows. Protects the distribution partners investment by limiting competing distribution during the agreement term. | Column holdback_restrictions (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the carriage agreement. | Column last_amendment_date (DATE) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Guarantee' ;
    rdfs:comment 'Minimum number of subscribers the distribution partner guarantees to deliver for the channel. Used in per-subscriber fee calculations and performance commitments. | Column minimum_subscriber_guarantee (INT) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mustCarryElection rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election' ;
    rdfs:comment 'Indicates whether the broadcaster has elected must-carry status under FCC rules, requiring the MVPD to carry the signal without negotiation. Applicable to qualified broadcast stations. | Column must_carry_election (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationHistory rdf:type rdf:Property ;
    rdfs:label 'Negotiation History' ;
    rdfs:comment 'Summary of key negotiation milestones, amendments, and material changes to the agreement over its lifecycle. Provides context for current terms and future renegotiations. | Column negotiation_history (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCommitment rdf:type rdf:Property ;
    rdfs:label 'Promotional Commitment' ;
    rdfs:comment 'Marketing and promotional obligations agreed by either party, such as on-air promotion, co-marketing campaigns, EPG placement guarantees, or cross-platform promotion. | Column promotional_commitment (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and terms governing agreement renewal, including renewal period length, rate adjustments, renegotiation triggers, and notice requirements. | Column renewal_terms (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentGranted rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Granted' ;
    rdfs:comment 'Indicates whether retransmission consent has been granted under FCC regulations, authorizing the MVPD to rebroadcast over-the-air signals. Applicable only to retransmission consent agreement types. | Column retransmission_consent_granted (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Performance commitments and service quality standards, including uptime guarantees, signal quality metrics, fault resolution times, and penalties for non-compliance. | Column service_level_agreement (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDeliveryRequirements rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Requirements' ;
    rdfs:comment 'Technical specifications for content delivery, including signal format (HD, 4K, HDR), encoding standards (MPEG-2, MPEG-4, HEVC), delivery method (satellite, fiber, IP), and quality parameters (bitrate, resolution, audio channels). | Column technical_delivery_requirements (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement. Protects both parties from abrupt service disruption. | Column termination_notice_days (INT) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCarriageFeeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Distribution Carriage Fee Invoice Id' ;
    rdfs:comment 'Unique identifier for the carriage fee invoice record. Primary key for this transactional billing entity. | Column distribution_carriage_fee_invoice_id (BIGINT) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Carriage fee invoices create A/R entries when billed to distribution partners. Monthly A/R aging reports include outstanding carriage fee invoices for cash flow management and collections tracking in  | Column accounts_receivable_id (BIGINT) in finance.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:responsibleSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Responsible Sales Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Carriage fee invoices are tracked by responsible sales rep for commission calculation and dispute resolution. Essential for rep compensation on recurring carriage revenue, account health monitoring, a | Column responsible_sales_rep_id (BIGINT) in sales.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition_event. Business justification: Carriage fee invoices trigger revenue recognition events under ASC 606/IFRS 15. Monthly revenue recognition close ties invoices to recognition events for financial statement preparation and revenue as | Column revenue_recognition_event_id (BIGINT) in finance.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:subscriberCountReportId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Report Id' ;
    rdfs:comment 'Foreign key linking to distribution.subscriber_count_report. Business justification: Carriage fee invoices are based on subscriber count reports. Billing uses reported subscriber counts for fee calculation. Removes subscriber_count BIGINT (derivable from subscriber_count_report.report | Column subscriber_count_report_id (BIGINT) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriberCountReport .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Total adjustments applied to the base fee, including discounts, credits, penalties, or promotional adjustments. May be positive or negative. | Column adjustment_amount (DECIMAL(18,2)) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Fee Amount' ;
    rdfs:comment 'The base carriage fee amount before any adjustments, discounts, or taxes. Represents the core contractual fee for the billing period. | Column base_fee_amount (DECIMAL(18,2)) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The username or identifier of the user or system process that created this invoice record. Used for audit and accountability. | Column created_by_user (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the dispute was formally raised by the distribution partner. Null if the invoice has never been disputed. | Column dispute_date (DATE) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'The pricing model or calculation method used to determine the carriage fee amount. Defines whether the fee is per-subscriber, flat-rate, tiered by volume, revenue-share, or a hybrid structure. | Column fee_basis (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:DistributionCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'The GL account code to which this carriage fee invoice is posted in the financial system. Used for financial reporting and revenue recognition. | Column general_ledger_account_code (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the carriage fee invoice. Tracks progression from draft through issuance, acknowledgment, payment, and potential dispute or cancellation. [ENUM-REF-CANDIDATE: draft|issued|sent|acknowledged|paid|partially_paid|overdue|disputed|cancelled|void — 10 candidates stripped; promote to reference product] | Column invoice_status (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'The date on which payment was received and applied to this invoice. Null if the invoice has not been paid. | Column payment_received_date (DATE) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number or transaction identifier provided by the payer or payment processor. Used for payment reconciliation and traceability. | Column payment_reference_number (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the invoice was successfully reconciled against subscriber data, payments, and contractual obligations. Null if reconciliation is pending or failed. | Column reconciliation_date (DATE) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the revenue assurance reconciliation process for this invoice. Indicates whether the invoice has been matched to subscriber reports, payments, and contractual terms. | Column reconciliation_status (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The final total amount due on the invoice, calculated as base fee plus adjustments plus taxes. This is the amount the distribution partner must pay. | Column total_amount (DECIMAL(18,2)) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The username or identifier of the user or system process that last modified this invoice record. Used for audit and accountability. | Column updated_by_user (STRING) in distribution.distribution_carriage_fee_invoice' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Unique identifier for the delivery channel. Primary key. | Column delivery_channel_id (BIGINT) in distribution.delivery_channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryChannel .

ind:adInsertionMethod rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Method' ;
    rdfs:comment 'Technical method used for inserting advertisements into the content stream: server-side stitching, client-side insertion, DAI (Dynamic Ad Insertion), SCTE-35 marker-based, or none for ad-free channels. | Column ad_insertion_method (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Enabled' ;
    rdfs:comment 'Indicates whether geographic or rights-based blackout restrictions are enforced for this channel (true) or not (false). | Column blackout_rules_enabled (BOOLEAN) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'The official brand name of the delivery channel as presented to audiences (e.g., \'HBO Max\', \'NBC Sports\', \'Pluto TV Comedy\'). | Column channel_name (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Logical channel number or position in the Electronic Program Guide (EPG) lineup (e.g., \'7.1\', \'502\', \'virtual 12\'). | Column channel_number (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRefreshCadence rdf:type rdf:Property ;
    rdfs:label 'Content Refresh Cadence' ;
    rdfs:comment 'Frequency at which the channel programming lineup or content library is updated with new material. | Column content_refresh_cadence (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTechnology rdf:type rdf:Property ;
    rdfs:label 'Delivery Technology' ;
    rdfs:comment 'The technical transmission standard used for content delivery. DVB (Digital Video Broadcasting) variants for European broadcast, ATSC (Advanced Television Systems Committee) for North American broadcast, QAM (Quadrature Amplitude Modulation) for cable, HLS (HTTP Live Streaming) and MPEG-DASH for adaptive bitrate streaming. [ENUM-REF-CANDIDATE: dvb-t|dvb-s|dvb-c|atsc|qam|hls|mpeg-dash|smooth-streaming|rtmp|webrtc — 10 candidates stripped; promote to reference product] | Column delivery_technology (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgSourceCode rdf:type rdf:Property ;
    rdfs:label 'Epg Source Code' ;
    rdfs:comment 'External identifier linking this channel to its Electronic Program Guide (EPG) metadata feed provider (e.g., Gracenote, Tribune Media Services). | Column epg_source_code (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastAggregatorPlatform rdf:type rdf:Property ;
    rdfs:label 'Fast Aggregator Platform' ;
    rdfs:comment 'Name of the FAST platform aggregator hosting the channel (e.g., \'Pluto TV\', \'Tubi\', \'Samsung TV Plus\', \'Roku Channel\', \'Xumo\'). Applicable only to FAST channel types. | Column fast_aggregator_platform (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastPlaylistType rdf:type rdf:Property ;
    rdfs:label 'Fast Playlist Type' ;
    rdfs:comment 'Content scheduling model for FAST channels: linear-loop (repeating content block), scheduled (traditional time-based EPG), dynamic (algorithm-driven), or hybrid. Applicable only to FAST channel types. | Column fast_playlist_type (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreCategory rdf:type rdf:Property ;
    rdfs:label 'Genre Category' ;
    rdfs:comment 'Primary content genre or programming category of the channel. [ENUM-REF-CANDIDATE: news|sports|entertainment|kids|lifestyle|documentary|music|movies|drama|comedy — 10 candidates stripped; promote to reference product] | Column genre_category (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Revenue model for the channel: AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), TVOD (Transactional Video On Demand), hybrid (multiple models), or free (no monetization). | Column monetization_model (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlRating rdf:type rdf:Property ;
    rdfs:label 'Parental Control Rating' ;
    rdfs:comment 'TV Parental Guidelines rating assigned to the channel for content filtering and parental control systems. | Column parental_control_rating (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionFormat rdf:type rdf:Property ;
    rdfs:label 'Resolution Format' ;
    rdfs:comment 'Video resolution tier supported by the channel: SD (standard definition 480p), HD (720p), Full HD (1080p), 4K UHD (2160p), 8K UHD (4320p). | Column resolution_format (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Secondary Language' ;
    rdfs:comment 'ISO 639-3 three-letter code for the secondary audio track or subtitle language, if available (e.g., SAP - Secondary Audio Program). | Column secondary_language (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Contractual uptime guarantee for the channel expressed as a percentage (e.g., 99.95 for \'four nines\' availability). | Column sla_uptime_percent (DECIMAL(5,2)) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamingEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Url' ;
    rdfs:comment 'Primary streaming endpoint URL or manifest URL for OTT and FAST channels. Confidential operational data. | Column streaming_endpoint_url (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic market for the channel (e.g., \'USA\', \'GBR\', \'CAN\'). | Column target_market (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Airplay Enabled' ;
    rdfs:comment 'Flag indicating whether Apple AirPlay streaming to external devices is permitted. | Column airplay_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedCountries rdf:type rdf:Property ;
    rdfs:label 'Allowed Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is permitted. | Column allowed_countries (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogOutputControl rdf:type rdf:Property ;
    rdfs:label 'Analog Output Control' ;
    rdfs:comment 'Policy governing analog video output (allowed, restricted with downscaling, or completely blocked). | Column analog_output_control (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analogSunsetEnabled rdf:type rdf:Property ;
    rdfs:label 'Analog Sunset Enabled' ;
    rdfs:comment 'Flag indicating whether analog output is progressively restricted or disabled (analog sunset policy). | Column analog_sunset_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedCountries rdf:type rdf:Property ;
    rdfs:label 'Blocked Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content playback is explicitly blocked. | Column blocked_countries (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromecastEnabled rdf:type rdf:Property ;
    rdfs:label 'Chromecast Enabled' ;
    rdfs:comment 'Flag indicating whether Google Chromecast streaming to external devices is permitted. | Column chromecast_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'The maximum number of simultaneous streams allowed per user account or license. | Column concurrent_stream_limit (INT) in distribution.drm_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentKeyReference rdf:type rdf:Property ;
    rdfs:label 'Content Key Reference' ;
    rdfs:comment 'The unique identifier for the encryption key used to protect the content. | Column content_key_reference (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceBindingEnabled rdf:type rdf:Property ;
    rdfs:label 'Device Binding Enabled' ;
    rdfs:comment 'Flag indicating whether licenses are bound to specific devices to prevent unauthorized sharing. | Column device_binding_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmVendor rdf:type rdf:Property ;
    rdfs:label 'Drm Vendor' ;
    rdfs:comment 'The vendor or provider of the DRM solution (e.g., Google, Microsoft, Apple, Adobe). | Column drm_vendor (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionScheme rdf:type rdf:Property ;
    rdfs:label 'Encryption Scheme' ;
    rdfs:comment 'The encryption scheme used for content protection (CENC, CBC1, CENS, CBCS) as defined by Common Encryption standards. | Column encryption_scheme (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Enabled' ;
    rdfs:comment 'Flag indicating whether geographic restrictions are enforced for content delivery based on viewer location. | Column geo_restriction_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdcpLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Hdcp Level Required' ;
    rdfs:comment 'The minimum HDCP version required for output protection to prevent unauthorized digital copying. [ENUM-REF-CANDIDATE: none|hdcp_1_0|hdcp_1_1|hdcp_1_2|hdcp_1_3|hdcp_1_4|hdcp_2_0|hdcp_2_1|hdcp_2_2|hdcp_2_3 — 10 candidates stripped; promote to reference product] | Column hdcp_level_required (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRotationIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Key Rotation Interval Hours' ;
    rdfs:comment 'The frequency in hours at which encryption keys are rotated for enhanced security. | Column key_rotation_interval_hours (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'License Duration Seconds' ;
    rdfs:comment 'The validity period in seconds for a DRM license before it must be renewed. | Column license_duration_seconds (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseServerEndpoint rdf:type rdf:Property ;
    rdfs:label 'License Server Endpoint' ;
    rdfs:comment 'The URL endpoint of the DRM license server that issues decryption keys to authorized clients. | Column license_server_endpoint (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDeviceRegistrations rdf:type rdf:Property ;
    rdfs:label 'Max Device Registrations' ;
    rdfs:comment 'The maximum number of devices that can be registered for content playback per user account. | Column max_device_registrations (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlineLicenseDurationHours rdf:type rdf:Property ;
    rdfs:label 'Offline License Duration Hours' ;
    rdfs:comment 'The maximum duration in hours that offline downloaded content remains playable before license expiration. | Column offline_license_duration_hours (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offlinePlaybackWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Window Hours' ;
    rdfs:comment 'The time window in hours during which offline content must be played once playback begins. | Column offline_playback_window_hours (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:persistentLicenseEnabled rdf:type rdf:Property ;
    rdfs:label 'Persistent License Enabled' ;
    rdfs:comment 'Flag indicating whether licenses can be stored persistently on the device for offline or repeated playback. | Column persistent_license_enabled (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playbackDurationHours rdf:type rdf:Property ;
    rdfs:label 'Playback Duration Hours' ;
    rdfs:comment 'The time window in hours during which content must be consumed once playback begins for rental content. | Column playback_duration_hours (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business code or identifier for the DRM policy used across systems and platforms. | Column policy_code (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the DRM policy for identification and reference purposes. | Column policy_name (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyPriority rdf:type rdf:Property ;
    rdfs:label 'Policy Priority' ;
    rdfs:comment 'The priority ranking of this policy when multiple policies could apply. Lower numbers indicate higher priority. | Column policy_priority (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentalDurationHours rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Hours' ;
    rdfs:comment 'The total rental period in hours during which content is accessible for Transactional Video On Demand (TVOD) rentals. | Column rental_duration_hours (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenCaptureBlocked rdf:type rdf:Property ;
    rdfs:label 'Screen Capture Blocked' ;
    rdfs:comment 'Flag indicating whether screen capture and recording are blocked during content playback. | Column screen_capture_blocked (BOOLEAN) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'The security level required for DRM implementation (software or hardware-based cryptography and decoding). | Column security_level (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpirySeconds rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Seconds' ;
    rdfs:comment 'The expiration time in seconds for authentication tokens used in DRM license acquisition. | Column token_expiry_seconds (INT) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:widevineSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Widevine Security Level' ;
    rdfs:comment 'The Widevine-specific security level (L1 hardware-backed, L2 software-backed, L3 software only). | Column widevine_security_level (STRING) in distribution.drm_policy' ;
    rdfs:domain ind:DrmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Technology Broadcast Facility Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:cacheControlHeader rdf:type rdf:Property ;
    rdfs:label 'Cache Control Header' ;
    rdfs:comment 'HTTP Cache-Control header directives applied to CDN responses, controlling caching behavior at edge and client levels. | Column cache_control_header (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabled rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled' ;
    rdfs:comment 'Indicates whether content compression (gzip, brotli) is enabled at the CDN edge to reduce bandwidth consumption and improve delivery performance. | Column compression_enabled (BOOLEAN) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Failover Origin Url' ;
    rdfs:comment 'Secondary origin server URL used for redundancy and failover when the primary origin is unavailable. | Column failover_origin_url (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingCountries rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes subject to geo-blocking rules (allowed or denied based on mode). | Column geo_blocking_countries (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Enabled' ;
    rdfs:comment 'Indicates whether geographic content restrictions are enforced at the CDN edge based on viewer location. | Column geo_blocking_enabled (BOOLEAN) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoBlockingMode rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Mode' ;
    rdfs:comment 'Specifies whether the geo-blocking rules operate as an allow-list (whitelist) or deny-list (blacklist) of countries. | Column geo_blocking_mode (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:http2Enabled rdf:type rdf:Property ;
    rdfs:label 'Http2 Enabled' ;
    rdfs:comment 'Indicates whether HTTP/2 protocol is enabled for this CDN configuration to improve streaming performance through multiplexing and header compression. | Column http2_enabled (BOOLEAN) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originPullUrl rdf:type rdf:Property ;
    rdfs:label 'Origin Pull Url' ;
    rdfs:comment 'The origin server URL from which the CDN pulls content when not cached. Typically points to the media asset management system or playout server. | Column origin_pull_url (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prefetchEnabled rdf:type rdf:Property ;
    rdfs:label 'Prefetch Enabled' ;
    rdfs:comment 'Indicates whether content prefetching is enabled to proactively cache content at edge locations before viewer requests. | Column prefetch_enabled (BOOLEAN) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propertyHostname rdf:type rdf:Property ;
    rdfs:label 'Property Hostname' ;
    rdfs:comment 'The fully qualified domain name (FQDN) of the CDN property or edge hostname used for content delivery. | Column property_hostname (STRING) in distribution.cdn_configuration' ;
    rdfs:domain ind:CdnConfiguration ;
