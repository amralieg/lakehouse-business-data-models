ind:syndicationType rdf:type rdf:Property ;
    rdfs:label 'Syndication Type' ;
    rdfs:comment 'Classification of the syndication arrangement: first-run syndication (original content distributed directly to local stations), off-network syndication (previously aired network content), international syndication (cross-border distribution), digital syndication (online/streaming platforms), barter (ad inventory exchange), or cash-plus-barter (hybrid model). | Column syndication_type (STRING) in rights.rights_syndication_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
