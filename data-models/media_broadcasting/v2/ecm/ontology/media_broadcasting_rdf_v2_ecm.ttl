    rdfs:comment 'Status: pending, accruing, payable, paid, forfeited.' ;
    rdfs:domain ind:DeferredCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Tax jurisdiction governing deferral' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Tax treatment: 409a_compliant, non_qualified, foreign_jurisdiction.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Total amount due including principal and interest.' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Condition that triggers payment: release_date, box_office_threshold, streaming_launch.' ;
