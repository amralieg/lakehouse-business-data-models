    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'The market segment or customer category this sales team focuses on (e.g., local advertisers, national agencies, direct clients, programmatic buyers). | Column market_segment (STRING) in sales.sales_team' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFocus rdf:type rdf:Property ;
    rdfs:label 'Product Focus' ;
    rdfs:comment 'Primary product or content type this sales team specializes in selling (e.g., linear TV spots, streaming inventory, sports programming, news sponsorships). | Column product_focus (STRING) in sales.sales_team' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
