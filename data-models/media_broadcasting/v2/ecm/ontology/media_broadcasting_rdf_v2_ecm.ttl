    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocRace rdf:type rdf:Property ;
    rdfs:label 'Eeoc Race' ;
    rdfs:comment 'Self-reported race for EEOC applicant flow reporting. Collected for diversity and compliance tracking purposes. | Column eeoc_race (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest level of formal education completed by the applicant (e.g., high school, bachelor, master, doctorate). | Column highest_education_level (STRING) in workforce.applicant' ;
