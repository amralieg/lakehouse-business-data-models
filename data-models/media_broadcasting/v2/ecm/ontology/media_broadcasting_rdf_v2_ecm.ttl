ind:reportFilePath rdf:type rdf:Property ;
    rdfs:label 'Report File Path' ;
    rdfs:comment 'Storage location or file path reference for the audit report document in the document management system. | Column report_file_path (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date on which the formal audit report was issued to management or regulatory body. | Column report_issued_date (DATE) in compliance.audit' ;
    rdfs:domain ind:Audit ;
