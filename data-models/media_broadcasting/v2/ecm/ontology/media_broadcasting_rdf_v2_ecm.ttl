    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'The maximum monetary amount this employee is authorized to approve for transactions against this cost center. Null indicates unlimited approval authority or non-monetary authorization. | Column approval_limit_amount (DECIMAL(18,2)) in finance.cost_center_authorization' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
