    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Documented analysis of the underlying cause of the dispute, used for process improvement and future prevention. | Column root_cause_analysis (STRING) in partner.partner_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount Usd' ;
