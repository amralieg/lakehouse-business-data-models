    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact. Primary method for reaching emergency contact in case of workplace incident or employee emergency. | Column emergency_contact_phone (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the employee (e.g., spouse, parent, sibling, friend). Provides context for emergency communications. | Column emergency_contact_relationship (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
