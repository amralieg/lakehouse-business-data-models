    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoverySource rdf:type rdf:Property ;
    rdfs:label 'Discovery Source' ;
    rdfs:comment 'The source or method by which the compliance incident was discovered (e.g., internal audit, regulator inspection, viewer complaint, self-disclosure, automated monitoring). [ENUM-REF-CANDIDATE: internal_audit|external_audit|regulator_inspection|viewer_complaint|self_disclosure|automated_monitoring|third_party_report — 7 candidates stripped; promote to reference product] | Column discovery_source (STRING) in compliance.incident' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
