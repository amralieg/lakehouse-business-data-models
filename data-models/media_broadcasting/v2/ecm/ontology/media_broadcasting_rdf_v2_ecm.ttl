    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityResponsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Facility Responsible Person' ;
    rdfs:comment 'Name or identifier of the person at this facility responsible for ensuring compliance with this specific obligation (may differ from the corporate responsible_team). | Column facility_responsible_person (STRING) in compliance.facility_compliance_obligation' ;
    rdfs:domain ind:FacilityComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityComplianceId rdf:type rdf:Property ;
