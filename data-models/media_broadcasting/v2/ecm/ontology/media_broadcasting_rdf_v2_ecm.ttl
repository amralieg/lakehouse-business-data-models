    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'The precise date and time when the reconciliation was formally signed off, providing audit trail for SOX compliance. | Column sign_off_timestamp (TIMESTAMP) in finance.financial_reconciliation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subledgerBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Subledger Balance Amount' ;
    rdfs:comment 'The balance amount recorded in the subledger system (AR, AP, fixed assets, or revenue system) as of the reconciliation date, to be compared against the GL balance. | Column subledger_balance_amount (DECIMAL(18,2)) in finance.financial_reconciliation' ;
    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityLegalAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Facility Legal Assignment Id' ;
    rdfs:comment 'Unique identifier for this facility-legal entity assignment record. Primary key. | Column facility_legal_assignment_id (BIGINT) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'Percentage of facility operating costs allocated to this legal entity. Used for intercompany charging and cost center allocation. Sum of percentages across all legal entities for a facility should equal 100.00 for shared facilities. | Column cost_allocation_percentage (DECIMAL(5,2)) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyChargeCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Charge Code' ;
    rdfs:comment 'Code used for intercompany billing and cost allocation transactions related to this facility assignment. Links to the chart of accounts for proper financial posting. | Column intercompany_charge_code (STRING) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseOrOwnFlag rdf:type rdf:Property ;
    rdfs:label 'Lease Or Own Flag' ;
    rdfs:comment 'Boolean indicator of whether the facility is leased (true) or owned (false) by this legal entity. Simplified binary view of ownership_type for financial reporting. | Column lease_or_own_flag (BOOLEAN) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryUserFlag rdf:type rdf:Property ;
    rdfs:label 'Primary User Flag' ;
    rdfs:comment 'Indicates whether this legal entity is the primary operational user of the facility. Used to designate the primary responsible entity for regulatory reporting and operational management when multiple entities share a facility. | Column primary_user_flag (BOOLEAN) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Entity Flag' ;
    rdfs:comment 'Indicates whether this legal entity is responsible for tax reporting obligations related to this facility (property tax, local business tax, etc.). Critical for multi-entity shared facilities. | Column tax_reporting_entity_flag (BOOLEAN) in finance.facility_legal_assignment' ;
    rdfs:domain ind:FacilityLegalAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Project Assignment Id' ;
    rdfs:comment 'Unique identifier for the project assignment record. Primary key. | Column project_assignment_id (BIGINT) in finance.project_assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProjectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Project Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee | Column project_manager_employee_id (BIGINT) in workforce.project_assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Approved By Employee Id' ;
    rdfs:comment 'Employee who approved the assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Employee Id' ;
    rdfs:comment 'Foreign key linking to the employee assigned to the capital project. | Column employee_id (BIGINT) in workforce.project_assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Actual hours worked on assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercent rdf:type rdf:Property ;
    rdfs:label 'Allocation Percent' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether the employee\'s time on this project is billable to the project budget or capitalized as part of project costs. Used for cost accounting and capitalization calculations. Explicitly identified in detection reasoning. | Column billable_flag (BOOLEAN) in finance.project_assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'Total budgeted cost' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Hours' ;
    rdfs:comment 'Budgeted hours for the assignment' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Hourly billing rate for assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'Currency for hourly rate' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The specific role or function the employee performs on this capital project. Examples include Project Manager, Technical Lead, Finance Controller, Procurement Specialist. Explicitly identified in detection reasoning. | Column role (STRING) in finance.project_assignment' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'Variance between budgeted and actual hours' ;
    rdfs:domain ind:ProjectAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationGlMappingId rdf:type rdf:Property ;
    rdfs:label 'Obligation Gl Mapping Id' ;
    rdfs:comment 'Unique identifier for this obligation-to-GL-account mapping record. Primary key. | Column obligation_gl_mapping_id (BIGINT) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualRequired rdf:type rdf:Property ;
    rdfs:label 'Accrual Required' ;
    rdfs:comment 'Indicates whether costs for this obligation must be accrued in this GL account prior to cash payment. True for obligations with annual fees that must be accrued monthly, regulatory penalties under dispute, or multi-year license fees. Corresponds to accrual_required_flag from detection data. | Column accrual_required (BOOLEAN) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAllocationRule rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Rule' ;
    rdfs:comment 'Business rule describing how costs for this obligation should be allocated to this GL account. May reference allocation keys, cost centers, profit centers, or percentage splits (e.g., \'Allocate 60% to linear TV cost center, 40% to OTT\', \'Direct charge to broadcast operations functional area\'). Corresponds to cost_allocation_rule from detection data. | Column cost_allocation_rule (STRING) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Amount' ;
    rdfs:comment 'Estimated annual financial impact of this obligation in this GL account, in the account\'s currency. Used for budgeting, forecasting, and materiality assessments. May be null for event-driven obligations with unpredictable costs. | Column estimated_annual_amount (DECIMAL(18,2)) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current status of this mapping: active (currently in use for financial postings), inactive (no longer used but retained for historical reference), pending_approval (proposed mapping awaiting finance/compliance approval), superseded (replaced by a newer mapping). | Column mapping_status (STRING) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingType rdf:type rdf:Property ;
    rdfs:label 'Mapping Type' ;
    rdfs:comment 'Classification of how this obligation maps to this GL account: license_fee (broadcast spectrum fees), compliance_expense (ongoing compliance costs), capital_expenditure (EAS equipment, closed captioning infrastructure), prepaid_regulatory (prepaid license fees), accrued_penalty (potential fines), legal_reserve (litigation reserves), equipment_maintenance (regulatory equipment upkeep), consulting_fee (compliance consultants), audit_cost (regulatory audits), other. Corresponds to obligation_gl_mapping_type from detection data. | Column mapping_type (STRING) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLineItem rdf:type rdf:Property ;
    rdfs:label 'Reporting Line Item' ;
    rdfs:comment 'The financial statement line item or regulatory report line where this obligation-account combination should be reported. Used for external regulatory financial reporting (e.g., FCC Form 323, Ofcom Annual Return) and internal management reporting. Corresponds to reporting_line_item from detection data. | Column reporting_line_item (STRING) in finance.obligation_gl_mapping' ;
    rdfs:domain ind:ObligationGlMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterObligationAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Obligation Allocation Id' ;
    rdfs:comment 'Unique identifier for this cost center obligation allocation record. Primary key. | Column cost_center_obligation_allocation_id (BIGINT) in finance.cost_center_obligation_allocation' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costApprovedByEmployeeId rdf:type rdf:Property ;
