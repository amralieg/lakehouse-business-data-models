    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Approval status indicating whether the reconciliation has been formally signed off by the reviewer as part of period-end close procedures. | Column sign_off_status (STRING) in finance.financial_reconciliation' ;
