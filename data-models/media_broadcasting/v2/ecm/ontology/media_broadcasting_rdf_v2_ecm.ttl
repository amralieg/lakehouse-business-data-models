    rdfs:range xsd:integer .

ind:auditedInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Audited Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Partner audits (royalty audits, subscriber count verification audits, revenue share audits) examine specific invoices for accuracy. Linking audit events to invoices enables audit trail documentation,  | Column audited_invoice_id (BIGINT) in billing.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:disputedContentTitleId rdf:type rdf:Property ;
    rdfs:label 'Disputed Content Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Audits often dispute specific title performance data, revenue allocation, or delivery compliance. Audit finding resolution, adjustment calculation, evidence documentation, and settlement negotiation r | Column disputed_content_title_id (BIGINT) in content.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:internalCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Partner audits require internal coordinator tracking for liaison with external auditors, document gathering, response management, and follow-up. Essential for audit workload planning, response time tr | Column internal_coordinator_employee_id (BIGINT) in workforce.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partnerRightsAuditEventId rdf:type rdf:Property ;
    rdfs:label 'Partner Rights Audit Event Id' ;
    rdfs:comment 'Foreign key to SSOT rights.rights_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsAuditEvent .

ind:partnerRightsRightsAuditEventId rdf:type rdf:Property ;
    rdfs:label 'Partner Rights Rights Audit Event Id' ;
    rdfs:comment 'FK to SSOT rights.rights_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsAuditEvent .

ind:adjustmentAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the adjustment amount (e.g., USD, GBP, EUR). | Column adjustment_amount_currency (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCost rdf:type rdf:Property ;
    rdfs:label 'Audit Cost' ;
    rdfs:comment 'The total cost incurred for conducting the audit, including audit firm fees, internal resource costs, travel expenses, and other related costs. Used for cost recovery and budget tracking. | Column audit_cost (DECIMAL(18,2)) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost (e.g., USD, GBP, EUR). | Column audit_cost_currency (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Summary' ;
    rdfs:comment 'High-level summary of the audit findings, including key discrepancies, compliance issues, or areas of concern identified during the audit. | Column audit_finding_summary (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the external audit firm or internal audit team conducting the audit. May be a third-party accounting firm, specialized media audit firm, or internal audit department. | Column audit_firm_name (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Initiated Date' ;
    rdfs:comment 'The date on which the audit was formally initiated, typically when the audit notice was sent to the partner or when the audit firm was engaged. | Column audit_initiated_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit event. Planned audits are scheduled but not started; in-progress audits are actively being conducted; fieldwork complete indicates data collection is done; draft report indicates preliminary findings are documented; final report indicates audit is complete; disputed indicates findings are contested; resolved indicates disputes are settled; closed indicates all actions are complete. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|draft_report|final_report|disputed|resolved|closed — 8 candidates stripped; promote to reference product] | Column audit_status (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrigger rdf:type rdf:Property ;
    rdfs:label 'Audit Trigger' ;
    rdfs:comment 'The event or condition that initiated the audit. Scheduled audits are routine contractual audits; threshold breach audits are triggered by variance thresholds; dispute audits arise from disagreements; regulatory audits are mandated by authorities; random audits are part of compliance sampling; partner request audits are initiated by the partner. | Column audit_trigger (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions required or agreed upon, including process changes, system enhancements, training, or compliance measures. | Column corrective_action_description (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The deadline by which the partner must complete the required corrective actions. Used for tracking compliance with audit remediation requirements. | Column corrective_action_due_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective actions are required from the partner as a result of the audit findings. True if process improvements, system changes, or compliance remediation is mandated. | Column corrective_action_required (BOOLEAN) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRecoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Recovery Status' ;
    rdfs:comment 'Status of recovering audit costs from the partner when contractually permitted. Not applicable if costs are not recoverable; pending if recovery not yet initiated; invoiced if bill sent; partially recovered if some payment received; fully recovered if all costs reimbursed; waived if costs forgiven. | Column cost_recovery_status (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmountCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disputed amount (e.g., USD, GBP, EUR). | Column disputed_amount_currency (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftReportDate rdf:type rdf:Property ;
    rdfs:label 'Draft Report Date' ;
    rdfs:comment 'The date on which the draft audit report was issued to the partner for review and response before finalization. | Column draft_report_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date on which the audit fieldwork was completed, when auditors finished their on-site or remote examination activities. | Column fieldwork_end_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date on which the audit fieldwork began, when auditors started examining records, conducting interviews, and gathering evidence. | Column fieldwork_start_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalReportDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Date' ;
    rdfs:comment 'The date on which the final audit report was issued, incorporating partner responses and auditor conclusions. | Column final_report_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Classification of the severity and nature of audit findings. No findings indicates clean audit; minor discrepancy indicates immaterial variances; material discrepancy indicates significant financial impact; compliance breach indicates contractual violations; fraud suspected indicates potential intentional misrepresentation; process weakness indicates control deficiencies. | Column finding_category (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'The scheduled or actual date of the follow-up audit to verify corrective action implementation and compliance. | Column follow_up_audit_date (DATE) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions or to re-examine areas of concern. True if subsequent audit is mandated. | Column follow_up_audit_required (BOOLEAN) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and overseeing the audit engagement. | Column lead_auditor_name (STRING) in partner.partner_audit_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Partner Response Date' ;
