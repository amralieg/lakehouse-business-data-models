    rdfs:range xsd:decimal .

ind:requiredCodec rdf:type rdf:Property ;
    rdfs:label 'Required Codec' ;
    rdfs:comment 'Video and audio codec specifications required for the delivery, such as H.264, H.265, AAC, or Dolby Digital. | Column required_codec (STRING) in partner.delivery_obligation' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredFormat rdf:type rdf:Property ;
    rdfs:label 'Required Format' ;
    rdfs:comment 'Technical delivery format required by the partner, such as HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), or mezzanine file format. | Column required_format (STRING) in partner.delivery_obligation' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredResolution rdf:type rdf:Property ;
    rdfs:label 'Required Resolution' ;
    rdfs:comment 'Video resolution specification required for delivery, ranging from standard definition to ultra-high definition. | Column required_resolution (STRING) in partner.delivery_obligation' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance' ;
    rdfs:comment 'Indicates whether the delivery was completed within the service level agreement timeframe specified in the partner contract. | Column sla_compliance (BOOLEAN) in partner.delivery_obligation' ;
    rdfs:domain ind:DeliveryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalStandard rdf:type rdf:Property ;
    rdfs:label 'Technical Standard' ;
    rdfs:comment 'Broadcasting or streaming technical standard that the delivery must comply with, such as ATSC (Advanced Television Systems Committee) or DVB (Digital Video Broadcasting). | Column technical_standard (STRING) in partner.delivery_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the carriage fee schedule. Primary key for this entity. | Column carriage_fee_schedule_id (BIGINT) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseFeePerSubscriber rdf:type rdf:Property ;
    rdfs:label 'Base Fee Per Subscriber' ;
    rdfs:comment 'The baseline carriage fee amount charged per subscriber per month. This is the foundational rate before any escalations, discounts, or adjustments are applied. | Column base_fee_per_subscriber (DECIMAL(15,4)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'Frequency at which fee escalations are applied. Defines how often the base fee is adjusted according to the escalation type and rate. | Column escalation_frequency (STRING) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Percentage' ;
    rdfs:comment 'Annual percentage rate by which the base fee per subscriber increases, if escalation type is fixed percentage. Expressed as a percentage (e.g., 3.00 for 3% annual increase). | Column escalation_rate_percentage (DECIMAL(5,2)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Method by which carriage fees increase over time. Options include no escalation, fixed annual percentage increase, Consumer Price Index (CPI) indexing, negotiated increases at specified intervals, or tiered increases based on subscriber growth. | Column escalation_type (STRING) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee structure. Indicates whether fees are charged per subscriber, as a flat monthly rate, in tiers based on subscriber count, volume-based with discounts, a hybrid model, or as a percentage of revenue share. | Column fee_type (STRING) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied as a penalty for late payment of carriage fees beyond the payment terms. Expressed as an annual percentage rate or per-period rate. | Column late_payment_penalty_rate (DECIMAL(5,2)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumFeeCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Cap' ;
    rdfs:comment 'The maximum total carriage fee amount per billing period, regardless of subscriber count. Protects the distributor from excessive fees in high-subscriber scenarios. | Column maximum_fee_cap (DECIMAL(15,2)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mfnProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Mfn Provision Flag' ;
    rdfs:comment 'Boolean indicator of whether this schedule includes a Most-Favored-Nation clause. If true, the distributor is entitled to the most favorable carriage fee terms that Media Broadcasting offers to any comparable distributor. | Column mfn_provision_flag (BOOLEAN) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfnScope rdf:type rdf:Property ;
    rdfs:label 'Mfn Scope' ;
    rdfs:comment 'Defines the scope and conditions under which the MFN provision applies, including comparable distributor criteria, geographic limitations, and exclusions. | Column mfn_scope (STRING) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedFee rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Fee' ;
    rdfs:comment 'The minimum total carriage fee amount guaranteed per billing period, regardless of subscriber count. Protects Media Broadcasting revenue in low-subscriber scenarios. | Column minimum_guaranteed_fee (DECIMAL(15,2)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberCountSource rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Source' ;
    rdfs:comment 'Source of subscriber count data used to calculate carriage fees. Options include distributor self-reporting, third-party audit, Nielsen measurement, or Media Broadcasting internal estimates. | Column subscriber_count_source (STRING) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeDiscountTier1Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 1 threshold. | Column volume_discount_tier_1_rate (DECIMAL(15,4)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the first volume discount tier is triggered. Distributors exceeding this subscriber count qualify for a reduced per-subscriber fee. | Column volume_discount_tier_1_threshold (BIGINT) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier2Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 2 threshold. | Column volume_discount_tier_2_rate (DECIMAL(15,4)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the second volume discount tier is triggered, offering further per-subscriber fee reduction. | Column volume_discount_tier_2_threshold (BIGINT) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier3Rate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Rate' ;
    rdfs:comment 'Discounted per-subscriber fee rate applicable when subscriber count exceeds the Tier 3 threshold. | Column volume_discount_tier_3_rate (DECIMAL(15,4)) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Threshold' ;
    rdfs:comment 'Subscriber count threshold at which the third volume discount tier is triggered, offering the deepest per-subscriber fee reduction. | Column volume_discount_tier_3_threshold (BIGINT) in partner.carriage_fee_schedule' ;
    rdfs:domain ind:CarriageFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerAgreementId rdf:type rdf:Property ;
    rdfs:label 'Partner Agreement Id' ;
    rdfs:comment 'Reference to the parent partner agreement under which this performance obligation is defined. | Column partner_agreement_id (BIGINT) in partner.performance_obligation' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerAgreement .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'The cumulative number of times this performance obligation has been breached since the effective start date or last reset. | Column breach_count (INT) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cureDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cure Deadline Date' ;
    rdfs:comment 'The calculated deadline by which the partner must cure the most recent breach to avoid penalties. Null if no active breach exists. | Column cure_deadline_date (DATE) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Cure Period Days' ;
    rdfs:comment 'The number of days allowed for the partner to remedy a breach before penalties or escalation actions are triggered, as defined in the agreement. | Column cure_period_days (INT) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMeasuredDate rdf:type rdf:Property ;
    rdfs:label 'Last Measured Date' ;
    rdfs:comment 'The date when the performance obligation was last evaluated for compliance. | Column last_measured_date (DATE) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Last Measured Value' ;
    rdfs:comment 'The actual measured value from the most recent compliance evaluation period. | Column last_measured_value (DECIMAL(18,4)) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Date' ;
    rdfs:comment 'The date when the partner was last notified regarding the compliance status or breach of this performance obligation. | Column last_notification_date (DATE) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodSpotsRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Spots Required' ;
    rdfs:comment 'The number of compensatory advertising spots or content deliveries required to remedy a breach, if makegood provision applies. | Column makegood_spots_required (INT) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'The time period over which the performance obligation is measured and evaluated for compliance. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_broadcast|per_delivery — 7 candidates stripped; promote to reference product] | Column measurement_period (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Monitoring System' ;
    rdfs:comment 'The name or identifier of the system or platform used to monitor and measure compliance with this performance obligation (e.g., Nielsen, Akamai CDN, internal monitoring tool). | Column monitoring_system (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the partner must be formally notified of compliance status or breach events for this obligation. | Column notification_required_flag (BOOLEAN) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the performance obligation, used for tracking and reporting purposes. | Column obligation_code (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the performance obligation, including specific terms, conditions, and expectations as stated in the partner agreement. | Column obligation_description (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name describing the performance obligation (e.g., \'Uptime Guarantee\', \'Content Delivery Timeliness\', \'Ratings Performance Threshold\'). | Column obligation_name (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when this performance obligation is breached, as specified in the partner agreement. | Column penalty_type (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetric rdf:type rdf:Property ;
    rdfs:label 'Sla Metric' ;
    rdfs:comment 'The specific metric being measured for this obligation (e.g., \'System Uptime Percentage\', \'Content Delivery Time\', \'Average Rating Points\', \'Subscriber Count\'). | Column sla_metric (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator used to evaluate compliance against the threshold value (e.g., greater than or equal to 99.9% uptime). | Column threshold_operator (STRING) in partner.performance_obligation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Id' ;
    rdfs:comment 'Unique identifier for the minimum guarantee commitment within a content acquisition deal. | Column minimum_guarantee_id (BIGINT) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Recoupment Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: MG recoupment tracking requires linking actual invoiced revenue (syndication fees, royalty statements) back to the guarantee for overage calculation, royalty true-ups, and partner financial reporting. | Column recoupment_invoice_id (BIGINT) in billing.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:accountingTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Accounting Treatment Code' ;
    rdfs:comment 'The financial accounting classification for the minimum guarantee: asset (capitalized content cost), expense (immediate P&L impact), deferred expense (amortized over time), prepaid (advance payment), or liability (obligation to provider). | Column accounting_treatment_code (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'The method used to amortize the minimum guarantee cost over its useful life: straight-line (equal periods), usage-based (viewership-driven), revenue-based (proportional to earnings), accelerated (front-loaded), or none (expensed immediately). | Column amortization_method (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'The date when the last scheduled minimum guarantee payment was made or is due. Relevant for installment or milestone-based payment structures. | Column final_payment_date (DATE) in partner.minimum_guarantee' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'The date when the initial minimum guarantee payment was made or is scheduled to be made to the content provider. | Column first_payment_date (DATE) in partner.minimum_guarantee' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullyRecoupedDate rdf:type rdf:Property ;
    rdfs:label 'Fully Recouped Date' ;
    rdfs:comment 'The date when the minimum guarantee was fully recouped and the outstanding balance reached zero. After this date, overage royalty terms apply to additional revenue. | Column fully_recouped_date (DATE) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCrossCollateralized rdf:type rdf:Property ;
    rdfs:label 'Is Cross Collateralized' ;
    rdfs:comment 'Indicates whether this minimum guarantee can be recouped from revenue generated by other content titles or deals with the same provider (true) or is isolated to this specific deal (false). | Column is_cross_collateralized (BOOLEAN) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecoupable rdf:type rdf:Property ;
    rdfs:label 'Is Recoupable' ;
    rdfs:comment 'Indicates whether the minimum guarantee can be recouped from revenue (true) or is a non-recoupable floor payment (false). Non-recoupable MGs are paid regardless of performance with no offset. | Column is_recoupable (BOOLEAN) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recoupment Calculation Date' ;
    rdfs:comment 'The date when the most recent recoupment calculation was performed, updating the recouped to date and outstanding balance amounts. | Column last_recoupment_calculation_date (DATE) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mgAmount rdf:type rdf:Property ;
    rdfs:label 'Mg Amount' ;
    rdfs:comment 'The floor payment amount owed to the content provider regardless of actual viewership or revenue performance. This is the baseline financial commitment. | Column mg_amount (DECIMAL(18,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mgNumber rdf:type rdf:Property ;
    rdfs:label 'Mg Number' ;
    rdfs:comment 'Business identifier for the minimum guarantee commitment, used in contracts and financial reconciliation. | Column mg_number (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgStatus rdf:type rdf:Property ;
    rdfs:label 'Mg Status' ;
    rdfs:comment 'Current lifecycle state of the minimum guarantee: draft (under negotiation), active (in effect), partially recouped (some revenue applied), fully recouped (MG threshold met), overage (revenue exceeds MG), expired (term ended), or terminated (contract cancelled). [ENUM-REF-CANDIDATE: draft|active|partially_recouped|fully_recouped|overage|expired|terminated — 7 candidates stripped; promote to reference product] | Column mg_status (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mgType rdf:type rdf:Property ;
    rdfs:label 'Mg Type' ;
    rdfs:comment 'Classification of the minimum guarantee structure: flat (single fixed payment), tiered (stepped payments based on milestones), performance-based (adjusted by viewership), hybrid (combination), recoupable (can be offset by revenue share), or non-recoupable (floor payment regardless of performance). | Column mg_type (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecoupmentCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recoupment Calculation Date' ;
    rdfs:comment 'The scheduled date for the next recoupment calculation cycle. Typically aligned with monthly, quarterly, or annual reporting periods. | Column next_recoupment_calculation_date (DATE) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Remaining minimum guarantee amount not yet recouped. Calculated as MG amount minus recouped to date amount. When zero, the MG is fully recouped. | Column outstanding_balance_amount (DECIMAL(18,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Amount' ;
    rdfs:comment 'Revenue earned beyond the minimum guarantee threshold. Once the MG is fully recouped, additional revenue share payments are calculated on this overage amount per the contract terms. | Column overage_amount (DECIMAL(18,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Overage Royalty Rate' ;
    rdfs:comment 'The percentage rate applied to overage revenue to calculate additional royalty payments owed to the content provider after the minimum guarantee is fully recouped. Typically ranges from 0.00 to 100.00 percent. | Column overage_royalty_rate (DECIMAL(5,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Detailed narrative of the payment schedule, milestones, and conditions governing the minimum guarantee disbursement. Includes specific dates, amounts, and triggering events. | Column payment_terms_description (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Recouped To Date Amount' ;
    rdfs:comment 'Cumulative revenue amount that has been applied against the minimum guarantee as of the current reporting period. Tracks progress toward full recoupment. | Column recouped_to_date_amount (DECIMAL(18,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentBasis rdf:type rdf:Property ;
    rdfs:label 'Recoupment Basis' ;
    rdfs:comment 'The revenue or performance metric against which the minimum guarantee is recouped: gross revenue (total), net revenue (after costs), advertising revenue (CPM/GRP-based), subscription revenue (SVOD/ARPU), combined revenue (multi-stream), or viewership metric (Nielsen ratings, reach). | Column recoupment_basis (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Recoupment Percentage' ;
    rdfs:comment 'The percentage of revenue (based on recoupment basis) that is applied toward recouping the minimum guarantee. Typically ranges from 0.00 to 100.00 percent. | Column recoupment_percentage (DECIMAL(5,2)) in partner.minimum_guarantee' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recoupment Period Months' ;
    rdfs:comment 'The duration in months over which the minimum guarantee can be recouped from revenue. Common periods are 12, 24, 36, or 60 months depending on content type and windowing strategy. | Column recoupment_period_months (INT) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoupmentWaterfallDescription rdf:type rdf:Property ;
    rdfs:label 'Recoupment Waterfall Description' ;
    rdfs:comment 'Detailed explanation of the revenue allocation sequence and priority order for recouping the minimum guarantee. Defines which revenue streams are applied first and how costs are deducted before recoupment. | Column recoupment_waterfall_description (STRING) in partner.minimum_guarantee' ;
    rdfs:domain ind:MinimumGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Unique identifier for the partner payment term record. Primary key. | Column payment_term_id (BIGINT) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Milestone Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Partner payment terms define milestone-based invoicing (delivery milestones, window activation, subscriber thresholds). Linking actual invoices to terms enables payment compliance tracking, late payme | Column milestone_invoice_id (BIGINT) in billing.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:paymentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Id' ;
    rdfs:comment 'Reference to a detailed payment schedule record that breaks down this term into multiple installments or recurring payments. | Column payment_schedule_id (BIGINT) in partner.payment_term' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentSchedule .

ind:invoiceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Required Flag' ;
    rdfs:comment 'Indicates whether the partner must submit an invoice before payment can be processed. True if invoice is required, False if payment is automatic or self-billed. | Column invoice_required_flag (BOOLEAN) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Late Payment Grace Period Days' ;
    rdfs:comment 'Number of days after the payment due date during which no late payment penalty is assessed, allowing the payer time to remit without financial consequence. | Column late_payment_grace_period_days (INT) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Required Flag' ;
    rdfs:comment 'Indicates whether internal approval is required before payment can be released. True if approval workflow must be completed, False if payment is automatic upon due date. | Column payment_approval_required_flag (BOOLEAN) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Bank Account Number' ;
    rdfs:comment 'Reference to the partner\'s bank account record where payment should be remitted. Used for wire transfer and ACH payments. | Column payment_bank_account_number (BIGINT) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMilestone rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone' ;
    rdfs:comment 'Business event or condition that triggers this payment obligation (e.g., \'Upon Delivery\', \'First Broadcast\', \'Quarterly Arrears\', \'Upon Execution\', \'Net 30 Days from Invoice\'). | Column payment_milestone (STRING) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRemittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Payment Remittance Email' ;
    rdfs:comment 'Email address to which payment remittance advice and confirmation should be sent. May differ from the partner\'s primary contact email. | Column payment_remittance_email (STRING) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Business identifier for this payment term, often used in invoicing and reconciliation. May follow partner-specific or internal numbering conventions. | Column term_number (STRING) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the payment term based on the nature of the financial obligation: acquisition fee (content licensing), carriage fee (distribution payment), syndication fee (content resale), co-production contribution (shared production cost), royalty (usage-based payment), or residual (talent reuse payment). | Column term_type (STRING) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction whose tax laws govern the withholding obligation (e.g., USA, GBR, CAN). | Column withholding_tax_jurisdiction (STRING) in partner.payment_term' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGrantId rdf:type rdf:Property ;
    rdfs:label 'Territory Grant Id' ;
    rdfs:comment 'Unique identifier for the territory grant record. Primary key. | Column territory_grant_id (BIGINT) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rights grants require legal reviewer tracking for clearance verification, compliance sign-off, and dispute resolution. Clearance_status exists but no FK to attorney who verified - critical for legal w | Column legal_reviewer_employee_id (BIGINT) in workforce.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:ObjectProperty ;
