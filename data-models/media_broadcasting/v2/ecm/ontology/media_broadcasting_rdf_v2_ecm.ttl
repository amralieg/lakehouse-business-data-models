    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for this entity. | Column benefit_enrollment_id (BIGINT) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Reference to the specific benefit plan in which the employee is enrolling. Links to the benefit plan master record. | Column benefit_plan_id (BIGINT) in workforce.benefit_enrollment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:supersededBenefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Benefit Enrollment Id' ;
    rdfs:comment 'Self-referencing FK on benefit_enrollment (superseded_benefit_enrollment_id) | Column superseded_benefit_enrollment_id (BIGINT) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitEnrollment .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'For FSA, HSA, or other contribution-based plans, the total annual amount the employee elected to contribute for the plan year. Expressed in USD. Nullable for non-contribution plans. | Column annual_election_amount (DECIMAL(15,2)) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The name of the insurance carrier or benefits provider administering this plan (e.g., Blue Cross Blue Shield, Aetna, Fidelity, Vanguard). Used for vendor management and claims coordination. | Column carrier_name (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Name' ;
    rdfs:comment 'The full legal name of the contingent (secondary) beneficiary who receives benefits if the primary beneficiary is deceased or unable to receive benefits. Nullable if no contingent beneficiary designated. | Column contingent_beneficiary_name (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentBeneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the contingent beneficiary to the employee. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other_relative|friend|estate|trust|other — 10 candidates stripped; promote to reference product] | Column contingent_beneficiary_relationship (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The level of coverage selected by the employee, determining who is covered under the benefit plan (employee only, employee plus spouse, employee plus children, full family, or employee plus domestic partner). | Column coverage_tier (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Frequency' ;
    rdfs:comment 'The frequency at which the employee contribution is deducted from payroll or paid by the employee. | Column employee_contribution_frequency (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Frequency' ;
    rdfs:comment 'The frequency at which the employer contribution is made toward the benefit plan. | Column employer_contribution_frequency (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Number' ;
    rdfs:comment 'A confirmation or transaction number provided by the benefits administration system or carrier when the enrollment is processed. Used for audit trail and employee inquiries. | Column enrollment_confirmation_number (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Human-readable business identifier for the benefit enrollment, typically used in HR systems and employee communications. Format: BEN-YYYYNNNN where YYYY is year and NNNN is sequence. | Column enrollment_number (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'The triggering event or process that allowed this enrollment to occur. New hire indicates initial employment enrollment; open enrollment indicates annual election period; qualifying life event (QLE) indicates mid-year change due to marriage, birth, etc.; plan change indicates employee-initiated modification; rehire indicates return to employment. | Column enrollment_source (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrollment. Pending indicates awaiting approval or effective date; active indicates currently in force; terminated indicates coverage has ended; suspended indicates temporary hold; cancelled indicates enrollment was voided before becoming active; waived indicates employee declined coverage. | Column enrollment_status (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required' ;
    rdfs:comment 'Boolean flag indicating whether the employee must provide medical evidence of insurability (health questionnaire, medical exam) to qualify for this coverage level. Typically required for supplemental life insurance above guaranteed issue amounts. | Column evidence_of_insurability_required (BOOLEAN) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'If evidence_of_insurability_required is true, this field tracks the status of the EOI submission and approval process. Not_required indicates no EOI needed; pending indicates awaiting carrier review; approved indicates coverage granted; denied indicates coverage declined; incomplete indicates additional information needed. | Column evidence_of_insurability_status (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The calendar or fiscal year for which this enrollment is effective. Used to track enrollments across annual benefit cycles and open enrollment periods. Format: YYYY. | Column plan_year (INT) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Name' ;
    rdfs:comment 'The full legal name of the primary beneficiary designated to receive benefits in the event of the employees death. Applicable primarily to life insurance and retirement plans. Nullable if no beneficiary designated. | Column primary_beneficiary_name (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBeneficiaryPercentage rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Percentage' ;
    rdfs:comment 'The percentage of benefits allocated to the primary beneficiary. Typically 100 for single beneficiary or split among multiple. Value range 0.00 to 100.00. | Column primary_beneficiary_percentage (DECIMAL(5,2)) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBeneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the primary beneficiary to the employee. Used for compliance and verification purposes. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other_relative|friend|estate|trust|other — 10 candidates stripped; promote to reference product] | Column primary_beneficiary_relationship (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'The date on which the qualifying life event occurred (e.g., marriage date, birth date, loss of coverage date). Nullable for non-QLE enrollments. Used to validate enrollment timing compliance. | Column qualifying_event_date (DATE) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'If enrollment_source is qualifying_life_event, this field specifies the type of life event that triggered the mid-year enrollment change. Nullable for non-QLE enrollments. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death_of_dependent|loss_of_coverage|employment_status_change|dependent_age_limit|other — 9 candidates stripped; promote to reference product] | Column qualifying_event_type (STRING) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tobaccoUserFlag rdf:type rdf:Property ;
    rdfs:label 'Tobacco User Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee declared tobacco use during enrollment. Used for premium rating and wellness program eligibility. Protected health information under HIPAA. | Column tobacco_user_flag (BOOLEAN) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'The total cost of the benefit plan per pay period, representing the sum of employee and employer contributions. Expressed in USD. Used for financial reporting and cost analysis. | Column total_premium_amount (DECIMAL(15,2)) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellnessProgramParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Wellness Program Participant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee is participating in employer-sponsored wellness programs that may affect premium rates or provide incentives. | Column wellness_program_participant_flag (BOOLEAN) in workforce.benefit_enrollment' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request. Primary key for the leave request transaction. | Column leave_request_id (BIGINT) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalLeaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Original Leave Request Id' ;
    rdfs:comment 'Self-referencing FK on leave_request (original_leave_request_id) | Column original_leave_request_id (BIGINT) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaveRequest .

ind:primaryLeaveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Employee Id' ;
    rdfs:comment 'Identifier of the employee submitting the leave request. Links to the employee master record in the workforce domain. | Column primary_leave_employee_id (BIGINT) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLeaveSubstituteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Substitute Employee Id' ;
    rdfs:comment 'Identifier of the employee designated to cover the absent employee\'s responsibilities during the leave period. Null if no formal substitute assigned. | Column tertiary_leave_substitute_employee_id (BIGINT) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDaysTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Days Taken' ;
    rdfs:comment 'Actual number of leave days taken, calculated from time and attendance records. Used for leave balance deduction and payroll processing. | Column actual_days_taken (DECIMAL(5,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual last date the employee was absent on approved leave. May differ from requested end date if employee returned early or extended leave. | Column actual_end_date (DATE) in workforce.leave_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualHoursTaken rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Taken' ;
    rdfs:comment 'Actual number of leave hours taken, calculated from time and attendance records. Used for hourly leave balance deduction and payroll processing. | Column actual_hours_taken (DECIMAL(6,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the employee when submitting the leave request, such as reason for leave or special circumstances. | Column comments (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized categorical reason for denial: staffing_shortage (inadequate coverage), blackout_period (restricted dates such as sweeps or upfront periods), insufficient_notice (did not meet advance notice policy), policy_violation (does not meet eligibility or usage rules), other (see denial_reason for details). | Column denial_reason_code (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Fmla Certification Date' ;
    rdfs:comment 'Date when FMLA medical certification was received and approved by HR. Null for non-FMLA leave or if certification not yet approved. | Column fmla_certification_date (DATE) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmlaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fmla Certification Status' ;
    rdfs:comment 'Status of required medical certification for FMLA leave: not_required (non-FMLA leave), pending (certification requested but not yet received), received (certification submitted by employee), approved (HR approved certification), insufficient (certification does not meet requirements). | Column fmla_certification_status (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Fmla Protected Flag' ;
    rdfs:comment 'Indicates whether this leave request is protected under the Family and Medical Leave Act. True if FMLA-eligible and certified. | Column fmla_protected_flag (BOOLEAN) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermittentLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Intermittent Leave Flag' ;
    rdfs:comment 'Indicates whether this is an intermittent leave request (multiple non-consecutive absences for the same condition) rather than a continuous block of leave. Common for FMLA medical treatment schedules. | Column intermittent_leave_flag (BOOLEAN) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'Employee\'s remaining leave balance in days or hours after this request was approved and taken. Used for leave accrual and entitlement tracking. | Column leave_balance_after (DECIMAL(6,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'Employee\'s available leave balance in days or hours before this request was approved and taken. Snapshot for audit and balance tracking. | Column leave_balance_before (DECIMAL(6,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Optional granular classification within the leave type, such as maternity vs paternity under parental leave, or continuous vs intermittent under FMLA. | Column leave_subtype (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave being requested: vacation (paid time off), sick (illness or medical appointments), FMLA (Family and Medical Leave Act protected leave), parental (maternity/paternity/adoption), bereavement (death of family member), jury_duty (civic duty), military (military service), unpaid (leave without pay). | Column leave_type (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the approving manager when reviewing the leave request, such as approval conditions or coverage arrangements. | Column manager_comments (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Leave Flag' ;
    rdfs:comment 'Indicates whether this leave is paid (employee receives regular compensation) or unpaid (no compensation during absence). Drives payroll deduction calculations. | Column paid_leave_flag (BOOLEAN) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Payroll period (YYYY-MM format) in which this leave was processed for compensation adjustments. Used to reconcile leave with payroll cycles. | Column payroll_period (STRING) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this leave request has been processed by payroll for deductions or adjustments. True once payroll cycle has incorporated the leave. | Column payroll_processed_flag (BOOLEAN) in workforce.leave_request' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reducedScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Reduced Schedule Flag' ;
    rdfs:comment 'Indicates whether this leave request involves a reduced work schedule (working fewer hours per day or days per week) rather than full-day absences. Common for FMLA return-to-work transitions. | Column reduced_schedule_flag (BOOLEAN) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'Last date of the requested leave period. Employee intends to return to work the following business day. | Column requested_end_date (DATE) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'First date of the requested leave period. Employee intends to be absent starting this date. | Column requested_start_date (DATE) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDaysRequested rdf:type rdf:Property ;
    rdfs:label 'Total Days Requested' ;
    rdfs:comment 'Total number of leave days requested, calculated as business days between start and end dates. May include fractional days for partial-day leave. | Column total_days_requested (DECIMAL(5,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursRequested rdf:type rdf:Property ;
    rdfs:label 'Total Hours Requested' ;
    rdfs:comment 'Total number of leave hours requested, used for hourly leave tracking and partial-day absences. Supports intermittent FMLA leave measured in hours. | Column total_hours_requested (DECIMAL(6,2)) in workforce.leave_request' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceId rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Id' ;
    rdfs:comment 'Unique identifier for the leave balance record. Primary key. | Column leave_balance_id (BIGINT) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorLeaveBalanceId rdf:type rdf:Property ;
    rdfs:label 'Prior Leave Balance Id' ;
    rdfs:comment 'Self-referencing FK on leave_balance (prior_leave_balance_id) | Column prior_leave_balance_id (BIGINT) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaveBalance .

ind:accrualCap rdf:type rdf:Property ;
    rdfs:label 'Accrual Cap' ;
    rdfs:comment 'Maximum leave balance that can be accrued for this leave type per Media Broadcasting policy. Once reached, no further accrual occurs until balance drops below cap. | Column accrual_cap (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'End date of the current accrual period. Balances may reset, roll over, or be forfeited at this boundary per policy. | Column accrual_period_end_date (DATE) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'Start date of the current accrual period (e.g., calendar year, fiscal year, or anniversary year depending on Media Broadcasting policy). | Column accrual_period_start_date (DATE) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualRate rdf:type rdf:Property ;
    rdfs:label 'Accrual Rate' ;
    rdfs:comment 'Rate at which leave accrues per pay period or per hour worked, based on employee tenure and policy tier. Expressed in hours or days per unit time. | Column accrual_rate (DECIMAL(10,4)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrued Current Period' ;
    rdfs:comment 'Total leave hours or days accrued during the current period based on accrual rate and service time. Updated each pay period by payroll system. | Column accrued_current_period (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedBalance rdf:type rdf:Property ;
    rdfs:label 'Adjusted Balance' ;
    rdfs:comment 'Manual adjustments to the leave balance (positive or negative) made by HR for corrections, policy exceptions, or one-time grants. Includes adjustment reason in notes. | Column adjusted_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Current available leave balance that the employee can request. Calculated as: opening_balance + accrued_current_period - used_current_period + adjusted_balance - pending_requests. | Column available_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Date' ;
    rdfs:comment 'The date as of which this leave balance snapshot is accurate. Typically updated at the end of each pay period or after a leave transaction. | Column balance_as_of_date (DATE) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carriedOverBalance rdf:type rdf:Property ;
    rdfs:label 'Carried Over Balance' ;
    rdfs:comment 'Leave balance carried forward from the prior accrual period. Subject to carryover caps per Media Broadcasting policy (e.g., maximum 40 hours vacation carryover). | Column carried_over_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryoverCap rdf:type rdf:Property ;
    rdfs:label 'Carryover Cap' ;
    rdfs:comment 'Maximum leave balance that can be carried over to the next accrual period. Any balance above this cap is forfeited per policy. | Column carryover_cap (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forfeitedBalance rdf:type rdf:Property ;
    rdfs:label 'Forfeited Balance' ;
    rdfs:comment 'Leave hours or days forfeited at the end of the prior period due to exceeding carryover caps or use-it-or-lose-it policy. Represents lost leave liability. | Column forfeited_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAccrualDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Date' ;
    rdfs:comment 'Date of the most recent leave accrual transaction for this employee and leave type. Typically aligns with pay period end date. | Column last_accrual_date (DATE) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date of the most recent leave usage (deduction) for this employee and leave type. Helps identify stale balances and usage patterns. | Column last_usage_date (DATE) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveTypeCode rdf:type rdf:Property ;
    rdfs:label 'Leave Type Code' ;
    rdfs:comment 'Code representing the type of leave (e.g., VAC for vacation, SICK for sick leave, PTO for paid time off, FLOAT for floating holiday, COMP for compensatory time). Standardized codes per Media Broadcasting HR policy. | Column leave_type_code (STRING) in workforce.leave_balance' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveTypeName rdf:type rdf:Property ;
    rdfs:label 'Leave Type Name' ;
    rdfs:comment 'Human-readable name of the leave type (e.g., Vacation, Sick Leave, Personal Time Off, Floating Holiday, Compensatory Time). | Column leave_type_name (STRING) in workforce.leave_balance' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Monetary value of the current available leave balance, calculated as available_balance multiplied by the employees hourly or daily rate. Represents financial liability for Media Broadcasting. | Column liability_amount (DECIMAL(12,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'Leave balance at the start of the current accrual period, including any carryover from the prior period. Expressed in hours or days per unit of measure. | Column opening_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingRequests rdf:type rdf:Property ;
    rdfs:label 'Pending Requests' ;
    rdfs:comment 'Total leave hours or days currently requested but not yet approved or denied. Represents potential future deductions from available balance. | Column pending_requests (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyTier rdf:type rdf:Property ;
    rdfs:label 'Policy Tier' ;
    rdfs:comment 'The accrual policy tier applicable to this employee for this leave type, typically based on tenure or job level (e.g., Tier 1: 0-2 years, Tier 2: 3-5 years, Tier 3: 6+ years). | Column policy_tier (STRING) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedYearEndBalance rdf:type rdf:Property ;
    rdfs:label 'Projected Year End Balance' ;
    rdfs:comment 'Forecasted leave balance at the end of the current accrual period, assuming no further usage. Used for liability planning and to alert employees of potential forfeitures. | Column projected_year_end_balance (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Used Current Period' ;
    rdfs:comment 'Total leave hours or days used (taken) by the employee during the current period. Sourced from approved leave requests and time-tracking system. | Column used_current_period (DECIMAL(10,2)) in workforce.leave_balance' ;
    rdfs:domain ind:LeaveBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Unique identifier for the timesheet record. Primary key. | Column timesheet_id (BIGINT) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctedTimesheetId rdf:type rdf:Property ;
    rdfs:label 'Corrected Timesheet Id' ;
    rdfs:comment 'Self-referencing FK on timesheet (corrected_timesheet_id) | Column corrected_timesheet_id (BIGINT) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timesheet .

ind:primaryTimesheetApprovingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Timesheet Approving Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor who approved or is responsible for approving this timesheet. Links to employee master record. | Column timesheet_approving_manager_employee_id (BIGINT) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTimesheetModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Timesheet Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this timesheet record. Used for audit trail and accountability. | Column timesheet_modified_by_user_employee_id (BIGINT) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:holidayHours rdf:type rdf:Property ;
    rdfs:label 'Holiday Hours' ;
    rdfs:comment 'Total number of paid holiday hours included in this timesheet period for recognized company holidays. | Column holiday_hours (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onCallHours rdf:type rdf:Property ;
    rdfs:label 'On Call Hours' ;
    rdfs:comment 'Total number of on-call hours during the pay period. Relevant for broadcast engineers and technical staff required to be available for emergency playout or transmission issues. | Column on_call_hours (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialHours rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Hours' ;
    rdfs:comment 'Total number of hours worked during shifts eligible for differential pay (e.g., night shift, weekend shift). Common in 24/7 broadcast operations. | Column shift_differential_hours (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timesheetNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Number' ;
    rdfs:comment 'Human-readable business identifier for the timesheet, typically formatted as TS-YYYYMMDD or similar pattern for external reference and reporting. | Column timesheet_number (STRING) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoursApproved rdf:type rdf:Property ;
    rdfs:label 'Total Hours Approved' ;
    rdfs:comment 'Total number of hours approved by the manager for payroll processing. May differ from submitted hours if adjustments were made during approval. | Column total_hours_approved (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursSubmitted rdf:type rdf:Property ;
    rdfs:label 'Total Hours Submitted' ;
    rdfs:comment 'Total number of hours submitted by the employee across all categories (regular, overtime, double-time, on-call, shift differential, PTO, holiday, unpaid leave). Sum of all hour types. | Column total_hours_submitted (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unpaidLeaveHours rdf:type rdf:Property ;
    rdfs:label 'Unpaid Leave Hours' ;
    rdfs:comment 'Total number of unpaid leave hours recorded in this timesheet period, such as unpaid personal leave or leave without pay. | Column unpaid_leave_hours (DECIMAL(8,2)) in workforce.timesheet' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Work order number associated with the timesheet, used for tracking time against specific maintenance, production, or operational tasks. | Column work_order_number (STRING) in workforce.timesheet' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workScheduleId rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Id' ;
    rdfs:comment 'Unique identifier for the work schedule pattern. Primary key. | Column work_schedule_id (BIGINT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseWorkScheduleId rdf:type rdf:Property ;
    rdfs:label 'Base Work Schedule Id' ;
    rdfs:comment 'Self-referencing FK on work_schedule (base_work_schedule_id) | Column base_work_schedule_id (BIGINT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkSchedule .

ind:primaryDaypartId rdf:type rdf:Property ;
    rdfs:label 'Primary Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Broadcast work schedules align with dayparts (morning shift covers morning daypart, prime time shift covers prime daypart). 24/7 operations shift planning requires mapping work schedules to broadcast  | Column primary_daypart_id (BIGINT) in scheduling.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:applicableJobFamilies rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Families' ;
    rdfs:comment 'Comma-separated list of job families or roles this schedule is designed for (e.g., Broadcast Engineer, Playout Operator, Master Control Technician, Production Staff, Administrative). Supports role-based schedule assignment. | Column applicable_job_families (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOrgUnits rdf:type rdf:Property ;
    rdfs:label 'Applicable Org Units' ;
    rdfs:comment 'Comma-separated list of organizational unit codes or names where this schedule is used (e.g., Broadcast Operations, Playout Engineering, News Production, Corporate Office). Enables filtering schedules by department or division. | Column applicable_org_units (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total duration of unpaid breaks during the shift, measured in minutes (e.g., 30 for half-hour lunch, 60 for one-hour lunch). Used to calculate net working hours and compliance with labor regulations. | Column break_duration_minutes (INT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartClassification rdf:type rdf:Property ;
    rdfs:label 'Daypart Classification' ;
    rdfs:comment 'Broadcast industry daypart classification for the schedule: morning (6-9 AM), daytime (9 AM-4 PM), early_fringe (4-7 PM), prime_access (7-8 PM), prime_time (8-11 PM), late_fringe (11 PM-1 AM), overnight (1-6 AM). Aligns shift schedules with programming and advertising dayparts. [ENUM-REF-CANDIDATE: morning|daytime|early_fringe|prime_access|prime_time|late_fringe|overnight — 7 candidates stripped; promote to reference product] | Column daypart_classification (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Holiday Work Required' ;
    rdfs:comment 'Indicates whether employees on this schedule are expected to work on company-recognized holidays. True for essential broadcast operations (playout, master control), false for administrative roles. | Column holiday_work_required (BOOLEAN) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealBreakRequired rdf:type rdf:Property ;
    rdfs:label 'Meal Break Required' ;
    rdfs:comment 'Indicates whether a meal break is legally or contractually required for this schedule. True for shifts exceeding a certain duration (typically 6+ hours), false for shorter shifts. Ensures compliance with labor regulations. | Column meal_break_required (BOOLEAN) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onCallFrequency rdf:type rdf:Property ;
    rdfs:label 'On Call Frequency' ;
    rdfs:comment 'Frequency of on-call duty for schedules that include on-call rotation: none (no on-call), weekly (one week per rotation), biweekly (one week every two weeks), monthly (one week per month), as_needed (ad-hoc). Relevant for broadcast engineering and technical support roles. | Column on_call_frequency (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onCallResponseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'On Call Response Time Minutes' ;
    rdfs:comment 'Maximum time in minutes an on-call employee must respond to a call-out (e.g., 30 for 30-minute response, 60 for one-hour response). Null for schedules without on-call duty. Critical for broadcast continuity and Service Level Agreement (SLA) compliance. | Column on_call_response_time_minutes (INT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Overtime Calculation Basis' ;
    rdfs:comment 'Basis for calculating overtime: daily (hours beyond threshold in a single day), weekly (hours beyond threshold in a work week), biweekly (hours beyond threshold in a two-week pay period). Determines when premium pay rates apply. | Column overtime_calculation_basis (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Duration Minutes' ;
    rdfs:comment 'Total duration of paid breaks during the shift, measured in minutes (e.g., 15 for two 15-minute breaks). Separate from unpaid meal breaks; included in compensable time. | Column paid_break_duration_minutes (INT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresBroadcastLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Broadcast License' ;
    rdfs:comment 'Indicates whether employees assigned to this schedule must hold a valid broadcast engineering or operator license (e.g., FCC General Radiotelephone Operator License). True for technical playout and transmission roles, false for administrative and production roles. | Column requires_broadcast_license (BOOLEAN) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restPeriodBetweenShiftsHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Between Shifts Hours' ;
    rdfs:comment 'Minimum number of hours required between the end of one shift and the start of the next for employees on this schedule (e.g., 8 for eight-hour rest, 11 for eleven-hour rest). Ensures compliance with labor regulations and employee well-being, especially for rotating broadcast shifts. | Column rest_period_between_shifts_hours (DECIMAL(5,2)) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationCycleDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Cycle Days' ;
    rdfs:comment 'Number of days in the rotation cycle for rotating shift schedules (e.g., 7 for weekly rotation, 14 for bi-weekly, 28 for four-week cycle). Null for fixed schedules. Broadcast operations often use 7, 14, or 21-day cycles to ensure equitable distribution of overnight and weekend shifts. | Column rotation_cycle_days (INT) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the schedule pattern (e.g., STD-9TO5, SHIFT-AM, SHIFT-PM, ONCALL-ROT). Used for quick reference in HR systems and employee assignments. | Column schedule_code (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the work schedule pattern, including any special conditions, rotation details, or operational notes (e.g., \'Four 10-hour shifts Monday-Thursday with Friday off; on-call rotation every fourth week; requires FCC license\'). | Column schedule_description (STRING) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Standard end time for the work shift in HH:MM 24-hour format (e.g., 17:00 for 5 PM, 06:00 for 6 AM next day). For rotating or flexible schedules, this represents the primary or latest end time. | Column shift_end_time (TIMESTAMP) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Standard start time for the work shift in HH:MM 24-hour format (e.g., 09:00 for 9 AM, 22:00 for 10 PM). For rotating or flexible schedules, this represents the primary or earliest start time. | Column shift_start_time (TIMESTAMP) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Total Weekly Hours' ;
    rdfs:comment 'Total number of hours per week defined by this schedule pattern. Standard full-time is typically 40 hours; broadcast operations may have 37.5, 40, or 42 hours depending on shift structure and break policies. | Column total_weekly_hours (DECIMAL(5,2)) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weekendWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Weekend Work Required' ;
    rdfs:comment 'Indicates whether this schedule includes regular weekend work (Saturday and/or Sunday). True for broadcast operations requiring 24/7 coverage, false for standard Monday-Friday office schedules. | Column weekend_work_required (BOOLEAN) in workforce.work_schedule' ;
    rdfs:domain ind:WorkSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key for the performance review entity. | Column performance_review_id (BIGINT) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousPerformanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Previous Performance Review Id' ;
    rdfs:comment 'Self-referencing FK on performance_review (previous_performance_review_id) | Column previous_performance_review_id (BIGINT) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceReview .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in the workforce domain. | Column primary_performance_employee_id (BIGINT) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'The date on which the performance review rating was calibrated through management review session. | Column calibration_date (DATE) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status indicating whether the review has undergone calibration process to ensure rating consistency across the organization. Calibration involves peer review of ratings by management. | Column calibration_status (STRING) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Rating' ;
    rdfs:comment 'Competency rating for teamwork, communication, and cross-functional collaboration on a 1-5 scale. | Column collaboration_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationAdjustmentRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether a compensation adjustment (salary increase, bonus) is recommended based on this performance review. | Column compensation_adjustment_recommended_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Development Plan Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal performance improvement or development plan is required as an outcome of this review. | Column development_plan_required_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeComments rdf:type rdf:Property ;
    rdfs:label 'Dispute Comments' ;
    rdfs:comment 'Narrative explanation provided by the employee if they dispute the performance review rating or feedback. | Column dispute_comments (STRING) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has acknowledged the performance review. Required for review completion. | Column employee_acknowledgement_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Narrative comments and self-reflection provided by the employee as part of their self-assessment in the performance review. | Column employee_comments (STRING) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has formally disputed the performance review rating or feedback. | Column employee_dispute_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeSelfAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment Score' ;
    rdfs:comment 'The self-rating provided by the employee on a 1-5 scale as part of the performance review process. Captures employee\'s own perception of their performance. | Column employee_self_assessment_score (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalApprovedRating rdf:type rdf:Property ;
    rdfs:label 'Final Approved Rating' ;
    rdfs:comment 'The final overall performance rating after calibration and approval by senior management. This is the official rating used for compensation and promotion decisions. | Column final_approved_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Score' ;
    rdfs:comment 'Percentage score representing the degree to which the employee achieved their performance goals during the review period. Calculated as weighted average of individual goal completion rates. | Column goal_achievement_score (DECIMAL(5,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationRating rdf:type rdf:Property ;
    rdfs:label 'Innovation Rating' ;
    rdfs:comment 'Competency rating for creativity, problem-solving, and innovative thinking on a 1-5 scale. | Column innovation_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadershipRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Rating' ;
    rdfs:comment 'Competency rating for leadership capabilities, people management, and influence on a 1-5 scale. Applicable to employees in leadership roles or demonstrating leadership potential. | Column leadership_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'The overall performance rating assigned to the employee on a 1-5 scale, where 1 is unsatisfactory and 5 is exceptional. May include decimal precision for nuanced scoring. | Column overall_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preCalibrationRating rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Rating' ;
    rdfs:comment 'The initial overall rating assigned by the reviewer before the calibration process. Retained for audit trail and calibration impact analysis. | Column pre_calibration_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is eligible for promotion consideration based on this performance review outcome. | Column promotion_eligible_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCompensationAdjustmentPercent rdf:type rdf:Property ;
    rdfs:label 'Recommended Compensation Adjustment Percent' ;
    rdfs:comment 'The recommended percentage increase in base compensation resulting from this performance review. Used to inform compensation planning decisions. | Column recommended_compensation_adjustment_percent (DECIMAL(5,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Review Acknowledgement Date' ;
    rdfs:comment 'The date on which the employee formally acknowledged receipt and review of their performance evaluation. | Column review_acknowledgement_date (DATE) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the performance period being evaluated in this review. | Column review_period_end_date (DATE) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the performance period being evaluated in this review. | Column review_period_start_date (DATE) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'The type or category of performance review being conducted. Determines the review cycle and evaluation criteria applied. | Column review_type (STRING) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed narrative feedback provided by the reviewer regarding the employee\'s performance, strengths, areas for improvement, and development recommendations. | Column reviewer_comments (STRING) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee should be included in succession planning discussions based on this performance review outcome. | Column succession_planning_flag (BOOLEAN) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Competency rating for technical skills and job-specific expertise on a 1-5 scale. Evaluates proficiency in role-required technical capabilities. | Column technical_skills_rating (DECIMAL(3,2)) in workforce.performance_review' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalId rdf:type rdf:Property ;
    rdfs:label 'Goal Id' ;
    rdfs:comment 'Unique identifier for the employee performance goal record. Primary key. | Column goal_id (BIGINT) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentGoalId rdf:type rdf:Property ;
    rdfs:label 'Parent Goal Id' ;
    rdfs:comment 'Self-referencing FK on goal (parent_goal_id) | Column parent_goal_id (BIGINT) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Goal .

ind:primaryGoalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goal Employee Id' ;
    rdfs:comment 'Reference to the employee to whom this goal is assigned. Links to the employee master record in the workforce domain. | Column goal_employee_id (BIGINT) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Reference to the performance review cycle or period to which this goal belongs (e.g., 2024 Annual Review, Q2 2024 Quarterly Review). Links to the review cycle master record. | Column review_cycle_id (BIGINT) in billing.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:achievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Achievement Percentage' ;
    rdfs:comment 'Calculated percentage of goal completion based on current value relative to target value. Values over 100% indicate the goal was exceeded. Used for performance scoring and reporting. | Column achievement_percentage (DECIMAL(5,2)) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Starting or current value of the metric at the time the goal was set. Provides context for measuring progress and improvement (e.g., current audience reach before the goal period). | Column baseline_value (DECIMAL(18,4)) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalCategory rdf:type rdf:Property ;
    rdfs:label 'Goal Category' ;
    rdfs:comment 'Classification of the goal scope and level. Individual goals are personal performance targets; team goals are shared across a work group; organizational goals cascade from company-wide objectives; departmental goals align with division priorities; project goals are tied to specific initiatives; strategic goals support long-term business strategy. | Column goal_category (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalDescription rdf:type rdf:Property ;
    rdfs:label 'Goal Description' ;
    rdfs:comment 'Detailed narrative description of the goal, including context, expected outcomes, and success criteria. Provides comprehensive understanding of what the employee is expected to achieve. | Column goal_description (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNotes rdf:type rdf:Property ;
    rdfs:label 'Employee Notes' ;
    rdfs:comment 'Free-text notes from the employee documenting progress, challenges encountered, resources needed, or self-assessment. Supports employee self-reflection and two-way performance dialogue. | Column employee_notes (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalType rdf:type rdf:Property ;
    rdfs:label 'Goal Type' ;
    rdfs:comment 'Nature of the goal measurement. Quantitative goals have numeric targets (e.g., revenue, ratings); qualitative goals are assessed subjectively (e.g., leadership quality); behavioral goals focus on conduct and values; developmental goals target skill acquisition; operational goals improve processes; strategic goals advance long-term positioning. | Column goal_type (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this goal is mandatory (required for all employees in a role or department) or optional (individually selected). Mandatory goals often relate to compliance, training, or core job functions. | Column is_mandatory (BOOLEAN) in workforce.goal' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStretchGoal rdf:type rdf:Property ;
    rdfs:label 'Is Stretch Goal' ;
    rdfs:comment 'Indicates whether this is a stretch goal (aspirational target beyond normal expectations). Stretch goals are typically weighted differently in performance evaluations and partial achievement is often considered successful. | Column is_stretch_goal (BOOLEAN) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the target value (e.g., \'percent\', \'viewers\', \'hours\', \'episodes\', \'dollars\', \'rating points\'). Clarifies how the numeric target should be interpreted. | Column measurement_unit (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:okrAlignment rdf:type rdf:Property ;
    rdfs:label 'Okr Alignment' ;
    rdfs:comment 'Reference to the company-level or department-level OKR (Objectives and Key Results) that this goal supports. Ensures goal alignment with organizational strategy. May reference specific objective identifiers or descriptive text. | Column okr_alignment (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressStatus rdf:type rdf:Property ;
    rdfs:label 'Progress Status' ;
    rdfs:comment 'Current state of goal progress. Not started: work has not begun; in progress: actively being worked on; on track: progressing as expected; at risk: may not meet target; behind: falling short of milestones; completed: target achieved; exceeded: surpassed target; cancelled: goal no longer applicable. [ENUM-REF-CANDIDATE: not_started|in_progress|on_track|at_risk|behind|completed|exceeded|cancelled — 8 candidates stripped; promote to reference product] | Column progress_status (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'The specific measurable indicator or key performance indicator (KPI) used to assess goal achievement (e.g., \'Audience Reach\', \'Content Production Volume\', \'System Uptime Percentage\', \'Training Completion Rate\'). | Column target_metric (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Defines who can view this goal. Private: only employee and manager; manager: visible to management chain; department: visible to department members; organization: visible company-wide; public: visible to external stakeholders. | Column visibility_level (STRING) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'Relative importance or weight of this goal within the employees overall performance review, expressed as a percentage (e.g., 25.00 means this goal represents 25% of the total performance score). All goals for an employee typically sum to 100%. | Column weight_percentage (DECIMAL(5,2)) in workforce.goal' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course. Primary key. | Column training_course_id (BIGINT) in workforce.training_course' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:applicableDaypartId rdf:type rdf:Property ;
    rdfs:label 'Applicable Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: Training courses for broadcast operations may be daypart-specific (e.g., "Prime Time Programming Strategy", "Morning Show Production Techniques"). Specialized training curriculum design requires linki | Column applicable_daypart_id (BIGINT) in scheduling.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:prerequisiteTrainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Training Course Id' ;
    rdfs:comment 'Self-referencing FK on training_course (prerequisite_training_course_id) | Column prerequisite_training_course_id (BIGINT) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:trainingCourseCategory rdf:type rdf:Property ;
    rdfs:label 'Training Course Category' ;
    rdfs:comment 'Primary classification of the training course by subject area: broadcast operations (playout, scheduling, transmission), regulatory compliance (FCC, EEO, COPPA), technical skills (MAM, CDN, encoding), leadership development, cybersecurity awareness, or editorial standards. | Column training_course_category (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationAwarded rdf:type rdf:Property ;
    rdfs:label 'Certification Awarded' ;
    rdfs:comment 'Name of the certification, credential, or certificate of completion awarded upon successful course completion (e.g., FCC Broadcast Operator License, SCTE Broadband Transportation Specialist, Media Broadcasting Editorial Standards Certificate). Null if no formal certification is awarded. | Column certification_awarded (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education units (CEUs) or professional development hours (PDHs) awarded upon course completion, recognized by industry associations or regulatory bodies. Null if no formal credits are awarded. | Column continuing_education_credits (DECIMAL(5,2)) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost charged per participant for enrollment in the training course, in USD. Includes tuition, materials, and vendor fees. Used for training budget planning and cost allocation. Null if the course is provided at no charge. | Column cost_per_participant (DECIMAL(10,2)) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the training course for catalog and registration purposes (e.g., BC-101, FCC-REG-2023, EEO-COMP). | Column course_code (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Comprehensive narrative description of the training course content, topics covered, instructional approach, and target audience. Used in the learning catalog and course registration materials. | Column course_description (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total instructional time required to complete the training course, measured in hours (e.g., 2.5 hours for a half-day workshop, 40 hours for a week-long certification program). | Column duration_hours (DECIMAL(5,2)) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Detailed description of the knowledge, skills, and competencies that participants will acquire upon successful completion of the training course. Defines the expected learning outcomes. | Column learning_objectives (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether the training course is mandatory for specific job roles or all employees (True) or optional/elective (False). Mandatory courses are typically driven by regulatory requirements (FCC, EEO, COPPA) or critical operational competencies. | Column mandatory_flag (BOOLEAN) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxEnrollment rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single offering or session of the training course. Null if there is no enrollment cap (e.g., for self-paced e-learning courses). | Column max_enrollment (INT) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of prerequisite courses, certifications, or experience required before an employee can enroll in this training course (e.g., Must complete BC-100 Introduction to Broadcasting, Requires 6 months experience in playout operations). Null if no prerequisites. | Column prerequisites (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or entity that developed or delivers the training course (e.g., Media Broadcasting Learning & Development, Dalet Academy, Society of Cable Telecommunications Engineers). | Column provider_name (STRING) in workforce.training_course' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Source of the training course: internal (developed and delivered by Media Broadcasting HR/L&D), external (third-party training vendor), vendor (system vendor training such as Dalet or Ericsson), industry association (MPA, ATSC, SCTE), or regulatory body (FCC-mandated training). | Column provider_type (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Period Months' ;
    rdfs:comment 'Number of months after which the certification or training must be renewed or retaken to maintain compliance or currency (e.g., 12 months for annual cybersecurity awareness, 36 months for FCC regulatory training). Null if no recertification is required. | Column recertification_period_months (INT) in workforce.training_course' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCourseStatus rdf:type rdf:Property ;
    rdfs:label 'Training Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course: active (available for enrollment), inactive (temporarily unavailable), under development (being created or updated), retired (permanently discontinued), or suspended (on hold pending review or update). | Column training_course_status (STRING) in workforce.training_course' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Unique identifier for the training enrollment record. Primary key for this entity. | Column training_enrollment_id (BIGINT) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPreviousEnrollmentTrainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Previous Enrollment Training Enrollment Id' ;
    rdfs:comment 'Identifier of the previous training enrollment record that this recertification enrollment supersedes. Used to track recertification history and lineage. Null for initial enrollments. | Column previous_enrollment_training_enrollment_id (BIGINT) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEnrollment .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the training assessment indicating whether the employee passed, failed, has a pending assessment, did not require assessment for completion, or has an incomplete assessment. | Column assessment_result (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved by the employee on the training assessment, test, or examination. Typically expressed as a percentage (0-100) or raw score. Null if no assessment was administered or not yet taken. | Column assessment_score (DECIMAL(5,2)) in workforce.training_enrollment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of scheduled training sessions or modules that the employee attended or completed. Calculated as (hours completed / hours scheduled) * 100. Used for compliance verification and completion criteria. | Column attendance_percentage (DECIMAL(5,2)) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Boolean flag indicating whether a training completion certificate was issued to the employee upon successful completion. True if certificate was issued, False otherwise. | Column certificate_issued (BOOLEAN) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrolledByUser rdf:type rdf:Property ;
    rdfs:label 'Enrolled By User' ;
    rdfs:comment 'Username or identifier of the person who initiated the enrollment (e.g., HR administrator, manager, or self-enrollment by employee). Used for audit trail and enrollment source tracking. | Column enrolled_by_user (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Classification of the enrollment indicating whether the training is mandatory (required by policy or regulation), voluntary (employee-initiated), recommended (suggested by manager), or compliance-driven (regulatory requirement such as FCC or EEO training). | Column enrollment_type (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor, facilitator, or trainer who delivered the training session. Null for self-paced online courses without instructor involvement. | Column instructor_name (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecertification rdf:type rdf:Property ;
    rdfs:label 'Is Recertification' ;
    rdfs:comment 'Boolean flag indicating whether this enrollment represents a recertification or refresher training for a previously completed course. True for recertification enrollments, False for initial certifications. | Column is_recertification (BOOLEAN) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Boolean flag indicating whether this training is required to meet regulatory compliance obligations such as FCC broadcast licensing requirements, EEO training mandates, or technical certification standards. True for regulatory-required training. | Column is_regulatory_required (BOOLEAN) in workforce.training_enrollment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfAttempts rdf:type rdf:Property ;
    rdfs:label 'Number Of Attempts' ;
    rdfs:comment 'Count of how many times the employee attempted the training assessment or examination. Used for tracking learning progress and identifying employees who may need additional support. | Column number_of_attempts (INT) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment and achieve completion status. Used to determine pass/fail result. Null if no assessment is required for completion. | Column passing_score_threshold (DECIMAL(5,2)) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Method by which the training content is delivered to the employee. Includes in-person classroom sessions, virtual instructor-led training, self-paced online courses, blended learning combining multiple methods, or on-the-job practical training. | Column training_delivery_method (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Actual number of training hours completed by the employee. Used for tracking progress, compliance reporting, and crediting continuing education units. | Column training_hours_completed (DECIMAL(6,2)) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursScheduled rdf:type rdf:Property ;
    rdfs:label 'Training Hours Scheduled' ;
    rdfs:comment 'Total number of training hours scheduled for this enrollment based on the course curriculum. Used for planning and resource allocation. | Column training_hours_scheduled (DECIMAL(6,2)) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training is conducted. For in-person training, includes facility name or address. For virtual training, may include platform name (e.g., Zoom, Microsoft Teams). Null for self-paced online courses. | Column training_location (STRING) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the employee withdrew from the training course before completion. Null if the enrollment was not withdrawn. | Column withdrawal_date (DATE) in workforce.training_enrollment' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the professional certification record. Primary key for the certification entity. | Column certification_id (BIGINT) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewedCertificationId rdf:type rdf:Property ;
    rdfs:label 'Renewed Certification Id' ;
    rdfs:comment 'Self-referencing FK on certification (renewed_certification_id) | Column renewed_certification_id (BIGINT) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:certificationCategory rdf:type rdf:Property ;
    rdfs:label 'Certification Category' ;
    rdfs:comment 'Functional domain or technical discipline that the certification covers. Used to align certifications with job roles and departmental needs. [ENUM-REF-CANDIDATE: broadcast_engineering|it_infrastructure|cloud_computing|network_engineering|audio_engineering|video_engineering|rf_transmission|compliance_regulatory|project_management|cybersecurity — 10 candidates stripped; promote to reference product] | Column certification_category (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Url' ;
    rdfs:comment 'Web URL or digital link to the electronic certificate or credential badge. Used for digital verification and display of credentials. | Column certificate_url (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Classification of the certification based on its nature and purpose. Regulatory licenses are legally required for specific broadcast operations; professional certifications demonstrate industry expertise; technical certifications validate specialized technical skills; vendor certifications are product-specific credentials; industry credentials are association-based qualifications. | Column certification_type (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Short code or abbreviation for the certification type. Examples: GROL, CBNT, CBT, CPBE, AWS-SAA, SMPTE-CTS. Used for internal classification and reporting. | Column certification_code (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Number of continuing education hours the employee has completed toward the current renewal cycle. Used to track progress toward recertification requirements. | Column continuing_education_hours_completed (DECIMAL(6,2)) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'Number of continuing education or professional development hours required to maintain or renew the certification. Null for certifications without continuing education requirements. | Column continuing_education_hours_required (DECIMAL(6,2)) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File path or document management system reference to the scanned or digital copy of the physical certificate. Used for record retention and audit purposes. | Column document_storage_path (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerSponsored rdf:type rdf:Property ;
    rdfs:label 'Employer Sponsored' ;
    rdfs:comment 'Indicates whether the certification was sponsored or paid for by the employer. True if the company funded the certification; false if the employee self-funded it. | Column employer_sponsored (BOOLEAN) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'Score achieved on the certification exam, if applicable. May be a percentage, numeric score, or standardized score depending on the certification body. Null for certifications that do not have scored exams. | Column exam_score (DECIMAL(5,2)) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRequiredForRole rdf:type rdf:Property ;
    rdfs:label 'Is Required For Role' ;
    rdfs:comment 'Indicates whether this certification is a mandatory requirement for the employees current job role. True for certifications that are job prerequisites (e.g., FCC GROL for broadcast engineers); false for optional or supplementary credentials. | Column is_required_for_role (BOOLEAN) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Proficiency or seniority level represented by the certification. Entry-level certifications demonstrate foundational knowledge; expert and master levels indicate advanced expertise and leadership capability. | Column certification_level (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full official name of the professional certification, license, or credential. Examples: FCC General Radiotelephone Operator License (GROL), SBE Certified Broadcast Networking Technologist (CBNT), AWS Certified Solutions Architect, SMPTE Certified Technology Specialist. | Column certification_name (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to maintain active status. Used for proactive renewal reminders and compliance monitoring. | Column next_renewal_due_date (DATE) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum score required to pass the certification exam. Used to contextualize the exam score and assess performance relative to the standard. | Column passing_score (DECIMAL(5,2)) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or institution that provided the training or preparation for the certification exam. May be the same as the issuing body or a separate training vendor. | Column training_provider (STRING) in workforce.certification' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Id' ;
    rdfs:comment 'Unique identifier for the disciplinary action record. Primary key for the disciplinary action entity. | Column disciplinary_action_id (BIGINT) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalatedDisciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Escalated Disciplinary Action Id' ;
    rdfs:comment 'Self-referencing FK on disciplinary_action (escalated_disciplinary_action_id) | Column escalated_disciplinary_action_id (BIGINT) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisciplinaryAction .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Identifier of the Media Broadcasting employee who is the subject of this disciplinary action. | Column primary_disciplinary_employee_id (BIGINT) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryIssuingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Issuing Manager Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor who issued the disciplinary action to the employee. | Column tertiary_disciplinary_issuing_manager_employee_id (BIGINT) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date the disciplinary action was formally issued to the employee. This is the official date of record for the action and starts any applicable timelines. | Column action_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the disciplinary action, formatted as DA-YYYYNNNN for external reference and case tracking. | Column action_number (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the disciplinary action: draft (being prepared), pending review (awaiting HR/legal approval), active (in effect), completed (action fulfilled or time elapsed), overturned (reversed on appeal), or expired (no longer on employee record per retention policy). | Column action_status (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date the employee filed a formal appeal or grievance. Null if no appeal has been filed. | Column appeal_filed_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date the employee signed or electronically acknowledged the disciplinary action documentation. Null if not yet acknowledged. | Column employee_acknowledgment_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the employee has acknowledged receipt and review of the disciplinary action documentation. True if acknowledged, false if not yet acknowledged. | Column employee_acknowledgment_flag (BOOLEAN) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeResponse rdf:type rdf:Property ;
    rdfs:label 'Employee Response' ;
    rdfs:comment 'Written response or statement provided by the employee regarding the disciplinary action. May include explanations, disagreements, or mitigating circumstances. Null if no response provided. | Column employee_response (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Summary' ;
    rdfs:comment 'Summary of the investigation conducted prior to issuing the disciplinary action, including interviews, evidence reviewed, and findings. Documents due process and fair treatment. | Column investigation_summary (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipEndDate rdf:type rdf:Property ;
    rdfs:label 'Pip End Date' ;
    rdfs:comment 'End date of the performance improvement plan period if action type is PIP. Typically 30, 60, or 90 days from start. Null for non-PIP actions. | Column pip_end_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Start date of the performance improvement plan period if action type is PIP. Null for non-PIP actions. | Column pip_start_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyViolated rdf:type rdf:Property ;
    rdfs:label 'Policy Violated' ;
    rdfs:comment 'Reference to the specific company policy, code of conduct section, or employment agreement clause that was violated. Includes policy number and title for traceability. | Column policy_violated (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Date' ;
    rdfs:comment 'Date until which this disciplinary action record must be retained in the employee file per employment law and company policy. After this date, record may be purged or archived per retention schedule. | Column record_retention_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Date by which the employee must provide a written response, complete required corrective actions, or demonstrate improvement. Null if no response is required. | Column response_deadline_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'End date of suspension period if action type is suspension. Null for non-suspension actions. | Column suspension_end_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Suspension Paid Flag' ;
    rdfs:comment 'Indicates whether the suspension is paid (true) or unpaid (false). Null for non-suspension actions. Paid suspensions are typically used during investigations; unpaid for disciplinary purposes. | Column suspension_paid_flag (BOOLEAN) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Start date of suspension period if action type is suspension. Null for non-suspension actions. | Column suspension_start_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Triggered Flag' ;
    rdfs:comment 'Indicates whether this disciplinary action resulted in or triggered employee termination. True if termination occurred, false otherwise. Feeds termination workflow when true. | Column termination_triggered_flag (BOOLEAN) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Union Notification Required Flag' ;
    rdfs:comment 'Indicates whether union notification is required for this disciplinary action per collective bargaining agreement. True for union-represented employees in positions covered by CBA disciplinary procedures. | Column union_notification_required_flag (BOOLEAN) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Union Notified Date' ;
    rdfs:comment 'Date the union representative was formally notified of the disciplinary action. Null if union notification is not required or not yet completed. | Column union_notified_date (DATE) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the union representative notified and involved in the disciplinary action process. Null if not applicable. | Column union_representative_name (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'High-level classification of the policy violation type: attendance (tardiness, absenteeism), performance (failure to meet job standards), conduct (behavioral issues), safety (workplace safety violations), compliance (regulatory or legal violations), confidentiality (data/information breach), or harassment (workplace harassment or discrimination). [ENUM-REF-CANDIDATE: attendance|performance|conduct|safety|compliance|confidentiality|harassment — 7 candidates stripped; promote to reference product] | Column violation_category (STRING) in workforce.disciplinary_action' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Workforce Grievance Id' ;
    rdfs:comment 'Unique identifier for the workforce grievance record. Primary key for the workforce grievance entity. | Column workforce_grievance_id (BIGINT) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalatedWorkforceGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Escalated Workforce Grievance Id' ;
    rdfs:comment 'Self-referencing FK on workforce_grievance (escalated_workforce_grievance_id) | Column escalated_workforce_grievance_id (BIGINT) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceGrievance .

ind:primaryWorkforceComplainantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Complainant Employee Id' ;
    rdfs:comment 'Identifier of the employee who filed the grievance. Links to the employee master record. | Column primary_workforce_complainant_employee_id (BIGINT) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the HR investigator or case manager assigned to investigate and resolve the grievance. Links to the employee master record. | Column tertiary_workforce_employee_id (BIGINT) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the grievance, including the nature of the complaint, circumstances, and impact on the complainant. | Column complaint_description (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Taken' ;
    rdfs:comment 'Type of disciplinary action taken against the respondent if the grievance was substantiated. | Column disciplinary_action_taken (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyName rdf:type rdf:Property ;
    rdfs:label 'External Agency Name' ;
    rdfs:comment 'Name of the external agency to which the grievance was reported (e.g., EEOC, OSHA, state labor department). | Column external_agency_name (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyReportedFlag rdf:type rdf:Property ;
    rdfs:label 'External Agency Reported Flag' ;
    rdfs:comment 'Indicates whether the grievance was also reported to an external regulatory or enforcement agency such as EEOC, OSHA, or state labor board. | Column external_agency_reported_flag (BOOLEAN) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Status' ;
    rdfs:comment 'Current lifecycle status of the grievance case in the investigation and resolution workflow. | Column grievance_status (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Physical or virtual location where the alleged incident occurred (e.g., studio, office, remote work, production site). | Column incident_location (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEndDate rdf:type rdf:Property ;
    rdfs:label 'Investigation End Date' ;
    rdfs:comment 'The date when the investigation was completed and findings were documented. | Column investigation_end_date (DATE) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Summary of the investigation findings, evidence collected, witness statements, and conclusions reached by the investigator. | Column investigation_findings (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'The date when the formal investigation of the grievance commenced. | Column investigation_start_date (DATE) in workforce.workforce_grievance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether legal counsel was engaged by either party during the grievance process. | Column legal_counsel_involved_flag (BOOLEAN) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the resolution actions taken, corrective measures implemented, and any remediation provided to the complainant. | Column resolution_description (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Classification of the respondent entity: individual employee, manager, department, organization-level, or external party. | Column respondent_type (STRING) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retaliationReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Retaliation Reported Flag' ;
    rdfs:comment 'Indicates whether the complainant reported retaliation following the filing of the grievance. | Column retaliation_reported_flag (BOOLEAN) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Union Involved Flag' ;
    rdfs:comment 'Indicates whether a labor union was involved in the grievance filing or resolution process. | Column union_involved_flag (BOOLEAN) in workforce.workforce_grievance' ;
    rdfs:domain ind:WorkforceGrievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Unique identifier for the headcount plan record. Primary key for the headcount plan entity. | Column headcount_plan_id (BIGINT) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisedHeadcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Revised Headcount Plan Id' ;
    rdfs:comment 'Self-referencing FK on headcount_plan (revised_headcount_plan_id) | Column revised_headcount_plan_id (BIGINT) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeadcountPlan .

ind:approvedFteCount rdf:type rdf:Property ;
    rdfs:label 'Approved Fte Count' ;
    rdfs:comment 'The approved target headcount expressed in Full-Time Equivalent (FTE) units for this org unit, job family, and fiscal year. Represents the authorized staffing level approved by finance and executive leadership. | Column approved_fte_count (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attritionAssumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Attrition Assumption Percentage' ;
    rdfs:comment 'The assumed annual attrition rate (as a percentage) used in workforce planning for this org unit and job family. Informs net hiring targets and replacement planning. | Column attrition_assumption_percentage (DECIMAL(5,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorFteCount rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Count' ;
    rdfs:comment 'The planned or approved headcount for contractors and contingent workers expressed in FTE units. Tracked separately from permanent employee FTE for total workforce visibility. | Column contractor_fte_count (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Role Flag' ;
    rdfs:comment 'Indicates whether this headcount plan record covers critical or hard-to-fill roles that require special attention in workforce planning and talent acquisition. True if critical; False otherwise. | Column critical_role_flag (BOOLEAN) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentFilledFte rdf:type rdf:Property ;
    rdfs:label 'Current Filled Fte' ;
    rdfs:comment 'The current actual headcount in FTE units as of the plan snapshot date. Used to calculate variance against approved FTE and identify open capacity. | Column current_filled_fte (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityHiringTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversity Hiring Target Percentage' ;
    rdfs:comment 'The target percentage of new hires from underrepresented groups for this org unit and job family. Supports diversity, equity, and inclusion (DEI) goals and regulatory compliance. | Column diversity_hiring_target_percentage (DECIMAL(5,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internFteCount rdf:type rdf:Property ;
    rdfs:label 'Intern Fte Count' ;
    rdfs:comment 'The planned or approved headcount for interns and temporary student workers expressed in FTE units. Supports talent pipeline and early career program planning. | Column intern_fte_count (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netHiringTarget rdf:type rdf:Property ;
    rdfs:label 'Net Hiring Target' ;
    rdfs:comment 'The net number of new hires required to achieve the approved FTE count after accounting for attrition and current filled FTE. Calculated as (approved_fte_count - current_filled_fte + expected_attrition). | Column net_hiring_target (INT) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openRequisitionCount rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count' ;
    rdfs:comment 'The number of open job requisitions currently in the recruitment pipeline for this org unit and job family. Tracks active hiring efforts against the approved plan. | Column open_requisition_count (INT) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Status' ;
    rdfs:comment 'The current approval status of this headcount plan record in the budget and planning workflow. Tracks progression from draft through executive approval. | Column plan_approval_status (STRING) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective End Date' ;
    rdfs:comment 'The date through which this headcount plan remains effective. Typically aligns with the end of the fiscal year or planning period. Null indicates an open-ended plan. | Column plan_effective_end_date (DATE) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Start Date' ;
    rdfs:comment 'The date from which this headcount plan becomes effective. Typically aligns with the start of the fiscal year or the beginning of a planning period. | Column plan_effective_start_date (DATE) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and commentary on this headcount plan record. Captures business context, assumptions, constraints, or special considerations for workforce planning. | Column plan_notes (STRING) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersionCode rdf:type rdf:Property ;
    rdfs:label 'Plan Version Code' ;
    rdfs:comment 'Version identifier for the headcount plan (e.g., FY2024-V1, FY2024-V2-REVISED). Supports multiple iterations of the annual plan as revisions are made during budget cycles. | Column plan_version_code (STRING) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'The business scenario or strategic context for this headcount plan (e.g., Baseline, Growth, Cost Reduction, Restructuring, Merger Integration). Supports scenario-based workforce planning. | Column planning_scenario (STRING) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkFteCount rdf:type rdf:Property ;
    rdfs:label 'Remote Work Fte Count' ;
    rdfs:comment 'The number of FTEs in this plan designated for remote or hybrid work arrangements. Supports workforce flexibility planning and real estate optimization. | Column remote_work_fte_count (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Required Flag' ;
    rdfs:comment 'Indicates whether roles in this headcount plan require formal succession planning due to business criticality or leadership pipeline needs. True if succession planning is required; False otherwise. | Column succession_plan_required_flag (BOOLEAN) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionFteCount rdf:type rdf:Property ;
    rdfs:label 'Union Fte Count' ;
    rdfs:comment 'The number of FTEs in this plan covered by collective bargaining agreements or union membership. Critical for labor relations planning and compliance in broadcast operations. | Column union_fte_count (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFte rdf:type rdf:Property ;
    rdfs:label 'Variance Fte' ;
    rdfs:comment 'The variance between approved FTE count and current filled FTE. Calculated as (approved_fte_count - current_filled_fte). Positive values indicate unfilled capacity; negative values indicate overstaffing. | Column variance_fte (DECIMAL(10,2)) in workforce.headcount_plan' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Unique identifier for the job requisition record. Primary key for the requisition entity. | Column requisition_id (BIGINT) in workforce.requisition' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:primaryRequisitionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Requisition Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this requisition, typically a senior manager or HR director. | Column requisition_approved_by_employee_id (BIGINT) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:replacementRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Requisition Id' ;
    rdfs:comment 'Self-referencing FK on requisition (replacement_requisition_id) | Column replacement_requisition_id (BIGINT) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:tertiaryRequisitionRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Requisition Recruiter Employee Id' ;
    rdfs:comment 'Reference to the HR recruiter or talent acquisition specialist assigned to manage this requisition. | Column requisition_recruiter_employee_id (BIGINT) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedHeadcountSource rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount Source' ;
    rdfs:comment 'Source of headcount authorization indicating whether the position is funded from annual budget, supplemental budget, backfill allocation, reallocation, or new approval. | Column approved_headcount_source (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityEligible rdf:type rdf:Property ;
    rdfs:label 'Equity Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible for equity compensation such as stock options or restricted stock units. | Column equity_eligible (BOOLEAN) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfOpenings rdf:type rdf:Property ;
    rdfs:label 'Number Of Openings' ;
    rdfs:comment 'Total number of positions to be filled under this requisition. Supports bulk hiring for multiple identical roles. | Column number_of_openings (INT) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingsFilled rdf:type rdf:Property ;
    rdfs:label 'Openings Filled' ;
    rdfs:comment 'Number of positions that have been successfully filled and closed under this requisition. | Column openings_filled (INT) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingDescription rdf:type rdf:Property ;
    rdfs:label 'Posting Description' ;
    rdfs:comment 'Full job description text used in external job postings, including responsibilities, qualifications, and company information. | Column posting_description (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'Public-facing job title used in job postings and external advertisements, which may differ from internal job profile title. | Column posting_title (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether the position allows remote or hybrid work arrangements. | Column remote_work_eligible (BOOLEAN) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business-facing unique requisition identifier used in HR systems and communications. Externally visible requisition code. | Column requisition_number (STRING) in workforce.requisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition indicating its stage in the talent acquisition pipeline. [ENUM-REF-CANDIDATE: draft|pending_approval|open|on_hold|filled|cancelled|closed — 7 candidates stripped; promote to reference product] | Column requisition_status (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition indicating whether it is for a new position, backfill of a departed employee, replacement, contract-to-hire conversion, internal transfer, or seasonal hire. | Column requisition_type (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual salary or hourly rate for the position, defining the upper bound of the compensation band. | Column salary_range_maximum (DECIMAL(15,2)) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual salary or hourly rate for the position, used for candidate expectations and budget planning. | Column salary_range_minimum (DECIMAL(15,2)) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether the position requires a security clearance or background check due to access to sensitive broadcast content or systems. | Column security_clearance_required (BOOLEAN) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of authorized sourcing channels for candidate recruitment (e.g., internal job board, LinkedIn, agency, referral, campus recruiting). | Column sourcing_channels (STRING) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired start date for the new hire to begin employment. Used for workforce planning and onboarding preparation. | Column target_start_date (DATE) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionPosition rdf:type rdf:Property ;
    rdfs:label 'Union Position' ;
    rdfs:comment 'Indicates whether the position is covered by a collective bargaining agreement or union contract. | Column union_position (BOOLEAN) in workforce.requisition' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantId rdf:type rdf:Property ;
    rdfs:label 'Applicant Id' ;
    rdfs:comment 'Unique identifier for each job applicant who has applied to a Media Broadcasting requisition. Primary key for the applicant master record. | Column applicant_id (BIGINT) in workforce.applicant' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Applicant .

ind:referralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Referral Employee Id' ;
