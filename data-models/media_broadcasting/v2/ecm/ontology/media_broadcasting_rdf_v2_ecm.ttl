ind:capacityThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Threshold Percentage' ;
    rdfs:comment 'The utilization percentage threshold that triggers capacity expansion or optimization actions. Typically set based on Service Level Agreement (SLA) requirements and operational best practices (e.g., 80% for storage, 70% for network to maintain performance headroom). | Column capacity_threshold_percentage (DECIMAL(5,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'The unit of measurement for capacity and utilization values. TB/PB for storage (terabytes/petabytes), Gbps/Mbps for network bandwidth, cores/vCPU for compute, studio_hours for production facility time, channels for playout capacity, streams for concurrent delivery capacity, transcode_hours for encoding capacity. [ENUM-REF-CANDIDATE: tb|pb|gbps|mbps|cores|vcpu|studio_hours|channels|streams|transcode_hours — 10 candidates stripped; promote to reference product] | Column capacity_unit (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityValue rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Value' ;
    rdfs:comment 'The current total capacity available in the infrastructure domain, expressed in the unit specified by capacity_unit (e.g., terabytes for storage, gigabits per second for network, compute cores for processing). | Column current_capacity_value (DECIMAL(18,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Percentage' ;
    rdfs:comment 'The current utilization expressed as a percentage of total available capacity (current_utilization_value / current_capacity_value * 100). Key metric for determining proximity to capacity thresholds. | Column current_utilization_percentage (DECIMAL(5,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationValue rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Value' ;
    rdfs:comment 'The current amount of capacity being consumed or utilized, expressed in the same unit as current_capacity_value. | Column current_utilization_value (DECIMAL(18,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'The sensitivity classification of this capacity plan document. Public: shareable externally; Internal: for employee access only; Confidential: restricted to authorized personnel; Restricted: highly sensitive, executive access only. | Column data_classification (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex Amount' ;
    rdfs:comment 'The estimated capital expenditure required to implement the recommended action, including hardware, software, installation, and integration costs. Critical for budget planning and investment approval processes. | Column estimated_capex_amount (DECIMAL(15,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedOpexAnnualAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Opex Annual Amount' ;
    rdfs:comment 'The estimated annual operating expenditure impact of the recommended action, including maintenance, support, power, cooling, and licensing costs. Used for total cost of ownership (TCO) analysis. | Column estimated_opex_annual_amount (DECIMAL(15,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationPriority rdf:type rdf:Property ;
    rdfs:label 'Implementation Priority' ;
    rdfs:comment 'The urgency level for implementing the capacity plan. Critical: immediate action required to prevent service disruption; High: needed within current quarter; Medium: planned for next quarter; Low: long-term strategic initiative. | Column implementation_priority (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureDomain rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Domain' ;
    rdfs:comment 'The category of broadcast infrastructure being assessed in this capacity plan. Network covers transmission bandwidth and connectivity; Storage covers Media Asset Management (MAM) and archive systems; Compute covers processing and rendering resources; Studio covers production facilities and equipment; Transmission covers broadcast towers and signal distribution; CDN covers Content Delivery Network edge caching; Playout covers channel automation systems; Encoding covers transcoding and ABR (Adaptive Bitrate Streaming) infrastructure. [ENUM-REF-CANDIDATE: network|storage|compute|studio|transmission|cdn|mam|playout|encoding — 9 candidates stripped; promote to reference product] | Column infrastructure_domain (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The date when this capacity plan was last reviewed and validated by the plan owner or governance committee. Used to ensure plans remain current and aligned with business needs. | Column last_reviewed_date (DATE) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planOwner rdf:type rdf:Property ;
    rdfs:label 'Plan Owner' ;
    rdfs:comment 'Name or identifier of the individual responsible for developing, maintaining, and executing this capacity plan. Typically an Infrastructure Manager, Network Operations Center (NOC) Manager, or Engineering Director. | Column plan_owner (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planOwnerDepartment rdf:type rdf:Property ;
