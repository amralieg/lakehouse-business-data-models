    rdfs:comment 'Job title or role of the internal signatory (e.g., \'SVP Content Acquisition\', \'Chief Business Officer\'). | Column internal_signatory_title (STRING) in partner.deal_amendment' ;
    rdfs:domain ind:DealAmendment ;
    rdf:type owl:DatatypeProperty ;
