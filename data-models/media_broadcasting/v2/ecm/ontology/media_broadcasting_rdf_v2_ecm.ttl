    rdfs:range xsd:boolean .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'Full name of the regulation, law, or standard that mandates this obligation (e.g., Communications Act Section 73, GDPR Article 30, SOX Section 404). | Column regulation_name (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference Number' ;
    rdfs:comment 'Official citation or reference number of the regulation (e.g., 47 CFR 73.3526, GDPR Art. 30, SOX §404). | Column regulation_reference_number (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicyDocument rdf:type rdf:Property ;
    rdfs:label 'Related Policy Document' ;
    rdfs:comment 'Reference to internal policy, procedure, or guideline document that governs how this obligation is implemented and monitored. | Column related_policy_document (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Primary key for incident | Column incident_id (BIGINT) in compliance.incident' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_change. Business justification: Compliance incidents may be triggered by new regulatory requirements that the organization has not yet implemented. This FK links incidents to the regulatory change that introduced the requirement, su | Column regulatory_change_id (BIGINT) in compliance.incident' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:affectedRegulation rdf:type rdf:Property ;
