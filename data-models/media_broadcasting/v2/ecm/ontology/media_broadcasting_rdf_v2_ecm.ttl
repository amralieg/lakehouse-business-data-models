    rdfs:comment 'Reference to the parent series to which this episode belongs. Links episode to its series container. | Column content_series_id (BIGINT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:masterMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Master Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Broadcast playout and VOD distribution require direct lookup of the master media asset file for each episode. Traffic systems and playout automation depend on episode-to-asset mapping for scheduling a | Column master_media_asset_id (BIGINT) in mediaasset.content_episode' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:breakingNewsFlag rdf:type rdf:Property ;
    rdfs:label 'Breaking News Flag' ;
    rdfs:comment 'Indicates if episode is breaking news content per VREQ-019' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastCount rdf:type rdf:Property ;
    rdfs:label 'Broadcast Count' ;
    rdfs:comment 'Total number of times this episode has been broadcast on linear television. Used for residuals calculation and syndication rights management. | Column broadcast_count (INT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Advisory' ;
    rdfs:comment 'Specific content warnings or advisories for viewer guidance (e.g., violence, language, adult themes). Displayed in Electronic Program Guide (EPG) and Video On Demand (VOD) interfaces. | Column content_advisory (STRING) in content.content_episode' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrIdentifier rdf:type rdf:Property ;
    rdfs:label 'Eidr Identifier' ;
    rdfs:comment 'Globally unique identifier for the episode registered with the Entertainment Identifier Registry. Enables universal content identification across distribution platforms and rights management systems. | Column eidr_identifier (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeStatus rdf:type rdf:Property ;
    rdfs:label 'Episode Status' ;
    rdfs:comment 'Current lifecycle state of the episode. Determines availability for scheduling, playout automation, and distribution to Over-The-Top (OTT) platforms. | Column episode_status (STRING) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'Classification of the episode format and purpose within the series. Affects scheduling strategy, promotional treatment, and rights valuation. [ENUM-REF-CANDIDATE: standard|special|pilot|finale|recap|bonus|behind_the_scenes — 7 candidates stripped; promote to reference product] | Column episode_type (STRING) in content.content_episode' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicCueSheetSubmitted rdf:type rdf:Property ;
    rdfs:label 'Music Cue Sheet Submitted' ;
    rdfs:comment 'Indicates whether the music cue sheet has been submitted for royalty collection. Required for music rights compliance and royalty distribution. | Column music_cue_sheet_submitted (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-3 three-letter code for the primary audio language of the episode. Used for content cataloging, rights clearance, and distribution targeting. | Column primary_language (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCode rdf:type rdf:Property ;
    rdfs:label 'Production Code' ;
    rdfs:comment 'Internal production identifier assigned during content creation. Used for tracking production workflow, post-production tasks, and archival reference. | Column production_code (STRING) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunFlag rdf:type rdf:Property ;
    rdfs:label 'Rerun Flag' ;
    rdfs:comment 'Indicates whether this broadcast is a rerun. Affects advertising rates, Cost Per Rating Point (CPRP) calculations, and residuals payments to talent. | Column rerun_flag (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Current status of rights clearance for broadcast and distribution. Determines whether episode can be scheduled for playout or made available on Over-The-Top (OTT) platforms. | Column rights_clearance_status (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeWithAdsSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime With Ads Seconds' ;
    rdfs:comment 'Total broadcast duration including commercial ad breaks. Used for linear scheduling and daypart planning. | Column runtime_with_ads_seconds (INT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlesAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitles Available' ;
    rdfs:comment 'Indicates whether subtitle tracks are available for this episode. Supports international distribution and localization strategies. | Column subtitles_available (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoResolution rdf:type rdf:Property ;
    rdfs:label 'Video Resolution' ;
    rdfs:comment 'Maximum video resolution available for this episode. Determines distribution channel eligibility and Adaptive Bitrate Streaming (ABR) profile selection. | Column video_resolution (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodAvailableFromDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available From Date' ;
    rdfs:comment 'Date when the episode becomes available on Video On Demand (VOD) platforms. Part of windowing strategy and rights holdback management. | Column vod_available_from_date (DATE) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vodAvailableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available Until Date' ;
    rdfs:comment 'Date when the episode is removed from Video On Demand (VOD) platforms. Enforces rights windows and exclusivity periods. | Column vod_available_until_date (DATE) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Primary key for version | Column version_id (BIGINT) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionDrmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Distribution Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to distribution.drm_policy. Business justification: Each content version is protected by specific DRM policy (Widevine L1, HDCP 2.2 requirements). Required for rights enforcement, device compatibility validation, and studio compliance in premium conten | Column distribution_drm_policy_id (BIGINT) in distribution.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:encoderConfigId rdf:type rdf:Property ;
    rdfs:label 'Encoder Config Id' ;
    rdfs:comment 'Foreign key linking to technology.encoder_config. Business justification: Each content version is encoded using specific encoder configurations. QC workflows, bitrate ladder validation, delivery troubleshooting, and platform certification require knowing which encoder profi | Column encoder_config_id (BIGINT) in technology.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EncoderConfig .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_grant. Business justification: Version-specific grants (4K rights vs HD rights, dubbed vs subtitled) are tracked separately in modern distribution. Clearance systems must validate that the specific version has an active grant. | Column grant_id (BIGINT) in rights.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when this version was approved for distribution and playout. | Column approved_timestamp (TIMESTAMP) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this version was moved to long-term archive storage. | Column archived_timestamp (TIMESTAMP) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'Audio compression codec used for this version (e.g., \'AAC\', \'AC-3\', \'E-AC-3\', \'Dolby Atmos\', \'DTS\'). | Column audio_codec (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioTrackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Track Configuration' ;
    rdfs:comment 'Comma-separated list of audio track languages and types available in this version (e.g., \'en:stereo,es:5.1,fr:stereo,en:descriptive\'). | Column audio_track_configuration (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastSafe rdf:type rdf:Property ;
    rdfs:label 'Broadcast Safe' ;
    rdfs:comment 'Indicates whether this version has been certified as broadcast-safe, meeting technical standards for linear transmission (audio levels, video levels, closed captioning). | Column broadcast_safe (BOOLEAN) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash checksum of the version file, used for integrity verification during transfer and archival. | Column checksum_md5 (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorSpace rdf:type rdf:Property ;
    rdfs:label 'Color Space' ;
    rdfs:comment 'Color space standard used for this version (Rec. 709, Rec. 2020, DCI-P3, sRGB). | Column color_space (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editorialWorkflowState rdf:type rdf:Property ;
    rdfs:label 'Editorial Workflow State' ;
    rdfs:comment 'Current editorial workflow state (draft/assigned/filed/edited/cleared/published) per VREQ-019' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Container file format for this version (e.g., \'MP4\', \'MXF\', \'MOV\', \'TS\', \'WebM\'). | Column file_format (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Total file size of this version in bytes, used for storage planning and delivery bandwidth estimation. | Column file_size_bytes (BIGINT) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'Frame rate of this version in frames per second (e.g., 23.98, 24.00, 25.00, 29.97, 30.00, 50.00, 59.94, 60.00). | Column frame_rate (DECIMAL(5,2)) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isrcCode rdf:type rdf:Property ;
    rdfs:label 'Isrc Code' ;
    rdfs:comment 'International Standard Recording Code for music or audio content versions, enabling tracking and royalty distribution. | Column isrc_code (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label identifying this version (e.g., \'Theatrical Cut\', \'Director\'s Cut\', \'Broadcast Safe\', \'Spanish Dub\', \'UK Censored\'). | Column label (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639 two or three-letter code for the primary audio language of this version (e.g., \'en\', \'es\', \'fr\'). | Column primary_language_code (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Date' ;
    rdfs:comment 'Date when quality control review was completed for this version. | Column qc_completed_date (DATE) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Quality control review status for this version, indicating whether it has passed technical and content quality checks. | Column qc_status (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution classification for this version (SD, HD 720p, HD 1080p, UHD 4K, UHD 8K). | Column resolution (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeDeltaSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Delta Seconds' ;
    rdfs:comment 'Difference in runtime (in seconds) between this version and the master version. Positive values indicate longer runtime, negative indicate shorter. | Column runtime_delta_seconds (INT) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage location identifier where this version is archived (e.g., tape library ID, cloud bucket path, MAM archive reference). | Column storage_location (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleLanguages rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for subtitle tracks included in this version (e.g., \'en,es,fr,de\'). | Column subtitle_languages (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlatform rdf:type rdf:Property ;
    rdfs:label 'Target Platform' ;
    rdfs:comment 'Distribution platform or window this version is optimized for (e.g., linear broadcast, SVOD, AVOD, theatrical). [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|home_video|syndication|fast|mvpd|vmvpd — 10 candidates stripped; promote to reference product] | Column target_platform (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritory rdf:type rdf:Property ;
    rdfs:label 'Target Territory' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary geographic territory this version is intended for (e.g., USA, GBR, FRA). | Column target_territory (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the version indicating its readiness for distribution and playout. [ENUM-REF-CANDIDATE: draft|in_production|qc_pending|approved|active|archived|deprecated|rejected — 8 candidates stripped; promote to reference product] | Column version_status (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version type indicating the nature of the edit or adaptation. [ENUM-REF-CANDIDATE: theatrical|broadcast|director|extended|unrated|censored|dubbed|subtitled|localized|preview|trailer — 11 candidates stripped; promote to reference product] | Column version_type (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'Video compression codec used for this version (e.g., \'H.264\', \'H.265/HEVC\', \'VP9\', \'AV1\', \'MPEG-2\'). | Column video_codec (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGenreId rdf:type rdf:Property ;
    rdfs:label 'Parent Genre Id' ;
    rdfs:comment 'Reference to the parent genre in the hierarchical taxonomy, enabling multi-level classification such as Drama > Legal Drama or Sports > Football. Null for top-level genres. | Column parent_genre_id (BIGINT) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:adPodCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Compatibility' ;
    rdfs:comment 'Indicates whether content in this genre is compatible with Dynamic Ad Insertion (DAI) and ad pod placement. False for genres requiring uninterrupted viewing (e.g., live sports critical moments, news breaking coverage). | Column ad_pod_compatibility (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableContentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Content Types' ;
    rdfs:comment 'Comma-separated list of content types to which this genre applies (e.g., series, film, clip, live_event, news_segment, music_video). Enables content-type-specific genre filtering. | Column applicable_content_types (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Archive Retention Policy' ;
    rdfs:comment 'Digital asset archival retention policy for content in this genre. Permanent retention for high-value evergreen genres; short-term for time-sensitive news and event content. | Column archive_retention_policy (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avodMonetizationPotential rdf:type rdf:Property ;
    rdfs:label 'Avod Monetization Potential' ;
    rdfs:comment 'Revenue generation potential for this genre on Advertising-Supported Video On Demand (AVOD) platforms, based on Cost Per Mille (CPM) rates and advertiser demand. High-potential genres command premium ad rates. | Column avod_monetization_potential (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreCode rdf:type rdf:Property ;
    rdfs:label 'Genre Code' ;
    rdfs:comment 'Short alphanumeric code representing the genre for system integration and Electronic Program Guide (EPG) feeds. Used as a business key across scheduling, distribution, and metadata systems. | Column genre_code (STRING) in content.genre' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartAffinity rdf:type rdf:Property ;
    rdfs:label 'Daypart Affinity' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts where this genre typically performs best (e.g., prime_time, late_night, early_morning, daytime, weekend). Informs program scheduling and playout automation strategies. | Column daypart_affinity (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreDescription rdf:type rdf:Property ;
    rdfs:label 'Genre Description' ;
    rdfs:comment 'Detailed textual description of the genre, including defining characteristics, typical content examples, and audience expectations. Used for editorial guidance and content acquisition briefings. | Column genre_description (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this genre classification was retired or superseded. Null for currently active genres. Used for historical content classification and reporting continuity. | Column effective_end_date (DATE) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this genre classification became effective and available for use in content metadata and scheduling systems. | Column effective_start_date (DATE) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrGenreMapping rdf:type rdf:Property ;
    rdfs:label 'Eidr Genre Mapping' ;
    rdfs:comment 'Mapping to Entertainment Identifier Registry (EIDR) genre taxonomy for cross-industry content identification and rights management interoperability. | Column eidr_genre_mapping (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelApplicability rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Applicability' ;
    rdfs:comment 'Indicates whether this genre is suitable for Free Ad-Supported Streaming Television (FAST) linear channel programming. FAST channels require genres with deep catalog availability and consistent audience appeal. | Column fast_channel_applicability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestrictionApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Applicability' ;
    rdfs:comment 'Indicates whether content in this genre is subject to geographic blackout restrictions or regional licensing constraints. Common for sports genres with territorial rights and retransmission consent agreements. | Column geographic_restriction_applicability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabContentCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category' ;
    rdfs:comment 'Mapping to Interactive Advertising Bureau (IAB) content taxonomy for programmatic advertising and contextual ad targeting. Enables Share of Voice (SOV) optimization and Cost Per Mille (CPM) rate alignment. | Column iab_content_category (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this genre is currently active and available for content classification. Inactive genres are retained for historical content but not used for new acquisitions. | Column is_active (BOOLEAN) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this genre record was last updated. Used for change tracking and metadata synchronization across Electronic Program Guide (EPG), Media Asset Management (MAM), and distribution systems. | Column last_modified_timestamp (TIMESTAMP) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linearBroadcastSuitability rdf:type rdf:Property ;
    rdfs:label 'Linear Broadcast Suitability' ;
    rdfs:comment 'Indicates whether this genre is suitable for traditional linear scheduled broadcasting. Some genres (e.g., interactive, choose-your-own-adventure) are non-linear only. | Column linear_broadcast_suitability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationPriority rdf:type rdf:Property ;
    rdfs:label 'Localization Priority' ;
    rdfs:comment 'Priority level for content localization (dubbing, subtitling, cultural adaptation) for this genre. High-priority genres justify investment in multi-language versions for international distribution. | Column localization_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentPriority rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Priority' ;
    rdfs:comment 'Priority level for metadata enrichment and tagging in Media Asset Management (MAM) systems. Critical genres require comprehensive metadata for content discovery and personalization. | Column metadata_enrichment_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpaRatingApplicability rdf:type rdf:Property ;
    rdfs:label 'Mpa Rating Applicability' ;
    rdfs:comment 'Comma-separated list of Motion Picture Association (MPA) ratings typically associated with this genre (e.g., G, PG, PG-13, R, NC-17). Used for content clearance and daypart scheduling compliance. | Column mpa_rating_applicability (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreName rdf:type rdf:Property ;
    rdfs:label 'Genre Name' ;
    rdfs:comment 'Full display name of the genre as presented to audiences in Electronic Program Guides (EPG), streaming platform interfaces, and content discovery systems. | Column genre_name (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenGenreCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Genre Code' ;
    rdfs:comment 'Nielsen Media Research genre classification code used for audience measurement, ratings analysis, and Gross Rating Point (GRP) reporting alignment. | Column nielsen_genre_code (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottPlatformPriority rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Priority' ;
    rdfs:comment 'Priority level for featuring this genre on Over-The-Top (OTT) streaming platforms and Video On Demand (VOD) services. High priority genres receive prominent placement in content discovery and recommendation engines. | Column ott_platform_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Flag' ;
    rdfs:comment 'Indicates whether content in this genre typically requires parental guidance warnings or viewer discretion advisories. Used for compliance with Federal Communications Commission (FCC) broadcast standards and Children\'s Online Privacy Protection Act (COPPA) requirements. | Column parental_guidance_flag (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Svod Performance Tier' ;
    rdfs:comment 'Performance classification for this genre on Subscription Video On Demand (SVOD) platforms. Premium genres drive subscriber acquisition and reduce churn rate; catalog genres provide library depth. | Column svod_performance_tier (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibility rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligibility' ;
    rdfs:comment 'Indicates whether content in this genre is typically eligible for syndication to multiple outlets and resale. Used in rights and royalties management and windowing strategy planning. | Column syndication_eligibility (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Hierarchical level of the genre within the taxonomy. Primary represents top-level genres, secondary represents sub-genres, and tertiary represents granular classifications. | Column genre_tier (STRING) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Internal notes and guidelines for content producers, schedulers, and metadata specialists on proper application of this genre classification. Includes edge cases and disambiguation rules. | Column usage_notes (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingId rdf:type rdf:Property ;
    rdfs:label 'Rating Id' ;
    rdfs:comment 'Primary key for rating | Column rating_id (BIGINT) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulatory Obligation Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'The current status of any appeal filed by the content producer or distributor to challenge or modify the assigned rating classification. | Column appeal_status (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The official name of the regulatory or industry body that issued the rating (e.g., Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft). | Column body (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate or reference number issued by the rating body upon classification approval. Used for audit and compliance verification. | Column certificate_number (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingCode rdf:type rdf:Property ;
    rdfs:label 'Rating Code' ;
    rdfs:comment 'The official rating classification code assigned to the content (e.g., G, PG, PG-13, R, NC-17 for MPA film ratings; TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA for TV Parental Guidelines; or international equivalents such as BBFC, FSK, OFLC codes). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product] | Column rating_code (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorDrugUse rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Drug Use' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for drug use or substance abuse. | Column content_descriptor_drug_use (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorFear rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Fear' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for frightening or intense scenes that may be unsuitable for younger audiences. | Column content_descriptor_fear (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Language' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for strong or offensive language. | Column content_descriptor_language (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorNudity rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Nudity' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for nudity or sexual content. | Column content_descriptor_nudity (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorViolence rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Violence' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for violence or intense action. | Column content_descriptor_violence (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Description' ;
    rdfs:comment 'Detailed textual description of the rating, including the rationale for the classification and any additional context provided by the rating body (e.g., \'Rated PG-13 for intense sequences of violence and action, some suggestive content, and brief strong language\'). | Column rating_description (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which this rating classification became effective and applicable to the content asset. | Column effective_date (DATE) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this rating classification expires or is no longer valid. Null if the rating does not expire. | Column expiration_date (DATE) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'The minimum recommended or legally mandated age (in years) for viewers of content with this rating. Null if no specific age restriction applies. | Column minimum_age (INT) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional internal notes or comments regarding the rating classification, including any special considerations, conditional approvals, or compliance requirements. | Column notes (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this rating is used to enforce parental control features on linear broadcast, OTT (Over-The-Top), or MVPD (Multichannel Video Programming Distributor) platforms. | Column parental_control_enabled (BOOLEAN) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean flag indicating whether the rating is legally mandated by a regulatory body (e.g., FCC, Ofcom) or is a voluntary industry classification. | Column regulatory_mandate_flag (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating body for classification review. | Column submission_date (DATE) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'The rating system or classification framework under which the rating was assigned (e.g., MPA for Motion Picture Association, TVPG for TV Parental Guidelines, BBFC for British Board of Film Classification, FSK for Freiwillige Selbstkontrolle der Filmwirtschaft, OFLC for Australian Classification Board, CBFC for Central Board of Film Certification India). | Column system (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or territory code indicating the geographic jurisdiction where this rating applies (e.g., USA, GBR, DEU, AUS, IND). | Column territory_code (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the rating record, incremented when the rating is re-evaluated or updated due to content edits, appeals, or regulatory changes. | Column version (INT) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationId rdf:type rdf:Property ;
    rdfs:label 'Localization Id' ;
    rdfs:comment 'Unique identifier for the localization work product record. | Column localization_id (BIGINT) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Localization .

ind:complianceContentRatingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Content Rating Id' ;
    rdfs:comment 'Foreign key linking to compliance.content_rating. Business justification: Localized content versions require territory-specific ratings (BBFC for UK, FSK for Germany, MPAA for US). Localization workflow must track rating submission, approval, and certificate for regulatory  | Column compliance_content_rating_id (BIGINT) in compliance.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentRating .

ind:localizedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Localized Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Localized audio tracks and subtitle files are delivered as media assets. Distribution workflows require linking localization records to their delivered asset files for QC, versioning, and platform del | Column localized_media_asset_id (BIGINT) in mediaasset.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:ottPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Localizations are prepared for specific platform technical specs (Netflix TDF, iTunes metadata format). Platform-specific subtitle formats, audio track configurations, and metadata requirements drive  | Column ott_platform_id (BIGINT) in distribution.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Reference to the external vendor or internal facility performing the localization work. | Column partner_id (BIGINT) in partner.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:titleVersionId rdf:type rdf:Property ;
    rdfs:label 'Title Version Id' ;
    rdfs:comment 'Reference to the specific title version being localized. | Column title_version_id (BIGINT) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:voiceTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Voice Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Dubbing and voice localization require tracking which talent performed the localized version for residual payments, credit attribution, and guild reporting. Essential for international content distrib | Column voice_talent_profile_id (BIGINT) in talent.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:accessibilityStandardMet rdf:type rdf:Property ;
    rdfs:label 'Accessibility Standard Met' ;
    rdfs:comment 'Specific accessibility standard that the localization work product complies with (e.g., WCAG 2.1 AA, FCC CVAA). | Column accessibility_standard_met (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the localization work product was delivered by the vendor or internal team. | Column actual_delivery_date (DATE) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the localization work product received final approval for distribution. | Column approval_timestamp (TIMESTAMP) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual or role who provided final approval for the localization work product. | Column approved_by_name (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFilePath rdf:type rdf:Property ;
    rdfs:label 'Asset File Path' ;
    rdfs:comment 'Storage location or URI path to the delivered localization asset file in the Media Asset Management (MAM) system or Content Delivery Network (CDN). | Column asset_file_path (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total number of characters in the subtitle or metadata translation work product, used for billing and capacity planning. | Column character_count (INT) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether the localization meets regulatory compliance requirements for the target territory (e.g., local content quotas, language laws, accessibility standards). | Column compliance_certification_flag (BOOLEAN) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for this localization work product, including vendor fees, studio costs, and internal labor. | Column cost_amount (DECIMAL(15,2)) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the localization cost amount. | Column currency_code (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total runtime duration in minutes of the content being localized, relevant for dubbing and subtitling scope. | Column duration_minutes (DECIMAL(10,2)) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationStatus rdf:type rdf:Property ;
    rdfs:label 'Localization Status' ;
    rdfs:comment 'Current workflow status of the localization work product. [ENUM-REF-CANDIDATE: ordered|in_progress|delivered|qc_review|approved|rejected|revision_required — 7 candidates stripped; promote to reference product] | Column localization_status (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizationType rdf:type rdf:Property ;
    rdfs:label 'Localization Type' ;
    rdfs:comment 'The type of localization work being performed on the content asset. | Column localization_type (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the localization work was ordered from the vendor or internal team. | Column order_date (DATE) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number issued to the localization vendor for this work product. | Column purchase_order_number (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Detailed notes and findings from the quality control review process, including any defects or issues identified. | Column qc_notes (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Boolean indicator of whether the localization work product passed quality control review. | Column qc_pass_flag (BOOLEAN) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qc Review Date' ;
    rdfs:comment 'Date when quality control review of the localization work product was completed. | Column qc_review_date (DATE) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewerName rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewer Name' ;
    rdfs:comment 'Name of the individual or team who performed the quality control review. | Column qc_reviewer_name (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason or description for why a revision of the localization work product was required. | Column revision_reason (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Contractually agreed or planned delivery date for the completed localization work product. | Column scheduled_delivery_date (DATE) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtitleFormat rdf:type rdf:Property ;
    rdfs:label 'Subtitle Format' ;
    rdfs:comment 'Technical format specification for subtitle files (SRT, TTML, WebVTT, etc.). [ENUM-REF-CANDIDATE: SRT|TTML|WebVTT|EBU-STL|SMPTE-TT|SCC|DFXP — 7 candidates stripped; promote to reference product] | Column subtitle_format (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Target Language Code' ;
    rdfs:comment 'ISO 639 language code for the target localization language (e.g., es-MX for Mexican Spanish, fr-CA for Canadian French). | Column target_language_code (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Target Territory Code' ;
    rdfs:comment 'ISO 3166 three-letter country code representing the target distribution territory for this localization. | Column target_territory_code (STRING) in content.localization' ;
    rdfs:domain ind:Localization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for this localization work product, supporting iterative revisions and updates. | Column version_number (STRING) in content.localization' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierId rdf:type rdf:Property ;
    rdfs:label 'Identifier Id' ;
    rdfs:comment 'Primary key for identifier | Column identifier_id (BIGINT) in content.identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentVersionId rdf:type rdf:Property ;
    rdfs:label 'Content Version Id' ;
    rdfs:comment 'Foreign key linking to content.version. Business justification: Identifiers like EIDR can be version-specific (different EIDR for theatrical vs broadcast version). Allows version-level identifier tracking. | Column content_version_id (BIGINT) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'Check digit or checksum component for identifier validation (used by ISAN, ISWC standards)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this identifier expires or is no longer valid. Nullable for identifiers that do not expire. | Column expiry_date (DATE) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'A URL or web link to the external registry or system where this identifier can be looked up or verified (e.g., EIDR registry lookup page, ISAN database). | Column external_reference_url (STRING) in content.identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Type of identifier standard: EIDR, ISAN, ISRC, ISWC, EBUCore, Dublin Core, TVAnytime' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this identifier is the primary or preferred identifier for the content asset within its type category. Used to prioritize identifiers when multiple exist. | Column is_primary (BOOLEAN) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'Indicates whether the identifier value has been validated against its standard pattern' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Is Validated Flag' ;
    rdfs:comment 'Indicates whether the identifier value has been validated against its standard pattern' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The organization, system, or registry that issued or assigned this identifier (e.g., Entertainment Identifier Registry, Dalet Galaxy MAM, distributor name, platform name). | Column issuing_authority (STRING) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Validated Timestamp' ;
    rdfs:comment 'Timestamp when the identifier was last validated against its standard' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:metadataSchemaRef rdf:type rdf:Property ;
    rdfs:label 'Metadata Schema Ref' ;
    rdfs:comment 'Reference to the XML/RDF schema or ontology definition for metadata standards like EBUCore, Dublin Core, TVAnytime' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namespaceUri rdf:type rdf:Property ;
    rdfs:label 'Namespace Uri' ;
    rdfs:comment 'RDF/OWL namespace URI for the identifier standard (e.g., http://www.ebu.ch/metadata/ontologies/ebucore for EBUCore alignment)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date on which this identifier was officially registered or assigned to the content asset by the issuing authority. | Column registration_date (DATE) in content.identifier' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registryUrl rdf:type rdf:Property ;
    rdfs:label 'Registry Url' ;
    rdfs:comment 'Direct URL link to the identifier entry in its authoritative registry (e.g., EIDR registry, ISAN database)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionEndpoint rdf:type rdf:Property ;
    rdfs:label 'Resolution Endpoint' ;
    rdfs:comment 'API or service endpoint URL for resolving the identifier to its metadata' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'The geographic or organizational scope of the identifier. Indicates whether the identifier is globally recognized, region-specific, platform-specific, or internal to the organization. | Column scope (STRING) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standard rdf:type rdf:Property ;
    rdfs:label 'Standard' ;
    rdfs:comment 'The industry standard classification for this identifier (e.g., EIDR, ISAN, ISRC, ISWC, EBUCore, Dublin Core, TVAnytime)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Name of the identifier standard: EIDR (Entertainment Identifier Registry), ISAN (International Standard Audiovisual Number), ISRC (International Standard Recording Code), ISWC (International Standard Musical Work Code), EBUCore (EBU Core Metadata Set), Dublin Core (Dublin Core Metadata Element Set), TVAnytime (TV-Anytime Metadata Specification)' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardNamespace rdf:type rdf:Property ;
    rdfs:label 'Standard Namespace' ;
    rdfs:comment 'Namespace URI for the identifier standard (e.g., EBUCore, Dublin Core, TVAnytime namespaces)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUri rdf:type rdf:Property ;
    rdfs:label 'Standard Uri' ;
    rdfs:comment 'URI or namespace reference for the identifier standard (e.g., EBU CCDM, Dublin Core namespace)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version of the identifier standard specification being used' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'The primary business context or use case for which this identifier is utilized (e.g., rights clearance, royalty calculation, metadata syndication to downstream platforms, distribution tracking, archival reference). | Column usage_context (STRING) in content.identifier' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Error message if identifier validation failed' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationPattern rdf:type rdf:Property ;
    rdfs:label 'Validation Pattern' ;
    rdfs:comment 'Regular expression pattern used to validate the identifier value format according to industry standards (EIDR, ISAN, ISRC, ISWC, etc.)' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The actual identifier value conforming to the standard format (EIDR, ISAN, ISRC, ISWC, etc.)' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the identifier was last verified or validated against the issuing authority or source system. | Column verification_date (DATE) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'The current verification or validation status of the identifier. Indicates whether the identifier has been confirmed as accurate and active by the issuing authority or internal validation process. | Column verification_status (STRING) in content.identifier' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentCreditId rdf:type rdf:Property ;
    rdfs:label 'Talent Credit Id' ;
    rdfs:comment 'Unique identifier for the talent credit record. Primary key for the talent credit association entity. | Column talent_credit_id (BIGINT) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_contract. Business justification: Credits must link to contracts for residual calculation, compensation verification, guild compliance reporting, and billing position validation. Fundamental to talent payment and rights management pro | Column contract_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_role. Business justification: Credits reference specific roles for character attribution, billing position validation, and role-specific residual eligibility. Eliminates denormalized role/character data and ensures single source o | Column role_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Reference to the talent master record in the talent domain. Links to the individual or entity receiving credit for their contribution to the content. | Column talent_profile_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:billingPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Position' ;
    rdfs:comment 'The ordinal position of the talent in the credit sequence, determining the order in which credits are displayed. Lower numbers indicate higher prominence (e.g., 1 = top billing). Used for EPG display and contractual compliance. | Column billing_position (INT) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bylineText rdf:type rdf:Property ;
    rdfs:label 'Byline Text' ;
    rdfs:comment 'Byline credit text for news reporter/photographer per VREQ-019' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'The date on which the credit was officially approved for publication. Used for audit trails and compliance with guild credit determination timelines. | Column credit_approval_date (DATE) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Status' ;
    rdfs:comment 'Current approval state of the credit. Pending indicates awaiting review; Approved indicates credit is finalized and ready for publication; Disputed indicates a challenge has been raised; Rejected indicates credit was not approved; Arbitration indicates the credit is under formal guild arbitration process. | Column credit_approval_status (STRING) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'High-level categorization of the credit by functional area or department. Used for grouping credits in EPG displays, streaming platform interfaces, and analytics. [ENUM-REF-CANDIDATE: cast|director|producer|writer|cinematography|editing|music|sound|production_design|costume|makeup|visual_effects|executive|other — 14 candidates stripped; promote to reference product] | Column credit_category (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayName rdf:type rdf:Property ;
    rdfs:label 'Credit Display Name' ;
    rdfs:comment 'The exact name as it should appear in credits, EPG metadata, and streaming platform displays. May differ from the talents legal name if a pseudonym or stage name is used. This is the authoritative display value for all public-facing credit presentations. | Column credit_display_name (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Credit Display Order' ;
    rdfs:comment 'The sequence number for displaying this credit within its credit type or section (e.g., within the cast section or crew section). Used for rendering credits in EPG, streaming platforms, and promotional materials. | Column credit_display_order (INT) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit End Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit ceases to be effective or visible. Nullable for credits that remain active indefinitely. Used for managing credit corrections, disputes, or contractual credit windows. | Column credit_end_timestamp (TIMESTAMP) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for additional context, special credit requirements, contractual stipulations, or notes related to credit disputes, arbitration outcomes, or special billing arrangements. | Column credit_notes (STRING) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Start Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit becomes effective or visible in EPG and streaming platform metadata. Used for managing credit changes over time and versioning. | Column credit_start_timestamp (TIMESTAMP) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit based on how the talent contribution is presented. On-screen credits appear in the visual content; off-screen credits appear in end titles or metadata only; voice credits are for voice-over or dubbing; stunt credits are for stunt performers; archive credits are for archival footage appearances. | Column credit_type (STRING) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymFlag rdf:type rdf:Property ;
    rdfs:label 'Pseudonym Flag' ;
    rdfs:comment 'Indicates whether the talent is credited under a pseudonym or stage name rather than their legal name. True if pseudonym is used; False if legal name is used. Relevant for guild compliance and contractual credit requirements. | Column pseudonym_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualsEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligibility Flag' ;
    rdfs:comment 'Indicates whether this credit qualifies the talent for residual payments based on content reuse, syndication, or secondary distribution. True if eligible; False otherwise. Triggers residuals calculation workflows in the rights and royalties domain. | Column residuals_eligibility_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Flag' ;
    rdfs:comment 'Indicates whether the talent is affiliated with a recognized industry union (SAG-AFTRA, DGA, WGA, IATSE) for this credit. True if union-affiliated; False otherwise. Used for residuals eligibility determination and compliance reporting. | Column union_affiliation_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Primary key for acquisition | Column acquisition_id (BIGINT) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Content acquisition deals create payment obligations to licensors/distributors. AP tracks amounts owed under acquisition agreements for cash flow forecasting, payment scheduling, and vendor relationsh | Column accounts_payable_id (BIGINT) in finance.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:acquisitionDealId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Id' ;
    rdfs:comment 'Reference to the originating rights deal or contract under which this content was acquired. Links to the master rights agreement. | Column acquisition_deal_id (BIGINT) in partner.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquisitionDeal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Content acquisition deals require tracking the employee who negotiated and manages the deal for accountability, commission calculation, and workload balancing. Critical for rights management operation | Column manager_employee_id (BIGINT) in workforce.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revenueStreamId rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_stream. Business justification: Content acquisition deals define licensing terms that determine revenue recognition treatment. Acquired content flows through specific revenue streams based on deal structure (output deals, first-run  | Column revenue_stream_id (BIGINT) in finance.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueStream .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current lifecycle state of the acquisition. Negotiating = deal in discussion; Committed = contract signed but content not yet delivered; Delivered = content received and ingested; Active = content in use; Cancelled = deal terminated before delivery; Expired = license period ended. | Column acquisition_status (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Classification of the acquisition method. Purchase = outright ownership transfer; License = time-limited rights; Co-production = joint production investment; Commission = original content commissioned from producer; Barter = content exchanged for advertising inventory; Syndication = content licensed from syndicator for regional broadcast. | Column acquisition_type (STRING) in content.acquisition' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ancillary Rights Flag' ;
    rdfs:comment 'Indicates whether ancillary rights (merchandising, soundtrack, publishing, remake, sequel, spin-off, clip licensing) are included in the acquisition (True) or retained by the supplier (False). | Column ancillary_rights_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Rights verification status confirming that all necessary clearances (music rights, talent rights, third-party content, trademarks) have been obtained for broadcast or distribution. Pending = verification in progress; Cleared = all rights confirmed; Restricted = partial clearance with limitations; Failed = clearance issues prevent exploitation. | Column clearance_status (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentWindowType rdf:type rdf:Property ;
    rdfs:label 'Content Window Type' ;
    rdfs:comment 'The distribution window or rights category acquired. Windowing refers to the sequential release strategy where content is made available through different channels over time. Theatrical = cinema release; Home Video = physical/digital sell-through; SVOD = Subscription Video On Demand; AVOD = Advertising-Supported Video On Demand; TVOD = Transactional Video On Demand; Linear Broadcast = traditional scheduled TV; Syndication = resale to multiple outlets; All Rights = comprehensive rights across all windows. [ENUM-REF-CANDIDATE: theatrical|home_video|svod|avod|tvod|linear_broadcast|syndication|all_rights — 8 candidates stripped; promote to reference product] | Column content_window_type (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost amount (e.g., USD, GBP, EUR, JPY). | Column cost_currency (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date on which the content master files and associated materials (metadata, artwork, closed captions, promotional assets) were delivered by the supplier and ingested into the enterprise Media Asset Management (MAM) system. | Column delivery_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'The technical format and delivery method used by the supplier to provide the content. Examples: ProRes 422 HQ via FTP, IMF package via Aspera, DCP hard drive, MPEG-4 via CDN, tape (legacy). | Column delivery_format (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the acquired rights are exclusive (True) or non-exclusive (False) within the specified territory and window. Exclusive rights prevent the supplier from licensing the same content to competitors in the same territory/window. | Column exclusivity_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatRights rdf:type rdf:Property ;
    rdfs:label 'Format Rights' ;
    rdfs:comment 'The technical formats or delivery specifications covered by the acquisition. May include SD, HD, 4K, HDR, theatrical DCP, broadcast master, streaming-optimized, etc. Defines the quality and format tiers the enterprise is authorized to distribute. | Column format_rights (STRING) in content.acquisition' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Days' ;
    rdfs:comment 'The number of days during which the content cannot be exploited in certain windows or territories as stipulated by the acquisition agreement. Holdback periods protect prior windows (e.g., theatrical holdback prevents SVOD release for 90 days post-theatrical). | Column holdback_period_days (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageRights rdf:type rdf:Property ;
    rdfs:label 'Language Rights' ;
    rdfs:comment 'The languages or language versions for which rights were acquired. May specify original language only, dubbed versions, subtitled versions, or all language adaptations. Examples: English, Spanish, French; All Languages; Original + Subtitles. | Column language_rights (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'The date on which the acquired content rights expire and the enterprise must cease exploitation. Null for perpetual purchases. For time-limited licenses, this defines the end of the license term. | Column license_end_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'The date from which the enterprise is authorized to begin exploiting the acquired content rights. For licenses, this is the effective start of the license term; for purchases, typically the acquisition date. | Column license_start_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'The minimum guaranteed payment to the supplier regardless of actual revenue performance. Common in revenue-sharing deals where the enterprise commits to a floor payment even if royalties do not reach this threshold. | Column minimum_guarantee_amount (DECIMAL(18,2)) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment schedule and conditions for the acquisition cost. May include milestone-based payments, installment schedules, advance payments, or revenue-sharing arrangements. | Column payment_terms (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External business identifier for this acquisition transaction. May be a purchase order number, deal reference, or contract line item identifier used in communications with the supplier. | Column reference_number (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Obligation Flag' ;
    rdfs:comment 'Indicates whether the enterprise has an obligation to pay residuals (talent reuse payments) to performers, writers, directors, or other rights holders each time the content is rebroadcast or redistributed (True) or if residuals are the supplier\'s responsibility (False). | Column residuals_obligation_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage of revenue or receipts that must be paid to the supplier as ongoing royalties under a revenue-sharing acquisition model. Null if the acquisition is a flat-fee structure with no revenue share. | Column royalty_rate_percent (DECIMAL(5,2)) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runsAllowed rdf:type rdf:Property ;
    rdfs:label 'Runs Allowed' ;
    rdfs:comment 'The maximum number of times the content may be broadcast or streamed under the acquisition agreement. Common in linear broadcast licenses (e.g., 3 runs over 2 years). Null indicates unlimited runs within the license period. | Column runs_allowed (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsConsumed rdf:type rdf:Property ;
    rdfs:label 'Runs Consumed' ;
    rdfs:comment 'The number of runs (broadcasts or streams) that have been executed to date against the runs_allowed limit. Tracked to ensure compliance with contractual run restrictions. | Column runs_consumed (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sublicensingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed Flag' ;
    rdfs:comment 'Indicates whether the enterprise is permitted to sublicense the acquired content to third parties (True) or must exploit the content directly only (False). Sublicensing enables syndication and secondary distribution deals. | Column sublicensing_allowed_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territories or markets for which the content rights were acquired. May be specified as country codes (ISO 3166), regional groupings, or worldwide. Examples: USA, GBR, North America, EMEA, Worldwide. | Column territory_scope (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingPlanId rdf:type rdf:Property ;
    rdfs:label 'Windowing Plan Id' ;
    rdfs:comment 'Unique identifier for the windowing plan record. Primary key for the windowing plan entity. | Column windowing_plan_id (BIGINT) in content.windowing_plan' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WindowingPlan .

ind:abrProfileId rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Id' ;
    rdfs:comment 'Foreign key linking to distribution.abr_profile. Business justification: Windows specify technical delivery profiles (4K/HDR for premium SVOD, HD for AVOD). ABR profile determines quality tier, bandwidth costs, and subscriber experience per distribution window. | Column abr_profile_id (BIGINT) in distribution.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbrProfile .

ind:coppaDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Coppa Declaration Id' ;
    rdfs:comment 'Foreign key linking to compliance.coppa_declaration. Business justification: Windowing plans targeting children\'s platforms (Nick Jr., Disney+, YouTube Kids) require COPPA compliance declarations before distribution. Links distribution window to child-directed content determin | Column coppa_declaration_id (BIGINT) in compliance.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoppaDeclaration .

ind:distributionPartnerId rdf:type rdf:Property ;
    rdfs:label 'Distribution Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Windowing plans specify distribution partners for each window (theatrical exhibitor, streaming platform, broadcast network). Partner performance tracking, holdback enforcement, exclusivity compliance  | Column distribution_partner_id (BIGINT) in partner.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:governingLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Governing License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Windowing strategies must comply with license agreement terms (holdbacks, exclusivity windows, platform restrictions). Windowing plan validation and conflict detection require checking against the gov | Column governing_license_agreement_id (BIGINT) in rights.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Revenue recognition and billing cycles are directly tied to distribution windows. Finance teams track which invoices correspond to which windows for SVOD/TVOD/AVOD revenue allocation, holdback complia | Column invoice_id (BIGINT) in billing.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Reference identifier for the marketing campaign associated with this window release. Links to promotional activities, advertising spend, and audience acquisition efforts. | Column marketing_campaign_id (BIGINT) in sales.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesCampaign .

ind:primaryWindowingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Windowing Employee Id' ;
    rdfs:comment 'Identifier of the content planning or distribution strategy team member who created this windowing plan. Used for accountability and workflow tracking. | Column primary_windowing_employee_id (BIGINT) in workforce.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:satelliteTransponderId rdf:type rdf:Property ;
    rdfs:label 'Satellite Transponder Id' ;
    rdfs:comment 'Foreign key linking to technology.satellite_transponder. Business justification: Linear broadcast windows are delivered via specific satellite transponders. Transmission scheduling, transponder capacity planning, regulatory filings, and uplink coordination require transponder assi | Column satellite_transponder_id (BIGINT) in technology.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SatelliteTransponder .

ind:streamingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Id' ;
    rdfs:comment 'Foreign key linking to distribution.streaming_endpoint. Business justification: Each distribution window may use specific streaming endpoints (regional CDN POPs, premium tier endpoints). Required for geo-restriction enforcement, SLA tier assignment, and CDN cost allocation per wi | Column streaming_endpoint_id (BIGINT) in distribution.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:abrEnabled rdf:type rdf:Property ;
    rdfs:label 'Abr Enabled' ;
    rdfs:comment 'Indicates whether adaptive bitrate streaming is enabled for this window, allowing dynamic quality adjustment based on viewer bandwidth. True=ABR enabled, False=fixed bitrate. | Column abr_enabled (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Configuration' ;
    rdfs:comment 'The audio format specification for this window. Stereo=2-channel, Surround 5.1=5.1 channel surround, Surround 7.1=7.1 channel surround, Dolby Atmos=object-based audio, DTS:X=immersive audio format. | Column audio_configuration (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Restrictions' ;
    rdfs:comment 'Geographic or temporal blackout rules that restrict content availability in specific regions or time periods within the territory (e.g., sports blackouts, regional exclusions). | Column blackout_restrictions (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleEligibility rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility' ;
    rdfs:comment 'Indicates whether this content is eligible for inclusion in subscription bundles or multi-title packages during this window. True=bundle eligible, False=standalone only. | Column bundle_eligibility (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamsLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Streams Limit' ;
    rdfs:comment 'Maximum number of simultaneous streams allowed per subscriber account for this content in this window. Used for subscription service tier management. | Column concurrent_streams_limit (INT) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'The technical format specification for content delivery in this window. SD=standard definition, HD=high definition 1080p, 4K=ultra high definition, 8K=8K resolution, HDR=high dynamic range, Dolby Vision=premium HDR format. | Column content_format (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRestriction rdf:type rdf:Property ;
    rdfs:label 'Daypart Restriction' ;
    rdfs:comment 'Time-of-day broadcast restrictions for linear windows, defining when content may air (e.g., prime time only, late night only, daytime safe). Applies primarily to linear broadcast and cable windows. | Column daypart_restriction (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadToGoEnabled rdf:type rdf:Property ;
    rdfs:label 'Download To Go Enabled' ;
    rdfs:comment 'Indicates whether offline download capability is enabled for this window, allowing viewers to download content for offline viewing. True=downloads allowed, False=streaming only. | Column download_to_go_enabled (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dubbingAvailability rdf:type rdf:Property ;
    rdfs:label 'Dubbing Availability' ;
    rdfs:comment 'Indicates whether dubbed audio tracks in alternate languages are available for this window release. True=dubbing provided, False=original language only. | Column dubbing_availability (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTier rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Tier' ;
    rdfs:comment 'The level of exclusivity granted to the platform during this window. Exclusive=sole distribution rights, Non-Exclusive=concurrent availability on multiple platforms, Shared Exclusive=limited to a defined group of platforms, First Run=premiere window, Second Run=subsequent availability. | Column exclusivity_tier (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackDurationDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Duration Days' ;
    rdfs:comment 'The number of days between the close of the previous window and the open of this window, representing the exclusivity period or gap between release phases. | Column holdback_duration_days (INT) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageVersion rdf:type rdf:Property ;
    rdfs:label 'Language Version' ;
    rdfs:comment 'ISO 639-2 or ISO 639-3 language code for the primary audio/subtitle language version to be released in this window (e.g., eng, spa, fra, deu). | Column language_version (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Close Date' ;
    rdfs:comment 'The intended end date when the content will no longer be available on the specified platform/channel in the specified territory. Nullable for open-ended windows. | Column planned_close_date (DATE) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOpenDate rdf:type rdf:Property ;
    rdfs:label 'Planned Open Date' ;
    rdfs:comment 'The intended start date when the content becomes available on the specified platform/channel in the specified territory. Represents the editorial/commercial release plan. | Column planned_open_date (DATE) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricePoint rdf:type rdf:Property ;
    rdfs:label 'Price Point' ;
    rdfs:comment 'The consumer-facing price for transactional windows (TVOD, EST, PPV) in the specified currency. Represents the retail price charged to end viewers. | Column price_point (DECIMAL(10,2)) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Pricing Flag' ;
    rdfs:comment 'Indicates whether promotional or discounted pricing is applied for this window. True=promotional pricing active, False=standard pricing. | Column promotional_pricing_flag (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'The monetization approach for this window. Subscription=SVOD model, Advertising=AVOD model, Transactional=TVOD/PPV/EST, Hybrid=combination of models, Free=no direct revenue. | Column revenue_model (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Streaming Protocol' ;
    rdfs:comment 'The streaming delivery protocol used for OTT windows. HLS=HTTP Live Streaming (Apple), DASH=Dynamic Adaptive Streaming over HTTP (MPEG-DASH), Smooth Streaming=Microsoft, RTMP=Real-Time Messaging Protocol, WebRTC=real-time communication. | Column streaming_protocol (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleAvailability rdf:type rdf:Property ;
    rdfs:label 'Subtitle Availability' ;
    rdfs:comment 'Indicates whether subtitles or closed captions are available for this window release. True=subtitles provided, False=no subtitles. | Column subtitle_availability (BOOLEAN) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewingWindowHours rdf:type rdf:Property ;
    rdfs:label 'Viewing Window Hours' ;
    rdfs:comment 'For TVOD/rental windows, the number of hours a viewer has to complete watching the content after initiating playback (e.g., 48-hour rental window). | Column viewing_window_hours (INT) in content.windowing_plan' ;
    rdfs:domain ind:WindowingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Window Sequence Number' ;
    rdfs:comment 'Sequential ordering of this window within the overall release strategy for the content. Lower numbers indicate earlier windows (e.g., 1=theatrical, 2=SVOD, 3=AVOD). | Column window_sequence_number (INT) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle status of the windowing plan. Planned=initial strategy, Confirmed=approved by stakeholders, Active=currently in release window, Completed=window has closed, Cancelled=window will not execute, Postponed=delayed to future date. | Column window_status (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'The distribution window category defining the release channel type. Theatrical=cinema release, SVOD=subscription video on demand, AVOD=advertising-supported video on demand, TVOD=transactional video on demand, Linear Broadcast=traditional scheduled TV, Home Video=physical media, Syndication=content resale to multiple outlets, FAST=free ad-supported streaming television, PPV=pay-per-view, EST=electronic sell-through. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear_broadcast|home_video|syndication|fast|vod|ppv|est — 11 candidates stripped; promote to reference product] | Column window_type (STRING) in content.windowing_plan' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event | Column lifecycle_event_id (BIGINT) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Content lifecycle transitions (ingest, QC, archive) occur at specific facilities. Audit trails, compliance reporting, operational metrics, and facility performance dashboards require facility attribut | Column broadcast_facility_id (BIGINT) in technology.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:primaryLifecycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Employee Id' ;
    rdfs:comment 'The system identifier of the user who initiated or approved this lifecycle transition. Used for accountability and audit purposes. | Column primary_lifecycle_employee_id (BIGINT) in workforce.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:automatedFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Flag' ;
    rdfs:comment 'Indicates whether this lifecycle transition was triggered automatically by the workflow system (True) or manually by a user (False). | Column automated_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingCondition rdf:type rdf:Property ;
    rdfs:label 'Blocking Condition' ;
    rdfs:comment 'Any condition, issue, or dependency that is blocking or delaying the content from progressing to the next lifecycle stage (e.g., pending rights clearance, QC failure, missing metadata, technical issue). Null if no blocking condition exists. | Column blocking_condition (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingResolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Resolved Flag' ;
    rdfs:comment 'Indicates whether any previously identified blocking condition has been resolved. True if resolved, False if still blocking, Null if no blocking condition was present. | Column blocking_resolved_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCheckpointPassed rdf:type rdf:Property ;
    rdfs:label 'Compliance Checkpoint Passed' ;
    rdfs:comment 'Indicates whether all regulatory and compliance checkpoints required for this lifecycle stage were successfully passed (e.g., content rating verification, rights clearance, broadcast standards review). True if passed, False if failed, Null if not applicable. | Column compliance_checkpoint_passed (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPlatform rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform' ;
    rdfs:comment 'The target delivery platform or distribution channel for which this lifecycle stage is being prepared (e.g., Linear Broadcast, OTT, VOD, SVOD, AVOD, Theatrical, Syndication). Applicable primarily for distribution-related lifecycle stages. | Column delivery_platform (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'The sequential order of this lifecycle event within the complete lifecycle history of the content asset. Used to reconstruct the chronological audit trail. | Column event_sequence_number (INT) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The operational lifecycle stage of the content asset at the time of this event. Represents the major phase in the content workflow from acquisition through archival. [ENUM-REF-CANDIDATE: acquisition|commission|development|pre_production|production|post_production|clearance|mastering|distribution|archival|retired — 11 candidates stripped; promote to reference product] | Column lifecycle_stage (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the content asset immediately after this lifecycle transition. Represents the current state following the event. | Column new_status (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the content asset immediately before this lifecycle transition. Captures the prior state for audit trail and provenance. | Column previous_status (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'The business unit, department, or team responsible for executing or approving this lifecycle transition (e.g., Production, Post-Production, Rights Management, Quality Control, Distribution). | Column responsible_team (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event represents a rollback to a previous stage due to failure, rejection, or rework requirement. True if rollback, False for forward progression. | Column rollback_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'The reason or justification for rolling back the content to a previous lifecycle stage. Null if rollback_flag is False. | Column rollback_reason (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualDate rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Date' ;
    rdfs:comment 'The actual date when this lifecycle stage was completed. Used to measure SLA compliance by comparing against sla_target_date. | Column sla_actual_date (DATE) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this lifecycle transition breached the defined SLA target. True if actual date exceeded target date, False otherwise. | Column sla_breach_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Date' ;
    rdfs:comment 'The target date by which this lifecycle stage should be completed, as defined by internal SLA or contractual delivery commitment. Used for SLA monitoring and performance tracking. | Column sla_target_date (DATE) in content.lifecycle_event' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The name of the source system or module that generated this lifecycle event record (e.g., Dalet Galaxy, Ericsson MediaFirst, Rightsline, manual entry). | Column system_source (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Transition Duration Hours' ;
    rdfs:comment 'The elapsed time in hours between the previous lifecycle event and this event. Measures the duration spent in the previous stage. Used for operational efficiency analysis. | Column transition_duration_hours (DECIMAL(10,2)) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the lifecycle stage transition occurred. This is the business event timestamp, distinct from audit timestamps. | Column transition_timestamp (TIMESTAMP) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeredByEvent rdf:type rdf:Property ;
    rdfs:label 'Triggered By Event' ;
    rdfs:comment 'The specific event or action that triggered this lifecycle transition (e.g., QC approval, rights clearance, ingest completion, delivery confirmation, manual override). | Column triggered_by_event (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Code' ;
    rdfs:comment 'The unique identifier of the workflow instance in the Media Asset Management (MAM) system that orchestrated this lifecycle transition. Links to Dalet Galaxy workflow execution. | Column workflow_instance_code (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Content Clearance Id' ;
    rdfs:comment 'Unique identifier for the content clearance record. Primary key for the content clearance entity. | Column content_clearance_id (BIGINT) in content.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Content Employee Id' ;
    rdfs:comment 'Reference to the clearance officer or rights specialist responsible for verifying and approving this clearance. Links to the talent or employee master data. | Column primary_content_employee_id (BIGINT) in workforce.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:validatingLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Validating License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Clearance requests validate against license agreement terms before approving content for air. Automated clearance systems check holdbacks, exclusivity, and platform restrictions defined in the agreeme | Column validating_license_agreement_id (BIGINT) in rights.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:validatingRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Validating Rights Grant Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_grant. Business justification: Clearance validates specific grant permissions (run counts, platforms, dates, territories). Automated clearance workflows check that the requested exploitation falls within an active grant\'s scope. | Column validating_rights_grant_id (BIGINT) in rights.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Detailed explanation of why the clearance was blocked or denied. Captures the specific legal, contractual, or rights-related issue preventing broadcast or distribution. | Column blocking_reason (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Ready Flag' ;
    rdfs:comment 'Boolean indicator of whether the content has passed all clearance requirements and is approved for broadcast or distribution. True indicates the content is ready; false indicates clearance is incomplete or blocked. | Column broadcast_ready_flag (BOOLEAN) in content.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'Date when the clearance was officially approved and the content was deemed ready for broadcast or distribution. Null if clearance has not yet been granted. | Column clearance_date (DATE) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceType rdf:type rdf:Property ;
    rdfs:label 'Clearance Type' ;
    rdfs:comment 'Category of rights clearance being verified. Identifies the specific type of intellectual property or usage right that requires clearance before broadcast or distribution. [ENUM-REF-CANDIDATE: music_sync|music_master_use|talent_residuals|third_party_footage|archive_clips|stock_footage|trademark|logo|product_placement — 9 candidates stripped; promote to reference product] | Column clearance_type (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms' ;
    rdfs:comment 'Specific conditions or restrictions attached to the clearance approval. Examples include geographic blackouts, time-of-day restrictions, or required attribution statements. | Column conditional_terms (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the underlying rights contract or licensing agreement that governs this clearance. Links to the contract management system for full terms and conditions. | Column contract_reference (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether the clearance request has been escalated to senior management or legal counsel due to complexity, cost, or urgency. True indicates escalation is active. | Column escalation_flag (BOOLEAN) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Monetary amount paid or payable to the rights holder for clearance approval. Represents the cost of securing the right to use the intellectual property in the specified territory, platform, and window. | Column fee_amount (DECIMAL(15,2)) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the clearance fee amount. Supports multi-currency rights transactions. | Column fee_currency (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedPlatform rdf:type rdf:Property ;
    rdfs:label 'Intended Platform' ;
    rdfs:comment 'Target platform or distribution channel for which the clearance is being verified. Clearance requirements vary by platform due to different rights agreements and territorial restrictions. [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|fast|ott|theatrical|home_video|syndication — 9 candidates stripped; promote to reference product] | Column intended_platform (STRING) in content.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedTerritory rdf:type rdf:Property ;
    rdfs:label 'Intended Territory' ;
    rdfs:comment 'Geographic territory or market for which the clearance is being verified, represented as a three-letter ISO country code. Rights clearance is often territory-specific due to licensing agreements. | Column intended_territory (STRING) in content.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedWindow rdf:type rdf:Property ;
    rdfs:label 'Intended Window' ;
    rdfs:comment 'Sequential release window for which the clearance is being verified. Windowing strategy determines when and where content can be distributed, and clearance requirements differ by window. [ENUM-REF-CANDIDATE: theatrical|home_video|pay_per_view|premium_cable|basic_cable|broadcast|streaming|syndication — 8 candidates stripped; promote to reference product] | Column intended_window (STRING) in content.content_clearance' ;
    rdfs:domain ind:ContentClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the clearance requires formal legal review before approval. True indicates legal counsel must review and sign off on the clearance. | Column legal_review_required_flag (BOOLEAN) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the clearance request. Urgent and high-priority clearances are expedited to meet tight broadcast schedules or upfront commitments. | Column priority (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the clearance verification request was initiated. Marks the beginning of the clearance workflow and is used to track turnaround time and service level agreement (SLA) compliance. | Column request_date (DATE) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsHolderContact rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Contact' ;
    rdfs:comment 'Primary contact information (email, phone, or address) for the rights holder. Used for clearance negotiation and communication. | Column rights_holder_contact (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderName rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Name' ;
    rdfs:comment 'Name of the individual or organization that holds the intellectual property rights requiring clearance. May be a music publisher, talent agent, stock footage provider, or other rights owner. | Column rights_holder_name (STRING) in content.content_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataProfileId rdf:type rdf:Property ;
    rdfs:label 'Metadata Profile Id' ;
    rdfs:comment 'Unique identifier for the metadata profile record. Primary key. | Column metadata_profile_id (BIGINT) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Metadata profiles require employee accountability for quality control, audit trails, and platform compliance. Broadcasting operations need to track who created/modified metadata for error resolution a | Column created_by_employee_id (BIGINT) in workforce.metadata_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previewMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Preview Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Metadata packages for platform delivery often include preview clips or thumbnail assets. Distribution systems require linking metadata profiles to their associated preview/promo assets for bundled del | Column preview_media_asset_id (BIGINT) in mediaasset.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:castSummary rdf:type rdf:Property ;
    rdfs:label 'Cast Summary' ;
    rdfs:comment 'Summarized list of principal cast members and their roles. Used for promotional materials and EPG (Electronic Program Guide) displays where full cast lists are impractical. | Column cast_summary (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directorCredit rdf:type rdf:Property ;
    rdfs:label 'Director Credit' ;
    rdfs:comment 'Name(s) of the director(s) of the content. Used for attribution, promotional materials, and search/discovery. | Column director_credit (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreClassification rdf:type rdf:Property ;
    rdfs:label 'Genre Classification' ;
    rdfs:comment 'Genre or category classification specific to the target platform. May differ from the master title genre to align with platform-specific taxonomies (e.g., Netflix genres vs. broadcast EPG genres). | Column genre_classification (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywordTags rdf:type rdf:Property ;
    rdfs:label 'Keyword Tags' ;
    rdfs:comment 'Comma-separated list of keyword tags for content discovery, search indexing, and recommendation engines. Includes themes, topics, moods, and contextual descriptors. | Column keyword_tags (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longSynopsis rdf:type rdf:Property ;
    rdfs:label 'Long Synopsis' ;
    rdfs:comment 'Extended narrative description of the content title. Typically 200-500 words, used for detailed program guides, press releases, and promotional materials. | Column long_synopsis (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataLanguage rdf:type rdf:Property ;
    rdfs:label 'Metadata Language' ;
    rdfs:comment 'ISO 639 language code (2 or 3 letters) with optional ISO 3166 country code for the language in which this metadata profile is written. Examples: en, en-US, fr, es-MX. | Column metadata_language (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataStandard rdf:type rdf:Property ;
    rdfs:label 'Metadata Standard' ;
    rdfs:comment 'The metadata standard or schema used for this profile. Defines the structure and vocabulary of the metadata package. | Column metadata_standard (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User or system identifier of the person or process that last modified this metadata profile. Used for audit trails and accountability. | Column modified_by (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceNotes rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Notes' ;
    rdfs:comment 'Detailed notes explaining the content rating, including specific content descriptors (violence, language, sexual content, etc.). Used for parental controls and compliance. | Column parental_guidance_notes (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformSpecificCode rdf:type rdf:Property ;
    rdfs:label 'Platform Specific Code' ;
    rdfs:comment 'Unique identifier assigned by the target platform for this metadata profile. Used for cross-referencing and reconciliation with external systems. | Column platform_specific_code (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posterUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the poster or cover art image associated with this metadata profile. Used for streaming platform UI, marketing, and promotional materials. | Column poster_url (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the metadata profile. Indicates whether the profile is in draft, has been validated, is published to the target platform, rejected due to validation errors, archived, or expired. | Column profile_status (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalTagline rdf:type rdf:Property ;
    rdfs:label 'Promotional Tagline' ;
    rdfs:comment 'Short, catchy promotional phrase or slogan used in marketing campaigns, social media, and advertising. Typically 10-30 words. | Column promotional_tagline (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Runtime Minutes' ;
    rdfs:comment 'Total runtime of the content in minutes. Used for scheduling, EPG (Electronic Program Guide) display, and audience planning. | Column runtime_minutes (INT) in content.metadata_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortSynopsis rdf:type rdf:Property ;
    rdfs:label 'Short Synopsis' ;
    rdfs:comment 'Brief narrative description of the content title. Typically 50-150 words, used for EPG (Electronic Program Guide) listings, mobile apps, and quick reference. | Column short_synopsis (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the thumbnail image associated with this metadata profile. Used for EPG (Electronic Program Guide) display, streaming platform UI, and promotional materials. | Column thumbnail_url (STRING) in content.metadata_profile' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUrl rdf:type rdf:Property ;
    rdfs:label 'Trailer Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) to the trailer or preview video associated with this content. Used for promotional campaigns and streaming platform previews. | Column trailer_url (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'Detailed list of validation errors or warnings encountered during metadata quality checks. Used for troubleshooting and metadata remediation. | Column validation_errors (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of automated or manual validation checks against the target metadata standard. Indicates whether the profile meets all required schema and business rules. | Column validation_status (STRING) in content.metadata_profile' ;
    rdfs:domain ind:MetadataProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkId rdf:type rdf:Property ;
    rdfs:label 'Artwork Id' ;
    rdfs:comment 'Unique identifier for the artwork asset record. Primary key for the artwork catalog. | Column artwork_id (BIGINT) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the artwork received final approval for distribution and use. Marks the transition from draft/review to production-ready status. Format: yyyy-MM-dd. | Column approval_date (DATE) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork has passed legal, brand, and creative approval processes and is authorized for public distribution. True indicates approved and ready for use, False indicates pending approval or rejected. | Column approved_for_use_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:artworkType rdf:type rdf:Property ;
    rdfs:label 'Artwork Type' ;
    rdfs:comment 'Classification of the artwork asset by its intended use and format. Key-art is primary promotional image, thumbnail for Electronic Program Guide (EPG) and streaming UI, banner for web headers, poster for theatrical/retail, logo for branding, still for scene captures. | Column artwork_type (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space standard applied to the artwork for accurate color reproduction across devices and platforms. sRGB for web/digital, Adobe RGB for professional photography, CMYK for print, Rec. 709 for HD broadcast, Rec. 2020 for Ultra HD (UHD) broadcast. | Column color_profile (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingDisplayedFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Displayed Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork includes a visible Motion Picture Association (MPA) or equivalent content rating badge (G, PG, PG-13, R, NC-17, TV-Y, TV-PG, TV-14, TV-MA). True indicates rating is burned into the image, False indicates clean artwork without rating overlay. | Column content_rating_displayed_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Legal entity or organization that owns the copyright to the artwork asset. May be the production company, studio, distributor, or external agency. Critical for rights clearance and syndication. | Column copyright_holder (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightYear rdf:type rdf:Property ;
    rdfs:label 'Copyright Year' ;
    rdfs:comment 'Year in which the artwork was created and copyright was established. Used for copyright notice display and rights duration calculation. | Column copyright_year (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Vertical dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels. | Column height_pixels (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language of any text overlay or localization present in the artwork. Used for multi-territory distribution and localization workflows. | Column language_code (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Language Overlay Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork contains burned-in text, titles, or language-specific graphic elements. True indicates localized artwork requiring territory-specific versions, False indicates language-neutral artwork suitable for all markets. | Column language_overlay_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Name or attribution of the photographer, artist, or creative agency responsible for creating the artwork. Used for copyright attribution, residuals tracking, and legal compliance with talent agreements. | Column photographer_credit (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the preferred display order or priority of this artwork when multiple artwork assets exist for the same title and type. Lower numbers indicate higher priority. Used by Electronic Program Guide (EPG) and streaming platform UI to select the primary artwork. | Column priority_rank (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Image resolution measured in dots per inch. 72 DPI for web/screen display, 300 DPI for high-quality print, 150 DPI for standard print. Critical for determining print suitability and image quality. | Column resolution_dpi (INT) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier or reference key for the artwork asset in the originating source system. Enables traceability and synchronization with upstream Digital Asset Management (DAM) or creative management platforms. | Column source_system_code (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Scope of authorized usage channels and media types for the artwork. All-media for unrestricted use, digital-only for Over-The-Top (OTT) and web, print-only for press kits and retail, broadcast-only for linear television, theatrical-only for cinema, promotional-only for advertising and marketing campaigns. | Column usage_rights (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Horizontal dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels. | Column width_pixels (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagId rdf:type rdf:Property ;
    rdfs:label 'Tag Id' ;
    rdfs:comment 'Primary key for tag | Column tag_id (BIGINT) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTagId rdf:type rdf:Property ;
    rdfs:label 'Parent Tag Id' ;
    rdfs:comment 'Reference to a parent tag in a hierarchical taxonomy structure. Enables multi-level tag classification (e.g., \'Action\' as parent, \'Car Chase\' as child). Null for top-level tags. | Column parent_tag_id (BIGINT) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tag .

ind:primaryTagEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tag Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that applied this tag. Supports audit trails and editorial accountability. May reference internal staff, partner systems, or automated processes. | Column tag_employee_id (BIGINT) in workforce.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:taxonomyId rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Id' ;
    rdfs:comment 'External identifier linking this tag to a standardized industry taxonomy or controlled vocabulary system (e.g., IAB Content Taxonomy, Gracenote Video Descriptors, EIDR Content Identifiers). Enables interoperability and consistent metadata across platforms. | Column taxonomy_id (BIGINT) in content.tag' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Taxonomy .

ind:advertiserSafe rdf:type rdf:Property ;
    rdfs:label 'Advertiser Safe' ;
    rdfs:comment 'Indicates whether content with this tag is suitable for advertising placement according to brand safety guidelines. False may indicate sensitive or controversial content that requires restricted ad inventory. | Column advertiser_safe (BOOLEAN) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date when the tag was first applied to the content asset. Tracks the temporal evolution of content metadata and editorial curation. | Column applied_date (DATE) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence level for algorithmically-generated tags, expressed as a decimal between 0.0000 and 1.0000. A score of 1.0000 indicates highest confidence. Null for manually-applied editorial tags. | Column confidence_score (DECIMAL(5,4)) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaCompliant rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant' ;
    rdfs:comment 'Indicates whether this tag and its associated content comply with COPPA regulations for children\'s content. True indicates the tag is appropriate for content directed at children under 13. | Column coppa_compliant (BOOLEAN) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Depth level of this tag within a hierarchical taxonomy structure. Level 1 represents top-level categories, with increasing numbers indicating deeper nesting. Supports faceted navigation and drill-down discovery. | Column hierarchy_level (INT) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisplayable rdf:type rdf:Property ;
    rdfs:label 'Is Displayable' ;
    rdfs:comment 'Indicates whether this tag should be displayed to end users in content detail pages, Electronic Program Guides (EPG), or Over-The-Top (OTT) platform interfaces. Some tags are for backend analytics only. | Column is_displayable (BOOLEAN) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this tag should be indexed and surfaced in user-facing search interfaces. Some tags may be used for internal classification or algorithmic purposes only. | Column is_searchable (BOOLEAN) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-2/T three-letter language code indicating the language in which the tag value is expressed. Supports multilingual tagging for international content catalogs. | Column language (STRING) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the tag assignment was reviewed by editorial staff. Null if no review has occurred. | Column review_date (DATE) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes or comments from the editorial reviewer regarding the tag assignment. May include rationale for approval or rejection, suggested alternatives, or quality feedback. | Column review_notes (STRING) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Editorial review and approval status for the tag assignment. Supports quality control workflows where algorithmically-generated or partner-supplied tags require human validation before publication. | Column review_status (STRING) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Origin of the tag assignment. Indicates whether the tag was applied by internal editorial staff, generated by machine learning algorithms, provided by a content partner or rights holder, contributed by users, or supplied by the production team. | Column tag_source (STRING) in content.tag' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Category of the tag applied to the content. Defines the semantic purpose of the tag (e.g., mood for emotional tone, theme for subject matter, setting for location context, era for time period, franchise for brand universe, content_warning for viewer advisories, editorial_collection for curated groupings, campaign for promotional initiatives). [ENUM-REF-CANDIDATE: mood|theme|setting|era|franchise|universe|content_warning|editorial_collection|campaign|keyword — 10 candidates stripped; promote to reference product] | Column tag_type (STRING) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version number of the external taxonomy or controlled vocabulary system referenced by taxonomy_id. Tracks schema evolution and ensures backward compatibility. | Column taxonomy_version (STRING) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Relative importance or prominence of this tag for the content asset, expressed as a decimal between 0.0000 and 1.0000. Higher weights indicate more central or defining characteristics. Used to prioritize tags in recommendation and discovery algorithms. | Column weight (DECIMAL(5,4)) in content.tag' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestEventId rdf:type rdf:Property ;
    rdfs:label 'Ingest Event Id' ;
    rdfs:comment 'Unique identifier for the content ingest event. Primary key for the ingest_event product. | Column ingest_event_id (BIGINT) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'The user or system account that initiated or supervised the ingest operation. Used for operational audit and accountability. | Column employee_id (BIGINT) in workforce.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ingestBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Ingest Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Ingest operations occur at specific facilities with dedicated ingest infrastructure. Operational dashboards, capacity planning, SLA tracking, and facility performance metrics require facility attribut | Column ingest_broadcast_facility_id (BIGINT) in technology.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:thirdPartyVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Third Party Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Third-party vendors deliver content for ingest. Delivery acceptance tracking, technical QC dispute resolution, redelivery cost allocation, and vendor performance scorecarding require partner attributi | Column third_party_vendor_partner_id (BIGINT) in partner.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:audioDescriptionDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Detected Flag' ;
    rdfs:comment 'Indicates whether an audio description track for visually impaired audiences was detected in the ingested content. True if audio description present, False otherwise. | Column audio_description_detected_flag (BOOLEAN) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automatedQcResult rdf:type rdf:Property ;
    rdfs:label 'Automated Qc Result' ;
    rdfs:comment 'The outcome of automated quality control checks performed during or immediately after ingest (e.g., technical compliance, audio/video sync, black frames, silence detection). | Column automated_qc_result (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 hash of the ingested file for enhanced integrity verification and forensic audit. Calculated at ingest time. | Column checksum_sha256 (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Detected Flag' ;
    rdfs:comment 'Indicates whether closed caption or subtitle tracks were detected in the ingested content. True if captions present, False otherwise. | Column closed_caption_detected_flag (BOOLEAN) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The specific protocol or service used for content delivery (e.g., Aspera, FTP, SFTP, AWS S3, physical courier). Provides additional detail beyond ingest_source_type. | Column delivery_method (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Completion Timestamp' ;
    rdfs:comment 'The date and time when the ingest operation reached a terminal state (completed, failed, or cancelled). Null for in-progress operations. | Column ingest_completion_timestamp (TIMESTAMP) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestErrorCode rdf:type rdf:Property ;
    rdfs:label 'Ingest Error Code' ;
    rdfs:comment 'Machine-readable error code generated when the ingest operation fails. Null for successful ingests. | Column ingest_error_code (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Ingest Error Description' ;
    rdfs:comment 'Human-readable description of the failure reason when ingest status is failed or quarantined. Null for successful ingests. | Column ingest_error_description (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestJobNumber rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Number' ;
    rdfs:comment 'Externally-known unique job identifier assigned by the MAM (Media Asset Management) system for tracking and audit purposes. | Column ingest_job_number (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestSourceLocation rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Location' ;
    rdfs:comment 'The physical or logical location from which the content was ingested (e.g., file path, tape library slot, satellite feed identifier, cloud bucket URI). | Column ingest_source_location (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestSourceType rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Type' ;
    rdfs:comment 'The delivery mechanism or medium through which the content was received into the MAM (Media Asset Management) system. [ENUM-REF-CANDIDATE: tape|file|satellite|ip_stream|cloud|ftp|aspera|physical_media — 8 candidates stripped; promote to reference product] | Column ingest_source_type (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestStatus rdf:type rdf:Property ;
    rdfs:label 'Ingest Status' ;
    rdfs:comment 'Current lifecycle status of the ingest operation. Tracks progression from queued through completion or failure states. | Column ingest_status (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Timestamp' ;
    rdfs:comment 'The date and time when the content ingest operation was initiated. Represents the principal business event time for this transaction. | Column ingest_timestamp (TIMESTAMP) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Ingest Workflow Code' ;
    rdfs:comment 'Reference to the specific workflow template or automation rule that governed this ingest operation in the MAM (Media Asset Management) system. | Column ingest_workflow_code (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataPackageReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Metadata Package Received Flag' ;
    rdfs:comment 'Indicates whether accompanying metadata (EIDR, ISAN, descriptive metadata, rights information) was received with the media file. True if metadata was included, False otherwise. | Column metadata_package_received_flag (BOOLEAN) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'The processing priority assigned to this ingest operation. Determines queue position and resource allocation for time-sensitive content. | Column priority_level (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcErrorCode rdf:type rdf:Property ;
    rdfs:label 'Qc Error Code' ;
    rdfs:comment 'Machine-readable error code generated by the automated QC system when issues are detected. Null if QC passed or was not performed. | Column qc_error_code (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Qc Error Description' ;
    rdfs:comment 'Human-readable description of quality control issues detected during ingest. Null if QC passed or was not performed. | Column qc_error_description (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times this ingest operation has been retried after initial failure. Zero for first-attempt ingests. | Column retry_count (INT) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Source Aspect Ratio' ;
    rdfs:comment 'The aspect ratio of the ingested video content (e.g., 16:9, 4:3, 21:9). Null for audio-only content. | Column source_aspect_ratio (NUMERIC) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceAudioChannels rdf:type rdf:Property ;
    rdfs:label 'Source Audio Channels' ;
    rdfs:comment 'The number of audio channels in the ingested content (e.g., 2 for stereo, 6 for 5.1 surround). Null for video-only content. | Column source_audio_channels (INT) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceAudioCodec rdf:type rdf:Property ;
    rdfs:label 'Source Audio Codec' ;
    rdfs:comment 'The audio codec used in the ingested content (e.g., AAC, AC-3, PCM, Dolby Digital). Null for video-only content. | Column source_audio_codec (STRING) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Source Duration Seconds' ;
    rdfs:comment 'The runtime duration of the ingested media content in seconds. Null for still images or non-time-based assets. | Column source_duration_seconds (DECIMAL(12,3)) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Source File Size Bytes' ;
    rdfs:comment 'The size of the ingested media file in bytes. Used for storage planning, bandwidth analysis, and integrity verification. | Column source_file_size_bytes (BIGINT) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFormat rdf:type rdf:Property ;
    rdfs:label 'Source Format' ;
    rdfs:comment 'The technical format and codec of the ingested media file (e.g., MPEG-4, ProRes, MXF, H.264, HEVC). Captured as received before any transcoding. | Column source_format (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFrameRate rdf:type rdf:Property ;
    rdfs:label 'Source Frame Rate' ;
    rdfs:comment 'The frame rate of the ingested video content in frames per second (e.g., 23.976, 25.000, 29.970, 59.940). Null for audio-only content. | Column source_frame_rate (DECIMAL(6,3)) in content.ingest_event' ;
    rdfs:domain ind:IngestEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceResolution rdf:type rdf:Property ;
    rdfs:label 'Source Resolution' ;
    rdfs:comment 'The video resolution of the ingested content (e.g., 1920x1080, 3840x2160, 1280x720). Null for audio-only content. | Column source_resolution (STRING) in content.ingest_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Primary key for package | Column package_id (BIGINT) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content packages sold to distributors/platforms generate invoices. Sales operations and revenue accounting track which invoices bill for which packages for revenue allocation, package performance anal | Column billing_invoice_id (BIGINT) in billing.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'The externally-known unique business identifier or code for the package used in contracts, invoicing, and distribution systems. | Column package_code (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialContext rdf:type rdf:Property ;
    rdfs:label 'Commercial Context' ;
    rdfs:comment 'Free-text description of the business purpose or deal context for which the package was assembled, such as upfront sales event, scatter market offering, MVPD (Multichannel Video Programming Distributor) carriage negotiation, or international syndication deal. | Column commercial_context (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A detailed narrative description of the package content, target audience, and commercial positioning. Used for marketing, sales proposals, and catalog listings. | Column package_description (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Required Flag' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection is required for distribution of this package (True/False). Critical for rights enforcement and anti-piracy compliance. | Column drm_required_flag (BOOLEAN) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language of the content in the package, expressed as ISO 639-2 three-letter language code (e.g., eng, spa, fra). Critical for localization and international distribution. | Column language_primary (STRING) in content.package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'The business name or title of the content package as recognized in commercial agreements and distribution deals. | Column package_name (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package: draft (under construction), active (available for distribution), suspended (temporarily unavailable), expired (past effective period), terminated (cancelled before expiry), or archived (historical record). | Column package_status (STRING) in content.package' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The classification of the package based on its commercial or distribution purpose: syndication (content resale to multiple outlets), SVOD (Subscription Video On Demand) library (subscription-based catalog), AVOD (Advertising-Supported Video On Demand) catalog (ad-supported offering), FAST (Free Ad-Supported Streaming Television) channel (linear streaming channel), educational (academic or training content bundle), or international (cross-border distribution bundle). | Column package_type (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Hours' ;
    rdfs:comment 'The aggregate runtime of all content in the package, expressed in hours. Used for programming and scheduling calculations. | Column total_runtime_hours (DECIMAL(10,2)) in content.package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleCount rdf:type rdf:Property ;
    rdfs:label 'Total Title Count' ;
    rdfs:comment 'The total number of distinct titles (episodes, films, clips, or other content assets) included in the package. Used for inventory reporting and deal valuation. | Column total_title_count (INT) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueUsd rdf:type rdf:Property ;
    rdfs:label 'Value Usd' ;
    rdfs:comment 'The estimated or contracted commercial value of the package in United States Dollars (USD). Used for revenue forecasting, deal valuation, and financial reporting. | Column value_usd (DECIMAL(15,2)) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Finding Id' ;
    rdfs:comment 'Primary key for compliance_finding | Column compliance_finding_id (BIGINT) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceFinding .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Content compliance findings discovered during SOX, FCC, or internal audits are recorded as audit findings for remediation tracking, management response, and auditor verification. Essential for audit c | Column audit_finding_id (BIGINT) in compliance.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:complianceIncidentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.incident. Business justification: Content compliance findings are compliance incidents requiring incident management workflow (root cause analysis, corrective action, regulatory notification). Links finding to enterprise incident trac | Column compliance_incident_id (BIGINT) in compliance.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Content compliance findings (broadcast standards violations, content rating disputes) trigger FCC/regulatory filings. Broadcasters must link findings to formal regulatory submissions for audit trail a | Column regulatory_filing_id (BIGINT) in compliance.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:responsibleOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory compliance findings must link to the responsible compliance officer for FCC/regulatory reporting, escalation workflows, and accountability tracking. Essential for broadcast license maintena | Column responsible_officer_employee_id (BIGINT) in workforce.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transmissionEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Transmission Equipment Id' ;
    rdfs:comment 'Foreign key linking to technology.transmission_equipment. Business justification: Technical compliance issues (closed captioning failure, audio levels) are equipment-specific. FCC incident reports, equipment maintenance triggers, root cause analysis, and corrective action tracking  | Column transmission_equipment_id (BIGINT) in technology.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionEquipment .

ind:violatedLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Violated License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Compliance violations often stem from license agreement breaches (unauthorized territory, expired rights, platform violations). Audit trails and remediation workflows require linking findings to the v | Column violated_license_agreement_id (BIGINT) in rights.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:affectedBroadcastDate rdf:type rdf:Property ;
    rdfs:label 'Affected Broadcast Date' ;
    rdfs:comment 'The date on which the content was broadcast or distributed when the compliance issue occurred. Nullable if the finding relates to pre-broadcast content or non-time-specific violations. | Column affected_broadcast_date (DATE) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedDaypart rdf:type rdf:Property ;
    rdfs:label 'Affected Daypart' ;
    rdfs:comment 'The broadcast daypart (time segment of broadcast day) during which the compliance issue occurred, relevant for content standards and audience protection regulations (e.g., prime time, children\'s programming hours, late night). | Column affected_daypart (STRING) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedPlatform rdf:type rdf:Property ;
    rdfs:label 'Affected Platform' ;
    rdfs:comment 'The distribution platform or channel type where the compliance issue was identified: linear (traditional broadcast), OTT (Over-The-Top), VOD (Video On Demand), SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), FAST (Free Ad-Supported Streaming Television), streaming, mobile, web. [ENUM-REF-CANDIDATE: linear|OTT|VOD|SVOD|AVOD|TVOD|FAST|streaming|mobile|web — 10 candidates stripped; promote to reference product] | Column affected_platform (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitReference rdf:type rdf:Property ;
    rdfs:label 'Affidavit Reference' ;
    rdfs:comment 'Reference number or identifier for the broadcast affidavit (proof of broadcast) associated with this compliance finding, if applicable. | Column affidavit_reference (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Comprehensive audit trail documenting all actions, decisions, communications, and status changes related to this compliance finding throughout its lifecycle. | Column audit_trail (STRING) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'Category of compliance finding: broadcast_standard (FCC technical violations), content_standard (Ofcom content breach), rating_dispute (MPA rating challenge), accessibility (closed-caption or audio description QC), privacy (COPPA, GDPR violations), blackout_restriction (geographic restriction enforcement). | Column compliance_type (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action plan or measures implemented to address the root cause and prevent recurrence of the compliance issue. | Column corrective_action (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The business department or organizational unit responsible for addressing the compliance finding (e.g., Legal, Compliance, Content Operations, Broadcast Engineering, Digital Distribution). | Column department (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The deadline or target date by which the compliance finding must be resolved or remediated, as mandated by regulatory requirements or internal policy. | Column due_date (DATE) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the compliance finding was escalated to senior management, legal counsel, or external regulatory authority. Nullable if no escalation occurred. | Column escalation_date (DATE) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCaseNumber rdf:type rdf:Property ;
    rdfs:label 'External Case Number' ;
    rdfs:comment 'Case number or reference identifier assigned by the external regulatory body or governing authority for tracking this compliance matter in their system. | Column external_case_number (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'The date on which the compliance finding was identified, logged, or officially reported by the regulatory body or internal compliance team. | Column finding_date (DATE) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the compliance finding, typically assigned by the compliance system or regulatory body for tracking and reference purposes. | Column finding_number (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Monetary fine or penalty amount assessed by the regulatory body for this compliance violation. Nullable if no financial penalty was imposed. | Column fine_amount (DECIMAL(15,2)) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fineCurrency rdf:type rdf:Property ;
    rdfs:label 'Fine Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fine amount (e.g., USD, GBP, EUR). | Column fine_currency (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic region, territory, or jurisdiction to which this compliance finding applies, using 3-letter ISO country codes or regional identifiers (e.g., USA, GBR, EUR). Relevant for blackout restrictions, regional content standards, and jurisdiction-specific regulations. | Column geographic_scope (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Makegoods Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether compensatory ad spots (makegoods) are required as part of the resolution for advertising-related compliance issues. | Column makegoods_required_flag (BOOLEAN) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures, process improvements, or controls implemented to reduce the likelihood of similar compliance issues occurring in the future. | Column preventive_action (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean flag indicating whether this compliance finding is a recurrence of a previously identified issue for the same title or similar content. | Column recurrence_flag (BOOLEAN) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or regulatory authority that issued or is associated with this compliance finding: FCC (Federal Communications Commission), Ofcom (UK Office of Communications), MPA (Motion Picture Association), ATSC (Advanced Television Systems Committee), DVB (Digital Video Broadcasting), ISO (International Organization for Standardization), GDPR (General Data Protection Regulation), CCPA (California Consumer Privacy Act), COPPA (Children\'s Online Privacy Protection Act), PCI_DSS (Payment Card Industry Data Security Standard), or Internal (self-identified compliance issue). [ENUM-REF-CANDIDATE: FCC|Ofcom|MPA|ATSC|DVB|ISO|GDPR|CCPA|COPPA|PCI_DSS|Internal — 11 candidates stripped; promote to reference product] | Column regulatory_body (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCost rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost' ;
    rdfs:comment 'Estimated or actual cost incurred by the organization to remediate the compliance issue, including labor, technology, content rework, and process improvements. Nullable if not tracked or not applicable. | Column remediation_cost (DECIMAL(15,2)) in content.compliance_finding' ;
    rdfs:domain ind:ComplianceFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the compliance finding was resolved, remediated, or formally closed. Nullable if the finding is still open or in progress. | Column resolution_date (DATE) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the resolution actions taken, corrective measures implemented, or explanations for closure of the compliance finding. | Column resolution_notes (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the compliance finding in its resolution lifecycle: open (newly identified, not yet addressed), in_progress (remediation underway), resolved (corrective action completed), closed (finding formally closed and archived), escalated (elevated to higher authority), pending_review (awaiting regulatory or management review). | Column resolution_status (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the compliance violation, documenting the underlying process failure, system defect, human error, or policy gap that led to the non-compliance. | Column root_cause (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'The severity classification of the compliance finding indicating the level of risk, impact, or urgency: critical (immediate action required, significant regulatory or reputational risk), high (prompt action needed), medium (moderate impact), low (minor issue), informational (advisory or observation). | Column severity_level (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the compliance violation, including the specific standard or regulation breached, the nature of the non-compliance, and any relevant context or circumstances. | Column violation_description (STRING) in content.compliance_finding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Title Relationship Id' ;
    rdfs:comment 'Unique identifier for the title relationship record. Primary key. | Column title_relationship_id (BIGINT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTitleRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Parent Title Relationship Id' ;
    rdfs:comment 'Self-referencing FK on title_relationship (parent_title_relationship_id) | Column parent_title_relationship_id (BIGINT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleRelationship .

ind:sourceTitleId rdf:type rdf:Property ;
    rdfs:label 'Source Title Id' ;
    rdfs:comment 'The originating content title in the relationship. References the title that serves as the starting point of the relationship (e.g., the original film in a sequel relationship, the parent series in a spin-off). | Column source_title_id (BIGINT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:targetTitleId rdf:type rdf:Property ;
    rdfs:label 'Target Title Id' ;
    rdfs:comment 'The destination content title in the relationship. References the title that is the result or endpoint of the relationship (e.g., the sequel film, the spin-off series, the remake). | Column target_title_id (BIGINT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:bidirectionalFlag rdf:type rdf:Property ;
    rdfs:label 'Bidirectional Flag' ;
    rdfs:comment 'Indicates whether the relationship should be surfaced in both directions (e.g., show sequel on original AND show original on sequel). True for symmetric relationships like franchise siblings or crossovers, false for asymmetric relationships like clip-of or compilation. | Column bidirectional_flag (BOOLEAN) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canonicalOrder rdf:type rdf:Property ;
    rdfs:label 'Canonical Order' ;
    rdfs:comment 'The sequence position of the target title within a series or franchise when viewed in canonical order (e.g., Episode IV is canonical_order 4 in Star Wars franchise). Null for non-sequential relationships like remakes or crossovers. | Column canonical_order (INT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chronologicalOrder rdf:type rdf:Property ;
    rdfs:label 'Chronological Order' ;
    rdfs:comment 'The sequence position of the target title when viewed in story chronological order (e.g., Episode I is chronological_order 1 in Star Wars despite being released later). Null for non-sequential relationships. | Column chronological_order (INT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric ranking (lower numbers = higher priority) controlling the order in which related titles are displayed in user interfaces, Electronic Program Guides (EPG), and recommendation carousels. Enables editorial control over content discovery presentation. | Column display_priority (INT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editorialNotes rdf:type rdf:Property ;
    rdfs:label 'Editorial Notes' ;
    rdfs:comment 'Free-text notes from content editors or curators explaining the nature, context, or nuances of the relationship. May include information about shared characters, plot connections, or reasons for the relationship classification. | Column editorial_notes (STRING) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier for this relationship in an external system or metadata provider (e.g., EIDR relationship ID, ISAN linkage ID, third-party content graph ID). Enables cross-system reconciliation and metadata enrichment. | Column external_reference_code (STRING) in content.title_relationship' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVisibility rdf:type rdf:Property ;
    rdfs:label 'Platform Visibility' ;
    rdfs:comment 'Comma-separated list of platforms or distribution channels where this relationship should be surfaced (e.g., OTT, Linear, SVOD, AVOD, FAST). Enables platform-specific content discovery strategies. Empty or null indicates visibility across all platforms. | Column platform_visibility (STRING) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationWeight rdf:type rdf:Property ;
    rdfs:label 'Recommendation Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) indicating the priority or relevance of this relationship for recommendation engine algorithms. Higher weights indicate stronger recommendation signals. Used to tune content discovery and auto-play sequences. | Column recommendation_weight (DECIMAL(5,2)) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipDirection rdf:type rdf:Property ;
    rdfs:label 'Relationship Direction' ;
    rdfs:comment 'Indicates the directionality of the relationship. Forward means source points to target, reverse means target points back to source, bidirectional means the relationship is mutual and non-hierarchical (e.g., franchise siblings). | Column relationship_direction (STRING) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship. Active relationships are live and used by recommendation engines. Pending relationships are scheduled but not yet effective. Inactive relationships are temporarily disabled. Deprecated relationships are historical and no longer relevant. | Column relationship_status (STRING) in content.title_relationship' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Indicates the strength or importance of the relationship for content discovery and recommendation purposes. Primary relationships are direct and essential (e.g., direct sequel), secondary are significant but less direct (e.g., shared universe), tertiary are weak connections (e.g., cameo appearance), tangential are loosely related (e.g., similar theme). | Column relationship_strength (STRING) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The nature of the relationship between the source and target titles. Defines how the two content assets are connected (e.g., sequel indicates target follows source chronologically, spin-off indicates target derives characters/universe from source, remake indicates target is a new version of source). [ENUM-REF-CANDIDATE: sequel|prequel|remake|reboot|spin-off|compilation|clip-of|franchise-sibling|crossover|adaptation|parody|documentary-of|behind-the-scenes — promote to reference product] | Column relationship_type (STRING) in content.title_relationship' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrder rdf:type rdf:Property ;
    rdfs:label 'Release Order' ;
    rdfs:comment 'The sequence position of the target title in the order of original release or premiere dates within the franchise or relationship set. Supports viewing content in historical release sequence. | Column release_order (INT) in content.title_relationship' ;
    rdfs:domain ind:TitleRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the user, editor, or system that verified the accuracy of this relationship. Null for unverified relationships. Supports audit trail and quality assurance. | Column verified_by (STRING) in content.title_relationship' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier or name of the user, system, or process that created this relationship record. Supports audit trail and accountability. | Column created_by (STRING) in content.title_relationship' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesTalentCreditId rdf:type rdf:Property ;
    rdfs:label 'Series Talent Credit Id' ;
    rdfs:comment 'Unique identifier for this series talent credit record. Primary key for the association. | Column series_talent_credit_id (BIGINT) in content.series_talent_credit' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characterName rdf:type rdf:Property ;
    rdfs:label 'Character Name' ;
    rdfs:comment 'The name of the character portrayed by the talent in this series, if applicable. Null for non-acting roles. Derived from detection phase relationship data. | Column character_name (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The total compensation amount for this talent\'s series-level engagement. May represent per-episode rate or series total depending on contract structure. Sensitive financial data. Derived from detection phase relationship data. | Column compensation_amount (DECIMAL) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditEndDate rdf:type rdf:Property ;
    rdfs:label 'Credit End Date' ;
    rdfs:comment 'The date when this talent\'s credited involvement in the series ended. Null for ongoing roles. Used for residual eligibility windows. | Column credit_end_date (DATE) in content.series_talent_credit' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditStartDate rdf:type rdf:Property ;
    rdfs:label 'Credit Start Date' ;
    rdfs:comment 'The date when this talent\'s credited involvement in the series began. Used for tenure calculation and anniversary tracking. | Column credit_start_date (DATE) in content.series_talent_credit' ;
    rdfs:domain ind:SeriesTalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:episodeScopeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Scope End' ;
    rdfs:comment 'The last episode identifier where this talent\'s involvement ends in the series. Null for ongoing roles. Supports character arc tracking and residual calculation. Derived from detection phase relationship data. | Column episode_scope_end (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeScopeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Scope Start' ;
    rdfs:comment 'The first episode identifier where this talent\'s involvement begins in the series. Supports partial-series engagements and guest appearances. Derived from detection phase relationship data. | Column episode_scope_start (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'High-level classification of the talent\'s role in the series. Used for credit sequencing and union reporting. Derived from detection phase relationship data. | Column role_category (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'The specific role or job function the talent performed in this series (e.g., Lead Actor, Director, Executive Producer, Writer). Derived from detection phase relationship data. | Column role_name (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'The current status of this talent\'s role in the series. Indicates whether the role is ongoing, completed, or recurring across seasons. Derived from detection phase relationship data. | Column role_status (STRING) in content.series_talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditId rdf:type rdf:Property ;
    rdfs:label 'Credit Id' ;
    rdfs:comment 'Unique identifier for this talent credit record. Primary key for the credit association. | Column credit_id (BIGINT) in content.credit' ;
    rdfs:domain ind:Credit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newsroomNewsStoryId rdf:type rdf:Property ;
    rdfs:label 'Newsroom News Story Id' ;
    rdfs:comment 'FK to newsroom.news_story for news-related credits' ;
    rdfs:domain ind:Credit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NewsStory .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval workflow state for this credit. Tracks whether the talent and legal have approved the credit wording, billing position, and character name. | Column approval_status (STRING) in content.credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'The absolute display order of this credit in the end credits sequence. Determines the exact position in the credit roll for broadcast and streaming. | Column display_order (INT) in content.credit' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time when this credit relationship ended or was completed. Used for tracking production timelines and contract fulfillment. | Column end_timestamp (TIMESTAMP) in content.credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The date and time when this credit relationship became effective. Typically corresponds to the start of the talent\'s work on this title. | Column start_timestamp (TIMESTAMP) in content.credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingLineId rdf:type rdf:Property ;
    rdfs:label 'Billing Line Id' ;
    rdfs:comment 'Unique identifier for this content billing line item. Primary key. | Column billing_line_id (BIGINT) in content.billing_line' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Finance Cost Center Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period for this specific title line item. Supports ASC 606 revenue recognition at the line level. | Column billing_period_end_date (DATE) in content.billing_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period for this specific title line item. May differ from invoice-level billing period for mid-period license activations or consumption-based billing. | Column billing_period_start_date (DATE) in content.billing_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseWindowType rdf:type rdf:Property ;
    rdfs:label 'License Window Type' ;
    rdfs:comment 'Type of distribution window being billed for this title (SVOD, TVOD, AVOD, Linear, Syndication, Theatrical). Determines revenue recognition treatment and pricing model. | Column license_window_type (STRING) in content.billing_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total amount for this billing line before taxes and adjustments. Calculated as units_consumed × rate_per_unit, or flat fee for fixed-price licensing. | Column line_amount (DECIMAL(18,2)) in content.billing_line' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Status of this billing line item in the revenue recognition workflow (pending, recognized, disputed, adjusted, voided). | Column line_status (STRING) in content.billing_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Billing rate per consumption unit for this title-territory-window combination. Supports consumption-based billing models (per-stream, per-transaction, per-impression, per-subscriber). | Column rate_per_unit (DECIMAL(18,6)) in content.billing_line' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Revenue share percentage applicable to this title-territory-window combination. Used for SVOD subscription allocation, AVOD ad revenue splits, and syndication revenue sharing agreements. | Column revenue_share_percentage (DECIMAL(5,2)) in content.billing_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsConsumed rdf:type rdf:Property ;
    rdfs:label 'Units Consumed' ;
    rdfs:comment 'Quantity of consumption units for this title during the billing period. Interpretation varies by window type: stream count for SVOD/AVOD, transaction count for TVOD, impression count for advertising, subscriber count for carriage fees. | Column units_consumed (BIGINT) in content.billing_line' ;
    rdfs:domain ind:BillingLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Title Rights Grant Id' ;
    rdfs:comment 'Unique identifier for this title-grant association record. Primary key. | Column title_rights_grant_id (BIGINT) in content.title_rights_grant' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Grant Effective Date' ;
    rdfs:comment 'The date on which this specific title became available under this rights grant. May differ from the grant\'s overall start date if titles are added to an existing grant. | Column grant_effective_date (DATE) in content.title_rights_grant' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Grant Expiry Date' ;
    rdfs:comment 'The date on which rights for this specific title expire under this grant. May differ from the grant\'s overall end date if titles have different term lengths. | Column grant_expiry_date (DATE) in content.title_rights_grant' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The specific platform or distribution channel for which this title is cleared under this grant. A single grant may cover multiple platforms, each tracked separately per title. | Column platform_type (STRING) in content.title_rights_grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runLimit rdf:type rdf:Property ;
    rdfs:label 'Run Limit' ;
    rdfs:comment 'Maximum number of times the content may be broadcast or streamed under this grant. Nullable if unlimited runs are permitted. [Moved from rights_grant: Run limits are often title-specific within a grant (e.g., a catalog grant may allow 10 runs for blockbuster titles but unlimited runs for library content). This should move to runs_allocated in the association.] | Column run_limit (INT) in content.title_rights_grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsAllocated rdf:type rdf:Property ;
    rdfs:label 'Runs Allocated' ;
    rdfs:comment 'Number of broadcast or streaming runs allocated for this specific title under this grant. Titles within the same grant may have different run limits. | Column runs_allocated (INT) in content.title_rights_grant' ;
    rdfs:domain ind:TitleRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsUsed rdf:type rdf:Property ;
    rdfs:label 'Runs Used' ;
    rdfs:comment 'Number of runs already consumed against the run limit. Used for availability tracking and compliance. [Moved from rights_grant: Run consumption must be tracked per title-grant combination, not at the grant level. A grant covering 100 titles needs separate run tracking for each title. This becomes runs_consumed in the association.] | Column runs_used (INT) in content.title_rights_grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleAssetUsageId rdf:type rdf:Property ;
    rdfs:label 'Title Asset Usage Id' ;
    rdfs:comment 'Unique identifier for this title-to-asset usage relationship record. Primary key. | Column title_asset_usage_id (BIGINT) in content.title_asset_usage' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User or system identifier that last modified this usage relationship record. Used for audit trail and accountability. | Column last_modified_by (STRING) in content.title_asset_usage' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformTarget rdf:type rdf:Property ;
    rdfs:label 'Platform Target' ;
    rdfs:comment 'Target distribution platform or channel for this asset-title pairing. Examples: \'Linear Broadcast\', \'Netflix\', \'Hulu\', \'Theatrical\', \'YouTube\', \'Social Media\'. Used for format optimization and delivery workflow routing. | Column platform_target (STRING) in content.title_asset_usage' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this asset is the primary or canonical representation of the title for the given usage context and territory. Used to identify the default asset when multiple options exist (e.g., primary broadcast master vs. backup). | Column primary_flag (BOOLEAN) in content.title_asset_usage' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Status' ;
    rdfs:comment 'Current lifecycle status of this asset-title usage relationship. Active=currently valid for distribution, Pending=scheduled for future activation, Expired=past expiry_date, Suspended=temporarily disabled, Archived=historical record only. | Column usage_status (STRING) in content.title_asset_usage' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable label identifying the specific version or cut of the title represented by this asset. Examples: \'Theatrical Cut\', \'Director\'s Cut\', \'TV Edit\', \'International Version\', \'Trailer 1\', \'Teaser\', \'Behind the Scenes\'. Used for editorial tracking and distribution planning. | Column version_label (STRING) in content.title_asset_usage' ;
    rdfs:domain ind:TitleAssetUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreBuyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Genre Buy Agreement Id' ;
    rdfs:comment 'Unique identifier for this advertiser-genre buy agreement record. Primary key. | Column genre_buy_agreement_id (BIGINT) in content.genre_buy_agreement' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertiserId rdf:type rdf:Property ;
    rdfs:label 'Advertiser Id' ;
    rdfs:comment 'Foreign key linking to the advertiser who has negotiated terms for this genre | Column advertiser_id (BIGINT) in sales.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Advertiser .

ind:salesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Employee Id' ;
    rdfs:comment 'The identifier of the sales account executive who negotiated and owns this genre buy agreement. Links to employee master data. | Column sales_employee_id (BIGINT) in workforce.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of this genre buy agreement (active, pending, expired, suspended, terminated). Tracks the operational state of the commercial relationship. | Column agreement_status (STRING) in content.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Category Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this advertiser has purchased category exclusivity within this genre, preventing direct competitors from advertising in the same genre during the contract period. Explicitly identified in detection phase relationship data. | Column category_exclusivity_flag (BOOLEAN) in content.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The expiration date when this advertiser-genre buy agreement terminates and the negotiated terms no longer apply. Null indicates an evergreen agreement. Explicitly identified in detection phase relationship data. | Column contract_end_date (DATE) in content.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The effective start date when this advertiser-genre buy agreement becomes active and the negotiated terms apply. Explicitly identified in detection phase relationship data. | Column contract_start_date (DATE) in content.genre_buy_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genreCpmPremiumPercent rdf:type rdf:Property ;
    rdfs:label 'Genre Cpm Premium Percent' ;
    rdfs:comment 'The percentage premium (or discount if negative) applied to the base CPM rate for this advertiser when buying inventory within this specific genre. Reflects negotiated pricing that varies by advertiser-genre combination. Explicitly identified in detection phase relationship data. | Column genre_cpm_premium_percent (DECIMAL(5,2)) in content.genre_buy_agreement' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSpendCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Commitment' ;
    rdfs:comment 'The contractually committed minimum advertising spend amount for this advertiser within this genre over the contract period. Used for upfront deal tracking and revenue forecasting. Explicitly identified in detection phase relationship data. | Column minimum_spend_commitment (DECIMAL(15,2)) in content.genre_buy_agreement' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredGenreFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Genre Flag' ;
    rdfs:comment 'Indicates whether this genre has been designated as a preferred or priority genre for this advertiser, typically resulting in preferential ad placement, first-right-of-refusal on premium inventory, or priority scheduling. Explicitly identified in detection phase relationship data. | Column preferred_genre_flag (BOOLEAN) in content.genre_buy_agreement' ;
    rdfs:domain ind:GenreBuyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageInclusionId rdf:type rdf:Property ;
    rdfs:label 'Package Inclusion Id' ;
    rdfs:comment 'Unique identifier for this package inclusion record. Primary key. | Column package_inclusion_id (BIGINT) in content.package_inclusion' ;
    rdfs:domain ind:PackageInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPackageId rdf:type rdf:Property ;
    rdfs:label 'Content Package Id' ;
    rdfs:comment 'Foreign key to content.package. Identifies which package this inclusion belongs to. | Column content_package_id (BIGINT) in content.package_inclusion' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date when this title was added to the package. Used for tracking package evolution and audit purposes. | Column inclusion_date (DATE) in content.package_inclusion' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this title within the package: active (currently included), pending (scheduled for inclusion), expired (inclusion window ended), removed (manually removed), suspended (temporarily unavailable). | Column inclusion_status (STRING) in content.package_inclusion' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseFeeAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Allocated Usd' ;
    rdfs:comment 'The portion of the package license fee allocated to this specific title. Used for revenue allocation, royalty calculations, and content valuation within package deals. | Column license_fee_allocated_usd (DECIMAL(15,2)) in content.package_inclusion' ;
    rdfs:domain ind:PackageInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The ordinal position of this title within the package for display purposes in EPG, catalog listings, or playlists. Used for FAST channel lineups and syndication package ordering. | Column sequence_number (INT) in content.package_inclusion' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seriesCrewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Series Crew Assignment Id' ;
    rdfs:comment 'Unique identifier for this series crew assignment record. Primary key for the association. | Column series_crew_assignment_id (BIGINT) in content.series_crew_assignment' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the crew member completed or left this series assignment. Null for ongoing assignments. Used for crew availability and historical tracking. | Column assignment_end_date (DATE) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the crew member began work on this series assignment. Used for scheduling, availability tracking, and contract compliance. | Column assignment_start_date (DATE) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of this crew assignment. Indicates whether the crew member is actively working, has completed their work, or the assignment is paused/terminated. | Column assignment_status (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructure rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure' ;
    rdfs:comment 'The payment model for this crew assignment. Determines how the employee is compensated for their work on this series. Critical for payroll processing and residuals calculation. Explicitly identified in detection reasoning. | Column compensation_structure (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the employment contract structure for this crew assignment. Determines payment schedule, exclusivity terms, and renewal options. Critical for union compliance and residuals calculation. Explicitly identified in detection reasoning. | Column contract_type (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditName rdf:type rdf:Property ;
    rdfs:label 'Credit Name' ;
    rdfs:comment 'The name to be used in on-screen credits for this crew member on this series. May differ from legal name per union rules or professional preference. | Column credit_name (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPosition rdf:type rdf:Property ;
    rdfs:label 'Credit Position' ;
    rdfs:comment 'The order/position of this crew member\'s credit within their role category. Determines credit sequence in opening/closing titles per union rules. | Column credit_position (INT) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Range End' ;
    rdfs:comment 'Ending episode number within the season scope for this crew assignment. Null if assignment covers entire season or is ongoing. Used for episodic directors, writers, and guest crew. Explicitly identified in detection reasoning. | Column episode_range_end (INT) in content.series_crew_assignment' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Range Start' ;
    rdfs:comment 'Starting episode number within the season scope for this crew assignment. Null if assignment covers entire season. Used for episodic directors, writers, and guest crew. Explicitly identified in detection reasoning. | Column episode_range_start (INT) in content.series_crew_assignment' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualsEligible rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligible' ;
    rdfs:comment 'Indicates whether this crew assignment qualifies for residual payments based on contract type, union rules, and distribution windows. Critical for long-term compensation tracking. | Column residuals_eligible (BOOLEAN) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The specific production role the employee performs on this series. Determines union jurisdiction, credit placement, and compensation structure. Explicitly identified in detection reasoning. | Column role_type (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonScope rdf:type rdf:Property ;
    rdfs:label 'Season Scope' ;
    rdfs:comment 'Identifies which season(s) this crew assignment applies to. May be \'all\', a specific season number, or a range (e.g., \'S1-S3\'). Critical for tracking crew continuity and contract scope. Explicitly identified in detection reasoning. | Column season_scope (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:SeriesCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'The labor union governing this crew assignment. Determines contract terms, minimum compensation, working conditions, and residuals eligibility. | Column union_affiliation (STRING) in content.series_crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPackageId rdf:type rdf:Property ;
    rdfs:label 'Distribution Package Id' ;
    rdfs:comment 'Unique identifier for each title-partner distribution package record. Primary key for the association. | Column distribution_package_id (BIGINT) in content.distribution_package' ;
    rdfs:domain ind:DistributionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'Date when this title was removed from the distribution package for this partner. Null indicates the title is currently active in the package. Used for windowing strategy and rights expiration tracking. | Column exclusion_date (DATE) in content.distribution_package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier classification for this title within the partner package. Determines royalty rates, licensing fees, and revenue share terms specific to this title-partner combination. | Column pricing_tier (STRING) in content.distribution_package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeTransmissionId rdf:type rdf:Property ;
    rdfs:label 'Episode Transmission Id' ;
    rdfs:comment 'Unique identifier for this specific transmission event. Primary key for the episode_transmission association. | Column episode_transmission_id (BIGINT) in content.episode_transmission' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeBroadcastChannelId rdf:type rdf:Property ;
    rdfs:label 'Episode Broadcast Channel Id' ;
    rdfs:comment 'FK to the channel on which the episode was transmitted' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:episodeChannelId rdf:type rdf:Property ;
    rdfs:label 'Episode Channel Id' ;
    rdfs:comment 'Channel on which the episode was transmitted' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual end time of transmission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual start time of transmission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affiliateCallSign rdf:type rdf:Property ;
    rdfs:label 'Affiliate Call Sign' ;
    rdfs:comment 'Call sign of the affiliate station' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateStationCallSign rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Call Sign' ;
    rdfs:comment 'Call sign of the affiliate station' ;
    rdfs:domain ind:EpisodeTransmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airDate rdf:type rdf:Property ;
    rdfs:label 'Air Date' ;
    rdfs:comment 'The calendar date when this episode was transmitted via this equipment. Critical for as-run logs and regulatory compliance reporting. | Column air_date (DATE) in content.episode_transmission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
