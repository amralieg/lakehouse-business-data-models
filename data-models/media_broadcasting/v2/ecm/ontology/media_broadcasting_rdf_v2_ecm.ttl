    rdfs:comment 'Whether follow-up was completed' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Requested Flag' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpRequiredFlag rdf:type rdf:Property ;
