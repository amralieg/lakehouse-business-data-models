    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacement rdf:type rdf:Property ;
    rdfs:label 'Credit Placement' ;
    rdfs:comment 'Specifies where the credit must appear: opening credits, closing credits, both, or promotional materials only. | Column credit_placement (STRING) in talent.credit_attribution' ;
