    rdfs:comment 'Corporate phone number assigned to the employee. May be desk phone, mobile, or extension. Used for business communications and internal directory. | Column work_phone (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
