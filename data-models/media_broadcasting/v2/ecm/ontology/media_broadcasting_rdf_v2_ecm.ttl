    rdfs:range xsd:string .

ind:proposedDealValue rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value' ;
    rdfs:comment 'Total monetary value proposed by the initiating party for this deal, in the deal currency. | Column proposed_deal_value (DECIMAL(18,2)) in partner.deal_negotiation' ;
