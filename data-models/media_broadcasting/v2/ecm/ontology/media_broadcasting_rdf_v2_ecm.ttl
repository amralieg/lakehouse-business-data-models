ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the agreement term is extended (positive) or shortened (negative). Null for amendments that do not modify the agreement duration. | Column term_extension_months (INT) in partner.deal_amendment' ;
