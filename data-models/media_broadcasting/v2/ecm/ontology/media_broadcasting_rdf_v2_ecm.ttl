ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total ad units available' ;
    rdfs:domain ind:SchedulingLocalAvailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseeSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Licensee Sales Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: OTT platforms are licensed to enterprise customers and distribution partners tracked as sales accounts. Supports B2B platform licensing deals, white-label OTT agreements, and enterprise streaming serv | Column licensee_sales_account_id (BIGINT) in sales.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:platformManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Platform Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: OTT platforms require operational ownership for launch management, SLA compliance monitoring, sunset decisions, and incident escalation. Platform managers are accountable for subscriber growth, ARPU t | Column platform_manager_employee_id (BIGINT) in workforce.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:techProjectId rdf:type rdf:Property ;
    rdfs:label 'Tech Project Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_project. Business justification: OTT platforms are launched via technology projects. Required for platform launch project tracking and capex budget allocation. | Column tech_project_id (BIGINT) in technology.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechProject .

ind:adobePropertyCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Property Code' ;
    rdfs:comment 'The unique property identifier assigned to this OTT platform within Adobe Experience Platform (AEP) for audience data collection, segmentation, and personalization. Used to link platform-level engagement events to subscriber profiles and Nielsen cross-platform measurement. | Column adobe_property_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated per active subscriber on this platform, expressed in the platform\'s billing currency. Calculated at the platform level for strategic pricing and investor reporting. Confidential as a key financial performance indicator. Sourced from Zuora revenue recognition data. | Column arpu (DECIMAL(10,4)) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSubscriptionPrice rdf:type rdf:Property ;
    rdfs:label 'Base Subscription Price' ;
    rdfs:comment 'The standard monthly subscription price for this platform in the billing currency. Applicable for SVOD and HYBRID tiers. Null for AVOD and FAST platforms with no subscription fee. Used in Zuora plan configuration and financial forecasting in SAP S/4HANA. | Column base_subscription_price (DECIMAL(10,2)) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary billing currency used on this platform (e.g., \'USD\', \'GBP\', \'EUR\'). Governs Zuora subscription plan pricing, SAP S/4HANA financial reconciliation, and multi-currency revenue reporting. | Column billing_currency (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'The primary CDN provider contracted to deliver streaming content for this OTT platform. Drives SLA monitoring, peering agreements, and cost allocation. \'Multi-CDN\' indicates a load-balanced or failover configuration across multiple providers. Maps to Akamai CDN platform configuration records. | Column cdn_provider (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiProvider rdf:type rdf:Property ;
    rdfs:label 'Dai Provider' ;
    rdfs:comment 'The technology vendor or platform providing DAI services for this OTT platform (e.g., \'Google DAI\', \'FreeWheel\', \'Yospace\', \'Brightcove SSAI\'). Null if DAI is not enabled. Used for vendor management, SLA tracking, and ad revenue reconciliation. | Column dai_provider (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVerified rdf:type rdf:Property ;
    rdfs:label 'Distribution Verified' ;
    rdfs:comment 'Flag indicating distribution verification' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'The DRM technology binding enforced on this platform for content protection. Widevine = Google DRM for Android/Chrome; FairPlay = Apple DRM for iOS/Safari; PlayReady = Microsoft DRM for Windows/Xbox; Multi-DRM = all three enforced simultaneously; NONE = no DRM (e.g., FAST free content). Directly linked to Rightsline rights window enforcement and content clearance workflows. | Column drm_system (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedUrl rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Url' ;
    rdfs:comment 'The URL of the Electronic Program Guide data feed for this platform, used by third-party EPG aggregators, smart TV manufacturers, and vMVPD partners to display scheduling information. Null for pure VOD platforms without a linear schedule. Sourced from Ericsson MediaFirst playout system. | Column epg_feed_url (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Enabled' ;
    rdfs:comment 'Indicates whether this platform operates or hosts FAST channels — linear-style, ad-supported free streaming channels. True = FAST channel delivery active; False = no FAST channel. Relevant for FAST syndication partnerships and Wide Orbit ad scheduling. | Column fast_channel_enabled (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTrialDays rdf:type rdf:Property ;
    rdfs:label 'Free Trial Days' ;
    rdfs:comment 'Number of days in the free trial period offered to new subscribers on this platform. Zero or null if no free trial is offered. Configured in Zuora subscription plans and used in churn rate and LTV analysis. | Column free_trial_days (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR data protection obligations apply to this platform based on its geographic availability and subscriber base. True = GDPR applies (EU/EEA territories served); False = GDPR not applicable. Governs consent management, data subject rights workflows, and Adobe Experience Platform profile handling. | Column gdpr_applicable (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupported rdf:type rdf:Property ;
    rdfs:label 'Hdr Supported' ;
    rdfs:comment 'Indicates whether the platform supports High Dynamic Range video delivery (HDR10, Dolby Vision, or HLG). True = HDR delivery supported; False = SDR only. Relevant for premium content licensing negotiations and CTV device compatibility. | Column hdr_supported (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'The maximum number of simultaneous streams permitted per subscriber account on this platform. Enforced at the entitlement layer to prevent credential sharing and manage CDN bandwidth capacity. A key parameter in Zuora subscription plan configuration. | Column max_concurrent_streams (INT) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDownloadDevices rdf:type rdf:Property ;
    rdfs:label 'Max Download Devices' ;
    rdfs:comment 'The maximum number of devices on which a subscriber may store downloaded content for offline viewing on this platform. Null if offline downloads are not supported. Governed by DRM policy and Rightsline windowing rules. | Column max_download_devices (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVideoResolution rdf:type rdf:Property ;
    rdfs:label 'Max Video Resolution' ;
    rdfs:comment 'The highest video resolution tier supported for streaming on this platform. SD = Standard Definition (480p); HD = High Definition (720p); FHD = Full HD (1080p); 4K = Ultra HD (2160p); 8K = Super Hi-Vision (4320p). Drives ABR profile configuration, CDN bandwidth planning, and content ingest specifications in Dalet Galaxy. | Column max_video_resolution (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdCarriageEligible rdf:type rdf:Property ;
    rdfs:label 'Mvpd Carriage Eligible' ;
    rdfs:comment 'Indicates whether this OTT platform\'s content or channels are eligible for carriage by MVPD or vMVPD partners (cable, satellite, virtual pay-TV operators). True = eligible for carriage agreements; False = direct-to-consumer only. Governs retransmission consent and must-carry negotiations. | Column mvpd_carriage_eligible (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBrand rdf:type rdf:Property ;
    rdfs:label 'Parent Brand' ;
    rdfs:comment 'The overarching corporate or media brand under which this OTT platform operates (e.g., \'Media Broadcasting Group\', \'MB Sports Network\'). Supports brand hierarchy reporting, consolidated audience measurement, and multi-brand advertising sales in Salesforce Media Cloud. | Column parent_brand (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the OTT platform (e.g., \'MB_SVOD_WEB\', \'MB_AVOD_CTV\'). Used in operational systems, contracts, and partner integrations as the canonical platform identifier. Maps to the platform identifier used in Zuora subscription plans and Akamai CDN configuration. | Column platform_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDescription rdf:type rdf:Property ;
    rdfs:label 'Platform Description' ;
    rdfs:comment 'Detailed narrative description of the platform\'s content offering, target audience, and service proposition. Used in partner onboarding documentation, regulatory filings, and internal product catalogues. | Column platform_description (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Official commercial brand name of the OTT platform as presented to subscribers and partners (e.g., \'MediaBroadcast+\', \'MB Sports Live\'). Used in marketing materials, EPG listings, and subscriber-facing interfaces. | Column platform_name (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current lifecycle state of the OTT platform. \'active\' = live and serving audiences; \'beta\' = limited release for testing; \'sunset\' = scheduled for decommission; \'suspended\' = temporarily offline; \'inactive\' = decommissioned. Governs whether the platform is eligible for new subscriber acquisition, ad campaign targeting, and CDN resource allocation. | Column platform_status (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Primary Streaming Protocol' ;
    rdfs:comment 'The primary adaptive bitrate streaming protocol used for content delivery on this platform. HLS = HTTP Live Streaming (Apple standard, widely supported); MPEG-DASH = Dynamic Adaptive Streaming over HTTP (ISO 23009 standard); RTMP = Real-Time Messaging Protocol (legacy live); SRT = Secure Reliable Transport (low-latency live). Drives CDN configuration in Akamai and player SDK selection. | Column primary_streaming_protocol (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled' ;
    rdfs:comment 'Flag indicating programmatic advertising support' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Secondary Streaming Protocol' ;
    rdfs:comment 'Fallback or secondary adaptive bitrate streaming protocol supported by the platform for device compatibility or redundancy. Null or \'NONE\' if only one protocol is used. Supports multi-protocol CDN origin configuration in Akamai. | Column secondary_streaming_protocol (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Business model classification of the OTT platform. SVOD = Subscription Video On Demand (recurring fee, no ads); AVOD = Advertising-Supported Video On Demand (free with ads); TVOD = Transactional Video On Demand (pay-per-view); FAST = Free Ad-Supported Streaming Television (linear-style free channel); HYBRID = combination of tiers. Drives revenue recognition logic in Zuora and ad inventory management in Wide Orbit. | Column service_tier (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Pct' ;
    rdfs:comment 'The contractually committed platform availability target expressed as a percentage (e.g., 99.95). Governs CDN SLA enforcement with Akamai, incident escalation thresholds, and operational reporting. Distinct from actual measured uptime. | Column sla_uptime_target_pct (DECIMAL(5,2)) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Current count of active paying or registered subscribers on this platform as of the last reconciliation cycle. A key operational metric for ARPU calculation, churn rate monitoring, and Zuora revenue reporting. Confidential as it represents commercially sensitive business performance data. | Column subscriber_count (BIGINT) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Planned or actual date on which the OTT platform will be or was decommissioned. Null if the platform has no scheduled end-of-life. Used for subscriber migration planning, contract wind-down, and CDN resource deallocation. | Column sunset_date (DATE) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Device Classes' ;
    rdfs:comment 'Comma-separated list of device categories supported by this platform (e.g., \'web,mobile,ctv,stb,gaming_console\'). Drives device compatibility testing, app store distribution, and audience reach reporting. [ENUM-REF-CANDIDATE: web|mobile|ctv|stb|gaming_console|smart_tv|tablet — promote to reference product] | Column supported_device_classes (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Start Bitrate Kbps' ;
    rdfs:comment 'The minimum target bitrate in kilobits per second at which the ABR player should initiate playback on this platform. Drives ABR profile ladder configuration in Akamai CDN and QoS monitoring thresholds. Key parameter for streaming quality benchmarking. | Column target_start_bitrate_kbps (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraProductCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Code' ;
    rdfs:comment 'The product identifier in Zuora\'s subscription billing platform corresponding to this OTT platform\'s subscription offering. Used for revenue recognition, invoice generation, and subscription lifecycle management. Links the platform master record to Zuora\'s billing product catalogue. | Column zuora_product_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Device Type Id' ;
    rdfs:comment 'Unique identifier for the device type record. Primary key. | Column device_type_id (BIGINT) in distribution.device_type' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:broadcastStandardId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_standard. Business justification: Device types support specific broadcast standards (ATSC 3.0, DVB-T2). Required for device certification and broadcast standard support matrix. | Column broadcast_standard_id (BIGINT) in technology.device_type' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastStandard .

ind:abrProfileDash rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Dash' ;
    rdfs:comment 'Indicates whether the device supports MPEG-DASH (Dynamic Adaptive Streaming over HTTP) adaptive bitrate streaming protocol. | Column abr_profile_dash (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileHls rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Hls' ;
    rdfs:comment 'Indicates whether the device supports HLS (HTTP Live Streaming) adaptive bitrate streaming protocol. | Column abr_profile_hls (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abrProfileSmooth rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Smooth' ;
    rdfs:comment 'Indicates whether the device supports Microsoft Smooth Streaming adaptive bitrate protocol. | Column abr_profile_smooth (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeInstallBase rdf:type rdf:Property ;
    rdfs:label 'Active Install Base' ;
    rdfs:comment 'Estimated number of active devices of this type currently accessing the OTT platform, used for capacity planning and analytics. | Column active_install_base (BIGINT) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the device successfully completed OTT platform certification testing. | Column certification_date (DATE) in distribution.device_type' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the device certification expires and requires re-certification for continued platform support. | Column certification_expiry_date (DATE) in distribution.device_type' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current certification status of the device for OTT platform compatibility (certified, pending, failed, not_tested). | Column certification_status (STRING) in distribution.device_type' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecAudioSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Audio Support' ;
    rdfs:comment 'List of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Pipe-separated list. | Column codec_audio_support (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecVideoSupport rdf:type rdf:Property ;
    rdfs:label 'Codec Video Support' ;
    rdfs:comment 'List of video codecs supported by the device (e.g., H.264, H.265/HEVC, VP9, AV1). Pipe-separated list. | Column codec_video_support (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiSupported rdf:type rdf:Property ;
    rdfs:label 'Dai Supported' ;
    rdfs:comment 'Indicates whether the device supports DAI (Dynamic Ad Insertion) for server-side ad stitching in streaming content. | Column dai_supported (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceCategory rdf:type rdf:Property ;
    rdfs:label 'Device Category' ;
    rdfs:comment 'High-level classification of the device type (e.g., smart TV, mobile phone, tablet, desktop browser, streaming stick, gaming console, set-top box). [ENUM-REF-CANDIDATE: smart_tv|mobile_phone|tablet|desktop_browser|streaming_stick|gaming_console|set_top_box — 7 candidates stripped; promote to reference product] | Column device_category (STRING) in distribution.device_type' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmFairplaySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Fairplay Supported' ;
    rdfs:comment 'Indicates whether the device supports Apple FairPlay DRM for content protection. | Column drm_fairplay_supported (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmPlayreadySupported rdf:type rdf:Property ;
    rdfs:label 'Drm Playready Supported' ;
    rdfs:comment 'Indicates whether the device supports Microsoft PlayReady DRM for content protection. | Column drm_playready_supported (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmWidevineLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Widevine Level' ;
    rdfs:comment 'Google Widevine DRM security level supported (L1 = hardware-backed, L2 = software-backed, L3 = software only, not_supported). | Column drm_widevine_level (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical form factor of the device (handheld, television, desktop, wearable, embedded). | Column form_factor (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrCapable rdf:type rdf:Property ;
    rdfs:label 'Hdr Capable' ;
    rdfs:comment 'Indicates whether the device supports HDR (High Dynamic Range) video playback for enhanced color and contrast. | Column hdr_capable (BOOLEAN) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputMethod rdf:type rdf:Property ;
    rdfs:label 'Input Method' ;
    rdfs:comment 'Primary input method(s) supported by the device (e.g., touchscreen, remote_control, keyboard_mouse, voice, gamepad). Pipe-separated list if multiple. | Column input_method (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Mbps' ;
    rdfs:comment 'Maximum streaming bitrate supported by the device in megabits per second (Mbps), used for ABR profile selection and QoS (Quality of Service) optimization. | Column max_bitrate_mbps (DECIMAL(10,2)) in distribution.device_type' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Specific model name or identifier assigned by the manufacturer (e.g., Galaxy S21, iPhone 13 Pro, Fire TV Stick 4K). | Column model_name (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCapability rdf:type rdf:Property ;
    rdfs:label 'Network Capability' ;
    rdfs:comment 'Network connectivity capabilities of the device (e.g., wifi, ethernet, cellular_4g, cellular_5g). Pipe-separated list if multiple. | Column network_capability (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osFamily rdf:type rdf:Property ;
    rdfs:label 'Os Family' ;
    rdfs:comment 'Operating system family running on the device (e.g., Android, iOS, tvOS, webOS, Tizen, Roku OS, Fire OS, Windows, macOS, Linux, PlayStation, Xbox). [ENUM-REF-CANDIDATE: android|ios|tvos|webos|tizen|roku_os|fire_os|windows|macos|linux|playstation|xbox — 12 candidates stripped; promote to reference product] | Column os_family (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMax rdf:type rdf:Property ;
    rdfs:label 'Os Version Max' ;
    rdfs:comment 'Maximum OS version tested and certified for compatibility. Null indicates no upper bound. | Column os_version_max (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersionMin rdf:type rdf:Property ;
    rdfs:label 'Os Version Min' ;
    rdfs:comment 'Minimum OS version required for OTT (Over-The-Top) platform compatibility and playback support. | Column os_version_min (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolutionClass rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution Class' ;
    rdfs:comment 'Display resolution category supported by the device (SD, HD, Full HD, 4K UHD (Ultra High Definition), 8K UHD). | Column screen_resolution_class (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportEndDate rdf:type rdf:Property ;
    rdfs:label 'Support End Date' ;
    rdfs:comment 'Date when platform support for this device type will be discontinued, after which playback may no longer be guaranteed. | Column support_end_date (DATE) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:userAgentString rdf:type rdf:Property ;
    rdfs:label 'User Agent String' ;
    rdfs:comment 'Standard HTTP user agent string reported by the device, used for device detection and analytics. | Column user_agent_string (STRING) in distribution.device_type' ;
    rdfs:domain ind:DeviceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersionId rdf:type rdf:Property ;
    rdfs:label 'App Version Id' ;
    rdfs:comment 'Unique identifier for each application version release. Primary key for the app_version product. | Column app_version_id (BIGINT) in distribution.app_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppVersion .

ind:abTestCohort rdf:type rdf:Property ;
    rdfs:label 'Ab Test Cohort' ;
    rdfs:comment 'Identifier for the A/B test cohort or experiment group assigned to this application version. Used for controlled feature testing and user experience optimization. | Column ab_test_cohort (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeInstallCount rdf:type rdf:Property ;
    rdfs:label 'Active Install Count' ;
    rdfs:comment 'The current number of active installations of this application version across all users. Used for version adoption tracking and deprecation planning. | Column active_install_count (BIGINT) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticsSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Analytics Sdk Version' ;
    rdfs:comment 'Version of the analytics SDK integrated for tracking user engagement, viewership metrics, and QoS (Quality of Service) data. | Column analytics_sdk_version (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appSizeMb rdf:type rdf:Property ;
    rdfs:label 'App Size Mb' ;
    rdfs:comment 'The total download size of the application package in megabytes. Important for user download experience and app store requirements. | Column app_size_mb (DECIMAL(10,2)) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Internal build identifier assigned by the continuous integration system. Used for precise version tracking and debugging. May be numeric or alphanumeric. | Column build_number (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant' ;
    rdfs:comment 'Indicates whether this application version meets CCPA (California Consumer Privacy Act) requirements for viewer data privacy in California. | Column ccpa_compliant (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Endpoint Url' ;
    rdfs:comment 'The primary CDN (Content Delivery Network) endpoint URL configured for this application version. Determines content delivery infrastructure and streaming performance. | Column cdn_endpoint_url (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionSupport rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Support' ;
    rdfs:comment 'Indicates whether this application version supports closed captioning and subtitles for accessibility compliance. | Column closed_caption_support (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crashReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Crash Reporting Enabled' ;
    rdfs:comment 'Indicates whether automated crash reporting and error tracking is enabled for this application version. Critical for QoS root-cause analysis. | Column crash_reporting_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dashSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Dash Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports MPEG-DASH (Dynamic Adaptive Streaming over HTTP) protocol for video streaming. | Column dash_support_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'The date when this application version will be officially deprecated and no longer supported. Nullable for current production versions. | Column deprecation_date (DATE) in distribution.app_version' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dolbyAtmosEnabled rdf:type rdf:Property ;
    rdfs:label 'Dolby Atmos Enabled' ;
    rdfs:comment 'Indicates whether this application version supports Dolby Atmos immersive audio technology. | Column dolby_atmos_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Drm Library Version' ;
    rdfs:comment 'Version of the DRM (Digital Rights Management) library integrated into this application build. Critical for content protection and license enforcement compliance. | Column drm_library_version (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'Comma-separated list or JSON string of feature flags enabled in this application version. Controls experimental features, A/B test variants, and gradual rollout capabilities. | Column feature_flags (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceUpgradeThreshold rdf:type rdf:Property ;
    rdfs:label 'Force Upgrade Threshold' ;
    rdfs:comment 'The minimum application version number below which users will be forced to upgrade. Used to enforce critical security patches or deprecate incompatible versions. | Column force_upgrade_threshold (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether this application version meets GDPR (General Data Protection Regulation) requirements for user data privacy and consent management in EU markets. | Column gdpr_compliant (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports HDR (High Dynamic Range) video playback for enhanced picture quality. | Column hdr_support_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlsSupportEnabled rdf:type rdf:Property ;
    rdfs:label 'Hls Support Enabled' ;
    rdfs:comment 'Indicates whether this application version supports HLS (HTTP Live Streaming) protocol for adaptive bitrate video delivery. | Column hls_support_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal technical notes and documentation for this application version. Includes deployment instructions, known issues, and rollback procedures. | Column internal_notes (STRING) in distribution.app_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOsVersion rdf:type rdf:Property ;
    rdfs:label 'Minimum Os Version' ;
    rdfs:comment 'The minimum operating system version required to run this application version. Format varies by platform (e.g., iOS 14.0, Android 10, Roku OS 9.4). | Column minimum_os_version (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlinePlaybackEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Playback Enabled' ;
    rdfs:comment 'Indicates whether this application version supports offline content download and playback for SVOD (Subscription Video On Demand) users. | Column offline_playback_enabled (BOOLEAN) in distribution.app_version' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The OTT (Over-The-Top) platform or operating system for which this application version was built. Determines device compatibility and distribution channel. [ENUM-REF-CANDIDATE: iOS|Android|tvOS|Roku|Fire TV|Samsung Tizen|LG webOS|Xbox|PlayStation|Web — 10 candidates stripped; promote to reference product] | Column platform (STRING) in distribution.app_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerSdkVersion rdf:type rdf:Property ;
    rdfs:label 'Player Sdk Version' ;
    rdfs:comment 'Version of the video player SDK embedded in this application. Determines streaming capabilities, ABR (Adaptive Bitrate Streaming) support, and playback features. | Column player_sdk_version (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'User-facing description of new features, bug fixes, and improvements included in this application version. Published in app stores and update notifications. | Column release_notes (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the application version. Tracks progression from development through production release to eventual deprecation. [ENUM-REF-CANDIDATE: development|alpha|beta|release_candidate|released|deprecated|withdrawn — 7 candidates stripped; promote to reference product] | Column release_status (STRING) in distribution.app_version' ;
    rdfs:domain ind:AppVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Rollout Percentage' ;
    rdfs:comment 'The percentage of users to whom this application version is currently deployed. Used for gradual rollout and canary deployment strategies (0.00 to 100.00). | Column rollout_percentage (DECIMAL(5,2)) in distribution.app_version' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedResolutions rdf:type rdf:Property ;
    rdfs:label 'Supported Resolutions' ;
    rdfs:comment 'Comma-separated list of video resolutions supported by this application version (e.g., 480p, 720p, 1080p, 4K). Determines playback quality options. | Column supported_resolutions (STRING) in distribution.app_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Cdn Configuration Id' ;
    rdfs:comment 'Foreign key linking to distribution.cdn_configuration. Business justification: Streaming endpoints use specific CDN configurations. streaming_endpoint.cdn_provider is STRING but should FK to cdn_configuration. Removes cdn_provider STRING. | Column cdn_configuration_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdnConfiguration .

ind:drmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Id' ;
    rdfs:comment 'Foreign key linking to distribution.drm_policy. Business justification: Streaming endpoints enforce specific DRM policies. streaming_endpoint.drm_system is STRING but should FK to drm_policy. Removes drm_system STRING (derivable from drm_policy.drm_system). | Column drm_policy_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrmPolicy .

ind:failoverEndpointId rdf:type rdf:Property ;
    rdfs:label 'Failover Endpoint Id' ;
    rdfs:comment 'Reference to the backup streaming endpoint that should be used if this endpoint becomes unavailable. Supports high availability and disaster recovery. | Column failover_endpoint_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to technology.maintenance_work_order. Business justification: Streaming endpoints require maintenance work orders for updates and repairs. Required for endpoint maintenance history and downtime impact tracking. | Column maintenance_work_order_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceWorkOrder .

ind:marketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Market Coverage Id' ;
    rdfs:comment 'Foreign key linking to audience.market_coverage. Business justification: CDN endpoints serve specific DMAs for geo-restriction enforcement, local ad insertion, and market-specific content delivery. Required for retransmission consent compliance and must-carry obligations i | Column market_coverage_id (BIGINT) in audience.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:networkCircuitId rdf:type rdf:Property ;
    rdfs:label 'Network Circuit Id' ;
    rdfs:comment 'Foreign key linking to technology.network_circuit. Business justification: Streaming endpoints rely on network circuits for connectivity. Required for circuit capacity planning and endpoint failover configuration. | Column network_circuit_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCircuit .

ind:nocMonitorId rdf:type rdf:Property ;
    rdfs:label 'Noc Monitor Id' ;
    rdfs:comment 'Foreign key linking to technology.noc_monitor. Business justification: Streaming endpoints have assigned NOC monitors tracking uptime and latency. Required for NOC monitoring configuration and alert routing. | Column noc_monitor_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocMonitor .

ind:outageRecordId rdf:type rdf:Property ;
    rdfs:label 'Outage Record Id' ;
    rdfs:comment 'Foreign key linking to technology.outage_record. Business justification: Streaming endpoints experience outages requiring tracking. Required for endpoint availability reporting and outage pattern analysis. | Column outage_record_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutageRecord .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to distribution.sla_definition. Business justification: Streaming endpoints have SLA commitments. streaming_endpoint.sla_tier is STRING but should FK to sla_definition. Removes sla_tier STRING (derivable from sla_definition.sla_tier). | Column sla_definition_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:softwareLicenseId rdf:type rdf:Property ;
    rdfs:label 'Software License Id' ;
    rdfs:comment 'Foreign key linking to technology.software_license. Business justification: Streaming endpoints run licensed CDN and DRM software. Required for software license compliance tracking and endpoint cost allocation. | Column software_license_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareLicense .

ind:techSlaId rdf:type rdf:Property ;
    rdfs:label 'Tech Sla Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_sla. Business justification: Streaming endpoints have technology SLAs for uptime and latency. Required for endpoint SLA compliance reporting and performance benchmarking. | Column tech_sla_id (BIGINT) in technology.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechSla .

ind:technicalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Streaming endpoints are critical infrastructure requiring technical ownership for incident response, maintenance windows, configuration changes, and failover testing. Essential for on-call rotations,  | Column technical_owner_employee_id (BIGINT) in workforce.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:technicalStandardCertId rdf:type rdf:Property ;
    rdfs:label 'Technical Standard Cert Id' ;
    rdfs:comment 'Foreign key linking to compliance.technical_standard_cert. Business justification: Streaming endpoints must be certified against technical standards (HLS spec, DASH spec, DRM robustness, accessibility). Each endpoint references its certification records for compliance validation. | Column technical_standard_cert_id (BIGINT) in compliance.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalStandardCert .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was first activated and began serving live traffic. | Column activated_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bandwidthLimitGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Limit Gbps' ;
    rdfs:comment 'Maximum aggregate bandwidth capacity in gigabits per second allocated to this endpoint. Used for capacity planning and cost management. | Column bandwidth_limit_gbps (DECIMAL(10,2)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheTtlSeconds rdf:type rdf:Property ;
    rdfs:label 'Cache Ttl Seconds' ;
    rdfs:comment 'The duration in seconds that content should be cached at edge locations before refreshing from origin. Balances freshness with CDN efficiency. | Column cache_ttl_seconds (INT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerGb rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb' ;
    rdfs:comment 'The CDN provider\'s charge per gigabyte of data transferred through this endpoint. Used for cost allocation and financial forecasting. | Column cost_per_gb (DECIMAL(10,4)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was deactivated or taken out of service. Null if currently active. | Column deactivated_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drmLicenseServerUrl rdf:type rdf:Property ;
    rdfs:label 'Drm License Server Url' ;
    rdfs:comment 'URL of the DRM license server that provides decryption keys and enforces content protection policies for this endpoint. Critical for securing premium content. | Column drm_license_server_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Human-readable name or label for the streaming endpoint, used for identification and operational reference. | Column endpoint_name (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Classification of the endpoint role within the CDN architecture. Origin endpoints serve as the source, edge endpoints serve end users, and backup endpoints provide failover capability. | Column endpoint_type (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The full URL address of the streaming endpoint, including protocol, domain, and path. This is the technical delivery address for the stream. | Column endpoint_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionMode rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Mode' ;
    rdfs:comment 'Defines whether geo_restriction_rules represent an allow list (whitelist) or deny list (blacklist) for content delivery. | Column geo_restriction_mode (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Rules' ;
    rdfs:comment 'Comma-separated list of ISO country codes or regions where content delivery is allowed or blocked. Enforces territorial licensing and rights management requirements. | Column geo_restriction_rules (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which automated health checks are performed against this endpoint. | Column health_check_interval_seconds (INT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCheckUrl rdf:type rdf:Property ;
    rdfs:label 'Health Check Url' ;
    rdfs:comment 'URL endpoint used for automated health monitoring and availability checks. Returns status codes indicating endpoint health. | Column health_check_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv6Enabled rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Enabled' ;
    rdfs:comment 'Indicates whether this endpoint supports IPv6 addressing in addition to IPv4, enabling delivery to modern network infrastructures. | Column ipv6_enabled (BOOLEAN) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'The date and time of the most recent successful health check performed on this endpoint. | Column last_health_check_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestFormat rdf:type rdf:Property ;
    rdfs:label 'Manifest Format' ;
    rdfs:comment 'The streaming manifest file format used by this endpoint. m3u8 for HLS, mpd for MPEG-DASH, ism for Smooth Streaming, f4m for Adobe HDS. | Column manifest_format (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the streaming endpoint. Active endpoints are serving traffic; inactive endpoints are provisioned but not in use; maintenance indicates scheduled downtime. | Column operational_status (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedDate rdf:type rdf:Property ;
    rdfs:label 'Provisioned Date' ;
    rdfs:comment 'The date when this streaming endpoint was initially provisioned and configured in the CDN infrastructure. | Column provisioned_date (DATE) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Percent' ;
    rdfs:comment 'The contractual uptime percentage target for this endpoint (e.g., 99.99%). Used for SLA compliance monitoring and vendor accountability. | Column sla_uptime_target_percent (DECIMAL(5,2)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sslCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the SSL/TLS certificate securing this endpoint. Critical for maintaining secure HTTPS delivery and avoiding service disruptions. | Column ssl_certificate_expiry_date (DATE) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDevices rdf:type rdf:Property ;
    rdfs:label 'Supported Devices' ;
    rdfs:comment 'Comma-separated list of device types or platforms that this endpoint is optimized to serve (e.g., iOS, Android, Smart TV, Web Browser, Set-Top Box). | Column supported_devices (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenAuthenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Scheme' ;
    rdfs:comment 'The authentication mechanism used to secure access to the endpoint. Prevents unauthorized access and hotlinking through cryptographic token validation. | Column token_authentication_scheme (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: ABR profiles implement technical delivery standards (codec, bitrate ladder, resolution tiers) defined in format specifications. Broadcasters validate ABR configs against house specs for compliance. Qo | Column format_specification_id (BIGINT) in mediaasset.abr_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:audioBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Audio Bitrate Kbps' ;
    rdfs:comment 'Audio bitrate in kilobits per second (e.g., 128, 192, 256). Defines audio quality. | Column audio_bitrate_kbps (INT) in distribution.abr_profile' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioChannelConfig rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Config' ;
    rdfs:comment 'Audio channel layout (mono, stereo, 5.1 surround, 7.1 surround, Dolby Atmos). Defines spatial audio configuration. | Column audio_channel_config (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnOptimizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Optimization Flag' ;
    rdfs:comment 'Indicates whether the profile is optimized for CDN delivery with caching-friendly segment naming and structure. True if CDN-optimized; false otherwise. | Column cdn_optimization_flag (BOOLEAN) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports DRM encryption. True if DRM is enabled; false otherwise. | Column drm_support_flag (BOOLEAN) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encodingPreset rdf:type rdf:Property ;
    rdfs:label 'Encoding Preset' ;
    rdfs:comment 'Encoder speed/quality preset (fast, medium, slow, veryslow). Slower presets yield better compression but require more processing time. | Column encoding_preset (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Hdr Support Flag' ;
    rdfs:comment 'Indicates whether the profile supports HDR (High Dynamic Range) video. True if HDR is enabled; false for SDR (Standard Dynamic Range) only. | Column hdr_support_flag (BOOLEAN) in distribution.abr_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyframeIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Keyframe Interval Seconds' ;
    rdfs:comment 'Interval between keyframes (I-frames) in seconds. Aligns with segment duration for seamless ABR switching. | Column keyframe_interval_seconds (INT) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manifestTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Manifest Template Reference' ;
    rdfs:comment 'Reference to the MPEG-DASH MPD or HLS M3U8 manifest template used for this profile. Defines playlist structure and metadata. | Column manifest_template_reference (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Kbps' ;
    rdfs:comment 'Highest video bitrate in kilobits per second across all renditions in the ladder. Used for high-quality streaming on fast connections. | Column max_bitrate_kbps (INT) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolution rdf:type rdf:Property ;
    rdfs:label 'Max Resolution' ;
    rdfs:comment 'Highest video resolution in the ladder (e.g., \'1920x1080\', \'3840x2160\'). Defines the top quality tier. | Column max_resolution (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Min Bitrate Kbps' ;
    rdfs:comment 'Lowest video bitrate in kilobits per second across all renditions in the ladder. Used for low-bandwidth scenarios. | Column min_bitrate_kbps (INT) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minResolution rdf:type rdf:Property ;
    rdfs:label 'Min Resolution' ;
    rdfs:comment 'Lowest video resolution in the ladder (e.g., \'320x180\', \'640x360\'). Typically used for mobile or constrained bandwidth. | Column min_resolution (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Name of the engineering or operations team responsible for maintaining and updating this ABR profile. | Column owner_team (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for the ABR profile used in transcode job requests and CDN configuration. | Column profile_code (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Detailed description of the ABR profile, including use cases, target audience, and technical notes. | Column profile_description (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name of the ABR profile (e.g., \'Premium 4K HDR\', \'Standard HD\', \'Mobile Optimized\'). | Column profile_name (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renditionCount rdf:type rdf:Property ;
    rdfs:label 'Rendition Count' ;
    rdfs:comment 'Total number of video renditions (bitrate/resolution variants) in the ABR ladder. Typical range is 3-10 renditions. | Column rendition_count (INT) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Segment Duration Seconds' ;
    rdfs:comment 'Duration of each media segment in seconds (e.g., 2, 4, 6, 10). Shorter segments enable faster ABR switching but increase overhead. | Column segment_duration_seconds (INT) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDeviceClass rdf:type rdf:Property ;
    rdfs:label 'Target Device Class' ;
    rdfs:comment 'Primary device class this profile is optimized for (mobile, tablet, desktop, smart TV, set-top box, gaming console). Influences resolution and bitrate choices. | Column target_device_class (STRING) in distribution.abr_profile' ;
    rdfs:domain ind:AbrProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playbackSessionId rdf:type rdf:Property ;
    rdfs:label 'Playback Session Id' ;
    rdfs:comment 'Unique identifier for each individual viewer playback session initiated on the OTT (Over-The-Top) platform. Primary key for the playback session record. | Column playback_session_id (BIGINT) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaybackSession .

ind:playbackDeviceDeviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Playback Device Device Type Id' ;
    rdfs:comment 'Reference to the device used for this playback session. Enables device-level analytics and QoS (Quality of Service) monitoring. | Column device_device_type_id (BIGINT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:playbackDeviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Playback Device Type Id' ;
    rdfs:comment 'Foreign key linking to distribution.device_type. Business justification: Playback sessions should FK to device_type master for accurate device tracking. Removes device_type STRING (derivable from device_type.device_category). | Column device_type_id (BIGINT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceType .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Reference to the subscriber who initiated this playback session. Links to the subscriber master record for audience measurement and personalization. | Column subscriber_id (BIGINT) in subscriber.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:techIncidentId rdf:type rdf:Property ;
    rdfs:label 'Tech Incident Id' ;
    rdfs:comment 'Foreign key linking to technology.tech_incident. Business justification: Playback sessions are impacted by technology incidents. Required for incident viewer impact assessment and session failure correlation. | Column tech_incident_id (BIGINT) in technology.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechIncident .

ind:transactionInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Transaction Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Playback sessions for TVOD, rental, and pay-per-view models generate per-transaction invoices. Real business process: transactional VOD billing, rental revenue recognition, PPV event billing. Role pre | Column transaction_invoice_id (BIGINT) in billing.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:adBreaksServedCount rdf:type rdf:Property ;
    rdfs:label 'Ad Breaks Served Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) served during this playback session. Used for advertising inventory management and revenue reconciliation. | Column ad_breaks_served_count (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Average Bitrate Kbps' ;
    rdfs:comment 'Average streaming bitrate in kilobits per second during the session. Indicates video quality delivered and network performance. | Column average_bitrate_kbps (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnPopLocation rdf:type rdf:Property ;
    rdfs:label 'Cdn Pop Location' ;
    rdfs:comment 'Geographic location identifier of the CDN point of presence that served this session. Critical for CDN performance optimization and SLA monitoring. | Column cdn_pop_location (STRING) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Enabled' ;
    rdfs:comment 'Indicates whether closed captions were enabled during the session. Critical for accessibility compliance reporting and user preference analysis. | Column closed_captions_enabled (BOOLEAN) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of content watched relative to total content duration. Key engagement metric for content performance and recommendation algorithms. | Column completion_percentage (DECIMAL(5,2)) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Content Duration Seconds' ;
    rdfs:comment 'Total duration of the content asset in seconds. Used to calculate completion rate and identify partial vs. full viewing sessions. | Column content_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason the playback session ended. Critical for distinguishing intentional exits from technical failures and optimizing viewer experience. | Column exit_reason (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City where the viewer is located during playback. Enables hyper-local audience analytics and targeted advertising campaigns. | Column geographic_city (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicPostalCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Postal Code' ;
    rdfs:comment 'Postal code derived from viewer location. Used for demographic overlay and targeted advertising. Subject to privacy regulations. | Column geographic_postal_code (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Initial Buffering Duration Ms' ;
    rdfs:comment 'Time in milliseconds from session start until playback began. Key QoS metric for measuring time-to-first-frame and viewer experience. | Column initial_buffering_duration_ms (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackMode rdf:type rdf:Property ;
    rdfs:label 'Playback Mode' ;
    rdfs:comment 'The mode of content consumption: live linear broadcast, VOD (Video On Demand), DVR (time-shifted), or restart. Critical for audience measurement methodology and rights management. | Column playback_mode (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebufferingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Rebuffering Events Count' ;
    rdfs:comment 'Number of rebuffering (stalling) events that occurred during the session. Critical QoS metric for viewer experience and churn prediction. | Column rebuffering_events_count (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Created Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was created in the system. Used for data lineage and operational monitoring. | Column session_created_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Precise timestamp when the playback session ended. Used to calculate total watch duration and session completion metrics. | Column session_end_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the viewer initiated the playback session. Critical for audience measurement, daypart analysis, and concurrent viewer calculations. | Column session_start_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Updated Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was last updated. Supports audit trail and data quality monitoring. | Column session_updated_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalAdDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Duration Seconds' ;
    rdfs:comment 'Cumulative duration of all advertisements served during the session. Essential for advertising billing and viewer experience analysis. | Column total_ad_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRebufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Total Rebuffering Duration Ms' ;
    rdfs:comment 'Cumulative time in milliseconds spent in rebuffering state during the session. Complements rebuffering count for comprehensive QoS analysis. | Column total_rebuffering_duration_ms (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWatchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Watch Duration Seconds' ;
    rdfs:comment 'Total time in seconds the viewer actively watched content during this session. Primary metric for audience measurement and content engagement analysis. | Column total_watch_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Viewer Ip Address' ;
    rdfs:comment 'IP address of the viewer during the playback session. Used for geographic analysis, fraud detection, and blackout enforcement. Subject to GDPR and CCPA privacy regulations. | Column viewer_ip_address (STRING) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosEventId rdf:type rdf:Property ;
    rdfs:label 'Qos Event Id' ;
    rdfs:comment 'Unique identifier for the QoS event record. Primary key. | Column qos_event_id (BIGINT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nocAlertId rdf:type rdf:Property ;
    rdfs:label 'Noc Alert Id' ;
    rdfs:comment 'Foreign key linking to technology.noc_alert. Business justification: QoS events are generated in response to NOC alerts. Required for event correlation analysis and root cause determination. | Column noc_alert_id (BIGINT) in technology.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NocAlert .

ind:adPodPosition rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Position' ;
    rdfs:comment 'Position of the ad pod within the content stream when event_type is ad_pod_insertion. Null for other event types. Used for DAI analysis. | Column ad_pod_position (INT) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Current streaming bitrate in kilobits per second at the time of the event. Reflects the ABR profile tier active during this event. | Column bitrate_kbps (INT) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bufferLevelSeconds rdf:type rdf:Property ;
    rdfs:label 'Buffer Level Seconds' ;
    rdfs:comment 'Amount of video content buffered in the player at the time of the event, measured in seconds. Indicates playback health and risk of stalling. | Column buffer_level_seconds (DECIMAL(8,3)) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnCacheStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Cache Status' ;
    rdfs:comment 'CDN cache status for the content segment at the time of the event: hit (served from cache), miss (fetched from origin), stale (expired cache), bypass (cache bypassed). | Column cdn_cache_status (STRING) in distribution.qos_event' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device on which the playback event occurred: smart TV, mobile phone, tablet, desktop, set-top box, gaming console, etc. | Column device_type (STRING) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadThroughputKbps rdf:type rdf:Property ;
    rdfs:label 'Download Throughput Kbps' ;
    rdfs:comment 'Measured download throughput in kilobits per second at the time of the event. Used by ABR algorithms to determine optimal bitrate. | Column download_throughput_kbps (INT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:droppedFramesCount rdf:type rdf:Property ;
    rdfs:label 'Dropped Frames Count' ;
    rdfs:comment 'Number of video frames dropped by the player at the time of the event. Indicates rendering performance issues. | Column dropped_frames_count (INT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Severity level of the QoS event indicating impact on user experience: critical (playback failure), high (significant degradation), medium (noticeable impact), low (minor impact), info (informational only). | Column event_severity (STRING) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise timestamp when the QoS event occurred during playback, in format yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column event_timestamp (TIMESTAMP) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market where the viewer is located at the time of the event. Used for regional QoS analysis and CDN optimization. | Column geographic_region (STRING) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ispName rdf:type rdf:Property ;
    rdfs:label 'Isp Name' ;
    rdfs:comment 'Name of the Internet Service Provider through which the viewer is connected. Used for ISP-level QoS analysis and peering optimization. | Column isp_name (STRING) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Network Latency Ms' ;
    rdfs:comment 'Network round-trip latency in milliseconds measured at the time of the event. Indicates network performance and potential delivery issues. | Column network_latency_ms (INT) in distribution.qos_event' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'New Bitrate Kbps' ;
    rdfs:comment 'Bitrate in kilobits per second after a bitrate switch event. Populated when event_type is bitrate_switch_up or bitrate_switch_down. Null for other event types. | Column new_bitrate_kbps (INT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originServerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Origin Server Response Time Ms' ;
    rdfs:comment 'Response time in milliseconds from the origin server when CDN cache status is miss. Null for cache hits. Indicates origin performance. | Column origin_server_response_time_ms (INT) in distribution.qos_event' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Playback Position Seconds' ;
    rdfs:comment 'Current playback position in seconds within the content at the time of the event. Used to correlate events with specific content segments. | Column playback_position_seconds (DECIMAL(12,3)) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerState rdf:type rdf:Property ;
    rdfs:label 'Player State' ;
    rdfs:comment 'State of the video player at the time of the event: playing, paused, buffering, seeking, idle, or error. | Column player_state (STRING) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerVersion rdf:type rdf:Property ;
    rdfs:label 'Player Version' ;
    rdfs:comment 'Version identifier of the video player software that generated this QoS event. Used for player-specific issue analysis. | Column player_version (STRING) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Previous Bitrate Kbps' ;
    rdfs:comment 'Bitrate in kilobits per second before a bitrate switch event. Populated when event_type is bitrate_switch_up or bitrate_switch_down. Null for other event types. | Column previous_bitrate_kbps (INT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seekPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Seek Position Seconds' ;
    rdfs:comment 'Playback position in seconds to which the user seeked. Populated when event_type is seek. Null for other event types. | Column seek_position_seconds (DECIMAL(12,3)) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stallDurationMs rdf:type rdf:Property ;
    rdfs:label 'Stall Duration Ms' ;
    rdfs:comment 'Duration of the playback stall or buffering event in milliseconds. Populated when event_type is buffering_start, buffering_end, or stall. Null for other event types. | Column stall_duration_ms (INT) in distribution.qos_event' ;
    rdfs:domain ind:QosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'User agent string of the viewer device and browser/app at the time of the event. Used for device and platform-specific issue analysis. | Column user_agent (STRING) in distribution.qos_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workforce Employee Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicablePlatform rdf:type rdf:Property ;
    rdfs:label 'Applicable Platform' ;
    rdfs:comment 'The OTT platform, CDN, or service to which this SLA applies (e.g., \'OTT Web Platform\', \'Mobile App\', \'Akamai CDN\', \'All Platforms\'). | Column applicable_platform (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'The monetary amount or percentage of the penalty applied per SLA breach incident. | Column breach_penalty_amount (DECIMAL(18,2)) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency' ;
    rdfs:comment 'The currency in which the breach penalty is denominated, using ISO 4217 three-letter currency code. | Column breach_penalty_currency (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when the SLA is breached (credit, refund, none, custom). | Column breach_penalty_type (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Description of the formula or methodology used to calculate the SLA metric from raw measurements. | Column calculation_method (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalThreshold rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold' ;
    rdfs:comment 'The threshold value at which a critical alert is triggered, indicating an SLA breach has occurred or is imminent. | Column critical_threshold (DECIMAL(18,6)) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The system or platform from which the SLA metric data is collected (e.g., \'Akamai CDN Monitoring\', \'Adobe Analytics\', \'Internal QoS System\'). | Column data_source (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA, including business context, objectives, and any special conditions. | Column sla_definition_description (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process and contacts when an SLA breach occurs or is imminent. | Column escalation_procedure (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or events that are excluded from SLA measurement (e.g., scheduled maintenance, force majeure, third-party failures). | Column exclusion_criteria (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the metric is sampled and evaluated (real-time, hourly, daily, weekly, monthly). | Column measurement_frequency (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindow rdf:type rdf:Property ;
    rdfs:label 'Measurement Window' ;
    rdfs:comment 'The time period over which the SLA metric is calculated and evaluated (e.g., \'monthly\', \'daily\', \'rolling_30_days\', \'per_incident\'). | Column measurement_window (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the specific performance metric being measured (e.g., \'Streaming Uptime\', \'Start Time Latency\', \'Rebuffering Ratio\', \'CDN Cache Hit Rate\', \'DRM License Issuance Latency\', \'API Response Time\'). | Column metric_name (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the metric being measured (uptime, latency, throughput, error rate, response time, availability). | Column metric_type (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often SLA performance reports are generated and delivered to stakeholders (real-time, daily, weekly, monthly, quarterly). | Column reporting_frequency (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Unique business identifier or code for the SLA definition used in contracts and operational systems. | Column sla_code (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition (active, inactive, draft, superseded, retired). | Column sla_definition_status (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the SLA definition (e.g., \'Premium Streaming Uptime SLA\', \'Standard CDN Performance SLA\'). | Column sla_name (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA defining the nature of the service commitment (availability, performance, quality, capacity, support, security). | Column sla_type (STRING) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target threshold value that defines the SLA commitment (e.g., 99.9 for 99.9% uptime, 2.0 for 2 seconds latency). | Column target_value (DECIMAL(18,6)) in distribution.sla_definition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'The threshold value at which a warning alert is triggered, indicating performance is approaching but has not yet breached the SLA target. | Column warning_threshold (DECIMAL(18,6)) in distribution.sla_definition' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique identifier for the SLA performance measurement record. | Column sla_performance_id (BIGINT) in distribution.sla_performance' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyCreditMemoId rdf:type rdf:Property ;
    rdfs:label 'Penalty Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: SLA breaches trigger contractual penalties and service credits to distribution partners or advertisers. Real business process: SLA penalty assessment, makegood credit issuance, partner compensation fo | Column penalty_credit_memo_id (BIGINT) in billing.sla_performance' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured value of the SLA metric during the measurement period. Unit of measure is defined in the associated SLA definition. | Column actual_value (DECIMAL(18,4)) in distribution.sla_performance' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedRegion rdf:type rdf:Property ;
    rdfs:label 'Affected Region' ;
    rdfs:comment 'The geographic region or market affected by this SLA measurement. May be a country code, region name, or CDN edge location identifier. | Column affected_region (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the SLA was in breach state during the measurement period. Null if no breach occurred. | Column breach_duration_minutes (INT) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether the SLA was breached during this measurement period. True indicates a breach occurred; False indicates SLA was met. | Column breach_flag (BOOLEAN) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'The severity classification of the SLA breach if one occurred. None indicates no breach; minor through critical indicate escalating severity levels based on business impact. | Column breach_severity (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether this SLA performance measurement is under dispute by the distribution partner or internal stakeholders. True indicates active dispute. | Column dispute_flag (BOOLEAN) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Textual description of the reason for disputing this SLA performance measurement. Captures partner or stakeholder objections for resolution tracking. | Column dispute_reason (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementGranularity rdf:type rdf:Property ;
    rdfs:label 'Measurement Granularity' ;
    rdfs:comment 'The time granularity at which this SLA performance measurement was captured (hourly, daily, weekly, monthly, quarterly, annual). | Column measurement_granularity (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The end timestamp of the measurement period for this SLA performance record. Represents the conclusion of the observation window. | Column measurement_period_end (TIMESTAMP) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The start timestamp of the measurement period for this SLA performance record. Represents the beginning of the observation window. | Column measurement_period_start (TIMESTAMP) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The source system or monitoring tool that captured this SLA performance measurement (e.g., Akamai CDN analytics, Ericsson MediaFirst monitoring, custom QoS probe). Provides data lineage. | Column measurement_source (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The workflow status of this SLA performance measurement record. Tracks progression from initial capture through validation, dispute resolution, and final approval. | Column measurement_status (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'The name of the distribution partner (MVPD, vMVPD, OTT platform, syndication partner) to whom this SLA applies. Used for partner-specific SLA reporting and governance. | Column partner_name (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The monetary penalty or service credit amount assessed due to the SLA breach. Expressed in the contract currency. Null if no penalty applies. | Column penalty_amount (DECIMAL(15,2)) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable Flag' ;
    rdfs:comment 'Boolean indicator of whether a contractual penalty or service credit is applicable due to this SLA breach. True indicates financial or contractual consequences apply. | Column penalty_applicable_flag (BOOLEAN) in distribution.sla_performance' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the penalty amount (e.g., USD, GBP, EUR). | Column penalty_currency_code (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective action taken to address the SLA breach or performance degradation. Documents operational response and resolution steps. | Column remediation_action (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Timestamp' ;
    rdfs:comment 'The timestamp when remediation action was completed and normal service levels were restored. Null if remediation is pending or not applicable. | Column remediation_timestamp (TIMESTAMP) in distribution.sla_performance' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'The high-level category of the root cause for SLA breach or performance degradation (e.g., network congestion, origin server failure, CDN capacity, encoding issue, third-party dependency). [ENUM-REF-CANDIDATE: network|infrastructure|capacity|configuration|third-party|content|security|unknown — promote to reference product] | Column root_cause_category (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed textual description of the root cause analysis findings for the SLA breach or performance issue. Provides operational context for remediation and reporting. | Column root_cause_description (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of individual observations or data points used to calculate the aggregated SLA metric value. Provides statistical context for measurement confidence. | Column sample_size (BIGINT) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The threshold value at which an SLA breach is triggered. May differ from target value to allow for acceptable variance before breach declaration. | Column threshold_value (DECIMAL(18,4)) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'The username or identifier of the user who validated this SLA performance measurement. Part of the approval and sign-off workflow. | Column validated_by (STRING) in distribution.sla_performance' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'The timestamp when this SLA performance measurement was validated and approved. Null if validation is pending. | Column validated_timestamp (TIMESTAMP) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the target value. Calculated as ((actual - target) / target) * 100. | Column variance_percentage (DECIMAL(7,4)) in distribution.sla_performance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The calculated variance between actual value and target value (actual minus target). Positive values indicate over-performance, negative values indicate under-performance. | Column variance_value (DECIMAL(18,4)) in distribution.sla_performance' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointId rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Id' ;
