    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Employee\'s legal middle name or initial as it appears on government-issued identification documents. May be null if not applicable. | Column legal_middle_name (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
