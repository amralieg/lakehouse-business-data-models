    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerAuditEventId rdf:type rdf:Property ;
    rdfs:label 'Partner Audit Event Id' ;
    rdfs:comment 'Unique identifier for the partner audit event record. Primary key. | Column partner_audit_event_id (BIGINT) in partner.partner_audit_event' ;
    rdfs:domain ind:PartnerAuditEvent ;
