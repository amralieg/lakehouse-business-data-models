    rdfs:comment 'Name the employee prefers to be called in day-to-day work interactions. May differ from legal name. Used in email signatures, internal directories, and workplace communications. | Column preferred_name (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationExpiryDate rdf:type rdf:Property ;
