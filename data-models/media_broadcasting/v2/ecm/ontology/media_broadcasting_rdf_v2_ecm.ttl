    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Financial Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the financial reconciliation record. Primary key for the financial reconciliation entity. | Column financial_reconciliation_id (BIGINT) in finance.financial_reconciliation' ;
