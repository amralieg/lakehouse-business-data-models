    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'The total monetary value of the endorsement deal. This is the contracted compensation amount for the talent\'s endorsement services, which varies by talent-advertiser combination and belongs to the deal itself. | Column deal_value_amount (DECIMAL(18,2)) in talent.endorsement_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period End' ;
    rdfs:comment 'The end date of the exclusivity period. After this date, the talent may be free to endorse competitors even if the contract is still active. | Column exclusivity_period_end (DATE) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Period Start' ;
    rdfs:comment 'The start date of any exclusivity period during which the talent cannot endorse competing brands in the same category. May differ from contract start date. | Column exclusivity_period_start (DATE) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moralsClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Morals Clause Flag' ;
    rdfs:comment 'Indicates whether the deal includes a morals clause allowing the advertiser to terminate if the talent engages in conduct that damages their brand reputation. | Column morals_clause_flag (BOOLEAN) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'The agreed payment schedule for the deal value (e.g., \'Lump Sum on Signing\', \'Quarterly Installments\', \'50% upfront, 50% on completion\'). Defines how the deal value is disbursed over time. | Column payment_schedule (STRING) in talent.endorsement_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceDeliverables rdf:type rdf:Property ;
    rdfs:label 'Performance Deliverables' ;
    rdfs:comment 'Description of the specific deliverables the talent must provide (e.g., \'2 TV commercials, 4 social media posts per month, 1 live event appearance\'). Defines the scope of work for this deal. | Column performance_deliverables (STRING) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'The deadline by which the advertiser must exercise their renewal option, if applicable. After this date, the talent is free to negotiate with other advertisers. | Column renewal_deadline_date (DATE) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageMediaTypes rdf:type rdf:Property ;
    rdfs:label 'Usage Media Types' ;
    rdfs:comment 'The media channels where the advertiser is permitted to use the talent\'s endorsement (e.g., \'TV, Digital, Print\', \'Social Media Only\', \'All Media\'). Defines the scope of usage rights. | Column usage_media_types (STRING) in talent.endorsement_deal' ;
    rdfs:domain ind:EndorsementDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTerritory rdf:type rdf:Property ;
