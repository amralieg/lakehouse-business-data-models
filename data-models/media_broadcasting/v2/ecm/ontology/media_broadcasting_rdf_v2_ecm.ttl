ind:obligationAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Obligation Allocation Percentage' ;
    rdfs:comment 'The percentage of responsibility for this regulatory obligation allocated to this specific cost center. Used for budget allocation and accountability tracking. Sum of all allocations for a given obligation should equal 100%. | Column obligation_allocation_percentage (DECIMAL(5,2)) in finance.cost_center_obligation_allocation' ;
    rdfs:domain ind:CostCenterObligationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Authorization Id' ;
    rdfs:comment 'Unique identifier for this cost center authorization record. Primary key. | Column cost_center_authorization_id (BIGINT) in finance.cost_center_authorization' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cost Employee Id' ;
    rdfs:comment 'Foreign key linking to the employee who holds authorization for this cost center | Column employee_id (BIGINT) in workforce.cost_center_authorization' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costGrantedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cost Granted By Employee Id' ;
    rdfs:comment 'Reference to the employee who granted or approved this authorization. Used for audit trail and authorization chain of custody. | Column granted_by_employee_id (BIGINT) in workforce.cost_center_authorization' ;
    rdfs:domain ind:CostCenterAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costRevokedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cost Revoked By Employee Id' ;
