    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Self-reported disability status for OFCCP Section 503 compliance reporting. Collected separately for accommodation and compliance purposes. | Column disability_status (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Start Date' ;
    rdfs:comment 'Earliest date the applicant is available to begin employment if an offer is extended. | Column earliest_start_date (DATE) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
