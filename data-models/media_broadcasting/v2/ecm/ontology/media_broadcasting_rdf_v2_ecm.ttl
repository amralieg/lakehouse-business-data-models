    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Gl Balance Amount' ;
