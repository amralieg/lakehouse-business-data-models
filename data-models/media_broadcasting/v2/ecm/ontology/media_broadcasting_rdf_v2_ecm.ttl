    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorshipName rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Name' ;
    rdfs:comment 'Descriptive name of the sponsorship deal for business reference and reporting. | Column sponsorship_name (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDistribution rdf:type rdf:Property ;
    rdfs:label 'Platform Distribution' ;
    rdfs:comment 'Platforms where the sponsored content will be distributed (linear broadcast, OTT, VOD, digital, social media). | Column platform_distribution (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoredContentType rdf:type rdf:Property ;
    rdfs:label 'Sponsored Content Type' ;
    rdfs:comment 'Type of content being sponsored (program, series, event, segment, etc.). | Column sponsored_content_type (STRING) in sales.sponsorship' ;
