ind:resumeDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Resume Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the applicant\'s resume/CV document stored in the Media Asset Management (MAM) or document management system. | Column resume_document_reference (STRING) in workforce.applicant' ;
