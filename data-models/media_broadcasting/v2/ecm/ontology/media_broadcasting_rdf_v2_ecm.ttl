ind:disputedPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Disputed Period Start Date' ;
    rdfs:comment 'Start date of the time period to which the dispute relates (e.g., billing cycle, content delivery window). | Column disputed_period_start_date (DATE) in partner.partner_dispute' ;
