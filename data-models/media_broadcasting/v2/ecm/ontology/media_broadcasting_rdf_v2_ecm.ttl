    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perEpisodeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee Amount' ;
    rdfs:comment 'Fee amount charged per episode, if applicable. Null if fee structure is not per-episode based. | Column per_episode_fee_amount (DECIMAL(18,2)) in rights.rights_syndication_deal' ;
