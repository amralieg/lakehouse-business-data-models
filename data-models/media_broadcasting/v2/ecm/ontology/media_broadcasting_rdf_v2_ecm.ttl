    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPay rdf:type rdf:Property ;
    rdfs:label 'Regular Pay' ;
    rdfs:comment 'Earnings from regular hours worked at the base hourly or salary rate. Excludes overtime and other premium pay. | Column regular_pay (DECIMAL(15,2)) in workforce.payroll_record' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirement401kDeduction rdf:type rdf:Property ;
    rdfs:label 'Retirement 401k Deduction' ;
