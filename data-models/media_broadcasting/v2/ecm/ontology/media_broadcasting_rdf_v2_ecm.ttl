    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedService rdf:type rdf:Property ;
    rdfs:label 'Impacted Service' ;
    rdfs:comment 'The broadcast service, streaming platform, or distribution channel affected by the compliance incident (e.g., linear broadcast, OTT platform, MVPD service). | Column impacted_service (STRING) in compliance.incident' ;
