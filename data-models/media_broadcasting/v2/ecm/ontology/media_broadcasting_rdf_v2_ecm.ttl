ind:licenseOwnershipId rdf:type rdf:Property ;
    rdfs:label 'License Ownership Id' ;
    rdfs:comment 'Unique identifier for this ownership relationship record. Primary key for the license_ownership association. | Column license_ownership_id (BIGINT) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Regulatory classification indicating whether this ownership interest is attributable under FCC rules (typically interests above 5% for voting stock, 33% for limited partnerships, or any officer/director position). Values: Attributable, Non-Attributable, Pending Review, Exempt. | Column attribution_status (STRING) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRelationshipType rdf:type rdf:Property ;
    rdfs:label 'Control Relationship Type' ;
    rdfs:comment 'Nature of the control or ownership relationship between the partner and the licensed entity. Values: Equity Owner, Parent Company, Officer, Director, General Partner, Limited Partner, Creditor, Other. | Column control_relationship_type (STRING) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Disclosure Required' ;
    rdfs:comment 'Indicates whether this ownership interest must be disclosed on FCC Form 323 or equivalent regulatory filings. True if the interest meets attribution thresholds or involves officers/directors. | Column disclosure_required (BOOLEAN) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory filing (FCC Form 323, license transfer application, etc.) that documents this ownership relationship. Used for audit trail and compliance verification. | Column filing_reference (STRING) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity or voting interest that the partner holds in the licensed entity. Used to determine attributable interest under FCC ownership rules. Values range from 0.01 to 100.00. | Column ownership_percentage (DECIMAL(5,2)) in partner.license_ownership' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Official title or position held by the partner representative in the licensed entity (e.g., CEO, Board Member, General Partner). Applicable when control_relationship_type is Officer, Director, or General Partner. | Column position_title (STRING) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the partner, which may differ from equity ownership percentage in cases of dual-class stock or special voting arrangements. Critical for FCC attribution analysis. | Column voting_rights_percentage (DECIMAL(5,2)) in partner.license_ownership' ;
    rdfs:domain ind:LicenseOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

