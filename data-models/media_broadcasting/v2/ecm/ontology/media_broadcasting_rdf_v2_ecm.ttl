ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value of the sponsorship deal. | Column value_amount (DECIMAL(18,2)) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:politicalAdDisclosureId rdf:type rdf:Property ;
