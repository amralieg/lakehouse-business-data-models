    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total revenue across all streams for the reporting period. Sum of advertising, subscription, carriage fees, syndication, and other revenue. | Column total_revenue_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
