    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer\'s model number or designation for the asset, identifying the specific product line and configuration. | Column model (STRING) in technology.it_asset' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
