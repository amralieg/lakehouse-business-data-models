ind:requiredBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Required Bitrate Mbps' ;
    rdfs:comment 'Minimum or target bitrate in megabits per second required for the delivered content to meet quality standards. | Column required_bitrate_mbps (DECIMAL(10,2)) in partner.delivery_obligation' ;
