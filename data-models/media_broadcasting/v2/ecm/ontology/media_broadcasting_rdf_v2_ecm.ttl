    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCost rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost' ;
    rdfs:comment 'Original purchase price or acquisition cost of the asset in the organization\'s base currency, used for financial reporting and depreciation. | Column procurement_cost (DECIMAL(15,2)) in technology.it_asset' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementDate rdf:type rdf:Property ;
    rdfs:label 'Procurement Date' ;
    rdfs:comment 'Date when the asset was purchased or acquired by the organization, used for depreciation calculations and lifecycle tracking. | Column procurement_date (DATE) in technology.it_asset' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the software application or license, used for compatibility verification, upgrade planning, and support entitlement. | Column software_version (STRING) in technology.it_asset' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContractNumber rdf:type rdf:Property ;
    rdfs:label 'Support Contract Number' ;
    rdfs:comment 'Reference number for extended support or maintenance contract covering this asset beyond standard warranty. | Column support_contract_number (STRING) in technology.it_asset' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage begins for this asset. | Column warranty_start_date (DATE) in technology.it_asset' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redundantNetworkCircuitId rdf:type rdf:Property ;
    rdfs:label 'Redundant Network Circuit Id' ;
    rdfs:comment 'Self-referencing FK on network_circuit (redundant_network_circuit_id) | Column redundant_network_circuit_id (BIGINT) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCircuit .

ind:averageUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Average Utilization Percent' ;
    rdfs:comment 'Average bandwidth utilization as a percentage of provisioned capacity over the most recent measurement period (typically 30 days). Used for capacity planning and right-sizing decisions. Range 0.00 to 100.00. | Column average_utilization_percent (DECIMAL(5,2)) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProviderName rdf:type rdf:Property ;
    rdfs:label 'Carrier Provider Name' ;
    rdfs:comment 'Name of the telecommunications carrier or service provider that provisions and maintains the circuit (e.g., AT&T, Verizon, Level 3, Comcast Business, Intelsat). | Column carrier_provider_name (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTroubleTicketUrl rdf:type rdf:Property ;
    rdfs:label 'Carrier Trouble Ticket Url' ;
    rdfs:comment 'Web URL for the carriers trouble ticket or service portal where incidents and service requests for this circuit can be submitted and tracked. | Column carrier_trouble_ticket_url (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Circuit Identifier' ;
    rdfs:comment 'Business identifier or circuit ID assigned by the carrier or internal network operations team. This is the externally-known reference number used in carrier documentation, trouble tickets, and billing statements. | Column circuit_identifier (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitPurpose rdf:type rdf:Property ;
    rdfs:label 'Circuit Purpose' ;
    rdfs:comment 'Business purpose or use case for the circuit. Examples: live broadcast contribution feed, studio-to-transmitter link (STL), content distribution network (CDN) interconnect, remote production backhaul, disaster recovery link, office internet access, inter-facility MPLS backbone. | Column circuit_purpose (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitType rdf:type rdf:Property ;
    rdfs:label 'Circuit Type' ;
    rdfs:comment 'Classification of the network circuit technology. MPLS (Multiprotocol Label Switching) for managed IP networks, dark fiber for unlit fiber optic infrastructure, satellite for space-based transmission, internet transit for public internet connectivity, dedicated broadcast contribution for live content feeds, ethernet for layer-2 connectivity, wavelength for DWDM optical circuits. [ENUM-REF-CANDIDATE: MPLS|dark_fiber|satellite|internet_transit|dedicated_broadcast_contribution|ethernet|wavelength — 7 candidates stripped; promote to reference product] | Column circuit_type (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedInformationRateMbps rdf:type rdf:Property ;
    rdfs:label 'Committed Information Rate Mbps' ;
    rdfs:comment 'Guaranteed minimum bandwidth committed by the carrier under the SLA, measured in megabits per second. For burstable circuits, this is the sustained rate; peak burst rate may be higher. Equal to bandwidth_mbps for non-burstable circuits. | Column committed_information_rate_mbps (DECIMAL(12,3)) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demarcationPoint rdf:type rdf:Property ;
    rdfs:label 'Demarcation Point' ;
    rdfs:comment 'Physical location description of the network demarcation point where carrier responsibility ends and customer responsibility begins. Typically a patch panel, network interface device (NID), or equipment rack location. | Column demarcation_point (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Address' ;
    rdfs:comment 'Physical street address of the destination facility including street, city, state/province, and postal code. Required for carrier provisioning and site access coordination. | Column destination_facility_address (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Name of the destination facility, remote site, transmission tower, or endpoint where the circuit terminates. This is the Z-end of the circuit. For point-to-multipoint circuits, this represents the primary destination. | Column destination_facility_name (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityRouteIndicator rdf:type rdf:Property ;
    rdfs:label 'Diversity Route Indicator' ;
    rdfs:comment 'Identifier or description of the physical route diversity for this circuit. Used to ensure redundant circuits do not share common failure points (e.g., same conduit, same central office). Examples: Route A, Route B, North Path, South Path. | Column diversity_route_indicator (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'One-time installation or provisioning cost in USD. Includes circuit installation, equipment installation, site survey, and activation fees. Does not include monthly recurring charges. | Column installation_cost (DECIMAL(15,2)) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interfaceType rdf:type rdf:Property ;
    rdfs:label 'Interface Type' ;
    rdfs:comment 'Physical media type of the circuit interface at the customer premises. Fiber optic (single-mode or multi-mode), copper (ethernet over copper), coaxial (cable modem), wireless (microwave or radio), satellite dish (VSAT terminal). | Column interface_type (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressRange rdf:type rdf:Property ;
    rdfs:label 'Ip Address Range' ;
    rdfs:comment 'IP address range or subnet assigned to this circuit in CIDR notation (e.g., 10.50.100.0/24). Applicable for routed IP circuits. Null for layer-2 or non-IP circuits. | Column ip_address_range (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryPath rdf:type rdf:Property ;
    rdfs:label 'Is Primary Path' ;
    rdfs:comment 'Boolean flag indicating whether this circuit is the primary (active) path in a redundant configuration. True for primary circuits, false for backup/standby circuits. Null if redundancy does not apply. | Column is_primary_path (BOOLEAN) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Monitoring Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this circuit is actively monitored by network operations center (NOC) monitoring systems for availability, performance, and threshold alerts. True if monitored, false if not. | Column monitoring_enabled (BOOLEAN) in technology.network_circuit' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyRecurringCost rdf:type rdf:Property ;
    rdfs:label 'Monthly Recurring Cost' ;
    rdfs:comment 'Monthly recurring charge for the circuit service in USD. Includes port fees, bandwidth charges, and managed service fees. Does not include one-time installation costs or usage-based overage charges. | Column monthly_recurring_cost (DECIMAL(15,2)) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned maintenance window for this circuit. Used for change management coordination and service availability planning. | Column next_scheduled_maintenance_date (DATE) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originFacilityAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Address' ;
    rdfs:comment 'Physical street address of the origin facility including street, city, state/province, and postal code. Required for carrier provisioning and site access coordination. | Column origin_facility_address (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityName rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Name' ;
    rdfs:comment 'Name of the originating facility, studio, broadcast center, or network operations center (NOC) where the circuit originates. This is the A-end of the circuit. | Column origin_facility_name (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Peak Utilization Percent' ;
    rdfs:comment 'Peak bandwidth utilization as a percentage of provisioned capacity over the most recent measurement period (typically 30 days). Identifies capacity constraints and congestion risk. Range 0.00 to 100.00. | Column peak_utilization_percent (DECIMAL(5,2)) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date when the circuit was successfully provisioned, tested, and turned up for production use. This is the service activation date, not the order date. | Column provisioning_date (DATE) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the internal technical contact responsible for this circuit. Used for automated alerts and incident notifications. | Column technical_contact_email (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Name of the internal technical contact or network engineer responsible for this circuit. Used for escalation and coordination during incidents or maintenance. | Column technical_contact_name (STRING) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vlanNumber rdf:type rdf:Property ;
    rdfs:label 'Vlan Number' ;
    rdfs:comment 'VLAN identifier used for layer-2 segmentation on this circuit. Applicable for ethernet and MPLS circuits. Range 1-4094 per IEEE 802.1Q standard. Null for non-VLAN circuits. | Column vlan_number (INT) in technology.network_circuit' ;
    rdfs:domain ind:NetworkCircuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundantSignalPathId rdf:type rdf:Property ;
    rdfs:label 'Redundant Signal Path Id' ;
    rdfs:comment 'Self-referencing FK on signal_path (redundant_signal_path_id) | Column redundant_signal_path_id (BIGINT) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SignalPath .

ind:sourceTransmissionEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Source Transmission Equipment Id' ;
    rdfs:comment 'Foreign key linking to technology.transmission_equipment. Business justification: Signal paths originate from transmission equipment (encoder, multiplexer). The \'source_endpoint\' field should reference specific equipment. Adding FK to link the signal path to its source equipment, e | Column source_transmission_equipment_id (BIGINT) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransmissionEquipment .

ind:assignedChannel rdf:type rdf:Property ;
    rdfs:label 'Assigned Channel' ;
    rdfs:comment 'Broadcast channel, frequency, or logical channel identifier associated with this signal path for transmission or distribution purposes. | Column assigned_channel (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Destination Endpoint' ;
    rdfs:comment 'Identifier or address of the terminating endpoint where the signal exits this path. May be a transmitter, encoder, playout server, or distribution output. | Column destination_endpoint (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCorrectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Error Correction Enabled' ;
    rdfs:comment 'Boolean flag indicating whether forward error correction (FEC) or other error correction mechanisms are enabled on this signal path to ensure signal integrity. | Column error_correction_enabled (BOOLEAN) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermediateNodes rdf:type rdf:Property ;
    rdfs:label 'Intermediate Nodes' ;
    rdfs:comment 'Comma-separated list or description of intermediate processing equipment, routers, switches, or nodes that the signal traverses between source and destination. | Column intermediate_nodes (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent failure or outage event recorded for this signal path, used for reliability analysis and maintenance planning. | Column last_failure_timestamp (TIMESTAMP) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Description or reference to the planned maintenance schedule for this signal path, including frequency and maintenance windows. | Column maintenance_schedule (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathCode rdf:type rdf:Property ;
    rdfs:label 'Path Code' ;
    rdfs:comment 'Unique business identifier or code used to reference this signal path in operational systems, scheduling, and technical documentation. | Column path_code (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathName rdf:type rdf:Property ;
    rdfs:label 'Path Name' ;
    rdfs:comment 'Human-readable name or label assigned to this signal routing path for operational identification and reference. | Column path_name (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathType rdf:type rdf:Property ;
    rdfs:label 'Path Type' ;
    rdfs:comment 'Classification of the signal path based on its operational purpose: contribution (incoming feeds), distribution (outgoing delivery), interstitial (internal routing), backhaul (remote site return), studio-to-transmitter link, or satellite uplink. | Column path_type (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPathIndicator rdf:type rdf:Property ;
    rdfs:label 'Primary Path Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this signal path is designated as the primary (true) or backup/secondary (false) path in a redundant configuration. | Column primary_path_indicator (BOOLEAN) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redundancyConfiguration rdf:type rdf:Property ;
    rdfs:label 'Redundancy Configuration' ;
    rdfs:comment 'Redundancy strategy configured for this signal path to ensure continuity: none (single path), primary/backup (failover), active-active (load balanced), N+1 (shared backup), or dual-path (simultaneous routing). | Column redundancy_configuration (STRING) in technology.signal_path' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalFormat rdf:type rdf:Property ;
    rdfs:label 'Signal Format' ;
    rdfs:comment 'Technical format specification of the signal carried on this path, such as HD-SDI 1080i, 4K UHD, MPEG-2 TS, H.264, H.265/HEVC, or audio format specifications. | Column signal_format (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEndpoint rdf:type rdf:Property ;
    rdfs:label 'Source Endpoint' ;
    rdfs:comment 'Identifier or address of the originating endpoint where the signal enters this path. May be an ingest port, satellite receiver, remote contribution feed, or studio source. | Column source_endpoint (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContact rdf:type rdf:Property ;
    rdfs:label 'Technical Contact' ;
    rdfs:comment 'Name or identifier of the technical contact person or team responsible for troubleshooting and maintenance of this signal path. | Column technical_contact (STRING) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Percentage' ;
    rdfs:comment 'Calculated uptime percentage for this signal path over a defined measurement period, used for SLA compliance reporting and performance analysis. | Column uptime_percentage (DECIMAL(5,2)) in technology.signal_path' ;
    rdfs:domain ind:SignalPath ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpMaintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Maintenance Work Order Id' ;
    rdfs:comment 'Self-referencing FK on maintenance_work_order (follow_up_maintenance_work_order_id) | Column follow_up_maintenance_work_order_id (BIGINT) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceWorkOrder .

ind:maintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Id' ;
    rdfs:comment 'Foreign key linking to technology.maintenance_schedule. Business justification: Maintenance work orders can be generated from recurring maintenance schedules (preventive maintenance) or created ad-hoc (reactive maintenance). This FK links scheduled maintenance executions back to  | Column maintenance_schedule_id (BIGINT) in technology.maintenance_work_order' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceSchedule .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Reference to the internal technician or engineer assigned primary responsibility for executing this maintenance work order. May be updated if work is reassigned during execution. | Column primary_maintenance_employee_id (BIGINT) in workforce.maintenance_work_order' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMaintenanceApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Maintenance Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager, engineer, or operations supervisor who approved this work order for execution. Required when approval_required_flag is true, particularly for emergency work or work requiring broadcast service interruption. | Column tertiary_maintenance_approved_by_employee_id (BIGINT) in workforce.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work was completed and asset returned to operational status. Marks the end of the maintenance window and restoration of service availability. | Column actual_end_datetime (TIMESTAMP) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work physically commenced. Used to measure schedule adherence, calculate actual labor duration, and determine precise downtime windows for broadcast operations impact analysis. | Column actual_start_datetime (TIMESTAMP) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Detailed narrative documentation of work performed, findings, corrective actions taken, parts replaced, test results, and any follow-up recommendations. Serves as permanent maintenance history record for the asset. | Column completion_notes (STRING) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the asset or facility was unavailable for broadcast operations due to this maintenance activity. Critical metric for Service Level Agreement (SLA) compliance, availability reporting, and operational impact assessment. | Column downtime_duration_minutes (DECIMAL(10,2)) in technology.maintenance_work_order' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Standardized fault classification code from organizational taxonomy or equipment manufacturer fault code library. Enables categorization, trending analysis, and root cause identification across maintenance events. | Column fault_code (STRING) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this maintenance work order, including internal technician time and external vendor service charges. Used for maintenance budget management and cost per asset analysis. | Column labor_cost_amount (DECIMAL(15,2)) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours expended by technicians and engineers on this maintenance work order. Used for cost allocation, resource utilization analysis, and maintenance budget tracking. May include multiple technicians working concurrently. | Column labor_hours (DECIMAL(10,2)) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceWorkOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance work order. Tracks progression from initial creation through assignment, execution, completion, and closure. On_hold indicates temporary suspension pending parts, approvals, or external dependencies. [ENUM-REF-CANDIDATE: draft|scheduled|assigned|in_progress|on_hold|completed|cancelled|closed — 8 candidates stripped; promote to reference product] | Column maintenance_work_order_status (STRING) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Outage Required Flag' ;
    rdfs:comment 'Indicates whether this maintenance work requires taking the asset or facility offline, resulting in broadcast service interruption. True requires coordination with Network Operations Center (NOC) and scheduling during approved maintenance windows. | Column outage_required_flag (BOOLEAN) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Amount' ;
    rdfs:comment 'Total cost of replacement parts, components, and materials consumed during this maintenance activity. Excludes labor costs. Used for maintenance cost analysis, budget tracking, and asset lifecycle costing. | Column parts_cost_amount (DECIMAL(15,2)) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether a safety incident occurred during execution of this maintenance work order. True triggers mandatory incident investigation, reporting to safety committee, and potential regulatory notification per Occupational Safety and Health Administration (OSHA) requirements. | Column safety_incident_flag (BOOLEAN) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time when maintenance work is expected to be completed. Used for resource planning, outage window management, and coordination with broadcast operations to minimize service disruption. | Column scheduled_end_datetime (TIMESTAMP) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to begin. For preventive maintenance, aligns with maintenance calendar; for corrective work, represents target response time based on priority and Service Level Agreement (SLA). | Column scheduled_start_datetime (TIMESTAMP) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether this work order was completed within the defined Service Level Agreement (SLA) target times for response and resolution. False indicates SLA breach requiring management review and potential customer credits or penalties. | Column sla_compliance_flag (BOOLEAN) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'Target resolution time in minutes from work order creation to completion, as defined by Service Level Agreement (SLA) for this priority level and asset class. Critical metric for measuring maintenance effectiveness and meeting operational commitments. | Column sla_target_resolution_minutes (INT) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Minutes' ;
    rdfs:comment 'Target response time in minutes from work order creation to actual start of work, as defined by Service Level Agreement (SLA) for this priority level and asset class. Used to measure maintenance team responsiveness and SLA compliance. | Column sla_target_response_minutes (INT) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost of this maintenance work order, including parts, labor, vendor charges, and any other direct costs. Primary metric for maintenance expense tracking and asset total cost of ownership analysis. | Column total_cost_amount (DECIMAL(15,2)) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this maintenance work is covered under manufacturer or vendor warranty, enabling cost recovery. True triggers warranty claim process and excludes costs from internal maintenance budget allocation. | Column warranty_claim_flag (BOOLEAN) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance work order by nature of activity: preventive (scheduled routine maintenance), corrective (repair of known issue), emergency (unplanned critical repair), inspection (compliance or condition assessment), upgrade (enhancement or modernization), decommission (asset retirement). | Column work_order_type (STRING) in technology.maintenance_work_order' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMaintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Parent Maintenance Schedule Id' ;
    rdfs:comment 'Self-referencing FK on maintenance_schedule (parent_maintenance_schedule_id) | Column parent_maintenance_schedule_id (BIGINT) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceSchedule .

ind:tertiaryMaintenanceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Maintenance Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that last modified this maintenance schedule record. Used for audit trail and accountability. | Column tertiary_maintenance_last_modified_by_user_employee_id (BIGINT) in workforce.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceStandardReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard Reference' ;
    rdfs:comment 'Reference to regulatory or industry standard that mandates or guides this maintenance activity (e.g., \'FCC 47 CFR Part 73.1350\', \'ATSC A/53\', \'Manufacturer SLA\', \'OSHA 1910.147\'). | Column compliance_standard_reference (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the maintenance activity requires taking the equipment or system offline (True) or can be performed while operational (False). Critical for broadcast continuity planning. | Column downtime_required_flag (BOOLEAN) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Expected duration in hours that the equipment or system will be offline during maintenance. Used for broadcast scheduling and redundancy planning. | Column estimated_downtime_hours (DECIMAL(6,2)) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Date when the maintenance activity was most recently completed. Used to calculate next due date and track maintenance history. | Column last_performed_date (DATE) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedure Reference' ;
    rdfs:comment 'Reference to detailed maintenance procedure document, work instruction, or manufacturer service manual that guides the execution of the maintenance activity. | Column maintenance_procedure_reference (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance schedule: active (in use), inactive (temporarily disabled), suspended (on hold), under_review (being evaluated), or retired (no longer applicable). | Column maintenance_schedule_status (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity: preventive (scheduled routine), corrective (repair), predictive (data-driven), condition-based (triggered by monitoring), emergency (unplanned critical), or regulatory (compliance-driven). | Column maintenance_type (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated or scheduled date when the next maintenance activity is due. Critical for proactive maintenance planning and compliance tracking. | Column next_due_date (DATE) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Days' ;
    rdfs:comment 'Number of days in advance that stakeholders (operations, engineering, management) should be notified before the scheduled maintenance activity. | Column notification_lead_time_days (INT) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsRequiredDescription rdf:type rdf:Property ;
    rdfs:label 'Parts Required Description' ;
    rdfs:comment 'Description of spare parts, consumables, or materials required for the maintenance activity (e.g., \'Transmitter tubes\', \'Air filters\', \'Cooling fluid\', \'Backup batteries\'). | Column parts_required_description (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMaintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Preferred Maintenance Window' ;
    rdfs:comment 'Preferred time window for performing maintenance to minimize broadcast impact (e.g., \'Overnight 2AM-6AM\', \'Weekend\', \'Off-peak hours\'). Aligns with broadcast schedule and audience patterns. | Column preferred_maintenance_window (STRING) in technology.maintenance_schedule' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceInterval rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval' ;
    rdfs:comment 'Numeric interval for the recurrence pattern (e.g., \'2\' for every 2 weeks, \'3\' for every 3 months). Used in conjunction with recurrence_pattern for flexible scheduling. | Column recurrence_interval (INT) in technology.maintenance_schedule' ;
