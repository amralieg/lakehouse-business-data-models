ind:assetTitle rdf:type rdf:Property ;
    rdfs:label 'Asset Title' ;
    rdfs:comment 'Primary human-readable title or name of the media asset. Used for search, cataloging, and display in MAM interfaces. | Column asset_title (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Primary media type classification of the digital object. Determines handling, playback, and workflow routing in the MAM system. [ENUM-REF-CANDIDATE: video|audio|image|graphics|document|subtitle|caption — 7 candidates stripped; promote to reference product] | Column asset_type (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitRateMbps rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mbps' ;
    rdfs:comment 'Average bit rate of the encoded media in megabits per second. Indicates quality level and bandwidth requirements for streaming and playout. | Column bit_rate_mbps (DECIMAL(10,3)) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentClassification rdf:type rdf:Property ;
    rdfs:label 'Content Classification' ;
    rdfs:comment 'Business classification tags for content categorization (e.g., news, sports, drama, documentary, commercial, promo). Supports search, rights management, and workflow routing. Pipe-separated list for multiple classifications. | Column content_classification (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time of the most recent access or playback of the asset. Used for storage tier optimization and usage analytics. | Column last_accessed_timestamp (TIMESTAMP) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the asset is under legal hold and must not be modified or deleted. Overrides retention policies until hold is released. | Column legal_hold_flag (BOOLEAN) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system or device that created or ingested the asset (e.g., camera model, editing suite, ingest station, external vendor). Provides provenance for chain-of-custody tracking. | Column originating_system (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcOperator rdf:type rdf:Property ;
    rdfs:label 'Qc Operator' ;
    rdfs:comment 'User ID or name of the operator who performed quality control review. Used for accountability and audit trails. | Column qc_operator (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when the asset becomes eligible for purge based on retention policy. Null indicates indefinite retention or active legal hold. | Column retention_expiry_date (DATE) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Code' ;
    rdfs:comment 'Code identifying the retention policy governing lifecycle and purge rules for this asset. Drives automated archival and deletion workflows per regulatory and business requirements. | Column retention_policy_code (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsRestriction rdf:type rdf:Property ;
    rdfs:label 'Rights Restriction' ;
    rdfs:comment 'Rights and usage restrictions governing distribution and use of the asset. Enforces compliance with licensing agreements, territorial restrictions, and legal holds. | Column rights_restriction (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Full URI path to the physical storage location of the media file (e.g., s3://bucket/path, file://server/share/path). Used by MAM for retrieval and playout automation. | Column storage_location_uri (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umid rdf:type rdf:Property ;
    rdfs:label 'Umid' ;
    rdfs:comment 'SMPTE 330M globally unique identifier for the media essence. 64-character hexadecimal string providing universal identification across systems and organizations. | Column umid (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Delivery Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Specific versions may be delivered by different partners (e.g., international dub from foreign partner, localized version from regional distributor). Tracks provenance for quality issues, delivery acc | Column delivery_partner_partner_partner_id (BIGINT) in partner.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:transcodeJobId rdf:type rdf:Property ;
    rdfs:label 'Transcode Job Id' ;
    rdfs:comment 'Reference to the transcode or encoding job that created this version. Links to workflow orchestration system (Dalet Galaxy) for lineage tracking and troubleshooting. | Column transcode_job_id (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TranscodeJob .

ind:abrLadderRung rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Rung' ;
    rdfs:comment 'Position in the ABR ladder for HLS or DASH streaming (e.g., 1 for lowest quality, 5 for highest). Enables adaptive streaming based on viewer bandwidth. Null if not part of an ABR ladder. | Column abr_ladder_rung (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to generate the checksum value (MD5, SHA-256, SHA-512). Identifies the hashing method for integrity verification. | Column checksum_algorithm (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'Cryptographic hash (MD5 or SHA-256) of the file content. Ensures integrity verification, detects corruption during transfer or storage, and supports chain-of-custody audit trails for legal hold and regulatory compliance. | Column checksum_value (DECIMAL(18,2)) in mediaasset.asset_version' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drmProtection rdf:type rdf:Property ;
    rdfs:label 'Drm Protection' ;
    rdfs:comment 'Indicates whether this version is protected by DRM encryption (True/False). DRM systems include Widevine, PlayReady, FairPlay. Supports content security and anti-piracy. | Column drm_protection (BOOLEAN) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Expiry Date' ;
    rdfs:comment 'Date when this proxy or preview version expires and should be purged from storage. Applicable only when rendition_purpose is proxy or preview. Supports storage cost optimization and compliance with retention policies. | Column proxy_expiry_date (DATE) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renditionPurpose rdf:type rdf:Property ;
    rdfs:label 'Rendition Purpose' ;
    rdfs:comment 'Business purpose or use case for this version: playout (broadcast transmission), distribution (delivery to platforms), archive (long-term preservation), preview (review/approval), proxy (low-res editing), watermark (forensic tracking), mezzanine (high-quality master), localized_dub (language variant), thumbnail (visual reference). [ENUM-REF-CANDIDATE: playout|distribution|archive|preview|proxy|watermark|mezzanine|localized_dub|thumbnail — 9 candidates stripped; promote to reference product] | Column rendition_purpose (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'Vertical resolution of the video frame in pixels (e.g., 1080 for 1080p, 2160 for 4K). Used for format classification and quality assessment. | Column resolution_height (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'Horizontal resolution of the video frame in pixels (e.g., 1920 for 1080p, 3840 for 4K). Used for format classification and quality assessment. | Column resolution_width (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full storage path or URI where this version is physically stored (e.g., s3://bucket/path, file://nas/volume/path, https://cdn.example.com/asset). Supports multi-tier storage (hot/warm/cold/archive) and CDN distribution via Akamai. | Column storage_uri (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleTracks rdf:type rdf:Property ;
    rdfs:label 'Subtitle Tracks' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for embedded subtitle or closed caption tracks (e.g., eng,spa,fra). Supports accessibility compliance (COPPA, FCC) and multi-language distribution. | Column subtitle_tracks (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watermarkPayload rdf:type rdf:Property ;
    rdfs:label 'Watermark Payload' ;
    rdfs:comment 'Forensic watermark identifier or payload embedded in this version for anti-piracy tracking and content protection. Applicable only when rendition_purpose is watermark. Supports DRM (Digital Rights Management) and content security. | Column watermark_payload (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestJobId rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Id' ;
    rdfs:comment 'Unique identifier for the media ingest job. Primary key for the ingest_job data product. | Column ingest_job_id (BIGINT) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Created Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Ingest job creates a specific version (typically the mezzanine or raw master). This FK links the ingest job to the version it produced. Populated upon successful ingest completion. | Column created_asset_version_id (BIGINT) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:sourcePartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Source Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Content ingested from partner feeds (satellite, FTP, aspera) requires tracking source partner for SLA compliance monitoring, billing reconciliation, delivery acceptance workflows, and automated partne | Column source_partner_partner_partner_id (BIGINT) in partner.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:techChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Tech Change Request Id' ;
    rdfs:comment 'Reference to the automated workflow or orchestration process that triggered or manages this ingest job. Used for end-to-end process tracking. | Column tech_change_request_id (BIGINT) in technology.ingest_job' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechChangeRequest .

ind:bytesTransferred rdf:type rdf:Property ;
    rdfs:label 'Bytes Transferred' ;
    rdfs:comment 'Total number of bytes successfully transferred during the ingest operation. Used for capacity planning and performance monitoring. | Column bytes_transferred (BIGINT) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionPresent rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Present' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are embedded in the ingested media. Required for FCC accessibility compliance validation. | Column closed_caption_present (BOOLEAN) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest End Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job completed or terminated. Null for jobs still in progress. | Column ingest_end_timestamp (TIMESTAMP) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Start Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job began processing. Represents the actual start of media transfer, not the queued time. | Column ingest_start_timestamp (TIMESTAMP) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobNumber rdf:type rdf:Property ;
    rdfs:label 'Job Number' ;
    rdfs:comment 'Human-readable business identifier for the ingest job, typically formatted as prefix-date-sequence (e.g., ING-20240115-0042). Used for operational tracking and reference. | Column job_number (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the ingest job. Tracks progression from queued through execution to final disposition. | Column job_status (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Physical or logical location of the source media. May be a tape ID, file path, URL, satellite transponder identifier, or cloud storage bucket path. | Column source_location (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormat rdf:type rdf:Property ;
    rdfs:label 'Target Format' ;
    rdfs:comment 'Desired output format for the ingested media. May differ from source format if transcoding is required during ingest. | Column target_format (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Target Storage Location' ;
    rdfs:comment 'Destination storage path or tier where the ingested media asset will be stored. May reference nearline, online, or archive storage systems. | Column target_storage_location (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRateMbps rdf:type rdf:Property ;
    rdfs:label 'Transfer Rate Mbps' ;
    rdfs:comment 'Average data transfer rate achieved during ingest, measured in megabits per second. Key performance indicator for ingest infrastructure. | Column transfer_rate_mbps (DECIMAL(10,2)) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itAssetId rdf:type rdf:Property ;
    rdfs:label 'It Asset Id' ;
    rdfs:comment 'Identifier of the physical or virtual processing node that executed the transcode job, used for troubleshooting and resource tracking. | Column it_asset_id (BIGINT) in technology.transcode_job' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItAsset .

ind:targetFormatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Target Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Normalization: transcode job targets an approved format specification from the catalog. The target_format_specification STRING attribute becomes a FK. Format details retrieved via JOIN. | Column target_format_specification_id (BIGINT) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:abrLadderConfiguration rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Configuration' ;
    rdfs:comment 'Configuration specification for ABR ladder generation, defining the set of bitrate/resolution variants to be created for adaptive streaming (e.g., 240p@400kbps, 360p@800kbps, 480p@1.2Mbps, 720p@2.5Mbps, 1080p@5Mbps). Applicable when job_type is abr_ladder_generation. | Column abr_ladder_configuration (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecParameters rdf:type rdf:Property ;
    rdfs:label 'Codec Parameters' ;
    rdfs:comment 'Detailed codec encoding parameters including profile, level, GOP structure, B-frames, reference frames, and other encoder-specific settings (e.g., x264 preset=medium, crf=23, profile=high, level=4.1). | Column codec_parameters (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated processing cost in US dollars for this transcode job, based on compute time, storage, and resource utilization. Used for chargeback and budget tracking. | Column cost_estimate_usd (DECIMAL(10,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobPriority rdf:type rdf:Property ;
    rdfs:label 'Job Priority' ;
    rdfs:comment 'Processing priority level for the transcode job, determining queue position and resource allocation. Critical jobs are processed immediately, batch jobs during off-peak hours. | Column job_priority (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the transcode operation: standard transcode for routine format conversion, ABR (Adaptive Bitrate) ladder generation for streaming, proxy creation for editing workflows, delivery package preparation for distribution, or format migration for obsolescence-driven conversions. [ENUM-REF-CANDIDATE: standard_transcode|abr_ladder_generation|proxy_creation|delivery_package|format_migration|tape_digitization|analogue_to_digital — 7 candidates stripped; promote to reference product] | Column job_type (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationReason rdf:type rdf:Property ;
    rdfs:label 'Migration Reason' ;
    rdfs:comment 'Business justification for format migration jobs. Applicable only when job_type is format_migration, tape_digitization, or analogue_to_digital. Captures whether the conversion is driven by format obsolescence (e.g., MPEG-2 to H.265), storage optimization, distribution requirements, or regulatory compliance. [ENUM-REF-CANDIDATE: format_obsolescence|storage_optimization|distribution_requirement|quality_enhancement|compliance_mandate|archive_preservation|not_applicable — 7 candidates stripped; promote to reference product] | Column migration_reason (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputChecksum rdf:type rdf:Property ;
    rdfs:label 'Output Checksum' ;
    rdfs:comment 'Cryptographic checksum (MD5, SHA-256, or SHA-512) of the output file for integrity verification and chain-of-custody audit trails. | Column output_checksum (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Output File Size Gb' ;
    rdfs:comment 'Total file size of the transcoded output in gigabytes. Populated upon job completion. | Column output_file_size_gb (DECIMAL(12,3)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputStorageUri rdf:type rdf:Property ;
    rdfs:label 'Output Storage Uri' ;
    rdfs:comment 'Storage location URI for the transcoded output file(s), including protocol, bucket/path, and filename pattern (e.g., s3://media-archive/transcoded/2024/01/asset_12345_1080p.mp4). | Column output_storage_uri (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from processing start to completion, used for performance monitoring and capacity planning. | Column processing_duration_seconds (INT) in mediaasset.transcode_job' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine completed or terminated processing of this job. | Column processing_end_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine began processing this job. | Column processing_start_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityValidationResult rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Result' ;
    rdfs:comment 'Outcome of automated quality validation checks performed on the transcoded output, including video integrity, audio sync, and compliance with target specifications. | Column quality_validation_result (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Score' ;
    rdfs:comment 'Numeric quality score (0-100) assigned by automated validation tools, measuring output fidelity against source and target specifications. | Column quality_validation_score (DECIMAL(5,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Queue Entry Timestamp' ;
    rdfs:comment 'Date and time when the transcode job was submitted to the processing queue. | Column queue_entry_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Source Asset Version Id' ;
    rdfs:comment 'Reference to the specific version of the source asset used for this transcode operation. | Column source_asset_version_id (BIGINT) in mediaasset.transcode_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:sourceBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Source Bitrate Mbps' ;
    rdfs:comment 'Average bitrate of the source asset in megabits per second. | Column source_bitrate_mbps (DECIMAL(10,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCodec rdf:type rdf:Property ;
    rdfs:label 'Source Codec' ;
    rdfs:comment 'Video codec of the source asset (e.g., H.264, H.265/HEVC, MPEG-2, ProRes, DNxHD). | Column source_codec (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Source File Size Gb' ;
    rdfs:comment 'File size of the source asset in gigabytes. | Column source_file_size_gb (DECIMAL(12,3)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodingEngine rdf:type rdf:Property ;
    rdfs:label 'Transcoding Engine' ;
    rdfs:comment 'Name and version of the transcoding engine or software used to perform the conversion (e.g., FFmpeg 5.1.2, AWS Elemental MediaConvert, Dalet Brio). | Column transcoding_engine (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectionId rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Id' ;
    rdfs:comment 'Unique identifier for the quality control inspection record. Primary key. | Column qc_inspection_id (BIGINT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Version Id' ;
    rdfs:comment 'Reference to the specific version of the media asset that underwent this quality control inspection. | Column media_asset_version_id (BIGINT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:aspectRatioComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio Compliance Result' ;
    rdfs:comment 'Result of aspect ratio compliance check. Verifies that video aspect ratio (e.g., 16:9, 4:3, 21:9) matches expected format and Active Format Description (AFD) metadata is correct. | Column aspect_ratio_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Compliance Result' ;
    rdfs:comment 'Result of audio codec format compliance check. Verifies that audio encoding conforms to expected codec standard (e.g., AAC, Dolby Digital, Dolby Atmos, MPEG-1 Layer II). | Column audio_codec_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSyncOffsetMs rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Offset Ms' ;
    rdfs:comment 'Measured audio-to-video synchronization offset in milliseconds. Positive values indicate audio leads video; negative values indicate audio lags video. Null if sync check not performed. | Column audio_sync_offset_ms (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSyncResult rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Result' ;
    rdfs:comment 'Result of audio-to-video synchronization check. Detects lip-sync errors or audio drift. | Column audio_sync_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackFrameCount rdf:type rdf:Property ;
    rdfs:label 'Black Frame Count' ;
    rdfs:comment 'Total number of black frames detected in the media asset. Zero if none detected. | Column black_frame_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Black Frame Detected' ;
    rdfs:comment 'Indicates whether unintended black frames (video signal dropout or encoding error) were detected during inspection. | Column black_frame_detected (BOOLEAN) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionValidationResult rdf:type rdf:Property ;
    rdfs:label 'Caption Validation Result' ;
    rdfs:comment 'Result of closed caption (CEA-608, CEA-708) or subtitle validation check. Verifies presence, format compliance, and synchronization of captions. | Column caption_validation_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical-severity defects that block asset approval for playout or distribution. Critical defects require remediation. | Column critical_defect_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of quality defects detected during inspection. Zero indicates no defects found. | Column defect_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSummary rdf:type rdf:Property ;
    rdfs:label 'Defect Summary' ;
    rdfs:comment 'Structured JSON or delimited text summary of all detected defects with timecode references, severity levels, and defect type codes. Detailed defect records may be stored in a separate qc_defect child table. | Column defect_summary (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Detected Aspect Ratio' ;
    rdfs:comment 'Actual aspect ratio detected in the video stream (e.g., 16:9, 4:3, 1.85:1, 2.39:1). Null if aspect ratio check not performed. | Column detected_aspect_ratio (NUMERIC) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeFrameCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Count' ;
    rdfs:comment 'Total number of freeze frame incidents detected in the media asset. Zero if none detected. | Column freeze_frame_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freezeFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Detected' ;
    rdfs:comment 'Indicates whether freeze frames (static video for extended duration) were detected during inspection. | Column freeze_frame_detected (BOOLEAN) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrMetadataValidationResult rdf:type rdf:Property ;
    rdfs:label 'Hdr Metadata Validation Result' ;
    rdfs:comment 'Result of High Dynamic Range (HDR) metadata validation check. Verifies presence and correctness of HDR10, HDR10+, Dolby Vision, or HLG metadata. Not applicable for Standard Dynamic Range (SDR) content. | Column hdr_metadata_validation_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds required to complete the quality control inspection process. | Column inspection_duration_seconds (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Human-readable business identifier for the inspection record, formatted as QC-YYYYMMDD-NNNNNN. | Column inspection_number (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the quality control inspection process. | Column inspection_status (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the quality control inspection was performed or completed. Primary business event timestamp. | Column inspection_timestamp (TIMESTAMP) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loudnessComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Result' ;
    rdfs:comment 'Result of audio loudness compliance check against regulatory standards (EBU R128 for Europe, ATSC A/85 for North America, ITU-R BS.1770 globally). | Column loudness_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final pass/fail determination for the quality control inspection. Conditional pass indicates minor issues that do not block playout. Review required indicates human escalation needed. | Column overall_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name and version of the automated quality control software or tool used for inspection (e.g., Baton, Interra, Venera, Dalet QC Module). | Column qc_tool_name (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Video Codec Compliance Result' ;
    rdfs:comment 'Result of video codec format compliance check. Verifies that video encoding conforms to expected codec standard (e.g., H.264/AVC, H.265/HEVC, MPEG-2, AV1). | Column video_codec_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Unique identifier for the storage location within the Media Asset Management (MAM) infrastructure. Primary key. | Column storage_location_id (BIGINT) in mediaasset.storage_location' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:accessProtocol rdf:type rdf:Property ;
    rdfs:label 'Access Protocol' ;
    rdfs:comment 'Network protocol or interface used to access the storage location (NFS = Network File System, SMB = Server Message Block, S3 = Amazon S3 API, SFTP = Secure File Transfer Protocol, iSCSI = Internet Small Computer Systems Interface, Fibre_Channel = FC SAN protocol). [ENUM-REF-CANDIDATE: NFS|SMB|S3|SFTP|iSCSI|Fibre_Channel|HTTP|HTTPS — 8 candidates stripped; promote to reference product] | Column access_protocol (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Tb' ;
    rdfs:comment 'Remaining available storage capacity (total minus used), measured in terabytes (TB). Drives automated alerts and provisioning workflows. | Column available_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Checksum Validation Enabled' ;
    rdfs:comment 'Indicates whether automated checksum integrity validation is performed on assets stored at this location (True = enabled, False = disabled). Critical for ensuring asset integrity and detecting corruption. | Column checksum_validation_enabled (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for the technical or operational contact responsible for this storage location. Used for alerts, maintenance coordination, and incident response. | Column contact_email (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerTbPerMonth rdf:type rdf:Property ;
    rdfs:label 'Cost Per Tb Per Month' ;
    rdfs:comment 'Monthly cost per terabyte of storage at this location, used for cost allocation and financial reporting. Includes infrastructure, licensing, and operational costs. | Column cost_per_tb_per_month (DECIMAL(12,2)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name or identifier of the physical data center or facility housing the storage infrastructure (e.g., \'NYC-DC1\', \'AWS-US-East-1\', \'Azure-WestEurope\'). | Column data_center_name (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption algorithm or method applied to data at rest (e.g., \'AES-256\', \'AES-128\', \'RSA-2048\'). Null if encryption is not enabled. | Column encryption_method (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCapacityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Capacity Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent capacity measurement or audit for this storage location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column last_capacity_check_timestamp (TIMESTAMP) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldCapable rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Capable' ;
    rdfs:comment 'Indicates whether this storage location supports legal hold functionality to prevent deletion or modification of assets under litigation or regulatory investigation (True = capable, False = not capable). | Column legal_hold_capable (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mountPoint rdf:type rdf:Property ;
    rdfs:label 'Mount Point' ;
    rdfs:comment 'File system mount point, UNC path, or object storage URI used by MAM systems to access the location (e.g., \'/mnt/production_san\', \'\\\\nas01\\media\', \'s3://bucket-name/prefix\'). | Column mount_point (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationEnabled rdf:type rdf:Property ;
    rdfs:label 'Replication Enabled' ;
    rdfs:comment 'Indicates whether this storage location is replicated to another location for redundancy and disaster recovery (True = replicated, False = not replicated). | Column replication_enabled (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restoreTimeObjectiveHours rdf:type rdf:Property ;
    rdfs:label 'Restore Time Objective Hours' ;
    rdfs:comment 'Maximum acceptable time to restore or retrieve assets from this storage location, measured in hours. Critical for disaster recovery and operational planning. | Column restore_time_objective_hours (DECIMAL(10,2)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Default retention period in days for assets stored at this location, after which assets may be migrated or purged per policy. Null if no default retention applies. | Column retention_policy_days (INT) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical or logical storage technology (SAN = Storage Area Network, NAS = Network Attached Storage, LTO_Tape = Linear Tape-Open, Cloud_Object_Storage = S3/Azure Blob/GCS, CDN_Origin = Content Delivery Network origin store, Deep_Archive = long-term cold storage vault). | Column storage_type (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageVendor rdf:type rdf:Property ;
    rdfs:label 'Storage Vendor' ;
    rdfs:comment 'Name of the storage hardware or cloud service provider (e.g., \'Dell EMC\', \'NetApp\', \'AWS\', \'Azure\', \'Google Cloud\', \'IBM Spectrum Archive\'). | Column storage_vendor (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Tb' ;
    rdfs:comment 'Total storage capacity of the location measured in terabytes (TB). Used for capacity planning and allocation reporting. | Column total_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Tb' ;
    rdfs:comment 'Current amount of storage capacity consumed or allocated, measured in terabytes (TB). Updated periodically to reflect actual usage. | Column used_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetStorageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Storage Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset storage assignment record. Primary key for tracking storage placement history. | Column asset_storage_assignment_id (BIGINT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalHoldId rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Id' ;
    rdfs:comment 'Identifier of the legal case or matter requiring this file to be preserved. Used for legal discovery and compliance tracking. | Column legal_hold_id (BIGINT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalHold .

ind:retentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Id' ;
    rdfs:comment 'Reference to the retention policy governing this storage assignment. Determines how long the file must be retained and when it can be purged. | Column retention_policy_id (BIGINT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:accessFrequency rdf:type rdf:Property ;
    rdfs:label 'Access Frequency' ;
    rdfs:comment 'Number of times this file has been accessed since assignment to this storage location. Used to inform tiering and migration decisions. | Column access_frequency (INT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was migrated, purged, or removed from this storage location. Null if still active. | Column assignment_end_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was placed at this storage location. Provides exact time for chain-of-custody audit trails. | Column assignment_start_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Complete file system path or URI where the asset file is physically stored. Enables restore path resolution and file retrieval. | Column file_path (STRING) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp of the most recent access to this file at this storage location. Used for tiering policy enforcement and usage analytics. | Column last_access_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationTrigger rdf:type rdf:Property ;
    rdfs:label 'Migration Trigger' ;
    rdfs:comment 'Reason why the asset was moved to or from this storage location. Captures business or technical driver for storage placement decisions. | Column migration_trigger (STRING) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of redundant copies of this file maintained at this storage location. Used for disaster recovery and high availability planning. | Column replication_count (INT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Storage Cost Per Gb' ;
    rdfs:comment 'Cost per gigabyte for this storage tier at the time of assignment. Used for storage cost allocation and financial reporting. | Column storage_cost_per_gb (DECIMAL(10,4)) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersedesPolicyRetentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Policy Retention Policy Id' ;
    rdfs:comment 'Reference to the previous retention policy that this policy replaces. Null if this is the first version. Supports policy lineage and historical analysis. | Column supersedes_policy_retention_policy_id (BIGINT) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:appliesToLegalHold rdf:type rdf:Property ;
    rdfs:label 'Applies To Legal Hold' ;
    rdfs:comment 'Indicates whether this retention policy applies to assets under legal hold. If false, legal hold assets are exempt from automated lifecycle actions governed by this policy. | Column applies_to_legal_hold (BOOLEAN) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToSyndicationContent rdf:type rdf:Property ;
    rdfs:label 'Applies To Syndication Content' ;
    rdfs:comment 'Indicates whether this retention policy applies to syndicated content (content resold to multiple outlets). Syndication agreements may impose distinct retention obligations. | Column applies_to_syndication_content (BOOLEAN) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetClassScope rdf:type rdf:Property ;
    rdfs:label 'Asset Class Scope' ;
    rdfs:comment 'The category of media assets to which this retention policy applies. Aligns with MAM (Media Asset Management) asset classification in Dalet Galaxy. [ENUM-REF-CANDIDATE: raw|mezzanine|proxy|archive|master|graphics|audio|metadata — 8 candidates stripped; promote to reference product] | Column asset_class_scope (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether a full chain-of-custody audit trail must be maintained for assets governed by this policy. Critical for regulatory compliance and legal hold scenarios. | Column audit_trail_required (BOOLEAN) in mediaasset.retention_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checksumVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Checksum Verification Required' ;
    rdfs:comment 'Indicates whether checksum integrity verification is mandatory before executing post-retention actions. Ensures asset integrity throughout the retention lifecycle. | Column checksum_verification_required (BOOLEAN) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatMigrationAllowed rdf:type rdf:Property ;
    rdfs:label 'Format Migration Allowed' ;
    rdfs:comment 'Indicates whether format migration (transcoding to newer codecs or containers) is permitted during the retention period. Supports long-term preservation and format obsolescence mitigation. | Column format_migration_allowed (BOOLEAN) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Period Days' ;
    rdfs:comment 'The maximum number of days an asset may be retained before mandatory action (purge or archive migration). Null indicates indefinite retention. | Column maximum_retention_period_days (INT) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Period Days' ;
    rdfs:comment 'The minimum number of days an asset must be retained before any deletion or migration action can occur. Enforces regulatory and contractual obligations. | Column minimum_retention_period_days (INT) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses or role identifiers to be notified when retention actions are triggered (e.g., \'legal@mediabroadcasting.com, content-ops-team\'). | Column notification_recipients (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed business description of the retention policy, including rationale, scope, and any special handling instructions. | Column policy_description (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'The business role, department, or individual responsible for defining and maintaining this retention policy (e.g., \'Legal & Compliance\', \'Media Operations Director\', \'Chief Content Officer\'). | Column policy_owner (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRetentionAction rdf:type rdf:Property ;
    rdfs:label 'Post Retention Action' ;
    rdfs:comment 'The action to be taken when the retention period expires. Drives automated lifecycle workflows in MAM (Media Asset Management) systems. | Column post_retention_action (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'The regulatory framework, statute, or compliance requirement that mandates or informs this retention policy (e.g., \'FCC 47 CFR 73.1840\', \'Ofcom Section 11\', \'GDPR Article 5\', \'SOX Section 802\', \'Legal Hold Case #12345\'). | Column regulatory_basis (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTrigger rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger' ;
    rdfs:comment 'The business event that starts the retention clock for this policy (e.g., when the asset was ingested, when it was first broadcast, when the licensing contract expires, or when a legal hold is placed). | Column retention_trigger (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTierTarget rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Target' ;
    rdfs:comment 'The target storage tier for assets governed by this policy after the retention period. Aligns with tiered storage strategies in MAM (Media Asset Management) and CDN (Content Delivery Network) architectures. | Column storage_tier_target (STRING) in mediaasset.retention_policy' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the asset lifecycle event record. Primary key. Inferred role: EVENT_LOG. This entity represents an immutable audit log of state transitions for media assets, capturing the complete chain-of-custody trail required for regulatory, legal, and rights compliance in media asset management systems. | Column asset_lifecycle_event_id (BIGINT) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'External reference identifier linking this lifecycle event to broader audit trail systems, compliance documentation, or regulatory filing records. Used to connect MAM (Media Asset Management) events to enterprise audit and compliance frameworks. | Column audit_trail_reference (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAfter rdf:type rdf:Property ;
    rdfs:label 'Checksum After' ;
    rdfs:comment 'The cryptographic checksum (MD5, SHA-256, or other hash) of the media file after this event. Used to verify file integrity and detect unauthorized modifications. Critical for chain-of-custody audit trail. | Column checksum_after (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumBefore rdf:type rdf:Property ;
    rdfs:label 'Checksum Before' ;
    rdfs:comment 'The cryptographic checksum (MD5, SHA-256, or other hash) of the media file before this event. Used to verify file integrity and detect unauthorized modifications. Critical for chain-of-custody audit trail. | Column checksum_before (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this lifecycle event was executed in compliance with applicable regulatory, legal, and internal policy requirements. True indicates compliant execution; False indicates a compliance violation or exception that requires review. | Column compliance_flag (BOOLEAN) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDurationMilliseconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Milliseconds' ;
    rdfs:comment 'The elapsed time in milliseconds that this lifecycle event took to complete. Used for performance monitoring, SLA (Service Level Agreement) tracking, and workflow optimization. Applicable for transcode, migration, and ingest events. | Column event_duration_milliseconds (BIGINT) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventReason rdf:type rdf:Property ;
    rdfs:label 'Event Reason' ;
    rdfs:comment 'Free-text explanation or justification for why this lifecycle event occurred. May include business context, regulatory requirement, editorial decision rationale, or technical reason. Critical for audit trail and compliance documentation. | Column event_reason (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataVersion rdf:type rdf:Property ;
    rdfs:label 'Metadata Version' ;
    rdfs:comment 'Version number of the assets descriptive metadata at the time of this lifecycle event. Incremented with each metadata_update event. Used to track metadata evolution and support rollback scenarios. | Column metadata_version (INT) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The lifecycle state of the media asset immediately after this event occurred. Captures the to state in the state transition. Uses the same value set as previous_state. This is the EVENT_PAYLOAD_OR_VALUE required for EVENT_LOG role. [ENUM-REF-CANDIDATE: raw|ingested|qc_pending|qc_approved|qc_rejected|approved|published|archived|on_legal_hold|migrated|purged|active|inactive — 13 candidates stripped; promote to reference product] | Column new_state (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorIdentity rdf:type rdf:Property ;
    rdfs:label 'Operator Identity' ;
    rdfs:comment 'The identity of the human operator or automated system that triggered or executed this lifecycle event. May be a user ID, system account name, or automated workflow identifier. Used for accountability and audit trail purposes. | Column operator_identity (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Classification of the entity that initiated the lifecycle event. Values: human (manual user action), automated_workflow (Dalet Galaxy workflow automation), scheduled_job (time-based system task), api_integration (external system integration), system_process (internal MAM process). | Column operator_type (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The lifecycle state of the media asset immediately before this event occurred. Captures the from state in the state transition. Values include: raw (unprocessed footage), ingested (imported into MAM), qc_pending (awaiting quality control), qc_approved (passed quality control), qc_rejected (failed quality control), approved (editorially approved), published (available for distribution), archived (moved to long-term storage), on_legal_hold (preservation hold active), migrated (format converted), purged (deleted), active (in use), inactive (not in use). [ENUM-REF-CANDIDATE: raw|ingested|qc_pending|qc_approved|qc_rejected|approved|published|archived|on_legal_hold|migrated|purged|active|inactive — 13 candidates stripped; promote to reference product] | Column previous_state (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcDefectCount rdf:type rdf:Property ;
    rdfs:label 'Qc Defect Count' ;
    rdfs:comment 'Number of quality defects identified during quality control inspection, applicable for qc_fail events. Defects may include video artifacts, audio issues, metadata errors, or format compliance violations. | Column qc_defect_count (INT) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcScore rdf:type rdf:Property ;
    rdfs:label 'Qc Score' ;
    rdfs:comment 'Numeric quality control score assigned during qc_pass or qc_fail events. Scale typically 0-100, representing technical quality assessment of video, audio, and metadata completeness. Used to track asset quality metrics over time. | Column qc_score (DECIMAL(5,2)) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceStorageTier rdf:type rdf:Property ;
    rdfs:label 'Source Storage Tier' ;
    rdfs:comment 'The storage tier where the asset resided before this event, applicable for storage_tier_migration events. Values: hot (high-performance online storage), warm (standard online storage), cold (infrequent access storage), archive (long-term preservation), glacier (deep archive), nearline (tape-based near-online), offline (physical media storage). [ENUM-REF-CANDIDATE: hot|warm|cold|archive|glacier|nearline|offline — 7 candidates stripped; promote to reference product] | Column source_storage_tier (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStorageTier rdf:type rdf:Property ;
    rdfs:label 'Target Storage Tier' ;
    rdfs:comment 'The storage tier where the asset was moved to during this event, applicable for storage_tier_migration events. Uses the same value set as source_storage_tier. [ENUM-REF-CANDIDATE: hot|warm|cold|archive|glacier|nearline|offline — 7 candidates stripped; promote to reference product] | Column target_storage_tier (STRING) in mediaasset.asset_lifecycle_event' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Subject Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Legal holds triggered by talent-related litigation (contract disputes, likeness rights claims, guild grievances) require tracking which talent is the subject. Essential for legal compliance and discov | Column subject_talent_profile_id (BIGINT) in talent.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:acknowledgmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Deadline Date' ;
    rdfs:comment 'Deadline by which custodians must acknowledge the legal hold order. Nullable if acknowledgment is not required. Format: yyyy-MM-dd. | Column acknowledgment_deadline_date (DATE) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required' ;
    rdfs:comment 'Indicates whether custodians and stakeholders are required to formally acknowledge receipt and understanding of the legal hold order. | Column acknowledgment_required (BOOLEAN) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetCount rdf:type rdf:Property ;
    rdfs:label 'Asset Count' ;
    rdfs:comment 'Total number of media assets currently under this legal hold. Updated as assets are added or removed from hold scope. | Column asset_count (INT) in mediaasset.legal_hold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Official case, docket, or investigation number associated with the legal matter requiring the hold. Used for cross-referencing with legal case management systems. | Column case_number (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianEmail rdf:type rdf:Property ;
    rdfs:label 'Custodian Email' ;
    rdfs:comment 'Primary email address of the legal hold custodian for communication regarding hold status, scope changes, and release authorization. | Column custodian_email (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Full name of the individual responsible for managing and enforcing this legal hold order, typically a legal counsel or compliance officer. | Column custodian_name (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianPhone rdf:type rdf:Property ;
    rdfs:label 'Custodian Phone' ;
    rdfs:comment 'Primary contact phone number for the legal hold custodian. | Column custodian_phone (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselContact rdf:type rdf:Property ;
    rdfs:label 'External Counsel Contact' ;
    rdfs:comment 'Full name of the primary contact person at the external counsel firm managing this legal hold matter. | Column external_counsel_contact (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or legal counsel representing the organization in the matter associated with this legal hold. | Column external_counsel_firm (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdEndDate rdf:type rdf:Property ;
    rdfs:label 'Hold End Date' ;
    rdfs:comment 'Date when the legal hold order was formally released or expired, allowing normal retention policies to resume. Nullable for active holds. Format: yyyy-MM-dd. | Column hold_end_date (DATE) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdPriority rdf:type rdf:Property ;
    rdfs:label 'Hold Priority' ;
    rdfs:comment 'Priority level assigned to this legal hold, indicating urgency and importance for compliance and enforcement purposes. | Column hold_priority (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed explanation of the legal matter, dispute, investigation, or regulatory inquiry that necessitates preservation of media assets under this hold. | Column hold_reason (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this legal hold order for tracking and citation purposes. Format: LH-YYYY-NNNNNN. | Column hold_reference_number (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'Date when the legal hold order became effective and preservation obligations commenced. Format: yyyy-MM-dd. | Column hold_start_date (DATE) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the legal hold order. Active holds prevent automated retention policy actions (purge, tier migration) on in-scope assets. | Column hold_status (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the legal hold based on the nature of the legal matter requiring preservation of media assets. | Column hold_type (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the specific authority, court, or regulatory body that issued the legal hold order. | Column issuing_authority_name (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mamSystemLockEnabled rdf:type rdf:Property ;
    rdfs:label 'Mam System Lock Enabled' ;
    rdfs:comment 'Indicates whether a system-level lock has been applied in the Media Asset Management (MAM) system (Dalet Galaxy) to prevent modification or deletion of held assets. | Column mam_system_lock_enabled (BOOLEAN) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when formal notification of the legal hold was sent to relevant custodians, stakeholders, and Media Asset Management (MAM) system administrators. Format: yyyy-MM-dd. | Column notification_sent_date (DATE) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Date' ;
    rdfs:comment 'Date when formal authorization was granted to release the legal hold, allowing normal retention policies to resume on previously held assets. Format: yyyy-MM-dd. | Column release_authorization_date (DATE) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Release Authorized By' ;
    rdfs:comment 'Full name of the individual or authority who formally authorized the release of this legal hold order. | Column release_authorized_by (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Override Flag' ;
    rdfs:comment 'Indicates whether this legal hold overrides standard retention policies and prevents automated purge, archival tier migration, or deletion actions on in-scope assets. | Column retention_override_flag (BOOLEAN) in mediaasset.legal_hold' ;
    rdfs:domain ind:LegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the media assets, content types, date ranges, and metadata criteria that define which assets are subject to this legal hold. | Column scope_description (STRING) in mediaasset.legal_hold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyBroadcastStandardId rdf:type rdf:Property ;
    rdfs:label 'Technology Broadcast Standard Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastStandard .

ind:bitRateMode rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mode' ;
    rdfs:comment 'Encoding bit rate control mode: CBR (Constant Bit Rate), VBR (Variable Bit Rate), or ABR (Average Bit Rate / Adaptive Bitrate Streaming). | Column bit_rate_mode (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this format specification becomes active and available for use in production workflows. | Column effective_from_date (DATE) in mediaasset.format_specification' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date when this format specification is scheduled to be deprecated or retired. Null for formats with no planned end date. | Column effective_until_date (DATE) in mediaasset.format_specification' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fileExtension rdf:type rdf:Property ;
    rdfs:label 'File Extension' ;
    rdfs:comment 'Standard file extension for files encoded in this format (e.g., .mxf, .mp4, .mov, .ts, .m3u8). | Column file_extension (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCategory rdf:type rdf:Property ;
    rdfs:label 'Format Category' ;
    rdfs:comment 'Classification of the format by its intended use case in the media workflow: ingest (acquisition), mezzanine (high-quality intermediate), proxy (low-res editing), playout (broadcast transmission), OTT delivery (streaming), or archive (long-term preservation). | Column format_category (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingStandard rdf:type rdf:Property ;
    rdfs:label 'Governing Standard' ;
    rdfs:comment 'Primary industry or regulatory standard governing this format specification (e.g., ATSC 3.0, DVB-T2, SMPTE ST 2110, ISO/IEC 14496, ITU-R BT.2020). | Column governing_standard (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizontalResolution rdf:type rdf:Property ;
    rdfs:label 'Horizontal Resolution' ;
    rdfs:comment 'Horizontal pixel count of the video frame (e.g., 1920 for Full HD, 3840 for UHD). | Column horizontal_resolution (INT) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loudnessStandard rdf:type rdf:Property ;
    rdfs:label 'Loudness Standard' ;
    rdfs:comment 'Audio loudness normalization standard applied (e.g., ITU-R BS.1770-4 LKFS, EBU R128 LUFS, ATSC A/85 for broadcast). | Column loudness_standard (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'MIME (Multipurpose Internet Mail Extensions) type for HTTP delivery and content negotiation (e.g., video/mp4, application/mxf, video/MP2T). | Column mime_type (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcProfile rdf:type rdf:Property ;
    rdfs:label 'Qc Profile' ;
    rdfs:comment 'Quality control validation profile applied to assets in this format, defining automated checks for technical compliance (e.g., video levels, audio loudness, format conformance). | Column qc_profile (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionClass rdf:type rdf:Property ;
    rdfs:label 'Resolution Class' ;
    rdfs:comment 'Video resolution classification: SD (Standard Definition 480/576), HD (720p), FHD (Full HD 1080p), UHD (Ultra HD 2160p), 4K (4096x2160), 8K (7680x4320). | Column resolution_class (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Minimum retention period in years for assets encoded in this format, driven by regulatory, legal hold, or business requirements. | Column retention_period_years (INT) in mediaasset.format_specification' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'Video scanning method: progressive (all lines scanned sequentially, denoted \'p\') or interlaced (alternating fields, denoted \'i\'). | Column scan_type (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLoudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Target Loudness Lufs' ;
    rdfs:comment 'Target integrated loudness level in LUFS (Loudness Units relative to Full Scale) or LKFS, typically -23 LUFS for broadcast, -14 LUFS for streaming. | Column target_loudness_lufs (DECIMAL(5,2)) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodePriority rdf:type rdf:Property ;
    rdfs:label 'Transcode Priority' ;
    rdfs:comment 'Default processing priority for transcode jobs targeting this format: critical (immediate), high (expedited), normal (standard queue), low (off-peak), batch (scheduled bulk processing). | Column transcode_priority (STRING) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalResolution rdf:type rdf:Property ;
    rdfs:label 'Vertical Resolution' ;
    rdfs:comment 'Vertical pixel count of the video frame (e.g., 1080 for Full HD, 2160 for UHD). | Column vertical_resolution (INT) in mediaasset.format_specification' ;
    rdfs:domain ind:FormatSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetCollectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Id' ;
    rdfs:comment 'Unique identifier for the asset collection. Primary key. | Column asset_collection_id (BIGINT) in mediaasset.asset_collection' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCollection .

ind:archiveTier rdf:type rdf:Property ;
    rdfs:label 'Archive Tier' ;
    rdfs:comment 'Storage tier classification for the collection: hot (frequent access), warm (occasional access), cold (rare access), glacier (long-term preservation), or deep-archive (regulatory retention). | Column archive_tier (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Status' ;
    rdfs:comment 'Current lifecycle status of the collection: draft (being assembled), active (available for use), archived (preserved but not active), deprecated (superseded), under-review (pending approval), or locked (no modifications allowed). | Column asset_collection_status (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkOperationEnabled rdf:type rdf:Property ;
    rdfs:label 'Bulk Operation Enabled' ;
    rdfs:comment 'Indicates whether bulk operations (bulk QC, bulk rights check, bulk archive, bulk transcode) are enabled for this collection (true) or must be performed individually (false). | Column bulk_operation_enabled (BOOLEAN) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionCode rdf:type rdf:Property ;
    rdfs:label 'Collection Code' ;
    rdfs:comment 'Business identifier or code for the collection, used for external reference and cataloging (e.g., \'GOT-S08-PKG\', \'NEWS-ELEC24-001\'). | Column collection_code (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionName rdf:type rdf:Property ;
    rdfs:label 'Collection Name' ;
    rdfs:comment 'Human-readable name of the asset collection (e.g., \'Breaking News Package - Election 2024\', \'Game of Thrones Season 8 Bundle\', \'Super Bowl LVIII Highlights\'). | Column collection_name (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Classification of the collection by content grouping purpose: series (episodic television), film-franchise (related films), news-package (story bundle), sports-event (game/match clips), music-album (music tracks), campaign-creative (advertising assets), documentary-series, special-event, archive-bundle, or promo-package. [ENUM-REF-CANDIDATE: series|film-franchise|news-package|sports-event|music-album|campaign-creative|documentary-series|special-event|archive-bundle|promo-package — 10 candidates stripped; promote to reference product] | Column collection_type (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curatorName rdf:type rdf:Property ;
    rdfs:label 'Curator Name' ;
    rdfs:comment 'Name of the individual or team responsible for curating and maintaining the collection. | Column curator_name (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCollectionDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Collection Description' ;
    rdfs:comment 'Detailed narrative description of the collection\'s content, purpose, and editorial context. Used for cataloging and discovery. | Column asset_collection_description (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Distribution Window End' ;
    rdfs:comment 'End date of the distribution window after which the collection may no longer be distributed or broadcast. Part of windowing strategy. | Column distribution_window_end (DATE) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionWindowStart rdf:type rdf:Property ;
    rdfs:label 'Distribution Window Start' ;
    rdfs:comment 'Start date of the distribution window during which the collection may be distributed or broadcast. Part of windowing strategy. | Column distribution_window_start (DATE) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified the collection record. Used for audit trail and accountability. | Column last_modified_by_user (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Metadata Completeness Score' ;
    rdfs:comment 'Percentage score (0.00 to 100.00) indicating the completeness of metadata across all assets in the collection. Used for quality assurance and discoverability. | Column metadata_completeness_score (DECIMAL(5,2)) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingFormat rdf:type rdf:Property ;
    rdfs:label 'Packaging Format' ;
    rdfs:comment 'Technical packaging format used for distribution (e.g., \'IMF\', \'DPP\', \'AS-11\', \'ProRes Package\', \'MPEG-DASH Manifest\'). Relevant for distribution deals. | Column packaging_format (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGenre rdf:type rdf:Property ;
    rdfs:label 'Primary Genre' ;
    rdfs:comment 'Primary content genre or category for the collection (e.g., \'Drama\', \'News\', \'Sports\', \'Documentary\', \'Comedy\', \'Music\', \'Reality\'). | Column primary_genre (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible Flag' ;
    rdfs:comment 'Indicates whether the collection is eligible for syndication (resale to multiple outlets) based on rights and content suitability (true) or not (false). | Column syndication_eligible_flag (BOOLEAN) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Intended audience demographic or segment for the collection (e.g., \'Adults 18-49\', \'Children 6-11\', \'General Audience\', \'Sports Enthusiasts\'). | Column target_audience (STRING) in mediaasset.asset_collection' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssetCount rdf:type rdf:Property ;
    rdfs:label 'Total Asset Count' ;
    rdfs:comment 'Total number of media assets currently included in the collection. | Column total_asset_count (INT) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStorageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total Storage Size Bytes' ;
    rdfs:comment 'Total storage footprint of all assets in the collection, measured in bytes. Used for capacity planning and archival costing. | Column total_storage_size_bytes (BIGINT) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the collection was first created in the MAM (Media Asset Management) system. | Column creation_date (DATE) in mediaasset.asset_collection' ;
    rdfs:domain ind:AssetCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveRecordId rdf:type rdf:Property ;
    rdfs:label 'Archive Record Id' ;
    rdfs:comment 'Primary key for archive_record | Column archive_record_id (BIGINT) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Custodian Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Archives may be held at partner facilities (Iron Mountain, AWS Glacier, offsite vaults). Tracks custodian partner for retrieval requests, audit compliance, disaster recovery planning, and vendor perfo | Column custodian_partner_partner_partner_id (BIGINT) in partner.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:archiveCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Archive Cost Per Gb' ;
    rdfs:comment 'The cost per gigabyte for storing the asset in the archive destination, used for financial planning and cost allocation. | Column archive_cost_per_gb (DECIMAL(10,4)) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveDestinationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Identifier' ;
    rdfs:comment 'Specific identifier for the archive destination such as LTO (Linear Tape-Open) tape barcode, cloud vault identifier, or off-site facility location code. | Column archive_destination_identifier (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveDestinationType rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Type' ;
    rdfs:comment 'The type of long-term storage destination where the asset was archived. | Column archive_destination_type (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Archive File Size Bytes' ;
    rdfs:comment 'The size of the archived media file in bytes, used for storage capacity planning and billing. | Column archive_file_size_bytes (BIGINT) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveFormat rdf:type rdf:Property ;
    rdfs:label 'Archive Format' ;
    rdfs:comment 'The file format or container format of the archived asset (e.g., MXF, MOV, MP4, ProRes, DNxHD) as stored in the archive. | Column archive_format (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveJobReference rdf:type rdf:Property ;
    rdfs:label 'Archive Job Reference' ;
    rdfs:comment 'Unique reference number assigned to the archival job or batch process that created this archive record. | Column archive_job_reference (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveNotes rdf:type rdf:Property ;
    rdfs:label 'Archive Notes' ;
    rdfs:comment 'Free-text notes or comments about the archival process, special handling instructions, or any issues encountered during archival. | Column archive_notes (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveStatus rdf:type rdf:Property ;
    rdfs:label 'Archive Status' ;
    rdfs:comment 'Current lifecycle status of the archived asset indicating its availability and operational state. [ENUM-REF-CANDIDATE: archived|restore_requested|restore_in_progress|restored|purge_pending|purged|failed — 7 candidates stripped; promote to reference product] | Column archive_status (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveSystemName rdf:type rdf:Property ;
    rdfs:label 'Archive System Name' ;
    rdfs:comment 'Name of the archival system or MAM module that performed the archival operation (e.g., Dalet Galaxy Archive, Spectra Logic). | Column archive_system_name (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Precise timestamp when the archival process completed and the asset was committed to long-term storage. | Column archive_timestamp (TIMESTAMP) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cloudVaultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cloud Vault Identifier' ;
    rdfs:comment 'Unique identifier for the cloud deep-archive vault or bucket where the asset is stored (e.g., AWS Glacier vault ARN, Azure Archive Storage container). | Column cloud_vault_identifier (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionCodec rdf:type rdf:Property ;
    rdfs:label 'Compression Codec' ;
    rdfs:comment 'The compression codec applied to the media asset for archival storage (e.g., H.264, H.265, JPEG2000, uncompressed). | Column compression_codec (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltoTapeGeneration rdf:type rdf:Property ;
    rdfs:label 'Lto Tape Generation' ;
    rdfs:comment 'The LTO tape generation standard used for archival (e.g., LTO-8, LTO-9) if the destination is tape-based storage. | Column lto_tape_generation (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oaisComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Oais Compliance Flag' ;
    rdfs:comment 'Indicates whether this archive record complies with ISO 14721 OAIS reference model standards for long-term digital preservation. | Column oais_compliance_flag (BOOLEAN) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsiteFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Offsite Facility Code' ;
    rdfs:comment 'Code identifying the physical off-site archival facility or vault location where the media is stored. | Column offsite_facility_code (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Purge Approval Status' ;
    rdfs:comment 'Approval status for purging the archived asset, ensuring compliance with retention and legal hold requirements before deletion. | Column purge_approval_status (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Purge Scheduled Date' ;
    rdfs:comment 'The scheduled date for purging or permanently deleting the archived asset, based on retention policy expiration. | Column purge_scheduled_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Restore Completion Date' ;
    rdfs:comment 'The date when the restore operation was completed and the asset was made available for use. | Column restore_completion_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreRequestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Request Date' ;
    rdfs:comment 'The date when a restore request was submitted for this archived asset, if applicable. | Column restore_request_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreSlaTier rdf:type rdf:Property ;
    rdfs:label 'Restore Sla Tier' ;
    rdfs:comment 'The service level tier defining the expected restore time for retrieving this archived asset (e.g., expedited within hours, standard within days, bulk within weeks). | Column restore_sla_tier (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restoreTestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Test Date' ;
    rdfs:comment 'The date when the last restore test was performed to verify the integrity and retrievability of the archived asset. | Column restore_test_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreTestResult rdf:type rdf:Property ;
    rdfs:label 'Restore Test Result' ;
    rdfs:comment 'Outcome of the most recent restore test indicating whether the asset was successfully retrieved and validated. | Column restore_test_result (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeBarcode rdf:type rdf:Property ;
    rdfs:label 'Tape Barcode' ;
    rdfs:comment 'Physical barcode identifier on the LTO tape cartridge used for archival, enabling physical inventory tracking. | Column tape_barcode (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatMigrationId rdf:type rdf:Property ;
    rdfs:label 'Format Migration Id' ;
    rdfs:comment 'Unique identifier for the format migration operation. Primary key. | Column format_migration_id (BIGINT) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFormatSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Source Format Specification Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.format_specification. Business justification: Normalization: source format details should be retrieved from format_specification catalog via JOIN. Removes redundant format attributes. The source_format STRING becomes a FK to the authoritative for | Column source_format_specification_id (BIGINT) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormatSpecification .

ind:migrationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Migration Duration Seconds' ;
    rdfs:comment 'Total elapsed time for the migration operation in seconds. Used for performance monitoring and capacity planning. | Column migration_duration_seconds (DECIMAL(12,2)) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:migrationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Migration End Timestamp' ;
    rdfs:comment 'Date and time when the format migration job completed or terminated. Used to calculate migration duration and throughput. | Column migration_end_timestamp (TIMESTAMP) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationEngine rdf:type rdf:Property ;
    rdfs:label 'Migration Engine' ;
    rdfs:comment 'Name and version of the transcoding or migration software used to perform the format conversion (e.g., FFmpeg 5.1, Telestream Vantage 8.2, AWS MediaConvert). | Column migration_engine (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationJobNumber rdf:type rdf:Property ;
    rdfs:label 'Migration Job Number' ;
    rdfs:comment 'Business identifier for the migration job. Externally-known unique code used for tracking and reporting. | Column migration_job_number (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationNotes rdf:type rdf:Property ;
    rdfs:label 'Migration Notes' ;
    rdfs:comment 'Free-text notes and comments about the migration operation. Captures operator observations, special handling instructions, or business context. | Column migration_notes (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationPriority rdf:type rdf:Property ;
    rdfs:label 'Migration Priority' ;
    rdfs:comment 'Business priority assigned to the migration job. Determines queue position and resource allocation. | Column migration_priority (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Migration Start Timestamp' ;
    rdfs:comment 'Date and time when the format migration job began processing. Principal business event timestamp for the migration operation. | Column migration_start_timestamp (TIMESTAMP) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationStatus rdf:type rdf:Property ;
    rdfs:label 'Migration Status' ;
    rdfs:comment 'Current state of the migration job in its workflow lifecycle. | Column migration_status (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationType rdf:type rdf:Property ;
    rdfs:label 'Migration Type' ;
    rdfs:comment 'Technical classification of the migration operation performed on the asset. | Column migration_type (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Full name of the operator who initiated the migration job. Denormalized for reporting and audit purposes. | Column operator_name (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Notes' ;
    rdfs:comment 'Detailed findings from quality validation process. Includes warnings, errors, or observations about the migrated asset quality. | Column quality_validation_notes (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChecksum rdf:type rdf:Property ;
    rdfs:label 'Source Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the source file before migration. Ensures file integrity and supports chain-of-custody verification. | Column source_checksum (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTierSource rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Source' ;
    rdfs:comment 'Storage tier classification of the source asset before migration. Indicates retrieval latency and cost profile. | Column storage_tier_source (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Bitrate Kbps' ;
    rdfs:comment 'Average bitrate of the migrated media file in kilobits per second. Indicates encoding quality and bandwidth requirements after migration. | Column target_bitrate_kbps (DECIMAL(12,2)) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetChecksum rdf:type rdf:Property ;
    rdfs:label 'Target Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the migrated file after conversion. Validates successful migration and file integrity. | Column target_checksum (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCodec rdf:type rdf:Property ;
    rdfs:label 'Target Codec' ;
    rdfs:comment 'Video and audio codec specifications of the migrated asset (e.g., H.264 + AAC, H.265/HEVC + Dolby AC-3). | Column target_codec (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Target File Size Bytes' ;
    rdfs:comment 'Size of the migrated media file in bytes after conversion. Used to measure storage optimisation achieved. | Column target_file_size_bytes (BIGINT) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResolution rdf:type rdf:Property ;
    rdfs:label 'Target Resolution' ;
    rdfs:comment 'Pixel dimensions of the migrated video (e.g., 1920x1080, 3840x2160, 7680x4320). | Column target_resolution (STRING) in mediaasset.format_migration' ;
    rdfs:domain ind:FormatMigration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetAccessRequestId rdf:type rdf:Property ;
    rdfs:label 'Asset Access Request Id' ;
    rdfs:comment 'Unique identifier for the asset access request. Primary key. | Column asset_access_request_id (BIGINT) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Identifier of the individual or system user who submitted the access request. Supports chain-of-custody tracking and accountability. | Column primary_asset_employee_id (BIGINT) in workforce.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessDurationHours rdf:type rdf:Property ;
    rdfs:label 'Access Duration Hours' ;
    rdfs:comment 'Number of hours for which access is granted, calculated from access_granted_timestamp to access_expiry_timestamp. Used for policy enforcement and reporting. | Column access_duration_hours (INT) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Expiry Timestamp' ;
    rdfs:comment 'Date and time when the granted access expires and the URI or checkout lock is automatically revoked. Enforces time-bound access for security and rights compliance. | Column access_expiry_timestamp (TIMESTAMP) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessGrantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Granted Timestamp' ;
    rdfs:comment 'Date and time when access was actually granted and the URI or download became available to the requestor. May differ from approval_timestamp if provisioning delay exists. | Column access_granted_timestamp (TIMESTAMP) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessGrantedUri rdf:type rdf:Property ;
    rdfs:label 'Access Granted Uri' ;
    rdfs:comment 'Secure URL or file path provided to the requestor for accessing the approved asset. Generated upon approval and may include time-limited token or DRM protection. | Column access_granted_uri (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessPurpose rdf:type rdf:Property ;
    rdfs:label 'Access Purpose' ;
    rdfs:comment 'Business reason for requesting access to the asset. Determines approval workflow and usage restrictions applied. [ENUM-REF-CANDIDATE: editing|review|distribution|legal|compliance|research|archival|rights_clearance|promotional|internal_use — 10 candidates stripped; promote to reference product] | Column access_purpose (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Type of access being requested: stream (view-only online), download (local copy), checkout (exclusive edit lock), preview (low-res proxy), or metadata-only (descriptive information without media file). | Column access_type (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text comments or justification provided by the approver explaining the approval or rejection decision. Supports audit trail and dispute resolution. | Column approval_notes (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether the request requires explicit approval (true) or is auto-approved based on policy rules (false). Determined by asset sensitivity, rights restrictions, and requestor role. | Column approval_required (BOOLEAN) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who approved or rejected the request. Captured for audit trail and accountability. | Column approver_name (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutLockActive rdf:type rdf:Property ;
    rdfs:label 'Checkout Lock Active' ;
    rdfs:comment 'Indicates whether an exclusive checkout lock is currently active on the asset (true) or not (false). Prevents concurrent editing and ensures version control integrity. | Column checkout_lock_active (BOOLEAN) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceClassification rdf:type rdf:Property ;
    rdfs:label 'Compliance Classification' ;
    rdfs:comment 'Data classification level of the asset being accessed, determining approval workflow rigor and access logging requirements. | Column compliance_classification (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadCount rdf:type rdf:Property ;
    rdfs:label 'Download Count' ;
    rdfs:comment 'Number of times the asset was downloaded by the requestor under this access grant. Supports usage tracking and compliance auditing. | Column download_count (INT) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmApplied rdf:type rdf:Property ;
    rdfs:label 'Drm Applied' ;
    rdfs:comment 'Indicates whether DRM protection was applied to the accessed asset (true) or not (false). Supports rights protection and anti-piracy compliance. | Column drm_applied (BOOLEAN) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business identifier for the access request, formatted as REQ-YYYYMMDD-XXXXXX for tracking and reference purposes. | Column request_number (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'System or interface through which the access request was submitted. Supports usage analytics and integration monitoring. | Column request_source (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the access request. Tracks progression through approval workflow and final disposition. | Column request_status (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the access request was submitted. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX) for audit trail and SLA tracking. | Column request_timestamp (TIMESTAMP) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Business unit or department of the requestor (e.g., News, Sports, Production, Legal, Compliance, Marketing). Used for access policy enforcement and usage analytics. | Column requestor_department (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the requestor for notification and communication regarding the access request status and approval. | Column requestor_email (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the access request. Captured for audit trail and human-readable reporting. | Column requestor_name (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Required' ;
    rdfs:comment 'Indicates whether the requested access purpose requires explicit rights clearance verification (true) or not (false). Applies to distribution, promotional, and external use cases. | Column rights_clearance_required (BOOLEAN) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:streamCount rdf:type rdf:Property ;
    rdfs:label 'Stream Count' ;
    rdfs:comment 'Number of times the asset was streamed by the requestor under this access grant. Supports usage tracking and analytics. | Column stream_count (INT) in mediaasset.asset_access_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Usage Restrictions' ;
    rdfs:comment 'Free-text description of any usage restrictions or conditions applied to the granted access (e.g., internal use only, no redistribution, watermarked, editorial use only). Enforces rights and compliance requirements. | Column usage_restrictions (STRING) in mediaasset.asset_access_request' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watermarkApplied rdf:type rdf:Property ;
    rdfs:label 'Watermark Applied' ;
    rdfs:comment 'Indicates whether a forensic or visible watermark was applied to the accessed asset (true) or not (false). Supports leak tracing and chain-of-custody enforcement. | Column watermark_applied (BOOLEAN) in mediaasset.asset_access_request' ;
    rdfs:domain ind:AssetAccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Asset Rights Grant Id' ;
    rdfs:comment 'Unique identifier for this specific rights grant record | Column asset_rights_grant_id (BIGINT) in mediaasset.asset_rights_grant' ;
    rdfs:domain ind:AssetRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the rights grant. Tracks whether the grant is pending activation, currently active, temporarily suspended, naturally expired, or contractually terminated. | Column grant_status (STRING) in mediaasset.asset_rights_grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedDate rdf:type rdf:Property ;
    rdfs:label 'Granted Date' ;
    rdfs:comment 'Timestamp when this rights grant record was created in the system, representing when the business agreement was executed. | Column granted_date (TIMESTAMP) in mediaasset.asset_rights_grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Type of distribution rights granted (linear broadcast, video-on-demand, streaming, theatrical, etc.). Determines how the partner may exploit the asset. | Column rights_type (STRING) in mediaasset.asset_rights_grant' ;
    rdfs:domain ind:AssetRightsGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealAssetLicenseId rdf:type rdf:Property ;
    rdfs:label 'Deal Asset License Id' ;
    rdfs:comment 'Unique identifier for this specific asset license within an acquisition deal | Column deal_asset_license_id (BIGINT) in mediaasset.deal_asset_license' ;
    rdfs:domain ind:DealAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'The specific fee paid for licensing this individual asset as part of the deal, may be allocated from package pricing or individually negotiated | Column license_fee_amount (DECIMAL(18,2)) in mediaasset.deal_asset_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'License Term End Date' ;
    rdfs:comment 'The date when the license rights for this specific asset expire, may differ from overall deal expiration for asset-specific terms | Column license_term_end_date (DATE) in mediaasset.deal_asset_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'License Term Start Date' ;
    rdfs:comment 'The date when the license rights for this specific asset become effective, may differ from overall deal effective date for staggered releases | Column license_term_start_date (DATE) in mediaasset.deal_asset_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsRestrictions rdf:type rdf:Property ;
    rdfs:label 'Rights Restrictions' ;
    rdfs:comment 'Specific usage restrictions or limitations for this asset beyond the general deal terms, such as platform restrictions, time-of-day limitations, or promotional restrictions | Column rights_restrictions (STRING) in mediaasset.deal_asset_license' ;
    rdfs:domain ind:DealAssetLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Collection Membership Id' ;
    rdfs:comment 'Unique identifier for this collection membership record. Primary key. | Column collection_membership_id (BIGINT) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedByUser rdf:type rdf:Property ;
    rdfs:label 'Added By User' ;
    rdfs:comment 'Username or identifier of the user who added this asset to the collection. Supports audit trail and accountability. | Column added_by_user (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Date when the media asset was added to this collection. Tracks membership history and supports temporal queries. | Column added_date (DATE) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curatorNotes rdf:type rdf:Property ;
    rdfs:label 'Curator Notes' ;
    rdfs:comment 'Free-text notes from the curator about this specific membership, such as editorial decisions, version notes, or special handling instructions. | Column curator_notes (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionReason rdf:type rdf:Property ;
    rdfs:label 'Inclusion Reason' ;
    rdfs:comment 'Business justification or editorial rationale for including this asset in the collection. Supports curatorial decision tracking. | Column inclusion_reason (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'Role or purpose of this asset within the collection context. Values: primary (main content), supplemental (supporting material), bonus (extra content), trailer (preview), promo (promotional), archive (historical reference). | Column membership_role (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of this membership. Values: active (currently included), pending (queued for inclusion), removed (no longer included), archived (historical record). | Column membership_status (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedByUser rdf:type rdf:Property ;
    rdfs:label 'Removed By User' ;
    rdfs:comment 'Username or identifier of the user who removed this asset from the collection. Null if still active. Supports audit trail. | Column removed_by_user (STRING) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedDate rdf:type rdf:Property ;
    rdfs:label 'Removed Date' ;
    rdfs:comment 'Date when the media asset was removed from this collection. Null if still active. Enables tracking of membership lifecycle. | Column removed_date (DATE) in mediaasset.collection_membership' ;
    rdfs:domain ind:CollectionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetLegalHoldId rdf:type rdf:Property ;
    rdfs:label 'Asset Legal Hold Id' ;
    rdfs:comment 'Unique identifier for this specific assignment of a legal hold to a media asset. Primary key. | Column asset_legal_hold_id (BIGINT) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custodian Employee Id' ;
    rdfs:comment 'Employee identifier of the custodian responsible for managing this specific asset under this specific legal hold. May differ from the overall legal hold custodian for specialized asset types. | Column custodian_employee_id (BIGINT) in workforce.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:custodianAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Custodian Acknowledgment Date' ;
    rdfs:comment 'Date when the assigned custodian formally acknowledged responsibility for preserving this specific asset under this legal hold. | Column custodian_acknowledgment_date (DATE) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdApplicationNotes rdf:type rdf:Property ;
    rdfs:label 'Hold Application Notes' ;
    rdfs:comment 'Detailed notes regarding the application of this legal hold to this specific asset, including any special handling instructions, relevance to the case, or preservation requirements. | Column hold_application_notes (STRING) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdAppliedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Applied Date' ;
    rdfs:comment 'Date when this specific legal hold was applied to this specific media asset. Marks the beginning of preservation obligations for this asset under this hold. | Column hold_applied_date (DATE) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Released Date' ;
    rdfs:comment 'Date when this specific legal hold was released from this specific media asset, allowing normal retention policies to resume. Nullable while hold is active. | Column hold_released_date (DATE) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mamLockApplied rdf:type rdf:Property ;
    rdfs:label 'Mam Lock Applied' ;
    rdfs:comment 'Indicates whether a system-level lock has been successfully applied in the Media Asset Management system to prevent automated retention actions on this specific asset. | Column mam_lock_applied (BOOLEAN) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Reference' ;
    rdfs:comment 'Reference number or document identifier for the formal authorization to release this specific asset from this legal hold. Required for audit trail and compliance verification. | Column release_authorization_reference (STRING) in mediaasset.asset_legal_hold' ;
    rdfs:domain ind:AssetLegalHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationInventoryId rdf:type rdf:Property ;
    rdfs:label 'Syndication Inventory Id' ;
    rdfs:comment 'Unique identifier for this syndication inventory record. Primary key. | Column syndication_inventory_id (BIGINT) in mediaasset.syndication_inventory' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Sales Syndication Deal Id' ;
    rdfs:comment 'Foreign key linking to the syndication deal that includes this collection | Column sales_syndication_deal_id (BIGINT) in sales.syndication_inventory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesSyndicationDeal .

ind:actualClearancePercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Clearance Percentage' ;
    rdfs:comment 'Actual percentage of target market coverage achieved for this collection within this syndication deal. Compared against the deal-level clearance_percentage_target to determine if the collection meets clearance requirements. | Column actual_clearance_percentage (DECIMAL(5,2)) in mediaasset.syndication_inventory' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barterInventoryAllocation rdf:type rdf:Property ;
    rdfs:label 'Barter Inventory Allocation' ;
    rdfs:comment 'Specific allocation of advertising inventory slots for this collection within this barter or cash-plus-barter syndication deal. Details which ad breaks are retained by syndicator vs. sold by stations for this specific content package. | Column barter_inventory_allocation (STRING) in mediaasset.syndication_inventory' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeSequence rdf:type rdf:Property ;
    rdfs:label 'Episode Sequence' ;
    rdfs:comment 'Sequential order in which episodes from this collection should be delivered or aired within this specific syndication deal. Controls the strip schedule for the station group. | Column episode_sequence (INT) in mediaasset.syndication_inventory' ;
    rdfs:domain ind:SyndicationInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsPerEpisode rdf:type rdf:Property ;
    rdfs:label 'Runs Per Episode' ;
    rdfs:comment 'Number of times each episode in this collection may be broadcast by stations under this specific syndication deal. This is deal-and-collection-specific, as different deals may grant different run counts for the same content. | Column runs_per_episode (INT) in mediaasset.syndication_inventory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetStatusRefId rdf:type rdf:Property ;
    rdfs:label 'Asset Status Ref Id' ;
    rdfs:comment 'Column asset_status_ref_id in media_broadcasting.mediaasset.asset_status_ref' ;
    rdfs:domain ind:AssetStatusRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Is Available Flag' ;
    rdfs:comment 'Column is_available_flag in media_broadcasting.mediaasset.asset_status_ref' ;
    rdfs:domain ind:AssetStatusRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTierRefId rdf:type rdf:Property ;
    rdfs:label 'Storage Tier Ref Id' ;
    rdfs:comment 'Column storage_tier_ref_id in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Access Latency Ms' ;
    rdfs:comment 'Column access_latency_ms in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerGbMonthly rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb Monthly' ;
    rdfs:comment 'Column cost_per_gb_monthly in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Column tier_code in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Column tier_description in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Column tier_name in media_broadcasting.mediaasset.storage_tier_ref' ;
    rdfs:domain ind:StorageTierRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaassetWatermarkForensicMatchId rdf:type rdf:Property ;
    rdfs:label 'Mediaasset Watermark Forensic Match Id' ;
    rdfs:comment 'Primary key for watermark match' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:antiPiracyTakedownId rdf:type rdf:Property ;
    rdfs:label 'Anti Piracy Takedown Id' ;
    rdfs:comment 'FK to related takedown if applicable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AntiPiracyTakedown .

ind:sourceSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Source Subscriber Id' ;
    rdfs:comment 'FK to subscriber if watermark traced to account' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Action taken (none, warning, account_suspension, legal)' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedPlatform rdf:type rdf:Property ;
    rdfs:label 'Detected Platform' ;
    rdfs:comment 'Platform where content was detected' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedUrl rdf:type rdf:Property ;
    rdfs:label 'Detected Url' ;
    rdfs:comment 'URL where watermarked content was found' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'When watermark was detected' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Confidence score of watermark match (0-1)' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleFileUrl rdf:type rdf:Property ;
    rdfs:label 'Sample File Url' ;
    rdfs:comment 'URL to sample of detected content' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Source Device Code' ;
    rdfs:comment 'Device ID from watermark if available' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSessionCode rdf:type rdf:Property ;
    rdfs:label 'Source Session Code' ;
    rdfs:comment 'Session ID embedded in watermark' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source Timestamp' ;
    rdfs:comment 'Timestamp embedded in watermark' ;
    rdfs:domain ind:MediaassetWatermarkForensicMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:watermarkVendor rdf:type rdf:Property ;
    rdfs:label 'Watermark Vendor' ;
    rdfs:comment 'Watermarking technology vendor' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLicenseHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary License Holder Id' ;
    rdfs:comment 'Reference to the party granting rights under this agreement (studio, distributor, music publisher, talent guild, production company). | Column primary_license_holder_id (BIGINT) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:primaryLicenseePartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensee Partner Partner Id' ;
    rdfs:comment 'FK to partner.partner_partner | Column primary_licensee_partner_partner_id (BIGINT) in partner.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Upfront payment made upon execution of the agreement, typically recoupable against future royalties or license fees. | Column advance_payment_amount (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clearance Required Flag' ;
    rdfs:comment 'Indicates whether additional rights clearance verification is required before content can be broadcast or distributed under this agreement. True = clearance workflow required, False = no additional clearance needed. | Column clearance_required_flag (BOOLEAN) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Media Rights Granted' ;
    rdfs:comment 'Comma-separated list of media exploitation rights included in this agreement (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, digital download, mobile streaming). | Column media_rights_granted (STRING) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Flag' ;
    rdfs:comment 'Indicates whether this agreement includes music synchronization rights for use of musical compositions in audiovisual content. True = music sync rights included, False = no music sync rights. | Column music_sync_license_flag (BOOLEAN) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'Structure of the payment obligation. Determines how total_license_fee is disbursed over time. | Column payment_schedule_type (STRING) in rights.license_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee' ;
    rdfs:comment 'License fee charged per episode for episodic content. Applicable to syndication and first-run syndication agreements. | Column per_episode_fee (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal period if auto_renewal_flag is true. Null if agreement does not auto-renew. | Column renewal_term_months (INT) in rights.license_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to calculate ongoing royalty payments to the licensor. Determines how revenue is shared or how usage is monetized. | Column royalty_calculation_method (STRING) in rights.license_agreement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Percentage' ;
    rdfs:comment 'Percentage of revenue or receipts paid to the licensor as ongoing royalties. Applicable when royalty_calculation_method is percentage-based. | Column royalty_percentage (DECIMAL(5,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runCountLimit rdf:type rdf:Property ;
    rdfs:label 'Run Count Limit' ;
    rdfs:comment 'Maximum number of times each episode or program may be broadcast or streamed under this agreement. Common in syndication deals. Null indicates unlimited runs. | Column run_count_limit (INT) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Total License Fee' ;
    rdfs:comment 'Total contractual payment obligation for the license rights over the full term of the agreement. Sum of all payment milestones. | Column total_license_fee (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether geographic or temporal blackout restrictions apply to this grant (e.g., sports blackouts, regional restrictions). | Column blackout_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is associated with this grant. | Column carriage_fee_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Indicator' ;
    rdfs:comment 'Indicates whether the grant is exclusive (true) or non-exclusive (false). Exclusive grants prevent other parties from exploiting the same rights in the same territory and window. | Column exclusivity_indicator (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Business identifier for the rights grant, typically a human-readable code used in Rightsline and operational workflows. | Column grant_number (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackApplicable rdf:type rdf:Property ;
    rdfs:label 'Holdback Applicable' ;
    rdfs:comment 'Indicates whether a holdback period applies to this grant. Holdbacks restrict exploitation during specific windows to protect other distribution channels. | Column holdback_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback End Date' ;
    rdfs:comment 'The end date of the holdback period, after which exploitation may resume. Nullable if no holdback applies. | Column holdback_end_date (DATE) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Start Date' ;
    rdfs:comment 'The start date of any holdback period during which exploitation is restricted. Nullable if no holdback applies. | Column holdback_start_date (DATE) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'The media format or delivery mechanism covered by this grant (e.g., television, film, digital streaming, audio). | Column media_type (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Required' ;
    rdfs:comment 'Indicates whether a separate music synchronization license is required for the music tracks embedded in the content. | Column music_sync_license_required (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Type of distribution or exploitation right granted. Defines the platform or medium for which the content may be used. [ENUM-REF-CANDIDATE: broadcast|svod|avod|tvod|theatrical|home_video|music_sync|podcast|linear|non_linear|vod — 11 candidates stripped; promote to reference product] | Column right_type (STRING) in rights.grant' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the rights to third parties. | Column sublicense_permitted (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentResidualsApplicable rdf:type rdf:Property ;
    rdfs:label 'Talent Residuals Applicable' ;
    rdfs:comment 'Indicates whether talent residual payments (reuse payments to actors, directors, writers) are triggered by this grant. | Column talent_residuals_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Named distribution window (e.g., Theatrical, Premium VOD, Pay-TV, Free-TV) that this grant falls within. Used for windowing strategy enforcement. | Column window_name (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'The computed net availability status of the content for this window, considering window dates, holdbacks, and blackouts. Refreshed whenever upstream rights or holdback records change. Directly consumed by scheduling and distribution domains to validate playout eligibility. | Column availability_status (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'The business or regulatory reason for the blackout restriction (e.g., sports event local blackout, contractual exclusivity, regulatory compliance). Populated only when blackout_flag is true. | Column blackout_reason (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceNotes rdf:type rdf:Property ;
    rdfs:label 'Clearance Notes' ;
    rdfs:comment 'Free-text notes documenting clearance issues, pending approvals, conditional restrictions, or special instructions related to rights clearance for this window. | Column clearance_notes (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirement rdf:type rdf:Property ;
    rdfs:label 'Drm Requirement' ;
    rdfs:comment 'The DRM technology or protection scheme required for content distribution during this window. Enforces content protection and anti-piracy requirements specified in the rights agreement. | Column drm_requirement (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoBlockingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Geo Blocking Required Flag' ;
    rdfs:comment 'Indicates whether geographic blocking technology must be enforced to restrict access to the specified territory. True if geo-blocking is mandatory; false if not required. | Column geo_blocking_required_flag (BOOLEAN) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAvailabilityRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Availability Refresh Timestamp' ;
    rdfs:comment 'The timestamp when the availability_status was last recalculated. Updated whenever upstream rights, holdback, or blackout records change. Used to track data freshness for scheduling and distribution systems. | Column last_availability_refresh_timestamp (TIMESTAMP) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the license fee amount (e.g., USD, GBP, EUR). | Column license_fee_currency (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformScope rdf:type rdf:Property ;
    rdfs:label 'Platform Scope' ;
    rdfs:comment 'The specific platform, channel, service, or outlet authorized for distribution during this window (e.g., Netflix, HBO Max, ABC Network, theatrical chain). May be a single platform or a platform group. | Column platform_scope (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted Flag' ;
    rdfs:comment 'Indicates whether the platform or distributor is authorized to sublicense the content to third parties during this window. True if sublicensing is permitted; false if prohibited. | Column sublicense_permitted_flag (BOOLEAN) in rights.rights_content_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCapType rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Type' ;
    rdfs:comment 'The unit of measure for the usage cap (e.g., streams for SVOD, broadcasts for linear, screenings for theatrical). Defines how usage is counted against the cap. | Column usage_cap_type (STRING) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCapUnits rdf:type rdf:Property ;
    rdfs:label 'Usage Cap Units' ;
    rdfs:comment 'The maximum number of usage units (streams, downloads, broadcasts, screenings) permitted during this window. Used to enforce contractual usage limits. | Column usage_cap_units (INT) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowExtensionCount rdf:type rdf:Property ;
    rdfs:label 'Window Extension Count' ;
    rdfs:comment 'The number of times this window has been extended beyond its original close date. Tracks amendments and extensions to the original window terms. | Column window_extension_count (INT) in rights.rights_content_window' ;
    rdfs:domain ind:RightsContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdbackId rdf:type rdf:Property ;
    rdfs:label 'Holdback Id' ;
    rdfs:comment 'Unique identifier for the holdback restriction record. Primary key. | Column holdback_id (BIGINT) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:partnerContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Partner Content Window Id' ;
    rdfs:comment 'Reference to the triggering content window that activates this holdback restriction. | Column partner_content_window_id (BIGINT) in partner.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerContentWindow .

ind:automatedEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Enforcement Flag' ;
    rdfs:comment 'Indicates whether this holdback restriction is automatically enforced by scheduling and distribution systems or requires manual review. | Column automated_enforcement_flag (BOOLEAN) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageNegotiationReference rdf:type rdf:Property ;
    rdfs:label 'Carriage Negotiation Reference' ;
    rdfs:comment 'Reference identifier to the MVPD or vMVPD carriage negotiation that established this holdback restriction. | Column carriage_negotiation_reference (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Workflow Status' ;
    rdfs:comment 'Status of the clearance workflow process that validates whether content can be scheduled or distributed despite this holdback restriction. | Column clearance_workflow_status (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackCode rdf:type rdf:Property ;
    rdfs:label 'Holdback Code' ;
    rdfs:comment 'Business identifier code for the holdback restriction, used for external reference and clearance workflows. | Column holdback_code (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Documentation of any conflicts with other rights, windows, or holdbacks and how they were resolved. | Column conflict_resolution_notes (STRING) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current enforcement state of the holdback restriction, indicating whether it is actively blocking content exploitation or has been modified. | Column enforcement_status (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Scope of exclusivity granted by this holdback, defining whether the restriction is absolute or allows limited exploitation. | Column exclusivity_scope (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedChannel rdf:type rdf:Property ;
    rdfs:label 'Restricted Channel' ;
    rdfs:comment 'Specific broadcast or distribution channel that is restricted from airing or distributing the content during the holdback period. | Column restricted_channel (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedFormat rdf:type rdf:Property ;
    rdfs:label 'Restricted Format' ;
    rdfs:comment 'Distribution format or delivery method that is restricted during the holdback period, supporting windowing strategies. [ENUM-REF-CANDIDATE: theatrical|linear_tv|svod|avod|tvod|vod|physical_media|syndication|streaming|broadcast — 10 candidates stripped; promote to reference product] | Column restricted_format (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPlatform rdf:type rdf:Property ;
    rdfs:label 'Restricted Platform' ;
    rdfs:comment 'Name or identifier of the platform, distributor, or service that is restricted from exploiting the content during the holdback period. Applies to platform_holdback restriction types. | Column restricted_platform (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the holdback restriction type that defines the nature of the exclusivity period. | Column restriction_type (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringWindowType rdf:type rdf:Property ;
    rdfs:label 'Triggering Window Type' ;
    rdfs:comment 'Type of content window that triggers or activates this holdback restriction, defining the sequential release strategy. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear|syndication|home_video|pay_per_view|free_tv|premium_tv — 10 candidates stripped; promote to reference product] | Column triggering_window_type (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the waiver or override of the holdback restriction. | Column waiver_approved_by (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the waiver or override of the holdback restriction was officially approved. | Column waiver_approved_date (DATE) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or explanation for waiving or overriding the holdback restriction, if applicable. | Column waiver_reason (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy Notes' ;
    rdfs:comment 'Additional notes or context explaining how this holdback fits into the overall content windowing and sequential release strategy. | Column windowing_strategy_notes (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMarketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Audience Market Coverage Id' ;
    rdfs:comment 'FK added per VREQ' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:blackoutRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted Flag' ;
    rdfs:comment 'Indicates whether the territory is subject to geographic blackout restrictions for certain content (e.g., sports events, theatrical windows). True if blackouts apply, False otherwise. | Column blackout_restricted_flag (BOOLEAN) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether the territory is subject to GDPR data privacy regulations (EU member states and EEA). True if GDPR applies, False otherwise. Governs audience data collection and consent management. | Column gdpr_applicable_flag (BOOLEAN) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Holdback Eligible Flag' ;
    rdfs:comment 'Indicates whether the territory is eligible for holdback periods in windowing strategies (e.g., delaying SVOD release to protect theatrical revenue). True if holdbacks apply, False otherwise. | Column holdback_eligible_flag (BOOLEAN) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internetPenetrationPercent rdf:type rdf:Property ;
    rdfs:label 'Internet Penetration Percent' ;
    rdfs:comment 'Percentage of the population with internet access in the territory (e.g., 95.00 for USA, 60.00 for India). Used for OTT and streaming market opportunity assessment. | Column internet_penetration_percent (DECIMAL(5,2)) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 2 Code' ;
    rdfs:comment 'Two-letter ISO 3166-1 alpha-2 country code (e.g., US, GB, CA). Used for system integrations and data exchange with distribution platforms. | Column iso_alpha_2_code (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha 3 Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code (e.g., USA, GBR, CAN). Provides additional clarity for territories with similar two-letter codes. | Column iso_alpha_3_code (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit ISO 3166-1 numeric country code (e.g., 840 for USA, 826 for GBR). Language-independent identifier for international systems. | Column iso_numeric_code (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageSecondary rdf:type rdf:Property ;
    rdfs:label 'Language Secondary' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 code for a secondary or co-official language in the territory (e.g., fr for Canada, ca for Spain). Supports multi-language content delivery and compliance. | Column language_secondary (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottMarketMaturity rdf:type rdf:Property ;
    rdfs:label 'Ott Market Maturity' ;
    rdfs:comment 'Classification of the territory\'s OTT streaming market maturity: mature (high penetration, competitive), developing (growing adoption), emerging (early stage), nascent (minimal infrastructure). Informs distribution strategy and rights pricing. | Column ott_market_maturity (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population of the territory. Used for audience reach estimation, market sizing, and rights valuation. | Column population (BIGINT) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Percentage' ;
    rdfs:comment 'Minimum percentage of local or regional content required by regulation in the territory (e.g., 30.00 for EU, 0.00 for territories without quotas). Used for compliance reporting and content acquisition planning. | Column quota_percentage (DECIMAL(5,2)) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Quota Requirement Flag' ;
    rdfs:comment 'Indicates whether the territory mandates local content quotas for broadcasters and streaming platforms (e.g., EU Audiovisual Media Services Directive requiring 30% European content). True if quotas apply, False otherwise. | Column quota_requirement_flag (BOOLEAN) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsTerritoryStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Status' ;
    rdfs:comment 'Current operational status of the territory in the rights management system: active (available for licensing), inactive (not currently used), restricted (subject to special clearance), pending (under review for activation). | Column rights_territory_status (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGroup rdf:type rdf:Property ;
    rdfs:label 'Territory Group' ;
    rdfs:comment 'Regional grouping of the territory used for rights aggregation and windowing strategies (e.g., EMEA, LATAM, North America, Worldwide, APAC). Enables multi-territory licensing and holdback management. [ENUM-REF-CANDIDATE: worldwide|north_america|latin_america|emea|apac|europe|asia|africa|middle_east|oceania — 10 candidates stripped; promote to reference product] | Column territory_group (STRING) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Full official name of the territory (e.g., United States, United Kingdom, Canada). Human-readable identifier used in contracts and reporting. | Column territory_name (STRING) in rights.rights_territory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory scope: country (single nation), region (multi-country group), worldwide (global rights), or custom (bespoke territory definition). | Column territory_type (STRING) in rights.rights_territory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the territory (e.g., America/New_York, Europe/London, Asia/Tokyo). Used for scheduling, playout, and live event coordination. | Column time_zone (STRING) in rights.rights_territory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Vat Applicable Flag' ;
    rdfs:comment 'Indicates whether Value-Added Tax (VAT) or Goods and Services Tax (GST) applies to transactions in the territory. True if VAT/GST applies, False otherwise. Used for royalty and subscription billing calculations. | Column vat_applicable_flag (BOOLEAN) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRatePercent rdf:type rdf:Property ;
    rdfs:label 'Vat Rate Percent' ;
    rdfs:comment 'Standard VAT or GST rate percentage applicable in the territory (e.g., 20.00 for UK, 19.00 for Germany, 0.00 for territories without VAT). Used for financial reconciliation and revenue recognition. | Column vat_rate_percent (DECIMAL(5,2)) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate Percent' ;
    rdfs:comment 'Standard withholding tax rate percentage applied to royalty payments to rights holders in the territory (e.g., 30.00 for USA non-resident aliens, 0.00 for domestic). Used for talent residuals and royalty calculations. | Column withholding_tax_rate_percent (DECIMAL(5,2)) in rights.rights_territory' ;
    rdfs:domain ind:RightsTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRuleId rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Id' ;
    rdfs:comment 'Unique identifier for the royalty calculation rule. Primary key. | Column royalty_rule_id (BIGINT) in rights.royalty_rule' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyRule .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the rights holder has audit rights to verify royalty calculations under this rule. True if audit rights are granted, False otherwise. | Column audit_rights_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The financial or usage metric upon which the royalty calculation is based (e.g., gross revenue, net revenue, subscriber count, stream count, GRP). [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|subscriber_count|stream_count|grp|unit_sales|advertising_revenue — 7 candidates stripped; promote to reference product] | Column calculation_basis (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Deduction Allowed Flag' ;
    rdfs:comment 'Indicates whether deductions (e.g., distribution costs, marketing expenses) are allowed before calculating the royalty. True if deductions are permitted, False otherwise. | Column deduction_allowed_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Deduction Percentage' ;
    rdfs:comment 'The percentage of revenue or basis that may be deducted before applying the royalty rate. Nullable if no deduction applies. | Column deduction_percentage (DECIMAL(5,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Cap Amount' ;
    rdfs:comment 'The maximum royalty payment cap for this rule. Royalty calculations will not exceed this amount. Nullable if no cap applies. | Column maximum_cap_amount (DECIMAL(18,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The frequency at which royalty payments calculated by this rule are made (e.g., monthly, quarterly, semi-annually, annually, per event, on demand). | Column payment_frequency (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTiming rdf:type rdf:Property ;
    rdfs:label 'Payment Timing' ;
    rdfs:comment 'The timing of royalty payments relative to the calculation period (e.g., advance, arrears, upon delivery, upon release, milestone-based). | Column payment_timing (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the rate value (e.g., percentage, per stream, per subscriber, per unit, per GRP, flat amount). | Column rate_unit (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric rate or percentage applied in the royalty calculation. For percentage-based royalties, this is the percentage (e.g., 15.5 for 15.5%). For per-unit rates, this is the amount per unit. | Column rate_value (DECIMAL(18,6)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Flag' ;
    rdfs:comment 'Indicates whether this royalty rule includes recoupment provisions (e.g., advance payments must be recouped before additional royalties are paid). True if recoupment applies, False otherwise. | Column recoupment_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Recoupment Threshold' ;
    rdfs:comment 'The monetary threshold that must be recouped before additional royalty payments are made. Nullable if no recoupment applies. | Column recoupment_threshold (DECIMAL(18,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Formula' ;
    rdfs:comment 'The formula or calculation logic for residual payments to talent (actors, directors, writers) based on reuse, reruns, or secondary exploitation. Nullable if not applicable. | Column residual_formula (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Status' ;
    rdfs:comment 'Current lifecycle status of the royalty rule (e.g., draft, active, suspended, expired, terminated). | Column royalty_rule_status (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'The type of royalty calculation method applied by this rule. Determines how the royalty amount is computed. | Column royalty_type (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'The priority or precedence of this royalty rule when multiple rules may apply to the same content or transaction. Lower numbers indicate higher priority. | Column rule_priority (INT) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'The unit of measure for the threshold value (e.g., revenue, subscriber count, stream count, unit count, GRP). | Column threshold_unit (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyStatementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Id' ;
    rdfs:comment 'Unique identifier for the royalty statement. Primary key. | Column royalty_statement_id (BIGINT) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyStatement .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Identifier of the rights holder (licensor, talent guild, music publisher, or syndication partner) to whom this statement is issued. Links to the party receiving royalty payments. | Column holder_id (BIGINT) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Royalty statements require tracking the royalty analyst who prepared the statement for quality control, dispute resolution, and workload management. When rights holders dispute calculations, business  | Column prepared_by_employee_id (BIGINT) in workforce.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceRecoupmentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Amount' ;
    rdfs:comment 'Amount deducted from gross royalties to recoup advances previously paid to the rights holder under the agreement. | Column advance_recoupment_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTitleBreakdown rdf:type rdf:Property ;
    rdfs:label 'Content Title Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by content title or asset. Stored as JSON or delimited string for detailed reporting. | Column content_title_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationTypeBreakdown rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by exploitation type (theatrical, SVOD, AVOD, TVOD, linear, syndication, home video, etc.). Stored as JSON or delimited string for detailed reporting. | Column exploitation_type_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Royalty Amount' ;
    rdfs:comment 'Total royalty amount earned by the rights holder before any deductions, recoupments, or adjustments. | Column gross_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGuaranteeShortfall rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Shortfall' ;
    rdfs:comment 'The difference between the contractual minimum guarantee and actual royalties earned for the period. A positive value indicates the rights holder is entitled to a minimum guarantee payment. | Column minimum_guarantee_shortfall (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Amount' ;
    rdfs:comment 'Final royalty amount payable to the rights holder after all deductions, recoupments, taxes, and adjustments. This is the amount that will be paid. | Column net_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time when payment for this royalty statement was successfully processed and remitted to the rights holder. | Column paid_timestamp (TIMESTAMP) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statementDueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Due Date' ;
    rdfs:comment 'The date by which payment of the royalties on this statement is contractually due to the rights holder. | Column statement_due_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'The reporting frequency for this royalty statement as defined in the underlying rights agreement. | Column statement_frequency (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'The date on which this royalty statement was officially issued to the rights holder. | Column statement_issue_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments related to this royalty statement, including explanations of unusual adjustments, special circumstances, or clarifications for the rights holder. | Column statement_notes (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this royalty statement, used for reference in correspondence and payment processing. | Column statement_number (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the reporting period covered by this royalty statement. | Column statement_period_end_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the reporting period covered by this royalty statement. | Column statement_period_start_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the royalty statement. Draft statements are under review, approved statements are ready for payment, disputed statements have objections from rights holders, paid statements have been settled, and cancelled statements have been voided. | Column statement_status (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Territory Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by geographic territory or market. Stored as JSON or delimited string for detailed reporting. | Column territory_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Tax amount withheld from royalty payment as required by applicable tax treaties and regulations. | Column withholding_tax_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Line Id' ;
    rdfs:comment 'Unique identifier for the royalty statement line item. Primary key for this entity. | Column royalty_statement_line_id (BIGINT) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Additional adjustments applied to the royalty calculation, such as corrections from prior periods, contractual bonuses, penalties, or dispute resolutions. Can be positive or negative. | Column adjustments_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'Royalty amount calculated by applying the royalty rate to the net revenue. Represents the gross royalty obligation before advance recoupment or adjustments. | Column calculated_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTitle rdf:type rdf:Property ;
    rdfs:label 'Content Title' ;
    rdfs:comment 'Human-readable title of the content asset for which royalties are being calculated. Denormalized for reporting convenience. | Column content_title (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total deductions applied to gross revenue before calculating royalty base. May include distribution fees, marketing costs, platform fees, or other contractually allowed deductions. | Column deductions_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any dispute or query raised by the rights holder regarding this royalty line. Tracks the resolution workflow for contested royalty calculations. | Column dispute_status (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period End Date' ;
    rdfs:comment 'End date of the period during which the exploitation activity occurred. Defines the end of the reporting window for this royalty line. | Column exploitation_period_end_date (DATE) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period Start Date' ;
    rdfs:comment 'Start date of the period during which the exploitation activity occurred. Defines the beginning of the reporting window for this royalty line. | Column exploitation_period_start_date (DATE) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationType rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type' ;
    rdfs:comment 'Type of content exploitation that generated this royalty. Indicates the distribution channel or business model under which the content was used. [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|syndication|home_video|digital_download — 8 candidates stripped; promote to reference product] | Column exploitation_type (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated from the exploitation activity before any deductions, adjustments, or royalty calculations. Represents the top-line revenue attributable to this content asset. | Column gross_revenue_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackStatus rdf:type rdf:Property ;
    rdfs:label 'Holdback Status' ;
    rdfs:comment 'Status of any holdback or exclusivity period applicable to this exploitation. Indicates whether the content was exploited within or outside of contractual holdback restrictions. | Column holdback_status (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iswcCode rdf:type rdf:Property ;
    rdfs:label 'Iswc Code' ;
    rdfs:comment 'ISWC code for composition identification' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Final net amount payable to the rights holder for this line item after all deductions, advance recoupment, and adjustments. This is the amount that will be paid out. | Column net_payable_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after deductions, serving as the base for royalty calculation. Calculated as gross_revenue_amount minus deductions_amount. | Column net_revenue_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualType rdf:type rdf:Property ;
    rdfs:label 'Residual Type' ;
    rdfs:comment 'Classification of residual payment type for talent royalties. Indicates the nature of the reuse payment under guild agreements (SAG-AFTRA, WGA, DGA). [ENUM-REF-CANDIDATE: initial_use|rerun|foreign|supplemental|new_media|streaming|not_applicable — 7 candidates stripped; promote to reference product] | Column residual_type (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to the royalty base to calculate the royalty amount. Derived from the underlying rights agreement and may vary by territory, platform, and exploitation type. | Column royalty_rate_percentage (DECIMAL(5,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsExploited rdf:type rdf:Property ;
    rdfs:label 'Units Exploited' ;
    rdfs:comment 'Quantity of exploitation units for this line item. Interpretation depends on exploitation type: streams for SVOD/AVOD, broadcasts for linear, downloads for TVOD, tickets for theatrical. | Column units_exploited (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualId rdf:type rdf:Property ;
    rdfs:label 'Residual Id' ;
    rdfs:comment 'Unique identifier for the residual payment obligation record. Primary key. | Column residual_id (BIGINT) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendRevenueSource rdf:type rdf:Property ;
    rdfs:label 'Backend Revenue Source' ;
    rdfs:comment 'Source of backend revenue for participation calculation' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Residual Amount' ;
    rdfs:comment 'The computed residual payment amount owed to the talent based on the formula type, calculation basis, and applicable rates. | Column calculated_residual_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Amount' ;
    rdfs:comment 'The base revenue or gross receipts amount used as the input to the residual formula calculation. | Column calculation_basis_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisCurrency rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculation basis amount (e.g., USD, GBP, CAD). | Column calculation_basis_currency (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date when the residual amount was calculated by the royalty system. | Column calculation_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCycle rdf:type rdf:Property ;
    rdfs:label 'Contract Cycle' ;
    rdfs:comment 'The collective bargaining agreement cycle or contract period under which this residual is calculated (e.g., 2020-2023, 2023-2026). | Column contract_cycle (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculated residual amount (e.g., USD, GBP, CAD). | Column currency (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionCount rdf:type rdf:Property ;
    rdfs:label 'Exhibition Count' ;
    rdfs:comment 'The number of times the content was exhibited or broadcast during the residual calculation period, used for per-exhibition or tiered formulas. | Column exhibition_count (INT) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exploitationEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation End Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual ended. Nullable for ongoing exploitation. | Column exploitation_end_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Start Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual began (e.g., first streaming availability date, first rerun air date). | Column exploitation_start_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulaType rdf:type rdf:Property ;
    rdfs:label 'Formula Type' ;
    rdfs:comment 'The calculation method used to determine the residual amount (fixed amount, percentage of gross receipts, percentage of distributor gross, tiered scale based on exhibition count, per-exhibition fee, minimum guarantee). | Column formula_type (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submission Date' ;
    rdfs:comment 'The date when the residual payment was reported to the guild or union. Nullable if not yet reported. | Column guild_report_submission_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submitted Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in the mandatory guild reporting submission (True/False). | Column guild_report_submitted_flag (BOOLEAN) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildUnionCode rdf:type rdf:Property ;
    rdfs:label 'Guild Union Code' ;
    rdfs:comment 'The guild or union governing this residual obligation (SAG-AFTRA for actors, WGA for writers, DGA for directors, IATSE for crew, AFM for musicians, ACTRA for Canadian talent). [ENUM-REF-CANDIDATE: SAG-AFTRA|WGA|DGA|IATSE|AFM|ACTRA|OTHER — 7 candidates stripped; promote to reference product] | Column guild_union_code (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net residual payment amount disbursed to the talent after withholding taxes and any other deductions. | Column net_payment_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Participation Linked Flag' ;
    rdfs:comment 'Indicates if residual is linked to a participation deal' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage rate applied to the calculation basis when the formula type is percentage-based (e.g., 0.0350 for 3.5%). | Column percentage (DECIMAL(5,4)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The financial or royalty reporting period to which this residual obligation belongs (e.g., Q1-2024, 2024-H1), used for guild reporting and financial reconciliation. | Column reporting_period (STRING) in rights.residual' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseId rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Id' ;
    rdfs:comment 'Unique identifier for the music synchronization license record. Primary key. | Column music_sync_license_id (BIGINT) in rights.music_sync_license' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MusicSyncLicense .

ind:clearedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cleared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Music clearance workflows require tracking which music clearance coordinator negotiated and approved each sync license for accountability, performance metrics, and routing follow-up issues. Standard p | Column cleared_by_employee_id (BIGINT) in workforce.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clearanceApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Approved Date' ;
    rdfs:comment 'Date when the music synchronization license was officially cleared and approved for use. Nullable if not yet approved. | Column clearance_approved_date (DATE) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Requested Date' ;
    rdfs:comment 'Date when the music synchronization license clearance was initially requested from the rights holder or clearance team. | Column clearance_requested_date (DATE) in rights.music_sync_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compositionTitle rdf:type rdf:Property ;
    rdfs:label 'Composition Title' ;
    rdfs:comment 'The title of the musical composition or work being licensed for synchronization use. | Column composition_title (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cueSheetRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cue Sheet Required Flag' ;
    rdfs:comment 'Indicates whether a cue sheet (detailed music usage report) must be filed with performance rights organizations for this license, typically required for broadcast and public performance. | Column cue_sheet_required_flag (BOOLEAN) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this music synchronization license, typically assigned by the rights management system or licensing authority. | Column license_number (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the music synchronization license indicating the scope and nature of rights granted (master use for sound recording, synchronization for composition, blanket for multiple works, per-title for single work, mechanical for reproduction, performance for public performance). | Column license_type (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Licensed Platforms' ;
    rdfs:comment 'Comma-separated list of distribution platforms and channels where the licensed music may be used (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, social media). | Column licensed_platforms (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pro Affiliation' ;
    rdfs:comment 'Name of the Performance Rights Organization (e.g., ASCAP, BMI, SESAC, PRS, SOCAN) with which the composer or publisher is affiliated for performance royalty collection. | Column pro_affiliation (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderType rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Type' ;
    rdfs:comment 'Classification of the rights holder entity (publisher for composition rights, record label for master recording rights, PRO for performance rights organization, independent artist for self-owned rights, production company for commissioned works, collective for rights societies). | Column rights_holder_type (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The metric or revenue base upon which ongoing royalties are calculated (gross revenue, net revenue, per-stream count, per-download, per-unit sold, or flat fee with no ongoing royalties). | Column royalty_basis (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Classification of how the music is used within the content asset (background music, theme song, featured performance, promotional use, trailer, opening/closing credits). | Column usage_type (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Clearance Request Id' ;
    rdfs:comment 'Unique identifier for the rights clearance request. Primary key for the clearance request workflow record. | Column clearance_request_id (BIGINT) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictId rdf:type rdf:Property ;
    rdfs:label 'Conflict Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_conflict. Business justification: Clearance requests may be blocked by detected conflicts. Each clearance request may reference one blocking conflict that prevents exploitation. This FK enables tracing clearance denials back to the sp | Column conflict_id (BIGINT) in rights.clearance_request' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conflict .

ind:primaryClearanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Clearance Employee Id' ;
    rdfs:comment 'Identifier of the employee or system user who submitted the clearance request. Enables accountability and follow-up communication. | Column primary_clearance_employee_id (BIGINT) in workforce.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the clearance analyst during review. May include references to specific contract clauses, communications with rights holders, or special handling instructions. | Column analyst_notes (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingCategory rdf:type rdf:Property ;
    rdfs:label 'Blocking Category' ;
    rdfs:comment 'Classification of the primary reason for clearance denial. Enables reporting on common rights obstacles and process improvement. [ENUM-REF-CANDIDATE: holdback_period|territory_restriction|window_unavailable|rights_expired|music_sync_missing|talent_approval_required|residuals_unpaid|clearance_incomplete — promote to reference product] | Column blocking_category (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDecision rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision' ;
    rdfs:comment 'Final determination made by the clearance analyst regarding whether the content may be exploited as requested. Approved with conditions may require specific usage restrictions or additional payments. | Column clearance_decision (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirements' ;
    rdfs:comment 'Specific conditions or restrictions that must be met for conditional clearance approval. May include required credits, usage limitations, geographic blackouts, or additional royalty payments. | Column conditional_requirements (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the clearance request required escalation beyond standard analyst review. May reference contract ambiguity, conflicting rights claims, or high-value strategic decisions. | Column escalation_reason (STRING) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was escalated to senior rights management or legal counsel due to complexity, ambiguity, or high business impact. Null if no escalation occurred. | Column escalation_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Audience Reach' ;
    rdfs:comment 'Projected number of unique viewers or households expected to access the content in the requested exploitation. Used for royalty calculations and rights holder reporting. | Column estimated_audience_reach (BIGINT) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Grp' ;
    rdfs:comment 'Projected Gross Rating Point value for the scheduled broadcast or streaming event. GRP represents the sum of ratings achieved by the content and may trigger tiered royalty obligations. | Column estimated_grp (DECIMAL(10,2)) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedResidualsAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Residuals Amount' ;
    rdfs:comment 'Projected total residual payments owed to talent if the clearance is approved and content is distributed. Used for financial planning and budget approval workflows. | Column estimated_residuals_amount (DECIMAL(15,2)) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Status of data synchronization between Rightsline clearance system and downstream scheduling and playout systems (Ericsson MediaFirst). Ensures cleared content is automatically released to scheduling workflows. | Column integration_status (STRING) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Music Clearance Required' ;
    rdfs:comment 'Indicates whether separate music synchronization licenses must be verified before content can be cleared for distribution. True if content contains licensed music requiring additional clearance. | Column music_clearance_required (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformChannel rdf:type rdf:Property ;
    rdfs:label 'Platform Channel' ;
    rdfs:comment 'Specific platform, channel, or outlet where the content is intended to be distributed (e.g., HBO Max, NBC Network, YouTube, Hulu). Used to verify platform-specific licensing restrictions. | Column platform_channel (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was initially submitted into the workflow system. Marks the start of the clearance review lifecycle and SLA clock. | Column request_submitted_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedAirDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Date' ;
    rdfs:comment 'The target date when the content is scheduled to be broadcast, streamed, or published. Critical for verifying that rights are available within the requested window and that no holdback periods are violated. | Column requested_air_date (DATE) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirTime rdf:type rdf:Property ;
    rdfs:label 'Requested Air Time' ;
    rdfs:comment 'Precise timestamp for the intended broadcast or streaming start time, including time zone. Used for daypart-specific rights verification and scheduling coordination. | Column requested_air_time (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Business unit or department initiating the clearance request. Identifies which operational area needs rights verification before proceeding with content exploitation. | Column requesting_department (STRING) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsTriggered rdf:type rdf:Property ;
    rdfs:label 'Residuals Triggered' ;
    rdfs:comment 'Indicates whether the requested exploitation will trigger residual payments to talent per guild agreements. True if reuse payments are required for this distribution window. | Column residuals_triggered (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when a clearance analyst began active review of the request. Used to measure queue time and analyst response performance. | Column review_started_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the clearance request was resolved within the defined SLA target hours. Used for operational performance reporting and process improvement. | Column sla_met (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Number of business hours within which the clearance request must be resolved per service level agreement. Varies by priority level (urgent requests have shorter SLA targets). | Column sla_target_hours (INT) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required' ;
    rdfs:comment 'Indicates whether talent (actors, directors, producers) approval or notification is contractually required before the requested exploitation. True if talent has approval rights per guild agreements or individual contracts. | Column talent_approval_required (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingAllowed rdf:type rdf:Property ;
    rdfs:label 'Advertising Allowed' ;
    rdfs:comment 'Indicates whether advertising insertion (pre-roll, mid-roll, post-roll) is permitted during content playback for this availability window. True = ads allowed, False = ad-free distribution only. | Column advertising_allowed (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Indicator' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) applies to this availability window. True = blackout in effect, False = no blackout restriction. | Column blackout_indicator (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computed Timestamp' ;
    rdfs:comment 'The timestamp when this availability window record was computed from the intersection of upstream rights grants, holdbacks, and content windows. Represents the calculation execution time. | Column computed_timestamp (TIMESTAMP) in rights.rights_availability_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadToOwnAllowed rdf:type rdf:Property ;
    rdfs:label 'Download To Own Allowed' ;
    rdfs:comment 'Indicates whether permanent download (download-to-own, DTO) is permitted during this availability window. True = DTO allowed, False = streaming-only distribution. | Column download_to_own_allowed (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Notification Sent' ;
    rdfs:comment 'Indicates whether an expiration notification has been sent to scheduling and distribution systems alerting them that this availability window is approaching its end date. True = notification sent, False = not yet notified. | Column expiration_notification_sent (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The timestamp when this availability window was last verified against upstream rights and clearance records. Used for audit and compliance tracking. | Column last_verified_timestamp (TIMESTAMP) in rights.rights_availability_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offlineViewingAllowed rdf:type rdf:Property ;
    rdfs:label 'Offline Viewing Allowed' ;
    rdfs:comment 'Indicates whether temporary offline viewing (download for offline playback with expiration) is permitted during this availability window. True = offline viewing allowed, False = online streaming only. | Column offline_viewing_allowed (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastAllowed rdf:type rdf:Property ;
    rdfs:label 'Simulcast Allowed' ;
    rdfs:comment 'Indicates whether simultaneous multi-platform broadcast (simulcast) is permitted during this availability window. True = simulcast allowed, False = platform-exclusive distribution only. | Column simulcast_allowed (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtitleRequirement rdf:type rdf:Property ;
    rdfs:label 'Subtitle Requirement' ;
    rdfs:comment 'Indicates the subtitle or closed captioning requirement for this availability window. None = no subtitles required, Optional = subtitles available but not mandatory, Mandatory = subtitles must be provided, Closed_caption = closed captioning required for accessibility compliance. | Column subtitle_requirement (STRING) in rights.rights_availability_window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationAllowed rdf:type rdf:Property ;
    rdfs:label 'Syndication Allowed' ;
    rdfs:comment 'Indicates whether the content can be syndicated (resold to multiple outlets) during this availability window. True = syndication permitted, False = syndication prohibited. | Column syndication_allowed (BOOLEAN) in rights.rights_availability_window' ;
    rdfs:domain ind:RightsAvailabilityWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryConflictEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Conflict Employee Id' ;
    rdfs:comment 'Reference to the rights analyst or user responsible for reviewing and resolving this conflict. | Column conflict_employee_id (BIGINT) in workforce.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRightsGrantId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Grant Id' ;
    rdfs:comment 'Reference to the first rights grant involved in the conflict. | Column primary_rights_grant_id (BIGINT) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:tertiaryConflictResolvedByAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Conflict Resolved By Analyst Employee Id' ;
    rdfs:comment 'Reference to the rights analyst or user who ultimately resolved or closed the conflict. Null if conflict remains open. | Column conflict_resolved_by_analyst_employee_id (BIGINT) in workforce.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedDistributionPartners rdf:type rdf:Property ;
    rdfs:label 'Affected Distribution Partners' ;
    rdfs:comment 'Comma-separated list of distribution partner names or identifiers affected by this conflict (e.g., streaming platforms, broadcasters, MVPD partners). | Column affected_distribution_partners (STRING) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPriority rdf:type rdf:Property ;
    rdfs:label 'Business Priority' ;
    rdfs:comment 'Business priority classification for resolving the conflict: critical (blocks major release or high-value content), high (impacts significant revenue or strategic content), medium (standard business impact), or low (minimal business impact). | Column business_priority (STRING) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictType rdf:type rdf:Property ;
    rdfs:label 'Conflict Type' ;
    rdfs:comment 'Classification of the type of rights conflict detected: territorial overlap (same territory granted to multiple parties), platform overlap (same platform rights conflict), holdback violation (content released during holdback period), window gap (gap between sequential windows), exclusivity breach (non-exclusive grant conflicts with exclusive grant), or duration overlap (time period overlap). | Column conflict_type (STRING) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The precise date and time when the rights conflict was first detected by the system or identified by a rights analyst. | Column detected_timestamp (TIMESTAMP) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the conflict in USD, including potential revenue loss, penalty costs, or settlement amounts. Negative values represent costs; positive values represent avoided losses. | Column financial_impact_amount (DECIMAL(15,2)) in rights.conflict' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalOpinionSummary rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Summary' ;
    rdfs:comment 'Summary of the legal department\'s assessment and recommendations regarding the conflict. Contains privileged attorney-client communication. | Column legal_opinion_summary (STRING) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'The date when legal department completed their review of the conflict. Null if no legal review was performed. | Column legal_review_date (DATE) in rights.conflict' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when stakeholder notifications were sent. Null if no notifications have been sent. | Column notification_sent_timestamp (TIMESTAMP) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The approach used to resolve the conflict: contract amendment (modify existing agreement terms), rights buyback (purchase back conflicting rights), window adjustment (change release timing), territory restriction (limit geographic availability), platform exclusion (remove platform from grant), holdback extension (extend exclusivity period), or negotiated settlement (mutual agreement between parties). [ENUM-REF-CANDIDATE: contract_amendment|rights_buyback|window_adjustment|territory_restriction|platform_exclusion|holdback_extension|negotiated_settlement — 7 candidates stripped; promote to reference product] | Column resolution_method (STRING) in rights.conflict' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the conflict: blocking (prevents content distribution, must be resolved before release), warning (potential issue requiring review but not blocking), or informational (noted for awareness, no immediate action required). | Column severity (STRING) in rights.conflict' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionDeadline rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Deadline' ;
    rdfs:comment 'The target date and time by which the conflict must be resolved according to internal service level agreements, based on business priority and content release schedules. | Column sla_resolution_deadline (TIMESTAMP) in rights.conflict' ;
    rdfs:domain ind:Conflict ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseAmendmentId rdf:type rdf:Property ;
    rdfs:label 'License Amendment Id' ;
    rdfs:comment 'Unique identifier for the license amendment record. Primary key. | Column license_amendment_id (BIGINT) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensePartnerId rdf:type rdf:Property ;
    rdfs:label 'License Partner Id' ;
    rdfs:comment 'Reference to the rights holder or content owner party executing this amendment. Typically the same as the original agreement but may change in assignment scenarios. | Column partner_id (BIGINT) in partner.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:licensorRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Licensor Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Amendments track licensor party changes. Each amendment relates to one licensor rights holder. This FK enables tracing amendment parties back to the authoritative rights holder record. Using licensor_ | Column licensor_rights_holder_id (BIGINT) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:primaryLicenseePartyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensee Party Partner Id' ;
    rdfs:comment 'Reference to the content distributor or broadcaster party executing this amendment. Represents the organization acquiring or modifying rights. | Column licensee_party_partner_id (BIGINT) in partner.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:supersededByAmendmentLicenseAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment License Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this one. Null if this is the current active amendment. | Column superseded_by_amendment_license_amendment_id (BIGINT) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAmendment .

ind:amendedLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Amended License Fee Amount' ;
    rdfs:comment 'The new total license fee or minimum guarantee amount after this amendment. Null if the amendment does not modify financial terms. | Column amended_license_fee_amount (DECIMAL(18,2)) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Amended Term End Date' ;
    rdfs:comment 'The new license agreement end date after this amendment takes effect. Null if the amendment does not modify term duration. | Column amended_term_end_date (DATE) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment, typically sequential or alphanumeric code (e.g., AMD-001, A1, Amendment-2023-05). Used for external reference and legal documentation. | Column amendment_number (STRING) in rights.license_amendment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Business justification or trigger for the amendment. Examples: market opportunity, performance renegotiation, rights holder request, regulatory change, strategic partnership expansion. | Column amendment_reason (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment: draft (being prepared), pending_review (under legal review), pending_approval (awaiting executive sign-off), executed (fully signed and active), rejected (not approved), superseded (replaced by newer amendment). | Column amendment_status (STRING) in rights.license_amendment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the change: term extension (extending license duration), territory expansion (adding geographic markets), platform addition (adding distribution channels such as SVOD, AVOD, linear), fee renegotiation (changing financial terms), rights_modification (altering content usage rights), or termination (early contract end). | Column amendment_type (STRING) in rights.license_amendment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Changed Terms Summary' ;
    rdfs:comment 'Narrative summary of the specific terms modified by this amendment. Captures key changes for quick reference without requiring full legal document review. Examples: \'Extended term by 24 months\', \'Added AVOD rights for UK territory\', \'Reduced minimum guarantee by 15%\'. | Column changed_terms_summary (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when all parties signed the amendment, making it legally executed. Distinct from effective_date which may differ based on contract terms. | Column execution_date (DATE) in rights.license_amendment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Amount' ;
    rdfs:comment 'The incremental change in license fee resulting from this amendment. Positive for increases, negative for reductions. Calculated as amended_license_fee_amount minus original_license_fee_amount. | Column fee_adjustment_amount (DECIMAL(18,2)) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackPeriodChangeDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Change Days' ;
    rdfs:comment 'Change in holdback or exclusivity period measured in days. Positive for extensions, negative for reductions. Null if holdback terms unchanged. | Column holdback_period_change_days (INT) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Legal Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the executed legal amendment document stored in the document management system or MAM. | Column legal_document_reference (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Original License Fee Amount' ;
    rdfs:comment 'The total license fee or minimum guarantee amount before this amendment. Captured for financial audit and royalty recalculation. | Column original_license_fee_amount (DECIMAL(18,2)) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Original Term End Date' ;
    rdfs:comment 'The license agreement end date before this amendment. Captured for audit trail and to calculate term extension impact. | Column original_term_end_date (DATE) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformsAdded rdf:type rdf:Property ;
    rdfs:label 'Platforms Added' ;
    rdfs:comment 'Comma-separated list of distribution platforms or windows added by this amendment. Examples: SVOD, AVOD, TVOD, Linear, FAST, Theatrical. Empty if no platform expansion. | Column platforms_added (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformsRemoved rdf:type rdf:Property ;
    rdfs:label 'Platforms Removed' ;
    rdfs:comment 'Comma-separated list of distribution platforms or windows removed or restricted by this amendment. Empty if no platform reduction. | Column platforms_removed (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRoyaltyRecalculation rdf:type rdf:Property ;
    rdfs:label 'Requires Royalty Recalculation' ;
    rdfs:comment 'Indicates whether this amendment triggers retroactive royalty recalculation for past periods. True when financial terms are modified with retroactive effective dates. | Column requires_royalty_recalculation (BOOLEAN) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRateChangePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Change Percent' ;
    rdfs:comment 'Percentage point change in royalty rate resulting from this amendment. Positive for increases, negative for decreases. Null if royalty terms unchanged. | Column royalty_rate_change_percent (DECIMAL(5,2)) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoriesAdded rdf:type rdf:Property ;
    rdfs:label 'Territories Added' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for territories added by this amendment. Empty if no territory expansion. | Column territories_added (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoriesRemoved rdf:type rdf:Property ;
    rdfs:label 'Territories Removed' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes for territories removed or restricted by this amendment. Empty if no territory reduction. | Column territories_removed (STRING) in rights.license_amendment' ;
    rdfs:domain ind:LicenseAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationReportId rdf:type rdf:Property ;
    rdfs:label 'Exploitation Report Id' ;
    rdfs:comment 'Unique identifier for the exploitation report. Primary key for this entity. | Column exploitation_report_id (BIGINT) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossPlatformMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Measurement Id' ;
    rdfs:comment 'Foreign key linking to audience.cross_platform_measurement. Business justification: Modern exploitation reports must account for deduplicated cross-platform viewing (linear + OTT + MVPD) to accurately report total content usage. Rights holders require comprehensive cross-platform met | Column cross_platform_measurement_id (BIGINT) in audience.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossPlatformMeasurement .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the organization or business unit that generated and submitted this exploitation report (typically the distributor or platform operator). | Column legal_entity_id (BIGINT) in finance.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:nielsenRatingId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating Id' ;
    rdfs:comment 'Foreign key linking to audience.nielsen_rating. Business justification: Exploitation reports cite Nielsen ratings for broadcast performance metrics in royalty calculations. Rights holders receive exploitation reports showing Nielsen data to validate usage-based payments.  | Column nielsen_rating_id (BIGINT) in audience.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NielsenRating .

ind:reachFrequencyReportId rdf:type rdf:Property ;
    rdfs:label 'Reach Frequency Report Id' ;
    rdfs:comment 'Foreign key linking to audience.reach_frequency_report. Business justification: Exploitation reports for advertiser-supported content reference reach/frequency reports to demonstrate audience delivery performance. Rights holders use reach/frequency data to validate that content a | Column reach_frequency_report_id (BIGINT) in audience.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachFrequencyReport .

ind:reportingMarketCoverageId rdf:type rdf:Property ;
    rdfs:label 'Reporting Market Coverage Id' ;
    rdfs:comment 'Foreign key linking to audience.market_coverage. Business justification: Exploitation reports break down viewership by DMA (market coverage) for territory-specific license agreements and royalty calculations. Real business process: rights holders receive market-level explo | Column reporting_market_coverage_id (BIGINT) in audience.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketCoverage .

ind:validatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Exploitation reports from distribution partners require validation by royalty analysts before acceptance for payment processing. Business needs to track who validated each report for quality control,  | Column validated_by_employee_id (BIGINT) in workforce.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the rights holder formally accepted the exploitation report, closing the dispute window and confirming the usage data. | Column acceptance_date (DATE) in rights.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNotes rdf:type rdf:Property ;
    rdfs:label 'Amendment Notes' ;
    rdfs:comment 'Documentation of changes made to the exploitation report after initial submission, typically in response to disputes or data corrections. | Column amendment_notes (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'External audit identifier linking this exploitation report to a formal rights holder audit request, enabling traceability during royalty audits. | Column audit_reference_number (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system from which the exploitation usage data was extracted (e.g., Dalet Galaxy, Ericsson MediaFirst, Adobe Experience Platform), supporting data lineage and audit requirements. | Column data_source_system (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Report Format Version' ;
    rdfs:comment 'Version number of the exploitation report template or schema used, ensuring compatibility and correct interpretation of report fields over time. | Column report_format_version (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the exploitation report indicating its purpose: usage submission to rights holders, usage receipt from distributors, royalty evidence documentation, audit support materials, reconciliation reports, or ad-hoc custom reports. | Column report_type (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'Name of the organization that submitted the report, captured for audit trail and report header display. | Column reporting_entity_name (STRING) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBroadcasts rdf:type rdf:Property ;
    rdfs:label 'Total Broadcasts' ;
    rdfs:comment 'Total number of linear broadcast transmissions of the content during the reporting period. Null for on-demand exploitation. | Column total_broadcasts (INT) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStreams rdf:type rdf:Property ;
    rdfs:label 'Total Streams' ;
    rdfs:comment 'Total number of individual stream starts or playback initiations for on-demand content during the reporting period. Null for linear broadcast exploitation. | Column total_streams (BIGINT) in rights.exploitation_report' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalViewingHours rdf:type rdf:Property ;
    rdfs:label 'Total Viewing Hours' ;
    rdfs:comment 'Aggregate number of hours that audiences spent viewing the content during the reporting period, calculated as sum of all viewing durations. | Column total_viewing_hours (DECIMAL(18,2)) in rights.exploitation_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniqueViewers rdf:type rdf:Property ;
    rdfs:label 'Unique Viewers' ;
    rdfs:comment 'Count of distinct individual viewers or households that accessed the content during the reporting period, representing reach metric. | Column unique_viewers (BIGINT) in rights.exploitation_report' ;
    rdfs:domain ind:ExploitationReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Partner Id' ;
    rdfs:comment 'FK column added per VREQ-055' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:proAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Pro Affiliation Id' ;
    rdfs:comment 'FK to PRO affiliation for music rights holders' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBroadcasting .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'Name on the bank account designated for royalty payments. Must match legal entity name for payment processing compliance. | Column bank_account_name (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for royalty payment remittance. Encrypted at rest and in transit per PCI DSS requirements. | Column bank_account_number (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number or SWIFT/BIC code for international wire transfers. Used for automated royalty payment processing. | Column bank_routing_number (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearancePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Priority Level' ;
    rdfs:comment 'Priority level assigned to clearance requests for content from this rights holder. VIP and critical levels receive accelerated processing. | Column clearance_priority_level (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for advance payments or minimum guarantees to this rights holder. Used for financial risk management. | Column credit_limit_amount (DECIMAL(15,2)) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Default Royalty Rate' ;
    rdfs:comment 'Default royalty rate percentage applied to new agreements with this rights holder. Can be overridden at the contract level. | Column default_royalty_rate (DECIMAL(5,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the rights holder by organizational type. Determines applicable contract templates, royalty calculation methods, and clearance workflows. [ENUM-REF-CANDIDATE: film_studio|production_company|music_publisher|performing_rights_organization|talent_guild|record_label|news_agency|individual_creator — 8 candidates stripped; promote to reference product] | Column entity_type (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPreference rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Preference' ;
    rdfs:comment 'Rights holder\'s stated preference for exclusivity terms in licensing agreements. Influences windowing strategy and holdback negotiations. | Column exclusivity_preference (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation' ;
    rdfs:comment 'Name of talent guild or performing rights organization (PRO) that this rights holder is affiliated with. Determines residual payment rules and reporting requirements. [ENUM-REF-CANDIDATE: sag_aftra|wga|dga|afm|ascap|bmi|sesac|gema|prs|socan — promote to reference product] | Column guild_affiliation (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Threshold' ;
    rdfs:comment 'Minimum guarantee amount threshold below which this rights holder will not enter licensing agreements. Used for deal structuring and negotiation. | Column minimum_guarantee_threshold (DECIMAL(15,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mostFavoredNationsFlag rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nations Flag' ;
    rdfs:comment 'Indicates whether this rights holder has most favored nations clause requiring rate parity with other similar rights holders. True triggers rate comparison workflows. | Column most_favored_nations_flag (BOOLEAN) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the rights holder\'s preferred currency for royalty payments and contract valuations. | Column preferred_currency (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registrant Identifier' ;
    rdfs:comment 'The ISAN or ISRC registrant identifier assigned to the rights holder by the respective international registration authority. Used for global rights tracking and content identification. | Column registrant_identifier (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this rights holder was terminated or suspended. Null for active relationships. | Column relationship_end_date (DATE) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this rights holder was established. Used for historical reporting and relationship tenure analysis. | Column relationship_start_date (DATE) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsHolderCode rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Code' ;
    rdfs:comment 'Internal business identifier code assigned to the rights holder for operational reference and system integration across Rightsline and billing systems. | Column rights_holder_code (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Status' ;
    rdfs:comment 'Current lifecycle status of the rights holder relationship. Active status is required for new license agreements and royalty payments. | Column rights_holder_status (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number for the rights holder in their jurisdiction of incorporation. Required for tax reporting and withholding compliance. | Column tax_identification_number (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Classification' ;
    rdfs:comment 'Tax withholding classification for royalty payments. Determines applicable withholding rates based on tax treaties and domestic regulations. | Column tax_withholding_classification (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'Applicable tax withholding rate percentage for royalty payments to this rights holder. Derived from tax treaties and domestic law based on withholding classification. | Column tax_withholding_rate (DECIMAL(5,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Territory Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction where the rights holder entity is incorporated or registered. Determines applicable tax treaties and withholding requirements. | Column territory_of_incorporation (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useCaseFitnessGaps rdf:type rdf:Property ;
    rdfs:label 'Use Case Fitness Gaps' ;
    rdfs:comment 'Documents analytics use-case fitness gaps requiring A1 (news), A2 (sports), A3 (music) entity additions: Sports right-holder analytics (2-star): A2 sports entities (sports_league, sports_event, sports_team, athlete, event_blackout_rule); Newsroom analytics (2-star): A1 news entities (news_story, wire_ingest, byline_credit, breaking_news_event, editorial_workflow_state); Music label catalog & royalties (2-star): A3 composition/master split (composition, master_recording, release, publisher, pro_affiliation)' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsBlackoutRuleId rdf:type rdf:Property ;
    rdfs:label 'Rights Blackout Rule Id' ;
    rdfs:comment 'Unique identifier for the blackout rule record. Primary key. | Column rights_blackout_rule_id (BIGINT) in rights.rights_blackout_rule' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsBlackoutRule .

ind:primaryRightsMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Media Asset Id' ;
    rdfs:comment 'Reference to the specific content asset subject to blackout restriction. | Column primary_rights_media_asset_id (BIGINT) in mediaasset.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:rightsSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Rights Syndication Deal Id' ;
    rdfs:comment 'Foreign key linking to rights.syndication_deal. Business justification: Blackout rules may arise from syndication deals. Each blackout rule may reference one syndication deal that defines the blackout restrictions. This FK enables tracing blackout rules back to the source | Column rights_syndication_deal_id (BIGINT) in rights.rights_blackout_rule' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsSyndicationDeal .

ind:blackoutDurationHours rdf:type rdf:Property ;
    rdfs:label 'Blackout Duration Hours' ;
    rdfs:comment 'Calculated duration of the blackout period in hours, derived from start and end datetime. Used for reporting and analytics. | Column blackout_duration_hours (DECIMAL(10,2)) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Blackout End Datetime' ;
    rdfs:comment 'Precise date and time when the blackout restriction expires. Nullable for indefinite blackouts. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column blackout_end_datetime (TIMESTAMP) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutMessageText rdf:type rdf:Property ;
    rdfs:label 'Blackout Message Text' ;
    rdfs:comment 'Viewer-facing message or notification text to be displayed when content is unavailable due to this blackout restriction. Used for customer communication and transparency. | Column blackout_message_text (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRuleCode rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this blackout rule for operational reference and reporting. | Column blackout_rule_code (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Datetime' ;
    rdfs:comment 'Precise date and time when the blackout restriction becomes effective. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column blackout_start_datetime (TIMESTAMP) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutType rdf:type rdf:Property ;
    rdfs:label 'Blackout Type' ;
    rdfs:comment 'Classification of the blackout restriction: sports local market blackout (home team market protection), affiliate exclusivity blackout (local station rights), regulatory blackout (government-mandated restriction), territorial holdback (geographic windowing), competitive protection (anti-siphoning), or league-imposed (sports league rule). | Column blackout_type (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementMethod rdf:type rdf:Property ;
    rdfs:label 'Enforcement Method' ;
    rdfs:comment 'Technical mechanism used to enforce the blackout: geo-blocking (IP-based restriction), content suppression (removal from catalog), redirect (alternate content substitution), alternate feed (different broadcast signal), or manual override (operator intervention). | Column enforcement_method (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTeamMarketFlag rdf:type rdf:Property ;
    rdfs:label 'Home Team Market Flag' ;
    rdfs:comment 'Indicates whether this blackout applies to the home team\'s local market to protect local broadcast rights. True for home market blackouts, False otherwise. Applicable to sports content. | Column home_team_market_flag (BOOLEAN) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDatetime rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Datetime' ;
    rdfs:comment 'Date and time when automated notifications about this blackout rule were dispatched to downstream systems and stakeholders. Nullable if notifications not yet sent. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column notification_sent_datetime (TIMESTAMP) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the government or regulatory body that mandates this blackout restriction (e.g., FCC, Ofcom, CRTC). Applicable only for regulatory blackouts. | Column regulatory_authority (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number, docket number, or citation of the regulatory ruling or statute that mandates this blackout. Applicable only for regulatory blackouts. | Column regulatory_reference_number (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringRightsClause rdf:type rdf:Property ;
    rdfs:label 'Triggering Rights Clause' ;
    rdfs:comment 'Reference to the specific contractual clause, section, or provision in the license agreement that mandates this blackout restriction. May include clause number and brief description. | Column triggering_rights_clause (STRING) in rights.rights_blackout_rule' ;
    rdfs:domain ind:RightsBlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether an exception or waiver has been granted to bypass this blackout rule. True if waiver approved, False otherwise. | Column waiver_granted_flag (BOOLEAN) in rights.rights_blackout_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealExecutiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deal Executive Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Syndication deals require tracking the syndication sales executive responsible for the deal for commission calculations, territory assignment, renewal routing, and performance management. Standard pra | Column deal_executive_employee_id (BIGINT) in workforce.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:syndicationPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Syndication deals are partner-facing distribution agreements requiring direct FK to identify the syndication partner (licensee). Enables partner-centric syndication reporting, partner performance anal | Column syndication_partner_partner_id (BIGINT) in partner.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:autoRenewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Indicator' ;
    rdfs:comment 'Indicates whether the deal automatically renews for an additional term unless either party provides notice (True) or requires explicit renewal negotiation (False). | Column auto_renewal_indicator (BOOLEAN) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutDescription rdf:type rdf:Property ;
    rdfs:label 'Blackout Description' ;
    rdfs:comment 'Detailed description of any blackout restrictions, including affected territories, time periods, or triggering events. | Column blackout_description (STRING) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Content Package Description' ;
    rdfs:comment 'Detailed description of the content included in the syndication deal, including titles, episode counts, and any exclusions. | Column content_package_description (STRING) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealEndDate rdf:type rdf:Property ;
    rdfs:label 'Deal End Date' ;
    rdfs:comment 'Date on which the syndication rights expire and the licensee must cease distribution. Null indicates an open-ended or perpetual deal. | Column deal_end_date (DATE) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealNotes rdf:type rdf:Property ;
    rdfs:label 'Deal Notes' ;
    rdfs:comment 'Free-text field for additional notes, special terms, or contextual information about the syndication deal. | Column deal_notes (STRING) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStartDate rdf:type rdf:Property ;
    rdfs:label 'Deal Start Date' ;
    rdfs:comment 'Date on which the syndication rights become effective and the licensee may begin distribution. | Column deal_start_date (DATE) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealTermMonths rdf:type rdf:Property ;
    rdfs:label 'Deal Term Months' ;
    rdfs:comment 'Duration of the syndication deal in months, calculated from start date to end date. Facilitates term-based reporting and renewal planning. | Column deal_term_months (INT) in rights.rights_syndication_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeStructureType rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Type' ;
    rdfs:comment 'Model for syndication compensation: flat fee (single payment for entire deal), per-episode (payment per episode delivered), per-run (payment per broadcast), revenue share (percentage of licensee revenue), barter (ad inventory exchange), or hybrid (combination of models). | Column fee_structure_type (STRING) in rights.rights_syndication_deal' ;
    rdfs:domain ind:RightsSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatRestrictions rdf:type rdf:Property ;
    rdfs:label 'Format Restrictions' ;
    rdfs:comment 'Restrictions on the format or presentation of the content (e.g., no-editing, no-dubbing, original-aspect-ratio-only). | Column format_restrictions (STRING) in rights.rights_syndication_deal' ;
