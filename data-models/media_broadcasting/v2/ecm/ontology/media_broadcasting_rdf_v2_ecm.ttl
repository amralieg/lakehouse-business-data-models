    rdfs:range xsd:string .

ind:endpointStatus rdf:type rdf:Property ;
    rdfs:label 'Endpoint Status' ;
    rdfs:comment 'The current operational status of the endpoint (active for production use, beta for testing with select partners, alpha for internal testing, inactive for disabled, maintenance for temporary unavailability). | Column endpoint_status (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCategory rdf:type rdf:Property ;
    rdfs:label 'Functional Category' ;
    rdfs:comment 'The business function or domain that this endpoint serves (e.g., content discovery for browsing, playback authorization for DRM, DAI for Dynamic Ad Insertion, EPG for Electronic Program Guide). [ENUM-REF-CANDIDATE: content_discovery|playback_authorization|subscriber_entitlement|epg|search|recommendation|dai|user_profile|analytics|billing — 10 candidates stripped; promote to reference product] | Column functional_category (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:httpMethod rdf:type rdf:Property ;
    rdfs:label 'Http Method' ;
    rdfs:comment 'The HTTP method supported by this endpoint (GET for retrieval, POST for creation, PUT for full update, PATCH for partial update, DELETE for removal). [ENUM-REF-CANDIDATE: GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS — 7 candidates stripped; promote to reference product] | Column http_method (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
