    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedCapacity rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity' ;
    rdfs:comment 'The amount or extent of facility capacity allocated to this sales account under the agreement. Format varies by service type: hours per month for studio rental, bandwidth allocation for transmission, rack units for colocation, percentage of facility for full lease. This defines the resource commitment. | Column contracted_capacity (STRING) in sales.facility_service_agreement' ;
    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this facility service agreement record was first created in the system. Used for audit trail and contract lifecycle tracking. | Column created_date (TIMESTAMP) in sales.facility_service_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when this facility service agreement record was last updated. Tracks changes to contract terms, capacity allocations, or status changes. | Column last_modified_date (TIMESTAMP) in sales.facility_service_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier to the pricing rate card or pricing schedule that governs billing for this service agreement. Links to the commercial pricing structure negotiated for this account-facility combination, which may differ from standard rates based on volume commitments or strategic relationship. | Column rate_card_reference (STRING) in sales.facility_service_agreement' ;
    rdfs:domain ind:FacilityServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the service being provided under this agreement. Defines what type of facility access or service the sales account has contracted for (e.g., studio rental for production, transmission services for broadcast distribution, uplink services for satellite feeds, colocation for equipment hosting, managed services for technical operations, or full facility lease). | Column service_type (STRING) in sales.facility_service_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignFundingId rdf:type rdf:Property ;
    rdfs:label 'Campaign Funding Id' ;
    rdfs:comment 'Unique identifier for this campaign funding allocation record. Primary key. | Column campaign_funding_id (BIGINT) in sales.campaign_funding' ;
    rdfs:domain ind:CampaignFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'The dollar amount from this opportunity allocated to fund this specific campaign. Sum of all allocation_amounts for an opportunity should not exceed the opportunity\'s estimated_value. | Column allocation_amount (DECIMAL(18,2)) in sales.campaign_funding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the opportunity\'s total estimated value allocated to this campaign. Used for portfolio buys and umbrella deals where a single opportunity funds multiple campaigns. | Column allocation_percentage (DECIMAL(5,2)) in sales.campaign_funding' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignFundingStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Funding Status' ;
    rdfs:comment 'Current status of this funding allocation. Proposed = opportunity not yet closed, Committed = opportunity closed-won and funding committed, Active = campaign is running with this funding, Completed = flight dates passed, Cancelled = allocation removed. | Column campaign_funding_status (STRING) in sales.campaign_funding' ;
    rdfs:domain ind:CampaignFunding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Reference to the parent brand in a brand hierarchy. Used for sub-brands, regional variants, or digital extensions of a master brand. Null for top-level brands. | Column parent_brand_id (BIGINT) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:brandType rdf:type rdf:Property ;
    rdfs:label 'Brand Type' ;
    rdfs:comment 'Classification of the brand by its primary distribution or business model: network (broadcast network), station (local affiliate), digital_platform (online property), streaming_service (SVOD/AVOD), syndication (content distributor), or studio (production house). | Column brand_type (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Short alphanumeric code used as a unique business identifier for the brand in sales systems, rate cards, and trafficking systems. Typically 3-10 uppercase characters. | Column brand_code (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative description of the brand, its positioning, audience, and content offering. Used in sales proposals, syndication packages, and agency presentations. | Column brand_description (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdSupported rdf:type rdf:Property ;
    rdfs:label 'Is Ad Supported' ;
    rdfs:comment 'Indicates whether the brand carries advertising inventory. True for ad-supported brands (AVOD, linear TV); false for subscription-only or ad-free brands (SVOD). | Column is_ad_supported (BOOLEAN) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubscriptionBased rdf:type rdf:Property ;
    rdfs:label 'Is Subscription Based' ;
    rdfs:comment 'Indicates whether the brand operates on a subscription revenue model (SVOD, cable subscription). Used to distinguish revenue streams in sales reporting. | Column is_subscription_based (BOOLEAN) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSyndicationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Syndication Eligible' ;
    rdfs:comment 'Indicates whether the brand is eligible for content syndication deals. True if the brand can license content to third-party distributors; false otherwise. | Column is_syndication_eligible (BOOLEAN) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL to the official brand logo asset. Used in sales proposals, rate cards, and advertising creative materials. | Column brand_logo_url (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The official name of the brand as recognized in the market and used in advertising sales, content licensing, and syndication deals. | Column brand_name (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'The legal entity or corporate parent that owns the brand. Used for rights management, licensing, and syndication agreements. | Column brand_owner (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarket rdf:type rdf:Property ;
    rdfs:label 'Primary Market' ;
    rdfs:comment 'The primary geographic market or country where the brand operates, represented as a 3-letter ISO country code (e.g., USA, CAN, GBR). | Column primary_market (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Email' ;
    rdfs:comment 'Primary email address for sales inquiries and agency outreach for this brand. Organizational contact data classified as confidential. | Column sales_contact_email (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Phone' ;
    rdfs:comment 'Primary phone number for sales inquiries and agency outreach for this brand. Organizational contact data classified as confidential. | Column sales_contact_phone (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'The unique Salesforce Account ID linking this brand to the Salesforce Media Cloud CRM system. Used for opportunity tracking, pipeline management, and sales contract association. | Column salesforce_account_code (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand. Active brands are available for sales and trafficking; inactive brands are no longer sold; pending brands are in setup; retired brands are archived; suspended brands are temporarily unavailable. | Column status (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'The official marketing tagline or slogan associated with the brand. Used in advertising creative and promotional materials. | Column brand_tagline (STRING) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontParticipation rdf:type rdf:Property ;
    rdfs:label 'Upfront Participation' ;
    rdfs:comment 'Indicates whether the brand participates in the annual upfront advertising sales market. True for brands that sell inventory in upfront commitments; false for scatter-only brands. | Column upfront_participation (BOOLEAN) in sales.brand' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSalesTeamId rdf:type rdf:Property ;
    rdfs:label 'Parent Sales Team Id' ;
    rdfs:comment 'Identifier of the parent sales team if this team is part of a hierarchical sales organization structure. Null for top-level teams. | Column parent_team_id (BIGINT) in sales.sales_team' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:channelFocus rdf:type rdf:Property ;
    rdfs:label 'Channel Focus' ;
    rdfs:comment 'The distribution channel or platform this sales team primarily sells inventory or content for. | Column channel_focus (STRING) in sales.sales_team' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructure rdf:type rdf:Property ;
    rdfs:label 'Commission Structure' ;
    rdfs:comment 'The commission or incentive structure applied to this sales team (e.g., flat rate per deal, tiered based on quota attainment, revenue share percentage). | Column commission_structure (STRING) in sales.sales_team' ;
    rdfs:domain ind:SalesTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the sales team or team manager. | Column contact_phone (STRING) in sales.sales_team' ;
