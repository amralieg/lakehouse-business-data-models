    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingPercentage rdf:type rdf:Property ;
    rdfs:label 'Vesting Percentage' ;
    rdfs:domain ind:DeferredCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingSchedule rdf:type rdf:Property ;
    rdfs:label 'Vesting Schedule' ;
    rdfs:domain ind:DeferredCompensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Type' ;
    rdfs:comment 'Frequency of participation statements: quarterly, semi_annual, annual.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakevenAmount rdf:type rdf:Property ;
    rdfs:label 'Breakeven Amount' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakevenThreshold rdf:type rdf:Property ;
    rdfs:label 'Breakeven Threshold' ;
    rdfs:comment 'Revenue threshold before participation kicks in' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakevenThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Breakeven Threshold Amount' ;
    rdfs:comment 'Revenue threshold that must be exceeded before participation kicks in.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceilingAmount rdf:type rdf:Property ;
    rdfs:label 'Ceiling Amount' ;
    rdfs:comment 'Maximum cap on participation payments.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCategories rdf:type rdf:Property ;
    rdfs:label 'Deduction Categories' ;
    rdfs:comment 'Comma-separated list of allowable deductions from gross (distribution_fees, marketing, residuals, etc.).' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionFormula rdf:type rdf:Property ;
    rdfs:label 'Definition Formula' ;
    rdfs:comment 'Detailed formula or reference for calculating participation pool' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionFeeCapPercent rdf:type rdf:Property ;
    rdfs:label 'Distribution Fee Cap Percent' ;
    rdfs:comment 'Maximum distribution fee percentage deductible from gross.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionFeeCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Distribution Fee Cap Percentage' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAmount rdf:type rdf:Property ;
    rdfs:label 'Floor Amount' ;
    rdfs:comment 'Minimum guaranteed participation payment amount.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingDeductionCap rdf:type rdf:Property ;
    rdfs:label 'Marketing Deduction Cap' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingDeductionCapAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Deduction Cap Amount' ;
    rdfs:comment 'Maximum marketing costs deductible before participation calculation.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Percentage' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Type of participation: gross, adjusted_gross, net, modified_adjusted_gross.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePoolsIncluded rdf:type rdf:Property ;
    rdfs:label 'Revenue Pools Included' ;
    rdfs:comment 'Revenue streams included: theatrical, home_video, streaming, television, merchandising.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Definition Status' ;
    rdfs:comment 'Current status: draft, active, suspended, terminated.' ;
    rdfs:domain ind:ParticipationDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentSportsTeamId rdf:type rdf:Property ;
    rdfs:label 'Talent Sports Team Id' ;
    rdfs:comment 'Primary key for the sports team entity.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
