    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax' ;
    rdfs:comment 'Employee portion of Social Security tax withheld under the Federal Insurance Contributions Act (FICA). | Column social_security_tax (DECIMAL(15,2)) in workforce.payroll_record' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTax rdf:type rdf:Property ;
    rdfs:label 'State Income Tax' ;
    rdfs:comment 'Amount withheld for state income tax based on state tax regulations and employee elections. | Column state_income_tax (DECIMAL(15,2)) in workforce.payroll_record' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsuranceDeduction rdf:type rdf:Property ;
