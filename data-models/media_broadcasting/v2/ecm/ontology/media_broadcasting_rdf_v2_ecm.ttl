    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the work period covered by this payroll payment. Defines the beginning of the earnings period. | Column pay_period_start_date (DATE) in workforce.payroll_record' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunDate rdf:type rdf:Property ;
