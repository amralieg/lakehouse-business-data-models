ind:clearanceConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Confirmed Timestamp' ;
    rdfs:comment 'When clearance was confirmed' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayedAirDate rdf:type rdf:Property ;
    rdfs:label 'Delayed Air Date' ;
    rdfs:comment 'Rescheduled air date if delayed' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayedAirTime rdf:type rdf:Property ;
    rdfs:label 'Delayed Air Time' ;
    rdfs:comment 'Rescheduled air time if delayed' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Network Notification Sent Flag' ;
    rdfs:comment 'Whether network was notified' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementContent rdf:type rdf:Property ;
    rdfs:label 'Replacement Content' ;
    rdfs:comment 'Content aired instead if preempted' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAirDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Date' ;
    rdfs:comment 'Originally scheduled air date' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledAirTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Time' ;
    rdfs:comment 'Originally scheduled air time' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingLocalAvailInventoryId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Local Avail Inventory Id' ;
    rdfs:comment 'Primary key for local avail inventory' ;
    rdfs:domain ind:SchedulingLocalAvailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availDate rdf:type rdf:Property ;
    rdfs:label 'Avail Date' ;
    rdfs:comment 'Date of availability' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Avail Duration Seconds' ;
    rdfs:comment 'Total avail duration in seconds' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availEndTime rdf:type rdf:Property ;
    rdfs:label 'Avail End Time' ;
    rdfs:comment 'End time of avail window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availStartTime rdf:type rdf:Property ;
    rdfs:label 'Avail Start Time' ;
    rdfs:comment 'Start time of avail window' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availType rdf:type rdf:Property ;
    rdfs:label 'Avail Type' ;
    rdfs:comment 'Type (local_break, network_adjacency, local_news)' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Impressions' ;
    rdfs:comment 'Estimated impressions for this avail' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedRating rdf:type rdf:Property ;
    rdfs:label 'Estimated Rating' ;
    rdfs:comment 'Estimated rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Status (available, partially_sold, sold_out, held)' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardRate rdf:type rdf:Property ;
    rdfs:label 'Rate Card Rate' ;
    rdfs:comment 'Rate card rate per unit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUnits rdf:type rdf:Property ;
    rdfs:label 'Remaining Units' ;
    rdfs:comment 'Number of units remaining' ;
    rdfs:domain ind:SchedulingLocalAvailInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selloutPercentage rdf:type rdf:Property ;
    rdfs:label 'Sellout Percentage' ;
    rdfs:comment 'Percentage of inventory sold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soldUnits rdf:type rdf:Property ;
    rdfs:label 'Sold Units' ;
    rdfs:comment 'Number of units sold' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
