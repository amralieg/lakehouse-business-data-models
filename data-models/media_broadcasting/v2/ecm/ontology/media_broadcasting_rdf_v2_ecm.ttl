    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalEmail rdf:type rdf:Property ;
    rdfs:label 'Personal Email' ;
    rdfs:comment 'Employee\'s personal email address. Used for emergency communications, benefits notifications, and post-employment correspondence. Must be kept current. | Column personal_email (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalPhone rdf:type rdf:Property ;
