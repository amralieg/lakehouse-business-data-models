    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Frequency at which the maintenance activity repeats: daily, weekly, biweekly, monthly, quarterly, semiannual (twice yearly), annual, or biennial (every two years). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|semiannual|annual|biennial — 8 candidates stripped; promote to reference product] | Column recurrence_pattern (STRING) in technology.maintenance_schedule' ;
