ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to the dispute for tracking and communication purposes. | Column dispute_number (STRING) in partner.partner_dispute' ;
