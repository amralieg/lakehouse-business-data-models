    rdfs:comment 'When survey was completed' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerEffortScore rdf:type rdf:Property ;
    rdfs:label 'Customer Effort Score' ;
    rdfs:comment 'Customer Effort Score (1-7)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackText rdf:type rdf:Property ;
    rdfs:label 'Feedback Text' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompletedFlag rdf:type rdf:Property ;
