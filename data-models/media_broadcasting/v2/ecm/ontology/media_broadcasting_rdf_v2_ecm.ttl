ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Job title or role the applicant currently holds at their present employer. Nullable if unemployed. | Column current_job_title (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeField rdf:type rdf:Property ;
    rdfs:label 'Degree Field' ;
    rdfs:comment 'Major or field of study for the applicant\'s highest degree (e.g., Communications, Journalism, Film Production, Business Administration). | Column degree_field (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Desired Salary Amount' ;
    rdfs:comment 'Salary amount the applicant is seeking for the position. Used for compensation alignment during offer stage. | Column desired_salary_amount (DECIMAL(12,2)) in workforce.applicant' ;
