    rdfs:comment 'Name of affiliated member' ;
    rdfs:domain ind:PartnerProAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberType rdf:type rdf:Property ;
    rdfs:label 'Member Type' ;
    rdfs:comment 'Type: writer, publisher' ;
    rdfs:domain ind:PartnerProAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation Flag' ;
    rdfs:comment 'Indicates if this is the primary PRO affiliation' ;
    rdfs:domain ind:PartnerProAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proWriterNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Writer Number' ;
    rdfs:comment 'Reference to songwriter/composer associated with this PRO affiliation' ;
    rdfs:domain ind:PartnerProAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerProAffiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Pro Affiliation Status' ;
    rdfs:comment 'Affiliation status' ;
    rdfs:domain ind:PartnerProAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'The primary currency in which this account is maintained, using ISO 4217 three-letter currency codes (e.g., \'USD\', \'EUR\', \'GBP\'). Determines the currency for postings and balance reporting. | Column account_currency (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group classification that controls field status, number range assignment, and screen layout for the account. Groups accounts with similar characteristics and processing rules (e.g., \'REVENUE\', \'COGS\', \'OPEX\', \'CAPEX\'). | Column account_group (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNotes rdf:type rdf:Property ;
    rdfs:label 'Account Notes' ;
    rdfs:comment 'Free-text field for additional notes, usage guidelines, or special instructions related to this account. Used to document account-specific policies, restrictions, or business context. | Column account_notes (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortText rdf:type rdf:Property ;
    rdfs:label 'Account Short Text' ;
    rdfs:comment 'Abbreviated name or short description of the account used in reports and transaction displays where space is limited. | Column account_short_text (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'An alternative or legacy account number used for mapping to previous chart of accounts structures, external reporting systems, or consolidation systems. Supports migration and integration scenarios. | Column alternative_account_number (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, specifies whether the account is classified as current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts. | Column balance_sheet_classification (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'The chart of accounts identifier to which this account belongs. Media Broadcasting may maintain multiple charts of accounts for different regions or business units (e.g., \'USGA\' for US GAAP, \'IFRS\' for international operations). | Column chart_of_accounts_code (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP company code (legal entity) to which this chart of accounts entry applies. Supports multi-entity environments where different legal entities may have entity-specific account configurations. | Column company_code (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The consolidation account code used for corporate consolidation and intercompany eliminations. Maps local entity accounts to group-level chart of accounts for consolidated financial reporting. | Column consolidation_account (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'Indicates whether a cost center must be specified when posting to this account. True for expense accounts requiring cost center assignment; false for balance sheet and revenue accounts. | Column cost_center_required (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of the account as a cost element for controlling purposes: primary (direct posting from FI), secondary (internal allocations/assessments), revenue (revenue postings), or none (not a cost element). Links financial accounting to management accounting. | Column cost_element_category (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The line item code on the financial statement (balance sheet or income statement) where this account\'s balance is reported. Used for financial statement generation and external reporting. | Column financial_statement_item (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification used for segment reporting and cost-of-sales accounting. Represents business functions such as \'Content Production\', \'Distribution\', \'Sales & Marketing\', \'Technology\', \'Corporate\'. Enables P&L reporting by business function per IFRS requirements. | Column functional_area (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The unique account code used to identify this general ledger account across all financial postings. This is the authoritative account identifier used in SAP S/4HANA FI module for all financial transactions. | Column gl_account_number (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayAllowed rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Allowed' ;
    rdfs:comment 'Indicates whether individual line items (transaction details) can be displayed for this account. True enables drill-down to transaction level; false shows only account balance. Typically true for balance sheet accounts, false for P&L accounts. | Column line_item_display_allowed (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialityThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Materiality Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which transactions or balances in this account are considered material for audit and control purposes. Used to determine testing scope and control frequency for SOX compliance. | Column materiality_threshold_amount (DECIMAL(18,2)) in finance.chart_of_accounts' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether this account uses open item management, tracking individual postings until they are cleared (e.g., for receivables, payables, clearing accounts). True enables clearing transactions; false for standard balance accounts. | Column open_item_management (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plStatementClassification rdf:type rdf:Property ;
    rdfs:label 'Pl Statement Classification' ;
    rdfs:comment 'For P&L accounts, specifies the detailed classification within the income statement (e.g., \'Operating Revenue\', \'Cost of Sales\', \'Operating Expenses\', \'Depreciation\', \'Interest Expense\', \'Tax Expense\'). Not applicable for balance sheet accounts. | Column pl_statement_classification (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The planning level or budget category assigned to this account for financial planning and budgeting purposes. Links the account to budget planning hierarchies and enables budget vs. actual reporting. | Column planning_level (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether direct postings to this account are currently blocked. True prevents new transactions; false allows normal posting. Used to freeze accounts during period-end close or for inactive accounts. | Column posting_blocked (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'Indicates whether a profit center must be specified when posting to this account. True for accounts requiring segment profitability tracking; false otherwise. | Column profit_center_required (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies if this is a reconciliation account (subledger control account) and its type: customer (accounts receivable), vendor (accounts payable), asset (fixed assets), or none (standard GL account). Reconciliation accounts are automatically posted from subledgers. | Column reconciliation_account_type (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'Medallion lineage tracking column for bronze->silver->gold tracing | Column source_id (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlClassification rdf:type rdf:Property ;
    rdfs:label 'Sox Control Classification' ;
    rdfs:comment 'Classification of the account for SOX compliance purposes: key_control (critical accounts requiring enhanced controls and testing), supporting_control (accounts with standard controls), or not_in_scope (accounts outside SOX scope). Drives audit testing requirements. | Column sox_control_classification (STRING) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerRequired rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Required' ;
    rdfs:comment 'Indicates whether a trading partner (intercompany entity) must be specified when posting to this account. True for intercompany accounts requiring elimination tracking; false for standard accounts. | Column trading_partner_required (BOOLEAN) in finance.chart_of_accounts' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy, enabling hierarchical cost roll-ups and departmental P&L aggregation. | Column parent_cost_center_id (BIGINT) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The primary activity type or service provided by this cost center for internal cost allocation purposes (e.g., Studio Hours, Editing Hours, Transmission Hours). | Column activity_type (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'The total annual budget allocated to this cost center for the current fiscal year, in the cost center\'s currency. | Column annual_budget_amount (DECIMAL(18,2)) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Reference' ;
    rdfs:comment 'Reference identifier to the annual or periodic budget allocation document for this cost center, used for budget vs. actual variance analysis. | Column budget_allocation_reference (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business area or division within Media Broadcasting to which this cost center belongs (e.g., Linear Broadcasting, Streaming Platforms, News Division, Sports Division). | Column business_area (STRING) in finance.cost_center' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Classification of the cost center by cost behavior: direct costs attributable to specific content/programs, indirect costs supporting operations, overhead, or capital expenditure. | Column cost_center_category (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP Controlling Area code to which this cost center belongs. Controlling area represents the organizational unit for cost accounting. | Column controlling_area (STRING) in finance.cost_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'The method used to allocate costs from this cost center to other cost objects (e.g., direct assignment, activity-based costing, percentage allocation, driver-based). | Column cost_allocation_method (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center indicating whether it is operational and available for cost posting. | Column cost_center_status (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area within the media broadcasting business. [ENUM-REF-CANDIDATE: production|operations|sales|distribution|corporate|technology|content_acquisition — 7 candidates stripped; promote to reference product] | Column cost_center_type (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group or category that this cost center typically incurs (e.g., Personnel Costs, Production Costs, Technology Costs, Rights & Licensing). | Column cost_element_group (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The department code within the organizational structure to which this cost center is assigned. | Column department_code (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and responsibilities within the organization. | Column cost_center_description (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingSegment rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Segment' ;
    rdfs:comment 'The EBITDA reporting segment to which this cost center\'s costs are allocated for executive and investor reporting. | Column ebitda_reporting_segment (STRING) in finance.cost_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The position of this cost center within the organizational cost center hierarchy, used for roll-up reporting and consolidation. | Column hierarchy_node (STRING) in finance.cost_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in intercompany transactions requiring elimination entries during consolidation. | Column intercompany_flag (BOOLEAN) in finance.cost_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether this cost center directly generates revenue (e.g., Ad Sales regions) or is purely a cost-incurring unit. | Column is_revenue_generating (BOOLEAN) in finance.cost_center' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center (e.g., \'Digital Platform Operations\', \'News Production Studio A\', \'Ad Sales Northeast Region\'). | Column cost_center_name (STRING) in finance.cost_center' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'The unique employee identifier of the manager responsible for this profit center. Links to HR master data for organizational reporting. | Column responsible_manager_employee_id (BIGINT) in workforce.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Method' ;
    rdfs:comment 'The methodology used for allocating budgets to this profit center. Top-down allocates from corporate targets; bottom-up aggregates from operational plans; zero-based requires justification of all expenses; incremental adjusts prior year budgets. | Column budget_allocation_method (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which this profit center was closed and ceased operations. Null for active profit centers. Used for historical reporting and archival. | Column closure_date (DATE) in finance.profit_center' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying the profit center within the controlling area. Used in SAP CO for segment reporting and management accounting. Examples: SVOD-US, LINEAR-UK, ADSALES-NA. | Column profit_center_code (STRING) in finance.profit_center' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area to which this profit center is assigned. Controlling area is the organizational unit in SAP CO that represents a closed system for cost accounting purposes. | Column controlling_area_code (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Assignment Flag' ;
    rdfs:comment 'Indicates whether cost centers can be directly assigned to this profit center for cost allocation and internal charging purposes. | Column cost_center_assignment_flag (BOOLEAN) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed textual description of the profit centers business purpose, scope of operations, and strategic role within the enterprise. Used for documentation and onboarding. | Column profit_center_description (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center is included in EBITDA segment reporting for management and investor communications. EBITDA is a key profitability metric in media broadcasting. | Column ebitda_reporting_flag (BOOLEAN) in finance.profit_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether transactions involving this profit center require intercompany elimination adjustments during financial consolidation. Used in multi-entity corporate structures. | Column intercompany_elimination_flag (BOOLEAN) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center. Human-readable label used in financial reports and management dashboards. | Column profit_center_name (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'The code of the parent profit center in the organizational hierarchy, if this profit center rolls up to another. Enables hierarchical consolidation for segment EBITDA and management reporting. | Column parent_profit_center_code (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active profit centers are operational and accept postings; inactive are temporarily suspended; planned are future entities; closed are historical and no longer accept transactions. | Column profit_center_status (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center based on its accountability model. Revenue centers are responsible for revenue generation; cost centers for cost control; investment centers for return on invested capital; service centers provide internal services. | Column profit_center_type (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenuePostingFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Posting Flag' ;
    rdfs:comment 'Indicates whether revenue transactions can be posted directly to this profit center. Used to control which profit centers participate in revenue recognition workflows. | Column revenue_posting_flag (BOOLEAN) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit center, used in condensed reports and system displays where space is limited. | Column short_name (STRING) in finance.profit_center' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Scope Flag' ;
    rdfs:comment 'Indicates whether this profit center is within the scope of SOX financial controls and requires enhanced audit trails and segregation of duties for financial postings. | Column sox_control_scope_flag (BOOLEAN) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The method used for pricing internal transactions between this profit center and other organizational units. Examples: cost-plus, market-based, negotiated. Critical for accurate profit center performance measurement. | Column transfer_pricing_method (STRING) in finance.profit_center' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Unique identifier for the general ledger record. Primary key for the general ledger data product. | Column general_ledger_id (BIGINT) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Functional Currency' ;
    rdfs:comment 'Budgeted amount allocated to the general ledger account for the fiscal period, expressed in functional currency. Used for budget vs. actual variance analysis and financial planning. Particularly relevant for production budgets, content acquisition costs, and operational expense management. | Column budget_amount_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Functional Currency' ;
    rdfs:comment 'Closing balance of the general ledger account at the end of the fiscal period, expressed in functional currency. Calculated as opening balance plus net period activity. Represents the ending position for trial balance and financial statement generation. | Column closing_balance_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'Consolidation unit code representing the entity for group consolidation and statutory reporting. Used for multi-entity financial consolidation, intercompany eliminations, and corporate-level financial statement preparation. | Column consolidation_unit (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Functional Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts. | Column credit_amount_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Transaction Currency' ;
    rdfs:comment 'Total credit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes. | Column credit_amount_transaction_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Functional Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the functional currency of the company code. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts. | Column debit_amount_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Transaction Currency' ;
    rdfs:comment 'Total debit amount posted to the general ledger account for the period, expressed in the original transaction currency. Maintained for audit trail and foreign exchange reconciliation purposes. | Column debit_amount_transaction_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code representing the type of accounting document that generated the general ledger entry (e.g., SA for G/L account document, DR for customer invoice, KR for vendor invoice, DZ for payment). Used for document classification and posting control. | Column document_type (STRING) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaIndicator rdf:type rdf:Property ;
    rdfs:label 'Ebitda Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is included in EBITDA calculation for management reporting and investor disclosures. True if the account contributes to EBITDA (operating revenues and expenses), false if excluded (interest, taxes, depreciation, amortization). | Column ebitda_indicator (BOOLEAN) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the functional currency of the company code (e.g., USD, GBP, EUR). The functional currency is the primary currency in which the legal entity conducts business and prepares financial statements. | Column functional_currency_code (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account number from the chart of accounts. Represents the specific account classification (asset, liability, equity, revenue, expense) for financial transactions. Structured according to the enterprise chart of accounts hierarchy. | Column gl_account (STRING) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'Date of the most recent transaction posted to this general ledger account within the fiscal period. Used for audit trail and period-end reconciliation validation. | Column last_posting_date (DATE) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Ledger group code representing the accounting principle or reporting standard (e.g., 0L for leading ledger, 2L for IFRS, 3L for US GAAP). Enables parallel accounting for multiple reporting frameworks within a single system. | Column ledger_group (STRING) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Balance Functional Currency' ;
    rdfs:comment 'Net balance of the general ledger account for the period, calculated as debit amount minus credit amount (or vice versa depending on account type), expressed in the functional currency. Represents the aggregated account state for trial balance and financial statement generation. | Column net_balance_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalanceFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Functional Currency' ;
    rdfs:comment 'Opening balance of the general ledger account at the beginning of the fiscal period, expressed in functional currency. Represents the carried-forward balance from the previous period for balance sheet accounts. | Column opening_balance_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodLockStatus rdf:type rdf:Property ;
    rdfs:label 'Period Lock Status' ;
    rdfs:comment 'Status of the posting period indicating whether the period is open for new postings, closed for regular postings but open for adjustments, or locked for all postings. Used for period-end close control and financial statement finalization. | Column period_lock_status (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit numeric code that controls the posting behavior and determines whether the entry is a debit or credit (e.g., 40 for debit, 50 for credit). Used for transaction validation and account determination logic. | Column posting_key (STRING) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Numeric posting period within the fiscal year (typically 1-12 for monthly periods, with additional special periods 13-16 for year-end adjustments). Represents the accounting period for transaction posting and period-end close. | Column posting_period (INT) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is a reconciliation account (subledger control account) that must reconcile with subsidiary ledgers such as accounts receivable, accounts payable, or fixed assets. True if reconciliation account, false otherwise. | Column reconciliation_account_indicator (BOOLEAN) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Category' ;
    rdfs:comment 'Classification of revenue accounts by primary revenue stream type for Media Broadcasting business. Categories include advertising (linear and digital ad sales), subscription (SVOD/AVOD), carriage fees (MVPD/vMVPD distribution), syndication (content resale), licensing (rights monetization), transactional (TVOD), and other. Used for revenue assurance and segment reporting. [ENUM-REF-CANDIDATE: advertising|subscription|carriage_fees|syndication|licensing|transactional|other — 7 candidates stripped; promote to reference product] | Column revenue_stream_category (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segment code for external segment reporting as required by IFRS 8 and US GAAP. Represents reportable business segments for statutory financial reporting and investor disclosures (e.g., content production, advertising, subscription services). | Column segment (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Control Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the general ledger account is subject to Sarbanes-Oxley Act internal control requirements and audit procedures. True if SOX-controlled account requiring enhanced documentation and approval workflows, false otherwise. | Column sox_control_indicator (BOOLEAN) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Trading partner code identifying the intercompany counterparty for intercompany transactions. Used for intercompany eliminations and consolidated financial statement preparation. | Column trading_partner (STRING) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the original transaction currency if different from functional currency. Used for multi-currency transactions requiring foreign exchange conversion and revaluation. | Column transaction_currency_code (STRING) in finance.general_ledger' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Variance Amount Functional Currency' ;
    rdfs:comment 'Variance between actual net balance and budgeted amount for the fiscal period, expressed in functional currency. Calculated as actual minus budget. Positive variance indicates over-budget for expense accounts or under-budget for revenue accounts. | Column variance_amount_functional_currency (DECIMAL(18,2)) in finance.general_ledger' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'The SAP user ID of the individual who posted this journal entry into the system. Used for audit trail and accountability purposes. | Column primary_journal_employee_id (BIGINT) in workforce.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recurringEntryTemplateId rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Template Id' ;
    rdfs:comment 'The identifier of the recurring entry template from which this journal entry was generated. Populated only when recurring_entry_indicator is True. | Column recurring_entry_template_id (BIGINT) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecurringEntryTemplate .

ind:sourceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Source Document Id' ;
    rdfs:comment 'The unique identifier of the source document in the originating system that generated this journal entry. Used for traceability and reconciliation back to operational systems. | Column source_document_id (BIGINT) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourceDocument .

ind:accrualReversalDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Date' ;
    rdfs:comment 'The future posting date on which this accrual entry will automatically reverse. Populated only when accrual_reversal_indicator is True. | Column accrual_reversal_date (DATE) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualReversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Accrual Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is an automatic accrual reversal. True if this entry will automatically reverse in the subsequent period. | Column accrual_reversal_indicator (BOOLEAN) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the journal entry by its accounting purpose: standard operational posting, period-end accrual, prepayment amortization, account reclassification, intercompany elimination, or error correction. | Column adjustment_type (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The name of the batch input session if this journal entry was posted via batch processing rather than manual entry. Empty for manually posted entries. | Column batch_input_session (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract) that gave rise to this journal entry. May differ from posting date when entries are posted retrospectively. | Column document_date (DATE) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Descriptive text at the document header level providing context or explanation for the journal entry, such as the business purpose, transaction description, or special instructions. | Column document_header_text (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known SAP document number assigned to this journal entry at posting time. This is the business identifier used across financial reporting and audit trails. | Column document_number (STRING) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date when the journal entry was physically entered into the SAP system by the user, which may differ from both document date and posting date. | Column entry_date (DATE) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'The precise date and time when the journal entry was created in the SAP system. Provides audit trail for record creation. | Column entry_time (TIMESTAMP) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Single-character code indicating the type of exchange rate used (e.g., M=Average Rate, B=Bank Buying Rate, G=Bank Selling Rate). Determines which rate table is consulted for currency conversion. | Column exchange_rate_type (STRING) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between different legal entities within Media Broadcasting. True for intercompany entries requiring elimination in consolidated reporting. | Column intercompany_indicator (BOOLEAN) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the local currency of the company code. Used for parallel accounting and statutory reporting. | Column local_currency_code (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is in parked status (saved but not yet posted). True if parked, False if fully posted. | Column parked_indicator (BOOLEAN) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurringEntryIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurring Entry Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is part of a recurring entry template (e.g., monthly depreciation, rent accruals). True if generated from a recurring template. | Column recurring_entry_indicator (BOOLEAN) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previously posted document. True if this entry reverses another entry, False otherwise. | Column reversal_indicator (BOOLEAN) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Two-digit code indicating the business reason for reversing the original document (e.g., 01=Error Correction, 02=Accrual Reversal, 03=Period-End Adjustment). Populated only when reversal_indicator is True. | Column reversal_reason_code (STRING) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True. | Column reversed_document_number (STRING) in finance.journal_entry' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner for intercompany transactions. Populated only when intercompany_indicator is True. Used for intercompany reconciliation and consolidation eliminations. | Column trading_partner_company_code (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'The SAP transaction code (T-Code) used to post this journal entry (e.g., FB01, FB50, F-02). Indicates the posting interface and provides context for the entry method. | Column transaction_code (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current status of the journal entry within the SOX-compliant approval workflow. Tracks the document through draft, approval, posting, and potential reversal stages. | Column workflow_status (STRING) in finance.journal_entry' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aboveTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Above The Line Amount' ;
    rdfs:comment 'Budget allocated to above-the-line costs including key creative talent (writers, directors, producers, lead actors). These are typically negotiated individually and represent significant budget items. | Column above_the_line_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Cumulative actual expenditure against this budget as of the last financial update. Used for variance tracking and budget performance monitoring. | Column actual_spend_to_date (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:belowTheLineAmount rdf:type rdf:Property ;
    rdfs:label 'Below The Line Amount' ;
    rdfs:comment 'Budget allocated to below-the-line costs including crew, equipment, facilities, and production support. These are standard production costs not tied to key creative talent. | Column below_the_line_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Budget Effective Date' ;
    rdfs:comment 'The date from which this budget version becomes effective and spending authorization begins. | Column budget_effective_date (DATE) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Budget Expiry Date' ;
    rdfs:comment 'The date on which this budget version expires or is superseded by a new version. Null for open-ended budgets. | Column budget_expiry_date (DATE) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes and comments regarding this budget version, including justification for revisions, special conditions, or approval stipulations. | Column budget_notes (STRING) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique identifier for the production budget, used for tracking and reference in financial systems and production workflows. | Column budget_number (STRING) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the production budget. Tracks progression from draft through approval to active spending and final closure. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|revised|closed|cancelled — 7 candidates stripped; promote to reference product] | Column budget_status (STRING) in finance.production_budget' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the production budget by content type. Different content types have different cost structures and budget approval workflows. [ENUM-REF-CANDIDATE: scripted_series|film|live_event|news_programming|digital_original|documentary|sports|reality|animation — 9 candidates stripped; promote to reference product] | Column budget_type (STRING) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of the budget. Budgets are revised throughout the production lifecycle; this field tracks the iteration (e.g., 1 for initial, 2 for first revision). | Column budget_version (STRING) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitiesAmount rdf:type rdf:Property ;
    rdfs:label 'Facilities Amount' ;
    rdfs:comment 'Budget allocated to production facilities including studio rental, location fees, set construction, and production office space. | Column facilities_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used for production cost control and tracking actual expenditures against this budget. | Column internal_order_number (STRING) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicLicensingAmount rdf:type rdf:Property ;
    rdfs:label 'Music Licensing Amount' ;
    rdfs:comment 'Budget allocated to music licensing, original score composition, and music rights clearance for the production. | Column music_licensing_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postProductionAmount rdf:type rdf:Property ;
    rdfs:label 'Post Production Amount' ;
    rdfs:comment 'Budget allocated to post-production activities including editing, color correction, sound design, mixing, and final mastering. | Column post_production_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'Total approved budget amount for the production project across all cost categories. This is the authorized spending limit. | Column total_approved_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vfxAmount rdf:type rdf:Property ;
    rdfs:label 'Vfx Amount' ;
    rdfs:comment 'Budget allocated to visual effects production. VFX is often a significant cost category for scripted series, films, and high-production-value content. | Column vfx_amount (DECIMAL(18,2)) in finance.production_budget' ;
    rdfs:domain ind:ProductionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVersionId rdf:type rdf:Property ;
    rdfs:label 'Budget Version Id' ;
    rdfs:comment 'Unique identifier for the budget version record. Primary key. | Column budget_version_id (BIGINT) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Employee Id' ;
    rdfs:comment 'The user identifier of the person who last modified this budget version record. Links to the user management system for accountability and audit purposes. | Column employee_id (BIGINT) in workforce.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Amount' ;
    rdfs:comment 'The original baseline budget amount before any revisions or adjustments. Used as a reference point for variance analysis and tracking budget changes over time. | Column baseline_amount (DECIMAL(18,2)) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level classification of the budget type. Operating expense (OPEX) covers day-to-day costs; capital expenditure (CAPEX) covers long-term investments; production cost tracks content creation spend; revenue target sets income goals; headcount manages personnel costs; marketing covers promotional spend; content acquisition tracks licensing and rights purchases. [ENUM-REF-CANDIDATE: operating_expense|capital_expenditure|production_cost|revenue_target|headcount|marketing|content_acquisition — 7 candidates stripped; promote to reference product] | Column budget_category (STRING) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Version Status' ;
    rdfs:comment 'Current lifecycle status of the budget version. Draft indicates work in progress; pending approval is awaiting authorization; approved is authorized but not yet active; active is currently in effect; superseded has been replaced by a newer version; closed is finalized and archived. | Column budget_version_status (STRING) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Detailed explanation of why this budget version was created. Captures the business justification for revisions, reforecasts, or supplemental allocations. Critical for variance analysis and audit compliance. | Column change_rationale (STRING) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Indicates the organizational level at which this budget version is consolidated. Entity is the highest corporate level; division represents major business units; department is operational units; project is specific initiatives; consolidated represents fully aggregated enterprise-wide budgets. | Column consolidation_level (STRING) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning period granularity for this budget version. Supports quarterly (Q1-Q4), monthly (M01-M12), half-yearly (H1-H2), or full fiscal year (FY) planning cycles. | Column planning_period (STRING) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance percentage threshold for this budget version. Triggers alerts or approval workflows when actual spend deviates from budget by more than this percentage. Typically set between 5% and 15%. | Column variance_threshold_percentage (DECIMAL(5,2)) in finance.budget_version' ;
    rdfs:domain ind:BudgetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard governing revenue recognition for this stream (ASC 606 for US GAAP, IFRS 15 for international, or local GAAP variants). | Column accounting_standard (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMeasurementSource rdf:type rdf:Property ;
    rdfs:label 'Audience Measurement Source' ;
    rdfs:comment 'Primary audience measurement provider used for revenue validation and guarantees (e.g., Nielsen, Comscore, Adobe Analytics). Critical for advertising revenue streams with audience guarantees. | Column audience_measurement_source (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeferred rdf:type rdf:Property ;
    rdfs:label 'Is Deferred' ;
    rdfs:comment 'Indicates whether revenue from this stream is initially recorded as deferred revenue and recognized over time (True for advance payments, subscriptions; False for immediate recognition). | Column is_deferred (BOOLEAN) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodsPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegoods Policy' ;
    rdfs:comment 'Policy for providing makegoods (compensatory ad spots) when delivery guarantees are not met: automatic, negotiated, none, audience-based, or technical failure only. | Column makegoods_policy (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceObligation rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation' ;
    rdfs:comment 'Description of the performance obligation that must be satisfied for revenue recognition per ASC 606 / IFRS 15 (e.g., delivery of ad impressions, provision of streaming access, content licensing rights transfer). | Column performance_obligation (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSegment rdf:type rdf:Property ;
    rdfs:label 'Reporting Segment' ;
    rdfs:comment 'Corporate reporting segment for external financial reporting (e.g., Linear Broadcasting, Streaming Services, Content Licensing). Used for segment disclosure per ASC 280 / IFRS 8. | Column reporting_segment (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStreamStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Status' ;
    rdfs:comment 'Current lifecycle status of the revenue stream: active (currently generating revenue), inactive (not in use), suspended (temporarily halted), pending approval (awaiting finance approval), or deprecated (phased out). | Column revenue_stream_status (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSubcategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the revenue category (e.g., Upfront, Scatter, Programmatic for advertising; SVOD, AVOD, TVOD for subscription; Linear Carriage, OTT Carriage for carriage fees). | Column revenue_subcategory (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamCode rdf:type rdf:Property ;
    rdfs:label 'Stream Code' ;
    rdfs:comment 'Business identifier code for the revenue stream (e.g., ADV-UPFRONT, SVOD-PREM, CARRIAGE-FEE). Used across financial systems and reporting. | Column stream_code (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamName rdf:type rdf:Property ;
    rdfs:label 'Stream Name' ;
    rdfs:comment 'Full descriptive name of the revenue stream (e.g., Upfront Advertising Sales, Premium SVOD Subscription, Syndication License Fees). | Column stream_name (STRING) in finance.revenue_stream' ;
    rdfs:domain ind:RevenueStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRecognitionEventRevenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Event Revenue Recognition Event Id' ;
    rdfs:comment 'Reference to the original revenue recognition event ID if this record represents a reversal or adjustment. Enables full audit trail of revenue corrections. | Column original_recognition_event_revenue_recognition_event_id (BIGINT) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'The SAP S/4HANA accounting document number (FI document) that records this revenue recognition event. Provides full audit trail and drill-back capability to source transactions. | Column accounting_document_number (STRING) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asc606CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Asc 606 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with ASC 606 (US GAAP) revenue recognition standards. | Column asc_606_compliant_flag (BOOLEAN) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this revenue recognition event resulted from a contract modification. ASC 606 requires specific accounting treatment for modified contracts. | Column contract_modification_flag (BOOLEAN) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrs15CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 15 Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that this revenue recognition event was processed in accordance with IFRS 15 (International Financial Reporting Standards) revenue recognition standards. | Column ifrs_15_compliant_flag (BOOLEAN) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which this revenue was recognized in the general ledger. This is the principal business event timestamp for financial reporting and period-end close. | Column recognition_date (DATE) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The monetary amount of revenue recognized in this event and posted to the general ledger. Represents the earned portion of the transaction price allocated to the performance obligation. | Column recognized_amount (DECIMAL(18,2)) in finance.revenue_recognition_event' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAssuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Assurance Status' ;
    rdfs:comment 'Status of revenue assurance validation for this recognition event: verified (passed all controls), pending_verification (awaiting reconciliation), discrepancy_identified (variance detected), or reconciled (discrepancy resolved). | Column revenue_assurance_status (STRING) in finance.revenue_recognition_event' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'The aging category of the receivable based on days past due (current, 1-30 days, 31-60 days, 61-90 days, over 90 days). | Column aging_bucket (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field used for additional sorting, grouping, or reconciliation purposes in SAP FI-AR. | Column assignment_field (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date when the receivable was fully cleared through payment or other settlement mechanism. Null if still open. | Column clearing_date (DATE) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current clearing status of the receivable indicating whether it is open, partially cleared, fully cleared, disputed, or written off. | Column clearing_status (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the receivable was originally denominated (e.g., USD, EUR, GBP). | Column document_currency (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date when the most recent dunning notice was sent to the customer for this receivable. | Column dunning_date (DATE) in finance.accounts_receivable' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company\'s local reporting currency. | Column local_currency (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The receivable amount converted to the company\'s local reporting currency for consolidation and financial reporting. | Column local_currency_amount (DECIMAL(18,2)) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'The current outstanding amount still owed by the customer in document currency after partial payments or adjustments. | Column open_amount (DECIMAL(18,2)) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference document number such as customer purchase order number, contract number, or other business reference. | Column reference_document (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about this receivable entry. | Column text_description (STRING) in finance.accounts_receivable' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentProcurementId rdf:type rdf:Property ;
    rdfs:label 'Equipment Procurement Id' ;
    rdfs:comment 'Foreign key linking to technology.equipment_procurement. Business justification: AP invoices are matched to equipment purchase orders for three-way match (PO, goods receipt, invoice). Finance validates invoice against PO terms for payment approval, purchase price variance analysis | Column equipment_procurement_id (BIGINT) in technology.accounts_payable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentProcurement .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Free-text reference field for additional assignment information (e.g., production code, content title, project ID). Used for detailed cost tracking. | Column assignment_reference (STRING) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI document number of the payment document that cleared this payable. Null if not yet cleared. | Column clearing_document_number (STRING) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Date by which payment must be made to qualify for early payment discount. Null if no discount terms apply. | Column discount_due_date (DATE) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Single-character code indicating if payment is blocked (e.g., A=Blocked for Payment, R=Blocked for Review, blank=Not Blocked). Prevents automatic payment until resolved. | Column payment_block (STRING) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Free-text explanation for why payment is blocked (e.g., pending approval, invoice dispute, missing documentation). Null if not blocked. | Column payment_block_reason (STRING) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxIndicator rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Indicator' ;
    rdfs:comment 'Boolean flag indicating whether withholding tax applies to this payable. True if withholding tax is calculated and deducted. | Column withholding_tax_indicator (BOOLEAN) in finance.accounts_payable' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record within the Media Broadcasting corporate group. | Column intercompany_transaction_id (BIGINT) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Intercompany transactions can be allocated to sending cost center. The sending_cost_center STRING column will be replaced by FK to cost_center.cost_center_id. | Column sending_cost_center_id (BIGINT) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sendingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Sending Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Intercompany transactions have a sending legal entity. The sending_company_code is a business key reference to legal_entity. FK enables proper intercompany elimination and netting. | Column sending_legal_entity_id (BIGINT) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Free-text description providing additional business context for the intercompany transaction, such as the specific content title licensed, service provided, or purpose of the charge. | Column intercompany_transaction_description (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this intercompany transaction requires elimination entries during consolidated financial statement preparation at group level. | Column elimination_flag (BOOLEAN) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the consolidation elimination process for this intercompany transaction in the group financial consolidation system. | Column elimination_status (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code representing the corporate group reporting currency (typically USD for Media Broadcasting). | Column group_currency (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the corporate group reporting currency for consolidated financial statement preparation. | Column group_currency_amount (DECIMAL(18,2)) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether the intercompany transaction is subject to bilateral netting arrangements to reduce cash settlement volumes between legal entities. | Column netting_status (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'The SAP company code of the legal entity receiving or being charged for the intercompany transaction (the entity consuming the service, content, or financing). | Column receiving_company_code (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Cost Center' ;
    rdfs:comment 'The cost center within the receiving company code that is being charged for the intercompany transaction, enabling detailed cost allocation and budget tracking. | Column receiving_cost_center (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) in which this intercompany transaction is subject to monthly intercompany reconciliation procedures. | Column reconciliation_period (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this intercompany transaction to source documents such as content licensing agreements, service invoices, or loan agreements. | Column reference_document_number (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'The SAP company code of the legal entity originating or charging the intercompany transaction (the entity providing the service, content, or financing). | Column sending_company_code (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of cash settlement for the intercompany transaction, tracking whether payment has been made between the legal entities. | Column settlement_status (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated (e.g., USD, EUR, GBP). | Column transaction_currency (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction indicating its position in the approval, posting, and reconciliation workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|posted|reconciled|disputed|cancelled — 7 candidates stripped; promote to reference product] | Column transaction_status (STRING) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for interest calculation and cash flow purposes, particularly relevant for intercompany loans and financing arrangements. | Column value_date (DATE) in finance.intercompany_transaction' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Unique identifier for the financial period close record. Primary key for the period close entity. | Column period_close_id (BIGINT) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeChecklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Close Checklist Completion Pct' ;
    rdfs:comment 'Percentage of period-end close checklist tasks that have been completed. Ranges from 0.00 to 100.00. Provides visibility into close progress. | Column close_checklist_completion_pct (DECIMAL(5,2)) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completed Timestamp' ;
    rdfs:comment 'Date and time when the period close process was completed and the period was locked. Null if close is not yet completed. | Column close_completed_timestamp (TIMESTAMP) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Initiated Timestamp' ;
    rdfs:comment 'Date and time when the period close process was formally initiated in the system. | Column close_initiated_timestamp (TIMESTAMP) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeNotes rdf:type rdf:Property ;
    rdfs:label 'Close Notes' ;
    rdfs:comment 'Free-text field for documenting significant events, issues, or observations during the period close process. Provides context for future reference and audit trail. | Column close_notes (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closePhase rdf:type rdf:Property ;
    rdfs:label 'Close Phase' ;
    rdfs:comment 'Current phase of the period-end close process. Pre-close for preliminary activities, soft close for initial close with limited posting allowed, hard close for final close with restricted access, final close for locked period after SOX sign-off. | Column close_phase (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the period close execution. Tracks the lifecycle state from initiation through completion or failure. | Column close_status (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationStatus rdf:type rdf:Property ;
    rdfs:label 'Consolidation Status' ;
    rdfs:comment 'Status of financial consolidation processing for this company code and period. Tracks whether the legal entity data has been successfully consolidated into group reporting. | Column consolidation_status (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerEmail rdf:type rdf:Property ;
    rdfs:label 'Controller Email' ;
    rdfs:comment 'Email address of the responsible controller for communication and notification purposes during the close process. | Column controller_email (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'Calculated EBITDA for this company code and period in local currency. Key profitability metric for media broadcasting operations and corporate reporting. | Column ebitda_amount (DECIMAL(18,2)) in finance.period_close' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Indicates whether this period close requires external auditor review and sign-off. Typically true for quarterly and annual closes for publicly traded entities. | Column external_audit_required (BOOLEAN) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditStatus rdf:type rdf:Property ;
    rdfs:label 'External Audit Status' ;
    rdfs:comment 'Status of external auditor review for this period close. Tracks the progress of third-party audit activities. | Column external_audit_status (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Status' ;
    rdfs:comment 'Status of intercompany transaction elimination processing for consolidated financial reporting. Indicates whether intercompany balances have been identified and eliminated. | Column intercompany_elimination_status (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReopenDate rdf:type rdf:Property ;
    rdfs:label 'Last Reopen Date' ;
    rdfs:comment 'Date when the period was most recently reopened for adjustments. Null if the period has never been reopened. | Column last_reopen_date (DATE) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Items Count' ;
    rdfs:comment 'Number of open line items (uncleared documents) remaining in the general ledger at the time of close execution. Indicates outstanding reconciliation work. | Column open_items_count (INT) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Lock Timestamp' ;
    rdfs:comment 'Date and time when the posting period was locked in the system. Null if the period is not yet locked. | Column period_lock_timestamp (TIMESTAMP) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingPeriodLocked rdf:type rdf:Property ;
    rdfs:label 'Posting Period Locked' ;
    rdfs:comment 'Indicates whether the posting period has been locked to prevent further transactions. True when the period is closed and locked, false when still open for postings. | Column posting_period_locked (BOOLEAN) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Business justification for the most recent period reopen. Documents the reason for post-close adjustments for audit trail purposes. | Column reopen_reason (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleController rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller' ;
    rdfs:comment 'Name or identifier of the financial controller responsible for executing and certifying the period close for this company code and period. | Column responsible_controller (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCloseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Close Date' ;
    rdfs:comment 'The planned target date for completing the period close process. Established based on the financial calendar and reporting deadlines. | Column scheduled_close_date (DATE) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Control Status' ;
    rdfs:comment 'Status of SOX internal control testing and certification for this period close. Required for publicly traded companies to ensure financial reporting compliance. | Column sox_control_status (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSignoffBy rdf:type rdf:Property ;
    rdfs:label 'Sox Signoff By' ;
    rdfs:comment 'Name or identifier of the individual who provided the SOX control sign-off for this period close. | Column sox_signoff_by (STRING) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Sox Signoff Date' ;
    rdfs:comment 'Date when the SOX control certification was completed and signed off by the responsible controller or compliance officer. Null if not yet signed off. | Column sox_signoff_date (DATE) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unreconciledAmount rdf:type rdf:Property ;
    rdfs:label 'Unreconciled Amount' ;
    rdfs:comment 'Total monetary value of unreconciled items in the company code currency. Represents the financial exposure from incomplete reconciliations. | Column unreconciled_amount (DECIMAL(18,2)) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unreconciledItemsCount rdf:type rdf:Property ;
    rdfs:label 'Unreconciled Items Count' ;
    rdfs:comment 'Number of accounts or subledger items that have not been reconciled to the general ledger at the time of close. Critical metric for close quality. | Column unreconciled_items_count (INT) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceToForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Forecast Amount' ;
    rdfs:comment 'Monetary variance between actual period results and forecasted amounts in company code currency. Positive indicates favorable variance, negative indicates unfavorable. | Column variance_to_forecast_amount (DECIMAL(18,2)) in finance.period_close' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the corporate hierarchy. Used to establish organizational structure and consolidation relationships. Null for the ultimate parent entity. | Column parent_entity_legal_entity_id (BIGINT) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:broadcastLicenseHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast License Holder Flag' ;
    rdfs:comment 'Indicates whether this legal entity holds one or more broadcast licenses issued by the FCC or equivalent regulatory authority. True if the entity is a licensed broadcaster. | Column broadcast_license_holder_flag (BOOLEAN) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character code identifying the chart of accounts assigned to this legal entity in SAP S/4HANA. Defines the structure of general ledger accounts used for financial postings. | Column chart_of_accounts (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier for the consolidation group or reporting unit to which this legal entity belongs. Used for corporate consolidation, intercompany eliminations, and segment reporting. | Column consolidation_group (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the legal entity is incorporated and registered. Determines primary legal jurisdiction and regulatory framework. | Column country_of_incorporation (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'Four-character code identifying the credit control area assigned to this legal entity in SAP S/4HANA. Used for credit management and accounts receivable monitoring. | Column credit_control_area (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active indicates the entity is conducting business; inactive indicates temporary suspension; dormant indicates no current operations but entity remains registered; liquidation indicates entity is being wound down; dissolved indicates entity has been formally closed. | Column entity_status (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal year structure for this legal entity, including the number of periods, period start and end dates, and year-end closing rules. Used for period-based financial reporting. | Column fiscal_year_variant (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which the entity conducts its business and maintains its books of account. Used for financial statement preparation and consolidation. | Column functional_currency (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the governing authority. | Column incorporation_date (DATE) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationGroup rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Group' ;
    rdfs:comment 'Code identifying the group of entities for which intercompany transactions must be eliminated during consolidation. Used to ensure accurate consolidated financial statements. | Column intercompany_elimination_group (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'The legal structure or incorporation type of the entity (e.g., Corporation, Limited Liability Company, Partnership, Public Limited Company). Determines liability, taxation, and regulatory obligations. | Column legal_form (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full legal name of the entity as registered with the governing authority. This is the official name used in all legal documents, contracts, regulatory filings, and financial statements. | Column legal_entity_name (STRING) in finance.legal_entity' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as filed with the incorporation authority. Used for legal correspondence and regulatory filings. | Column registered_address_line1 (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address (suite, floor, building name). Optional field for additional address details. | Column registered_address_line2 (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the registered address. | Column registered_city (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code for the registered address. Typically matches the country of incorporation. | Column registered_country (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered address. | Column registered_postal_code (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or region of the registered address. Uses standard postal abbreviations where applicable. | Column registered_state_province (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number assigned by the government authority in the country of incorporation. Used for legal identification and regulatory compliance. | Column registration_number (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingObligations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Obligations' ;
    rdfs:comment 'Comma-separated list of regulatory reporting frameworks and obligations applicable to this legal entity (e.g., SEC 10-K, FCC Form 323, Ofcom Annual Return). Determines mandatory filings and disclosure requirements. | Column regulatory_reporting_obligations (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency used for external financial reporting and consolidation at the corporate level. | Column reporting_currency (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of SOX compliance and internal control testing. True if the entity is material to consolidated financial statements and subject to SOX Section 404 requirements. | Column sox_scope_flag (BOOLEAN) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for entities operating in jurisdictions requiring VAT registration. Used for VAT reporting and cross-border transactions. | Column vat_registration_number (STRING) in finance.legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementChartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Cost elements in SAP CO are GL accounts from the chart of accounts. The cost_element STRING is a business key that should be supplemented with FK to chart_of_accounts.chart_of_accounts_id. | Column cost_element_chart_of_accounts_id (BIGINT) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Foreign key reference to the original cost allocation record that this record reverses. Null if this is not a reversal transaction. | Column original_allocation_cost_allocation_id (BIGINT) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Foreign key reference to the cost center from which costs are being allocated (the source of the shared costs being distributed). | Column primary_sender_cost_center_id (BIGINT) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Foreign key reference to the profit center receiving the allocated costs. Null if the receiver is a cost center instead of a profit center. | Column receiver_profit_center_id (BIGINT) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:allocationKey rdf:type rdf:Property ;
    rdfs:label 'Allocation Key' ;
    rdfs:comment 'The allocation key or driver used to determine the proportion of costs allocated to the receiver (e.g., headcount, square footage, revenue, FTE, transaction volume). Defines the basis for cost distribution. | Column allocation_key (STRING) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationKeyValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Key Value' ;
    rdfs:comment 'The numeric value of the allocation key used for this specific allocation (e.g., 15 FTEs, 2500 square feet, 1000000 transactions). Used to calculate the allocated amount. | Column allocation_key_value (DECIMAL(18,4)) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRunDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Date' ;
    rdfs:comment 'The date on which the allocation cycle was executed and this allocation record was created. May differ from posting date if allocations are run in advance and posted later. | Column allocation_run_date (DATE) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'The SAP CO cost element (account assignment) under which the allocated cost is recorded. Maps to the general ledger account in SAP FI. | Column cost_element (STRING) in finance.cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Unique identifier for the capital expenditure project record. Primary key. | Column capex_project_id (BIGINT) in finance.capex_project' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:actualCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Capitalization Date' ;
    rdfs:comment 'Actual date when the project was settled to fixed assets and depreciation commenced. Used for SOX compliance and financial statement preparation. | Column actual_capitalization_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when project was completed and ready for asset settlement. Triggers capitalization workflow and depreciation start date calculation. | Column actual_completion_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when project execution commenced. Used for variance analysis against planned timeline. | Column actual_start_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital budget approved for the project by the investment committee. Represents the authorized spending limit for the capital investment. | Column approved_budget_amount (DECIMAL(18,2)) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Fixed asset class code that the project will be capitalized into upon completion. Determines depreciation method, useful life, and GL account assignment. Examples include broadcast equipment, buildings, IT infrastructure. | Column asset_class_code (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aucAccountCode rdf:type rdf:Property ;
    rdfs:label 'Auc Account Code' ;
    rdfs:comment 'General ledger account code for the asset under construction balance sheet account. All project costs are accumulated in this account until capitalization. Typically a fixed asset sub-account per chart of accounts. | Column auc_account_code (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Spend Amount' ;
    rdfs:comment 'Total actual expenditure incurred to date on the capital project. Aggregates all posted costs from journal entries and purchase orders. Used for budget variance analysis and capitalization. | Column cumulative_spend_amount (DECIMAL(18,2)) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Governance Review Status' ;
    rdfs:comment 'Status of the capital project governance review by the investment committee or capital allocation board. Tracks approval workflow and conditional requirements. | Column governance_review_status (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentJustification rdf:type rdf:Property ;
    rdfs:label 'Investment Justification' ;
    rdfs:comment 'Primary business rationale for the capital investment. Capacity expansion includes new studios or transmission capacity; technology upgrade covers platform modernization; regulatory compliance addresses FCC or technical standards; cost reduction targets operational efficiency; revenue generation supports new monetization channels. | Column investment_justification (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Capitalization Date' ;
    rdfs:comment 'Target date for transferring the asset under construction (AUC) to fixed assets and beginning depreciation. Aligns with asset placed-in-service date for financial reporting. | Column planned_capitalization_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion and readiness for capitalization. Used for depreciation planning and asset lifecycle management. | Column planned_completion_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for project execution to begin. Used for resource planning and timeline tracking. | Column planned_start_date (DATE) in finance.capex_project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectClassification rdf:type rdf:Property ;
    rdfs:label 'Project Classification' ;
    rdfs:comment 'Categorical classification of the capital project type. Infrastructure includes broadcast towers and transmission equipment; technology covers OTT platforms and enterprise systems; facilities encompasses studio construction and office build-outs; equipment includes production gear and IRDs. | Column project_classification (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business identifier for the capital project, used across financial systems and reporting. Typically follows organizational coding standards for capital investment tracking. | Column project_code (STRING) in finance.capex_project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed description of the capital project scope, objectives, and deliverables. Provides context for investment justification and asset capitalization. | Column project_description (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Descriptive name of the capital project, such as \'OTT Platform Infrastructure Upgrade\' or \'Studio B Renovation\'. | Column project_name (STRING) in finance.capex_project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital project. Planning indicates pre-approval stage; approved means budget authorized; in_progress reflects active execution; completed indicates project finished but not yet capitalized; capitalized means transferred to fixed assets; cancelled indicates project terminated. [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|capitalized|cancelled — 7 candidates stripped; promote to reference product] | Column project_status (STRING) in finance.capex_project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Unspent budget balance available for the project. Calculated as approved budget minus cumulative spend. Used for commitment control and budget monitoring. | Column remaining_budget_amount (DECIMAL(18,2)) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the executive sponsor or business owner who approved and champions the capital investment. Typically a VP or C-level executive. | Column sponsor_name (STRING) in finance.capex_project' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key. | Column fixed_asset_id (BIGINT) in finance.fixed_asset' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'The total depreciation expense recognized to date since acquisition. Used to calculate net book value. | Column accumulated_depreciation (DECIMAL(18,2)) in finance.fixed_asset' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset including make, model, specifications, and location details. Provides human-readable context for the asset. | Column asset_description (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Physical location or site where the asset is installed or deployed (e.g., transmission tower site, studio facility, data center). Used for asset tracking and maintenance planning. | Column asset_location (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNotes rdf:type rdf:Property ;
    rdfs:label 'Asset Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or special instructions related to the asset. Used for operational context and exception documentation. | Column asset_notes (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The externally-known unique asset number assigned by SAP FI-AA for tracking and identification purposes. This is the business identifier used across financial reporting and asset management processes. | Column asset_number (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset indicating whether it is in active use, under construction, disposed, retired, or impaired. | Column asset_status (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset number used when a main asset is divided into multiple components for separate depreciation tracking (e.g., building structure vs. HVAC system). | Column asset_sub_number (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSuperNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Super Number' ;
    rdfs:comment 'Parent asset number when this asset is part of a larger asset hierarchy (e.g., individual broadcast equipment within a transmission tower complex). | Column asset_super_number (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date on which the asset was placed in service and capitalization began. May differ from acquisition date for assets under construction. | Column capitalization_date (DATE) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP depreciation area code indicating the valuation view (e.g., 01 for book depreciation, 15 for tax depreciation). Supports parallel accounting. | Column depreciation_area (STRING) in finance.fixed_asset' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date on which the asset was disposed, sold, or retired from service. Null for active assets. | Column disposal_date (DATE) in finance.fixed_asset' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'The amount received from the sale or disposal of the asset. Used to calculate gain or loss on disposal. Null for active assets. | Column disposal_proceeds (DECIMAL(18,2)) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gainLossOnDisposal rdf:type rdf:Property ;
    rdfs:label 'Gain Loss On Disposal' ;
    rdfs:comment 'The financial gain or loss recognized upon disposal, calculated as disposal proceeds minus net book value at disposal. Null for active assets. | Column gain_loss_on_disposal (DECIMAL(18,2)) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The current carrying value of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation. Represents the asset\'s current financial value. | Column net_book_value (DECIMAL(18,2)) in finance.fixed_asset' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'The number of years remaining in the asset\'s useful life as of the current reporting period. Used for forward-looking depreciation planning. | Column remaining_useful_life_years (DECIMAL(5,2)) in finance.fixed_asset' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationRunId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Id' ;
    rdfs:comment 'Unique identifier for the depreciation calculation and posting run. Primary key for the depreciation run record. | Column depreciation_run_id (BIGINT) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorLogReference rdf:type rdf:Property ;
    rdfs:label 'Error Log Reference' ;
    rdfs:comment 'Reference identifier or file path to the detailed error log generated during the depreciation run. Used for troubleshooting and resolving posting errors before period-end close. | Column error_log_reference (STRING) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Depreciation Amount' ;
    rdfs:comment 'The total depreciation expense amount calculated by the system for the specified period, company code, and depreciation area based on asset master data and depreciation rules. Represents the expected value reduction before any adjustments or errors. | Column planned_depreciation_amount (DECIMAL(18,2)) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Posted Depreciation Amount' ;
    rdfs:comment 'The actual depreciation expense amount successfully posted to the general ledger for the period. May differ from planned amount due to posting errors, manual adjustments, or period-end corrections. | Column posted_depreciation_amount (DECIMAL(18,2)) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatRunIndicator rdf:type rdf:Property ;
    rdfs:label 'Repeat Run Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this run is a repeat execution for a period that was previously processed. True indicates repeat run to correct prior errors; false indicates initial run for the period. | Column repeat_run_indicator (BOOLEAN) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP financial document number of the reversal posting if this depreciation run was reversed. Null if no reversal has occurred. Links to the reversing document for audit trail. | Column reversal_document_number (STRING) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completed Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation run completed processing (successfully or with errors). Used to calculate run duration and monitor period-end close performance. | Column run_completed_timestamp (TIMESTAMP) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The calendar date on which the depreciation calculation and posting run was executed. Used for audit trail and reconciliation purposes. | Column run_date (DATE) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runInitiatedByUser rdf:type rdf:Property ;
    rdfs:label 'Run Initiated By User' ;
    rdfs:comment 'The SAP user ID of the person or system account that initiated the depreciation run. Provides accountability and audit trail for period-end close activities and SOX compliance. | Column run_initiated_by_user (STRING) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation run was initiated in the SAP FI-AA system. Provides granular audit trail for period-end close activities. | Column run_timestamp (TIMESTAMP) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testRunIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Run Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this was a test run executed to validate depreciation calculations without posting to the general ledger. True indicates test mode; false indicates production posting run. | Column test_run_indicator (BOOLEAN) in finance.depreciation_run' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting record in SAP FI. Primary key for the tax posting entity. | Column tax_posting_id (BIGINT) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number of the payment transaction that cleared this tax liability. Links the tax posting to the actual remittance to the tax authority. | Column payment_reference (STRING) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the tax posting. Posted indicates active posting; Parked indicates pending approval; Cleared indicates settled with tax authority; Reversed indicates cancelled by reversal entry; Cancelled indicates voided before posting. | Column posting_status (STRING) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Ten-digit SAP document number uniquely identifying the tax posting document within the company code and fiscal year. Used for audit trail and tax return reconciliation. | Column tax_document_number (STRING) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Country' ;
    rdfs:comment 'Three-letter ISO 3166 country code identifying the country where the tax return will be filed. May differ from company code country for cross-border transactions. | Column tax_reporting_country (STRING) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The reporting period (quarterly or monthly) to which this tax posting applies for tax return filing. Format: YYYY-Q# for quarterly or YYYY-M## for monthly (e.g., 2024-Q1, 2024-M03). | Column tax_return_period (STRING) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross amount subject to taxation before tax calculation. Represents the revenue, payment, or transaction value on which the tax is computed. | Column taxable_base_amount (DECIMAL(18,2)) in finance.tax_posting' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaSnapshotId rdf:type rdf:Property ;
    rdfs:label 'Ebitda Snapshot Id' ;
    rdfs:comment 'Unique identifier for the EBITDA snapshot record. Primary key for this period-locked financial management reporting record. | Column ebitda_snapshot_id (BIGINT) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertisingRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Advertising Revenue Amount' ;
    rdfs:comment 'Total revenue generated from advertising sales during the reporting period, including linear TV ads, digital ads, and DAI (Dynamic Ad Insertion). | Column advertising_revenue_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEbitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Ebitda Amount' ;
    rdfs:comment 'Budgeted EBITDA amount for this reporting period as approved in the annual planning cycle. | Column budget_ebitda_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Variance between actual EBITDA and budgeted EBITDA, calculated as actual minus budget. | Column budget_variance_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Percentage' ;
    rdfs:comment 'Budget variance expressed as a percentage of budgeted EBITDA. | Column budget_variance_percentage (DECIMAL(5,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'The business segment classification for this EBITDA snapshot, such as Linear Broadcasting, Streaming/OTT, Content Production, or Syndication. | Column business_segment (STRING) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Revenue Amount' ;
    rdfs:comment 'Revenue from carriage fees and retransmission consent agreements with MVPDs (Multichannel Video Programming Distributors) and vMVPDs during the reporting period. | Column carriage_fee_revenue_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentAcquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Content Acquisition Cost Amount' ;
    rdfs:comment 'Direct costs for acquiring or licensing content during the reporting period, including rights payments and royalties. | Column content_acquisition_cost_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covenantComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Compliance Flag' ;
    rdfs:comment 'Indicates whether this EBITDA snapshot is used for debt covenant compliance reporting and monitoring. | Column covenant_compliance_flag (BOOLEAN) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Distribution Cost Amount' ;
