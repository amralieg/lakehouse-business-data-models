    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointDescription rdf:type rdf:Property ;
    rdfs:label 'Endpoint Description' ;
    rdfs:comment 'Detailed description of the endpoint\'s purpose, functionality, and business use case. Explains what the endpoint does and when it should be used. | Column endpoint_description (STRING) in distribution.api_endpoint' ;
