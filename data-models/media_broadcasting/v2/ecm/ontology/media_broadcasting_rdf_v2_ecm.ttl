    rdfs:range xsd:boolean .

ind:communityOfLicense rdf:type rdf:Property ;
    rdfs:label 'Community Of License' ;
    rdfs:comment 'City or community that the broadcast station is licensed to serve. Determines local content and public interest obligations. | Column community_of_license (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Summary of specific regulatory compliance requirements attached to this license (e.g., closed captioning, EAS participation, local content quotas, children\'s programming). | Column compliance_obligations (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAreaContour rdf:type rdf:Property ;
    rdfs:label 'Coverage Area Contour' ;
    rdfs:comment 'Geographic boundary of the licensed coverage area, typically defined by signal strength contours (e.g., 60 dBu for FM, Grade A/B for TV). May be expressed as coordinates or geographic description. | Column coverage_area_contour (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easParticipationRequired rdf:type rdf:Property ;
    rdfs:label 'Eas Participation Required' ;
    rdfs:comment 'Indicates whether this license requires participation in the Emergency Alert System for public safety broadcasts. | Column eas_participation_required (BOOLEAN) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'Spectrum frequency band allocated to this license (e.g., 88.1 MHz for FM, 470-608 MHz for UHF TV). Expressed in MHz or GHz. | Column frequency_band (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Date when the broadcast license was originally granted or issued by the regulatory authority. | Column grant_date (DATE) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction where this license is valid (e.g., USA, GBR, AUS). | Column jurisdiction_country_code (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection or audit of the licensed facility and operations. | Column last_inspection_date (DATE) in compliance.broadcast_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent modification or amendment to the license terms, technical parameters, or ownership. | Column last_modification_date (DATE) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseClass rdf:type rdf:Property ;
    rdfs:label 'License Class' ;
    rdfs:comment 'Regulatory classification of the license indicating power level, coverage area, and operational constraints (e.g., Class A, Class B, Class C for FM; Full-Power, Low-Power for TV). | Column license_class (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Nature of the most recent license modification (e.g., Technical Change, Ownership Transfer, Power Increase, Frequency Change). | Column modification_type (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipAttribution rdf:type rdf:Property ;
    rdfs:label 'Ownership Attribution' ;
    rdfs:comment 'Details of attributable ownership interests in the licensee entity, required for regulatory ownership reporting and concentration limits. | Column ownership_attribution (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOutputErpWatts rdf:type rdf:Property ;
    rdfs:label 'Power Output Erp Watts' ;
    rdfs:comment 'Maximum authorized effective radiated power output for the transmitter, measured in watts. Determines the coverage area and signal strength. | Column power_output_erp_watts (DECIMAL(12,2)) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicInspectionFileLocation rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Location' ;
    rdfs:comment 'Physical or online location where the stations public inspection file is maintained, as required by regulatory authorities. | Column public_inspection_file_location (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'Date when the license renewal application was filed with the regulatory authority. | Column renewal_application_date (DATE) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'Medallion lineage tracking column for bronze->silver->gold tracing | Column source_id (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterAddress rdf:type rdf:Property ;
    rdfs:label 'Transmitter Address' ;
    rdfs:comment 'Physical street address of the licensed transmitter facility. Organizational contact data classified as confidential. | Column transmitter_address (STRING) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmitterLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the licensed transmitter site in decimal degrees. | Column transmitter_location_latitude (DECIMAL(10,7)) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmitterLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Transmitter Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the licensed transmitter site in decimal degrees. | Column transmitter_location_longitude (DECIMAL(10,7)) in compliance.broadcast_license' ;
    rdfs:domain ind:BroadcastLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseRenewalId rdf:type rdf:Property ;
    rdfs:label 'License Renewal Id' ;
    rdfs:comment 'Unique identifier for the broadcast license renewal application record. | Column license_renewal_id (BIGINT) in compliance.license_renewal' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseRenewal .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC license renewals require named responsible employee for filing preparation and regulatory correspondence. Responsible party contact data should reference employee record. | Column responsible_party_employee_id (BIGINT) in workforce.license_renewal' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceCertificationSubmitted rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Submitted' ;
    rdfs:comment 'Indicates whether the required compliance certifications (EEO, children\'s programming, political file, etc.) were submitted as part of the renewal application. | Column compliance_certification_submitted (BOOLEAN) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements imposed by the regulatory authority as part of the renewal grant (e.g., compliance reporting, technical upgrades, programming commitments). | Column conditions_imposed (STRING) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'The date the regulatory authority officially denied the license renewal application. | Column denial_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'The regulatory authority\'s stated reason for denying the license renewal (e.g., failure to meet public interest standard, character qualifications, technical violations). | Column denial_reason (STRING) in compliance.license_renewal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'The date the renewal filing fee was paid to the regulatory authority. | Column fee_payment_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'The current status of the renewal fee payment obligation. | Column fee_payment_status (STRING) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'The regulatory deadline by which the renewal application must be submitted to avoid license lapse (typically 4 months prior to expiration for FCC). | Column filing_deadline (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'The ultimate outcome of the license renewal application process. | Column final_disposition (STRING) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newLicenseTermEndDate rdf:type rdf:Property ;
    rdfs:label 'New License Term End Date' ;
    rdfs:comment 'The expiration date of the renewed license term, establishing the next renewal cycle. | Column new_license_term_end_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newLicenseTermStartDate rdf:type rdf:Property ;
    rdfs:label 'New License Term Start Date' ;
    rdfs:comment 'The effective start date of the renewed license term following approval. | Column new_license_term_start_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:petitionCount rdf:type rdf:Property ;
    rdfs:label 'Petition Count' ;
    rdfs:comment 'The total number of petitions to deny filed against this renewal application. | Column petition_count (INT) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:petitionToDenyFiled rdf:type rdf:Property ;
    rdfs:label 'Petition To Deny Filed' ;
    rdfs:comment 'Indicates whether any party filed a formal petition to deny the license renewal during the public comment period. | Column petition_to_deny_filed (BOOLEAN) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentDeadline rdf:type rdf:Property ;
    rdfs:label 'Public Comment Deadline' ;
    rdfs:comment 'The deadline by which the public may file comments or petitions to deny the renewal application. | Column public_comment_deadline (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicInspectionFileUpdated rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Updated' ;
    rdfs:comment 'Indicates whether the station\'s public inspection file has been updated with the renewal application and related documents as required by regulation. | Column public_inspection_file_updated (BOOLEAN) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'The date the regulatory body published public notice of the renewal application, opening the period for public comment and petitions to deny. | Column public_notice_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle End Date' ;
    rdfs:comment 'The date marking the expiration of the current license term, triggering the renewal requirement. | Column renewal_cycle_end_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Start Date' ;
    rdfs:comment 'The date marking the beginning of the current license term that is subject to renewal. | Column renewal_cycle_start_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The regulatory filing fee amount required for processing the license renewal application. | Column renewal_fee_amount (DECIMAL(15,2)) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the renewal fee (e.g., USD, GBP, CAD). | Column renewal_fee_currency (STRING) in compliance.license_renewal' ;
    rdfs:domain ind:LicenseRenewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'The date the regulatory authority formally commenced substantive review of the renewal application. | Column review_start_date (DATE) in compliance.license_renewal' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Filed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory filings (FCC Form 323, 396, etc.) require audit trail of which employee submitted the filing for compliance verification and accountability. Responsible party data should reference employee | Column filed_by_employee_id (BIGINT) in workforce.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing identifier if this submission is an amendment or correction, establishing the lineage of filing revisions. | Column original_filing_regulatory_filing_id (BIGINT) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is an amendment or correction to a previously submitted filing. | Column amendment_flag (BOOLEAN) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The unique confirmation or receipt number issued by the regulatory body upon successful submission of the filing, serving as proof of receipt. | Column confirmation_number (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'The Uniform Resource Locator (URL) or file path to the digital copy of the filed document stored in the Media Asset Management (MAM) system or document repository. | Column document_url (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'A detailed textual description of the filing content, purpose, and scope, providing context for the regulatory submission. | Column filing_description (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'The monetary fee charged by the regulatory body for processing this filing, expressed in the broadcaster\'s reporting currency. | Column filing_fee_amount (DECIMAL(15,2)) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency' ;
    rdfs:comment 'The three-letter International Organization for Standardization (ISO) 4217 currency code for the filing fee amount (e.g., USD, GBP, EUR). | Column filing_fee_currency (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'The externally-known unique filing number or reference code assigned by the broadcaster or regulatory body for tracking and identification purposes. | Column filing_number (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing indicating its progress through the submission and approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|accepted|rejected|under_review|pending_correction|completed — 7 candidates stripped; promote to reference product] | Column filing_status (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The category or type of regulatory filing being submitted, such as Equal Employment Opportunity (EEO) report, ownership report, political file, children\'s programming report, annual report, license renewal application, or public inspection file entry. [ENUM-REF-CANDIDATE: eeo_report|ownership_report|political_file|childrens_programming_report|annual_report|license_renewal|public_inspection_file — 7 candidates stripped; promote to reference product] | Column filing_type (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formNumber rdf:type rdf:Property ;
    rdfs:label 'Form Number' ;
    rdfs:comment 'The official form number or identifier designated by the regulatory body for this filing type (e.g., FCC Form 323, FCC Form 396, Ofcom Form 1). | Column form_number (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDesignation rdf:type rdf:Property ;
    rdfs:label 'Market Designation' ;
    rdfs:comment 'The designated market area or geographic market served by the broadcast facility, as defined by Nielsen or equivalent measurement authority. | Column market_designation (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'The anticipated due date for the next recurring filing of this type, supporting proactive compliance planning and calendar management. | Column next_filing_due_date (DATE) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Number' ;
    rdfs:comment 'The confirmation or transaction number for the filing fee payment, linking the financial transaction to the regulatory submission. | Column payment_confirmation_number (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Public Inspection Required' ;
    rdfs:comment 'Boolean indicator specifying whether this filing must be made available for public inspection as required by regulatory transparency mandates. | Column public_inspection_required (BOOLEAN) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Boolean indicator specifying whether this filing is subject to Sarbanes-Oxley Act (SOX) financial reporting and internal control requirements. | Column sox_applicable (BOOLEAN) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or mechanism through which the filing was submitted to the regulatory body, such as online portal, email, postal mail, fax, electronic filing system, or Application Programming Interface (API). | Column submission_method (STRING) in compliance.regulatory_filing' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDocumentPublicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Original Document Public Inspection File Id' ;
    rdfs:comment 'If this is an amendment, reference to the original public inspection file document being amended or corrected. | Column original_document_public_inspection_file_id (BIGINT) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:uploadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC public inspection file documents require audit trail of which employee uploaded each document for compliance verification and accountability. Compliance officer name should reference employee reco | Column uploaded_by_employee_id (BIGINT) in workforce.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'The FCC-mandated category of the public inspection file document. Categories include political file (advertising records), EEO reports (equal employment opportunity), ownership reports, issues/programs lists, children\'s programming reports, and contour maps. | Column document_category (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and any relevant context for public inspection. | Column document_description (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Document File Format' ;
    rdfs:comment 'The file format of the stored document (e.g., PDF, DOCX, XLSX). FCC typically requires PDF format for OPIF submissions. | Column document_file_format (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'The storage location or URI of the document file in the media asset management system or document repository. | Column document_file_path (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Document File Size Bytes' ;
    rdfs:comment 'The size of the document file in bytes. | Column document_file_size_bytes (BIGINT) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Document Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this document. | Column document_period_end_date (DATE) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Document Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this document (e.g., for quarterly EEO reports or issues/programs lists). | Column document_period_start_date (DATE) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'The descriptive title or name of the public inspection file document. | Column document_title (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Status' ;
    rdfs:comment 'Synchronization status with the FCC\'s Online Public Inspection File portal. Indicates whether the document has been successfully transmitted to and accepted by the FCC system. | Column fcc_opif_sync_status (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccOpifSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fcc Opif Sync Timestamp' ;
    rdfs:comment 'The date and time of the last successful synchronization with the FCC OPIF portal. | Column fcc_opif_sync_timestamp (TIMESTAMP) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fccReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fcc Reference Number' ;
    rdfs:comment 'The unique reference or confirmation number assigned by the FCC OPIF system upon successful document submission. | Column fcc_reference_number (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this document is an amendment or correction to a previously filed public inspection file document. | Column is_amendment (BOOLEAN) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalAdvertiserName rdf:type rdf:Property ;
    rdfs:label 'Political Advertiser Name' ;
    rdfs:comment 'For political file documents, the name of the candidate, campaign, or political organization that purchased advertising time. Required for political file category documents. | Column political_advertiser_name (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalOfficeSought rdf:type rdf:Property ;
    rdfs:label 'Political Office Sought' ;
    rdfs:comment 'For political file documents, the elected office being sought by the candidate (e.g., President, Senator, Governor, Mayor). | Column political_office_sought (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Public Access Status' ;
    rdfs:comment 'Indicates whether the document is currently available for public inspection. Documents may be restricted during review or removed after retention period expiration. | Column public_access_status (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'The date when the regulatory retention period expires and the document may be removed from the public inspection file. | Column retention_expiration_date (DATE) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uploadStatus rdf:type rdf:Property ;
    rdfs:label 'Upload Status' ;
    rdfs:comment 'Current status of the document upload to the FCC OPIF (Online Public Inspection File) portal. Tracks the lifecycle from pending submission through verification and archival. | Column upload_status (STRING) in compliance.public_inspection_file' ;
    rdfs:domain ind:PublicInspectionFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityRatingNotes rdf:type rdf:Property ;
    rdfs:label 'Accessibility Rating Notes' ;
    rdfs:comment 'Notes regarding accessibility features relevant to the rating, such as closed captioning compliance, audio description availability, or photosensitive epilepsy warnings. | Column accessibility_rating_notes (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptors rdf:type rdf:Property ;
    rdfs:label 'Content Descriptors' ;
    rdfs:comment 'Comma-separated list of content advisory descriptors that explain the reasons for the rating. Examples: violence, strong language, sexual content, drug use, nudity, adult themes, frightening scenes. | Column content_descriptors (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugUseDescriptor rdf:type rdf:Property ;
    rdfs:label 'Drug Use Descriptor' ;
    rdfs:comment 'Indicates whether the content contains drug use or substance abuse that contributed to the rating. | Column drug_use_descriptor (BOOLEAN) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageDescriptor rdf:type rdf:Property ;
    rdfs:label 'Language Descriptor' ;
    rdfs:comment 'Indicates whether the content contains strong or offensive language that contributed to the rating. | Column language_descriptor (BOOLEAN) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalGuidanceRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Required' ;
    rdfs:comment 'Indicates whether parental guidance is recommended or required for viewers under a certain age. | Column parental_guidance_required (BOOLEAN) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousRatingValue rdf:type rdf:Property ;
    rdfs:label 'Previous Rating Value' ;
    rdfs:comment 'The rating value that was assigned before the current rating, if the content was re-rated. Null for initial ratings. | Column previous_rating_value (DECIMAL(18,2)) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Certificate Number' ;
    rdfs:comment 'The official certificate or registration number issued by the rating authority for this content rating. | Column rating_certificate_number (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'The date on which the rating was officially assigned to the content by the rating authority. | Column rating_date (DATE) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiration Date' ;
    rdfs:comment 'The date on which the rating expires or requires renewal, if applicable. Null for ratings with no expiration. | Column rating_expiration_date (DATE) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Amount' ;
    rdfs:comment 'The fee charged by the rating authority for evaluating and assigning the rating to the content. | Column rating_fee_amount (DECIMAL(15,2)) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rating Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rating fee. Examples: USD, GBP, EUR, AUD, JPY. | Column rating_fee_currency (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNotes rdf:type rdf:Property ;
    rdfs:label 'Rating Notes' ;
    rdfs:comment 'Additional notes or comments regarding the rating, including any special conditions, context, or clarifications provided by the rating authority or compliance team. | Column rating_notes (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReason rdf:type rdf:Property ;
    rdfs:label 'Rating Reason' ;
    rdfs:comment 'Detailed explanation provided by the rating authority describing the specific content elements that led to the assigned rating. | Column rating_reason (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rating Review Date' ;
    rdfs:comment 'The date on which the rating was last reviewed or re-evaluated by the rating authority. | Column rating_review_date (DATE) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating authority for evaluation. | Column rating_submission_date (DATE) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingSystem rdf:type rdf:Property ;
    rdfs:label 'Rating System' ;
    rdfs:comment 'The rating authority or system that issued this rating. Examples: MPA (Motion Picture Association), TV Parental Guidelines, BBFC (British Board of Film Classification), FSK (Germany), ACB (Australia), EIRIN (Japan), KFCB (Kenya). [ENUM-REF-CANDIDATE: MPA|TV_PARENTAL_GUIDELINES|BBFC|FSK|ACB|EIRIN|KFCB — 7 candidates stripped; promote to reference product] | Column rating_system (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'The distribution context for which this rating was assigned. Different ratings may apply to theatrical release, television broadcast, home video, or streaming platforms. | Column rating_type (STRING) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingValue rdf:type rdf:Property ;
    rdfs:label 'Rating Value' ;
    rdfs:comment 'The specific rating classification assigned to the content. Examples: G, PG, PG-13, R, NC-17 (MPA); TV-Y, TV-Y7, TV-G, TV-PG, TV-14, TV-MA (TV Parental Guidelines); U, PG, 12A, 15, 18 (BBFC). [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA|U|12A|15|18|FSK0|FSK6|FSK12|FSK16|FSK18 — promote to reference product] | Column rating_value (DECIMAL(18,2)) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingVersion rdf:type rdf:Property ;
    rdfs:label 'Rating Version' ;
    rdfs:comment 'Version number of this rating record. Increments when the rating is re-evaluated or updated due to content changes or appeals. | Column rating_version (INT) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sexualContentDescriptor rdf:type rdf:Property ;
    rdfs:label 'Sexual Content Descriptor' ;
    rdfs:comment 'Indicates whether the content contains sexual content or nudity that contributed to the rating. | Column sexual_content_descriptor (BOOLEAN) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violenceDescriptor rdf:type rdf:Property ;
    rdfs:label 'Violence Descriptor' ;
    rdfs:comment 'Indicates whether the content contains violence that contributed to the rating. | Column violence_descriptor (BOOLEAN) in compliance.content_rating' ;
    rdfs:domain ind:ContentRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Declared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: COPPA declarations require named responsible party employee for legal accountability to FTC. Reviewer name should reference employee record rather than store as text. | Column declared_by_employee_id (BIGINT) in workforce.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualKnowledgeFlag rdf:type rdf:Property ;
    rdfs:label 'Actual Knowledge Flag' ;
    rdfs:comment 'Indicates whether the operator has actual knowledge that it is collecting personal information from children under 13, triggering COPPA compliance obligations regardless of directed-to-children status. | Column actual_knowledge_flag (BOOLEAN) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingAssessment rdf:type rdf:Property ;
    rdfs:label 'Advertising Assessment' ;
    rdfs:comment 'Assessment of whether advertising or promotional materials are directed to children, including ad placement, messaging, and products advertised. | Column advertising_assessment (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioContentAssessment rdf:type rdf:Property ;
    rdfs:label 'Audio Content Assessment' ;
    rdfs:comment 'Assessment of audio elements (music, voice talent, sound effects) that may appeal to children, per FTC child-directed determination factors. | Column audio_content_assessment (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childCelebrityPresenceFlag rdf:type rdf:Property ;
    rdfs:label 'Child Celebrity Presence Flag' ;
    rdfs:comment 'Indicates whether the content features child celebrities or characters that appeal to children, a factor in FTC child-directed determination. | Column child_celebrity_presence_flag (BOOLEAN) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which verifiable parental consent was obtained, if applicable. Must be maintained for audit purposes. | Column consent_date (DATE) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCollectionScope rdf:type rdf:Property ;
    rdfs:label 'Data Collection Scope' ;
    rdfs:comment 'Description of personal information collected from users, including identifiers, location data, photos, videos, audio recordings, and persistent identifiers for behavioral advertising. | Column data_collection_scope (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'Date on which the COPPA declaration was formally made or submitted for review. | Column declaration_date (DATE) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Business identifier for the COPPA declaration, formatted as COPPA-YYYY-XXXXXXXX for external reference and audit tracking. | Column declaration_number (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the COPPA declaration: draft (being prepared), active (in effect), under_review (legal/compliance review), approved (validated), rejected (non-compliant), expired (needs renewal), withdrawn (no longer applicable). [ENUM-REF-CANDIDATE: draft|active|under_review|approved|rejected|expired|withdrawn — 7 candidates stripped; promote to reference product] | Column declaration_status (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Type of digital asset being declared: content (video/audio program), service (subscription offering), platform (streaming service), website, mobile app, or interactive feature (games, social features). | Column declaration_type (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directedToChildrenStatus rdf:type rdf:Property ;
    rdfs:label 'Directed To Children Status' ;
    rdfs:comment 'Determination of whether the content or service is directed to children under 13: directed (primary audience is children), mixed_audience (general audience including children), not_directed (not intended for children), under_review (assessment in progress). | Column directed_to_children_status (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcFilingReference rdf:type rdf:Property ;
    rdfs:label 'Ftc Filing Reference' ;
    rdfs:comment 'Reference number or identifier for any filings, notifications, or correspondence with the FTC regarding this COPPA declaration or compliance matter. | Column ftc_filing_reference (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalOpinionReference rdf:type rdf:Property ;
    rdfs:label 'Legal Opinion Reference' ;
    rdfs:comment 'Reference to any legal opinion, memo, or external counsel advice supporting the COPPA determination. | Column legal_opinion_reference (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalConsentMechanism rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Mechanism' ;
    rdfs:comment 'Method used to obtain verifiable parental consent: email_plus (email plus additional verification), credit_card, toll_free (phone verification), video_conference, government_id, digital_certificate, not_required (content not directed to children), under_review. [ENUM-REF-CANDIDATE: email_plus|credit_card|toll_free|video_conference|government_id|digital_certificate|not_required|under_review — 8 candidates stripped; promote to reference product] | Column parental_consent_mechanism (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:persistentIdentifierCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Persistent Identifier Collection Flag' ;
    rdfs:comment 'Indicates whether persistent identifiers (cookies, device IDs, IP addresses) are collected for purposes other than internal operations, requiring parental consent under COPPA. | Column persistent_identifier_collection_flag (BOOLEAN) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL of the privacy policy that discloses data collection practices, parental rights, and COPPA compliance measures. Must be prominently displayed per COPPA requirements. | Column privacy_policy_url (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewer Title' ;
    rdfs:comment 'Job title or role of the reviewer (e.g., Chief Privacy Officer, Legal Counsel, Compliance Manager). | Column reviewer_title (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeHarborCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Safe Harbor Certification Number' ;
    rdfs:comment 'Certification number or identifier issued by the safe harbor program, if applicable. | Column safe_harbor_certification_number (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safeHarborProgram rdf:type rdf:Property ;
    rdfs:label 'Safe Harbor Program' ;
    rdfs:comment 'Name of the FTC-approved safe harbor program the operator participates in, if any (e.g., CARU, TRUSTe, iKeepSafe). Provides streamlined compliance pathway. | Column safe_harbor_program (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectMatterDescription rdf:type rdf:Property ;
    rdfs:label 'Subject Matter Description' ;
    rdfs:comment 'Description of the content\'s subject matter, themes, and topics used to assess child-directed nature per FTC (Federal Trade Commission) guidelines. | Column subject_matter_description (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRangeMax rdf:type rdf:Property ;
    rdfs:label 'Target Age Range Max' ;
    rdfs:comment 'Maximum age of the intended audience for the content or service. Used to assess mixed-audience scenarios. | Column target_age_range_max (INT) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAgeRangeMin rdf:type rdf:Property ;
    rdfs:label 'Target Age Range Min' ;
    rdfs:comment 'Minimum age of the intended audience for the content or service. Critical for determining COPPA applicability (under 13 threshold). | Column target_age_range_min (INT) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiableConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Verifiable Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether verifiable parental consent has been obtained for data collection from children under 13, as required by COPPA. | Column verifiable_consent_obtained_flag (BOOLEAN) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visualContentAssessment rdf:type rdf:Property ;
    rdfs:label 'Visual Content Assessment' ;
    rdfs:comment 'Assessment of visual content elements (characters, animation style, color schemes) that may appeal to children, per FTC child-directed determination factors. | Column visual_content_assessment (STRING) in compliance.coppa_declaration' ;
    rdfs:domain ind:CoppaDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByConsentRecordComplianceConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Consent Record Compliance Consent Record Id' ;
    rdfs:comment 'Reference to the consent record ID that supersedes this record. Used to maintain consent history and audit trail when consent is updated or renewed. Null if this is the current active record. | Column superseded_by_consent_record_compliance_consent_record_id (BIGINT) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceConsentRecord .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional audit notes, compliance annotations, or special circumstances related to this consent record. Used for regulatory audit preparation and internal compliance reviews. | Column audit_notes (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceSubscriberConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Compliance Subscriber Consent Record Id' ;
    rdfs:comment 'FK to subscriber consent record for audit linkage | Column subscriber_consent_record_id (BIGINT) in subscriber.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceSubscriberSubscriberConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Compliance Subscriber Subscriber Consent Record Id' ;
    rdfs:comment 'FK reference to canonical source' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Platform or channel through which the consent was collected. Distinguishes between web, mobile app, smart TV, email, phone, in-person, or API-driven consent capture. [ENUM-REF-CANDIDATE: web|mobile_app|smart_tv|email|phone|in_person|api — 7 candidates stripped; promote to reference product] | Column consent_channel (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the consent notice was presented to the subject (e.g., en for English, es for Spanish, fr for French). | Column consent_language (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMechanism rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism' ;
    rdfs:comment 'Method or interface through which consent was captured. Examples include Consent Management Platform (CMP) banner, registration form, opt-in email, in-app toggle, customer service call, or written form. | Column consent_mechanism (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Url' ;
    rdfs:comment 'URL or storage path to the archived proof of consent (e.g., screenshot, form submission, audit log entry). Used as evidence in regulatory audits. | Column consent_proof_url (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of the specific data processing activities or purposes covered by this consent. May include specific data categories, processing purposes, or third-party sharing arrangements. | Column consent_scope (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Consent Source System' ;
    rdfs:comment 'Name of the source system or application that captured the consent event. Examples include Adobe Experience Platform, Salesforce, Zuora, or custom Consent Management Platform (CMP). | Column consent_source_system (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Consent Transaction Code' ;
    rdfs:comment 'Unique transaction or session identifier from the source system that captured the consent. Used for cross-system audit trail and reconciliation. | Column consent_transaction_code (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieConsentCategories rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Categories' ;
    rdfs:comment 'Comma-separated list of cookie categories for which consent was granted (e.g., strictly_necessary, functional, analytics, advertising, social_media). Aligns with IAB Transparency and Consent Framework categories. | Column cookie_consent_categories (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEmailConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing communications via email. | Column marketing_email_consent (BOOLEAN) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPushConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Push Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing push notifications on mobile or web applications. | Column marketing_push_consent (BOOLEAN) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingSmsConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Sms Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to receive marketing communications via SMS or text message. | Column marketing_sms_consent (BOOLEAN) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent has been verified for subjects under the age of consent (required under Children\'s Online Privacy Protection Act (COPPA) and similar regulations). | Column parental_consent_verified (BOOLEAN) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Parental Verification Method' ;
    rdfs:comment 'Method used to verify parental consent for minors. Examples include credit card verification, government ID check, video conference, or signed consent form. Null if parental consent is not applicable. | Column parental_verification_method (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary privacy regulation or framework under which this consent was collected. Includes General Data Protection Regulation (GDPR), California Consumer Privacy Act (CCPA), Children\'s Online Privacy Protection Act (COPPA), California Privacy Rights Act (CPRA), Lei Geral de Proteção de Dados (LGPD), Personal Information Protection and Electronic Documents Act (PIPEDA), or other applicable laws. [ENUM-REF-CANDIDATE: GDPR|CCPA|COPPA|CPRA|LGPD|PIPEDA|other — 7 candidates stripped; promote to reference product] | Column regulatory_framework (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the data subject providing consent. Distinguishes between authenticated subscribers, registered users, anonymous viewers, guests, or device-level consent. | Column subject_type (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcfConsentString rdf:type rdf:Property ;
    rdfs:label 'Tcf Consent String' ;
    rdfs:comment 'IAB Transparency and Consent Framework encoded consent string capturing granular vendor and purpose consents. Used for programmatic advertising consent management. | Column tcf_consent_string (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingConsent rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the subject has consented to sharing their data with third parties (e.g., advertising partners, analytics providers, content partners). | Column third_party_sharing_consent (BOOLEAN) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalMechanism rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Mechanism' ;
    rdfs:comment 'Method or interface through which consent was withdrawn. Examples include preference center, unsubscribe link, customer service request, or in-app toggle. Null if consent has not been withdrawn. | Column withdrawal_mechanism (STRING) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when consent was withdrawn by the subject. Null if consent has not been withdrawn. Critical for demonstrating compliance with right to withdraw consent. | Column withdrawal_timestamp (TIMESTAMP) in compliance.compliance_consent_record' ;
    rdfs:domain ind:ComplianceConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Handler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GDPR/CCPA privacy requests (access, deletion, portability) must be assigned to specific employees for fulfillment tracking and regulatory deadline compliance. Assigned handler text should be FK. | Column assigned_handler_employee_id (BIGINT) in workforce.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dataCategoriesInvolved rdf:type rdf:Property ;
    rdfs:label 'Data Categories Involved' ;
    rdfs:comment 'Comma-separated list of data categories involved in the request (e.g., subscriber profile, viewing history, payment data, device identifiers). Used for scope tracking and audit. | Column data_categories_involved (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeProcessed rdf:type rdf:Property ;
    rdfs:label 'Data Volume Processed' ;
    rdfs:comment 'Total volume of data processed for this request in megabytes, used for operational metrics and resource planning. | Column data_volume_processed (DECIMAL(15,2)) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline' ;
    rdfs:comment 'New deadline date if an extension was granted. GDPR allows up to 3 months total; CCPA allows up to 90 days total. | Column extended_deadline (DATE) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGranted rdf:type rdf:Property ;
    rdfs:label 'Extension Granted' ;
    rdfs:comment 'Indicates whether a deadline extension was granted due to request complexity or volume. GDPR allows 2-month extension; CCPA allows 45-day extension. | Column extension_granted (BOOLEAN) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification for granting a deadline extension, such as request complexity, high volume of requests, or technical challenges. | Column extension_reason (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Processing Time Hours' ;
    rdfs:comment 'Total staff hours spent processing this request, used for cost tracking and efficiency analysis. | Column processing_time_hours (DECIMAL(10,2)) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'Calculated deadline for responding to the request based on regulatory requirements: 30 calendar days for GDPR, 45 calendar days for CCPA, from submission date. | Column regulatory_deadline (DATE) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of data subject rights request: access (right to know), erasure (right to delete), portability (data export), rectification (correction), restriction (processing limitation), or opt_out_sale (CCPA opt-out). | Column request_type (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Requestor Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the data subject\'s jurisdiction, used to determine applicable privacy law (e.g., DEU for Germany/GDPR, USA for US/CCPA). | Column requestor_jurisdiction (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the data subject for identity verification and request follow-up. | Column requestor_phone (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject: email (encrypted), secure_portal (download link), mail (postal), phone (verbal), or in_person. | Column response_method (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the privacy request was submitted: web_form (online portal), email, phone (call center), mail (postal), mobile_app, or chat (live support). | Column submission_channel (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsAccessed rdf:type rdf:Property ;
    rdfs:label 'Systems Accessed' ;
    rdfs:comment 'Comma-separated list of internal systems queried to fulfill the request (e.g., Zuora, Adobe Experience Platform, Akamai CDN logs). Used for audit trail and completeness verification. | Column systems_accessed (STRING) in compliance.privacy_request' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionVendorPartnerId rdf:type rdf:Property ;
    rdfs:label 'Caption Vendor Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Captioning vendor performance and FCC compliance is tracked by partner. Captioning accuracy failures, latency violations, and format errors may trigger vendor SLA breaches, disputes, or vendor substit | Column caption_vendor_partner_id (BIGINT) in partner.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:narratorTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Narrator Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Closed caption records may reference talent for audio description, voice identification, or accessibility compliance when talent narrates or appears in content. Accessibility teams identify talent voi | Column narrator_talent_profile_id (BIGINT) in talent.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:captionAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Caption Accuracy Score' ;
    rdfs:comment 'Percentage score representing the accuracy of the captions compared to the spoken audio, measured as a percentage from 0.00 to 100.00. | Column caption_accuracy_score (DECIMAL(5,2)) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionCompletenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Caption Completeness Percentage' ;
    rdfs:comment 'Percentage of the program duration that was captioned, measured from 0.00 to 100.00. | Column caption_completeness_percentage (DECIMAL(5,2)) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Caption File Format' ;
    rdfs:comment 'The technical format of the closed caption file used for this broadcast. [ENUM-REF-CANDIDATE: SRT|SCC|TTML|WebVTT|CEA-608|CEA-708|DFXP|STL — 8 candidates stripped; promote to reference product] | Column caption_file_format (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionLatencySeconds rdf:type rdf:Property ;
    rdfs:label 'Caption Latency Seconds' ;
    rdfs:comment 'The average delay in seconds between spoken audio and caption display, critical for live programming compliance. | Column caption_latency_seconds (DECIMAL(6,2)) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captionPlacementCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Placement Compliance' ;
    rdfs:comment 'Indicates whether caption placement on screen met regulatory standards for visibility and non-obstruction of critical content. | Column caption_placement_compliance (BOOLEAN) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionQualityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Caption Quality Review Date' ;
    rdfs:comment 'Date when the caption quality was formally reviewed for compliance assessment. | Column caption_quality_review_date (DATE) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captionSynchronizationCompliance rdf:type rdf:Property ;
    rdfs:label 'Caption Synchronization Compliance' ;
    rdfs:comment 'Indicates whether captions were properly synchronized with the audio and video content per regulatory requirements. | Column caption_synchronization_compliance (BOOLEAN) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionType rdf:type rdf:Property ;
    rdfs:label 'Caption Type' ;
    rdfs:comment 'Indicates whether the captions were generated live during broadcast or pre-recorded offline. | Column caption_type (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captionedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Captioned Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that was actually captioned within the program. | Column captioned_duration_minutes (INT) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Date' ;
    rdfs:comment 'Date when a viewer complaint regarding captioning was received by the broadcaster. | Column complaint_received_date (DATE) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Reference Number' ;
    rdfs:comment 'Reference number of any viewer complaint filed regarding caption quality or availability for this broadcast. | Column complaint_reference_number (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Category of the captioning complaint filed by viewers or regulatory bodies. | Column complaint_type (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exemption Category' ;
    rdfs:comment 'Category of exemption from captioning requirements as defined by regulatory frameworks. [ENUM-REF-CANDIDATE: primarily_textual|late_night|promotional|public_service_announcement|locally_produced|economic_burden|interstitial_material|secondary_audio — promote to reference product] | Column exemption_category (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Program Duration Minutes' ;
    rdfs:comment 'Total duration of the program in minutes for which captioning compliance is being tracked. | Column program_duration_minutes (INT) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicInspectionFileIncluded rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Included' ;
    rdfs:comment 'Indicates whether this caption record has been included in the broadcasters public inspection file as required by FCC regulations. | Column public_inspection_file_included (BOOLEAN) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the caption compliance record was filed with the regulatory authority. | Column regulatory_filing_date (DATE) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this caption record requires formal filing with regulatory authorities such as FCC or Ofcom. | Column regulatory_filing_required (BOOLEAN) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date when remediation actions to correct captioning issues were completed. | Column remediation_completed_date (DATE) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Detailed description of the remediation actions taken to address captioning compliance issues. | Column remediation_description (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:ClosedCaptionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts to address captioning deficiencies or complaints. | Column remediation_status (STRING) in compliance.closed_caption_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC accessibility obligations (CVAA, closed captioning, video description) require named employee owner for compliance tracking and regulatory correspondence. Contact email should reference employee r | Column responsible_contact_employee_id (BIGINT) in workforce.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary regulatory framework governing this obligation: CVAA (Twenty-First Century Communications and Video Accessibility Act), ADA (Americans with Disabilities Act), Ofcom Access Code, EU Audiovisual Media Services Directive, WCAG 2.1 (Web Content Accessibility Guidelines), or ATSC A/53 (Advanced Television Systems Committee standard for closed captioning). | Column applicable_regulation (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which the organization must achieve full compliance with this accessibility obligation. | Column compliance_deadline (DATE) in compliance.accessibility_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Percentage of content or platform features currently meeting this accessibility obligation (0.00 to 100.00), used for tracking progress toward full compliance. | Column compliance_percentage (DECIMAL(5,2)) in compliance.accessibility_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Content Type Applicability' ;
    rdfs:comment 'Types of content to which this obligation applies (e.g., all programming, news and emergency information, pre-recorded entertainment, live events, user-generated content exclusions). | Column content_type_applicability (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'Estimated total cost in USD to achieve full compliance with this obligation, including technology implementation, content remediation, training, and ongoing operational costs. | Column estimated_compliance_cost (DECIMAL(15,2)) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Explanation of why this obligation does not apply to the organization or why a waiver was granted (e.g., content category exemption, undue burden waiver, technical infeasibility). | Column exemption_reason (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Geographic Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where this obligation is enforceable (e.g., USA for FCC/CVAA, GBR for Ofcom, DEU for German regulations). | Column geographic_jurisdiction (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next internal review or audit of compliance with this accessibility obligation. | Column next_compliance_review_date (DATE) in compliance.accessibility_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of regulatory penalties, fines, or sanctions that may be imposed for failure to meet this obligation (e.g., FCC forfeiture up to $100,000 per violation, Ofcom statutory sanctions, license suspension risk). | Column penalty_for_non_compliance (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section, article, or clause of the regulation that mandates this obligation (e.g., 47 CFR 79.1, WCAG 2.1 Success Criterion 1.2.2). | Column regulation_section (STRING) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Compliance Percentage' ;
    rdfs:comment 'Required percentage of content or platform features that must meet this accessibility obligation to achieve regulatory compliance (typically 100.00, but may be lower for phased implementation schedules). | Column target_compliance_percentage (DECIMAL(5,2)) in compliance.accessibility_obligation' ;
    rdfs:domain ind:AccessibilityObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC EAS logs must record which licensed operator was on duty during alert transmission for regulatory compliance verification. Operator on duty text should be FK. | Column operator_employee_id (BIGINT) in workforce.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Alert Duration Seconds' ;
    rdfs:comment 'Duration of the EAS alert transmission in seconds, from start to end of the alert message. | Column alert_duration_seconds (INT) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertText rdf:type rdf:Property ;
    rdfs:label 'Alert Text' ;
    rdfs:comment 'Full text content of the EAS alert message that was transmitted or received, including any instructions to the public. | Column alert_text (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Timestamp' ;
    rdfs:comment 'Date and time when the EAS alert was activated or received by the station. This is the principal business event timestamp for the alert. | Column alert_timestamp (TIMESTAMP) in compliance.eas_log' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the EAS alert by geographic scope: national emergency, state emergency, local emergency, or test alert. | Column alert_type (STRING) in compliance.eas_log' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionSignalTransmitted rdf:type rdf:Property ;
    rdfs:label 'Attention Signal Transmitted' ;
    rdfs:comment 'Indicates whether the two-tone attention signal was transmitted as part of the EAS alert. | Column attention_signal_transmitted (BOOLEAN) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'Audio Message Transmitted' ;
    rdfs:comment 'Indicates whether the audio message portion of the EAS alert was transmitted. | Column audio_message_transmitted (BOOLEAN) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capMessageReceived rdf:type rdf:Property ;
    rdfs:label 'Cap Message Received' ;
    rdfs:comment 'Indicates whether the alert was received in Common Alerting Protocol (CAP) format via IPAWS or other digital alert system. | Column cap_message_received (BOOLEAN) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfMessageTransmitted rdf:type rdf:Property ;
    rdfs:label 'End Of Message Transmitted' ;
    rdfs:comment 'Indicates whether the End of Message (EOM) code was transmitted to signal completion of the EAS alert. | Column end_of_message_transmitted (BOOLEAN) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description or model identifier of the EAS equipment (encoder/decoder) used to process and transmit the alert. | Column equipment_used (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipawsMessageCode rdf:type rdf:Property ;
    rdfs:label 'Ipaws Message Code' ;
    rdfs:comment 'Unique message identifier from FEMA IPAWS system for alerts originated through the national alert infrastructure. | Column ipaws_message_code (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorCode rdf:type rdf:Property ;
    rdfs:label 'Originator Code' ;
    rdfs:comment 'Three-letter code identifying the entity that originated the alert (e.g., PEP for Primary Entry Point, CIV for Civil Authority, WXR for National Weather Service, EAS for EAS Participant). | Column originator_code (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Full name of the authority or organization that originated the EAS alert (e.g., FEMA IPAWS, National Weather Service, State Emergency Management Agency). | Column originator_name (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicInspectionFileEntry rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Entry' ;
    rdfs:comment 'Indicates whether this EAS log entry has been included in the stations public inspection file as required by FCC regulations. | Column public_inspection_file_entry (BOOLEAN) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relayChainPosition rdf:type rdf:Property ;
    rdfs:label 'Relay Chain Position' ;
    rdfs:comment 'Position of this station in the EAS relay chain, indicating how many hops the alert has traveled from the originator (1 for direct receipt, 2+ for relayed). | Column relay_chain_position (INT) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testComplianceType rdf:type rdf:Property ;
    rdfs:label 'Test Compliance Type' ;
    rdfs:comment 'Type of EAS test compliance this log entry satisfies: Required Weekly Test (RWT), Required Monthly Test (RMT), National Periodic Test, or none if not a test. | Column test_compliance_type (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Test Scheduled Date' ;
    rdfs:comment 'Date when the EAS test was scheduled to occur, used for tracking compliance with required weekly and monthly test schedules. | Column test_scheduled_date (DATE) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:upstreamSourceCallsign rdf:type rdf:Property ;
    rdfs:label 'Upstream Source Callsign' ;
    rdfs:comment 'Call sign of the upstream station or source from which this station received the EAS alert for relay. | Column upstream_source_callsign (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTimePeriod rdf:type rdf:Property ;
    rdfs:label 'Valid Time Period' ;
    rdfs:comment 'Four-digit code indicating the valid time period for the alert in 15-minute increments (e.g., 0030 for 30 minutes, 0100 for 1 hour). | Column valid_time_period (STRING) in compliance.eas_log' ;
    rdfs:domain ind:EasLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FCC political advertising records require compliance officer review for equal time and reasonable access rules. Tracking reviewer employee is essential for audit trail and accountability. | Column compliance_officer_employee_id (BIGINT) in workforce.political_ad_record' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advertiserType rdf:type rdf:Property ;
    rdfs:label 'Advertiser Type' ;
    rdfs:comment 'Classification of the political advertiser entity type for regulatory reporting and rate determination purposes. | Column advertiser_type (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affidavitIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Issued Flag' ;
    rdfs:comment 'Indicates whether a broadcast affidavit (proof of performance) has been issued to the advertiser confirming that this political ad aired as scheduled. | Column affidavit_issued_flag (BOOLEAN) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equalOpportunitiesRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Equal Opportunities Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was triggered by an equal opportunities request under Section 315 of the Communications Act, requiring equal treatment of opposing candidates. | Column equal_opportunities_request_flag (BOOLEAN) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Governmental jurisdiction level of the race or ballot measure (federal, state, or local) for compliance categorization and public file organization. | Column jurisdiction_level (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lucPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Luc Period Flag' ;
    rdfs:comment 'Indicates whether this ad aired during the Lowest Unit Charge (LUC) period (45 days before primary or 60 days before general election) when special rate protections apply to candidate ads. | Column luc_period_flag (BOOLEAN) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lucRate rdf:type rdf:Property ;
    rdfs:label 'Luc Rate' ;
    rdfs:comment 'The lowest unit charge rate applicable to this spot based on the rate class and daypart during the pre-election window (45 days before primary, 60 days before general election). Null if outside LUC period. | Column luc_rate (DECIMAL(15,2)) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeSought rdf:type rdf:Property ;
    rdfs:label 'Office Sought' ;
    rdfs:comment 'The elected office or ballot measure that the political advertisement relates to (e.g., President, U.S. Senate, Governor, State Representative, Proposition 22). | Column office_sought (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicFileDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public File Disclosure Date' ;
    rdfs:comment 'Date when this political ad record was uploaded to the stations online public inspection file as required by FCC rules. Must occur immediately upon ad placement. | Column public_file_disclosure_date (DATE) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCharged rdf:type rdf:Property ;
    rdfs:label 'Rate Charged' ;
    rdfs:comment 'Actual dollar amount charged to the political advertiser for this spot placement. Must comply with Lowest Unit Charge (LUC) requirements during pre-election windows. | Column rate_charged (DECIMAL(15,2)) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonableAccessRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonable Access Request Flag' ;
    rdfs:comment 'Indicates whether this ad placement was the result of a federal candidate reasonable access request under Section 312(a)(7) of the Communications Act, requiring broadcasters to provide reasonable access to federal candidates. | Column reasonable_access_request_flag (BOOLEAN) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorAddress rdf:type rdf:Property ;
    rdfs:label 'Sponsor Address' ;
    rdfs:comment 'Mailing address of the political advertiser or sponsor. Required for public inspection file disclosure. | Column sponsor_address (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Email' ;
    rdfs:comment 'Email address of the political advertiser or sponsor contact for correspondence and compliance communication. | Column sponsor_email (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Phone' ;
    rdfs:comment 'Contact telephone number for the political advertiser or sponsor. Required for public file records. | Column sponsor_phone (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipIdentification rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Identification' ;
    rdfs:comment 'The on-air sponsorship disclosure statement identifying who paid for the advertisement (e.g., \'Paid for by Committee to Elect Jane Smith\'). Required by FCC sponsorship identification rules. | Column sponsorship_identification (STRING) in compliance.political_ad_record' ;
    rdfs:domain ind:PoliticalAdRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlId rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Id' ;
    rdfs:comment 'Reference to another SOX control that serves as a compensating control if this control fails or is temporarily inactive. Compensating controls provide alternative assurance over the same financial reporting risk. | Column compensating_control_id (BIGINT) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControl .

ind:controlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Control Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SOX controls require named employee owners for accountability in financial reporting compliance. Control owner text should reference employee record for audit trail and performance tracking. | Column control_owner_employee_id (BIGINT) in workforce.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assertionCategory rdf:type rdf:Property ;
    rdfs:label 'Assertion Category' ;
    rdfs:comment 'The financial statement assertion that this control addresses. Existence ensures recorded transactions occurred; completeness ensures all transactions are recorded; accuracy ensures amounts are correct; valuation ensures proper measurement; rights and obligations ensure the entity has legal claim; presentation and disclosure ensure proper classification and disclosure; cutoff ensures transactions are recorded in the correct period. [ENUM-REF-CANDIDATE: existence|completeness|accuracy|valuation|rights and obligations|presentation and disclosure|cutoff — 7 candidates stripped; promote to reference product] | Column assertion_category (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Comprehensive description of the control activity, including specific procedures, data sources, systems involved, thresholds, and documentation requirements. For media companies, may reference systems such as Wide Orbit (traffic and billing), Rightsline (rights management), or Zuora (subscription billing). | Column control_description (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDocumentationPath rdf:type rdf:Property ;
    rdfs:label 'Control Documentation Path' ;
    rdfs:comment 'File path or document management system reference to the detailed control documentation, including procedures, flowcharts, and testing workpapers. Used for audit evidence and compliance verification. | Column control_documentation_path (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or operates. Continuous controls run automatically in real-time (e.g., system validations); periodic controls are executed at defined intervals; event-driven controls are triggered by specific business events (e.g., contract execution, content release). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annual|event-driven — 7 candidates stripped; promote to reference product] | Column control_frequency (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Short descriptive name of the control that summarizes its purpose (e.g., \'Advertising Revenue Recognition Review\', \'Subscriber Billing Reconciliation\'). | Column control_name (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business identifier for the control, typically formatted as a prefix code followed by a numeric sequence (e.g., FIN-001, REV-1234). Used for external reference and audit documentation. | Column control_number (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'Detailed statement of what the control is designed to achieve, including the specific financial reporting assertion it addresses (existence, completeness, accuracy, valuation, rights and obligations, presentation and disclosure). | Column control_objective (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current operational status of the control. Active controls are in effect; inactive controls are temporarily suspended; under remediation indicates deficiencies are being addressed; pending implementation means the control is designed but not yet operational; retired controls are no longer applicable. | Column control_status (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its nature and timing. Preventive controls stop errors before they occur; detective controls identify errors after occurrence; IT general controls (ITGC) govern system access and change management; IT application controls are embedded in financial systems; entity-level controls address governance and culture; management review controls involve oversight and analysis. | Column control_type (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of any identified control deficiency. No deficiency means the control is effective; control deficiency is a minor issue unlikely to result in misstatement; significant deficiency is important enough to merit attention by those charged with governance; material weakness is a deficiency or combination of deficiencies that creates a reasonable possibility of material misstatement not being prevented or detected. | Column deficiency_classification (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed explanation of any identified control deficiency, including the nature of the failure, root cause analysis, and potential impact on financial reporting. Null if no deficiency exists. | Column deficiency_description (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific financial statement account or line item that this control impacts (e.g., \'Advertising Revenue\', \'Subscription Revenue\', \'Content Amortization Expense\', \'Accounts Receivable\', \'Deferred Revenue\'). Maps control to financial reporting impact. | Column financial_statement_line_item (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this is a key control (True) that directly addresses a significant risk to financial reporting, or a supporting control (False). Key controls receive more rigorous testing and documentation. | Column key_control_flag (BOOLEAN) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'The most recent date on which the control was formally tested for design and operating effectiveness by internal audit, external auditors, or control owners. | Column last_test_date (DATE) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementAssertionMapping rdf:type rdf:Property ;
    rdfs:label 'Management Assertion Mapping' ;
    rdfs:comment 'Mapping of this control to management\'s assertions under SOX Section 302 (CEO/CFO certification) and Section 404 (internal control over financial reporting). Documents how this control supports management\'s ability to assert the effectiveness of internal controls. | Column management_assertion_mapping (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The business process or financial cycle to which this control applies. Media-specific areas include advertising revenue recognition (CPM, GRP-based billing), carriage fee billing (MVPD/vMVPD distribution payments), subscriber billing (SVOD, TVOD), content licensing revenue (syndication, windowing), rights royalty accruals (talent residuals, music licensing), and barter transactions (ad inventory exchanges). [ENUM-REF-CANDIDATE: advertising revenue recognition|carriage fee billing|subscriber billing|content licensing revenue|rights royalty accruals|barter transactions|production cost capitalization|content amortization|deferred revenue|accounts receivable|accounts payable|payroll|treasury|tax compliance|financial close|general ledger|fixed assets|inventory|intercompany transactions — 19 candidates stripped; promote to reference product] | Column process_area (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target date by which remediation activities are expected to be completed and validated. Null if no remediation is required. | Column remediation_target_date (DATE) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Name of the primary financial or operational system in which the control is executed or from which control evidence is derived (e.g., \'SAP S/4HANA FI\', \'Wide Orbit Traffic\', \'Zuora Billing\', \'Rightsline Rights Management\'). | Column system_name (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'How often the control is formally tested for effectiveness. Quarterly testing is typical for key controls; annual testing may suffice for lower-risk controls; event-driven testing occurs when significant changes are made to the control or underlying process. | Column test_frequency (STRING) in compliance.sox_control' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the most recent control test. Effective means the control operated as designed with no exceptions; ineffective with exception indicates isolated failures that do not rise to a deficiency; ineffective means the control did not operate as designed; not tested means no evaluation has been performed. | Column test_result (STRING) in compliance.sox_control' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Reference to the parent audit engagement or audit project during which this finding was identified. | Column audit_id (BIGINT) in compliance.audit_finding' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the prior audit finding record if this is a recurrence, enabling tracking of repeat issues and corrective action effectiveness. | Column previous_finding_audit_finding_id (BIGINT) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:remediationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Audit findings require assigned employee for remediation tracking and accountability. Remediation owner text should reference employee record for workload management and performance evaluation. | Column remediation_owner_employee_id (BIGINT) in workforce.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'The business process, operational area, or functional domain impacted by this finding (e.g., Content Acquisition and Licensing, Program Scheduling and Playout, Advertising Sales and Campaign Management, Rights and Royalties Management, Subscriber and Membership Management). | Column affected_process (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'The operational system, application, or platform where the non-compliance or control deficiency was identified (e.g., Dalet Galaxy, Wide Orbit, SAP S/4HANA, Salesforce Media Cloud, Nielsen Media Research Platform, Ericsson MediaFirst, Adobe Experience Platform, Rightsline, Akamai CDN, Zuora). | Column affected_system (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or audit firm responsible for identifying and documenting this finding. | Column auditor_name (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor: internal (company internal audit team), external (third-party audit firm), regulatory (government agency inspector or regulator). | Column auditor_type (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including the specific condition observed, the standard or requirement violated, and the evidence supporting the finding. | Column finding_description (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding: open (newly identified, not yet addressed), in_remediation (corrective action underway), pending_verification (remediation complete, awaiting validation), closed (verified and resolved), deferred (accepted risk or postponed remediation). | Column finding_status (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date on which the audit finding was first identified or documented during the audit engagement. | Column identified_date (DATE) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response or action plan provided by management in reply to the audit finding, including agreement or disagreement with the finding, proposed corrective actions, and committed timelines. | Column management_response (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Potential Penalty Amount' ;
    rdfs:comment 'Estimated or assessed monetary penalty, fine, or forfeiture amount that could be imposed by the regulatory authority if the finding is not remediated or if enforcement action is taken. | Column potential_penalty_amount (DECIMAL(15,2)) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedRemediation rdf:type rdf:Property ;
    rdfs:label 'Recommended Remediation' ;
    rdfs:comment 'The corrective action or remediation plan recommended by the auditor to address the finding and prevent recurrence. | Column recommended_remediation (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Recurrence Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this finding is a repeat or recurrence of a previously identified and closed finding, suggesting ineffective corrective action or systemic control weakness. | Column recurrence_indicator (BOOLEAN) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory rule, statute, standard, or policy section that was violated or not met (e.g., 47 CFR 73.3526 for FCC public file requirements, GDPR Article 32 for security measures, SOX Section 404 for internal controls). | Column regulatory_citation (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'The regulatory or compliance domain to which this finding pertains. [ENUM-REF-CANDIDATE: FCC Broadcast Licensing|Ofcom Broadcasting Standards|MPA Content Ratings|COPPA Childrens Content|GDPR Data Privacy|CCPA Consumer Privacy|SOX Financial Reporting|PCI DSS Payment Security|ATSC Technical Standards|DVB Technical Standards|Accessibility Mandates|Content Clearance|Closed Captioning|Consent Management — promote to reference product] | Column regulatory_domain (STRING) in compliance.audit_finding' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationRegulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Regulatory Obligation Id' ;
    rdfs:comment 'Reference to the regulatory obligation that supersedes this one, if applicable. Null if not superseded. | Column superseded_by_obligation_regulatory_obligation_id (BIGINT) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Business units, platforms, or services to which this obligation applies (e.g., linear TV, OTT platforms, radio, digital publishers, SVOD services, AVOD platforms, FAST channels). | Column applicability_scope (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationStatus rdf:type rdf:Property ;
    rdfs:label 'Automation Status' ;
    rdfs:comment 'Degree to which compliance monitoring and reporting for this obligation is automated: manual, partially automated, fully automated, or not applicable. | Column automation_status (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'How often compliance with this obligation must be demonstrated or reported: ongoing (continuous), annual, quarterly, monthly, event-driven (triggered by specific events), or biennial. | Column compliance_frequency (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether formal documentation, records, or evidence must be maintained to demonstrate compliance with this obligation. | Column documentation_required (BOOLEAN) in compliance.regulatory_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Number of years that compliance documentation must be retained, as mandated by the regulation or internal policy. | Column documentation_retention_years (INT) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReportingRequired rdf:type rdf:Property ;
    rdfs:label 'External Reporting Required' ;
    rdfs:comment 'Indicates whether compliance with this obligation requires formal reporting or filing to an external regulatory body. | Column external_reporting_required (BOOLEAN) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDeadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Description' ;
    rdfs:comment 'Human-readable description of the filing deadline (e.g., \'April 1 annually\', \'10 days after broadcast\', \'within 30 days of license expiration\'). | Column filing_deadline_description (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineType rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Type' ;
    rdfs:comment 'Type of deadline for compliance filing or reporting: fixed date (specific calendar date), rolling (X days from event), event-based (triggered by business event), or not applicable. | Column filing_deadline_type (STRING) in compliance.regulatory_obligation' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine amount that can be imposed for non-compliance, in the currency specified. | Column maximum_penalty_amount (DECIMAL(18,2)) in compliance.regulatory_obligation' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
