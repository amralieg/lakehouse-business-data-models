ind:overallSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Overall Satisfaction Score' ;
    rdfs:comment 'Overall satisfaction score (1-5 or 1-10)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionRating rdf:type rdf:Property ;
    rdfs:label 'Resolution Rating' ;
    rdfs:comment 'Rating of issue resolution (1-5)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondedAt rdf:type rdf:Property ;
    rdfs:label 'Responded At' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimeRating rdf:type rdf:Property ;
    rdfs:label 'Response Time Rating' ;
    rdfs:comment 'Rating of response time (1-5)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentAt rdf:type rdf:Property ;
    rdfs:label 'Sent At' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'When survey was sent' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentCategory rdf:type rdf:Property ;
    rdfs:label 'Sentiment Category' ;
    rdfs:comment 'Sentiment category (negative, neutral, positive)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Sentiment analysis score (-1 to 1)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'Channel (email, sms, in_app, ivr)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Status (sent, opened, completed, expired)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Type (post_contact, periodic, nps, ces)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'Open-ended feedback text' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wouldRecommendFlag rdf:type rdf:Property ;
    rdfs:label 'Would Recommend Flag' ;
    rdfs:comment 'Whether customer would recommend service' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodologyId rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology Id' ;
    rdfs:comment 'Foreign key linking to audience.measurement_methodology. Business justification: Each Nielsen rating uses a specific measurement methodology (PPM, diary, set-top box). The measurement_type string should be replaced with FK to measurement_methodology for MRC accreditation tracking  | Column measurement_methodology_id (BIGINT) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementMethodology .

ind:measurementSourceRefId rdf:type rdf:Property ;
    rdfs:label 'Measurement Source Ref Id' ;
    rdfs:comment 'Medallion lineage tracking column for bronze->silver->gold tracing | Column source_id (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementSourceRef .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Foreign key linking to compliance.sox_control. Business justification: Nielsen ratings data used in revenue recognition controls for SOX compliance (advertising revenue). Ratings support revenue assertions; links measurement data to financial reporting controls. | Column sox_control_id (BIGINT) in compliance.nielsen_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControl .

ind:sweepsPeriodId rdf:type rdf:Property ;
    rdfs:label 'Sweeps Period Id' ;
    rdfs:comment 'Foreign key linking to audience.sweeps_period. Business justification: Nielsen ratings during sweeps periods (Feb, May, July, Nov) are the currency for annual upfront negotiations and local ad sales. The sweeps_period_flag indicates relevance, but the specific sweeps per | Column sweeps_period_id (BIGINT) in audience.nielsen_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SweepsPeriod .

ind:airEndTime rdf:type rdf:Property ;
    rdfs:label 'Air End Time' ;
    rdfs:comment 'The precise date and time at which the program finished airing. Combined with air_start_time to derive program duration for audience measurement calculations. | Column air_end_time (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airStartTime rdf:type rdf:Property ;
    rdfs:label 'Air Start Time' ;
    rdfs:comment 'The precise date and time (including timezone offset) at which the program began airing. Used for exact scheduling alignment and daypart classification. | Column air_start_time (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audienceCompositionPct rdf:type rdf:Property ;
    rdfs:label 'Audience Composition Pct' ;
    rdfs:comment 'The percentage of the program\'s total audience represented by the primary target demographic (typically A18-49). Indicates how well the program indexes against its target audience and is used in ad sales proposals and programming strategy. | Column audience_composition_pct (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAudience rdf:type rdf:Property ;
    rdfs:label 'Average Audience' ;
    rdfs:comment 'The average number of persons or households tuned to the program during an average minute of the telecast. Expressed in thousands (000s). AA is the primary audience volume metric used in GRP and CPM calculations for ad sales. | Column average_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumeAudience rdf:type rdf:Property ;
    rdfs:label 'Cume Audience' ;
    rdfs:comment 'The unduplicated number of different persons or households that tuned to the program for at least one minute across all airings within a defined period. Expressed in thousands (000s). Cume measures total reach and is critical for frequency management in ad campaign planning. | Column cume_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A18 49 Rating' ;
    rdfs:comment 'The percentage of Adults aged 18-49 in the measured universe who were tuned to this program. A18-49 is the most commercially valuable and widely traded demographic in US television advertising, serving as the primary currency for primetime ad sales. | Column demo_a18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA2554Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A25 54 Rating' ;
    rdfs:comment 'The percentage of Adults aged 25-54 in the measured universe who were tuned to this program. A25-54 is a key secondary demographic used in news programming, cable networks, and certain advertiser categories. | Column demo_a25_54_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoK211Rating rdf:type rdf:Property ;
    rdfs:label 'Demo K2 11 Rating' ;
    rdfs:comment 'The percentage of Children aged 2-11 in the measured universe who were tuned to this program. K2-11 is the primary demographic for children\'s programming and toy/food advertisers. Subject to COPPA compliance requirements for data handling. | Column demo_k2_11_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoM1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo M18 49 Rating' ;
    rdfs:comment 'The percentage of Men aged 18-49 in the measured universe who were tuned to this program. M18-49 is a primary demographic for sports, automotive, and technology advertisers. | Column demo_m18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoW1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo W18 49 Rating' ;
    rdfs:comment 'The percentage of Women aged 18-49 in the measured universe who were tuned to this program. W18-49 is a primary demographic for lifestyle, beauty, and household product advertisers. | Column demo_w18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The average number of times a unique person or household was exposed to the program within the measurement period. Frequency = GRP / Reach. Used with reach for ad campaign effectiveness analysis and makegoods calculations. | Column frequency (DECIMAL(7,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'The sum of all ratings delivered by an advertising schedule or program, representing total audience delivery without deduplication. GRP = Reach × Frequency. A fundamental currency metric in ad sales negotiations, upfront deals, and scatter market transactions. | Column grp (DECIMAL(10,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdRating rdf:type rdf:Property ;
    rdfs:label 'Household Rating' ;
    rdfs:comment 'The percentage of all television households in the measured universe that were tuned to this program during the measurement period. Expressed as a decimal percentage (e.g., 5.2 = 5.2%). The foundational Nielsen rating metric used for ad pricing and programming evaluation. | Column household_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdShare rdf:type rdf:Property ;
    rdfs:label 'Household Share' ;
    rdfs:comment 'The percentage of households using television (HUT) that were tuned to this program. Share = (Program Audience / HUT) × 100. Measures competitive performance relative to active TV viewers at the same time. | Column household_share (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The timestamp at which this Nielsen rating record was ingested into the Databricks Lakehouse Silver layer from the Nielsen Media Research Platform. Used for data freshness monitoring, SLA tracking, and audit trail. | Column ingested_timestamp (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenReportDate rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Date' ;
    rdfs:comment 'The date on which Nielsen Media Research officially published or delivered this rating record to the broadcaster. Distinguishes the measurement air date from the data delivery date, which is critical for tracking preliminary vs. final rating release cycles. | Column nielsen_report_date (DATE) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nielsenReportWeek rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Week' ;
    rdfs:comment 'The ISO 8601 week identifier (e.g., 2024-W23) of the Nielsen measurement week in which this rating was reported. Nielsen measurement weeks run Monday through Sunday. Used for weekly ratings aggregation and trend analysis. | Column nielsen_report_week (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putLevel rdf:type rdf:Property ;
    rdfs:label 'Put Level' ;
    rdfs:comment 'The percentage of all persons in the measured universe who were watching television during the measurement period. PUT is the denominator for persons share calculations and complements HUT for demographic audience analysis. | Column put_level (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Lifecycle status of this Nielsen rating record indicating whether the data is preliminary (fast nationals), final, or has been revised. Ad sales and programming decisions must distinguish preliminary from final ratings. Preliminary ratings are typically released within 24 hours; final ratings follow within days. | Column rating_status (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'The unduplicated number of unique persons or households exposed to the program at least once within the measurement period. Expressed in thousands (000s). Reach is a core metric for ad campaign planning and audience delivery reporting. | Column reach (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier assigned by the Nielsen Media Research Platform for this rating record. Preserved in the Silver layer for data lineage, reconciliation, and re-ingestion traceability back to the authoritative source system. | Column source_system_record_code (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSpentViewingMin rdf:type rdf:Property ;
    rdfs:label 'Time Spent Viewing Min' ;
    rdfs:comment 'The average number of minutes that viewers in the measured audience spent watching the program. A key engagement metric used in programming decisions and content performance analysis. Expressed in minutes. | Column time_spent_viewing_min (DECIMAL(10,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAudience rdf:type rdf:Property ;
    rdfs:label 'Total Audience' ;
    rdfs:comment 'The total number of persons or households that tuned to the program for at least six consecutive minutes. Expressed in thousands (000s). TA provides a broader reach measure than AA and is used for program promotion and scheduling decisions. | Column total_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trp rdf:type rdf:Property ;
    rdfs:label 'Trp' ;
    rdfs:comment 'Rating points delivered specifically to a defined target demographic audience (e.g., Adults 18-49). TRP = (Target Audience Impressions / Target Universe) × 100. Used by advertisers to evaluate efficiency of reaching their specific target demographic. | Column trp (DECIMAL(10,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimateHh rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Hh' ;
    rdfs:comment 'The total estimated number of television households in the measured market or national universe used as the denominator for household rating calculations. Expressed in thousands (000s). Nielsen updates universe estimates annually based on census data. | Column universe_estimate_hh (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimatePersons rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Persons' ;
    rdfs:comment 'The total estimated number of persons in the measured market or national universe used as the denominator for persons rating calculations. Expressed in thousands (000s). Segmented by demographic group for TRP calculations. | Column universe_estimate_persons (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adobeSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Segment Code' ;
    rdfs:comment 'The corresponding segment identifier in Adobe Experience Platform (AEP) for digital audience activation. Enables cross-system reconciliation between Nielsen linear audience measurement and AEP digital audience profiles for cross-platform campaign targeting and DAI (Dynamic Ad Insertion) on OTT/streaming platforms. | Column adobe_segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Upper bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 49 for the A18-49 cell. A null value indicates an open-ended upper bound (e.g., Adults 55+). Null for non-age-based segments. | Column age_range_max (INT) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Lower bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 18 for the A18-49 cell. Null for non-age-based segments such as psychographic or income quintile segments. | Column age_range_min (INT) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpmIndex rdf:type rdf:Property ;
    rdfs:label 'Cpm Index' ;
    rdfs:comment 'Relative CPM (Cost Per Mille) pricing index for this demographic segment compared to the baseline segment (index = 100). Premium segments such as A18-49 or W25-54 carry higher indices reflecting advertiser demand. Used in Salesforce Media Cloud ad sales proposals and upfront/scatter market pricing negotiations. Confidential commercial pricing data. | Column cpm_index (DECIMAL(10,4)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartRelevance rdf:type rdf:Property ;
    rdfs:label 'Daypart Relevance' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts (e.g., \'Prime Time, Late Fringe, Daytime\') for which this demographic segment has primary relevance in programming and ad sales strategy. Informs Ericsson MediaFirst scheduling decisions and Wide Orbit daypart-based ad pod targeting. Null if the segment applies across all dayparts. | Column daypart_relevance (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityClassification rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Classification' ;
    rdfs:comment 'Standardized ethnicity classification label for ethnicity-based demographic segments (e.g., \'Hispanic/Latino\', \'African American\', \'Asian American\', \'Non-Hispanic White\'). Populated only for ethnicity segment types. Aligned with Nielsen multicultural audience measurement standards and used in targeted content programming and ad sales. [ENUM-REF-CANDIDATE: hispanic_latino|african_american|asian_american|non_hispanic_white|native_american|multiracial|other — promote to reference product] | Column ethnicity_classification (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSpecialCategory rdf:type rdf:Property ;
    rdfs:label 'Gdpr Special Category' ;
    rdfs:comment 'Indicates whether this demographic segment is based on GDPR Article 9 special category data (e.g., ethnicity, health status). When true, enhanced consent and data processing controls are required for EU audience data associated with this segment. Relevant for pan-European distribution platforms and Ofcom-regulated services. | Column gdpr_special_category (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderQualifier rdf:type rdf:Property ;
    rdfs:label 'Gender Qualifier' ;
    rdfs:comment 'Gender dimension of the demographic cell. \'All\' denotes combined-gender segments (e.g., Adults 18-49, Persons 2+). Aligns with Nielsen standard gender breakdowns used in GRP/TRP calculations and ad sales targeting. | Column gender_qualifier (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Grp Weight Factor' ;
    rdfs:comment 'Weighting factor applied to this demographic segment when calculating Gross Rating Points (GRP) and Target Rating Points (TRP) in audience measurement reports. Reflects the relative population size and measurement panel representation of the segment. Sourced from the Nielsen Media Research Platform and used in Wide Orbit ad scheduling and campaign delivery calculations. | Column grp_weight_factor (DECIMAL(10,6)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdComposition rdf:type rdf:Property ;
    rdfs:label 'Household Composition' ;
    rdfs:comment 'Classification of household structure for household-based demographic segments. Used in HUT (Homes Using Television) and PUT (Persons Using Television) audience measurement reporting and in family-oriented programming and advertising targeting strategies. | Column household_composition (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabAudienceCode rdf:type rdf:Property ;
    rdfs:label 'Iab Audience Code' ;
    rdfs:comment 'The IAB Audience Taxonomy 2.0 standardized code corresponding to this demographic segment. Enables cross-platform audience targeting alignment between linear broadcast, OTT/AVOD/SVOD digital campaigns, and programmatic advertising systems. Used in Salesforce Media Cloud ad proposals and Adobe Experience Platform segment mapping. | Column iab_audience_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeQuintile rdf:type rdf:Property ;
    rdfs:label 'Income Quintile' ;
    rdfs:comment 'Household income quintile ranking (1=lowest 20%, 5=highest 20%) for income-based demographic segments. Populated only for income quintile segment types. Used in premium CPM pricing tiers and upfront ad sales targeting for high-value audience packages. | Column income_quintile (INT) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChildrenSegment rdf:type rdf:Property ;
    rdfs:label 'Is Children Segment' ;
    rdfs:comment 'Indicates whether this demographic segment includes individuals under 13 years of age (e.g., K2-11, K2-5). Triggers COPPA compliance controls on data collection, ad targeting restrictions, and content rating enforcement. Critical for regulatory compliance in digital and broadcast advertising. | Column is_children_segment (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyDemo rdf:type rdf:Property ;
    rdfs:label 'Is Key Demo' ;
    rdfs:comment 'Flags whether this segment is designated as a key demographic (key demo) for the organization\'s primary ad sales and programming strategy. Key demos (typically A18-49, W25-54) command premium CPM rates and are the primary currency in upfront and scatter market negotiations. | Column is_key_demo (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNielsenStandardCell rdf:type rdf:Property ;
    rdfs:label 'Is Nielsen Standard Cell' ;
    rdfs:comment 'Indicates whether this demographic segment corresponds to an official Nielsen standard demographic cell (e.g., A18-49, W25-54). True for Nielsen-defined cells used in GRP/TRP/HUT/PUT ratings calculations; False for custom or proprietary segments defined internally or via Adobe Experience Platform. | Column is_nielsen_standard_cell (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The audience measurement methodology used to quantify this demographic segment. Panel-based measurement uses Nielsen People Meter panels; census-based uses set-top box or streaming data; hybrid combines both; modeled uses statistical projection. Determines data quality, confidence intervals, and applicability for regulatory reporting. | Column measurement_methodology (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenCellLabel rdf:type rdf:Property ;
    rdfs:label 'Nielsen Cell Label' ;
    rdfs:comment 'The exact Nielsen Media Research standard cell label for this demographic segment (e.g., \'A18-49\', \'W25-54\', \'M18-34\', \'K2-11\', \'P2+\'). Used as the authoritative cross-reference when ingesting Nielsen ratings data and reconciling audience measurement reports from the Nielsen Media Research Platform. | Column nielsen_cell_label (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Segment Code' ;
    rdfs:comment 'The native segment identifier assigned by the Nielsen Media Research Platform for this demographic cell. Used for direct API integration with Nielsen ratings data feeds, ensuring accurate mapping of audience measurement data to internal segment definitions. | Column nielsen_segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformApplicability rdf:type rdf:Property ;
    rdfs:label 'Platform Applicability' ;
    rdfs:comment 'Indicates the distribution platforms for which this demographic segment definition is applicable. Linear segments apply to traditional broadcast/cable measurement; digital applies to OTT/streaming (SVOD, AVOD, FAST); cross-platform spans both; all applies universally. Drives segment availability in Wide Orbit (linear) vs. Adobe Experience Platform (digital) targeting. | Column platform_applicability (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychographicProfile rdf:type rdf:Property ;
    rdfs:label 'Psychographic Profile' ;
    rdfs:comment 'Descriptive label for psychographic segment classification (e.g., \'Early Adopters\', \'Value Seekers\', \'Sports Enthusiasts\', \'News Junkies\'). Populated only for psychographic segment types. Derived from Adobe Experience Platform audience profiling and used in premium ad sales targeting and programming strategy. | Column psychographic_profile (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachPotentialPct rdf:type rdf:Property ;
    rdfs:label 'Reach Potential Pct' ;
    rdfs:comment 'Estimated maximum reach potential expressed as a percentage of the segment universe achievable across the organization\'s full distribution footprint. Used in media planning to set realistic reach targets for ad campaigns and programming strategies. Sourced from Nielsen reach and frequency models. | Column reach_potential_pct (DECIMAL(5,2)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Flag' ;
    rdfs:comment 'Indicates whether this demographic segment is subject to regulatory restrictions on data collection, targeting, or advertising. True for segments including minors (COPPA), sensitive demographic categories under GDPR Article 9, or segments subject to FCC advertising restrictions. Triggers compliance workflow in Adobe Experience Platform and Wide Orbit. | Column regulatory_restriction_flag (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the demographic segment, aligned with Nielsen and IAB standard cell codes (e.g., A18-49, W25-54, M18-34, K2-11, P2+). Used as the business-facing identifier in ad sales proposals, ratings reports, and audience targeting systems. | Column segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Full narrative description of the demographic segment\'s defining characteristics, measurement criteria, and intended use cases. Provides context for business users in ad sales, programming, and analytics teams on how to correctly apply and interpret the segment in audience measurement and targeting workflows. | Column segment_description (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable label for the demographic segment (e.g., \'Adults 18-49\', \'Women 25-54\', \'Men 18-34\', \'Kids 2-11\'). Used in reporting dashboards, ad sales presentations, and EPG audience targeting configurations. | Column segment_name (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the demographic segment definition. Active segments are available for audience targeting, ad sales proposals, and ratings reporting. Deprecated segments are retained for historical continuity but no longer used in new campaigns or programming decisions. | Column segment_status (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by its primary defining dimension. Distinguishes age/gender cells (Nielsen standard cells such as A18-49) from psychographic profiles, income quintiles, ethnicity classifications, behavioral clusters, and household composition segments. Drives which measurement methodology and data source applies. | Column segment_type (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPriority rdf:type rdf:Property ;
    rdfs:label 'Sweeps Priority' ;
    rdfs:comment 'Indicates whether this demographic segment is a priority measurement target during Nielsen sweeps periods (February, May, July, November). Priority segments receive enhanced panel measurement and are the primary basis for affiliate compensation and ad rate card negotiations during sweeps. | Column sweeps_priority (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimate rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate' ;
    rdfs:comment 'Total estimated population count (universe) for this demographic segment in the measurement geography, as defined by Nielsen. Used as the denominator in ratings calculations (rating = audience / universe × 100). Updated periodically from Nielsen universe estimates and used in GRP, TRP, reach, and frequency reporting. | Column universe_estimate (BIGINT) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEstimateYear rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Year' ;
    rdfs:comment 'The calendar year for which the universe estimate is valid. Nielsen updates universe estimates annually; this field identifies the vintage of the estimate to ensure correct ratings calculations and year-over-year audience trend analysis. | Column universe_estimate_year (INT) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_calendar. Business justification: Sweeps periods drive compliance calendar deadlines for ratings-based regulatory filings. FCC public file updates and license renewal exhibits tied to sweeps completion dates. | Column calendar_id (BIGINT) in compliance.sweeps_period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:audienceSampleSize rdf:type rdf:Property ;
    rdfs:label 'Audience Sample Size' ;
    rdfs:comment 'Total number of Nielsen panel respondents (diary participants or PPM device carriers) included in the measurement sample for this sweeps period. Larger sample sizes yield higher statistical confidence in ratings estimates. | Column audience_sample_size (INT) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable' ;
    rdfs:comment 'Indicates whether CCPA viewer data privacy requirements apply to the measurement data collected during this sweeps period (e.g., for California DMA markets in scope). Governs opt-out rights and data sale restrictions for audience panel data. | Column ccpa_applicable (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Data Release Status' ;
    rdfs:comment 'Indicates the current release state of Nielsen audience data for this sweeps period. \'unreleased\' = data not yet available; \'preliminary\' = fast affiliate estimates published; \'final\' = confirmed ratings delivered; \'revised_final\' = post-delivery corrections applied. | Column data_release_status (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartCoverage rdf:type rdf:Property ;
    rdfs:label 'Daypart Coverage' ;
    rdfs:comment 'Indicates which dayparts (time segments of the broadcast day) are included in the sweeps measurement scope. \'all_dayparts\' covers the full broadcast day; other values indicate restricted measurement windows. Daypart coverage affects which ad inventory can be rated and guaranteed. | Column daypart_coverage (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicBreakdowns rdf:type rdf:Property ;
    rdfs:label 'Demographic Breakdowns' ;
    rdfs:comment 'Comma-separated list of demographic segments for which Nielsen will provide audience measurement data during this sweeps period (e.g., \'A18-49,A25-54,W18-34,M18-49,HH\'). Determines which target audience guarantees can be supported for ad sales. | Column demographic_breakdowns (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diaryReturnRatePct rdf:type rdf:Property ;
    rdfs:label 'Diary Return Rate Pct' ;
    rdfs:comment 'For diary-methodology sweeps periods, the percentage of distributed Nielsen viewing diaries that were returned by respondents. A key data quality indicator; low return rates may trigger Nielsen data quality warnings or adjustments. | Column diary_return_rate_pct (DECIMAL(5,2)) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaListVersion rdf:type rdf:Property ;
    rdfs:label 'Dma List Version' ;
    rdfs:comment 'Version identifier of the Nielsen DMA market list applied during this sweeps period (e.g., \'DMA-2024-v1\'). Nielsen periodically revises DMA boundaries; this field ensures correct market mapping for historical comparisons. | Column dma_list_version (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpGuaranteeApplicable rdf:type rdf:Property ;
    rdfs:label 'Grp Guarantee Applicable' ;
    rdfs:comment 'Indicates whether Gross Rating Point (GRP) audience guarantees negotiated during the upfront or scatter market apply to advertising campaigns running within this sweeps period. True = GRP guarantees in effect; False = no guarantees applicable. | Column grp_guarantee_applicable (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hutMeasurementIncluded rdf:type rdf:Property ;
    rdfs:label 'Hut Measurement Included' ;
    rdfs:comment 'Indicates whether Homes Using Television (HUT) level data is captured and reported as part of this sweeps period measurement. HUT data is used to calculate share and contextualize ratings within total available audience. | Column hut_measurement_included (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialProgrammingFlag rdf:type rdf:Property ;
    rdfs:label 'Is Special Programming Flag' ;
    rdfs:comment 'Indicates whether special programming (e.g., season premieres, finales, major sporting events, stunting) was scheduled during this sweeps period that may inflate or distort ratings relative to non-sweeps periods. True = special programming present; False = standard schedule. | Column is_special_programming_flag (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Makegood Window End Date' ;
    rdfs:comment 'The last date by which makegoods (compensatory ad spots issued when audience guarantees are not met) must be aired following this sweeps period. Defined in advertiser contracts and governed by Wide Orbit traffic system scheduling. | Column makegood_window_end_date (DATE) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCount rdf:type rdf:Property ;
    rdfs:label 'Market Count' ;
    rdfs:comment 'Total number of Designated Market Areas (DMAs) included in this sweeps measurement period. Used to assess geographic coverage and local affiliate reporting obligations. | Column market_count (INT) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketScope rdf:type rdf:Property ;
    rdfs:label 'Market Scope' ;
    rdfs:comment 'Indicates whether this sweeps period covers national audience measurement, local market (DMA) measurement, or both. Determines which ad sales rate cards and audience guarantees apply. | Column market_scope (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenContractRef rdf:type rdf:Property ;
    rdfs:label 'Nielsen Contract Ref' ;
    rdfs:comment 'Reference number of the Nielsen Media Research contract or service agreement under which this sweeps period measurement is conducted. Used for billing reconciliation and SLA enforcement with Nielsen. | Column nielsen_contract_ref (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenSweepCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Sweep Code' ;
    rdfs:comment 'The externally-assigned Nielsen Media Research Platform identifier for this sweeps period (e.g., \'SWEEP-2024-NOV\'). Used to cross-reference records with Nielsen source data and reconcile audience measurement deliverables. | Column nielsen_sweep_code (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle state of the sweeps period record. \'scheduled\' = future period confirmed by Nielsen; \'active\' = measurement currently in progress; \'completed\' = measurement concluded and data delivered; \'cancelled\' = period cancelled (rare); \'revised\' = dates or scope amended post-publication. | Column period_status (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Ppm Compliance Rate Pct' ;
    rdfs:comment 'For PPM-methodology sweeps periods, the percentage of PPM panel members who met Nielsen\'s minimum daily wear-time compliance threshold. Low compliance rates may affect the statistical validity of ratings data. | Column ppm_compliance_rate_pct (DECIMAL(5,2)) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preliminaryRatingsDate rdf:type rdf:Property ;
    rdfs:label 'Preliminary Ratings Date' ;
    rdfs:comment 'The date on which Nielsen delivers preliminary (fast affiliate) ratings estimates for this sweeps period. Preliminary data is used for early ad sales negotiations before final ratings are confirmed. | Column preliminary_ratings_date (DATE) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:putMeasurementIncluded rdf:type rdf:Property ;
    rdfs:label 'Put Measurement Included' ;
    rdfs:comment 'Indicates whether Persons Using Television (PUT) level data is captured and reported as part of this sweeps period measurement. PUT data enables person-level demographic audience analysis beyond household-level HUT data. | Column put_measurement_included (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingsDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Ratings Delivery Date' ;
    rdfs:comment 'The date on which Nielsen is contractually obligated to deliver final audience ratings data for this sweeps period to the broadcaster. Drives downstream ad sales billing, makegoods calculations, and audience guarantee reconciliation. | Column ratings_delivery_date (DATE) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The timestamp at which this sweeps period record was first created in the Media Broadcasting Databricks Silver layer data product. Supports audit trail and data lineage tracking. | Column record_created_timestamp (TIMESTAMP) in audience.sweeps_period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp at which this sweeps period record was most recently modified in the Media Broadcasting Databricks Silver layer data product. Used for change tracking, SLA monitoring, and downstream refresh orchestration. | Column record_updated_timestamp (TIMESTAMP) in audience.sweeps_period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether audience measurement data from this sweeps period must be submitted to a regulatory body (e.g., FCC, Ofcom) as part of broadcast licensing compliance or public interest reporting obligations. | Column regulatory_reporting_required (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source Last Updated Timestamp' ;
    rdfs:comment 'The timestamp at which the source system (Nielsen Media Research Platform) last updated the record for this sweeps period. Used for incremental data ingestion and change detection in the Databricks Silver layer pipeline. | Column source_last_updated_timestamp (TIMESTAMP) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stuntingDescription rdf:type rdf:Property ;
    rdfs:label 'Stunting Description' ;
    rdfs:comment 'Free-text description of any programming stunts or special events scheduled during this sweeps period (e.g., \'Season finale of flagship drama\', \'Super Bowl lead-out programming\'). Populated only when is_special_programming_flag is True. | Column stunting_description (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepMonth rdf:type rdf:Property ;
    rdfs:label 'Sweep Month' ;
    rdfs:comment 'The calendar month in which the sweeps measurement period falls. Nielsen conducts four sweeps periods annually: February, May, July, and November. Drives programming strategy and ad rate negotiations. | Column sweep_month (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepName rdf:type rdf:Property ;
    rdfs:label 'Sweep Name' ;
    rdfs:comment 'Human-readable label for the sweeps period (e.g., \'November 2024 Sweeps\', \'February 2025 Sweeps\'). Used in reports, ad sales proposals, and programming strategy documents. | Column sweep_name (STRING) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepYear rdf:type rdf:Property ;
    rdfs:label 'Sweep Year' ;
    rdfs:comment 'The four-digit calendar year in which the sweeps measurement period occurs (e.g., 2024). Used to uniquely identify the period in combination with sweep_month. | Column sweep_year (INT) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trpGuaranteeApplicable rdf:type rdf:Property ;
    rdfs:label 'Trp Guarantee Applicable' ;
    rdfs:comment 'Indicates whether Target Rating Point (TRP) audience guarantees for specific demographic targets apply to advertising campaigns running within this sweeps period. True = TRP guarantees in effect; False = no TRP guarantees applicable. | Column trp_guarantee_applicable (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upfrontRateCardApplicable rdf:type rdf:Property ;
    rdfs:label 'Upfront Rate Card Applicable' ;
    rdfs:comment 'Indicates whether advertising rates negotiated during the upfront sales event apply to inventory sold within this sweeps period. True = upfront rate cards govern pricing; False = scatter market rates apply. | Column upfront_rate_card_applicable (BOOLEAN) in audience.sweeps_period' ;
    rdfs:domain ind:SweepsPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelId rdf:type rdf:Property ;
    rdfs:label 'Panel Id' ;
    rdfs:comment 'Unique surrogate identifier for the audience measurement panel record in the lakehouse. Primary key for the audience_panel entity. | Column panel_id (BIGINT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by the measurement provider (e.g., Nielsen) to uniquely identify this panel within their system. Used for cross-system reconciliation with the Nielsen Media Research Platform. | Column panel_code (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cooperationRate rdf:type rdf:Property ;
    rdfs:label 'Cooperation Rate' ;
    rdfs:comment 'Percentage of recruited panel households or individuals who are actively and consistently providing usable measurement data. A declining cooperation rate is an early indicator of panel quality degradation and may trigger MRC review. Expressed as a decimal (e.g., 0.8500 = 85%). | Column cooperation_rate (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Technical mechanism used to collect viewing data from panel members. Electronic meters (people meters) require active button-pressing; set-top-box (STB) and smart TV ACR (Automatic Content Recognition) are passive; diary is self-reported. Determines the granularity and reliability of minute-by-minute audience data. | Column data_collection_method (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicComposition rdf:type rdf:Property ;
    rdfs:label 'Demographic Composition' ;
    rdfs:comment 'Narrative or structured description of the demographic breakdowns captured by this panel (e.g., \'Age 2+, Adults 18-49, Adults 25-54, Persons 2-17, Households by income quintile\'). Defines which demographic cuts are available for TRP (Target Rating Point) calculations and demographic audience guarantees in ad sales. | Column demographic_composition (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Currency Flag' ;
    rdfs:comment 'Indicates whether this panel is designated as the official currency measurement source for audience guarantees in advertising transactions. True = this panel\'s data is used as the contractual basis for GRP/TRP delivery and makegood calculations in upfront and scatter market deals. False = supplemental or research-only panel. | Column measurement_currency_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minReportableRating rdf:type rdf:Property ;
    rdfs:label 'Min Reportable Rating' ;
    rdfs:comment 'The lowest audience rating value (expressed as a decimal fraction of the universe) that this panel can reliably report without exceeding acceptable statistical error thresholds. Ratings below this threshold are suppressed or flagged as unreliable. Typically expressed as a percentage (e.g., 0.0010 = 0.1%). Governed by MRC minimum cell size requirements. | Column min_reportable_rating (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrcAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Date' ;
    rdfs:comment 'Date on which the MRC most recently granted or renewed accreditation for this panel. Used to track accreditation currency and schedule renewal audits. Panels must maintain continuous accreditation to support upfront and scatter market ad sales guarantees. | Column mrc_accreditation_date (DATE) in audience.panel' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the current MRC accreditation for this panel expires and must be renewed. Expiry triggers a mandatory re-audit process. Ad sales teams must be notified of impending expiry to manage risk on guaranteed audience delivery commitments. | Column mrc_accreditation_expiry_date (DATE) in audience.panel' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Status' ;
    rdfs:comment 'Current accreditation status granted by the Media Rating Council (MRC) for this panel. MRC accreditation is the industry standard for currency-grade audience measurement. Accredited panels are required for guaranteed ad buys and upfront sales commitments. Non-accredited panels cannot be used as primary currency. | Column mrc_accreditation_status (STRING) in audience.panel' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Human-readable name of the audience measurement panel (e.g., \'Nielsen National People Meter 2024\', \'Nielsen Local People Meter — New York DMA\'). Used in reporting, dashboards, and ad sales presentations. | Column panel_name (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Code' ;
    rdfs:comment 'Nielsen\'s proprietary internal identifier for this panel as maintained in the Nielsen Media Research Platform. Used for direct API integration, data feed reconciliation, and cross-referencing Nielsen ratings reports. Distinct from the internal audience_panel_id surrogate key. | Column nielsen_panel_code (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfHomeMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Home Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures out-of-home (OOH) viewing, such as viewing in bars, hotels, airports, and other public venues. OOH measurement is captured via Portable People Meter (PPM) technology. OOH-inclusive panels produce higher total audience estimates than in-home-only panels. | Column out_of_home_measurement_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle state of the audience panel. Active panels are used for currency-grade audience projections. Suspended panels are temporarily halted due to quality or compliance issues. Retired panels are decommissioned and replaced by newer vintages. | Column panel_status (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the audience measurement methodology used by this panel. National People Meter (NPM) and Local People Meter (LPM) are electronic metered panels; Portable People Meter (PPM) captures out-of-home exposure; Diary is self-reported; Return Path Data (RPD) is set-top-box passback data; Hybrid combines multiple methods. | Column panel_type (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Recruitment Methodology' ;
    rdfs:comment 'Statistical sampling approach used to recruit panel members. Probability-based sampling (address-based or random-digit-dial) is required for MRC-accredited currency panels. Opt-in panels are used for supplemental or proprietary measurement. Affects the projectability and accreditation status of the panel. | Column recruitment_methodology (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which panel membership is rotated or refreshed to prevent panel conditioning effects and maintain demographic representativeness. Annual and biennial refreshes are standard for people meter panels; continuous recruitment is used for large-scale return path data panels. | Column refresh_frequency (STRING) in audience.panel' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingGranularity rdf:type rdf:Property ;
    rdfs:label 'Reporting Granularity' ;
    rdfs:comment 'Finest time interval at which this panel can produce reliable audience estimates. Minute-by-minute granularity is available from electronic people meter panels and supports DAI (Dynamic Ad Insertion) optimization. Quarter-hour is standard for diary panels. Determines compatibility with EPG-based program-level ratings reporting. | Column reporting_granularity (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Sampling Error Pct' ;
    rdfs:comment 'Estimated margin of error (as a percentage) for audience projections derived from this panel at a 95% confidence interval. Smaller panels have higher sampling error. Used by ad sales teams to communicate measurement uncertainty to advertisers and to set makegood thresholds for audience delivery shortfalls. | Column sampling_error_pct (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeHouseholds rdf:type rdf:Property ;
    rdfs:label 'Size Households' ;
    rdfs:comment 'Total number of sample households actively participating in this panel at any given time. Drives the statistical reliability and margin of error of projected audience estimates. A larger panel size yields lower sampling error for low-rated programs. | Column size_households (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeIndividuals rdf:type rdf:Property ;
    rdfs:label 'Size Individuals' ;
    rdfs:comment 'Total number of individual persons (panelists) actively measured within this panel. Distinct from household count because multiple individuals per household are measured for demographic breakdowns used in Target Rating Point (TRP) calculations. | Column size_individuals (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Streaming Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures streaming and OTT (Over-The-Top) viewing in addition to linear broadcast. Streaming-enabled panels support cross-platform audience measurement combining linear TV, SVOD, AVOD, and FAST channel viewing for total audience reporting. | Column streaming_measurement_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sweepsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Eligible Flag' ;
    rdfs:comment 'Indicates whether this panel is used during Nielsen Sweeps periods (February, May, July, November) for local market ratings measurement. Sweeps data drives local ad rates and program scheduling decisions. Only MRC-accredited panels with sufficient local market sample sizes are sweeps-eligible. | Column sweeps_eligible_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimateType rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Type' ;
    rdfs:comment 'Specifies whether the universe_estimate represents total households, total persons, or TV households (HUT-eligible). TV households are the standard denominator for HUT (Homes Using Television) calculations in broadcast ratings. | Column universe_estimate_type (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which this panel sample was designed and recruited. Panels are periodically refreshed to maintain demographic representativeness as the population changes. Vintage year is used to track panel age and schedule mandatory refreshes per MRC accreditation requirements. | Column vintage_year (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightingFactor rdf:type rdf:Property ;
    rdfs:label 'Weighting Factor' ;
    rdfs:comment 'Numeric multiplier applied to this panel\'s raw viewing data to project sample observations to the total universe estimate. A weighting factor greater than 1.0 indicates the panel under-represents a demographic segment relative to the population. Used in GRP and TRP calculations. | Column weighting_factor (DECIMAL(10,6)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'Description of the statistical weighting approach applied to panel data to correct for demographic imbalances and non-response bias (e.g., \'Iterative Proportional Fitting / Raking\', \'Post-stratification weighting by age/sex/race/income\'). Critical for ensuring projected audience estimates are representative of the total population. | Column weighting_methodology (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewershipRecordId rdf:type rdf:Property ;
    rdfs:label 'Viewership Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular viewership record in the Silver Layer lakehouse. Primary key for this entity. | Column viewership_record_id (BIGINT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Data Quality Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Viewership records undergo quality audits for billing reconciliation, ratings certification, and advertiser makegood disputes. Auditor assignment tracked for compliance trails, client dispute resoluti | Column data_quality_auditor_employee_id (BIGINT) in workforce.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originatingBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Originating Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Viewership records require originating facility tracking for CDN routing optimization, regional blackout enforcement, local ad insertion decisioning, and FCC local content compliance. Role prefix dist | Column originating_broadcast_facility_id (BIGINT) in technology.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:acrSource rdf:type rdf:Property ;
    rdfs:label 'Acr Source' ;
    rdfs:comment 'The data collection methodology or source system that generated this viewership record. ACR = Automatic Content Recognition from smart TV; set_top_box = return-path data from cable/satellite STB; streaming_telemetry = OTT platform event stream via Adobe Experience Platform; panel = Nielsen People Meter panel; return_path = MVPD return-path data. | Column acr_source (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakCount rdf:type rdf:Property ;
    rdfs:label 'Ad Break Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) encountered by the viewer during this viewing session. Used for DAI (Dynamic Ad Insertion) reconciliation, Wide Orbit affidavit verification, and advertiser delivery reporting. | Column ad_break_count (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsViewedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Viewed Count' ;
    rdfs:comment 'Total number of individual advertisement spots viewed (not skipped) by the viewer during this session. Used for AVOD monetization reporting, CPM impression counting, and advertiser campaign delivery verification against Wide Orbit schedules. | Column ads_viewed_count (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceShare rdf:type rdf:Property ;
    rdfs:label 'Audience Share' ;
    rdfs:comment 'The percentage of HUT (Homes Using Television) or PUT (Persons Using Television) tuned to this channel/program at the time of viewing, as reported by Nielsen. Share differs from rating in that it measures the proportion of active viewers rather than the total universe. Used for competitive programming analysis. | Column audience_share (DECIMAL(6,4)) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnEdgeNode rdf:type rdf:Property ;
    rdfs:label 'Cdn Edge Node' ;
    rdfs:comment 'Identifier of the Akamai CDN edge node or point-of-presence (PoP) that served the streaming content for this session. Used for CDN performance analysis, SLA compliance monitoring, and geographic delivery optimization. | Column cdn_edge_node (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRate rdf:type rdf:Property ;
    rdfs:label 'Completion Rate' ;
    rdfs:comment 'Proportion of the content asset viewed during this session, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.7500 = 75% viewed). Sourced directly from platform telemetry; not derived within this product. Used for engagement scoring, programming decisions, and advertiser reporting. | Column completion_rate (DECIMAL(5,4)) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of how the content was delivered to the viewer. Linear = traditional scheduled broadcast; VOD = on-demand; SVOD = subscription on-demand; AVOD = ad-supported on-demand; TVOD = transactional/pay-per-view; FAST = Free Ad-Supported Streaming Television; Simulcast = simultaneous multi-platform broadcast. Critical for rights windowing compliance and revenue attribution. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|fast|simulcast — 7 candidates stripped; promote to reference product] | Column delivery_type (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Indicates whether the content stream was delivered with DRM (Digital Rights Management) encryption active during this session. Used for rights compliance auditing, anti-piracy reporting to MPA, and content protection SLA verification. | Column drm_protected (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationViewedSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Viewed Seconds' ;
    rdfs:comment 'Total number of seconds the viewer actively watched the content during this session, as reported by the source telemetry system. Accounts for pauses and buffering exclusions per platform telemetry rules. Used for TSR (Time Spent Reading/Viewing) calculations and completion rate derivation. | Column duration_viewed_seconds (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time when this viewership record was first loaded into the Databricks Silver Layer lakehouse. Used for data freshness monitoring, SLA compliance, and audit trail purposes. Distinct from tune_in_timestamp (business event time). | Column ingestion_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the viewer was authenticated (logged in) at the time of viewing. Authenticated sessions enable individual-level audience measurement and subscriber-linked analytics. Unauthenticated sessions rely on household or device-level inference. | Column is_authenticated (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Period' ;
    rdfs:comment 'Flag indicating whether this viewership record falls within a Nielsen sweeps measurement period (February, May, July, November). Sweeps data is used for setting advertising rates and programming decisions. Critical for isolating sweeps vs. non-sweeps audience behavior. | Column is_sweeps_period (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:streamQuality rdf:type rdf:Property ;
    rdfs:label 'Stream Quality' ;
    rdfs:comment 'The video quality level at which the content was delivered during this session, as reported by the ABR (Adaptive Bitrate Streaming) player or CDN telemetry from Akamai. Used for quality-of-experience reporting, CDN SLA compliance, and premium content delivery analytics. | Column stream_quality (STRING) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuneInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune In Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer began watching the content or tuned to the channel. This is the principal business event timestamp for the viewership record. Used for daypart analysis, time-spent calculations, and sweeps period attribution. | Column tune_in_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tuneOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune Out Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer stopped watching, changed channel, or the session ended. Used in conjunction with tune_in_timestamp to calculate duration_viewed_seconds. | Column tune_out_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:viewingStatus rdf:type rdf:Property ;
    rdfs:label 'Viewing Status' ;
    rdfs:comment 'Current lifecycle status of the viewing session record. \'completed\' = viewer watched to end or tune-out cleanly; \'in_progress\' = session still active at ingestion time; \'abandoned\' = viewer left before 10% completion; \'interrupted\' = session ended due to technical failure; \'error\' = telemetry data quality issue flagged. | Column viewing_status (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Report Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Reach/frequency reports require certified analysts to validate GRP/TRP calculations, effective reach thresholds, and makegood determinations for advertiser guarantees. Analyst assignment tracked for c | Column report_analyst_employee_id (BIGINT) in workforce.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceSharePct rdf:type rdf:Property ;
    rdfs:label 'Audience Share Pct' ;
    rdfs:comment 'The percentage of the total viewing audience (persons using television) that was watching the specific network or program during the measurement period. Calculated as the program\'s audience divided by the total HUT/PUT audience. Used for competitive programming analysis and ad sales positioning. | Column audience_share_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Frequency' ;
    rdfs:comment 'The average number of times a unique viewer within the target demographic was exposed to the content or campaign during the measurement period. Calculated as total impressions divided by unduplicated reach. Core metric for evaluating campaign saturation and makegoods calculation. | Column average_frequency (DECIMAL(8,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprp rdf:type rdf:Property ;
    rdfs:label 'Cprp' ;
    rdfs:comment 'The cost per one rating point delivered against the target demographic segment, expressed in USD. The primary pricing metric for linear TV advertising transactions. Used for upfront guarantee reconciliation, makegood valuation, and scatter market pricing. Confidential as it reflects negotiated commercial pricing. | Column cprp (DECIMAL(10,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVariancePct rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Pct' ;
    rdfs:comment 'The percentage difference between the guaranteed audience delivery (GRP or TRP) and the actual delivered audience for the campaign flight. A negative value indicates under-delivery triggering makegood obligations; a positive value indicates over-delivery. Used for upfront guarantee reconciliation and scatter market adjustments. | Column delivery_variance_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveReach1plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 1plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least one time (1+) during the measurement period. Equivalent to reach_persons; included as an explicit effective reach threshold field for consistency with N+ reporting framework used in post-campaign analysis. | Column effective_reach_1plus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReach3plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 3plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least three times (3+) during the measurement period. The industry-standard effective reach threshold used to assess whether sufficient frequency was achieved for advertising message recall. Critical for makegoods determination and campaign effectiveness evaluation. | Column effective_reach_3plus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachNplus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Nplus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least N times (as defined by effective_reach_threshold) during the measurement period. Provides a configurable effective reach metric for custom campaign guarantee structures and advanced frequency analysis. | Column effective_reach_nplus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachThreshold rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Threshold' ;
    rdfs:comment 'The minimum number of exposures (N) used to define effective reach for this specific report. Configurable per campaign or client agreement (e.g., 3 for standard campaigns, 5 for high-frequency campaigns). Determines the N+ threshold applied in effective reach calculations beyond the standard 1+ and 3+ fields. | Column effective_reach_threshold (INT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutRating rdf:type rdf:Property ;
    rdfs:label 'Hut Rating' ;
    rdfs:comment 'The percentage of all television households in the market that had their television sets in use during the measurement period. Sourced from Nielsen Media Research Platform. Used as a contextual benchmark for evaluating audience share and competitive programming performance. | Column hut_rating (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMakegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Is Makegood Required' ;
    rdfs:comment 'Indicates whether this reach and frequency report has identified an audience delivery shortfall that requires a makegood (compensatory ad spot) to be issued to the advertiser. Triggers the makegood workflow in Wide Orbit and Salesforce Media Cloud when set to True. | Column is_makegood_required (BOOLEAN) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement window for which reach and frequency metrics are computed. Defines the end boundary of the campaign flight, programming block, or sweeps period being analyzed. | Column measurement_period_end_date (DATE) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement window for which reach and frequency metrics are computed. Defines the start boundary of the campaign flight, programming block, or sweeps period being analyzed. Used in conjunction with measurement_period_end_date to bound the audience measurement interval. | Column measurement_period_start_date (DATE) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies the type of measurement window for which this report was generated. \'campaign_flight\' covers a defined ad campaign run; \'programming_block\' covers a scheduled content block; \'daypart_window\' covers a standard broadcast daypart; \'sweeps_period\' covers an intensive Nielsen ratings measurement period; \'custom_window\' covers an ad hoc analysis window. | Column measurement_type (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Code' ;
    rdfs:comment 'The native report identifier assigned by the Nielsen Media Research Platform for this reach and frequency dataset. Used for source system traceability, data lineage, and reconciliation between the lakehouse Silver Layer and the Nielsen source system. | Column nielsen_report_code (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putRating rdf:type rdf:Property ;
    rdfs:label 'Put Rating' ;
    rdfs:comment 'The percentage of all persons in the target demographic who were watching television during the measurement period. Sourced from Nielsen Media Research Platform. Used alongside HUT to assess total available audience and calculate audience share for programming decisions. | Column put_rating (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPct rdf:type rdf:Property ;
    rdfs:label 'Reach Pct' ;
    rdfs:comment 'The percentage of the target demographic universe reached at least once during the measurement period, calculated as (reach_persons / universe_estimate) × 100. Expressed as a decimal percentage (e.g., 45.2500 = 45.25%). Used by ad sales for post-campaign delivery reporting and scatter market pricing justification. | Column reach_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPersons rdf:type rdf:Property ;
    rdfs:label 'Reach Persons' ;
    rdfs:comment 'The unduplicated count of unique persons within the target demographic segment who were exposed to the content or campaign at least once during the measurement period. The primary reach metric sourced from Nielsen Media Research Platform. Used for post-campaign delivery validation and upfront guarantee reconciliation. | Column reach_persons (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generated Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when this reach and frequency report was generated and delivered by the Nielsen Media Research Platform. Represents the business event time, distinct from audit timestamps. Used to track Nielsen data delivery SLAs and post-campaign reporting timeliness. | Column report_generated_timestamp (TIMESTAMP) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'The version number of this reach and frequency report, incremented each time a revised or corrected report is issued by Nielsen or reprocessed in the lakehouse. Version 1 represents the initial delivery; subsequent versions represent corrections or revisions. Used to ensure ad sales teams are working with the most current data. | Column report_version (INT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'The total number of audience exposures (duplicated) to the content or campaign during the measurement period. Equals reach_persons multiplied by average_frequency. Used as the gross delivery metric for CPM-based advertising transactions and campaign pacing analysis. | Column total_impressions (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Market coverage (DMA) must link to primary licensed broadcast facility for FCC must-carry compliance, retransmission consent negotiations, local content origination requirements, and emergency alert s | Column primary_broadcast_facility_id (BIGINT) in technology.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:blackoutRuleApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Applicable' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout rules apply to this market for sports or syndication exclusivity purposes. True if blackout restrictions can be enforced in this DMA; False otherwise. Used by rights management (Rightsline) and CDN geo-restriction (Akamai) to enforce territorial exclusivity. | Column blackout_rule_applicable (BOOLEAN) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cablePenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Cable Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that subscribe to cable television (MVPD or vMVPD service). Expressed as a decimal (e.g., 0.6234 = 62.34%). Used for carriage fee negotiations, distribution planning, and ad sales reach projections. | Column cable_penetration_rate (DECIMAL(8,4)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daylightSavingObserved rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Observed' ;
    rdfs:comment 'Indicates whether the DMA observes Daylight Saving Time (DST). True if DST is observed; False if not (e.g., markets in Arizona). Affects daypart scheduling, playout timing, and EPG accuracy in broadcast automation systems. | Column daylight_saving_observed (BOOLEAN) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date on which this market coverage record ceased to be effective, typically due to a DMA boundary redefinition, market merger, or discontinuation. Null for currently active market definitions. Supports slowly changing dimension (SCD) history tracking. | Column effective_to_date (DATE) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fccMarketCode rdf:type rdf:Property ;
    rdfs:label 'Fcc Market Code' ;
    rdfs:comment 'FCC-assigned market identifier used for must-carry and retransmission consent compliance filings. Maps the Nielsen DMA to the FCC\'s designated market definition for broadcast licensing, spectrum regulation, and MVPD carriage obligations. Required for regulatory reporting under FCC 47 CFR Part 76. | Column fcc_market_code (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Wkt' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the DMA\'s geographic boundary polygon. Used for spatial analysis, blackout rule enforcement, retransmission consent territory mapping, and OTT/streaming geo-restriction via CDN (Akamai). Conforms to OGC WKT standard. | Column geographic_boundary_wkt (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hispanicTvHouseholdPct rdf:type rdf:Property ;
    rdfs:label 'Hispanic Tv Household Pct' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that are Hispanic/Latino, as measured by Nielsen. Expressed as a decimal (e.g., 0.2341 = 23.41%). Used for Spanish-language content distribution decisions, targeted ad sales, and TRP (Target Rating Point) calculations for Hispanic demographic segments. | Column hispanic_tv_household_pct (DECIMAL(8,4)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Hut Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of television households in the DMA that are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.5823 = 58.23%). Used as a reference benchmark for HUT-based audience projections and ad sales planning. | Column hut_base_estimate (DECIMAL(10,4)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'Official human-readable name of the Designated Market Area (DMA) or television market as defined by Nielsen (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in audience reports, ad sales proposals, and regulatory filings. | Column market_name (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketStatus rdf:type rdf:Property ;
    rdfs:label 'Market Status' ;
    rdfs:comment 'Current lifecycle status of the market coverage record. \'active\' indicates the DMA is currently measured and used in audience reporting; \'inactive\' indicates it is no longer measured; \'pending\' indicates a newly defined market awaiting first measurement; \'discontinued\' indicates a market that has been merged or eliminated by Nielsen. | Column market_status (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Classification of the market scope. \'local\' indicates a single-city DMA; \'regional\' indicates a multi-city or multi-state DMA; \'national\' indicates a national aggregate market; \'international\' indicates a non-US market territory. Used for ad sales segmentation, carriage fee tiers, and programming distribution decisions. | Column market_type (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income (in USD) for the DMA, sourced from U.S. Census Bureau data as incorporated into Nielsen demographic profiles. Used for audience demographic segmentation, CPM (Cost Per Mille) pricing tiers, and advertiser targeting qualification. | Column median_household_income (DECIMAL(12,2)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustCarryApplicable rdf:type rdf:Property ;
    rdfs:label 'Must Carry Applicable' ;
    rdfs:comment 'Indicates whether FCC must-carry rules apply to broadcast stations in this market, requiring cable operators (MVPDs) to carry local broadcast signals. True if must-carry obligations exist; False otherwise. Critical for retransmission consent negotiations and MVPD carriage compliance. | Column must_carry_applicable (BOOLEAN) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenSourceMarketCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Source Market Code' ;
    rdfs:comment 'The native market identifier as assigned and used within the Nielsen Media Research Platform source system. Used for data lineage, reconciliation between the lakehouse silver layer and the Nielsen source system, and audit of universe estimate ingestion. | Column nielsen_source_market_code (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Index' ;
    rdfs:comment 'Total number of television stations measured by Nielsen within this DMA. Indicates the competitive landscape of the local market and is used in share calculations and ad sales competitive analysis. | Column nielsen_station_index (INT) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ottPenetrationRate rdf:type rdf:Property ;
    rdfs:label 'Ott Penetration Rate' ;
    rdfs:comment 'Estimated percentage of television households in the DMA that access video content via OTT (Over-The-Top) streaming services. Expressed as a decimal. Used for digital distribution planning, SVOD/AVOD audience projections, and DAI (Dynamic Ad Insertion) inventory estimation. | Column ott_penetration_rate (DECIMAL(8,4)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationUniverse rdf:type rdf:Property ;
    rdfs:label 'Population Universe' ;
    rdfs:comment 'Nielsen-estimated total population (persons 2+) residing within the DMA boundary. Used as the denominator for person-based ratings metrics including PUT (Persons Using Television) and TRP (Target Rating Point) calculations. Updated annually in the Nielsen universe estimates release. | Column population_universe (BIGINT) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalCity rdf:type rdf:Property ;
    rdfs:label 'Principal City' ;
    rdfs:comment 'Name of the primary city or metropolitan area that anchors and names the DMA (e.g., \'New York\', \'Los Angeles\', \'Chicago\'). Used in market identification, ad sales materials, and regulatory filings. | Column principal_city (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putBaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Put Base Estimate' ;
    rdfs:comment 'Nielsen baseline estimate of the percentage of persons (2+) in the DMA who are using television during an average primetime daypart. Expressed as a decimal (e.g., 0.4612 = 46.12%). Used as a reference benchmark for PUT-based audience projections and TRP calculations. | Column put_base_estimate (DECIMAL(10,4)) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary broadcast regulatory authority governing this market. \'FCC\' for US markets; \'Ofcom\' for UK markets; \'CRTC\' for Canadian markets; \'ACMA\' for Australian markets; \'other\' for all other jurisdictions. Determines applicable must-carry, retransmission consent, content standards, and licensing requirements. | Column regulatory_jurisdiction (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentApplicable rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Applicable' ;
    rdfs:comment 'Indicates whether retransmission consent rules apply to broadcast stations in this market, allowing broadcasters to negotiate compensation from MVPDs for carriage of their signals. True if retransmission consent is applicable; False otherwise. | Column retransmission_consent_applicable (BOOLEAN) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 two-letter state or province code of the primary state in which the DMA\'s principal city is located (e.g., \'NY\', \'CA\', \'IL\'). Used for geographic segmentation, blackout rule enforcement, and retransmission consent jurisdiction determination. | Column state_province_code (STRING) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsParticipation rdf:type rdf:Property ;
    rdfs:label 'Sweeps Participation' ;
    rdfs:comment 'Indicates whether this market participates in Nielsen sweeps periods (intensive ratings measurement periods in February, May, July, and November). True if the market is measured during sweeps; False if it is a non-sweeps market. Affects programming scheduling strategy and ad sales pricing. | Column sweeps_participation (BOOLEAN) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCounties rdf:type rdf:Property ;
    rdfs:label 'Total Counties' ;
    rdfs:comment 'Total number of counties or county-equivalents included within the DMA boundary. Nielsen defines DMA boundaries at the county level. Used for geographic coverage analysis, must-carry compliance, and retransmission consent territory verification. | Column total_counties (INT) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tvHouseholdUniverse rdf:type rdf:Property ;
    rdfs:label 'Tv Household Universe' ;
    rdfs:comment 'Nielsen-estimated total number of television households within the DMA boundary. This is the principal quantitative measurement fact for the market and serves as the denominator for all local ratings calculations, GRP/TRP computations, and CPM-based ad pricing. Updated annually in the Nielsen universe estimates release. | Column tv_household_universe (BIGINT) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Universe Effective Date' ;
    rdfs:comment 'The date from which the current Nielsen universe estimates (TV household and population) became effective for this market. Used to track the currency of universe data and ensure ratings calculations use the correct denominator for the applicable measurement period. | Column universe_effective_date (DATE) in audience.market_coverage' ;
    rdfs:domain ind:MarketCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete digital audience engagement action captured on OTT/streaming platforms. Primary key for this product in the Databricks Silver Layer. | Column engagement_event_id (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_request. Business justification: Privacy requests must locate and process engagement event data for GDPR/CCPA compliance. Links requests to behavioral data for subject access reports and deletion fulfillment. | Column privacy_request_id (BIGINT) in compliance.engagement_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyRequest .

ind:bufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Buffering Duration Ms' ;
    rdfs:comment 'Total duration of buffering experienced by the viewer immediately preceding or during this engagement event, in milliseconds. Sourced from Adobe Experience Platform quality-of-experience telemetry. Used to correlate buffering events with pause and abandonment engagement actions. | Column buffering_duration_ms (INT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentDurationMs rdf:type rdf:Property ;
    rdfs:label 'Content Duration Ms' ;
    rdfs:comment 'Total duration of the content asset in milliseconds at the time of the engagement event. Used in conjunction with content_position_ms to compute completion percentage and engagement depth score. Sourced from Dalet Galaxy asset metadata. | Column content_duration_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPositionMs rdf:type rdf:Property ;
    rdfs:label 'Content Position Ms' ;
    rdfs:comment 'Playback position within the content asset at the moment the engagement event was triggered, expressed in milliseconds from the start of the content. Core EVENT_PAYLOAD_OR_VALUE for this event log. Enables precise engagement depth analysis, completion rate calculation, and identification of drop-off points. | Column content_position_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyConsent rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent' ;
    rdfs:comment 'Viewer\'s data privacy consent status at the time of the engagement event, governing permissible use of this record for analytics, personalisation, and ad targeting. Sourced from Adobe Experience Platform consent management. Mandatory for GDPR Article 6 lawful basis determination and CCPA opt-out compliance. | Column data_privacy_consent (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system of the device that generated the engagement event (e.g., iOS, Android, tvOS, Roku OS, Fire OS, Windows, macOS). Sourced from Adobe Experience Platform device context. Supports technical platform compatibility analysis and audience reach reporting. | Column device_os (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDepthScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Depth Score' ;
    rdfs:comment 'Normalised score (0.00–100.00) representing the depth of audience engagement at the time of the event, calculated by Adobe Experience Platform based on playback position relative to content duration, interaction frequency, and event type weighting. Key metric for non-linear audience behaviour analysis and ad targeting propensity modelling. | Column engagement_depth_score (DECIMAL(5,2)) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the viewer\'s geographic location at the time of the engagement event, derived from IP geolocation. Used for territorial rights compliance (blackout enforcement, holdback windows), audience reach reporting by geography, and regulatory jurisdiction determination. | Column geo_country_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geo Region Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code (state, province, or region) of the viewer\'s location at the time of the engagement event. Used for sub-national blackout enforcement, regional audience measurement, and daypart-adjusted analytics. | Column geo_region_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdEvent rdf:type rdf:Property ;
    rdfs:label 'Is Ad Event' ;
    rdfs:comment 'Indicates whether this engagement event occurred during an advertisement (True) or during editorial content (False). Critical for separating content engagement metrics from ad engagement metrics in AVOD and DAI (Dynamic Ad Insertion) analytics. | Column is_ad_event (BOOLEAN) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConcurrentStream rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent Stream' ;
    rdfs:comment 'Indicates whether this engagement event occurred on a stream that was running concurrently with another active stream on the same viewer account (True) or not (False). Used for concurrent stream limit enforcement per subscription terms and HUT (Homes Using Television) measurement. | Column is_concurrent_stream (BOOLEAN) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'UTC timestamp when the engagement event was received and ingested by Adobe Experience Platform. Distinct from event_timestamp (client-side occurrence time). Used to measure event latency, detect clock skew, and support data quality auditing in the Silver Layer pipeline. | Column received_timestamp (TIMESTAMP) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or mechanism through which the viewer arrived at the content that triggered this engagement event. Used for audience acquisition attribution, marketing campaign effectiveness analysis, and content discovery optimisation. [ENUM-REF-CANDIDATE: direct|search|social|email|push_notification|in_app|external_link — promote to reference product] | Column referral_source (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seekFromPositionMs rdf:type rdf:Property ;
    rdfs:label 'Seek From Position Ms' ;
    rdfs:comment 'Playback position in milliseconds from which the viewer initiated a seek or rewind action. Populated only when event_type is \'seek\' or \'rewind\'. Combined with content_position_ms (seek-to position) to measure skip behaviour and identify content segments that audiences skip or revisit. | Column seek_from_position_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Original event identifier assigned by Adobe Experience Platform at the point of capture, before Silver Layer surrogate key assignment. Used for data lineage tracing, deduplication, and reconciliation between the Silver Layer and the Adobe Experience Platform source system. | Column source_system_event_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Subscription or access tier of the viewer at the time of the engagement event, reflecting the monetisation model under which content was consumed. Sourced from Zuora subscription billing. Used to segment engagement behaviour by revenue tier for ARPU analysis and churn prediction. | Column subscription_tier (STRING) in audience.engagement_event' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Id' ;
    rdfs:comment 'Pseudonymized identifier assigned by Nielsen Media Research to link this audience profile to a Nielsen panel household or individual. Enables direct integration of Nielsen ratings, GRP/TRP, and demographic data. Null for non-panel profiles. | Column nielsen_panel_id (BIGINT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:adReceptivityScore rdf:type rdf:Property ;
    rdfs:label 'Ad Receptivity Score' ;
    rdfs:comment 'Propensity score (0.00–100.00) indicating this audience member\'s likelihood to engage with advertising content, derived from behavioral signals in Adobe AEP and viewing pattern analysis. Used by ad sales teams for premium audience packaging and CPM pricing optimization. | Column ad_receptivity_score (DECIMAL(5,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aepProfileCode rdf:type rdf:Property ;
    rdfs:label 'Aep Profile Code' ;
    rdfs:comment 'Unique profile identifier from Adobe Experience Platform (AEP) used to link behavioral engagement data, segment memberships, and journey analytics to this audience profile. Enables personalization and digital engagement enrichment. | Column aep_profile_code (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentMembership rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Membership' ;
    rdfs:comment 'Comma-delimited list of Adobe Experience Platform (AEP) audience segment IDs to which this profile currently belongs. Segments represent behavioral, demographic, or propensity-based audience groups used for personalization, ad targeting, and journey activation. | Column aep_segment_membership (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgSessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Avg Session Duration Minutes' ;
    rdfs:comment 'Average duration in minutes of a single viewing session for this audience member, derived from set-top box or streaming platform telemetry. Represents Time Spent Viewing (TSV) at the individual level. Used for engagement scoring and content performance analytics. | Column avg_session_duration_minutes (DECIMAL(8,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this California-resident audience member has exercised their CCPA right to opt out of the sale or sharing of their personal information. When TRUE, this profile must be excluded from data sharing with third-party ad networks and data clean rooms. | Column ccpa_opt_out (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to any consent or privacy flag (GDPR consent status, CCPA opt-out, COPPA flag) for this audience profile. Critical for regulatory audit trails demonstrating timely consent management and data processing compliance. | Column consent_last_updated_timestamp (TIMESTAMP) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentAffinityGenre rdf:type rdf:Property ;
    rdfs:label 'Content Affinity Genre' ;
    rdfs:comment 'Top inferred content genre affinity for this audience member (e.g., \'news\', \'sports\', \'drama\', \'reality\', \'documentary\'), derived from viewing history and behavioral signals in Adobe AEP. Used for content recommendation, programming decisions, and audience-targeted ad sales. [ENUM-REF-CANDIDATE: news|sports|drama|comedy|reality|documentary|entertainment|kids|lifestyle|sci_fi — promote to reference product] | Column content_affinity_genre (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaProtected rdf:type rdf:Property ;
    rdfs:label 'Coppa Protected' ;
    rdfs:comment 'Indicates whether this audience profile is subject to COPPA (Children\'s Online Privacy Protection Act) protections, meaning the inferred or declared age is under 13. When TRUE, ad targeting, data sharing, and behavioral tracking are strictly restricted per COPPA compliance requirements. | Column coppa_protected (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCleanRoomEligible rdf:type rdf:Property ;
    rdfs:label 'Data Clean Room Eligible' ;
    rdfs:comment 'Indicates whether this audience profile is eligible for inclusion in data clean room matching operations with advertising partners. Eligibility is determined by consent status, CCPA opt-out flag, COPPA protection status, and contractual data sharing agreements. | Column data_clean_room_eligible (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypartPreference rdf:type rdf:Property ;
    rdfs:label 'Daypart Preference' ;
    rdfs:comment 'Preferred daypart (time segment of the broadcast day) during which this audience member most frequently views content. Dayparts are standard broadcast industry time segments used for ad scheduling, upfront sales, and audience guarantee reporting. | Column daypart_preference (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Enrichment Source Version' ;
    rdfs:comment 'Version identifier of the third-party enrichment data package (e.g., Nielsen demographic file version, Adobe AEP segment refresh batch ID) used to populate inferred attributes on this profile. Enables data lineage tracing and reproducibility of audience segment definitions. | Column enrichment_source_version (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this audience member\'s personal data for audience measurement and advertising purposes. \'granted\' permits processing; \'denied\' or \'withdrawn\' restricts processing; \'not_applicable\' for non-EU audience members. Drives data processing eligibility. | Column gdpr_consent_status (STRING) in audience.audience_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Estimated number of persons in the audience household, derived from Nielsen panel data or set-top box signals. Used in HUT (Homes Using Television) and PUT (Persons Using Television) calculations for audience measurement reporting. | Column household_size (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutEligible rdf:type rdf:Property ;
    rdfs:label 'Hut Eligible' ;
    rdfs:comment 'Indicates whether this household-level audience profile is eligible to be counted in HUT (Homes Using Television) calculations. HUT measures the percentage of TV-equipped homes actively watching television during a given time period, a foundational metric for broadcast ratings. | Column hut_eligible (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Confidence score (0.00–100.00) representing the reliability of the identity resolution that constructed this audience profile. Higher scores indicate stronger deterministic matching (e.g., authenticated login); lower scores indicate probabilistic device-graph inference. Used to qualify profiles for premium ad targeting. | Column identity_confidence_score (DECIMAL(5,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityHash rdf:type rdf:Property ;
    rdfs:label 'Identity Hash' ;
    rdfs:comment 'SHA-256 pseudonymized hash of the audience member\'s primary identity (e.g., email or subscriber ID) used for cross-platform identity resolution without exposing raw PII. Enables privacy-safe linkage across Nielsen, Adobe AEP, and first-party data sources. | Column identity_hash (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identitySource rdf:type rdf:Property ;
    rdfs:label 'Identity Source' ;
    rdfs:comment 'Originating source of the audience identity construction: \'first_party\' (subscriber or app registration data), \'nielsen\' (Nielsen Media Research panel linkage), \'adobe_aep\' (Adobe Experience Platform profile), \'set_top_box\' (STB device-level data), \'clean_room\' (data clean room match), or \'modeled\' (probabilistic inference). | Column identity_source (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Inferred household income band derived from third-party demographic enrichment (Nielsen, data clean rooms). Used for premium audience segmentation in upfront and scatter market ad sales, enabling CPM pricing differentiation by audience affluence. | Column income_band (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredAgeBand rdf:type rdf:Property ;
    rdfs:label 'Inferred Age Band' ;
    rdfs:comment 'Inferred age demographic band for the audience member, derived from Nielsen panel data, set-top box signals, or modeled enrichment. Used for GRP/TRP demographic targeting and ad sales audience guarantees. Not directly collected from the individual. | Column inferred_age_band (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredGender rdf:type rdf:Property ;
    rdfs:label 'Inferred Gender' ;
    rdfs:comment 'Inferred gender of the audience member derived from panel data or modeled signals. Used for demographic audience targeting in ad sales (GRP/TRP calculations) and programming decisions. Not directly collected. | Column inferred_gender (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observed audience activity event (viewing session, app interaction, or platform login) for this profile. Used to determine audience recency, drive re-engagement campaigns, and calculate viewing recency metrics. | Column last_seen_timestamp (TIMESTAMP) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenGrpIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Grp Index' ;
    rdfs:comment 'Indexed GRP (Gross Rating Point) score for this audience profile relative to the total population, sourced from Nielsen Media Research. A GRP index above 100 indicates above-average exposure to rated content. Used in ad sales audience guarantees and upfront negotiations. | Column nielsen_grp_index (DECIMAL(8,4)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Panel Weight Factor' ;
    rdfs:comment 'Statistical weighting factor assigned by Nielsen to this panel member profile to project panel observations to the total population. Applied in GRP, TRP, HUT, and PUT calculations. Null for non-panel (modeled or first-party only) profiles. | Column panel_weight_factor (DECIMAL(10,6)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformPreference rdf:type rdf:Property ;
    rdfs:label 'Platform Preference' ;
    rdfs:comment 'Primary viewing platform preference inferred from behavioral signals: \'linear_tv\' (traditional scheduled broadcast), \'svod\' (Subscription Video On Demand), \'avod\' (Advertising-Supported VOD), \'tvod\' (Transactional VOD), \'fast\' (Free Ad-Supported Streaming TV), \'ott\' (Over-The-Top), \'mvpd\' (Multichannel Video Programming Distributor), or \'vmvpd\' (Virtual MVPD). Drives distribution strategy and ad product targeting. [ENUM-REF-CANDIDATE: linear_tv|svod|avod|tvod|fast|ott|mvpd|vmvpd — 8 candidates stripped; promote to reference product] | Column platform_preference (STRING) in audience.audience_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDeviceType rdf:type rdf:Property ;
    rdfs:label 'Primary Device Type' ;
    rdfs:comment 'The primary device type through which this audience member most frequently consumes content, derived from device graph and behavioral data. Used for CDN delivery optimization, ad format targeting, and platform analytics. | Column primary_device_type (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpIndex rdf:type rdf:Property ;
    rdfs:label 'Trp Index' ;
    rdfs:comment 'Indexed TRP (Target Rating Point) score representing this audience member\'s contribution to a specific demographic target group\'s rating. Distinct from GRP in that it measures reach within a defined target demographic. Used for demographic-specific ad campaign planning and post-campaign analysis. | Column trp_index (DECIMAL(8,4)) in audience.audience_profile' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewingRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Viewing Recency Days' ;
    rdfs:comment 'Number of days since this audience member last engaged with any content on any tracked platform. Used for audience recency segmentation, churn prediction, and re-engagement campaign targeting. Lower values indicate more recently active audiences. | Column viewing_recency_days (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyViewingFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Viewing Frequency' ;
    rdfs:comment 'Average number of distinct viewing sessions per week for this audience member, calculated over a rolling 4-week window. Represents the Frequency dimension of audience measurement (average exposures per viewer). Used in reach and frequency reporting for ad campaign delivery. | Column weekly_viewing_frequency (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the independent body that has accredited or audited this measurement methodology (e.g., \'Media Rating Council (MRC)\', \'Joint Industry Committee (JIC)\', \'BARB\', \'Ofcom\'). Supports multi-market operations where different accreditation bodies govern different geographies. | Column accreditation_body (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarketTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Types' ;
    rdfs:comment 'Comma-separated list of market types where this methodology is valid (e.g., \'national, local_dma, regional, international\'). Nielsen PPM is typically used in national and large local DMA markets; diary methodology is used in smaller local markets. Determines which geographic market audience records can be attributed to this methodology. | Column applicable_market_types (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePlatformTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Platform Types' ;
    rdfs:comment 'Comma-separated list of platform types to which this methodology applies (e.g., \'linear_tv, ott_streaming, radio, digital_display, podcast\'). Governs which viewership records and distribution channels can be measured and reported using this methodology. Critical for cross-platform audience deduplication and hybrid measurement. | Column applicable_platform_types (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceMetricTypes rdf:type rdf:Property ;
    rdfs:label 'Audience Metric Types' ;
    rdfs:comment 'Comma-separated list of audience metrics that this methodology can produce (e.g., \'GRP, TRP, HUT, PUT, reach, frequency, share, Nielsen_rating, TSR, CPRP\'). Governs which KPIs can be reported using data collected under this methodology. GRP (Gross Rating Point), TRP (Target Rating Point), HUT (Homes Using Television), PUT (Persons Using Television), TSR (Time Spent Reading/Viewing), CPRP (Cost Per Rating Point). | Column audience_metric_types (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMechanismRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Mechanism Required' ;
    rdfs:comment 'The type of audience consent mechanism required for data collection under this methodology: opt_in (explicit consent required before data collection), opt_out (data collected unless individual opts out), panel_agreement (panelists sign participation agreement), no_consent_required (census/aggregate data with no individual tracking), or mixed. Governs GDPR, CCPA, and COPPA compliance posture. | Column consent_mechanism_required (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossPlatformCapable rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Capable' ;
    rdfs:comment 'Indicates whether this methodology supports cross-platform audience deduplication and unified reach/frequency reporting across linear TV, OTT (Over-The-Top), digital, and streaming platforms. Cross-platform capability is required for total audience measurement (TAM) reporting and advanced advertising guarantees. | Column cross_platform_capable (BOOLEAN) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyStandard rdf:type rdf:Property ;
    rdfs:label 'Currency Standard' ;
    rdfs:comment 'The audience measurement currency standard supported by this methodology, defining the viewing window used for commercial ratings: C3 (average commercial ratings including 3 days of DVR playback), C7 (7-day DVR playback), C35 (35-day), live_plus_same_day, live_only, or custom. The currency standard is the contractual basis for ad sales guarantees and makegood calculations in upfront and scatter markets. | Column currency_standard (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMechanism rdf:type rdf:Property ;
    rdfs:label 'Data Collection Mechanism' ;
    rdfs:comment 'The specific technical mechanism by which audience exposure data is collected: PPM device (Portable People Meter worn by panelists), diary form (paper or electronic self-report), STB return path (Set-Top Box return-path data), ACR fingerprint (Automatic Content Recognition audio/video fingerprinting), SDK telemetry (streaming app software development kit), pixel tracking (web/app pixel), or hybrid combination. Determines data fidelity and applicable use cases. [ENUM-REF-CANDIDATE: ppm_device|diary_form|stb_return_path|acr_fingerprint|sdk_telemetry|pixel_tracking|hybrid — 7 candidates stripped; promote to reference product] | Column data_collection_mechanism (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'The maximum number of days that raw audience measurement data collected under this methodology may be retained, as governed by privacy regulations (GDPR, CCPA) and MRC audit requirements. After this period, data must be anonymized or deleted. Drives data lifecycle management in the lakehouse. | Column data_retention_days (INT) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartApplicability rdf:type rdf:Property ;
    rdfs:label 'Daypart Applicability' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts for which this methodology produces valid audience estimates (e.g., \'early_morning, daytime, early_fringe, prime_time, late_news, overnight\'). Daypart is a standard time segment of the broadcast day used in ad scheduling and CPM pricing. Some methodologies may have reduced reliability in overnight or early morning dayparts. | Column daypart_applicability (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationMethod rdf:type rdf:Property ;
    rdfs:label 'Deduplication Method' ;
    rdfs:comment 'The method used to deduplicate audience reach across platforms or devices when this methodology is applied in cross-platform measurement: probabilistic (statistical modeling), deterministic (identity-matched), hybrid (combination), or none (single-platform only). Affects reported unique reach figures and frequency calculations. | Column deduplication_method (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicGranularity rdf:type rdf:Property ;
    rdfs:label 'Demographic Granularity' ;
    rdfs:comment 'Describes the level of demographic segmentation this methodology supports (e.g., \'age_sex_only\', \'age_sex_income\', \'full_psychographic\', \'household_level_only\'). Determines which audience segments can be reported for ad targeting, TRP calculations, and upfront sales guarantees. | Column demographic_granularity (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageLevel rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Level' ;
    rdfs:comment 'The geographic scope at which this methodology provides valid audience measurement: national (US-wide), dma (Designated Market Area), regional, local (sub-DMA), international, or global. Determines applicability for local vs. national ad sales, retransmission consent negotiations, and blackout enforcement. | Column geographic_coverage_level (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSweepsApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Applicable' ;
    rdfs:comment 'Indicates whether this measurement methodology is used or enhanced during Nielsen Sweeps periods (February, May, July, November) — the intensive ratings measurement periods used to set local advertising rates. Diary methodology is exclusively sweeps-based in many markets; PPM operates year-round. | Column is_sweeps_applicable (BOOLEAN) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodologyCode rdf:type rdf:Property ;
    rdfs:label 'Methodology Code' ;
    rdfs:comment 'Short, externally-recognized alphanumeric code uniquely identifying the measurement methodology (e.g., NIELSEN_PPM, NIELSEN_DIARY, STB_DATA, ACR, STREAMING_TELEMETRY, HYBRID_XPLATFORM). Used as a stable business key across systems including Nielsen Media Research Platform and Adobe Experience Platform integrations. | Column methodology_code (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Methodology Description' ;
    rdfs:comment 'Detailed narrative description of how the measurement methodology works, including data collection mechanism, panel recruitment approach, weighting procedures, and any known limitations. Used by ad sales teams, programming analysts, and regulatory compliance officers to understand how viewership and rating records are produced. | Column methodology_description (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyName rdf:type rdf:Property ;
    rdfs:label 'Methodology Name' ;
    rdfs:comment 'Full human-readable name of the audience measurement methodology (e.g., \'Nielsen Portable People Meter\', \'Nielsen Diary\', \'Set-Top Box Data\', \'Automatic Content Recognition\', \'Streaming Platform Telemetry\', \'Hybrid Cross-Platform Measurement\'). Used in reports, dashboards, and regulatory filings. | Column methodology_name (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyStatus rdf:type rdf:Property ;
    rdfs:label 'Methodology Status' ;
    rdfs:comment 'Current lifecycle status of the measurement methodology within the organization\'s audience measurement framework. Active methodologies are used in current ratings and GRP/TRP reporting; deprecated or retired methodologies are retained for historical record interpretation; pilot methodologies are under evaluation for MRC accreditation. | Column methodology_status (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyType rdf:type rdf:Property ;
    rdfs:label 'Methodology Type' ;
    rdfs:comment 'Categorical classification of the measurement approach: passive (device-based passive capture such as PPM or STB), diary (self-reported viewer logs), census (full population streaming telemetry), hybrid (cross-platform combination), panel (statistically sampled panel), or acr (Automatic Content Recognition fingerprinting). Governs how ratings and GRP/TRP calculations are interpreted. | Column methodology_type (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrcAccreditationCode rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Code' ;
    rdfs:comment 'The official accreditation reference number issued by the Media Rating Council (MRC) for this measurement methodology. Used in regulatory filings, ad sales contracts, and audit documentation to reference the specific MRC accreditation certificate. | Column mrc_accreditation_code (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyComplianceFramework rdf:type rdf:Property ;
    rdfs:label 'Privacy Compliance Framework' ;
    rdfs:comment 'Comma-separated list of privacy and data protection frameworks under which this methodology\'s data collection and processing is compliant (e.g., \'GDPR, CCPA, COPPA, TCPA\'). GDPR governs EU audience data; CCPA governs California viewer data; COPPA governs children\'s content measurement. Required for regulatory reporting and data governance. | Column privacy_compliance_framework (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLatencyHours rdf:type rdf:Property ;
    rdfs:label 'Reporting Latency Hours' ;
    rdfs:comment 'The typical number of hours between the audience exposure event and the availability of processed, reportable ratings data using this methodology. Nielsen PPM typically delivers overnight ratings within 24 hours; diary methodology may have 2–4 week latency. Critical for ad sales makegoods, scatter market decisions, and programming adjustments. | Column reporting_latency_hours (INT) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Sample Size Minimum' ;
    rdfs:comment 'The minimum number of panelists or measurement units required for this methodology to produce statistically valid audience estimates. Below this threshold, ratings data is considered unreliable and may be suppressed or flagged. Enforced per MRC accreditation requirements and Nielsen panel design standards. | Column sample_size_minimum (INT) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'The ideal or design target number of panelists or measurement units for this methodology to achieve the desired statistical confidence level and margin of error. Used in panel management and methodology performance monitoring against MRC accreditation benchmarks. | Column sample_size_target (INT) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorMethodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Vendor Methodology Version' ;
    rdfs:comment 'The vendor-assigned version identifier for this measurement methodology (e.g., \'PPM v3.2\', \'C3\', \'C7\', \'P2+ 2023\'). Version changes may affect historical comparability of ratings data and require restatement of audience guarantees. Critical for audit trails and makegood calculations. | Column vendor_methodology_version (STRING) in audience.measurement_methodology' ;
    rdfs:domain ind:MeasurementMethodology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle state of the segment governing whether it is available for use in ad targeting, campaign activation, or content personalization. \'draft\' indicates under construction; \'pending_review\' awaits compliance or data governance approval; \'active\' is live and deployable; \'inactive\' is suspended; \'archived\' is retired. | Column activation_status (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Code' ;
    rdfs:comment 'The segment identifier as defined and managed within Adobe Experience Platform (AEP). Used for digital audience activation, personalization journeys, and cross-channel targeting. Enables synchronization between the internal audience_segment master record and the AEP segment definition for OTT and digital platforms. | Column aep_segment_code (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'Business-facing category grouping segments for portfolio management and reporting (e.g., \'Ad Targeting\', \'Programming Strategy\', \'Content Personalization\', \'Subscriber Retention\', \'Regulatory Reporting\'). Enables segment library organization in Salesforce Media Cloud and Adobe AEP. [ENUM-REF-CANDIDATE: ad_targeting|programming_strategy|content_personalization|subscriber_retention|regulatory_reporting|audience_research — promote to reference product] | Column segment_category (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentGenreAffinity rdf:type rdf:Property ;
    rdfs:label 'Content Genre Affinity' ;
    rdfs:comment 'Primary content genre(s) this segment shows strong viewership affinity toward, used for programming strategy alignment and contextual ad targeting (e.g., \'drama,sports,news\'). Sourced from Nielsen viewing behavior data or Adobe AEP content interaction signals. Informs content acquisition decisions and ad pod placement strategy. | Column content_genre_affinity (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'The rule-based or SQL/JSON expression that defines segment membership criteria as implemented in Adobe AEP or Nielsen. Captures the inclusion/exclusion logic (e.g., age range, viewing frequency thresholds, content genre affinity, platform usage) used to qualify audience members into this segment. | Column definition_logic (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReachUnit rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach Unit' ;
    rdfs:comment 'Unit of measurement for the estimated_reach figure. \'persons\' aligns with Nielsen PUT (Persons Using Television) methodology; \'households\' aligns with HUT (Homes Using Television); \'devices\' applies to digital/OTT platform segments measured by device-level identity. | Column estimated_reach_unit (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Gender composition target for the segment as defined in Nielsen demographic cells and ad sales targeting parameters. \'all\' indicates gender-neutral targeting. Used in GRP (Gross Rating Point) and TRP (Target Rating Point) calculations for ad campaign planning. | Column gender_target (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hutPutBasis rdf:type rdf:Property ;
    rdfs:label 'Hut Put Basis' ;
    rdfs:comment 'Indicates whether the segment\'s reach and rating metrics are calculated on a HUT (Homes Using Television) or PUT (Persons Using Television) basis. HUT is household-level measurement; PUT is person-level. This distinction governs how GRP/TRP values are interpreted and how the segment is applied in Nielsen-based ad sales planning. | Column hut_put_basis (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'Household income tier associated with the segment\'s demographic composition, used in premium ad targeting and CPM (Cost Per Mille) pricing. Expressed as a standardized range label (e.g., \'$75K-$100K HHI\', \'$100K+ HHI\'). Sourced from Nielsen MRI-Simmons or first-party subscriber data. [ENUM-REF-CANDIDATE: under_25k|25k_50k|50k_75k|75k_100k|100k_150k|150k_plus — promote to reference product] | Column income_bracket (STRING) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDaiEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dai Eligible' ;
    rdfs:comment 'Indicates whether this segment is approved and technically configured for use in DAI (Dynamic Ad Insertion) workflows on OTT and streaming platforms. DAI-eligible segments can be activated in real-time ad decisioning systems integrated with Akamai CDN and programmatic ad servers for addressable advertising. | Column is_dai_eligible (BOOLEAN) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsValidated rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Validated' ;
    rdfs:comment 'Indicates whether this segment\'s reach and demographic composition estimates have been validated using Nielsen Sweeps period data (the intensive ratings measurement periods in February, May, July, and November). Sweeps-validated segments carry higher confidence for upfront ad sales commitments and programming decisions. | Column is_sweeps_validated (BOOLEAN) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership, reach estimates, and demographic composition were last recalculated from source data. Used to assess data freshness for ad sales proposals and campaign activation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column last_refresh_timestamp (TIMESTAMP) in audience.segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programmaticTargetableFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Targetable Flag' ;
    rdfs:comment 'Flag indicating segment is targetable in programmatic' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentTitleId rdf:type rdf:Property ;
    rdfs:label 'Content Title Id' ;
    rdfs:comment 'Reference to the content title or program for which this cross-platform audience measurement is recorded. Links to the content master data product in the Content domain. | Column content_title_id (BIGINT) in content.cross_platform_measurement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:measurementAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Measurement Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cross-platform measurement requires specialized analysts to perform deduplication, validate MRC-accredited methodologies, reconcile linear/OTT/MVPD impressions, and certify total audience metrics. Ana | Column measurement_analyst_employee_id (BIGINT) in workforce.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coViewingAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Co Viewing Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to account for co-viewing behavior (multiple persons watching on a single device/screen), particularly relevant for connected TV and OTT platforms. Values greater than 1.0 indicate upward adjustment for co-viewing. Sourced from Nielsen co-viewing methodology. | Column co_viewing_adjustment_factor (DECIMAL(8,6)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformGrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Grp' ;
    rdfs:comment 'Gross Rating Point (GRP) calculated across all measured platforms, representing the sum of ratings for all platform exposures within the target universe. Equals total impressions divided by the target universe population, multiplied by 100. Primary audience currency for converged TV ad buying. | Column cross_platform_grp (DECIMAL(10,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformTrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Trp' ;
    rdfs:comment 'Target Rating Point (TRP) calculated across all measured platforms for the specified target demographic segment. Measures GRP within the defined target audience, used for demographic-specific ad buying and campaign performance evaluation. | Column cross_platform_trp (DECIMAL(10,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyVersion rdf:type rdf:Property ;
    rdfs:label 'Currency Version' ;
    rdfs:comment 'Version identifier of the audience measurement currency standard applied to this record (e.g., \'Nielsen ONE v2.1\', \'Comscore Campaign Ratings v3.0\'). Supports multi-currency and currency transition tracking as the industry evolves from legacy Nielsen C3/C7 to cross-platform currencies. | Column currency_version (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Pipe-delimited list of operational source systems that contributed data to this cross-platform measurement record (e.g., \'Nielsen Media Research Platform|Adobe Experience Platform\'). Supports data lineage, audit, and methodology transparency requirements. | Column data_source_systems (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicatedReach rdf:type rdf:Property ;
    rdfs:label 'Deduplicated Reach' ;
    rdfs:comment 'Total count of unique, unduplicated individuals (persons) who were exposed to the content or campaign across all measured platforms within the measurement period. Core audience currency metric for converged TV buying. Expressed as absolute person count. | Column deduplicated_reach (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Primary distribution model classification for the content being measured: \'linear\' for traditional scheduled broadcast; \'vod\' for generic on-demand; \'svod\' for subscription streaming; \'avod\' for ad-supported streaming; \'tvod\' for transactional on-demand; \'fast\' for free ad-supported streaming TV; \'social\' for social video platforms. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|fast|social — 7 candidates stripped; promote to reference product] | Column distribution_type (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelImpressions rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Impressions' ;
    rdfs:comment 'Audience impressions attributed to Free Ad-Supported Streaming Television (FAST) channels within the measurement period. Represents the growing ad-supported streaming audience segment. | Column fast_channel_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDataSuppressed rdf:type rdf:Property ;
    rdfs:label 'Is Data Suppressed' ;
    rdfs:comment 'Indicates whether this measurement record has been suppressed from reporting due to insufficient panel sample size, MRC minimum reporting thresholds, or privacy regulations (GDPR/CCPA). Suppressed records are retained for audit but excluded from audience currency reporting. | Column is_data_suppressed (BOOLEAN) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrcAccredited rdf:type rdf:Property ;
    rdfs:label 'Is Mrc Accredited' ;
    rdfs:comment 'Indicates whether this measurement was produced using a methodology that holds current Media Rating Council (MRC) accreditation for cross-platform measurement. MRC accreditation is required for use as official audience currency in upfront and scatter market ad transactions. | Column is_mrc_accredited (BOOLEAN) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearImpressions rdf:type rdf:Property ;
    rdfs:label 'Linear Impressions' ;
    rdfs:comment 'Audience impressions attributed to traditional linear broadcast television (over-the-air, cable, satellite) within the measurement period. Component of the platform-level audience breakdown. | Column linear_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this cross-platform measurement record, used in reporting, ad sales proposals, and audience currency reconciliation. Sourced from Nielsen Media Research Platform or internal measurement workflow. | Column measurement_reference_number (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The principal real-world timestamp representing when the audience measurement observation period was captured or the measurement run was executed. Distinct from record audit timestamps. | Column measurement_timestamp (TIMESTAMP) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mvpdImpressions rdf:type rdf:Property ;
    rdfs:label 'Mvpd Impressions' ;
    rdfs:comment 'Audience impressions attributed to Multichannel Video Programming Distributor (MVPD) and virtual MVPD (vMVPD) platforms, including cable, satellite, and virtual pay-TV providers within the measurement period. | Column mvpd_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating' ;
    rdfs:comment 'The Nielsen Rating for the content or program within the measurement period, representing the percentage of all television households or persons in the universe tuned to the program. The foundational audience currency metric for linear broadcast. | Column nielsen_rating (DECIMAL(8,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ottStreamingImpressions rdf:type rdf:Property ;
    rdfs:label 'Ott Streaming Impressions' ;
    rdfs:comment 'Audience impressions attributed to Over-The-Top (OTT) and Subscription Video On Demand (SVOD) streaming platforms within the measurement period. Includes authenticated streaming on connected TV, mobile, and desktop devices. | Column ott_streaming_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelSampleSize rdf:type rdf:Property ;
    rdfs:label 'Panel Sample Size' ;
    rdfs:comment 'Number of panel households or persons in the Nielsen (or equivalent vendor) measurement panel that contributed to this cross-platform measurement. Indicates statistical reliability; low sample sizes may trigger data suppression per MRC minimum reporting standards. | Column panel_sample_size (INT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialVideoImpressions rdf:type rdf:Property ;
    rdfs:label 'Social Video Impressions' ;
    rdfs:comment 'Audience impressions attributed to social video platforms (e.g., YouTube, Facebook Video, TikTok, Instagram Reels) within the measurement period. Enables full cross-platform audience aggregation. | Column social_video_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetUniverseSize rdf:type rdf:Property ;
    rdfs:label 'Target Universe Size' ;
    rdfs:comment 'The estimated total population size of the target demographic universe used as the denominator for GRP and TRP calculations. Sourced from Nielsen universe estimates updated annually. | Column target_universe_size (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Market Distribution Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for this market-partner distribution agreement record | Column market_distribution_agreement_id (BIGINT) in audience.market_distribution_agreement' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date when this market-specific agreement was most recently renewed or renegotiated. | Column last_renewal_date (DATE) in audience.market_distribution_agreement' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextNegotiationDate rdf:type rdf:Property ;
    rdfs:label 'Next Negotiation Date' ;
    rdfs:comment 'Scheduled date for the next contract renegotiation or renewal discussion for this market-partner relationship. | Column next_negotiation_date (DATE) in audience.market_distribution_agreement' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penetrationRate rdf:type rdf:Property ;
    rdfs:label 'Penetration Rate' ;
    rdfs:comment 'Percentage of total TV households in the market that subscribe to this partner\'s service. Calculated as subscriber_count divided by market TV household universe. | Column penetration_rate (DECIMAL(8,4)) in audience.market_distribution_agreement' ;
    rdfs:domain ind:MarketDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classification of the partner\'s performance in this specific market based on subscriber growth, payment compliance, and audience delivery metrics. | Column performance_tier (STRING) in audience.market_distribution_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentDemographicAppealId rdf:type rdf:Property ;
    rdfs:label 'Talent Demographic Appeal Id' ;
    rdfs:comment 'Unique surrogate identifier for each talent demographic appeal measurement record. Primary key for the association. | Column talent_demographic_appeal_id (BIGINT) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealIndex rdf:type rdf:Property ;
    rdfs:label 'Appeal Index' ;
    rdfs:comment 'Normalized appeal index score measuring the talent\'s overall appeal within this specific demographic segment. Scale and methodology aligned with industry standards for talent appeal measurement. | Column appeal_index (DECIMAL(10,4)) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awarenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Awareness Percentage' ;
    rdfs:comment 'Percentage of the demographic segment that is aware of or recognizes this talent. Key metric for talent reach and recognition within the target demographic. | Column awareness_percentage (DECIMAL(5,2)) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:castingRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Casting Recommendation Flag' ;
    rdfs:comment 'Indicates whether this talent is recommended for casting in content targeting this demographic segment based on appeal thresholds. Used by casting directors and programming teams. | Column casting_recommendation_flag (BOOLEAN) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceInterval rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval' ;
    rdfs:comment 'Statistical confidence interval (margin of error) for the appeal metrics in this measurement, expressed as a percentage. Used to assess measurement precision. | Column confidence_interval (DECIMAL(5,2)) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:favorabilityRating rdf:type rdf:Property ;
    rdfs:label 'Favorability Rating' ;
    rdfs:comment 'Favorability or likability rating of the talent among respondents in this demographic segment who are aware of the talent. Measures positive sentiment. | Column favorability_rating (DECIMAL(10,4)) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when this appeal measurement was conducted or published. Critical for tracking appeal trends over time and ensuring measurement currency. | Column measurement_date (DATE) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementVendor rdf:type rdf:Property ;
    rdfs:label 'Measurement Vendor' ;
    rdfs:comment 'The research vendor or organization that conducted the appeal measurement (e.g., Marketing Evaluations Inc., Nielsen, custom internal research). Used for data provenance and methodology validation. | Column measurement_vendor (STRING) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qScore rdf:type rdf:Property ;
    rdfs:label 'Q Score' ;
    rdfs:comment 'The Marketing Evaluations Q Score for this talent within this demographic segment. Measures familiarity and appeal, used industry-wide for talent valuation and casting decisions. | Column q_score (DECIMAL(10,4)) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The directional trend of this talent\'s appeal within this demographic compared to prior measurements (Rising, Stable, Declining). Used for talent investment and booking strategy. | Column trend_direction (STRING) in audience.talent_demographic_appeal' ;
    rdfs:domain ind:TalentDemographicAppeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentRegulatoryComplianceId rdf:type rdf:Property ;
    rdfs:label 'Segment Regulatory Compliance Id' ;
    rdfs:comment 'Unique surrogate identifier for this segment-obligation compliance record. Primary key. | Column segment_regulatory_compliance_id (BIGINT) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Audience Segment Id' ;
    rdfs:comment 'Foreign key to audience_segment. Part of the natural key. | Column audience_segment_id (BIGINT) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings from the most recent compliance audit. Documents any violations, concerns, or confirmations of compliance. Used for audit trail and remediation tracking. | Column audit_findings (STRING) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutHonored rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored' ;
    rdfs:comment 'Indicates whether California Consumer Privacy Act (CCPA) opt-out signals are honored when activating this segment for California residents. When True, individuals who have exercised their CCPA right to opt out of sale/sharing of personal information are excluded from segment activation. Required for compliance with CCPA and its amendment CPRA. [Moved from audience_segment: CCPA opt-out handling is a compliance attribute specific to the CCPA regulatory obligation. This should be tracked in the segment-obligation compliance relationship where it can be audited, dated, and linked to the specific CCPA obligation record. The segment itself shouldn\'t carry obligation-specific compliance flags.] | Column ccpa_opt_out_honored (BOOLEAN) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this segment was deactivated or removed from use under this obligation. Null if segment remains active. Used to track compliance history. | Column deactivation_date (DATE) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiration Date' ;
    rdfs:comment 'Date when any granted exemption expires and full compliance is required. Null if no exemption or if exemption is permanent. | Column exemption_expiration_date (DATE) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR (General Data Protection Regulation) Article 6 lawful basis under which audience data is processed to build and activate this segment for EU audiences. \'consent\' requires explicit opt-in; \'legitimate_interest\' requires a balancing test; \'contract\' applies to subscriber-based segments; \'not_applicable\' for non-EU segments. Required for regulatory compliance reporting. [Moved from audience_segment: GDPR lawful basis is specific to the GDPR regulatory obligation and represents compliance metadata that belongs in the segment-obligation relationship. Different segments may have different lawful bases under GDPR, and this should be tracked as part of the compliance record with audit dates and status, not as a standalone attribute on the segment.] | Column gdpr_lawful_basis (STRING) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Coppa Restricted' ;
    rdfs:comment 'Indicates whether this segment is subject to COPPA (Children\'s Online Privacy Protection Act) restrictions, meaning it includes or may include children under 13. COPPA-restricted segments are prohibited from behavioral targeting and require parental consent mechanisms. Critical compliance flag for ad sales and digital activation workflows. [Moved from audience_segment: This boolean flag indicates COPPA applicability but doesn\'t capture the compliance relationship details. The segment_regulatory_compliance association should track the actual COPPA obligation (via regulatory_obligation_id) with full audit history, compliance status, and exemption basis. The flag in audience_segment can remain as a derived/cached indicator for quick filtering, but the authoritative compliance relationship lives in the association.] | Column is_coppa_restricted (BOOLEAN) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Deadline by which remediation actions must be completed to avoid penalties or enforcement action. Null if no remediation required. | Column remediation_due_date (DATE) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of corrective actions planned or in progress to address any compliance gaps. Null if segment is compliant or exempt. | Column remediation_plan (STRING) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Officer' ;
    rdfs:comment 'Name or employee ID of the compliance officer accountable for managing this segment-obligation compliance relationship. | Column responsible_compliance_officer (STRING) in audience.segment_regulatory_compliance' ;
    rdfs:domain ind:SegmentRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

