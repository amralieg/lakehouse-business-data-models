    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentRating rdf:type rdf:Property ;
    rdfs:label 'Agent Rating' ;
    rdfs:comment 'Rating of support agent (1-5)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
