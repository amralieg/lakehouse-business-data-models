    rdfs:comment 'Whether follow-up is required' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'NPS category (detractor, passive, promoter)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score (0-10)' ;
    rdfs:domain ind:CsatSurvey ;
    rdf:type owl:DatatypeProperty ;
