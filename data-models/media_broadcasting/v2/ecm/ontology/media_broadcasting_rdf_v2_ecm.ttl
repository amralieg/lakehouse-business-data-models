    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Indicates whether this asset is subject to specific regulatory compliance requirements (e.g., FCC equipment authorization, broadcast technical standards, data security regulations). | Column compliance_required (BOOLEAN) in technology.it_asset' ;
