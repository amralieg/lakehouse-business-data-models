    rdfs:range ind:Employee .

ind:quaternarySponsorshipModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Sponsorship Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the sponsorship record. | Column sponsorship_modified_by_user_employee_id (BIGINT) in workforce.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySponsorshipEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sponsorship Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for managing this sponsorship relationship. | Column sponsorship_employee_id (BIGINT) in workforce.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billboardCount rdf:type rdf:Property ;
    rdfs:label 'Billboard Count' ;
    rdfs:comment 'Number of billboard mentions or placements included in the sponsorship package. | Column billboard_count (INT) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorshipCode rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Code' ;
    rdfs:comment 'Business identifier or code for the sponsorship deal used in trafficking and billing systems. | Column sponsorship_code (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Detailed description of sponsorship deliverables including billboards, opens/closes, product integration, logo placement, mentions, and other sponsor benefits. | Column deliverables_description (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusive Category' ;
    rdfs:comment 'Product or service category for which the sponsor holds exclusivity rights (e.g., automotive, telecommunications, financial services). | Column exclusive_category (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
