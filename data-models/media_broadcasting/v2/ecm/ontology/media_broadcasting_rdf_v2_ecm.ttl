    rdfs:range xsd:boolean .

ind:blackoutZoneIndicator rdf:type rdf:Property ;
    rdfs:label 'Blackout Zone Indicator' ;
    rdfs:comment 'Flag indicating whether this grant defines a blackout zone where distribution is explicitly prohibited rather than authorized. | Column blackout_zone_indicator (BOOLEAN) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable Flag' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is required for this territorial grant. | Column carriage_fee_applicable_flag (BOOLEAN) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Verification Date' ;
    rdfs:comment 'Date when rights clearance was last verified for this territorial grant. | Column clearance_verification_date (DATE) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Grant Reference Code' ;
    rdfs:comment 'Business identifier for the territory grant, used in contracts and rights clearance documentation. | Column grant_reference_code (STRING) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'Type of territorial grant indicating exclusivity level. Exclusive grants prohibit other licensees in the territory; non-exclusive allows multiple licensees; co-exclusive allows a limited number of licensees; holdback restricts distribution during a specific window; reserved indicates rights retained by licensor. | Column grant_type (STRING) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestriction rdf:type rdf:Property ;
    rdfs:label 'Holdback Restriction' ;
    rdfs:comment 'Description of any holdback period or exclusivity restrictions that limit distribution during specific windows or in relation to other platforms. For example, a 90-day theatrical holdback before SVOD release. | Column holdback_restriction (STRING) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRestriction rdf:type rdf:Property ;
    rdfs:label 'Language Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes specifying which language versions are covered by this grant. Null if all language versions are included. | Column language_restriction (STRING) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Linear Rights Flag' ;
    rdfs:comment 'Indicates whether traditional scheduled broadcast (linear) distribution rights are included in this grant. | Column linear_rights_flag (BOOLEAN) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaFormatRestriction rdf:type rdf:Property ;
    rdfs:label 'Media Format Restriction' ;
    rdfs:comment 'Restrictions on media formats or technical specifications (e.g., HD only, 4K excluded, standard definition only). Null if no format restrictions apply. | Column media_format_restriction (STRING) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required Flag' ;
    rdfs:comment 'Indicates whether retransmission consent (rebroadcast authorization) is required for this territorial grant under FCC regulations. | Column retransmission_consent_required_flag (BOOLEAN) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Flag' ;
    rdfs:comment 'Indicates whether Subscription Video On Demand distribution rights are included in this grant. | Column svod_rights_flag (BOOLEAN) in partner.territory_grant' ;
    rdfs:domain ind:TerritoryGrant ;
