    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointPath rdf:type rdf:Property ;
    rdfs:label 'Endpoint Path' ;
    rdfs:comment 'The URI path of the API endpoint (e.g., /api/v2/content/search, /api/v1/playback/authorize). This is the resource path exposed to API consumers. | Column endpoint_path (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
