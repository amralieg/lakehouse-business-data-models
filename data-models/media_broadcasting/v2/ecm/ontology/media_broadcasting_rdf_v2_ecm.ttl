    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Business-assigned unique employee number used for HR operations, payroll, and external reporting. Format: two-letter prefix followed by six digits (e.g., MB123456). | Column employee_number (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employee\'s relationship with Media Broadcasting. Active indicates currently working; other statuses indicate various non-working states. | Column employment_status (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employee\'s employment arrangement. Determines benefits eligibility, work schedule expectations, and contract terms. | Column employment_type (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line1' ;
    rdfs:comment 'First line of the employee\'s residential address (street number and name). Used for payroll tax calculations, benefits administration, and emergency contact. | Column home_address_line1 (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line2' ;
    rdfs:comment 'Second line of the employee\'s residential address (apartment, suite, unit number). Optional field. Used for accurate mail delivery and address verification. | Column home_address_line2 (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the employee\'s residential address (e.g., USA, GBR, CAN). Used for international payroll, tax compliance, and global workforce analytics. | Column home_country_code (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePostalCode rdf:type rdf:Property ;
    rdfs:label 'Home Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the employee\'s residential address. Used for payroll tax calculations, benefits administration, and mail delivery. | Column home_postal_code (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Home State Province' ;
    rdfs:comment 'State, province, or region of the employee\'s residential address. Used for payroll tax withholding, benefits eligibility, and regional workforce reporting. | Column home_state_province (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrSystemCode rdf:type rdf:Property ;
    rdfs:label 'Hr System Code' ;
    rdfs:comment 'Unique identifier for this employee in the source HR system (SAP S/4HANA HR). Used for system integration, data reconciliation, and cross-system reference. | Column hr_system_code (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the employee\'s position within the organization. Used for compensation benchmarking, career pathing, and organizational structure analysis. [ENUM-REF-CANDIDATE: Entry|Associate|Mid|Senior|Lead|Manager|Director|VP|SVP|C-Level — 10 candidates stripped; promote to reference product] | Column job_level (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
