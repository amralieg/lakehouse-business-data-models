ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the location is situated. | Column city (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Business identifier code for the location used in production schedules and call sheets. Typically assigned by the location manager or production coordinator. | Column location_code (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the location owner requires specific production insurance coverage or certificates of insurance before filming can commence. | Column insurance_required_flag (BOOLEAN) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the location in decimal degrees format, used for mapping, navigation, and sunrise/sunset calculations. | Column latitude (DECIMAL(10,7)) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current lifecycle status of the location: scouted (identified by location scout), approved (approved for use by director/producer), contracted (agreement signed with owner), active (currently in use for shooting), wrapped (shooting completed), rejected (not suitable for production). | Column location_status (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location based on its physical characteristics and usage: practical interior (real indoor space), practical exterior (real outdoor space), backlot (studio-controlled outdoor set), remote (distant or hard-to-access site), international (foreign location), studio exterior (controlled outdoor studio space). | Column location_type (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the location in decimal degrees format, used for mapping, navigation, and logistics planning. | Column longitude (DECIMAL(10,7)) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerNotes rdf:type rdf:Property ;
    rdfs:label 'Manager Notes' ;
    rdfs:comment 'Free-text notes and observations from the location manager regarding access, restrictions, special requirements, or other relevant production considerations. | Column manager_notes (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or title of the production location (e.g., \'Downtown Warehouse District\', \'Malibu Beach House\', \'Historic City Hall\'). | Column location_name (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseAssessment rdf:type rdf:Property ;
    rdfs:label 'Noise Assessment' ;
    rdfs:comment 'Assessment of ambient noise levels at the location: quiet (minimal background noise, suitable for dialogue recording), moderate (some noise, may require sound treatment), noisy (significant noise, requires ADR or sound mitigation), unacceptable (excessive noise, unsuitable for production). | Column noise_assessment (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Email' ;
    rdfs:comment 'Primary email address for the location owner or authorized representative for contract and coordination communications. | Column owner_contact_email (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Phone' ;
    rdfs:comment 'Primary phone number for the location owner or authorized representative for coordination and emergency contact during production. | Column owner_contact_phone (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Number of vehicle parking spaces available at or near the location for crew, cast, and equipment trucks. | Column parking_capacity (INT) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitAuthority rdf:type rdf:Property ;
    rdfs:label 'Permit Authority' ;
    rdfs:comment 'Name of the governmental or regulatory authority responsible for issuing filming permits for this location (e.g., \'Los Angeles Film Office\', \'NYC Mayor Office of Media and Entertainment\'). | Column permit_authority (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Date when the filming permit expires and is no longer valid for production use. | Column permit_expiry_date (DATE) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date when the filming permit was officially issued by the permitting authority. | Column permit_issue_date (DATE) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit or authorization number issued by the permitting authority for filming at this location. | Column permit_number (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current status of filming permits required for this location: not required (no permit needed), pending (application submitted), approved (permit granted), denied (permit rejected), expired (permit validity lapsed). | Column permit_status (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the location address. | Column postal_code (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerAvailability rdf:type rdf:Property ;
    rdfs:label 'Power Availability' ;
    rdfs:comment 'Assessment of electrical power availability at the location: grid (connected to utility power), generator required (no grid power, generators needed), limited (some power available but insufficient for full production), none (no power infrastructure). | Column power_availability (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broader geographic region or area classification (e.g., \'Southern California\', \'Pacific Northwest\', \'New England\') used for production planning and logistics. | Column region (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Restoration Required Flag' ;
    rdfs:comment 'Indicates whether the production is contractually obligated to restore the location to its original condition after filming concludes. | Column restoration_required_flag (BOOLEAN) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restroomFacilities rdf:type rdf:Property ;
    rdfs:label 'Restroom Facilities' ;
    rdfs:comment 'Assessment of restroom availability: on site (permanent facilities available), portable required (portable restrooms must be brought in), nearby (facilities within walking distance), none (no facilities available). | Column restroom_facilities (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Date' ;
    rdfs:comment 'Date when the safety assessment was conducted by the production safety officer or third-party assessor. | Column safety_assessment_date (DATE) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Status' ;
    rdfs:comment 'Status of the safety and risk assessment conducted for this location: not assessed (no evaluation performed), in progress (assessment underway), passed (meets safety requirements), failed (does not meet safety standards), conditional (approved with specific safety measures required). | Column safety_assessment_status (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoutApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Scout Approval Status' ;
    rdfs:comment 'Approval status from the location scout assessment: pending (awaiting review), approved (meets production requirements), rejected (does not meet requirements), conditional (approved with specific conditions or modifications). | Column scout_approval_status (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the location. | Column state_province (STRING) in production.location' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterAvailability rdf:type rdf:Property ;
    rdfs:label 'Water Availability' ;
    rdfs:comment 'Assessment of water access at the location: available (connected to water supply), limited (some water but insufficient for full crew), trucked in required (no water infrastructure, must be transported), none (no water access). | Column water_availability (STRING) in production.location' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costTransactionId rdf:type rdf:Property ;
    rdfs:label 'Cost Transaction Id' ;
    rdfs:comment 'Primary key for cost_transaction | Column cost_transaction_id (BIGINT) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: Cost transactions must reference the GL account structure for financial posting, trial balance generation, and financial statement preparation. Replaces denormalized gl_account_code with FK to enforce | Column chart_of_accounts_id (BIGINT) in finance.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Production cost transactions generate or reference journal entries in the financial GL. Required for reconciliation between production spend tracking and financial ledger, mandatory for month-end clos | Column journal_entry_id (BIGINT) in finance.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:costTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Transaction Description' ;
    rdfs:comment 'Detailed description or narrative of the cost transaction, including purpose and context. | Column cost_transaction_description (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on the vendor invoice or billing document. | Column invoice_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Vendor invoice number or billing reference for this transaction. | Column invoice_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net transaction amount excluding taxes and other adjustments. | Column net_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the individual or entity receiving payment for this transaction (e.g., crew member, contractor, petty cash recipient). | Column payee_name (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which payment was made or is scheduled to be made for this transaction. | Column payment_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method used for payment: wire transfer, check, credit card, petty cash, ACH, or payroll. | Column payment_method (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the transaction: pending, approved, paid, cancelled, on hold, or rejected. | Column payment_status (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the transaction was posted to the general ledger in SAP. | Column posting_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the standard reporting currency (typically USD) for consolidated financial reporting. | Column reporting_currency_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA financial document number (FI/CO posting document) associated with this transaction. | Column sap_document_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'Line item number within the SAP document for granular traceability. | Column sap_line_item_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount associated with this transaction, if applicable. | Column tax_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary amount of the cost transaction in the original transaction currency. | Column transaction_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date on which the cost transaction was incurred or posted in the financial system. | Column transaction_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number or document reference for this cost entry. | Column transaction_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the cost transaction: purchase order, vendor invoice, petty cash disbursement, payroll charge, inter-company cost allocation, or credit memo. | Column transaction_type (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Id' ;
    rdfs:comment 'Primary key for insurance_policy | Column insurance_policy_id (BIGINT) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brokerContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When insurance brokers are internal employees (common in large media companies with in-house risk management), tracking for vendor management, compliance reporting, and contact continuity. | Column broker_contact_employee_id (BIGINT) in workforce.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:insurerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Insurer Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Insurance carriers are partners providing production insurance (E&O, general liability, equipment). Linking enables tracking all policies with that carrier, claims history analysis, renewal negotiatio | Column insurer_partner_id (BIGINT) in partner.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:additionalInsuredParties rdf:type rdf:Property ;
    rdfs:label 'Additional Insured Parties' ;
    rdfs:comment 'List of additional parties named as insured under this policy, such as broadcasters, distributors, or co-production partners. Comma-separated list. | Column additional_insured_parties (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for the insurance broker handling this policy. Used for policy inquiries and claims coordination. | Column broker_contact_email (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary phone number for the insurance broker handling this policy. | Column broker_contact_phone (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'The name of the insurance broker or agent who facilitated the policy placement. | Column broker_name (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'The date when the Certificate of Insurance was issued for this policy. | Column certificate_issue_date (DATE) in production.insurance_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfInsuranceIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Insurance Issued Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Insurance has been issued for this policy. Required for broadcaster delivery compliance and vendor contracts. | Column certificate_of_insurance_issued_flag (BOOLEAN) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Claim History Flag' ;
    rdfs:comment 'Indicates whether any claims have been filed against this policy. True if claims exist, False if no claims. | Column claim_history_flag (BOOLEAN) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequirementMetFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Met Flag' ;
    rdfs:comment 'Indicates whether this policy meets all broadcaster delivery and regulatory compliance requirements for the production. True if compliant, False if deficiencies exist. | Column compliance_requirement_met_flag (BOOLEAN) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'The maximum liability or coverage limit provided by this policy, expressed in the policy currency. | Column coverage_amount (DECIMAL(18,2)) in production.insurance_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Geographic territory or jurisdictions where the insurance coverage applies. May be worldwide or limited to specific countries/regions. | Column coverage_territory (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The deductible or excess amount that must be paid by the insured before the insurance coverage applies, expressed in the policy currency. | Column deductible_amount (DECIMAL(18,2)) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionsSummary rdf:type rdf:Property ;
    rdfs:label 'Exclusions Summary' ;
    rdfs:comment 'Summary of key exclusions or limitations in the insurance coverage. Describes what is NOT covered by this policy. | Column exclusions_summary (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the insurance premium payment is due to keep the policy in force. | Column payment_due_date (DATE) in production.insurance_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the full insurance policy document stored in the Media Asset Management (MAM) system or document repository. | Column policy_document_url (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Policy Effective Date' ;
    rdfs:comment 'The date when the insurance coverage begins and the policy becomes active. | Column policy_effective_date (DATE) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Policy Expiration Date' ;
    rdfs:comment 'The date when the insurance coverage ends and the policy is no longer in force. | Column policy_expiration_date (DATE) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The unique policy number assigned by the insurance carrier. This is the externally-known identifier for the policy. | Column policy_number (STRING) in production.insurance_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the insurance policy. Indicates whether the policy is in force, expired, or cancelled. | Column policy_status (STRING) in production.insurance_policy' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyTermDays rdf:type rdf:Property ;
    rdfs:label 'Policy Term Days' ;
    rdfs:comment 'The total duration of the insurance policy coverage period, measured in days. | Column policy_term_days (INT) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'The category of insurance coverage provided by this policy. Defines the risk domain covered. [ENUM-REF-CANDIDATE: cast_insurance|errors_and_omissions|general_liability|equipment_coverage|negative_film_protection|workers_compensation|completion_bond — 7 candidates stripped; promote to reference product] | Column policy_type (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'The total premium cost paid for this insurance policy, expressed in the policy currency. | Column premium_amount (DECIMAL(18,2)) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Policy Number' ;
    rdfs:comment 'The policy number of the previous insurance policy if this is a renewal. Null for new policies. | Column prior_policy_number (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this policy is a renewal of a previous policy. True if renewed, False if new policy. | Column renewal_flag (BOOLEAN) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Sap Policy Reference' ;
    rdfs:comment 'Reference number or identifier for this insurance policy in the SAP S/4HANA ERP system, used for financial reconciliation and cost tracking. | Column sap_policy_reference (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special conditions, endorsements, or riders attached to this policy that modify standard coverage terms. | Column special_conditions (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsFiled rdf:type rdf:Property ;
    rdfs:label 'Total Claims Filed' ;
    rdfs:comment 'The total number of insurance claims filed against this policy to date. | Column total_claims_filed (INT) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalClaimsPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Paid Amount' ;
    rdfs:comment 'The cumulative amount paid out by the insurer for all claims under this policy, expressed in the policy currency. | Column total_claims_paid_amount (DECIMAL(18,2)) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'The name of the underwriter at the insurance carrier who approved and underwrote this policy. | Column underwriter_name (STRING) in production.insurance_policy' ;
    rdfs:domain ind:InsurancePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionClearanceId rdf:type rdf:Property ;
    rdfs:label 'Production Clearance Id' ;
    rdfs:comment 'Unique identifier for the production clearance record. Primary key for tracking rights clearance throughout the clearance lifecycle. | Column production_clearance_id (BIGINT) in production.production_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionClearance .

ind:productionContentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Production Content Clearance Id' ;
    rdfs:comment 'FK to canonical content clearance for rights/legal | Column content_clearance_id (BIGINT) in content.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentClearance .

ind:productionContentContentClearanceId rdf:type rdf:Property ;
    rdfs:label 'Production Content Content Clearance Id' ;
    rdfs:comment 'FK reference to canonical source' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentClearance .

ind:requestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rights clearance requests track requester employee for workflow routing, approval escalation, and audit trails—standard in legal/business affairs operations. Replaces denormalized requested_by name. | Column requested_by_employee_id (BIGINT) in workforce.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rightsHolderPartnerId rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Rights clearances are obtained from IP owners, music publishers, stock footage libraries, and clearance agencies (partners). Linking enables tracking all clearances from that partner, payment processi | Column rights_holder_partner_id (BIGINT) in partner.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:attributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attribution Required Flag' ;
    rdfs:comment 'Indicates whether the clearance agreement requires on-screen or end-credit attribution to the rights holder or original creator. True if attribution is mandatory; false if not required. | Column attribution_required_flag (BOOLEAN) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attributionText rdf:type rdf:Property ;
    rdfs:label 'Attribution Text' ;
    rdfs:comment 'Exact text required for on-screen or end-credit attribution as specified by the rights holder. Must be displayed verbatim to comply with clearance terms. | Column attribution_text (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Number' ;
    rdfs:comment 'Business-facing unique reference number for the clearance record, used in legal documentation and rights management correspondence. | Column clearance_number (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of days for which the clearance is valid, calculated from effective_start_date to expiry_date. Used for rights management reporting and renewal planning. | Column duration_days (INT) in production.production_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Usd' ;
    rdfs:comment 'Total fee paid to the rights holder for clearance, expressed in US dollars. Includes all licensing costs, synchronization fees, master use fees, and any negotiated payments. | Column fee_usd (DECIMAL(15,2)) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipDescription rdf:type rdf:Property ;
    rdfs:label 'Ip Description' ;
    rdfs:comment 'Detailed description of the third-party intellectual property being cleared, including title, artist, duration, usage context, and specific elements requiring clearance. | Column ip_description (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaTypeCleared rdf:type rdf:Property ;
    rdfs:label 'Media Type Cleared' ;
    rdfs:comment 'Distribution channels and platforms for which the clearance is valid, specified as comma-separated values (e.g., broadcast,SVOD,AVOD,theatrical,FAST,social_media). Defines the media formats and delivery methods authorized under this clearance. | Column media_type_cleared (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the clearance requires periodic renewal or renegotiation. True if the clearance has a fixed term and must be renewed; false if perpetual or automatically renewing. | Column renewal_required_flag (BOOLEAN) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Any usage restrictions, limitations, or conditions imposed by the rights holder, such as prohibited contexts, content rating requirements, editorial approval rights, or blackout periods. | Column restrictions (STRING) in production.production_clearance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightslineClearanceReference rdf:type rdf:Property ;
    rdfs:label 'Rightsline Clearance Reference' ;
    rdfs:comment 'External identifier for this clearance record in the Rightsline rights and royalties management system. Used for cross-system reconciliation and audit trail. | Column rightsline_clearance_reference (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDescription rdf:type rdf:Property ;
    rdfs:label 'Usage Description' ;
    rdfs:comment 'Detailed description of how the intellectual property will be used within the production, including scene context, duration, prominence, and creative treatment. Critical for rights holder approval and compliance verification. | Column usage_description (STRING) in production.production_clearance' ;
    rdfs:domain ind:ProductionClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrProfile rdf:type rdf:Property ;
    rdfs:label 'Abr Profile' ;
    rdfs:comment 'The adaptive bitrate streaming profile or ladder configuration associated with this format specification. | Column abr_profile (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitDepth rdf:type rdf:Property ;
    rdfs:label 'Audio Bit Depth' ;
    rdfs:comment 'The number of bits used to represent each audio sample (e.g., 16, 24, 32). | Column audio_bit_depth (INT) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSampleRateKhz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Khz' ;
    rdfs:comment 'The audio sampling frequency in kilohertz (e.g., 48, 96, 192). | Column audio_sample_rate_khz (DECIMAL(6,2)) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastStandard rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard' ;
    rdfs:comment 'The broadcast television standard applicable to this format specification. | Column broadcast_standard (STRING) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromaSubsampling rdf:type rdf:Property ;
    rdfs:label 'Chroma Subsampling' ;
    rdfs:comment 'The chroma subsampling scheme defining color resolution relative to luminance (e.g., 4:2:0, 4:2:2, 4:4:4). | Column chroma_subsampling (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionStandard rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Standard' ;
    rdfs:comment 'The closed captioning or subtitle standard supported by this format (e.g., CEA-608, CEA-708, DVB Subtitles, TTML). | Column closed_caption_standard (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'List of regulatory or industry compliance requirements that this format specification satisfies (e.g., FCC broadcast standards, ATSC 3.0, DVB-T2). | Column compliance_requirements (STRING) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerFormat rdf:type rdf:Property ;
    rdfs:label 'Container Format' ;
    rdfs:comment 'The file container or wrapper format used to package video, audio, and metadata streams (e.g., MXF, MOV, MP4, TS). | Column container_format (STRING) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletFormatProfileReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Format Profile Reference' ;
    rdfs:comment 'The corresponding format profile identifier in Dalet Galaxy MAM system used for workflow orchestration and transcoding. | Column dalet_format_profile_reference (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCompatibility rdf:type rdf:Property ;
    rdfs:label 'Drm Compatibility' ;
    rdfs:comment 'The DRM systems or encryption standards compatible with this format specification (e.g., Widevine, PlayReady, FairPlay). | Column drm_compatibility (STRING) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'The current lifecycle status of this format specification within the production environment. | Column format_status (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the format specification by its intended use in the production workflow. | Column format_type (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrStandard rdf:type rdf:Property ;
    rdfs:label 'Hdr Standard' ;
    rdfs:comment 'The HDR standard applied to this format specification, or SDR if standard dynamic range. | Column hdr_standard (STRING) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultFormat rdf:type rdf:Property ;
    rdfs:label 'Is Default Format' ;
    rdfs:comment 'Boolean flag indicating whether this format specification is the default or recommended format for its type and resolution class. | Column is_default_format (BOOLEAN) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Notes' ;
    rdfs:comment 'Additional technical notes, specifications, or guidance for production teams using this format specification. | Column technical_notes (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeFormat rdf:type rdf:Property ;
    rdfs:label 'Timecode Format' ;
    rdfs:comment 'The timecode standard and format used for frame-accurate synchronization and editing. | Column timecode_format (STRING) in production.format_spec' ;
    rdfs:domain ind:FormatSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Video Bitrate Mbps' ;
    rdfs:comment 'The target or maximum video bitrate in megabits per second for this format specification. | Column video_bitrate_mbps (DECIMAL(10,2)) in production.format_spec' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Rating Submission Id' ;
    rdfs:comment 'Primary key for rating_submission | Column rating_submission_id (BIGINT) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRatingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rating Employee Id' ;
    rdfs:comment 'Identifier of the user or staff member who submitted the content for rating. | Column primary_rating_employee_id (BIGINT) in workforce.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'Date when the appeal was formally filed with the rating authority. | Column appeal_date (DATE) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether an appeal was filed against the initial rating decision. | Column appeal_filed_flag (BOOLEAN) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the appeal process. Upheld means original rating stands, overturned means rating was changed, modified means rating was adjusted. | Column appeal_outcome (STRING) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this rating is required for broadcast clearance and compliance with Federal Communications Commission (FCC) or equivalent regulatory requirements. | Column broadcast_clearance_required_flag (BOOLEAN) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the rating certificate expires and content must be re-submitted for re-rating if applicable. Null if certificate does not expire. | Column certificate_expiry_date (DATE) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Content Runtime Minutes' ;
    rdfs:comment 'Total runtime of the submitted content in minutes. | Column content_runtime_minutes (INT) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coppaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable Flag' ;
    rdfs:comment 'Indicates whether the content is subject to COPPA regulations due to being directed at children under 13. | Column coppa_applicable_flag (BOOLEAN) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutsDescription rdf:type rdf:Property ;
    rdfs:label 'Cuts Description' ;
    rdfs:comment 'Detailed description of the cuts, edits, or modifications required by the rating authority. Includes timecodes, scene descriptions, and nature of changes. | Column cuts_description (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cuts Required Flag' ;
    rdfs:comment 'Indicates whether the rating authority required editorial cuts or modifications to the content to achieve the assigned rating. | Column cuts_required_flag (BOOLEAN) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution Clearance Required Flag' ;
    rdfs:comment 'Indicates whether this rating is required for distribution clearance across platforms (theatrical, OTT, SVOD, AVOD, linear broadcast). | Column distribution_clearance_required_flag (BOOLEAN) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingAuthority rdf:type rdf:Property ;
    rdfs:label 'Rating Authority' ;
    rdfs:comment 'The governing body or ratings organization to which the content was submitted. Examples: MPA (Motion Picture Association), BBFC (British Board of Film Classification), FSK (Freiwillige Selbstkontrolle der Filmwirtschaft), CBFC (Central Board of Film Certification), ACB (Australian Classification Board), OFLC (Office of Film and Literature Classification), KMRB (Korea Media Rating Board), EIRIN (Film Classification and Rating Organization Japan), CSA (Conseil Supérieur de l\'Audiovisuel), DJCTQ (Departamento de Justiça Classificação Títulos e Qualificação), NICAM (Netherlands Institute for the Classification of Audiovisual Media), PEGI (Pan European Game Information), ESRB (Entertainment Software Rating Board), TV Parental Guidelines. [ENUM-REF-CANDIDATE: MPA|BBFC|FSK|CBFC|ACB|OFLC|KMRB|EIRIN|CSA|DJCTQ|NICAM|PEGI|ESRB|TV_PARENTAL_GUIDELINES — 14 candidates stripped; promote to reference product] | Column rating_authority (STRING) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingConditions rdf:type rdf:Property ;
    rdfs:label 'Rating Conditions' ;
    rdfs:comment 'Any conditions, restrictions, or requirements imposed by the rating authority for the assigned rating. Examples: specific scenes must be cut, warning messages required, restricted broadcast hours. | Column rating_conditions (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the rating authority completed its review and issued the final rating decision. | Column review_completion_date (DATE) in production.rating_submission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes or feedback provided by the rating authority reviewers regarding the content evaluation. May include guidance for future submissions. | Column reviewer_notes (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Amount' ;
    rdfs:comment 'Fee charged by the rating authority for processing the rating submission. | Column submission_fee_amount (DECIMAL(15,2)) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the submission fee. | Column submission_fee_currency_code (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'External reference number or tracking code assigned by the submitter or rating authority for this submission. | Column submission_reference_number (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the rating submission. Tracks progression from draft through submission, review, and final decision. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|appealed|withdrawn — 7 candidates stripped; promote to reference product] | Column submission_status (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedContentTitle rdf:type rdf:Property ;
    rdfs:label 'Submitted Content Title' ;
    rdfs:comment 'The title of the content as submitted to the rating authority. May differ from production working title. | Column submitted_content_title (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedContentVersion rdf:type rdf:Property ;
    rdfs:label 'Submitted Content Version' ;
    rdfs:comment 'Version identifier of the content submitted for rating (e.g., theatrical cut, director\'s cut, TV edit, unrated version). | Column submitted_content_version (STRING) in production.rating_submission' ;
    rdfs:domain ind:RatingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyProductionReportId rdf:type rdf:Property ;
    rdfs:label 'Daily Production Report Id' ;
