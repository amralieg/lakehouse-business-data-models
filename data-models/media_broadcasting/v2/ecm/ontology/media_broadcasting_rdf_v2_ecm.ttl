ind:complianceBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Budget Amount' ;
    rdfs:comment 'The budget amount allocated by this cost center specifically for compliance activities related to this regulatory obligation. Denominated in the cost center\'s currency. | Column compliance_budget_amount (DECIMAL(18,2)) in finance.cost_center_obligation_allocation' ;
