    rdfs:comment 'Percentage of sponsorship deliverables that have been completed and delivered to the sponsor. | Column fulfillment_percentage (DECIMAL(5,2)) in sales.sponsorship' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
