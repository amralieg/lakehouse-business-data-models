    rdfs:comment 'Date when the employee\'s work authorization (visa, permit) expires. Null for citizens and permanent residents. Used for compliance tracking and renewal planning. Format: yyyy-MM-dd. | Column work_authorization_expiry_date (DATE) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'Corporate email address assigned to the employee for business communications. Primary contact method for internal and external work-related correspondence. | Column work_email (STRING) in workforce.employee' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
