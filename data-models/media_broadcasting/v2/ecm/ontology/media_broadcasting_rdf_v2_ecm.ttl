    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hireRecommendation rdf:type rdf:Property ;
    rdfs:label 'Hire Recommendation' ;
    rdfs:comment 'Interviewer\'s recommendation on whether to proceed with hiring this candidate. | Column hire_recommendation (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewFormat rdf:type rdf:Property ;
    rdfs:label 'Interview Format' ;
    rdfs:comment 'Delivery method used to conduct the interview (phone, video conference, in-person meeting, or hybrid). | Column interview_format (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewLocation rdf:type rdf:Property ;
    rdfs:label 'Interview Location' ;
    rdfs:comment 'Physical location, office address, or virtual meeting platform where the interview was conducted. | Column interview_location (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewPanelSize rdf:type rdf:Property ;
    rdfs:label 'Interview Panel Size' ;
    rdfs:comment 'Total number of interviewers participating in this interview event. | Column interview_panel_size (INT) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewRecordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Interview Recording Available' ;
    rdfs:comment 'Indicates whether a recording of the interview is available for review, subject to consent and compliance requirements. | Column interview_recording_available (BOOLEAN) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewRoundNumber rdf:type rdf:Property ;
    rdfs:label 'Interview Round Number' ;
    rdfs:comment 'Sequential number indicating which round of interviews this represents in the hiring process (e.g., 1 for phone screen, 2 for panel interview, 3 for executive interview). | Column interview_round_number (INT) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStatus rdf:type rdf:Property ;
    rdfs:label 'Interview Status' ;
    rdfs:comment 'Current lifecycle status of the interview event itself. | Column interview_status (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewType rdf:type rdf:Property ;
    rdfs:label 'Interview Type' ;
    rdfs:comment 'Classification of the interview format and purpose conducted during this event. | Column interview_type (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewerCalibrationSession rdf:type rdf:Property ;
    rdfs:label 'Interviewer Calibration Session' ;
    rdfs:comment 'Reference to any calibration session where this interview was reviewed to ensure consistent evaluation standards across hiring panels. | Column interviewer_calibration_session (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingStatus rdf:type rdf:Property ;
    rdfs:label 'Scheduling Status' ;
    rdfs:comment 'Current state of the interview scheduling and execution process. | Column scheduling_status (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Summary of the candidate\'s key strengths and positive attributes identified during the interview. | Column strengths_summary (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Rating of the candidate\'s technical skills and job-specific competencies demonstrated during the interview. | Column technical_competency_rating (DECIMAL(3,2)) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoConferenceLink rdf:type rdf:Property ;
    rdfs:label 'Video Conference Link' ;
    rdfs:comment 'URL or meeting link for virtual interviews conducted via video conferencing platforms. | Column video_conference_link (STRING) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingTaskId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Task Id' ;
    rdfs:comment 'Unique identifier for each onboarding task assigned to a new hire or rehire at Media Broadcasting. Primary key for the onboarding task record. | Column onboarding_task_id (BIGINT) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingDependencyTaskId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Dependency Task Id' ;
    rdfs:comment 'Reference to another onboarding task that must be completed before this task can begin. Null if this task has no prerequisites. Enables sequencing of onboarding activities (e.g., system access setup depends on background check clearance). | Column dependency_task_id (BIGINT) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingTask .

ind:primaryOnboardingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Onboarding Employee Id' ;
    rdfs:comment 'Reference to the employee (new hire or rehire) to whom this onboarding task is assigned. Links to the employee master record. | Column primary_onboarding_employee_id (BIGINT) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPrerequisiteOnboardingTaskId rdf:type rdf:Property ;
    rdfs:label 'Primary Prerequisite Onboarding Task Id' ;
    rdfs:comment 'Self-referencing FK on onboarding_task (prerequisite_onboarding_task_id) | Column prerequisite_onboarding_task_id (BIGINT) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingTask .

ind:tertiaryOnboardingCompletedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Onboarding Completed By Employee Id' ;
    rdfs:comment 'Reference to the employee who actually completed the task. May differ from assigned owner if task was delegated or reassigned. Links to the employee master record. | Column tertiary_onboarding_completed_by_employee_id (BIGINT) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the onboarding task was assigned to the employee and owner. Typically triggered by hire date confirmation or completion of a prerequisite task. | Column assigned_date (DATE) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Role' ;
    rdfs:comment 'Functional role of the person assigned to complete this onboarding task. Indicates which department or function is responsible for task execution. [ENUM-REF-CANDIDATE: hr_specialist|it_administrator|hiring_manager|facilities_coordinator|training_coordinator|union_representative|payroll_administrator — 7 candidates stripped; promote to reference product] | Column assigned_owner_role (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Code' ;
    rdfs:comment 'Code identifying the regulatory or compliance requirement that mandates this onboarding task (e.g., IRCA for I-9 verification, FCC for broadcast license verification, OSHA for safety training, GDPR for data privacy training). Null for non-compliance tasks. | Column compliance_requirement_code (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Hours' ;
    rdfs:comment 'Estimated number of hours required to complete this onboarding task. Used for workload planning and resource allocation across HR, IT, and facilities teams. | Column estimated_hours (DECIMAL(5,2)) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBlockingTask rdf:type rdf:Property ;
    rdfs:label 'Is Blocking Task' ;
    rdfs:comment 'Boolean flag indicating whether this task must be completed before subsequent onboarding tasks can begin. True for critical path tasks (e.g., I-9 verification, background check clearance, system access setup); false for tasks that can proceed in parallel. | Column is_blocking_task (BOOLEAN) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'High-level category grouping onboarding tasks by functional area: compliance (I-9, background checks), hr_administration (benefits enrollment, payroll setup), it_provisioning (system access, equipment), facilities (badge, workspace), training (orientation, safety, compliance), union_processing (union card, dues setup). | Column task_category (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCode rdf:type rdf:Property ;
    rdfs:label 'Task Code' ;
    rdfs:comment 'Standardized code identifying the type of onboarding task (e.g., I9_VERIFY, BG_CHECK, EQUIP_PROV, SYS_ACCESS, BENEFITS_ENROLL, COMPLIANCE_TRAIN, FACILITY_ORIENT, UNION_CARD). Used for task categorization and reporting. | Column task_code (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the onboarding task, including specific actions required, documentation needed, and any special instructions for completion. | Column task_description (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Human-readable name of the onboarding task (e.g., I-9 Employment Eligibility Verification, Background Check Clearance, Equipment Provisioning, System Access Setup, Benefits Enrollment, Mandatory Compliance Training, Broadcast Facility Orientation, Union Card Processing). | Column task_name (STRING) in workforce.onboarding_task' ;
    rdfs:domain ind:OnboardingTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Union Membership Id' ;
    rdfs:comment 'Unique identifier for the union membership record. Primary key for tracking each employee\'s union affiliation within Media Broadcasting. | Column union_membership_id (BIGINT) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorUnionMembershipId rdf:type rdf:Property ;
    rdfs:label 'Prior Union Membership Id' ;
    rdfs:comment 'Self-referencing FK on union_membership (prior_union_membership_id) | Column prior_union_membership_id (BIGINT) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnionMembership .

ind:bargainingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Code' ;
    rdfs:comment 'Code identifying the specific bargaining unit to which this employee belongs. A bargaining unit is a group of employees with a clear community of interest who are represented by a union for collective bargaining purposes. Large employers may have multiple bargaining units for different job families, locations, or divisions. | Column bargaining_unit_code (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Cba Effective Start Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement became effective and binding. CBAs are typically negotiated for multi-year terms and this date marks the beginning of the current contract period. | Column cba_effective_start_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Cba Reference Code' ;
    rdfs:comment 'Reference code or identifier for the specific collective bargaining agreement that governs this employee\'s terms and conditions of employment. Multiple CBAs may exist for different unions, job classifications, or facilities within Media Broadcasting. | Column cba_reference_code (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Amount' ;
    rdfs:comment 'Amount of union dues deducted from the employee\'s paycheck each pay period. May be a flat amount or a percentage of gross earnings as specified in the collective bargaining agreement. Null if dues deduction is not authorized. | Column dues_deduction_amount (DECIMAL(10,2)) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duesDeductionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Authorized' ;
    rdfs:comment 'Indicates whether the employee has authorized automatic payroll deduction of union dues. True means the employee has signed a dues checkoff authorization form and Media Broadcasting deducts dues from each paycheck and remits to the union. False means the employee pays dues directly to the union. | Column dues_deduction_authorized (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duesDeductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Dues Deduction Frequency' ;
    rdfs:comment 'Frequency at which union dues are deducted from the employee\'s paycheck. Must align with the employee\'s pay frequency and union requirements. | Column dues_deduction_frequency (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairShareFeePayer rdf:type rdf:Property ;
    rdfs:label 'Fair Share Fee Payer' ;
    rdfs:comment 'Indicates whether the employee pays a fair share or agency fee rather than full union dues. In some jurisdictions and under some CBAs, non-members who are covered by the union contract must pay a fee to cover the cost of representation, but this fee is typically lower than full membership dues. This practice varies by state right-to-work laws and recent Supreme Court rulings. | Column fair_share_fee_payer (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceEligible rdf:type rdf:Property ;
    rdfs:label 'Grievance Eligible' ;
    rdfs:comment 'Indicates whether the employee is eligible to file grievances under the collective bargaining agreement\'s grievance and arbitration procedures. True for members in good standing. False for employees in probationary periods, suspended members, or those who have opted out of union representation where permitted by law. | Column grievance_eligible (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthWelfarePlanParticipant rdf:type rdf:Property ;
    rdfs:label 'Health Welfare Plan Participant' ;
    rdfs:comment 'Indicates whether the employee participates in a union-sponsored health and welfare benefit plan. Many unions maintain multi-employer health plans that provide medical, dental, vision, and other benefits funded by employer contributions. | Column health_welfare_plan_participant (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Initiation Fee Amount' ;
    rdfs:comment 'One-time initiation fee paid by the employee when joining the union. This fee covers administrative costs of processing the membership application and is typically specified in the union constitution. May be paid in a lump sum or through payroll deduction installments. | Column initiation_fee_amount (DECIMAL(10,2)) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiationFeePaidDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Fee Paid Date' ;
    rdfs:comment 'Date when the employee completed payment of the union initiation fee. Membership may not be fully active until this fee is paid in full. | Column initiation_fee_paid_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Job Classification Code' ;
    rdfs:comment 'Union job classification code that determines the employee\'s pay scale, work rules, and benefits under the collective bargaining agreement. Job classifications define specific roles, skill levels, and wage rates negotiated between the union and employer. | Column job_classification_code (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobClassificationTitle rdf:type rdf:Property ;
    rdfs:label 'Job Classification Title' ;
    rdfs:comment 'Descriptive title of the union job classification under which the employee is covered. Examples include Camera Operator, Audio Engineer, Production Assistant, Broadcast Technician, Grip, Electrician, Driver, etc. This may differ from the employee\'s official job title in HR systems. | Column job_classification_title (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date when the employee\'s union membership ended, either through withdrawal, termination of employment, or conversion to retired status. Null for active memberships. | Column membership_end_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Membership Initiation Date' ;
    rdfs:comment 'Date when the employee was formally initiated into union membership and became a full member. This may differ from the hire date if there was a probationary period or if the employee joined the union after starting employment. | Column membership_initiation_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionPlanParticipant rdf:type rdf:Property ;
    rdfs:label 'Pension Plan Participant' ;
    rdfs:comment 'Indicates whether the employee participates in a union-sponsored pension or retirement plan. Many unions, particularly in broadcasting and entertainment, maintain multi-employer pension plans funded by employer contributions negotiated in the CBA. | Column pension_plan_participant (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationaryPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Probationary Period End Date' ;
    rdfs:comment 'Date when the employee\'s probationary period under the collective bargaining agreement ends. During probation, employees may have limited rights and protections. After probation ends, employees typically gain full seniority rights, just cause protection, and full grievance rights. | Column probationary_period_end_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightToWorkState rdf:type rdf:Property ;
    rdfs:label 'Right To Work State' ;
    rdfs:comment 'Indicates whether the employee works in a right-to-work state where union membership and dues payment cannot be required as a condition of employment. This affects whether union security clauses in the CBA apply to this employee. | Column right_to_work_state (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorityDate rdf:type rdf:Property ;
    rdfs:label 'Seniority Date' ;
    rdfs:comment 'Date used to calculate the employee\'s seniority for purposes of layoffs, recalls, shift bidding, vacation scheduling, and other seniority-based rights under the collective bargaining agreement. May be the original hire date or adjusted for breaks in service. | Column seniority_date (DATE) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionLocalNumber rdf:type rdf:Property ;
    rdfs:label 'Union Local Number' ;
    rdfs:comment 'The local chapter or lodge number of the union to which the employee belongs. Local unions represent members in specific geographic regions or facilities and handle local grievances and contract administration. | Column union_local_number (STRING) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionStewardFlag rdf:type rdf:Property ;
    rdfs:label 'Union Steward Flag' ;
    rdfs:comment 'Indicates whether the employee serves as a union steward or shop steward. Union stewards are elected or appointed members who represent fellow workers in grievances, workplace disputes, and contract enforcement. Stewards have special protections under labor law and may have release time for union duties. | Column union_steward_flag (BOOLEAN) in workforce.union_membership' ;
    rdfs:domain ind:UnionMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:separationRecordId rdf:type rdf:Property ;
    rdfs:label 'Separation Record Id' ;
    rdfs:comment 'Unique identifier for the employee separation record. Primary key for the separation_record product. | Column separation_record_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySeparationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Separation Employee Id' ;
    rdfs:comment 'Reference to the employee who is separating from Media Broadcasting. Links to the employee master record. | Column primary_separation_employee_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorSeparationRecordId rdf:type rdf:Property ;
    rdfs:label 'Prior Separation Record Id' ;
    rdfs:comment 'Self-referencing FK on separation_record (prior_separation_record_id) | Column prior_separation_record_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeparationRecord .

ind:quaternaryQuinarySeparationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Quinary Separation Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or HR leader who approved the separation. Null if not yet approved. | Column quinary_separation_approved_by_employee_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryQuaternarySeparationInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quaternary Separation Initiated By Employee Id' ;
    rdfs:comment 'Reference to the employee or HR user who initiated the separation record in the system. | Column quaternary_separation_initiated_by_employee_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySeparationHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Separation Hr Business Partner Employee Id' ;
    rdfs:comment 'Reference to the HR business partner who managed the separation process and documentation. | Column tertiary_separation_hr_business_partner_employee_id (BIGINT) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:badgeAccessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Badge Access Revocation Date' ;
    rdfs:comment 'The date physical building access badges and credentials were deactivated. Important for facility security. | Column badge_access_revocation_date (DATE) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for COBRA health insurance continuation coverage under federal law. | Column cobra_eligible_flag (BOOLEAN) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Notification Date' ;
    rdfs:comment 'The date COBRA continuation coverage notification was sent to the employee. Required within 14 days of separation for compliance. | Column cobra_notification_date (DATE) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Date' ;
    rdfs:comment 'The date all company equipment was returned by the employee. Null if equipment has not been fully returned. | Column equipment_return_date (DATE) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Status' ;
    rdfs:comment 'Status of company equipment return: all returned (complete), partially returned (some items outstanding), not returned (no items returned), or not applicable (no equipment issued). | Column equipment_return_status (STRING) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed Flag' ;
    rdfs:comment 'Indicates whether an exit interview was conducted with the departing employee. True if completed, False if not completed or declined. | Column exit_interview_completed_flag (BOOLEAN) in workforce.separation_record' ;
