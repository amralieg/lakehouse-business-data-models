    rdfs:comment 'Column schedule_status_ref_id in media_broadcasting.scheduling.schedule_status_ref' ;
    rdfs:domain ind:ScheduleStatusRef ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingNetworkClearanceId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Network Clearance Id' ;
    rdfs:comment 'Primary key for network clearance' ;
    rdfs:domain ind:SchedulingNetworkClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliateStationId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Id' ;
    rdfs:comment 'FK to affiliate station' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateStation .

ind:confirmedByEmployeeId rdf:type rdf:Property ;
