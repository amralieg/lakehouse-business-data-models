ind:leagueId rdf:type rdf:Property ;
    rdfs:label 'League Id' ;
    rdfs:comment 'FK to sports_league' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SportsLeague .

ind:broadcastRightsHolder rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Holder' ;
    rdfs:comment 'Entity holding primary broadcast rights for the team.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conference rdf:type rdf:Property ;
    rdfs:label 'Conference' ;
    rdfs:comment 'Conference or division the team belongs to within the league.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
