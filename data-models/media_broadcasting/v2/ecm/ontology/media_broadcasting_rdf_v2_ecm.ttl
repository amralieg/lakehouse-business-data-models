    rdfs:range xsd:decimal .

ind:supportingEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Supporting Evidence Location' ;
    rdfs:comment 'File path, document repository reference, or Media Asset Management (MAM) location where supporting evidence and documentation are stored. | Column supporting_evidence_location (STRING) in partner.partner_dispute' ;
