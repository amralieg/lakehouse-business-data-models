    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateName rdf:type rdf:Property ;
    rdfs:label 'Candidate Name' ;
    rdfs:comment 'Full name of the political candidate featured in or sponsoring the advertisement. Required for candidate ads and independent expenditure communications. Null for issue-only advocacy. | Column candidate_name (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateOffice rdf:type rdf:Property ;
    rdfs:label 'Candidate Office' ;
    rdfs:comment 'The elected office being sought by the candidate (e.g., President, U.S. Senator, Governor, State Representative). Required for candidate-related political ads. | Column candidate_office (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Number' ;
    rdfs:comment 'Unique business identifier for the political ad disclosure record used in public inspection files and FCC reporting. Human-readable reference number for regulatory compliance tracking. | Column disclosure_number (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the political ad disclosure record. Tracks progression from initial filing through amendments to final archival in public inspection file. | Column disclosure_status (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Text' ;
    rdfs:comment 'The exact on-air or written disclosure statement required by FCC regulations identifying who paid for the advertisement. Must include \'paid for by\' language and sponsoring organization name. | Column disclosure_text (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDate rdf:type rdf:Property ;
    rdfs:label 'Election Date' ;
    rdfs:comment 'Date of the election for which the political advertisement is relevant. Used to determine lowest unit rate windows (45 days for primary, 60 days for general election). | Column election_date (DATE) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Type of election associated with the political advertisement. Determines applicable lowest unit rate periods and disclosure requirements. | Column election_type (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equalTimeObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Equal Time Obligation Flag' ;
    rdfs:comment 'Indicates whether this political ad triggers FCC equal time obligations requiring the broadcaster to offer comparable advertising opportunities to opposing candidates. | Column equal_time_obligation_flag (BOOLEAN) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowestUnitRateAmount rdf:type rdf:Property ;
    rdfs:label 'Lowest Unit Rate Amount' ;
    rdfs:comment 'The lowest unit rate available for the class of time and daypart in which the political ad aired. Used to verify compliance with FCC lowest unit rate requirements for candidate advertising. | Column lowest_unit_rate_amount (DECIMAL(15,2)) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowestUnitRateApplied rdf:type rdf:Property ;
    rdfs:label 'Lowest Unit Rate Applied' ;
    rdfs:comment 'Indicates whether the FCC-mandated lowest unit rate was applied to this political ad spot. Required to be true for candidate ads within 45 days of primary or 60 days of general election. | Column lowest_unit_rate_applied (BOOLEAN) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:politicalAdType rdf:type rdf:Property ;
    rdfs:label 'Political Ad Type' ;
    rdfs:comment 'Classification of the political advertisement according to FCC categories. Determines applicable disclosure requirements, lowest unit rate eligibility, and equal time obligations. | Column political_ad_type (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'The advertising rate class or tier under which the political ad was sold (e.g., preemptible, non-preemptible, fixed position). Determines lowest unit rate calculation and equal time obligations. | Column rate_class (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonableAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Reasonable Access Flag' ;
    rdfs:comment 'Indicates whether this ad purchase was made under FCC reasonable access requirements mandating broadcasters provide federal candidates reasonable access to purchase advertising time. | Column reasonable_access_flag (BOOLEAN) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the sponsoring organization for correspondence regarding the political advertising campaign. | Column sponsor_contact_email (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the sponsoring organization responsible for the political advertising campaign. | Column sponsor_contact_name (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact at the sponsoring organization. Required for FCC public inspection file and reasonable access compliance. | Column sponsor_contact_phone (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Organization' ;
    rdfs:comment 'Legal name of the organization sponsoring or paying for the political advertisement. May be a candidate committee, PAC, super PAC, issue advocacy group, or independent expenditure committee. | Column sponsoring_organization (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateCharged rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Charged' ;
    rdfs:comment 'The actual rate charged for the political ad spot. Must comply with lowest unit rate requirements during pre-election windows for candidate ads. | Column spot_rate_charged (DECIMAL(15,2)) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationCallSign rdf:type rdf:Property ;
    rdfs:label 'Station Call Sign' ;
    rdfs:comment 'FCC-assigned call letters identifying the broadcast station that aired the political advertisement. Required for public inspection file organization and regulatory reporting. | Column station_call_sign (STRING) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value of the political advertising contract. Required disclosure for public inspection file and transparency in political advertising spending. | Column total_contract_value (DECIMAL(15,2)) in sales.political_ad_disclosure' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotsContracted rdf:type rdf:Property ;
    rdfs:label 'Total Spots Contracted' ;
    rdfs:comment 'Total number of advertising spots contracted under the political advertising agreement. Used for campaign tracking and public disclosure of advertising volume. | Column total_spots_contracted (INT) in sales.political_ad_disclosure' ;
    rdfs:domain ind:PoliticalAdDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companyLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Company Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Sales accounts must be associated with the contracting legal entity for proper invoicing, tax treatment, and intercompany elimination. Required for contract execution authority, tax jurisdiction deter | Column company_legal_entity_id (BIGINT) in finance.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:parentAccountSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Sales Account Id' ;
    rdfs:comment 'Reference to the parent sales account in a hierarchical account structure. Used to model agency networks, holding company subsidiaries, and multi-location advertiser organizations. | Column parent_account_sales_account_id (BIGINT) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAccount .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Sales accounts are assigned to territories for territory management. Currently sales_account has market_territory as a STRING, which should be normalized to a FK to sales_territory. This FK enables pr | Column sales_territory_id (BIGINT) in sales.sales_account' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The legal or trading name of the sales account organization. This is the primary human-readable identifier for the account. | Column account_name (STRING) in sales.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'The strategic tier or classification of the account based on revenue potential, relationship depth, and strategic importance. Higher tiers receive preferential pricing, dedicated support, and priority inventory access. | Column account_tier (STRING) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the sales account based on its commercial relationship with Media Broadcasting. Agency represents advertising agencies; direct_advertiser represents brands buying media directly; MVPD (Multichannel Video Programming Distributor) and vMVPD (Virtual Multichannel Video Programming Distributor) represent distribution partners; syndicator represents content resale partners; content_licensee represents organizations licensing content rights. | Column account_type (STRING) in sales.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'The estimated annual revenue opportunity from this account based on historical spend, market share, and sales forecasts. Used for territory planning and quota allocation. | Column annual_revenue_potential (DECIMAL(18,2)) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Billing Account Id' ;
    rdfs:comment 'FK to SSOT billing.billing_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'The email address of the primary billing contact for invoice delivery and payment correspondence. | Column billing_contact_email (STRING) in sales.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'The full name of the primary billing contact at the account organization who handles invoices, payment processing, and financial inquiries. | Column billing_contact_name (STRING) in sales.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'The phone number of the primary billing contact for urgent payment or invoice inquiries. | Column billing_contact_phone (STRING) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit rating assigned to this account based on payment history, financial stability, and risk assessment. Used to determine payment terms, credit limits, and whether prepayment is required. NR indicates not rated. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product] | Column credit_rating (STRING) in sales.sales_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Holding Company Name' ;
    rdfs:comment 'The name of the parent holding company or corporate group to which this account belongs. Used to aggregate spend and manage relationships at the holding company level (e.g., WPP, Omnicom, Publicis Groupe for agencies). | Column holding_company_name (STRING) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry vertical or business sector of the account (e.g., Automotive, Financial Services, Retail, Pharmaceutical, Technology). Used for competitive separation and industry-specific rate cards. | Column industry_vertical (STRING) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'The date of the most recent sales activity, campaign, or transaction associated with this account. Used to identify dormant accounts and trigger re-engagement campaigns. | Column last_activity_date (DATE) in sales.sales_account' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'The source system identifier from Salesforce Media Cloud CRM. This is the external key used to synchronize account data between the lakehouse and the operational CRM system. | Column salesforce_account_reference (STRING) in sales.sales_account' ;
    rdfs:domain ind:SalesAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesContactId rdf:type rdf:Property ;
    rdfs:label 'Sales Contact Id' ;
    rdfs:comment 'Unique identifier for the sales contact record. Primary key. | Column sales_contact_id (BIGINT) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who most recently modified this contact record. | Column last_modified_by_user_employee_id (BIGINT) in workforce.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAuthorityUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Authority Usd' ;
    rdfs:comment 'Estimated annual advertising budget the contact controls or influences, in USD. Used for opportunity sizing and account prioritization. | Column budget_authority_usd (DECIMAL(18,2)) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactSource rdf:type rdf:Property ;
    rdfs:label 'Contact Source' ;
    rdfs:comment 'Origin or acquisition channel through which this contact was first captured. Used for lead source attribution and ROI analysis. | Column contact_source (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact. Inactive or departed contacts are excluded from active sales campaigns. | Column contact_status (STRING) in sales.sales_contact' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Level of purchasing authority the contact holds within their organization. Critical for routing proposals and negotiating upfront commitments. | Column decision_authority_level (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Master suppression flag indicating the contact has requested no further outreach. Overrides all other opt-in settings. | Column do_not_contact (BOOLEAN) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete display name of the sales contact, typically concatenation of first and last name. | Column full_name (STRING) in sales.sales_contact' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent sales interaction or touchpoint with this contact. Used for relationship health scoring. | Column last_contact_date (DATE) in sales.sales_contact' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contact\'s LinkedIn professional profile. Used for relationship intelligence and network mapping. | Column linkedin_profile_url (STRING) in sales.sales_contact' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'Primary street address line for physical correspondence and contract delivery. | Column mailing_address_line1 (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, or department information. | Column mailing_address_line2 (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City name for the contact\'s mailing address. | Column mailing_city (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the contact\'s mailing address (e.g., USA, CAN, GBR). | Column mailing_country_code (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
