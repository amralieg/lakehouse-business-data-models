ind:dealExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Deal Expiration Date' ;
    rdfs:comment 'Date when the acquisition deal expires and rights revert to the content provider, marking the end of the license period. | Column deal_expiration_date (DATE) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealTitle rdf:type rdf:Property ;
    rdfs:label 'Deal Title' ;
    rdfs:comment 'Human-readable name or title of the acquisition deal, typically reflecting the content package or series being acquired. | Column deal_title (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRights rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights' ;
    rdfs:comment 'Comma-separated list of distribution platforms and methods covered by this deal (e.g., linear, SVOD, AVOD, TVOD, FAST, syndication, VOD). | Column distribution_rights (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermMonths rdf:type rdf:Property ;
    rdfs:label 'License Term Months' ;
    rdfs:comment 'Duration of the content license in months, representing the period during which the broadcaster has rights to exploit the acquired content. | Column license_term_months (INT) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingMaterialsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Materials Included Flag' ;
    rdfs:comment 'Indicates whether the deal includes delivery of marketing and promotional materials such as trailers, key art, press kits, and promotional clips. | Column marketing_materials_included_flag (BOOLEAN) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataRequirements rdf:type rdf:Property ;
    rdfs:label 'Metadata Requirements' ;
    rdfs:comment 'Specifications for content metadata to be delivered with the content package, including descriptive, technical, and rights metadata standards. | Column metadata_requirements (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceGuarantees rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantees' ;
    rdfs:comment 'Contractual performance commitments such as minimum broadcast hours, promotional support, or audience delivery guarantees required by the content provider. | Column performance_guarantees (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensingTerms rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Terms' ;
    rdfs:comment 'Detailed terms and restrictions governing sublicensing rights, including revenue sharing with original content provider and territorial limitations. | Column sublicensing_terms (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:AcquisitionDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Territory Coverage' ;
    rdfs:comment 'Geographic territories or markets covered by this acquisition deal, specified as comma-separated ISO 3166-1 alpha-3 country codes or regional designations (e.g., USA, CAN, GBR, or NORTH_AMERICA). | Column territory_coverage (STRING) in partner.acquisition_deal' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDealLineId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Deal Line Id' ;
    rdfs:comment 'Unique identifier for the acquisition deal line item. Primary key for this entity. | Column acquisition_deal_line_id (BIGINT) in partner.acquisition_deal_line' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDueDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Due Date' ;
    rdfs:comment 'The date by which the content provider must deliver the content asset for this line item. Critical for production scheduling and playout planning. | Column delivery_due_date (DATE) in partner.acquisition_deal_line' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseDurationMonths rdf:type rdf:Property ;
    rdfs:label 'License Duration Months' ;
    rdfs:comment 'Total duration of the license term expressed in months. Calculated from start and end dates for reporting and windowing analysis. | Column license_duration_months (INT) in partner.acquisition_deal_line' ;
    rdfs:domain ind:AcquisitionDealLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Contracting Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Distribution agreements are executed by specific legal entities for proper revenue recognition, tax jurisdiction determination, and SOX compliance. Essential for carriage fee revenue allocation and in | Column contracting_legal_entity_id (BIGINT) in finance.distribution_agreement' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:auditRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Included' ;
    rdfs:comment 'Indicates whether Media Broadcasting retains the right to audit the distributors subscriber counts, revenue reports, and compliance with agreement terms. | Column audit_rights_included (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelsIncluded rdf:type rdf:Property ;
    rdfs:label 'Channels Included' ;
    rdfs:comment 'List or description of Media Broadcasting channels covered by this distribution agreement (e.g., primary network, secondary channels, HD feeds, regional variants). | Column channels_included (STRING) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligation rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation' ;
    rdfs:comment 'Indicates whether this agreement includes must-carry obligations under FCC regulations requiring the distributor to carry the broadcast signal. | Column must_carry_obligation (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum response time in hours for addressing service disruptions or technical issues under the SLA. | Column sla_response_time_hours (INT) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Streaming Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer live streaming or simulcast of Media Broadcasting channels via OTT platforms. | Column streaming_rights_included (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Svod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Subscription Video On Demand (SVOD) access as part of a subscription package. | Column svod_rights_included (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tvodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Tvod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Transactional Video On Demand (TVOD) access where viewers pay per transaction. | Column tvod_rights_included (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Vod Rights Included' ;
    rdfs:comment 'Indicates whether the agreement includes rights for the distributor to offer Video On Demand (VOD) access to Media Broadcasting content. | Column vod_rights_included (BOOLEAN) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodWindowDays rdf:type rdf:Property ;
    rdfs:label 'Vod Window Days' ;
    rdfs:comment 'Number of days that content remains available in the distributors VOD library after initial broadcast, if VOD rights are included. | Column vod_window_days (INT) in partner.distribution_agreement' ;
    rdfs:domain ind:DistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Id' ;
    rdfs:comment 'Reference to the third-party broadcaster, regional station, or international network acquiring syndication rights. | Column syndication_partner_id (BIGINT) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:barterSpotCount rdf:type rdf:Property ;
    rdfs:label 'Barter Spot Count' ;
    rdfs:comment 'Number of advertising spots retained by Media Broadcasting per episode in barter syndication arrangements. | Column barter_spot_count (INT) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceObligation rdf:type rdf:Property ;
    rdfs:label 'Clearance Obligation' ;
    rdfs:comment 'Party responsible for obtaining broadcast clearances and rights verification in the syndication territory. | Column clearance_obligation (STRING) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window End Date' ;
    rdfs:comment 'End date of the exclusivity period. Nullable if exclusivity_flag is false. | Column exclusivity_window_end_date (DATE) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Start Date' ;
    rdfs:comment 'Start date of the exclusivity period during which no other syndication partner may broadcast the content in the granted territory. Nullable if exclusivity_flag is false. | Column exclusivity_window_start_date (DATE) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceGuarantee rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee' ;
    rdfs:comment 'Minimum performance commitments required from the syndication partner, such as minimum broadcast frequency or audience reach targets. | Column performance_guarantee (STRING) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Syndication Fee Structure' ;
    rdfs:comment 'Compensation model governing how the syndication partner pays for content rights. | Column syndication_fee_structure (STRING) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryGrant rdf:type rdf:Property ;
    rdfs:label 'Territory Grant' ;
    rdfs:comment 'Geographic territories where the syndication partner is granted broadcast rights. Pipe-separated list of ISO 3166-1 alpha-3 country codes or regional designations. [ENUM-REF-CANDIDATE: USA|CAN|GBR|AUS|DEU|FRA|JPN|BRA|MEX|IND|CHN — promote to reference product] | Column territory_grant (STRING) in partner.syndication_agreement' ;
    rdfs:domain ind:SyndicationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coproductionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Coproduction Agreement Id' ;
    rdfs:comment 'Unique identifier for the co-production agreement record. Primary key. | Column coproduction_agreement_id (BIGINT) in partner.coproduction_agreement' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoproductionAgreement .

ind:executiveSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Coproduction agreements require executive sponsor tracking for approval authority, strategic oversight, and escalation. High-value IP investments need clear internal ownership beyond approval_authorit | Column executive_sponsor_employee_id (BIGINT) in workforce.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leadPartnerId rdf:type rdf:Property ;
    rdfs:label 'Lead Partner Id' ;
    rdfs:comment 'Reference to the primary partner organization responsible for managing the co-production. | Column lead_partner_id (BIGINT) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:leadTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Lead Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Co-production agreements frequently specify lead talent (star, showrunner, director) as part of the deal structure—attached talent drives financing approval and production greenlight decisions. Critic | Column lead_talent_profile_id (BIGINT) in talent.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Provisions allowing partners to audit financial records and production accounts related to the co-production. | Column audit_rights (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTerms rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Terms' ;
    rdfs:comment 'Non-disclosure obligations and confidentiality requirements binding all co-production partners. | Column confidentiality_terms (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeControlLevel rdf:type rdf:Property ;
    rdfs:label 'Creative Control Level' ;
    rdfs:comment 'Degree of creative decision-making authority held by our organization in the production process. | Column creative_control_level (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditObligation rdf:type rdf:Property ;
    rdfs:label 'Credit Obligation' ;
    rdfs:comment 'Contractual requirements for on-screen and promotional credits for each co-production partner. | Column credit_obligation (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRightsAllocation rdf:type rdf:Property ;
    rdfs:label 'Distribution Rights Allocation' ;
    rdfs:comment 'Description of how distribution rights are divided among co-production partners by territory and platform. | Column distribution_rights_allocation (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureProvision rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Provision' ;
    rdfs:comment 'Contractual terms addressing obligations and liabilities in the event of unforeseeable circumstances preventing performance. | Column force_majeure_provision (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Mandatory insurance coverage types and amounts required for the co-production. | Column insurance_requirements (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ourInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Our Investment Amount' ;
    rdfs:comment 'Financial contribution amount committed by our organization to the co-production. | Column our_investment_amount (DECIMAL(18,2)) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourInvestmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Investment Percentage' ;
    rdfs:comment 'Percentage of total production budget contributed by our organization. | Column our_investment_percentage (DECIMAL(5,2)) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourIpOwnershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Our Ip Ownership Percentage' ;
    rdfs:comment 'Percentage of intellectual property rights owned by our organization in the co-produced content. | Column our_ip_ownership_percentage (DECIMAL(5,2)) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ourPrimaryTerritory rdf:type rdf:Property ;
    rdfs:label 'Our Primary Territory' ;
    rdfs:comment 'Geographic territory or territories where our organization holds primary distribution rights. | Column our_primary_territory (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionEndDate rdf:type rdf:Property ;
    rdfs:label 'Production End Date' ;
    rdfs:comment 'Scheduled or actual date when principal photography or production activities are completed. | Column production_end_date (DATE) in partner.coproduction_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Start Date' ;
    rdfs:comment 'Scheduled or actual date when principal photography or production activities commence. | Column production_start_date (DATE) in partner.coproduction_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualsSharingFormula rdf:type rdf:Property ;
    rdfs:label 'Residuals Sharing Formula' ;
    rdfs:comment 'Formula or methodology for distributing residual payments to talent among co-production partners. | Column residuals_sharing_formula (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'Methodology for distributing revenues generated from the co-produced content among partners. | Column revenue_sharing_model (STRING) in partner.coproduction_agreement' ;
    rdfs:domain ind:CoproductionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Agreement Id' ;
    rdfs:comment 'Unique identifier for the affiliate agreement record. Primary key. | Column affiliate_agreement_id (BIGINT) in partner.affiliate_agreement' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateAgreement .

ind:affiliateChannelId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Channel Id' ;
    rdfs:comment 'Foreign key linking to scheduling.channel. Business justification: Affiliate agreements are channel-specific contracts between networks and local stations. Core to network-affiliate relationship management, affiliation fee calculation, must-air programming compliance | Column channel_id (BIGINT) in scheduling.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affiliateNetworkChannelId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network Channel Id' ;
    rdfs:comment 'Reference to the parent network or broadcast network entity that is the counterparty to this affiliate agreement. | Column network_channel_id (BIGINT) in scheduling.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affiliateStationPartnerId rdf:type rdf:Property ;
    rdfs:label 'Affiliate Station Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: affiliate_agreement.affiliate_station_id represents the affiliate station partner. Renaming to affiliate_station_partner_id for clarity (ends with partner_partner_partner_id pattern). Links to partner | Column affiliate_station_partner_id (BIGINT) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:networkLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Network Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Affiliate agreements generate intercompany transactions requiring legal entity tracking for network compensation accounting, retransmission revenue split allocation, and consolidation elimination. Cri | Column network_legal_entity_id (BIGINT) in finance.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryAffiliateStationChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliate Station Channel Id' ;
    rdfs:comment 'Reference to the local broadcast station or regional affiliate partner that is party to this agreement. | Column affiliate_station_channel_id (BIGINT) in scheduling.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affiliationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Amount' ;
    rdfs:comment 'Monthly or annual fee paid by the network to the affiliate station for carrying network programming, or reverse compensation paid by affiliate to network. Negative values indicate reverse compensation. | Column affiliation_fee_amount (DECIMAL(15,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affiliationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the affiliation fee amount (e.g., USD, CAD, GBP). | Column affiliation_fee_currency (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Affiliation Fee Frequency' ;
    rdfs:comment 'Frequency at which affiliation fees are calculated and paid between network and affiliate. | Column affiliation_fee_frequency (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Rights Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes rights to distribute network content via digital platforms, streaming services, and Over-The-Top (OTT) channels. | Column digital_rights_included_flag (BOOLEAN) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityTerritory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Territory' ;
    rdfs:comment 'Geographic territory within which the affiliate has exclusive rights to broadcast network programming, typically defined by DMA boundaries, county lists, or signal contours. | Column exclusivity_territory (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAdAvailsMinutesPerHour rdf:type rdf:Property ;
    rdfs:label 'Local Ad Avails Minutes Per Hour' ;
    rdfs:comment 'Number of minutes per hour of network programming that the affiliate may use for local advertising insertion, typically 2-4 minutes per hour. | Column local_ad_avails_minutes_per_hour (DECIMAL(4,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localInsertionRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Local Insertion Rights Flag' ;
    rdfs:comment 'Indicates whether the affiliate has the right to insert local advertising spots during designated network programming breaks (ad pods). | Column local_insertion_rights_flag (BOOLEAN) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumClearancePercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Clearance Percentage' ;
    rdfs:comment 'Minimum percentage of network programming hours that the affiliate is contractually obligated to broadcast, typically 85-95% for primary affiliates. Expressed as percentage (e.g., 90.00 for 90%). | Column minimum_clearance_percentage (DECIMAL(5,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mustAirProgrammingHours rdf:type rdf:Property ;
    rdfs:label 'Must Air Programming Hours' ;
    rdfs:comment 'Minimum number of weekly hours of network programming that the affiliate must broadcast without preemption, including prime-time, news, and sports. | Column must_air_programming_hours (DECIMAL(6,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkCompensationModel rdf:type rdf:Property ;
    rdfs:label 'Network Compensation Model' ;
    rdfs:comment 'Economic model governing compensation flow between network and affiliate: fixed fee paid to affiliate, revenue share from advertising, audience-based payments, hybrid model, or reverse compensation where affiliate pays network. | Column network_compensation_model (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMeasurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Performance Measurement Methodology' ;
    rdfs:comment 'Audience measurement methodology used to assess affiliate performance against contractual standards (Nielsen ratings, Comscore, proprietary measurement, or multi-source approach). | Column performance_measurement_methodology (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStandardGrpMinimum rdf:type rdf:Property ;
    rdfs:label 'Performance Standard Grp Minimum' ;
    rdfs:comment 'Minimum Gross Rating Points (GRP) that the affiliate must deliver for network programming to meet performance standards and avoid penalties or compensation adjustments. | Column performance_standard_grp_minimum (DECIMAL(8,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Preemption Notice Hours' ;
    rdfs:comment 'Minimum number of hours advance notice the affiliate must provide to the network before preempting scheduled programming, typically 24-72 hours except for breaking news. | Column preemption_notice_hours (INT) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionRights rdf:type rdf:Property ;
    rdfs:label 'Preemption Rights' ;
    rdfs:comment 'Extent to which the affiliate may preempt scheduled network programming for local content, special events, or breaking news. Preemption typically requires advance notice and makegoods. | Column preemption_rights (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Included Flag' ;
    rdfs:comment 'Indicates whether the affiliate agreement includes provisions for retransmission consent negotiations with Multichannel Video Programming Distributors (MVPDs) and virtual MVPDs (vMVPDs). | Column retransmission_consent_included_flag (BOOLEAN) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionRevenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Retransmission Revenue Split Percentage' ;
    rdfs:comment 'Percentage of retransmission consent fees collected from MVPDs that the affiliate must share with the network. Expressed as percentage (e.g., 30.00 for 30% to network). | Column retransmission_revenue_split_percentage (DECIMAL(5,2)) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:simulcastRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Requirement Flag' ;
    rdfs:comment 'Indicates whether the affiliate is required to simulcast network programming simultaneously across multiple platforms (linear broadcast, digital streaming, mobile apps). | Column simulcast_requirement_flag (BOOLEAN) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the affiliate agreement term expressed in months, typically ranging from 12 to 60 months for broadcast affiliations. | Column term_length_months (INT) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationForCauseProvisions rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Provisions' ;
    rdfs:comment 'Description of conditions under which either party may terminate the agreement for cause, including breach of clearance obligations, payment defaults, license revocation, or material violations of broadcast standards. | Column termination_for_cause_provisions (STRING) in partner.affiliate_agreement' ;
    rdfs:domain ind:AffiliateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealNegotiationId rdf:type rdf:Property ;
    rdfs:label 'Deal Negotiation Id' ;
    rdfs:comment 'Unique identifier for the deal negotiation record. Primary key for the deal negotiation entity. | Column deal_negotiation_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDealEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Deal Employee Id' ;
    rdfs:comment 'Reference to the employee or business development executive assigned as the primary negotiator for this deal. | Column primary_deal_employee_id (BIGINT) in workforce.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultingAcquisitionDealId rdf:type rdf:Property ;
    rdfs:label 'Resulting Acquisition Deal Id' ;
    rdfs:comment 'Foreign key linking to partner.acquisition_deal. Business justification: deal_negotiation tracks the negotiation lifecycle. When negotiation completes successfully, it results in an executed deal. New FK: resulting_acquisition_deal_id → acquisition_deal.acquisition_deal_id | Column resulting_acquisition_deal_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquisitionDeal .

ind:resultingAffiliateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Affiliate Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.affiliate_agreement. Business justification: deal_negotiation can result in affiliate_agreement. New FK: resulting_affiliate_agreement_id → affiliate_agreement.affiliate_agreement_id. Nullable (populated only when negotiation results in affiliat | Column resulting_affiliate_agreement_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffiliateAgreement .

ind:resultingCoproductionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Coproduction Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.coproduction_agreement. Business justification: deal_negotiation can result in coproduction_agreement. New FK: resulting_coproduction_agreement_id → coproduction_agreement.coproduction_agreement_id. Nullable (populated only when negotiation results | Column resulting_coproduction_agreement_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoproductionAgreement .

ind:resultingDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: deal_negotiation can result in distribution_agreement. New FK: resulting_distribution_agreement_id → distribution_agreement.distribution_agreement_id. Nullable (populated only when negotiation results | Column resulting_distribution_agreement_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:resultingSyndicationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Syndication Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.syndication_agreement. Business justification: deal_negotiation can result in syndication_agreement. New FK: resulting_syndication_agreement_id → syndication_agreement.syndication_agreement_id. Nullable (populated only when negotiation results in  | Column resulting_syndication_agreement_id (BIGINT) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAgreement .

ind:targetGenreId rdf:type rdf:Property ;
    rdfs:label 'Target Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Deal negotiations target specific content genres for portfolio strategy. Pipeline forecasting by genre, content gap analysis, competitive positioning assessment, and strategic acquisition planning req | Column target_genre_id (BIGINT) in content.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:tertiaryDealLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Deal Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel or attorney assigned to review this deal negotiation. | Column tertiary_deal_legal_reviewer_employee_id (BIGINT) in workforce.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date on which the deal was finalized and executed. Null if deal is still in negotiation or was not closed. | Column actual_close_date (DATE) in partner.deal_negotiation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreedDealValue rdf:type rdf:Property ;
    rdfs:label 'Agreed Deal Value' ;
    rdfs:comment 'Final agreed total monetary value of the deal after negotiation, in the deal currency. Null until deal is finalized. | Column agreed_deal_value (DECIMAL(18,2)) in partner.deal_negotiation' ;
    rdfs:domain ind:DealNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalChain rdf:type rdf:Property ;
    rdfs:label 'Approval Chain' ;
    rdfs:comment 'Comma-separated list of approval roles or levels required for this deal (e.g., Business Unit Head, Legal, CFO, CEO, Board) based on deal value and risk. | Column approval_chain (STRING) in partner.deal_negotiation' ;
