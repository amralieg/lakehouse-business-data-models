    rdfs:comment 'The organizational department or division responsible for this capacity plan (e.g., Network Operations, Broadcast Engineering, IT Infrastructure, Media Technology, Studio Operations). | Column plan_owner_department (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning End Date' ;
    rdfs:comment 'The last day of the planning period covered by this capacity assessment. Defines the planning horizon endpoint. | Column planning_end_date (DATE) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'The time horizon granularity for this capacity planning cycle (quarterly, half-yearly, annual, biennial, or multi-year strategic planning). | Column planning_period_type (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The first day of the planning period covered by this capacity assessment. Used to define the temporal scope of the plan. | Column planning_start_date (DATE) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedDemandValue rdf:type rdf:Property ;
    rdfs:label 'Projected Demand Value' ;
    rdfs:comment 'The forecasted capacity demand at the end of the planning period, calculated by applying the projected growth rate to current utilization. Expressed in the same unit as capacity_unit. | Column projected_demand_value (DECIMAL(18,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedGrowthRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Growth Rate Percentage' ;
    rdfs:comment 'The anticipated percentage increase in demand or utilization over the planning period, based on historical trends, content production forecasts, audience growth projections, and strategic initiatives (e.g., new channel launches, OTT expansion, 4K/8K content migration). | Column projected_growth_rate_percentage (DECIMAL(5,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'The strategic recommendation for addressing capacity needs. Expand: add new infrastructure capacity; Optimize: improve efficiency of existing resources; Consolidate: merge underutilized resources; Decommission: retire obsolete infrastructure; Monitor: continue observation without immediate action; Migrate: move workloads to alternative infrastructure (e.g., cloud, CDN). | Column recommended_action (STRING) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedCapacityAddition rdf:type rdf:Property ;
    rdfs:label 'Recommended Capacity Addition' ;
    rdfs:comment 'The amount of additional capacity recommended to be added, expressed in the same unit as capacity_unit. Null if the recommended action does not involve expansion. | Column recommended_capacity_addition (DECIMAL(18,2)) in technology.capacity_plan' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyPlatform rdf:type rdf:Property ;
