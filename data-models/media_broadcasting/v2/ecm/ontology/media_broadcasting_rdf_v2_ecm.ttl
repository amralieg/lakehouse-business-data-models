ind:correlatedNocAlertId rdf:type rdf:Property ;
    rdfs:label 'Correlated Noc Alert Id' ;
    rdfs:comment 'Self-referencing FK on noc_alert (correlated_noc_alert_id) | Column correlated_noc_alert_id (BIGINT) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
