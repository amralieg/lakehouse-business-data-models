    rdfs:range xsd:date .

ind:exitInterviewSentiment rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Sentiment' ;
    rdfs:comment 'Overall sentiment classification from the exit interview: positive (employee left on good terms), neutral (professional departure), negative (employee expressed dissatisfaction), or not applicable (no interview conducted). | Column exit_interview_sentiment (STRING) in workforce.separation_record' ;
    rdfs:domain ind:SeparationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewSummary rdf:type rdf:Property ;
