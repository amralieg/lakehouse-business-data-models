    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of inspector' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or role responsible for ensuring compliance with this obligation at this specific facility. Responsibility is facility-specific - different facility managers or compliance officers may own the same obligation at different locations. | Column responsible_party_name (STRING) in compliance.facility_compliance' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Number of violations found' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Id' ;
    rdfs:comment 'Self-referencing FK on audit (follow_up_audit_id) | Column follow_up_audit_id (BIGINT) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:accessibilityStandard rdf:type rdf:Property ;
    rdfs:label 'Accessibility Standard' ;
    rdfs:comment 'Accessibility standard or guideline under audit (e.g., WCAG 2.1, Section 508, CVAA closed captioning). | Column accessibility_standard (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique business identifier for the audit, used in regulatory filings and correspondence. | Column audit_number (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Classification of the auditing organization (internal audit team, external audit firm, or regulatory body inspection). | Column auditor_organization (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:comment 'Overall compliance assessment or rating assigned by the auditor based on findings. | Column compliance_rating (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees and internal resource costs. | Column audit_cost (DECIMAL(15,2)) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFindingCount rdf:type rdf:Property ;
    rdfs:label 'Critical Finding Count' ;
    rdfs:comment 'Number of critical or high-severity findings that require immediate remediation. | Column critical_finding_count (INT) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyFramework rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Framework' ;
    rdfs:comment 'Data privacy regulation or framework under audit (e.g., GDPR, CCPA, COPPA for children\'s content). | Column data_privacy_framework (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'Total number of audit findings, observations, or non-conformances identified during the audit. | Column finding_count (INT) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmName rdf:type rdf:Property ;
    rdfs:label 'Firm Name' ;
    rdfs:comment 'Name of the external audit firm or regulatory body conducting the audit, if applicable. | Column audit_firm_name (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Primary methodology or approach used to conduct the audit. | Column audit_methodology (STRING) in compliance.audit' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opinion rdf:type rdf:Property ;
    rdfs:label 'Opinion' ;
    rdfs:comment 'Formal auditor opinion or conclusion issued for financial or SOX audits. | Column audit_opinion (STRING) in compliance.audit' ;
