ind:platformRestrictions rdf:type rdf:Property ;
    rdfs:label 'Platform Restrictions' ;
    rdfs:comment 'Comma-separated list of platforms or distribution channels where the licensee is restricted from distributing the content (e.g., linear-only, no-streaming, no-mobile). | Column platform_restrictions (STRING) in rights.rights_syndication_deal' ;
