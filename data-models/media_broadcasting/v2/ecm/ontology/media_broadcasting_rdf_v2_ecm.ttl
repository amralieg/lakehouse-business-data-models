ind:primaryPoliticalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Political Employee Id' ;
    rdfs:comment 'Identifier of the user who created the political ad disclosure record. Supports audit trail and accountability for regulatory compliance documentation. | Column primary_political_employee_id (BIGINT) in workforce.political_ad_disclosure' ;
