    rdfs:range xsd:integer .

ind:deliveredAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Delivered Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Delivery obligations specify exact version/format requirements (HD vs 4K, dubbed vs subtitled). Tracks which specific version satisfies contractual delivery for acceptance sign-off, QC validation, and | Column delivered_asset_version_id (BIGINT) in mediaasset.delivery_obligation' ;
