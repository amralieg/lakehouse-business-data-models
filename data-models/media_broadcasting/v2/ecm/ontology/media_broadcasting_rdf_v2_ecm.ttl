    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality classification of the asset based on its impact to operations if unavailable (critical for broadcast continuity, high for major workflows, medium for standard operations, low for non-essential). | Column criticality_level (STRING) in technology.it_asset' ;
    rdfs:domain ind:ItAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostname rdf:type rdf:Property ;
