ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of this payroll record in its lifecycle from calculation through payment. | Column payroll_status (STRING) in workforce.payroll_record' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoHours rdf:type rdf:Property ;
    rdfs:label 'Pto Hours' ;
    rdfs:comment 'Number of paid time off hours used during this pay period, including vacation, sick leave, and personal days. | Column pto_hours (DECIMAL(10,2)) in workforce.payroll_record' ;
