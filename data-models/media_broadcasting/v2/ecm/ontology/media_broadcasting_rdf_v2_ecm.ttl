    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoutFeedId rdf:type rdf:Property ;
    rdfs:label 'Playout Feed Id' ;
    rdfs:comment 'Unique identifier for the playout feed. Primary key for the playout feed entity representing a discrete output stream from the playout automation system. | Column playout_feed_id (BIGINT) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverFeedId rdf:type rdf:Property ;
    rdfs:label 'Failover Feed Id' ;
    rdfs:comment 'Reference to the backup playout feed that will take over in case of failure of this primary feed, enabling high availability and business continuity. | Column failover_feed_id (BIGINT) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayoutFeed .

ind:playoutEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Playout Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Playout feeds are broadcast operations infrastructure requiring engineering ownership for failover testing, graphics overlay management, SCTE-35 configuration, and automation system integration. Essen | Column playout_engineer_employee_id (BIGINT) in workforce.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:brandingProfile rdf:type rdf:Property ;
    rdfs:label 'Branding Profile' ;
    rdfs:comment 'Name or identifier of the branding profile applied to this playout feed, controlling channel logos, watermarks, and visual identity elements. | Column branding_profile (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Enabled' ;
    rdfs:comment 'Indicates whether closed captioning (CEA-608, CEA-708) is enabled and embedded in the playout feed output for accessibility compliance. | Column closed_caption_enabled (BOOLEAN) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverTriggerMode rdf:type rdf:Property ;
    rdfs:label 'Failover Trigger Mode' ;
    rdfs:comment 'Method by which failover to the backup feed is initiated: automatic based on health monitoring, manual operator intervention, or scheduled for planned maintenance. | Column failover_trigger_mode (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedCode rdf:type rdf:Property ;
    rdfs:label 'Feed Code' ;
    rdfs:comment 'Unique business identifier code for the playout feed used in scheduling systems, traffic systems, and operational workflows. | Column feed_code (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedName rdf:type rdf:Property ;
    rdfs:label 'Feed Name' ;
    rdfs:comment 'Human-readable name of the playout feed used for identification and operational reference within the playout automation system. | Column feed_name (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Classification of the playout feed indicating its operational role: primary broadcast feed, backup feed for failover, redundant feed for high availability, test feed for validation, or preview feed for quality control. | Column feed_type (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsOverlayEnabled rdf:type rdf:Property ;
    rdfs:label 'Graphics Overlay Enabled' ;
    rdfs:comment 'Indicates whether real-time graphics overlay (bugs, tickers, lower thirds, branding elements) is enabled for this playout feed. | Column graphics_overlay_enabled (BOOLEAN) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multicastAddress rdf:type rdf:Property ;
    rdfs:label 'Multicast Address' ;
    rdfs:comment 'Multicast IP address used for distributing the playout feed to multiple receivers simultaneously in IP-based broadcast networks. | Column multicast_address (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Physical or network output format of the playout feed: Serial Digital Interface (SDI) for baseband video, Internet Protocol (IP) for network streaming, Asynchronous Serial Interface (ASI) for MPEG transport streams, Secure Reliable Transport (SRT), Reliable Internet Stream Transport (RIST), or Network Device Interface (NDI). | Column output_format (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutServerCode rdf:type rdf:Property ;
    rdfs:label 'Playout Server Code' ;
    rdfs:comment 'Identifier of the physical or virtual playout server assigned to generate this feed. Links the feed to the automation infrastructure. | Column playout_server_code (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portNumber rdf:type rdf:Property ;
    rdfs:label 'Port Number' ;
    rdfs:comment 'Network port number used for the playout feed output connection in IP-based delivery configurations. | Column port_number (INT) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyMode rdf:type rdf:Property ;
    rdfs:label 'Redundancy Mode' ;
    rdfs:comment 'Redundancy configuration for the playout feed: none (single feed), hot standby (backup ready to take over), active-active (both feeds broadcasting simultaneously), or N+1 (shared backup for multiple feeds). | Column redundancy_mode (STRING) in distribution.playout_feed' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Service Identifier' ;
    rdfs:comment 'DVB Service ID or ATSC program number identifying the service within the transport stream for Electronic Program Guide (EPG) and receiver tuning. | Column service_identifier (INT) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportStreamIdentifier rdf:type rdf:Property ;
    rdfs:label 'Transport Stream Identifier' ;
    rdfs:comment 'MPEG Transport Stream ID (TSID) assigned to this playout feed for multiplexing and demultiplexing in broadcast distribution networks. | Column transport_stream_identifier (INT) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Target Percent' ;
    rdfs:comment 'Target uptime percentage for the playout feed as defined in the Service Level Agreement (SLA), typically 99.9% or higher for mission-critical broadcast feeds. | Column uptime_target_percent (DECIMAL(5,2)) in distribution.playout_feed' ;
    rdfs:domain ind:PlayoutFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Primary key for deal | Column deal_id (BIGINT) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:dspId rdf:type rdf:Property ;
    rdfs:label 'Dsp Id' ;
    rdfs:comment 'FK to demand-side platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dsp .

ind:exchangeId rdf:type rdf:Property ;
    rdfs:label 'Exchange Id' ;
    rdfs:comment 'FK to ad exchange' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Exchange .

ind:programmaticDealId rdf:type rdf:Property ;
    rdfs:label 'Programmatic Deal Id' ;
    rdfs:comment 'External programmatic deal ID for OpenRTB' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:sspId rdf:type rdf:Property ;
    rdfs:label 'Ssp Id' ;
    rdfs:comment 'FK to supply-side platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ssp .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Description of the content assets included in this deal. May reference specific titles, series, libraries, or content categories covered by the agreement. | Column content_scope (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known unique business identifier for the distribution deal, used in contracts and communications. | Column deal_number (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle status of the distribution deal. Tracks progression from initial draft through negotiation, approval, active operation, and eventual closure or renewal. [ENUM-REF-CANDIDATE: draft|negotiation|pending approval|active|suspended|expired|terminated|renewed — 8 candidates stripped; promote to reference product] | Column deal_status (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowDays rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Days' ;
    rdfs:comment 'Duration in days of the exclusivity period or holdback window during which content cannot be distributed through competing channels. | Column exclusivity_window_days (INT) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Floor Price Cpm' ;
    rdfs:comment 'Floor price in CPM for programmatic' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable name or title of the distribution deal for identification and reporting purposes. | Column deal_name (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticDealType rdf:type rdf:Property ;
    rdfs:label 'Programmatic Deal Type' ;
    rdfs:comment 'Programmatic deal type (PMP, PG, open auction)' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the distribution deal contract was executed by all parties. | Column signed_date (DATE) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Duration of the deal term expressed in months. Calculated from effective date to expiration date. | Column term_months (INT) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Delivery orders specify exact rendition (proxy/mezzanine/distribution master) for partner fulfillment. Broadcasters track which version was delivered for audit/quality purposes. Existing content_asset | Column asset_version_id (BIGINT) in mediaasset.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:fulfillmentCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Content delivery orders require operations ownership for prioritization, troubleshooting delivery failures, SLA compliance, and partner communication. Essential for on-call rotations, delivery metrics | Column fulfillment_coordinator_employee_id (BIGINT) in workforce.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Service Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Content delivery orders for encoding, transcoding, QC, and distribution services are billable to content owners or internal cost centers. Real business process: content services billing, delivery fee  | Column service_invoice_id (BIGINT) in billing.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the user who approved this delivery order for fulfillment. Tracks authorization and approval workflow. | Column approved_by_user (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for audio tracks included in the delivery. Supports multi-language distribution requirements. | Column audio_languages (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsIncluded rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Included' ;
    rdfs:comment 'Indicates whether closed captions are included in the delivered content. Required for FCC compliance and accessibility standards. | Column closed_captions_included (BOOLEAN) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Timestamp' ;
    rdfs:comment 'Precise deadline timestamp for content delivery. Used for Service Level Agreement (SLA) compliance tracking and penalty calculations. | Column delivery_deadline_timestamp (TIMESTAMP) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes and special instructions for the delivery order. Captures partner-specific requirements, technical considerations, or operational alerts. | Column delivery_notes (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Duration Minutes' ;
    rdfs:comment 'Estimated time required to complete the content delivery, measured in minutes. Based on file size, bandwidth, and delivery method. | Column estimated_delivery_duration_minutes (INT) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Description of the reason for delivery failure if order status is failed. Used for root cause analysis and process improvement. | Column failure_reason (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Confirmation Number' ;
    rdfs:comment 'Unique confirmation identifier provided upon successful delivery completion. Used for proof of delivery and reconciliation with distribution partners. | Column fulfillment_confirmation_number (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content delivery is restricted or permitted. Enforces territorial rights and blackout rules. | Column geographic_restrictions (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for this delivery order. Used for tracking, communication, and reconciliation with distribution partners. | Column order_number (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order. Tracks the order through its workflow from creation to fulfillment or cancellation. [ENUM-REF-CANDIDATE: draft|pending|approved|in_progress|delivered|failed|cancelled — 7 candidates stripped; promote to reference product] | Column order_status (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the delivery order type. Indicates the nature and urgency of the content delivery request. | Column order_type (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the content must be delivered to the distribution partner. Drives scheduling and prioritization of delivery tasks. | Column requested_delivery_date (DATE) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transcodeProfileCode rdf:type rdf:Property ;
    rdfs:label 'Transcode Profile Code' ;
    rdfs:comment 'Reference to the transcode profile specifying encoding parameters, bitrates, resolutions, and quality settings for content preparation. | Column transcode_profile_code (BIGINT) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformDistributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Platform Distribution Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for each platform distribution agreement record | Column platform_distribution_agreement_id (BIGINT) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionTerritories rdf:type rdf:Property ;
    rdfs:label 'Distribution Territories' ;
    rdfs:comment 'Comma-separated list of ISO country codes or geographic regions where this partner is authorized to distribute the platform under this agreement | Column distribution_territories (STRING) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity End Date' ;
    rdfs:comment 'End date of the exclusivity window if exclusivity_flag is true | Column exclusivity_end_date (DATE) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Start Date' ;
    rdfs:comment 'Start date of the exclusivity window if exclusivity_flag is true | Column exclusivity_start_date (DATE) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Commitment' ;
    rdfs:comment 'Minimum number of subscribers the partner commits to deliver or the platform commits to maintain through this distribution channel, if applicable | Column minimum_subscriber_commitment (BIGINT) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Platform Launch Date' ;
    rdfs:comment 'The date on which the OTT platform was made available through this specific distribution partner channel. May differ from the platforms overall launch date. | Column platform_launch_date (DATE) in distribution.platform_distribution_agreement' ;
    rdfs:domain ind:PlatformDistributionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointAllocationId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Allocation Id' ;
    rdfs:comment 'Primary key uniquely identifying each endpoint-partner allocation record | Column endpoint_allocation_id (BIGINT) in distribution.endpoint_allocation' ;
    rdfs:domain ind:EndpointAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bandwidthAllocationGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Allocation Gbps' ;
    rdfs:comment 'Dedicated bandwidth in gigabits per second allocated to this partner for this endpoint. Explicitly identified in detection phase relationship data. | Column bandwidth_allocation_gbps (DECIMAL(10,2)) in distribution.endpoint_allocation' ;
    rdfs:domain ind:EndpointAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playoutId rdf:type rdf:Property ;
    rdfs:label 'Playout Id' ;
    rdfs:comment 'Unique identifier for this playout event record. Primary key. | Column playout_id (BIGINT) in distribution.playout' ;
    rdfs:domain ind:Playout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutApplied rdf:type rdf:Property ;
    rdfs:label 'Blackout Applied' ;
    rdfs:comment 'Indicates whether geographic or rights-based blackout restrictions are applied to this specific playout event. Enforces content licensing and distribution rights on a per-transmission basis. | Column blackout_applied (BOOLEAN) in distribution.playout' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelComplianceId rdf:type rdf:Property ;
    rdfs:label 'Channel Compliance Id' ;
    rdfs:comment 'Unique identifier for this channel-obligation compliance record. Primary key. | Column channel_compliance_id (BIGINT) in distribution.channel_compliance' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting channel-specific compliance considerations, remediation actions, or special circumstances for this obligation. | Column compliance_notes (STRING) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this specific channel with respect to this specific obligation. Tracks whether the channel is meeting the regulatory requirement. | Column compliance_status (STRING) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Legal or regulatory basis for exemption if this channel is exempt from this obligation (e.g., \'low-power exemption\', \'OTT platform exclusion\', \'grandfathered status\'). Null if no exemption applies. | Column exemption_basis (STRING) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent internal or external audit of this channel\'s compliance with this obligation. | Column last_audit_date (DATE) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date when compliance of this channel with this obligation was last reviewed or assessed. Channel-specific review date distinct from the obligation-level review. | Column last_compliance_review_date (DATE) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next audit of this channel\'s compliance with this obligation. | Column next_audit_date (DATE) in distribution.channel_compliance' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextFilingDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Date' ;
    rdfs:comment 'Scheduled date for the next compliance filing or submission for this channel-obligation combination. Channel-specific deadline that may differ from the general obligation deadline based on channel launch date or exemption status. | Column next_filing_date (DATE) in distribution.channel_compliance' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact' ;
    rdfs:comment 'Name or identifier of the individual responsible for ensuring this channel\'s compliance with this specific obligation. May be a channel manager, compliance officer, or legal counsel. | Column responsible_contact (STRING) in distribution.channel_compliance' ;
    rdfs:domain ind:ChannelCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

