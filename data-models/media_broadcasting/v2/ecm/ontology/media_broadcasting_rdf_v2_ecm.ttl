    rdfs:range xsd:decimal .

ind:depreciableBase rdf:type rdf:Property ;
    rdfs:label 'Depreciable Base' ;
    rdfs:comment 'The amount subject to depreciation, calculated as original cost minus salvage value. The total amount to be expensed over the asset\'s useful life. | Column depreciable_base (DECIMAL(18,2)) in finance.depreciation_schedule' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationBookType rdf:type rdf:Property ;
    rdfs:label 'Depreciation Book Type' ;
    rdfs:comment 'The accounting book or ledger for which this depreciation schedule applies. Supports parallel depreciation for different reporting frameworks. | Column depreciation_book_type (STRING) in finance.depreciation_schedule' ;
