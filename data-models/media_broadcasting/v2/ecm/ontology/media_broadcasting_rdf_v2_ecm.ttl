    rdfs:domain ind:FinancialReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconcilerName rdf:type rdf:Property ;
    rdfs:label 'Reconciler Name' ;
