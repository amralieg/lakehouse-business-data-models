    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the contact has explicitly consented to receive marketing and promotional emails. | Column opt_in_email (BOOLEAN) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Indicates whether the contact has consented to receive phone calls for sales and marketing purposes. | Column opt_in_phone (BOOLEAN) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the contact has consented to receive SMS text messages for time-sensitive sales notifications. | Column opt_in_sms (BOOLEAN) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'Contact\'s stated preference for how they wish to be reached for sales discussions and proposal reviews. | Column preferred_communication_channel (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for their account. Used for proposal routing and commission attribution. | Column primary_contact_flag (BOOLEAN) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Classification of the contact\'s relationship strength and priority level. Strategic contacts receive white-glove service and early access to upfront inventory. | Column relationship_tier (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPartnerContactId rdf:type rdf:Property ;
    rdfs:label 'Sales Partner Contact Id' ;
    rdfs:comment 'Foreign key to SSOT partner.partner_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesPartnerPartnerContactId rdf:type rdf:Property ;
    rdfs:label 'Sales Partner Partner Contact Id' ;
    rdfs:comment 'FK to SSOT partner.partner_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesTeamId rdf:type rdf:Property ;
    rdfs:label 'Sales Team Id' ;
    rdfs:comment 'Reference to the sales team or division responsible for this opportunity (e.g., National Sales, Local Sales, Digital Sales). Used for team performance tracking and territory alignment. | Column sales_team_id (BIGINT) in sales.opportunity' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary marketing objective the advertiser aims to achieve with this campaign. Influences creative strategy, placement selection, and success metrics. [ENUM-REF-CANDIDATE: brand_awareness|product_launch|direct_response|lead_generation|traffic|engagement|video_views|app_installs — 8 candidates stripped; promote to reference product] | Column campaign_objective (STRING) in sales.opportunity' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Target date by which the sales team expects to close this opportunity (win or lose). Used for pipeline forecasting and sales velocity tracking. Updated as negotiations progress. | Column close_date (DATE) in sales.opportunity' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Actual date when the opportunity was marked as closed-won or closed-lost. Null for open opportunities. Used for sales cycle analysis and win rate calculation. | Column closed_date (DATE) in sales.opportunity' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveDisplacement rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement' ;
    rdfs:comment 'Free-text notes capturing competitive intelligence about which competitor this deal may displace or compete against. Used for win/loss analysis and competitive strategy. | Column competitive_displacement (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Total estimated revenue value of the opportunity in USD. For advertising deals, represents total campaign spend; for content licensing, represents license fee. Used for revenue forecasting and quota tracking. | Column estimated_value (DECIMAL(15,2)) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category indicating confidence level for revenue recognition. Pipeline = early stage; Best Case = likely but not committed; Commit = high confidence; Closed = won. Used for revenue forecasting rollups. | Column forecast_category (STRING) in sales.opportunity' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUpfront rdf:type rdf:Property ;
    rdfs:label 'Is Upfront' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity is part of the annual upfront sales season. True = upfront commitment; False = scatter market or other deal type. Used for upfront tracking and reporting. | Column is_upfront (BOOLEAN) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin channel of this sales opportunity. Tracks how the lead was generated for marketing attribution and lead source ROI analysis. [ENUM-REF-CANDIDATE: inbound|outbound|referral|event|partner|renewal|upsell — 7 candidates stripped; promote to reference product] | Column lead_source (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossNotes rdf:type rdf:Property ;
    rdfs:label 'Loss Notes' ;
    rdfs:comment 'Free-text detailed explanation of why the opportunity was lost. Captures competitive intelligence, pricing feedback, and strategic insights for future deals. | Column loss_notes (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for losing the opportunity if stage is closed-lost. Used for loss analysis, competitive intelligence, and sales process improvement. Null for won or open opportunities. | Column loss_reason (STRING) in sales.opportunity' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the sales opportunity, typically including advertiser name, campaign type, and time period (e.g., \'Acme Corp Q4 Upfront Buy\'). | Column opportunity_name (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity. Used for sales activity tracking and pipeline hygiene. Updated regularly by sales executive. | Column next_step (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Human-readable business identifier for the opportunity, typically auto-generated in format OPP-YYYYNNNN. Used in sales communications and reporting. | Column opportunity_number (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated likelihood of closing this opportunity as a percentage (0.00 to 100.00). Typically aligned with stage (e.g., Proposal = 40%, Negotiation = 60%). Used for weighted pipeline forecasting. | Column probability (DECIMAL(5,2)) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresMakegood rdf:type rdf:Property ;
    rdfs:label 'Requires Makegood' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity includes makegood provisions for audience delivery shortfalls. True = makegoods may be required if audience guarantees are not met. Used for inventory planning. | Column requires_makegood (BOOLEAN) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales pipeline lifecycle. Tracks progression from initial prospecting through closure. Used for pipeline forecasting and sales funnel analysis. | Column stage (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Primary key for proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:proposalApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proposal Approved By Employee Id' ;
    rdfs:comment 'FK to employee who approved the proposal' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:proposalCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proposal Created By Employee Id' ;
    rdfs:comment 'FK to employee who created the proposal' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:proposalRepId rdf:type rdf:Property ;
    rdfs:label 'Proposal Rep Id' ;
    rdfs:comment 'FK to sales rep' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:proposalSalesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Proposal Sales Agency Id' ;
    rdfs:comment 'FK to sales agency' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:proposalSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Proposal Sales Rep Id' ;
    rdfs:comment 'FK to sales representative' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:approvedAt rdf:type rdf:Property ;
    rdfs:label 'Approved At' ;
    rdfs:comment 'Timestamp when proposal was approved' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectedAt rdf:type rdf:Property ;
    rdfs:label 'Rejected At' ;
    rdfs:comment 'Timestamp when proposal was rejected' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedAt rdf:type rdf:Property ;
    rdfs:label 'Submitted At' ;
    rdfs:comment 'Timestamp when proposal was submitted' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of the proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start of proposal validity period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'End of proposal validity period' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalLineId rdf:type rdf:Property ;
    rdfs:label 'Proposal Line Id' ;
    rdfs:comment 'Unique identifier for the proposal line item. Primary key. | Column proposal_line_id (BIGINT) in sales.proposal_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProposalLine .

ind:primaryProposalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Proposal Employee Id' ;
    rdfs:comment 'Reference to the sales user who created this proposal line item. | Column primary_proposal_employee_id (BIGINT) in workforce.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross value of this proposal line before any discounts or adjustments. | Column gross_amount (DECIMAL(15,2)) in sales.proposal_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Length Seconds' ;
    rdfs:comment 'Duration of each advertising unit in seconds (e.g., 15, 30, 60 seconds for spots). | Column unit_length_seconds (INT) in sales.proposal_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Quantity' ;
    rdfs:comment 'Number of advertising units or spots being proposed in this line (e.g., 30 spots, 5 sponsorships). | Column unit_quantity (INT) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upfrontCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Upfront Commitment Id' ;
    rdfs:comment 'Unique identifier for the upfront commitment record. Primary key. | Column upfront_commitment_id (BIGINT) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontCommitment .

ind:adjustedCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Commitment Amount' ;
    rdfs:comment 'The current binding commitment amount after all option exercises and cancellations have been applied. Calculated as total_committed_spend minus total_cancelled_amount. | Column adjusted_commitment_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationOptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Percentage' ;
    rdfs:comment 'The percentage of the total commitment that the advertiser has the option to cancel at defined option dates, typically 50%. | Column cancellation_option_percentage (DECIMAL(5,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business identifier for the upfront commitment, used in sales and billing communications. | Column commitment_number (STRING) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the upfront commitment. [ENUM-REF-CANDIDATE: draft|pending_approval|confirmed|active|partially_fulfilled|fulfilled|cancelled|expired — 8 candidates stripped; promote to reference product] | Column commitment_status (STRING) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Grp Volume' ;
    rdfs:comment 'The total GRP volume committed by the advertiser across the upfront period. GRP represents the sum of ratings achieved by the campaign. | Column committed_grp_volume (DECIMAL(12,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedImpressionVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Impression Volume' ;
    rdfs:comment 'The total number of impressions committed by the advertiser across the upfront period, typically used for digital and streaming platforms. | Column committed_impression_volume (BIGINT) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartAllocation rdf:type rdf:Property ;
    rdfs:label 'Daypart Allocation' ;
    rdfs:comment 'The broadcast daypart segments allocated for this upfront commitment (e.g., Prime Time, Early Morning, Late Night). Multiple dayparts may be specified. | Column daypart_allocation (STRING) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Delivered Spend To Date' ;
    rdfs:comment 'The cumulative dollar amount that has been delivered against this upfront commitment through actual ad orders and campaigns. | Column delivered_spend_to_date (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Digital Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to digital platform inventory. | Column digital_allocation_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstOptionDate rdf:type rdf:Property ;
    rdfs:label 'First Option Date' ;
    rdfs:comment 'The first date on which the advertiser may exercise their cancellation option. | Column first_option_date (DATE) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedCpm rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Cpm' ;
    rdfs:comment 'The guaranteed CPM rate negotiated for this upfront commitment. CPM represents the cost per thousand impressions. | Column guaranteed_cpm (DECIMAL(10,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Linear Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to linear (traditional broadcast) television inventory. | Column linear_allocation_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCommitmentBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Commitment Balance' ;
    rdfs:comment 'The remaining dollar amount yet to be fulfilled against the adjusted commitment. Calculated as adjusted_commitment_amount minus delivered_spend_to_date. | Column remaining_commitment_balance (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondOptionDate rdf:type rdf:Property ;
    rdfs:label 'Second Option Date' ;
    rdfs:comment 'The second date on which the advertiser may exercise their cancellation option, if applicable. | Column second_option_date (DATE) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:streamingAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Streaming Allocation Amount' ;
    rdfs:comment 'The portion of the total committed spend allocated to streaming (OTT, SVOD, AVOD) platform inventory. | Column streaming_allocation_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdOptionDate rdf:type rdf:Property ;
    rdfs:label 'Third Option Date' ;
    rdfs:comment 'The third date on which the advertiser may exercise their cancellation option, if applicable. | Column third_option_date (DATE) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cancelled Amount' ;
    rdfs:comment 'The cumulative dollar amount that has been cancelled by the advertiser across all option exercise events. | Column total_cancelled_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalExercisedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Exercised Amount' ;
    rdfs:comment 'The cumulative dollar amount that has been exercised (confirmed for delivery) across all option exercise events. | Column total_exercised_amount (DECIMAL(18,2)) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontYear rdf:type rdf:Property ;
    rdfs:label 'Upfront Year' ;
    rdfs:comment 'The broadcast season year for this upfront commitment, typically formatted as YYYY-YYYY (e.g., 2024-2025). | Column upfront_year (STRING) in sales.upfront_commitment' ;
    rdfs:domain ind:UpfrontCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'FK to sales rep' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:scatterApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scatter Approved By Employee Id' ;
    rdfs:comment 'FK to employee who approved the order' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scatterCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scatter Created By Employee Id' ;
    rdfs:comment 'FK to employee who created the order' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scatterSalesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Scatter Sales Agency Id' ;
    rdfs:comment 'FK to sales agency' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:confirmedAt rdf:type rdf:Property ;
    rdfs:label 'Confirmed At' ;
    rdfs:comment 'Timestamp when order was confirmed' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderName rdf:type rdf:Property ;
    rdfs:label 'Order Name' ;
    rdfs:comment 'Human-readable name for the scatter order' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Scatter Order Number' ;
    rdfs:comment 'Unique scatter order reference number' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpots rdf:type rdf:Property ;
    rdfs:label 'Total Spots' ;
    rdfs:comment 'Total number of ad spots in the order' ;
    rdfs:domain ind:ScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitRequired rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required' ;
    rdfs:comment 'Indicates whether proof-of-broadcast affidavits are required for this order to verify that ads were delivered as contracted. | Column affidavit_required (BOOLEAN) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'The date when the advertising sales contract was executed and signed by both parties. | Column contract_signed_date (DATE) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grpGuarantee rdf:type rdf:Property ;
    rdfs:label 'Grp Guarantee' ;
    rdfs:comment 'The guaranteed Gross Rating Points committed to the advertiser, representing the total percentage of the target audience reached multiplied by frequency. | Column grp_guarantee (DECIMAL(10,2)) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionGuarantee rdf:type rdf:Property ;
    rdfs:label 'Impression Guarantee' ;
    rdfs:comment 'The total number of impressions guaranteed to be delivered under this advertising order. | Column impression_guarantee (BIGINT) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isciCodes rdf:type rdf:Property ;
    rdfs:label 'Isci Codes' ;
    rdfs:comment 'Comma-separated list of ISCI codes identifying the creative assets approved for use in this advertising order. | Column isci_codes (STRING) in sales.ad_sales_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodProvisions rdf:type rdf:Property ;
    rdfs:label 'Makegood Provisions' ;
    rdfs:comment 'The contractual provisions defining how compensatory ad spots will be provided if the broadcaster fails to deliver the guaranteed audience or impressions. | Column makegood_provisions (STRING) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Preemption Risk Level' ;
    rdfs:comment 'The level of risk that this order may be preempted by higher-priority advertising inventory. Non-preemptible orders have guaranteed placement, while high-risk orders may be bumped for premium advertisers. | Column preemption_risk_level (STRING) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClass rdf:type rdf:Property ;
    rdfs:label 'Priority Class' ;
    rdfs:comment 'The priority classification of this order in the ad scheduling and trafficking system, determining placement precedence during inventory conflicts. | Column priority_class (STRING) in sales.ad_sales_order' ;
    rdfs:domain ind:AdSalesOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Unique identifier for the order line item. Primary key for the order line entity. | Column order_line_id (BIGINT) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airEndDate rdf:type rdf:Property ;
    rdfs:label 'Air End Date' ;
    rdfs:comment 'End date of the flight period for this ad unit. Defines the conclusion of the campaign window. | Column air_end_date (DATE) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airStartDate rdf:type rdf:Property ;
    rdfs:label 'Air Start Date' ;
    rdfs:comment 'Start date of the flight period for this ad unit. Used for campaigns spanning multiple days or weeks. | Column air_start_date (DATE) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Flag' ;
    rdfs:comment 'Indicates whether this line item has a guaranteed delivery commitment (impressions, GRPs, or placement) versus best-effort delivery. | Column guaranteed_flag (BOOLEAN) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programmaticFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Flag' ;
    rdfs:comment 'Indicates whether this line item was sold through programmatic advertising channels (automated bidding and buying). | Column programmatic_flag (BOOLEAN) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesType rdf:type rdf:Property ;
    rdfs:label 'Sales Type' ;
    rdfs:comment 'Type of sales transaction: upfront (advance commitment), scatter (last-minute inventory), direct, programmatic, sponsorship, or barter. | Column sales_type (STRING) in sales.order_line' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Licensor Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Content license deals are negotiated with content owners/licensors who are formal partners (studios, production companies, distributors). Critical for tracking licensor relationships, managing royalty | Column licensor_partner_partner_partner_id (BIGINT) in partner.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether this deal is eligible for sales commission calculation and payout. | Column commission_eligible_flag (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'The commission rate percentage applicable to this deal for sales compensation purposes. | Column commission_rate_percentage (DECIMAL(5,2)) in sales.content_license_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deal value amount. | Column deal_value_currency (STRING) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'The date when the contract was formally executed and signed by all parties, making it legally binding. | Column executed_date (DATE) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeStructure rdf:type rdf:Property ;
    rdfs:label 'License Fee Structure' ;
    rdfs:comment 'The pricing model or fee structure governing how the licensee compensates the licensor for the content rights. | Column license_fee_structure (STRING) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformRightsAvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Avod' ;
    rdfs:comment 'Indicates whether the license grants rights for Advertising-Supported Video On Demand (AVOD) distribution. | Column platform_rights_avod (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsFast rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Fast' ;
    rdfs:comment 'Indicates whether the license grants rights for Free Ad-Supported Streaming Television (FAST) channels. | Column platform_rights_fast (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsLinear rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Linear' ;
    rdfs:comment 'Indicates whether the license grants rights for traditional scheduled linear broadcasting. | Column platform_rights_linear (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsSvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Svod' ;
    rdfs:comment 'Indicates whether the license grants rights for Subscription Video On Demand (SVOD) distribution. | Column platform_rights_svod (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformRightsTvod rdf:type rdf:Property ;
    rdfs:label 'Platform Rights Tvod' ;
    rdfs:comment 'Indicates whether the license grants rights for Transactional Video On Demand (TVOD) distribution. | Column platform_rights_tvod (BOOLEAN) in sales.content_license_deal' ;
    rdfs:domain ind:ContentLicenseDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRightsRightsSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Sales Rights Rights Syndication Deal Id' ;
    rdfs:comment 'FK reference to canonical source' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsSyndicationDeal .

ind:salesRightsSyndicationDealId rdf:type rdf:Property ;
    rdfs:label 'Sales Rights Syndication Deal Id' ;
    rdfs:comment 'FK to rights syndication deal for licensing terms | Column rights_syndication_deal_id (BIGINT) in rights.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsSyndicationDeal .

ind:syndicationMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Syndication Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Syndication deals license specific program assets to local stations/broadcasters. While content_package_id references the editorial package, syndication_media_asset_id links to the actual broadcast ma | Column syndication_media_asset_id (BIGINT) in mediaasset.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:barterSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Barter Split Percentage' ;
    rdfs:comment 'Percentage of advertising inventory retained by the syndicator versus sold by the station. For example, 70/30 split means syndicator retains 70% of ad inventory and station sells 30%. Null for pure cash deals. | Column barter_split_percentage (DECIMAL(5,2)) in sales.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashLicenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cash License Fee Amount' ;
    rdfs:comment 'Total cash license fee paid by the station or station group to the syndicator for the content rights over the deal term. Null for pure barter deals. | Column cash_license_fee_amount (DECIMAL(15,2)) in sales.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearancePercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Clearance Percentage Target' ;
    rdfs:comment 'Target percentage of U.S. television households or market coverage that must be achieved for the syndication deal to be considered successful. Clearance is the percentage of the national audience that has access to the syndicated program. | Column clearance_percentage_target (DECIMAL(5,2)) in sales.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationCount rdf:type rdf:Property ;
    rdfs:label 'Station Count' ;
    rdfs:comment 'Number of broadcast stations or outlets that have committed to air the syndicated content under this deal. | Column station_count (INT) in sales.sales_syndication_deal' ;
    rdfs:domain ind:SalesSyndicationDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageDealId rdf:type rdf:Property ;
    rdfs:label 'Carriage Deal Id' ;
    rdfs:comment 'Unique identifier for the carriage deal. Primary key for this entity. | Column carriage_deal_id (BIGINT) in sales.carriage_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageDeal .

ind:originationBroadcastFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origination Broadcast Facility Id' ;
    rdfs:comment 'Foreign key linking to technology.broadcast_facility. Business justification: Carriage agreements specify the origination facility for signal delivery to distribution partners. Required for signal handoff coordination, technical specifications, SLA monitoring, and operational e | Column origination_broadcast_facility_id (BIGINT) in technology.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastFacility .

ind:advertisingRevenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Advertising Revenue Share Pct' ;
    rdfs:comment 'Percentage of advertising revenue generated on the carried channel(s) that is shared with the operator, if applicable. | Column advertising_revenue_share_pct (DECIMAL(5,2)) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutZoneRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Zone Restrictions' ;
    rdfs:comment 'Geographic regions or designated market areas (DMAs) where content must be blacked out due to territorial rights restrictions or sports blackout rules. | Column blackout_zone_restrictions (STRING) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdTierFlag rdf:type rdf:Property ;
    rdfs:label 'Hd Tier Flag' ;
    rdfs:comment 'Indicates whether the channel(s) are carried in the operators high-definition tier. | Column hd_tier_flag (BOOLEAN) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mostFavoredNationClause rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nation Clause' ;
    rdfs:comment 'Indicates whether the agreement includes a most-favored-nation clause guaranteeing the operator receives terms no less favorable than those offered to other operators. | Column most_favored_nation_clause (BOOLEAN) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mustCarryDesignation rdf:type rdf:Property ;
    rdfs:label 'Must Carry Designation' ;
    rdfs:comment 'Indicates whether this carriage is mandated under FCC must-carry rules, requiring cable operators to carry local broadcast stations without compensation. | Column must_carry_designation (BOOLEAN) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsNetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Net Days' ;
    rdfs:comment 'Number of days from invoice date within which the operator must remit carriage fee payment (e.g., Net 30, Net 60). | Column payment_terms_net_days (INT) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceGuaranteeSla rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Sla' ;
    rdfs:comment 'Service level agreement terms specifying uptime, signal quality, and technical performance guarantees for channel delivery. | Column performance_guarantee_sla (STRING) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Date' ;
    rdfs:comment 'Date by which either party must exercise renewal option or provide notice of non-renewal. | Column renewal_option_date (DATE) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retransmissionConsentDesignation rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Designation' ;
    rdfs:comment 'Indicates whether this carriage is governed by retransmission consent rules, allowing broadcasters to negotiate compensation for signal rebroadcast. | Column retransmission_consent_designation (BOOLEAN) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retransmissionConsentFee rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Fee' ;
    rdfs:comment 'Specific fee negotiated under retransmission consent rules for rebroadcast authorization of over-the-air signals. May be same as or distinct from general carriage fee. | Column retransmission_consent_fee (DECIMAL(15,4)) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdTierFlag rdf:type rdf:Property ;
    rdfs:label 'Sd Tier Flag' ;
    rdfs:comment 'Indicates whether the channel(s) are carried in the operators standard-definition tier. | Column sd_tier_flag (BOOLEAN) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierPlacement rdf:type rdf:Property ;
    rdfs:label 'Tier Placement' ;
    rdfs:comment 'Operator service tier in which the channel(s) are placed: basic (lowest tier), expanded basic, digital, premium, or specialized tiers (sports, news, entertainment), or a-la-carte (individual channel purchase). [ENUM-REF-CANDIDATE: basic|expanded_basic|digital|premium|sports|news|entertainment|a_la_carte — 8 candidates stripped; promote to reference product] | Column tier_placement (STRING) in sales.carriage_deal' ;
    rdfs:domain ind:CarriageDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCommissionId rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Id' ;
    rdfs:comment 'Unique identifier for the agency commission record. Primary key. | Column agency_commission_id (BIGINT) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDealTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Deal Types' ;
    rdfs:comment 'Comma-separated list of deal types to which this commission structure applies (e.g., upfront, scatter, sponsorship, programmatic). Empty indicates all deal types are eligible. | Column applicable_deal_types (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the commission amount was calculated by the system. Used for audit trail and version control. | Column calculation_timestamp (TIMESTAMP) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'The total commission amount earned by the agency for this order, calculated based on commission rate and basis. Expressed in the transaction currency. | Column commission_amount (DECIMAL(15,2)) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'The financial basis on which the commission is calculated. Gross billings includes all charges before discounts; net billings deducts agency commission; net net deducts both agency commission and cash discount; revenue recognized uses the accounting revenue figure. | Column commission_basis (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStatus rdf:type rdf:Property ;
    rdfs:label 'Commission Status' ;
    rdfs:comment 'Current lifecycle status of the commission record. Pending indicates awaiting calculation; calculated means amount determined but not approved; approved is ready for payment; paid indicates payment completed; disputed flags reconciliation issues; reversed indicates a reversal transaction; cancelled means the commission was voided. [ENUM-REF-CANDIDATE: pending|calculated|approved|paid|disputed|reversed|cancelled — 7 candidates stripped; promote to reference product] | Column commission_status (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionStructureCode rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Code' ;
    rdfs:comment 'Business identifier for the commission structure applied to this record. Used for reporting and reconciliation across systems. | Column commission_structure_code (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionType rdf:type rdf:Property ;
    rdfs:label 'Commission Type' ;
    rdfs:comment 'Classification of the commission structure. Standard represents the typical 15% agency commission; negotiated indicates custom rates; tiered applies different rates based on volume; performance-based ties commission to campaign outcomes; flat fee is a fixed amount; hybrid combines multiple methods. | Column commission_type (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which a disputed commission was resolved and either approved for payment or cancelled. | Column dispute_resolution_date (DATE) in sales.agency_commission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Order Gross Amount' ;
    rdfs:comment 'The gross billing amount of the associated ad order before any deductions. Used as the basis for commission calculation when commission_basis is gross_billings. | Column order_gross_amount (DECIMAL(15,2)) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNetAmount rdf:type rdf:Property ;
    rdfs:label 'Order Net Amount' ;
    rdfs:comment 'The net billing amount of the associated ad order after agency commission deduction. Used as the basis for commission calculation when commission_basis is net_billings. | Column order_net_amount (DECIMAL(15,2)) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person who approved the commission override. Required for audit compliance when override_flag is true. | Column override_approved_by (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this commission record was manually overridden from the standard calculation. True when a manual adjustment was applied; false for standard automated calculation. | Column override_flag (BOOLEAN) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification for manual override of the commission calculation. Required when override_flag is true. Documents special circumstances, contractual exceptions, or correction rationale. | Column override_reason (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes documenting reconciliation activities, discrepancies found, resolution steps, or special handling instructions. Used for audit trail and dispute resolution. | Column reconciliation_notes (STRING) in sales.agency_commission' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this record in the source operational system. Used for traceability and data lineage. | Column source_record_reference (STRING) in sales.agency_commission' ;
    rdfs:domain ind:AgencyCommission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Foreign key reference to the sales manager or team lead who supervises this sales representative. Self-referential relationship within the sales rep hierarchy. | Column manager_rep_id (BIGINT) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountPortfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Account Portfolio Segment' ;
    rdfs:comment 'Classification of the account portfolio managed by the sales representative. Indicates whether they manage agency relationships, direct advertiser accounts, distribution partners (MVPD/vMVPD), OTT platforms, syndication buyers, or other client segments. [ENUM-REF-CANDIDATE: agency|direct_advertiser|mvpd|vmvpd|ott_platform|syndicator|international|government — 8 candidates stripped; promote to reference product] | Column account_portfolio_segment (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Total annual revenue quota assigned to the sales representative for the current quota period. Measured in the company\'s reporting currency. | Column annual_quota_amount (DECIMAL(18,2)) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPlanType rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Type' ;
    rdfs:comment 'Type of commission structure applied to the sales representative. Defines how commissions are calculated based on sales performance (e.g., base salary plus commission, commission-only, tiered rates, accelerators for exceeding quota). | Column commission_plan_type (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealTypeSpecialization rdf:type rdf:Property ;
    rdfs:label 'Deal Type Specialization' ;
    rdfs:comment 'Primary deal type or sales channel specialization for the representative. Indicates whether they focus on national TV advertising, digital campaigns, content licensing, syndication deals, or other revenue streams. [ENUM-REF-CANDIDATE: national_tv|local_tv|digital|syndication|licensing|upfront|scatter|programmatic|sponsorship|multi_platform — 10 candidates stripped; promote to reference product] | Column deal_type_specialization (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to sell digital advertising inventory, including OTT, streaming, and programmatic channels. | Column digital_certified_flag (BOOLEAN) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired or onboarded into the sales organization. | Column hire_date (DATE) in sales.rep' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repName rdf:type rdf:Property ;
    rdfs:label 'Rep Name' ;
    rdfs:comment 'Full legal name of the sales representative as it appears in business records and communications. | Column rep_name (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Primary office location or city where the sales representative is based. May be a physical office or designated home office location. | Column office_location (STRING) in sales.rep' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, GBP, EUR). | Column quota_currency_code (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'End date of the current quota period for the sales representative. | Column quota_period_end_date (DATE) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'Start date of the current quota period for the sales representative. Typically aligns with fiscal year or calendar year. | Column quota_period_start_date (DATE) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current operational status of the sales representative within the sales organization. Indicates whether they are actively selling, on leave, or no longer with the company. | Column rep_status (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Reference' ;
    rdfs:comment 'Unique user identifier in Salesforce Media Cloud CRM system. Links the sales rep record to their Salesforce user profile for opportunity tracking and pipeline management. | Column salesforce_user_reference (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'Geographic or market territory assigned to the sales representative. May be defined by region, DMA (Designated Market Area), or account segment. | Column territory_assignment (STRING) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Certified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sales representative is certified and authorized to negotiate and close upfront advertising deals. Upfront deals are advance commitments made during the annual upfront sales event. | Column upfront_certified_flag (BOOLEAN) in sales.rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedSalesTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Team Id' ;
    rdfs:comment 'Identifier of the sales team collectively responsible for this territory, if team-based assignment is used. | Column assigned_sales_team_id (BIGINT) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTeam .

ind:parentTerritorySalesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Sales Territory Id' ;
    rdfs:comment 'Identifier of the parent territory in a hierarchical territory structure. Null for top-level territories. | Column parent_territory_sales_territory_id (BIGINT) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:salesRightsRightsTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Rights Rights Territory Id' ;
    rdfs:comment 'FK to SSOT rights.rights_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsTerritory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Number of active advertiser or agency accounts assigned to this territory. | Column account_count (INT) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSegment rdf:type rdf:Property ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Classification of accounts within this territory by size or relationship type: enterprise (largest accounts), major (key accounts), mid_market, small_business, agency (advertising agencies), or direct (direct advertisers). | Column account_segment (STRING) in sales.sales_territory' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Standard commission percentage rate applied to sales within this territory for compensation calculation. | Column commission_rate_percent (DECIMAL(5,2)) in sales.sales_territory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaList rdf:type rdf:Property ;
    rdfs:label 'Dma List' ;
    rdfs:comment 'Comma-separated list of Nielsen DMA codes or names included in this territory for broadcast market segmentation. | Column dma_list (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineFocus rdf:type rdf:Property ;
    rdfs:label 'Product Line Focus' ;
    rdfs:comment 'Primary advertising product lines or inventory types this territory is authorized to sell (e.g., Linear TV, Digital Video, OTT/Streaming, Radio, Display, Sponsorships). Comma-separated for multiple product lines. | Column product_line_focus (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Amount' ;
    rdfs:comment 'Annual or period revenue quota assigned to this territory, used for quota allocation and performance tracking. | Column revenue_target_amount (DECIMAL(18,2)) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue target amount (e.g., USD, GBP, EUR). | Column revenue_target_currency (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterMarketFlag rdf:type rdf:Property ;
    rdfs:label 'Scatter Market Flag' ;
    rdfs:comment 'Indicates whether this territory handles scatter market (last-minute, short-term) ad inventory sales. True if scatter sales are part of territory scope. | Column scatter_market_flag (BOOLEAN) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the territory scope, coverage rules, special conditions, and strategic objectives. | Column territory_description (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory: active (in use), inactive (not currently assigned), pending (awaiting activation), suspended (temporarily disabled), or archived (historical record). | Column territory_status (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Upfront Participation Flag' ;
    rdfs:comment 'Indicates whether this territory participates in annual upfront advertising sales events. True if territory is included in upfront planning and commitments. | Column upfront_participation_flag (BOOLEAN) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verticalIndustryFocus rdf:type rdf:Property ;
    rdfs:label 'Vertical Industry Focus' ;
    rdfs:comment 'Primary industry vertical or sector this territory specializes in (e.g., Automotive, Pharmaceutical, Retail, Entertainment, Financial Services, Technology). Used for vertical-based territory models. | Column vertical_industry_focus (STRING) in sales.sales_territory' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date when the advertiser or agency communicated their final decision on the RFP (awarded or lost). Nullable until decision is made. | Column award_decision_date (DATE) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total dollar value of the campaign if the RFP was awarded to the broadcaster. Nullable if RFP was lost or still pending. Used for revenue forecasting and sales performance tracking. | Column awarded_amount (DECIMAL(15,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amounts (e.g., USD, GBP, EUR). Ensures consistent financial reporting across international campaigns. | Column budget_currency_code (STRING) in sales.rfp' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetRangeMax rdf:type rdf:Property ;
    rdfs:label 'Budget Range Max' ;
    rdfs:comment 'Maximum budget amount the advertiser is willing to commit for the campaign. Defines the upper bound for proposal pricing. | Column budget_range_max (DECIMAL(15,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRangeMin rdf:type rdf:Property ;
    rdfs:label 'Budget Range Min' ;
    rdfs:comment 'Minimum budget amount the advertiser is willing to commit for the campaign. Used for opportunity qualification and inventory allocation. | Column budget_range_min (DECIMAL(15,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSeparationRequirements rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Requirements' ;
    rdfs:comment 'Rules for separating this advertiser\'s spots from competing brands within the same ad pod or program. Typically specifies minimum time separation or exclusivity within a break. | Column competitive_separation_requirements (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdjacencyRestrictions rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Restrictions' ;
    rdfs:comment 'Advertiser-specified restrictions on content types or genres where ads should not appear (e.g., no violent content, no political programming, no competitive sports). Used for brand safety and compliance. | Column content_adjacency_restrictions (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartRequirements rdf:type rdf:Property ;
    rdfs:label 'Daypart Requirements' ;
    rdfs:comment 'Specific broadcast daypart preferences or requirements (e.g., Prime Time, Early Morning, Late Night, Weekend). Dayparts are time segments of the broadcast day used for scheduling and pricing. | Column daypart_requirements (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredFrequency rdf:type rdf:Property ;
    rdfs:label 'Desired Frequency' ;
    rdfs:comment 'Target average number of times each unique viewer should be exposed to the advertisement during the campaign. Frequency is a key metric for message reinforcement. | Column desired_frequency (DECIMAL(5,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredGrpTarget rdf:type rdf:Property ;
    rdfs:label 'Desired Grp Target' ;
    rdfs:comment 'Target Gross Rating Points the advertiser seeks to achieve. GRP is a standard audience measurement metric representing the sum of all rating points delivered by a campaign. | Column desired_grp_target (DECIMAL(10,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredImpressions rdf:type rdf:Property ;
    rdfs:label 'Desired Impressions' ;
    rdfs:comment 'Total number of ad impressions the advertiser seeks to purchase. An impression represents a single ad view by a viewer. | Column desired_impressions (BIGINT) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:desiredReachPercent rdf:type rdf:Property ;
    rdfs:label 'Desired Reach Percent' ;
    rdfs:comment 'Target percentage of unique audience members the advertiser wants to reach at least once during the campaign. Reach is a key audience delivery metric. | Column desired_reach_percent (DECIMAL(5,2)) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModelPreference rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Preference' ;
    rdfs:comment 'Advertiser\'s preferred pricing structure for the campaign. Options include Cost Per Mille (CPM), Cost Per Rating Point (CPRP), flat rate, performance-based, or hybrid models. | Column pricing_model_preference (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the broadcaster submitted their proposal response to the RFP. Nullable until response is completed. Used to track response turnaround time. | Column response_submitted_date (DATE) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Business identifier for the RFP, typically assigned by the source system or agency. Used for external reference and tracking. | Column rfp_number (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the RFP in the sales pipeline. Tracks progression from receipt through final disposition. | Column rfp_status (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'Specific age demographic range requested by the advertiser (e.g., 18-34, 25-54, 35-49). Used for audience targeting and rate card selection. | Column target_age_range (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDescription rdf:type rdf:Property ;
    rdfs:label 'Target Audience Description' ;
    rdfs:comment 'Narrative description of the desired audience demographics and psychographics, including age range, gender, household income (HHI), geography, interests, and behavioral attributes. | Column target_audience_description (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'Gender demographic targeting requirement specified in the RFP. May be male, female, all genders, or unspecified. | Column target_gender (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeography rdf:type rdf:Property ;
    rdfs:label 'Target Geography' ;
    rdfs:comment 'Geographic targeting requirements, including designated market areas (DMAs), regions, states, or national coverage. May include multiple geographies separated by delimiters. | Column target_geography (STRING) in sales.rfp' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availId rdf:type rdf:Property ;
    rdfs:label 'Avail Id' ;
    rdfs:comment 'Unique identifier for the advertising inventory availability record. | Column avail_id (BIGINT) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAvailEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Avail Employee Id' ;
    rdfs:comment 'Reference to the user who created this availability record. | Column avail_employee_id (BIGINT) in workforce.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availCode rdf:type rdf:Property ;
    rdfs:label 'Avail Code' ;
    rdfs:comment 'Business identifier code for this availability record, typically generated by the traffic system. | Column avail_code (STRING) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Cpm Usd' ;
    rdfs:comment 'Minimum Cost Per Thousand Impressions (CPM) rate in USD that the seller will accept for this inventory. | Column floor_cpm_usd (DECIMAL(12,2)) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorRateUsd rdf:type rdf:Property ;
    rdfs:label 'Floor Rate Usd' ;
    rdfs:comment 'Minimum unit rate in USD that the seller will accept for this advertising slot. | Column floor_rate_usd (DECIMAL(12,2)) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'Date and time when the current hold on this inventory will expire if not confirmed. | Column hold_expiry_timestamp (TIMESTAMP) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Timestamp' ;
    rdfs:comment 'Date and time when the current hold was placed on this inventory. | Column hold_placed_timestamp (TIMESTAMP) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preemptibleFlag rdf:type rdf:Property ;
    rdfs:label 'Preemptible Flag' ;
    rdfs:comment 'Indicates whether this inventory can be preempted by higher-priority advertising (true) or is guaranteed (false). | Column preemptible_flag (BOOLEAN) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectedGrp rdf:type rdf:Property ;
    rdfs:label 'Projected Grp' ;
    rdfs:comment 'Estimated Gross Rating Points this slot is expected to deliver, representing the percentage of the target audience reached multiplied by frequency. | Column projected_grp (DECIMAL(10,2)) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedImpressions rdf:type rdf:Property ;
    rdfs:label 'Projected Impressions' ;
    rdfs:comment 'Estimated number of viewer impressions this advertising slot is expected to deliver based on historical audience data. | Column projected_impressions (BIGINT) in sales.avail' ;
    rdfs:domain ind:Avail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upfrontOptionExerciseId rdf:type rdf:Property ;
    rdfs:label 'Upfront Option Exercise Id' ;
    rdfs:comment 'Unique identifier for the upfront option exercise record. Primary key. | Column upfront_option_exercise_id (BIGINT) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tertiaryUpfrontLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Upfront Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this option exercise record. | Column tertiary_upfront_last_modified_by_user_employee_id (BIGINT) in workforce.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the contract amendment document associated with this option exercise, if applicable. | Column amendment_document_reference (STRING) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for the cancellation or reduction decision. Captured from sales representative or advertiser communication. | Column cancellation_reason_notes (STRING) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Amount' ;
    rdfs:comment 'The dollar amount the advertiser cancelled or declined to commit for this option window. Calculated as original_committed_spend minus exercised_amount. | Column cancelled_amount (DECIMAL(18,2)) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Cancelled Grp Volume' ;
    rdfs:comment 'The Gross Rating Point volume cancelled or declined for this option window. Calculated as committed_grp_volume minus exercised_grp_volume. | Column cancelled_grp_volume (DECIMAL(12,2)) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Required Flag' ;
    rdfs:comment 'Indicates whether this option exercise triggers a formal contract amendment or addendum to the original upfront agreement. True for material changes that require legal documentation. | Column contract_amendment_required_flag (BOOLEAN) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exerciseMethod rdf:type rdf:Property ;
    rdfs:label 'Exercise Method' ;
    rdfs:comment 'The communication channel or method through which the advertiser submitted their option exercise decision (e.g., email notification, phone call, self-service portal, in-person meeting, automatic per contract terms). | Column exercise_method (STRING) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exercisedAmount rdf:type rdf:Property ;
    rdfs:label 'Exercised Amount' ;
    rdfs:comment 'The dollar amount the advertiser confirmed and committed to spend for this option window. May equal original_committed_spend (full exercise) or be less (partial exercise). | Column exercised_amount (DECIMAL(18,2)) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exercisedGrpVolume rdf:type rdf:Property ;
    rdfs:label 'Exercised Grp Volume' ;
    rdfs:comment 'The Gross Rating Point volume the advertiser confirmed for this option window after exercise. May be less than committed_grp_volume if partially exercised. | Column exercised_grp_volume (DECIMAL(12,2)) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Release Date' ;
    rdfs:comment 'The date on which cancelled inventory from this option exercise was released to scatter market availability. Critical for scatter market inventory planning and sales. | Column inventory_release_date (DATE) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Released Flag' ;
    rdfs:comment 'Indicates whether the cancelled inventory from this option exercise has been released back to scatter market availability. True means inventory is available for scatter sales; False means it is still held or being reallocated. | Column inventory_released_flag (BOOLEAN) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Option Deadline Date' ;
    rdfs:comment 'The contractual deadline date by which the advertiser must exercise this option window. Failure to exercise by this date may result in automatic cancellation or confirmation per contract terms. | Column option_deadline_date (DATE) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseDate rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Date' ;
    rdfs:comment 'The date on which the advertiser exercised (confirmed or cancelled) this option window. This is the business event date when the decision was made. | Column option_exercise_date (DATE) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseNumber rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Number' ;
    rdfs:comment 'Business identifier for this option exercise event, typically formatted as commitment number plus option window sequence. | Column option_exercise_number (STRING) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionWindowNumber rdf:type rdf:Property ;
    rdfs:label 'Option Window Number' ;
    rdfs:comment 'Sequential number of the option window within the upfront commitment (e.g., 1 for first option, 2 for second option, 3 for third option). Upfront deals typically have multiple option dates where advertisers can confirm or cancel portions of their commitment. | Column option_window_number (INT) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Original Committed Spend' ;
    rdfs:comment 'The original dollar amount committed for this option window at the time the upfront deal was signed. This is the baseline amount subject to the option exercise decision. | Column original_committed_spend (DECIMAL(18,2)) in sales.upfront_option_exercise' ;
    rdfs:domain ind:UpfrontOptionExercise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique identifier for the revenue forecast record. | Column forecast_id (BIGINT) in sales.forecast' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

