ind:disputedTitleId rdf:type rdf:Property ;
    rdfs:label 'Disputed Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Disputes frequently concern specific title rights interpretation, royalty calculations, or delivery specifications. Legal case management, settlement negotiation, evidence gathering, and contract inte | Column disputed_title_id (BIGINT) in content.partner_dispute' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the receiving party formally acknowledged receipt of the dispute. | Column acknowledgment_date (DATE) in partner.partner_dispute' ;
