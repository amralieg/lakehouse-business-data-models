    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:referredByApplicantId rdf:type rdf:Property ;
    rdfs:label 'Referred By Applicant Id' ;
    rdfs:comment 'Self-referencing FK on applicant (referred_by_applicant_id) | Column referred_by_applicant_id (BIGINT) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Applicant .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of applicant\'s current residential address (street number and name). | Column address_line1 (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of applicant\'s address (apartment, suite, unit number). Nullable. | Column address_line2 (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the applicant. Optional backup contact method. | Column alternate_phone_number (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the applicant submitted their application for the requisition. Business event timestamp for application lifecycle. | Column application_date (DATE) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique application tracking number assigned when candidate submits application. Format: APP-YYYYMMDD-sequence. | Column application_number (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'Channel or platform through which the applicant submitted their application (e.g., LinkedIn, Indeed, employee referral, recruitment agency). | Column application_source (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the application in the recruitment workflow (e.g., new, screening, interviewed, offer extended, rejected). [ENUM-REF-CANDIDATE: new|screening|interview_scheduled|interviewed|offer_extended|offer_accepted|offer_declined|rejected|withdrawn — 9 candidates stripped; promote to reference product] | Column application_status (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckConsent rdf:type rdf:Property ;
    rdfs:label 'Background Check Consent' ;
    rdfs:comment 'Indicates whether the applicant has provided consent for a background check as part of the hiring process. Required for compliance. | Column background_check_consent (BOOLEAN) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverLetterReference rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Reference' ;
    rdfs:comment 'Reference identifier or URI to the applicant\'s cover letter document. Nullable if not provided. | Column cover_letter_reference (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the organization where the applicant is currently employed. Nullable if unemployed or not disclosed. | Column current_employer (STRING) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
