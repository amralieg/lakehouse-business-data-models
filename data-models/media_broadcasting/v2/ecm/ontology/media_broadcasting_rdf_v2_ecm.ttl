    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringProtocol rdf:type rdf:Property ;
    rdfs:label 'Monitoring Protocol' ;
    rdfs:comment 'Technical protocol or method used to collect telemetry and status data from the monitored entity. Examples include SNMP (Simple Network Management Protocol) for device polling, MPEG-TS probe for transport stream analysis, SCTE-35 listener for ad insertion markers. | Column monitoring_protocol (STRING) in technology.noc_monitor' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
