    rdfs:comment 'The date when depreciation was last calculated and posted for this schedule. Used to track period-end close activities. | Column last_depreciation_run_date (DATE) in finance.depreciation_schedule' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDepreciationRunDate rdf:type rdf:Property ;
