    rdfs:range xsd:string .

ind:pollingIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Polling Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which the NOC system queries or samples the monitored entity. Lower intervals provide faster fault detection but increase system load. | Column polling_interval_seconds (INT) in technology.noc_monitor' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redundancyGroup rdf:type rdf:Property ;
    rdfs:label 'Redundancy Group' ;
    rdfs:comment 'Identifier for the redundancy or failover group this monitor belongs to. Multiple monitors in the same group represent primary/backup configurations. | Column redundancy_group (STRING) in technology.noc_monitor' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationScriptPath rdf:type rdf:Property ;
    rdfs:label 'Remediation Script Path' ;
    rdfs:comment 'File system path or identifier of the automated remediation script executed when this monitor triggers an alert. Confidential as it exposes automation logic. | Column remediation_script_path (STRING) in technology.noc_monitor' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdMetric rdf:type rdf:Property ;
    rdfs:label 'Threshold Metric' ;
    rdfs:comment 'The specific performance or quality metric being measured against the alert threshold. Examples: packet_loss_percent, bitrate_mbps, uptime_percent, latency_ms, error_rate. | Column threshold_metric (STRING) in technology.noc_monitor' ;
    rdfs:domain ind:NocMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedChannelId rdf:type rdf:Property ;
