ind:varianceCount rdf:type rdf:Property ;
    rdfs:label 'Variance Count' ;
    rdfs:comment 'Numerical difference between reported subscriber count and verified subscriber count (verified minus reported). | Column variance_count (BIGINT) in distribution.subscriber_count_report' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Detailed explanation provided by the distribution partner or internal audit team describing the reason for any variance between reported and verified counts. | Column variance_explanation (STRING) in distribution.subscriber_count_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Indicator of whether a material variance exists between reported and verified subscriber counts, triggering additional review or dispute resolution. | Column variance_flag (BOOLEAN) in distribution.subscriber_count_report' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the reported subscriber count (automated system check, manual review, third-party audit, statistical sampling, or full audit). | Column verification_method (STRING) in distribution.subscriber_count_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Verified Subscriber Count' ;
    rdfs:comment 'Subscriber count after internal verification and audit processes, used as the basis for carriage fee calculation. | Column verified_subscriber_count (BIGINT) in distribution.subscriber_count_report' ;
    rdfs:domain ind:SubscriberCountReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelLineupId rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Id' ;
    rdfs:comment 'Primary key for channel_lineup | Column channel_lineup_id (BIGINT) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRulesApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Applicable' ;
    rdfs:comment 'Indicates whether geographic broadcast restriction (blackout) rules apply to this channel within the lineup. | Column blackout_rules_applicable (BOOLEAN) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee (e.g., USD, EUR, GBP). | Column carriage_fee_currency_code (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageType rdf:type rdf:Property ;
    rdfs:label 'Carriage Type' ;
    rdfs:comment 'Legal basis for the channel\'s inclusion in the lineup: must-carry (mandatory FCC requirement), retransmission consent (negotiated rebroadcast authorization), or negotiated carriage agreement. | Column carriage_type (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDisplayName rdf:type rdf:Property ;
    rdfs:label 'Channel Display Name' ;
    rdfs:comment 'The branded name of the channel as displayed to subscribers in the EPG (Electronic Program Guide) for this specific lineup. | Column channel_display_name (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Position Number' ;
    rdfs:comment 'Logical channel number or position assigned to the channel within this lineup (e.g., channel 101, channel 502). Used for Electronic Program Guide (EPG) display and subscriber navigation. | Column channel_position_number (INT) in distribution.channel_lineup' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the specific television market where this lineup is offered (e.g., \'501\' for New York). | Column dma_code (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dvrEnabled rdf:type rdf:Property ;
    rdfs:label 'Dvr Enabled' ;
    rdfs:comment 'Indicates whether subscribers can record content from this channel using DVR functionality. | Column dvr_enabled (BOOLEAN) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Rules' ;
    rdfs:comment 'Detailed description of geographic restrictions, including allowed and blocked regions, for subscriber entitlement validation. | Column geographic_restriction_rules (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdAvailable rdf:type rdf:Property ;
    rdfs:label 'Hd Available' ;
    rdfs:comment 'Indicates whether the channel is available in high definition (HD) format within this lineup. | Column hd_available (BOOLEAN) in distribution.channel_lineup' ;
