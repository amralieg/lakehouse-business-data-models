    rdfs:range xsd:string .

ind:deliveryObligationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Obligation Id' ;
    rdfs:comment 'Primary key for delivery_obligation | Column delivery_obligation_id (BIGINT) in partner.delivery_obligation' ;
