    rdfs:comment 'Indicates whether the applicant is willing to relocate for the position if required. | Column willing_to_relocate (BOOLEAN) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant professional work experience reported by the applicant. Used for qualification screening. | Column years_of_experience (DECIMAL(4,1)) in workforce.applicant' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewEventId rdf:type rdf:Property ;
    rdfs:label 'Interview Event Id' ;
    rdfs:comment 'Unique identifier for each interview event conducted as part of the hiring process. | Column interview_event_id (BIGINT) in workforce.interview_event' ;
    rdfs:domain ind:InterviewEvent ;
    rdf:type owl:DatatypeProperty ;
