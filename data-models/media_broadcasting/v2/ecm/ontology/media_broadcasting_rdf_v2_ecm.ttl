    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The contractual or operational SLA target resolution time in minutes for this alert severity level, used as the benchmark for performance measurement. | Column sla_target_minutes (INT) in technology.noc_alert' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacedItAssetId rdf:type rdf:Property ;
    rdfs:label 'Replaced It Asset Id' ;
