    rdfs:label 'Waiver Allowed Flag' ;
    rdfs:comment 'Indicates whether this requirement can be waived for employees in this job profile based on prior experience or equivalent credentials. | Column waiver_allowed_flag (BOOLEAN) in workforce.course_requirement' ;
    rdfs:domain ind:CourseRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

