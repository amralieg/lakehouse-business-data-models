ind:talentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Id' ;
    rdfs:comment 'FK to talent.talent_agency | Column talent_agency_id (BIGINT) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentAgency .

ind:biometricConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Consent Flag' ;
    rdfs:comment 'Indicates whether the talent has provided consent for collection and use of biometric data (facial recognition, voice prints) for digital effects, deepfake prevention, and AI training. Required for GDPR and CCPA compliance. | Column biometric_consent_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiration Date' ;
    rdfs:comment 'The date when the talent\'s current clearance status expires and requires renewal. Used for compliance tracking and production eligibility verification. | Column clearance_expiration_date (DATE) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether the talent is currently bound by an exclusivity clause that restricts their ability to work with competing networks, studios, or brands. Used for conflict checking during casting and booking. | Column exclusivity_clause_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'The talent\'s self-identified gender. Used for diversity reporting, casting analytics, and compliance with equal opportunity regulations. | Column gender_identity (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdbIdentifier rdf:type rdf:Property ;
    rdfs:label 'Imdb Identifier' ;
    rdfs:comment 'The talent\'s unique identifier in the Internet Movie Database (IMDb). Used for cross-referencing filmography, public profile linking, and industry data integration. | Column imdb_identifier (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the talent is currently covered by production insurance (liability, workers compensation, errors and omissions). Required for on-set work authorization. | Column insurance_coverage_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isniCode rdf:type rdf:Property ;
    rdfs:label 'Isni Code' ;
    rdfs:comment 'The International Standard Name Identifier (ISNI) for the talent. A globally unique identifier for creators used in rights management and royalty distribution systems. | Column isni_code (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the talent as it appears on official documents and contracts. Used for contract execution, payroll, and legal compliance. | Column legal_name (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The talent\'s nationality represented as a 3-letter ISO country code. Used for work authorization, tax treaty eligibility, and international co-production compliance. | Column nationality (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible to receive residual payments for reuse of their work in syndication, streaming, or international distribution. Determined by union status and contract terms. | Column residual_eligibility_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'The professional or stage name used by the talent for public appearances, credits, and marketing materials. May differ from legal name. | Column stage_name (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentTier rdf:type rdf:Property ;
    rdfs:label 'Talent Tier' ;
    rdfs:comment 'The classification tier of the talent based on industry recognition, box office draw, and compensation level. Used for budgeting, marketing strategy, and billing rate determination. | Column talent_tier (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentType rdf:type rdf:Property ;
    rdfs:label 'Talent Type' ;
    rdfs:comment 'The primary professional category or role type of the talent. Determines applicable guild rules, contract templates, and credit attribution standards. [ENUM-REF-CANDIDATE: actor|director|writer|producer|host|correspondent|crew|voice_artist|composer|cinematographer — 10 candidates stripped; promote to reference product] | Column talent_type (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The talent\'s tax identification number (SSN, EIN, or international equivalent). Required for payroll processing, tax withholding, and IRS 1099 reporting. | Column tax_id_number (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Union Member Number' ;
    rdfs:comment 'The talent\'s membership identifier within their primary union or guild. Required for residual payment processing and contract compliance verification. | Column union_member_number (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'The talent\'s current work authorization status in the primary production jurisdiction. Determines eligibility for employment and production participation. | Column work_authorization_status (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workVisaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Visa Expiration Date' ;
    rdfs:comment 'The expiration date of the talent\'s work visa. Critical for production scheduling and compliance with immigration regulations. | Column work_visa_expiration_date (DATE) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workVisaType rdf:type rdf:Property ;
    rdfs:label 'Work Visa Type' ;
    rdfs:comment 'The specific type of work visa held by the talent (e.g., O-1, P-1, H-1B). Used for compliance tracking and production planning for international talent. | Column work_visa_type (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation Id' ;
    rdfs:comment 'Unique identifier for the guild affiliation record. Primary key. | Column guild_affiliation_id (BIGINT) in talent.guild_affiliation' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuildAffiliation .

ind:cbaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cba Effective Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement became effective for this membership. | Column cba_effective_date (DATE) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cba Expiration Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement expires. Used to track contract renewal cycles and potential rate changes. | Column cba_expiration_date (DATE) in talent.guild_affiliation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaVersion rdf:type rdf:Property ;
    rdfs:label 'Cba Version' ;
    rdfs:comment 'Version or year identifier of the collective bargaining agreement that governs this membership. Critical for determining applicable residual rates, working conditions, and compensation structures. | Column cba_version (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Dues Payment Status' ;
    rdfs:comment 'Current status of membership dues payment obligations. Current (all dues paid up to date), overdue (payment past due but within grace period), delinquent (significantly past due, may affect standing), exempt (not required to pay dues), waived (dues forgiven by guild). | Column dues_payment_status (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildCode rdf:type rdf:Property ;
    rdfs:label 'Guild Code' ;
    rdfs:comment 'Standardized code identifying the entertainment industry guild or union. SAG-AFTRA (Screen Actors Guild - American Federation of Television and Radio Artists), WGA (Writers Guild of America), DGA (Directors Guild of America), IATSE (International Alliance of Theatrical Stage Employees), AFM (American Federation of Musicians), BECTU (Broadcasting Entertainment Communications and Theatre Union - UK), ACTRA (Alliance of Canadian Cinema Television and Radio Artists). [ENUM-REF-CANDIDATE: SAG-AFTRA|WGA|DGA|IATSE|AFM|BECTU|ACTRA|OTHER — 8 candidates stripped; promote to reference product] | Column guild_code (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildName rdf:type rdf:Property ;
    rdfs:label 'Guild Name' ;
    rdfs:comment 'Full legal name of the guild or union organization. | Column guild_name (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild-provided health insurance benefits based on this membership and earnings thresholds. True if eligible, false otherwise. | Column health_benefits_eligible_flag (BOOLEAN) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'Date when the talent officially became a member of this guild. Used to determine seniority and eligibility for certain benefits. | Column join_date (DATE) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Dues Payment Date' ;
    rdfs:comment 'Date of the most recent membership dues payment received by the guild. | Column last_dues_payment_date (DATE) in talent.guild_affiliation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localChapter rdf:type rdf:Property ;
    rdfs:label 'Local Chapter' ;
    rdfs:comment 'Local chapter, branch, or regional division of the guild to which this membership is assigned. Used for regional governance and event coordination. | Column local_chapter (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Unique membership identifier assigned by the guild to the talent member. Required for residual payment processing and production compliance verification. | Column membership_number (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Classification of membership level within the guild. Full member (standard active membership with full benefits), fi-core (financial core member with limited participation), apprentice (trainee or provisional member), honorary (recognition membership), lifetime (permanent membership status), emeritus (retired member with recognition). | Column membership_tier (STRING) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDuesPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Dues Payment Date' ;
    rdfs:comment 'Date when the next membership dues payment is due. | Column next_dues_payment_date (DATE) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pensionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pension Eligible Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible for guild pension plan contributions and benefits. True if eligible, false otherwise. | Column pension_eligible_flag (BOOLEAN) in talent.guild_affiliation' ;
    rdfs:domain ind:GuildAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financeProductionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Production Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.production_budget. Business justification: Talent contracts are charged against production budgets for cost control, variance analysis, and financial reporting. Every above-the-line deal must track to a specific budget for production accountin | Column finance_production_budget_id (BIGINT) in finance.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBudget .

ind:negotiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Business affairs employees negotiate talent contracts. Required for contract approval workflows, negotiator performance tracking, workload analysis, audit trails, and compliance documentation. Column ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustedGrossParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Adjusted Gross Participation Flag' ;
    rdfs:comment 'Indicates if talent has adjusted gross participation' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The total number of formal amendments made to this contract since initial execution. Tracks contract modification history. | Column amendment_count (INT) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Percentage' ;
    rdfs:comment 'The percentage of net profits, adjusted gross, or other revenue streams the talent is entitled to receive after recoupment of production costs. Common for above-the-line talent. | Column backend_participation_percentage (DECIMAL(5,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backendParticipationType rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Type' ;
    rdfs:comment 'The revenue calculation basis for backend participation. Net profits are after all costs; adjusted gross is after specific deductions; gross receipts are from first dollar. None indicates no backend participation. | Column backend_participation_type (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Base Compensation Amount' ;
    rdfs:comment 'The guaranteed base fee or salary payable to the talent for services rendered under this contract, excluding bonuses, backend participation, and residuals. | Column base_compensation_amount (DECIMAL(18,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCreditPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Credit Position' ;
    rdfs:comment 'The contractually specified position and format of the talent\'s on-screen credit (e.g., \'First Position Main Title\', \'Shared Card\', \'Single Card\', \'Above the Title\'). Critical for talent reputation and guild compliance. | Column billing_credit_position (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base compensation amount (e.g., USD, GBP, EUR). | Column compensation_currency (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentCompensationFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Compensation Flag' ;
    rdfs:comment 'Indicates if contract includes contingent compensation terms' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Business identifier for the contract, typically assigned by legal or business affairs. Used for external reference and tracking. | Column contract_number (STRING) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current stage of the contract in its lifecycle. Deal memo represents initial short-form agreement; countersigned indicates mutual acceptance; long-form executed is the final detailed contract; amended reflects modifications; suspended indicates temporary hold; terminated is early cancellation; expired is natural end. [ENUM-REF-CANDIDATE: deal_memo|countersigned|long_form_executed|amended|suspended|terminated|expired — 7 candidates stripped; promote to reference product] | Column contract_status (STRING) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacementRequirements rdf:type rdf:Property ;
    rdfs:label 'Credit Placement Requirements' ;
    rdfs:comment 'Detailed contractual requirements for credit placement, including main title vs end credits, paid advertising inclusion, promotional materials, and any special formatting or adjacency requirements. | Column credit_placement_requirements (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Size Percentage' ;
    rdfs:comment 'The minimum size of the talent\'s on-screen credit as a percentage of the title or other reference credit size. Null if not contractually specified. | Column credit_size_percentage (DECIMAL(5,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceUri rdf:type rdf:Property ;
    rdfs:label 'Document Reference Uri' ;
    rdfs:comment 'The storage location or document management system URI for the executed contract document and all amendments. Used for legal reference and audit. | Column document_reference_uri (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'The specific role or position the talent is contracted to perform (e.g., Lead Actor, Director, Showrunner, Writer, Executive Producer, Director of Photography, Host). | Column engagement_role (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingCba rdf:type rdf:Property ;
    rdfs:label 'Governing Cba' ;
    rdfs:comment 'The specific collective bargaining agreement that governs this contract, including version and effective date (e.g., SAG-AFTRA Television Agreement 2020-2023). Defines minimum compensation, working conditions, and residual structures. | Column governing_cba (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Gross Participation Flag' ;
    rdfs:comment 'Indicates if talent has gross participation in revenues' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteedEpisodes rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Episodes' ;
    rdfs:comment 'The minimum number of episodes for which the talent is guaranteed compensation, regardless of actual production. Common in series regular deals. Null for non-episodic contracts. | Column guaranteed_episodes (INT) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Net Participation Flag' ;
    rdfs:comment 'Indicates if talent has net participation in revenues' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionExerciseDeadline rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Deadline' ;
    rdfs:comment 'The date by which the company must notify the talent of its decision to exercise or decline the next option period. Null if no active option exists. | Column option_exercise_deadline (DATE) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Status' ;
    rdfs:comment 'Current status of the most recent option period. Not applicable if no options exist; pending if decision deadline has not passed; exercised if company extended; declined if company chose not to extend; expired if deadline passed without action. | Column option_exercise_status (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Option Periods Count' ;
    rdfs:comment 'The number of option periods (typically annual) the company holds to extend the contract beyond the initial term. Common in series regular and overall deals. | Column option_periods_count (INT) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payOrPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Or Play Flag' ;
    rdfs:comment 'Indicates whether the contract includes a pay-or-play provision, guaranteeing full compensation even if the talent services are not ultimately used or the production is cancelled. | Column pay_or_play_flag (BOOLEAN) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepUpAmount rdf:type rdf:Property ;
    rdfs:label 'Step Up Amount' ;
    rdfs:comment 'The incremental increase in base compensation for each exercised option period or season renewal. Null if no step-up provision exists. | Column step_up_amount (DECIMAL(18,2)) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:talentRepresentativeAgency rdf:type rdf:Property ;
    rdfs:label 'Talent Representative Agency' ;
    rdfs:comment 'The name of the agency or firm representing the talent (e.g., CAA, WME, UTA, law firm name). | Column talent_representative_agency (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Talent Representative Name' ;
    rdfs:comment 'The name of the talent\'s agent, manager, or attorney who negotiated on behalf of the talent. | Column talent_representative_name (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The primary reason for early contract termination. Null if contract was not terminated early. [ENUM-REF-CANDIDATE: mutual_agreement|breach_of_contract|force_majeure|production_cancellation|talent_unavailability|company_convenience|talent_request|other — 8 candidates stripped; promote to reference product] | Column termination_reason (STRING) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructureId rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure Id' ;
    rdfs:comment 'Unique identifier for the compensation structure record. Primary key. | Column compensation_structure_id (BIGINT) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cbaRateCardId rdf:type rdf:Property ;
    rdfs:label 'Cba Rate Card Id' ;
    rdfs:comment 'Foreign key linking to talent.cba_rate_card. Business justification: compensation_structure defines detailed compensation terms for talent contracts. Currently has union_scale_tier (STRING) and guild_affiliation (STRING) but no FK to the CBA rate card that defines mini | Column cba_rate_card_id (BIGINT) in talent.compensation_structure' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CbaRateCard .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Business affairs employees modify compensation structures. Required for audit trails, approval workflows, financial controls, and compliance tracking. Column modified_by_user is denormalized employee ' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backendGrossParticipationPct rdf:type rdf:Property ;
    rdfs:label 'Backend Gross Participation Pct' ;
    rdfs:comment 'The percentage of adjusted gross receipts or backend profits the talent is entitled to receive (e.g., 0.05 for 5% backend participation). Null if no backend participation is granted. | Column backend_gross_participation_pct (DECIMAL(5,4)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Base Episode Fee' ;
    rdfs:comment 'The guaranteed compensation amount per episode for episodic talent (actors, writers, directors). Expressed in the contract currency. | Column base_episode_fee (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The fixed or maximum bonus amount payable when the bonus threshold is met. Expressed in the contract currency. Null if no bonus provision exists. | Column bonus_amount (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusThresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Threshold Description' ;
    rdfs:comment 'Textual description of the performance or milestone thresholds that trigger bonus payments (e.g., \'Nielsen rating above 2.0 in key demo\', \'box office exceeds $100M domestic\'). | Column bonus_threshold_description (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakevenDefinition rdf:type rdf:Property ;
    rdfs:label 'Breakeven Definition' ;
    rdfs:comment 'Definition of breakeven point for net participation calculations' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'The guaranteed daily compensation amount for talent engaged on a day-player or daily basis. Expressed in the contract currency. | Column daily_rate (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation Amount' ;
    rdfs:comment 'The total amount of compensation deferred to a future payment date or contingent event (e.g., series pickup, profitability milestone). Expressed in the contract currency. | Column deferred_compensation_amount (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Deferred Payment Trigger' ;
    rdfs:comment 'The business event or milestone that triggers payment of deferred compensation (e.g., \'series_pickup\', \'profitability_threshold_met\', \'syndication_sale\', \'specific_date\'). | Column deferred_payment_trigger (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'The multiplier applied to the base rate for overtime hours worked (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if overtime is not applicable. | Column overtime_multiplier (DECIMAL(5,2)) in talent.compensation_structure' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Participation Ceiling Amount' ;
    rdfs:comment 'Maximum participation amount cap' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationDefinitionType rdf:type rdf:Property ;
    rdfs:label 'Participation Definition Type' ;
    rdfs:comment 'Type of participation: gross, adjusted_gross, net' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Participation Floor Amount' ;
    rdfs:comment 'Minimum participation amount guaranteed' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationPercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Percentage' ;
    rdfs:comment 'Percentage of participation in revenues' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionHealthRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Rate' ;
    rdfs:comment 'The percentage rate of gross compensation contributed to the guild pension and health plan (e.g., 0.185 for 18.5% SAG-AFTRA P&H). Used to calculate employer contributions. | Column pension_health_rate (DECIMAL(5,4)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Base Formula' ;
    rdfs:comment 'The formula or method used to calculate the residual base for reuse payments (e.g., \'initial_compensation\', \'applicable_minimum\', \'pro_rata_share\'). Defines how residuals are computed per guild rules. | Column residual_base_formula (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepUpTrigger rdf:type rdf:Property ;
    rdfs:label 'Step Up Trigger' ;
    rdfs:comment 'The condition or event that triggers an automatic increase in compensation (e.g., \'season_2_pickup\', \'episode_13_renewal\', \'ratings_threshold\'). Null if no step-up provision exists. | Column step_up_trigger (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Business-friendly name or label for this compensation structure (e.g., \'Series Regular Season 1\', \'Guest Star Rate Card\'). | Column structure_name (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the compensation structure: draft (under negotiation), active (in force), amended (modified after execution), superseded (replaced by a newer structure), or terminated (no longer applicable). | Column structure_status (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Description of the media usage rights covered by this compensation structure (e.g., \'initial broadcast only\', \'all media in perpetuity\', \'theatrical and SVOD\', \'domestic free television\'). Defines what exploitation is covered by the base compensation. | Column usage_rights_scope (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyGuarantee rdf:type rdf:Property ;
    rdfs:label 'Weekly Guarantee' ;
    rdfs:comment 'The guaranteed weekly compensation amount for talent engaged on a weekly basis (e.g., series regulars, production staff). Expressed in the contract currency. | Column weekly_guarantee (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityClauseId rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Id' ;
    rdfs:comment 'Unique identifier for the exclusivity clause record. Primary key. | Column exclusivity_clause_id (BIGINT) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Breach Incident Count' ;
    rdfs:comment 'The cumulative number of times the talent has breached this exclusivity clause. Used to track compliance history and inform enforcement decisions. | Column breach_incident_count (INT) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'The business identifier or reference number assigned to this exclusivity clause within the contract document (e.g., Section 5.2, Clause EX-001). Used for legal and operational reference. | Column clause_number (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'The category of exclusivity restriction imposed by this clause. Category exclusivity restricts talent from working in specific content genres or categories. Network exclusivity restricts talent from appearing on competing networks. Platform exclusivity restricts talent from appearing on competing streaming or distribution platforms. Geographic exclusivity restricts talent from working in specific territories. Time exclusivity restricts talent during specific dayparts or time windows. Project exclusivity restricts talent from working on competing projects or productions. | Column exclusivity_type (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Window End Date' ;
    rdfs:comment 'The date on which the exclusivity or holdback restriction expires. After this date, the talent is no longer bound by the exclusivity terms of this clause. Nullable for open-ended or perpetual exclusivity. | Column holdback_window_end_date (DATE) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Window Start Date' ;
    rdfs:comment 'The date on which the exclusivity or holdback restriction becomes effective. Marks the beginning of the period during which the talent is bound by the exclusivity terms. | Column holdback_window_start_date (DATE) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastBreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Breach Date' ;
    rdfs:comment 'The date of the most recent breach of this exclusivity clause by the talent. Nullable if no breach has occurred. | Column last_breach_date (DATE) in talent.exclusivity_clause' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether this exclusivity clause has been reviewed and approved by legal counsel. True indicates legal review is complete; False indicates pending or no review. | Column legal_review_completed_flag (BOOLEAN) in talent.exclusivity_clause' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name or identifier of the legal counsel or attorney who reviewed and approved this exclusivity clause. Used for audit and accountability purposes. | Column legal_reviewer_name (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedBy rdf:type rdf:Property ;
    rdfs:label 'Negotiated By' ;
    rdfs:comment 'Name or identifier of the business affairs executive, legal counsel, or talent agent who negotiated the terms of this exclusivity clause. Used for accountability and future reference. | Column negotiated_by (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyProvision rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision' ;
    rdfs:comment 'Detailed description of the financial or contractual penalties that apply if the talent breaches the exclusivity clause. May include liquidated damages amounts, contract termination rights, or other remedies available to the broadcaster. | Column penalty_provision (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCarveoutActivities rdf:type rdf:Property ;
    rdfs:label 'Permitted Carveout Activities' ;
    rdfs:comment 'Textual description of specific activities, roles, or engagements that are explicitly exempted or carved out from the exclusivity restriction. Examples include charity appearances, personal social media, pre-existing commitments, or non-competing content categories. | Column permitted_carveout_activities (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCompetitorList rdf:type rdf:Property ;
    rdfs:label 'Restricted Competitor List' ;
    rdfs:comment 'Comma-separated or structured list of specific competitors, networks, platforms, or entities with whom the talent is prohibited from engaging during the exclusivity period. May include network names, streaming platform identifiers, production company names, or brand names. | Column restricted_competitor_list (STRING) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'The date on which a granted waiver expires and the exclusivity clause becomes fully enforceable again. Nullable if the waiver is permanent or no waiver has been granted. | Column waiver_expiration_date (DATE) in talent.exclusivity_clause' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Date' ;
    rdfs:comment 'The date on which a waiver or exception to the exclusivity clause was officially granted. Nullable if no waiver has been granted. | Column waiver_granted_date (DATE) in talent.exclusivity_clause' ;
    rdfs:domain ind:ExclusivityClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Appearance Schedule Id' ;
    rdfs:comment 'Unique identifier for the appearance schedule record. Primary key for the appearance schedule entity. | Column appearance_schedule_id (BIGINT) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Production coordinators/schedulers create appearance schedules. Required for scheduling accountability, workload management, audit trails, and dispute resolution. Column created_by_user is denormalize' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rescheduledFromAppearanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appearance Schedule Id' ;
    rdfs:comment 'Reference to the original appearance schedule record if this schedule is a rescheduled version of a previous booking. | Column rescheduled_from_appearance_schedule_id (BIGINT) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppearanceSchedule .

ind:resultingMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Resulting Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Links scheduled talent appearances (talk shows, live events, promotional shoots) to the resulting recorded media assets. Required for archival cross-reference, rights verification, and tracking which  | Column resulting_media_asset_id (BIGINT) in mediaasset.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:appearanceType rdf:type rdf:Property ;
    rdfs:label 'Appearance Type' ;
    rdfs:comment 'Classification of the type of appearance or activity scheduled for the talent. ADR (Automated Dialogue Replacement) refers to post-production voice recording sessions. [ENUM-REF-CANDIDATE: principal_photography|adr_session|promotional_appearance|press_junket|live_broadcast|table_read|rehearsal|wardrobe_fitting|makeup_test|screen_test — 10 candidates stripped; promote to reference product] | Column appearance_type (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Availability Window End' ;
    rdfs:comment 'The end date of the period during which the talent has indicated availability for scheduling. | Column availability_window_end (DATE) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityWindowStart rdf:type rdf:Property ;
    rdfs:label 'Availability Window Start' ;
    rdfs:comment 'The start date of the period during which the talent has indicated availability for scheduling. | Column availability_window_start (DATE) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The scheduled date on which the talent is required to appear for the activity. Follows yyyy-MM-dd format. | Column call_date (DATE) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was cancelled, if applicable. | Column cancellation_timestamp (TIMESTAMP) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the appearance schedule indicating whether the booking is pending confirmation, confirmed, cancelled, rescheduled, completed, or resulted in a no-show. | Column confirmation_status (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Conflict Flag' ;
    rdfs:comment 'Boolean flag indicating whether this appearance schedule conflicts with any exclusivity clauses in the talent\'s contract. | Column exclusivity_conflict_flag (BOOLEAN) in talent.appearance_schedule' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether guild notification is required for this appearance per union agreements (SAG-AFTRA, WGA, DGA). | Column guild_notification_required (BOOLEAN) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Guild Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when notification was sent to the relevant guild regarding this appearance schedule. | Column guild_notification_sent_timestamp (TIMESTAMP) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdLevel rdf:type rdf:Property ;
    rdfs:label 'Hold Level' ;
    rdfs:comment 'Priority level of the talent booking indicating the strength of the commitment. First hold is highest priority, second and third holds are lower priority backups, first refusal gives talent right to accept or decline before offering to others. | Column hold_level (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Status' ;
    rdfs:comment 'Status indicating whether this appearance schedule has been synchronized with the playout and channel management system (Ericsson MediaFirst) for live broadcast coordination. | Column playout_system_sync_status (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutSystemSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Playout System Sync Timestamp' ;
    rdfs:comment 'The date and time when this appearance schedule was last synchronized with the playout system. | Column playout_system_sync_timestamp (TIMESTAMP) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Release Tracking Status' ;
    rdfs:comment 'Status of obtaining necessary talent releases, waivers, or permissions required for the appearance, particularly for promotional and publicity activities. | Column release_tracking_status (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingNotes rdf:type rdf:Property ;
    rdfs:label 'Scheduling Notes' ;
    rdfs:comment 'Free-text field for additional scheduling information, special requirements, or coordination notes relevant to this appearance. | Column scheduling_notes (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:AppearanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unavailabilityReason rdf:type rdf:Property ;
    rdfs:label 'Unavailability Reason' ;
    rdfs:comment 'Free-text explanation of why the talent is unavailable during certain periods, such as personal commitments, conflicting bookings, or contractual exclusivity. | Column unavailability_reason (STRING) in talent.appearance_schedule' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAttributionId rdf:type rdf:Property ;
    rdfs:label 'Credit Attribution Id' ;
    rdfs:comment 'Unique identifier for the credit attribution record. Primary key. | Column credit_attribution_id (BIGINT) in talent.credit_attribution' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingBlock rdf:type rdf:Property ;
    rdfs:label 'Billing Block' ;
    rdfs:comment 'The section or block within the credits where this attribution appears: above title, title card, opening sequence, closing sequence, end crawl, or promotional materials. | Column billing_block (STRING) in talent.credit_attribution' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Card Size Percentage' ;
    rdfs:comment 'The size of the talent credit card relative to the title card, expressed as a percentage (e.g., 100.00 means same size as title, 75.00 means 75% of title size). Contractually mandated for high-profile talent. | Column card_size_percentage (DECIMAL(5,2)) in talent.credit_attribution' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditDeterminationMethod rdf:type rdf:Property ;
    rdfs:label 'Credit Determination Method' ;
    rdfs:comment 'The method by which this credit was determined: contractual (per talent agreement), guild arbitration (resolved by guild dispute process), mutual agreement (negotiated between parties), or statutory (mandated by regulation). | Column credit_determination_method (STRING) in talent.credit_attribution' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Credit Duration Seconds' ;
    rdfs:comment 'The minimum duration in seconds that the credit card must be displayed on screen, as contractually required. | Column credit_duration_seconds (DECIMAL(6,2)) in talent.credit_attribution' ;
    rdfs:domain ind:CreditAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditFormat rdf:type rdf:Property ;
    rdfs:label 'Credit Format' ;
    rdfs:comment 'The format in which the credit is displayed: single card (talent alone), shared card (multiple talents on one card), alphabetical (ordered alphabetically with peers), or separate card (dedicated card for this talent). | Column credit_format (STRING) in talent.credit_attribution' ;
