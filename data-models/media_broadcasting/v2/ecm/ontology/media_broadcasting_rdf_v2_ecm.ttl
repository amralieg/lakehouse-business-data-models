ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost for all units in this procurement transaction (quantity × unit cost), before taxes and fees. | Column total_cost (DECIMAL(18,2)) in technology.equipment_procurement' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per single unit of equipment in the procurement currency. | Column unit_cost (DECIMAL(18,2)) in technology.equipment_procurement' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration of manufacturer or vendor warranty coverage in months from delivery or installation date. | Column warranty_period_months (INT) in technology.equipment_procurement' ;
    rdfs:domain ind:EquipmentProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTechIncidentId rdf:type rdf:Property ;
    rdfs:label 'Parent Tech Incident Id' ;
    rdfs:comment 'Self-referencing FK on tech_incident (parent_tech_incident_id) | Column parent_tech_incident_id (BIGINT) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechIncident .

ind:primaryTechEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tech Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that reported the incident. Links to user/employee master data. | Column primary_tech_employee_id (BIGINT) in workforce.tech_incident' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedChangeTechChangeRequestId rdf:type rdf:Property ;
    rdfs:label 'Related Change Tech Change Request Id' ;
    rdfs:comment 'Identifier of the related change request if this incident was caused by or resolved through a change in the ITIL change management process. | Column related_change_tech_change_request_id (BIGINT) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechChangeRequest .

ind:techProblemId rdf:type rdf:Property ;
    rdfs:label 'Tech Problem Id' ;
    rdfs:comment 'Identifier of the related problem record if this incident is linked to a known problem in the ITIL problem management process. | Column related_problem_id (BIGINT) in technology.tech_incident' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechProblem .

ind:tertiaryTechResolvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tech Resolved By User Employee Id' ;
    rdfs:comment 'Identifier of the technician or engineer who resolved the incident. Links to user/employee master data. | Column tertiary_tech_resolved_by_user_employee_id (BIGINT) in workforce.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedService rdf:type rdf:Property ;
    rdfs:label 'Affected Service' ;
    rdfs:comment 'Name of the business service or technical service impacted by the incident (e.g., Live News Broadcast, VOD Streaming Platform, Ad Insertion Service, Network Operations Center Monitoring). | Column affected_service (STRING) in technology.tech_incident' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedResolverTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Team' ;
    rdfs:comment 'Name of the technical support team or resolver group currently assigned to investigate and resolve the incident (e.g., Broadcast Engineering, Network Operations, IT Infrastructure, Cybersecurity). | Column assigned_resolver_team (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the incident was formally closed after confirmation that the resolution was successful and no further action is required. | Column closure_timestamp (TIMESTAMP) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Channel through which the incident was reported: phone call, email, self-service portal, automated monitoring system, or escalated from NOC alert. | Column contact_method (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level classification of the incident type: broadcast signal failures, IT system outages, network disruptions, cybersecurity events, infrastructure faults, or playout automation issues. | Column incident_category (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Incident Subcategory' ;
    rdfs:comment 'Detailed classification within the incident category (e.g., signal loss, server crash, DDoS attack, power failure, encoder malfunction). | Column incident_subcategory (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postIncidentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Date' ;
    rdfs:comment 'Scheduled or completed date of the post-incident review meeting. | Column post_incident_review_date (DATE) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postIncidentReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Post Incident Review Flag' ;
    rdfs:comment 'Indicates whether a formal post-incident review (PIR) or post-mortem is required for this incident. True = PIR required (typically for P1/P2 incidents), False = no PIR needed. | Column post_incident_review_flag (BOOLEAN) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the person or system that reported the incident. | Column reported_by_name (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the incident was first reported to the service desk or detected by monitoring systems. This is the principal business event timestamp for the incident lifecycle. | Column reported_timestamp (TIMESTAMP) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolvedByName rdf:type rdf:Property ;
    rdfs:label 'Resolved By Name' ;
    rdfs:comment 'Full name of the technician or engineer who resolved the incident. | Column resolved_by_name (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:techIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Tech Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident within the ITIL workflow: new (just reported), assigned (routed to resolver), in_progress (actively being worked), pending (awaiting external input), resolved (fix applied), closed (confirmed resolved), cancelled (invalid/duplicate). [ENUM-REF-CANDIDATE: new|assigned|in_progress|pending|resolved|closed|cancelled — 7 candidates stripped; promote to reference product] | Column tech_incident_status (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaroundApplied rdf:type rdf:Property ;
    rdfs:label 'Workaround Applied' ;
    rdfs:comment 'Indicates whether a temporary workaround was applied to restore service before a permanent fix. True = workaround used, False = permanent fix applied immediately. | Column workaround_applied (BOOLEAN) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workaroundDescription rdf:type rdf:Property ;
    rdfs:label 'Workaround Description' ;
    rdfs:comment 'Description of the temporary workaround applied to restore service while a permanent fix is developed. | Column workaround_description (STRING) in technology.tech_incident' ;
    rdfs:domain ind:TechIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseEncoderConfigId rdf:type rdf:Property ;
    rdfs:label 'Base Encoder Config Id' ;
    rdfs:comment 'Self-referencing FK on encoder_config (base_encoder_config_id) | Column base_encoder_config_id (BIGINT) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EncoderConfig .

ind:assignedStreamName rdf:type rdf:Property ;
    rdfs:label 'Assigned Stream Name' ;
    rdfs:comment 'Name of the specific stream or service feed that this encoder produces (e.g., main program feed, backup feed, regional variant). | Column assigned_stream_name (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'Named configuration profile or preset applied to the encoder defining encoding parameters, quality settings, and output specifications. | Column configuration_profile (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderCode rdf:type rdf:Property ;
    rdfs:label 'Encoder Code' ;
    rdfs:comment 'Unique business identifier or asset tag code for the encoder used in inventory and configuration management systems. | Column encoder_code (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderName rdf:type rdf:Property ;
    rdfs:label 'Encoder Name' ;
    rdfs:comment 'Human-readable name assigned to the encoder for operational identification and reference. | Column encoder_name (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoderType rdf:type rdf:Property ;
    rdfs:label 'Encoder Type' ;
    rdfs:comment 'Classification of the encoder deployment model: hardware-based encoder appliance, software encoder running on server, or cloud-based encoding instance. | Column encoder_type (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFormat rdf:type rdf:Property ;
    rdfs:label 'Input Format' ;
    rdfs:comment 'Video and audio input format accepted by the encoder (e.g., SDI, HDMI, IP/RTP, RTMP, file-based). | Column input_format (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyMode rdf:type rdf:Property ;
    rdfs:label 'Latency Mode' ;
    rdfs:comment 'Encoding latency profile configured for the encoder: low-latency for live sports and interactive content, ultra-low-latency for real-time applications, or standard for non-time-sensitive content. | Column latency_mode (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementUrl rdf:type rdf:Property ;
    rdfs:label 'Management Url' ;
    rdfs:comment 'Web-based management interface URL for accessing the encoder configuration and monitoring dashboard. | Column management_url (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputBitrateLadder rdf:type rdf:Property ;
    rdfs:label 'Output Bitrate Ladder' ;
    rdfs:comment 'Comma-separated list of output bitrates in kbps or Mbps defining the Adaptive Bitrate (ABR) ladder for multi-quality streaming (e.g., 500kbps, 1Mbps, 2.5Mbps, 5Mbps, 8Mbps). | Column output_bitrate_ladder (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputCodec rdf:type rdf:Property ;
    rdfs:label 'Output Codec' ;
    rdfs:comment 'Primary video codec used for encoding output streams (H.264/AVC, HEVC/H.265, AV1, VP9, MPEG-2). | Column output_codec (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputProtocol rdf:type rdf:Property ;
    rdfs:label 'Output Protocol' ;
    rdfs:comment 'Streaming protocol used for encoder output delivery (e.g., HLS, MPEG-DASH, RTMP, SRT, Zixi). | Column output_protocol (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformAssignment rdf:type rdf:Property ;
    rdfs:label 'Platform Assignment' ;
    rdfs:comment 'Name of the streaming platform, channel, or service to which this encoder is assigned (e.g., OTT platform, linear channel, FAST channel). | Column platform_assignment (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Typical power consumption of the encoder hardware in watts, used for capacity planning and energy cost calculation. | Column power_consumption_watts (DECIMAL(10,2)) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackLocation rdf:type rdf:Property ;
    rdfs:label 'Rack Location' ;
    rdfs:comment 'Physical rack and unit position where the hardware encoder is installed in the data center or broadcast facility (e.g., Rack-12-U24). | Column rack_location (STRING) in technology.encoder_config' ;
    rdfs:domain ind:EncoderConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSatelliteTransponderId rdf:type rdf:Property ;
    rdfs:label 'Parent Satellite Transponder Id' ;
    rdfs:comment 'Self-referencing FK on satellite_transponder (backup_satellite_transponder_id) | Column backup_satellite_transponder_id (BIGINT) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SatelliteTransponder .

ind:bandwidthMhz rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Mhz' ;
    rdfs:comment 'Total bandwidth capacity of the transponder in megahertz. Determines the data throughput and number of channels that can be multiplexed on this transponder. | Column bandwidth_mhz (DECIMAL(8,2)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProvider rdf:type rdf:Property ;
    rdfs:label 'Carrier Provider' ;
    rdfs:comment 'Name of the satellite operator or service provider leasing the transponder capacity (e.g., SES, Intelsat, Eutelsat, Telesat). Primary vendor contact for technical support and service issues. | Column carrier_provider (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Center Frequency Mhz' ;
    rdfs:comment 'Center operating frequency of the transponder in megahertz. Used for uplink/downlink tuning and interference coordination with adjacent transponders. | Column center_frequency_mhz (DECIMAL(10,3)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCapacity rdf:type rdf:Property ;
    rdfs:label 'Channel Capacity' ;
    rdfs:comment 'Number of standard-definition or high-definition channels that can be multiplexed on this transponder given current encoding parameters. Used for channel lineup planning. | Column channel_capacity (INT) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downlinkCoverageFootprint rdf:type rdf:Property ;
    rdfs:label 'Downlink Coverage Footprint' ;
    rdfs:comment 'Geographic coverage area of the transponders downlink beam (e.g., North America, Europe, Asia-Pacific, CONUS). Defines the audience reach and distribution territory. | Column downlink_coverage_footprint (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eirpDbw rdf:type rdf:Property ;
    rdfs:label 'Eirp Dbw' ;
    rdfs:comment 'Effective Isotropic Radiated Power of the transponder in decibels relative to one watt. Measures the signal strength at the coverage area, critical for reception quality planning. | Column eirp_dbw (DECIMAL(6,2)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Date when the transponder lease or capacity agreement expires. Nullable for owned capacity or indefinite agreements. Used for renewal planning and capacity forecasting. | Column lease_end_date (DATE) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Date when the transponder lease or capacity agreement becomes effective. Critical for capacity planning and financial forecasting. | Column lease_start_date (DATE) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leasedCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Leased Capacity Mbps' ;
    rdfs:comment 'Amount of transponder capacity leased by Media Broadcasting in megabits per second. Represents the contracted data rate available for broadcast distribution. | Column leased_capacity_mbps (DECIMAL(10,2)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modulationScheme rdf:type rdf:Property ;
    rdfs:label 'Modulation Scheme' ;
    rdfs:comment 'Digital modulation technique used (e.g., QPSK, 8PSK, 16APSK, 32APSK). Higher-order modulation increases throughput but requires better signal-to-noise ratio. | Column modulation_scheme (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLeaseCost rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Cost' ;
    rdfs:comment 'Monthly recurring cost for leasing the transponder capacity. Used for budget planning, cost allocation, and financial reporting. Excludes one-time setup fees. | Column monthly_lease_cost (DECIMAL(12,2)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orbitalSlot rdf:type rdf:Property ;
    rdfs:label 'Orbital Slot' ;
    rdfs:comment 'Geostationary orbital position of the satellite in degrees (e.g., 101.0W, 28.2E). Defines the satellites fixed position relative to Earth for broadcast coverage planning. | Column orbital_slot (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryService rdf:type rdf:Property ;
    rdfs:label 'Primary Service' ;
    rdfs:comment 'Primary broadcast service or channel distribution purpose for this transponder (e.g., Linear TV Distribution, VOD Delivery, Contribution Feed, Occasional Use). Supports capacity allocation and service planning. | Column primary_service (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory License Number' ;
    rdfs:comment 'FCC or equivalent regulatory authority license number authorizing the use of this transponder for broadcast transmission. Required for compliance reporting and spectrum management. | Column regulatory_license_number (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteName rdf:type rdf:Property ;
    rdfs:label 'Satellite Name' ;
    rdfs:comment 'Name of the satellite hosting this transponder (e.g., SES-1, Intelsat 21, Eutelsat 7B). Critical for uplink/downlink coordination and transmission planning. | Column satellite_name (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderCode rdf:type rdf:Property ;
    rdfs:label 'Transponder Code' ;
    rdfs:comment 'Business identifier code for the transponder, typically assigned by the satellite operator or internal asset management system. Used for operational reference and capacity planning. | Column transponder_code (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderName rdf:type rdf:Property ;
    rdfs:label 'Transponder Name' ;
    rdfs:comment 'Human-readable name or designation for the transponder, often including satellite name and transponder number for easy identification by broadcast operations teams. | Column transponder_name (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transponderType rdf:type rdf:Property ;
    rdfs:label 'Transponder Type' ;
    rdfs:comment 'Technology classification of the transponder: Analog (legacy FM), Digital (DVB-S/S2), or Hybrid (supporting both). Modern broadcast operations primarily use digital transponders. | Column transponder_type (STRING) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uplinkAntennaSizeMeters rdf:type rdf:Property ;
    rdfs:label 'Uplink Antenna Size Meters' ;
    rdfs:comment 'Diameter of the uplink antenna dish in meters. Larger antennas provide higher gain and better signal quality for satellite transmission. | Column uplink_antenna_size_meters (DECIMAL(5,2)) in technology.satellite_transponder' ;
    rdfs:domain ind:SatelliteTransponder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:techAssetLifecycleId rdf:type rdf:Property ;
    rdfs:label 'Tech Asset Lifecycle Id' ;
    rdfs:comment 'Unique identifier for the technology asset lifecycle event record. | Column tech_asset_lifecycle_id (BIGINT) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousTechAssetLifecycleId rdf:type rdf:Property ;
    rdfs:label 'Previous Tech Asset Lifecycle Id' ;
    rdfs:comment 'Self-referencing FK on tech_asset_lifecycle (previous_tech_asset_lifecycle_id) | Column previous_tech_asset_lifecycle_id (BIGINT) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechAssetLifecycle .

ind:tertiaryTechCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tech Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this lifecycle event record in the system. | Column tertiary_tech_created_by_user_employee_id (BIGINT) in workforce.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Name of the manager or executive who approved this lifecycle event. | Column approved_by_user_name (STRING) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Depreciation Impact Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event affects the depreciation schedule of the asset (e.g., upgrade extends useful life, disposal triggers final depreciation). | Column depreciation_impact_flag (BOOLEAN) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Certificate Number' ;
    rdfs:comment 'Certificate or documentation number proving compliant disposal of the asset (applicable for disposal events requiring regulatory proof). | Column disposal_certificate_number (STRING) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCostAmount rdf:type rdf:Property ;
    rdfs:label 'Event Cost Amount' ;
    rdfs:comment 'Direct cost incurred for this lifecycle event (e.g., procurement price, installation labor cost, repair cost, disposal fee). | Column event_cost_amount (DECIMAL(15,2)) in technology.tech_asset_lifecycle' ;
    rdfs:domain ind:TechAssetLifecycle ;
