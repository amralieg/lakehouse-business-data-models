ind:snapshotNumber rdf:type rdf:Property ;
    rdfs:label 'Snapshot Number' ;
    rdfs:comment 'Business identifier for this EBITDA snapshot, typically following a sequential or period-based numbering scheme for management reporting. | Column snapshot_number (STRING) in finance.ebitda_snapshot' ;
