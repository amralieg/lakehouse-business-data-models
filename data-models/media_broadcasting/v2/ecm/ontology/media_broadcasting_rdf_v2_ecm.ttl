ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Number of times the approval request has been escalated to a higher authority. Tracks workflow complexity and decision-making bottlenecks. | Column escalation_count (INT) in partner.partner_deal_approval' ;
