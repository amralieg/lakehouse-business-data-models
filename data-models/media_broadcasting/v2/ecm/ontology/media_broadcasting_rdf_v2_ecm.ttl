    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date on which the corrective action plan was completed and verified. | Column corrective_action_completion_date (DATE) in compliance.incident' ;
