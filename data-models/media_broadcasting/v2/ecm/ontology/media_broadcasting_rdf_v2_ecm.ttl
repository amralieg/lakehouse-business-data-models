    rdfs:range ind:NocAlert .

ind:impactedSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Impacted Subscriber Id' ;
    rdfs:comment 'Foreign key linking to subscriber.subscriber. Business justification: Critical streaming service alerts require identifying specific affected subscribers for proactive customer care outreach, SLA credit processing, and personalized service recovery. Incident management  | Column impacted_subscriber_id (BIGINT) in subscriber.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:primaryNocEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Noc Employee Id' ;
    rdfs:comment 'Identifier of the NOC operator or engineer who acknowledged the alert. Null if not yet acknowledged. | Column primary_noc_employee_id (BIGINT) in workforce.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedByUserName rdf:type rdf:Property ;
    rdfs:label 'Acknowledged By User Name' ;
    rdfs:comment 'Full name of the NOC operator or engineer who acknowledged the alert, providing audit trail for incident response. | Column acknowledged_by_user_name (STRING) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when a NOC operator or engineer acknowledged receipt of the alert and began investigation. Null if not yet acknowledged. | Column acknowledged_timestamp (TIMESTAMP) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affectedViewerCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Affected Viewer Count Estimate' ;
    rdfs:comment 'Estimated number of viewers or subscribers impacted by the alert event, based on audience measurement data and service reach. Used for prioritization and business impact analysis. | Column affected_viewer_count_estimate (INT) in technology.noc_alert' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'The priority level assigned to the alert event, typically classified as P1 (critical - immediate service impact), P2 (high - significant degradation), P3 (medium - minor impact), or P4 (low - informational). Determines escalation and response urgency. | Column alert_severity (STRING) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'The current lifecycle state of the alert event within the NOC incident management workflow. Tracks progression from initial detection through acknowledgment, investigation, resolution, and closure. [ENUM-REF-CANDIDATE: open|acknowledged|in_progress|resolved|closed|auto_resolved|escalated — 7 candidates stripped; promote to reference product] | Column alert_status (STRING) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Flag' ;
    rdfs:comment 'Boolean indicator of whether the alert was automatically resolved by the monitoring platform or automation system without human intervention (True) or required manual resolution (False). | Column auto_resolution_flag (BOOLEAN) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the equipment unit that experienced the fault, used for warranty claims and maintenance tracking. | Column equipment_serial_number (STRING) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationHistory rdf:type rdf:Property ;
    rdfs:label 'Escalation History' ;
    rdfs:comment 'Chronological log of escalation events, including timestamps, escalation reasons, and personnel notified. Captures the full escalation chain for audit and process improvement. | Column escalation_history (STRING) in technology.noc_alert' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed textual description of the fault or anomaly detected, including technical details, error codes, and diagnostic information captured by the monitoring system at the time of alert generation. | Column fault_description (STRING) in technology.noc_alert' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultLocation rdf:type rdf:Property ;
    rdfs:label 'Fault Location' ;
    rdfs:comment 'Physical or logical location where the fault was detected, such as facility name, rack identifier, transmission site, or network segment. Aids in dispatch and troubleshooting. | Column fault_location (STRING) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'The total elapsed time in minutes from alert timestamp to resolved timestamp, used for SLA compliance tracking and performance analysis. Null if not yet resolved. | Column resolution_duration_minutes (INT) in technology.noc_alert' ;
    rdfs:domain ind:NocAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Resolved By User Name' ;
    rdfs:comment 'Full name of the NOC operator, engineer, or technician who resolved the alert, providing audit trail for incident resolution. | Column resolved_by_user_name (STRING) in technology.noc_alert' ;
