    rdfs:range xsd:string .

ind:licenseKey rdf:type rdf:Property ;
    rdfs:label 'License Key' ;
    rdfs:comment 'Activation or license key for software assets, required for installation and compliance verification. Highly confidential to prevent unauthorized use. | Column license_key (STRING) in technology.it_asset' ;
