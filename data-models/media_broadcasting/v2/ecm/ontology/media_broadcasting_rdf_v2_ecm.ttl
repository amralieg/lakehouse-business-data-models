    rdfs:range xsd:decimal .

ind:desiredSalaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Desired Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the desired salary amount (e.g., USD, GBP, EUR). | Column desired_salary_currency (STRING) in workforce.applicant' ;
