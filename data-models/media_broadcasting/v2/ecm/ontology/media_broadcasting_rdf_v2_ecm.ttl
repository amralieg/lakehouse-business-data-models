    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApiEndpoint .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: API endpoints require engineering ownership for deprecation decisions, rate limit adjustments, SLA monitoring, and breaking change management. Essential for on-call rotations, API versioning accountab | Column owner_employee_id (BIGINT) in workforce.api_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowedOrigins rdf:type rdf:Property ;
    rdfs:label 'Allowed Origins' ;
    rdfs:comment 'Comma-separated list of allowed origin domains for CORS requests (e.g., https://www.example.com, https://app.example.com). Asterisk (*) indicates all origins are allowed. Null if CORS is disabled. | Column allowed_origins (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'The version of the API that this endpoint belongs to (e.g., v1, v2, v3). Used for versioning and backward compatibility management. | Column api_version (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Authentication Scheme' ;
    rdfs:comment 'The authentication mechanism required to access this endpoint (OAuth2 for token-based, API key for simple key-based, JWT for JSON Web Token, basic auth for username/password, none for public endpoints). | Column authentication_scheme (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationScope rdf:type rdf:Property ;
    rdfs:label 'Authorization Scope' ;
    rdfs:comment 'The OAuth2 scope or permission level required to access this endpoint (e.g., read:content, write:profile, admin:all). Defines what actions the authenticated user is authorized to perform. | Column authorization_scope (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacheStrategy rdf:type rdf:Property ;
    rdfs:label 'Cache Strategy' ;
    rdfs:comment 'The caching strategy applied to responses from this endpoint (no_cache for dynamic data, private for user-specific data, public for shared data, cdn for CDN-cacheable content). | Column cache_strategy (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsEnabled rdf:type rdf:Property ;
    rdfs:label 'Cors Enabled' ;
    rdfs:comment 'Indicates whether Cross-Origin Resource Sharing is enabled for this endpoint (true), allowing web browsers to make requests from different domains, or disabled (false) for same-origin only. | Column cors_enabled (BOOLEAN) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'The URL to the detailed API documentation for this endpoint, typically hosted in a developer portal or API documentation system (e.g., Swagger, Postman, Confluence). | Column documentation_url (STRING) in distribution.api_endpoint' ;
