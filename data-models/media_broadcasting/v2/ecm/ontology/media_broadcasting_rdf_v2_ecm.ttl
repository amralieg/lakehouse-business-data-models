ind:totalDirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Direct Cost Amount' ;
    rdfs:comment 'Total direct costs for the reporting period. Sum of content acquisition, production, distribution, and other direct costs. | Column total_direct_cost_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
