ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.cycle. Business justification: Invoice is generated by ONE billing cycle run. Need to track which cycle configuration was used to generate this invoice for audit and reconciliation purposes. No redundant columns to remove. | Column billing_cycle_id (BIGINT) in billing.invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:communicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Communication Template Id' ;
    rdfs:comment 'Foreign key linking to billing.communication_template. Business justification: Invoice delivery uses ONE communication template. Need to track which template was used to deliver this specific invoice for audit and customer service purposes. No redundant columns to remove. | Column communication_template_id (BIGINT) in billing.invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Foreign key linking to billing.run. Business justification: Invoice is generated by ONE billing run (batch process). Need to track which specific batch execution generated this invoice for operational audit trail and troubleshooting. No redundant columns to re | Column run_id (BIGINT) in billing.invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:mvpdSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Mvpd Subscriber Count' ;
    rdfs:comment 'Number of subscribers reported by the MVPD partner as the basis for carriage fee calculation. Relevant for carriage fee invoices. | Column mvpd_subscriber_count (INT) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice. Calculated as total_amount_due minus amount_paid. | Column outstanding_balance (DECIMAL(18,2)) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the invoice was fully paid. Null if not yet paid or only partially paid. | Column paid_date (DATE) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Flag' ;
    rdfs:comment 'Indicates whether this subscription invoice includes prorated charges due to mid-cycle changes. Relevant for SVOD billing. | Column proration_flag (BOOLEAN) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition End Date' ;
    rdfs:comment 'End date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines. | Column revenue_recognition_end_date (DATE) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Start Date' ;
    rdfs:comment 'Start date of the period over which revenue from this invoice should be recognized per ASC 606 guidelines. | Column revenue_recognition_start_date (DATE) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Reference' ;
    rdfs:comment 'Original invoice identifier from the source billing system. Used for reconciliation and audit trail. | Column source_system_invoice_reference (STRING) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total amount before taxes, fees, and adjustments. Sum of all line item amounts. | Column subtotal_amount (DECIMAL(18,2)) in billing.invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason this invoice was voided or cancelled. Populated when invoice_status is void or cancelled. | Column void_reason (STRING) in billing.invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice_line product. | Column invoice_line_id (BIGINT) in billing.invoice_line' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:originalInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Id' ;
    rdfs:comment 'Reference to the original invoice line that this line is adjusting, crediting, or replacing. Used for tracking billing corrections, credits, and makegoods. | Column original_invoice_line_id (BIGINT) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Identifier for the performance obligation under ASC 606 revenue recognition standard, linking this charge to a specific contractual promise to deliver goods or services. | Column performance_obligation_id (BIGINT) in partner.invoice_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed description of the charge appearing on the invoice line, explaining the service, ad spot, carriage fee period, or license fee installment being billed. | Column charge_description (STRING) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'Code or identifier for the discount program or promotion applied to this line, used for tracking discount effectiveness and revenue impact. | Column discount_code (STRING) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'Total amount for this line item including all charges, discounts, and taxes. This is the final billable amount for the line. | Column extended_amount (DECIMAL(18,2)) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpDelivered rdf:type rdf:Property ;
    rdfs:label 'Grp Delivered' ;
    rdfs:comment 'Gross Rating Points delivered for this advertising line item, measuring the total audience reach and frequency achieved for the campaign. | Column grp_delivered (DECIMAL(10,2)) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Business-facing line item identifier displayed on customer invoices and billing statements for reference and dispute resolution. | Column line_item_number (STRING) in billing.invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Rule or method for recognizing revenue from this line item, such as point-in-time (ad spot delivery), over-time (subscription period), or milestone-based (license installment). | Column revenue_recognition_rule (STRING) in billing.invoice_line' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period covered by this line item charge. For subscriptions this is the billing cycle end; for ad campaigns this is the flight end date. | Column service_period_end_date (DATE) in billing.invoice_line' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period covered by this line item charge. For subscriptions this is the billing cycle start; for ad campaigns this is the flight start date. | Column service_period_start_date (DATE) in billing.invoice_line' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code that determines the tax treatment for this line item, used for tax calculation and compliance reporting. | Column tax_code (STRING) in billing.invoice_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key for the payment record. | Column payment_id (BIGINT) in billing.payment' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to technology.vendor_contract. Business justification: Payments to technology vendors must reference contracts for payment terms validation, accrual matching, milestone-based payment verification, and audit trail compliance required in technology procurem | Column vendor_contract_id (BIGINT) in technology.payment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary amount of the payment transaction in the specified currency. Gross payment value before any adjustments. | Column amount (DECIMAL(18,2)) in billing.payment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied against outstanding invoices or account balances. May differ from payment_amount if partial application or overpayment. | Column applied_amount (DECIMAL(18,2)) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment processor or card issuer confirming approval of the transaction. | Column authorization_code (STRING) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transaction Reference' ;
    rdfs:comment 'Reference number provided by the bank for wire transfers, ACH transactions, or check deposits. Used for bank reconciliation. | Column bank_transaction_reference (STRING) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateway rdf:type rdf:Property ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Name of the payment gateway or processor used to handle the transaction (e.g., Stripe, Authorize.Net, PayPal, Adyen). | Column gateway (STRING) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for reconciliation and dispute resolution. | Column gateway_transaction_reference (STRING) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the payment was posted to the general ledger in the financial system. Format: yyyy-MM-dd. | Column gl_posting_date (DATE) in billing.payment' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutopay rdf:type rdf:Property ;
    rdfs:label 'Is Autopay' ;
    rdfs:comment 'Indicates whether this payment was processed automatically through a recurring payment or autopay setup. True if autopay, false if manual. | Column is_autopay (BOOLEAN) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether this payment is currently under dispute or chargeback. True if disputed, false otherwise. | Column is_disputed (BOOLEAN) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'The type of payment instrument used for the transaction. Indicates the financial mechanism (credit card, ACH, wire, check, etc.). [ENUM-REF-CANDIDATE: credit_card|debit_card|ach|wire_transfer|check|cash|paypal|direct_debit — 8 candidates stripped; promote to reference product] | Column method_type (STRING) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'The precise date and time when the payment transaction was processed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column payment_timestamp (TIMESTAMP) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount refunded to the customer if payment status is refunded. May be partial or full refund. | Column refund_amount (DECIMAL(18,2)) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund was processed and issued to the customer. Format: yyyy-MM-dd. | Column refund_date (DATE) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when the payment funds were settled and cleared in the business bank account. Format: yyyy-MM-dd. | Column settlement_date (DATE) in billing.payment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unapplied and is held as credit on the account. Calculated as payment_amount minus applied_amount. | Column unapplied_amount (DECIMAL(18,2)) in billing.payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number Last Four' ;
    rdfs:comment 'The last four digits of the bank account number. Used for customer identification without exposing full account details. Applicable for ACH, SEPA, and wire transfer methods. | Column bank_account_number_last_four (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryAlertDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Date' ;
    rdfs:comment 'The date when the system should trigger an alert to the subscriber about upcoming payment method expiration. Typically set 30-60 days before card expiry to enable proactive customer outreach and reduce involuntary churn. | Column expiry_alert_date (DATE) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gatewayCustomerProfileReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Customer Profile Reference' ;
    rdfs:comment 'The unique customer profile identifier in the payment gateway system. Used to link this payment method to the gateway\'s customer vault for secure transaction processing. | Column gateway_customer_profile_reference (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayPaymentMethodReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Payment Method Reference' ;
    rdfs:comment 'The unique payment method identifier assigned by the payment gateway. Used for transaction processing and reconciliation with gateway records. | Column gateway_payment_method_reference (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureDate rdf:type rdf:Property ;
    rdfs:label 'Last Failure Date' ;
    rdfs:comment 'The date of the most recent failed transaction attempt. Used in conjunction with failed_transaction_count to manage retry logic and customer communication. | Column last_failure_date (DATE) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFailureReason rdf:type rdf:Property ;
    rdfs:label 'Last Failure Reason' ;
    rdfs:comment 'The reason code or message returned by the payment gateway for the most recent failed transaction. Used for troubleshooting and customer support. | Column last_failure_reason (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'The last four digits of the payment card number. Used for customer identification and verification without exposing full card details. PCI DSS permits storage of last four digits. | Column last_four_digits (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Amount' ;
    rdfs:comment 'The amount of the most recent successful transaction in the subscriber\'s billing currency. Used for fraud detection and transaction pattern analysis. | Column last_transaction_amount (DECIMAL(15,2)) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mandateSignedDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Signed Date' ;
    rdfs:comment 'The date when the customer signed the direct debit mandate. Required for regulatory compliance and dispute resolution in direct debit transactions. | Column mandate_signed_date (DATE) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Method Status' ;
    rdfs:comment 'The current lifecycle status of the payment method. Determines whether the payment method can be used for new transactions. Inactive or expired methods require customer action to reactivate. | Column payment_method_status (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS-compliant tokenized representation of the payment instrument. Never stores raw Primary Account Number (PAN). Used for secure payment processing without exposing sensitive cardholder data. | Column token (STRING) in billing.payment_method' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCommunicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Default Communication Template Id' ;
    rdfs:comment 'Foreign key linking to billing.communication_template. Business justification: Billing account can have ONE default communication template for invoice delivery (customer preference). Need FK to track account-level communication preferences. No redundant columns to remove. | Column default_communication_template_id (BIGINT) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:defaultPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Default Payment Method Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_method. Business justification: Billing account has ONE default payment method for auto-pay and recurring charges. Currently only stores payment_method_type as STRING; need FK to the actual payment_method record. Remove default_paym | Column default_payment_method_id (BIGINT) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the billing account. Used on invoices, statements, and customer correspondence. | Column account_number (STRING) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this account. When true, invoices are automatically charged to the default payment method on the due date. | Column auto_pay_enabled_flag (BOOLEAN) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code in which this account is billed (e.g., USD, GBP, EUR). All invoices and payments for this account are denominated in this currency. | Column billing_currency_code (STRING) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current outstanding balance on the account, calculated as sum of unpaid invoices minus unapplied credits and payments. Positive values indicate amounts owed to the business; negative values indicate credit balances owed to the customer. | Column current_balance_amount (DECIMAL(15,2)) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current stage in the collections escalation process for overdue accounts. 0 indicates no dunning (account current); higher values indicate progressive escalation steps (e.g., 1=reminder notice, 2=warning, 3=service suspension notice, 4=final notice before write-off). | Column dunning_level (INT) in billing.billing_account' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices to this account. Email sends PDF invoices; postal mail sends printed invoices; electronic portal makes invoices available for download in customer self-service portal; EDI transmits invoices via Electronic Data Interchange (X12 810 or EDIFACT INVOIC). | Column invoice_delivery_method (STRING) in billing.billing_account' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice or collections contact sent to this account. | Column last_dunning_date (DATE) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice generated for this account. Used for billing cycle tracking and account activity monitoring. | Column last_invoice_date (DATE) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date on which this billing account was first established and activated. | Column opened_date (DATE) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCustomerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Account Number' ;
    rdfs:comment 'Customer master record number in SAP S/4HANA Financial Accounting (FI) module. Used for GL posting, accounts receivable management, and financial reconciliation. This is the authoritative financial system identifier. | Column sap_customer_account_number (STRING) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this account is exempt from sales tax, VAT, or other consumption taxes. True for tax-exempt organizations (e.g., non-profits, government entities, resellers with valid exemption certificates); false for standard taxable accounts. | Column tax_exempt_flag (BOOLEAN) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate or registration number authorizing tax exemption. Required for audit trail when tax_exempt_flag is true. | Column tax_exemption_certificate_number (STRING) in billing.billing_account' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiry Date' ;
    rdfs:comment 'Date on which the tax exemption certificate expires and must be renewed. Null for permanent exemptions. | Column tax_exemption_expiry_date (DATE) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wideorbitAccountReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Account Reference' ;
    rdfs:comment 'Account identifier in WideOrbit traffic and billing system. Used for advertising sales order management, spot scheduling, and ad billing for advertiser and agency accounts. | Column wideorbit_account_reference (STRING) in billing.billing_account' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Primary key for cycle | Column cycle_id (BIGINT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodEndDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice ends. Used to calculate service period duration for revenue recognition. Null for non-monthly frequencies. | Column billing_period_end_day (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodStartDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Day' ;
    rdfs:comment 'Day of the month (1-31) when the service period covered by the invoice begins. May differ from cycle_day for advance billing scenarios. Null for non-monthly frequencies. | Column billing_period_start_day (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingRunDayOffset rdf:type rdf:Property ;
    rdfs:label 'Billing Run Day Offset' ;
    rdfs:comment 'Number of days before or after the cycle day when the billing run executes. Positive values indicate days after cycle day; negative values indicate days before. Used to schedule invoice generation in advance of service period. | Column billing_run_day_offset (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTiming rdf:type rdf:Property ;
    rdfs:label 'Billing Timing' ;
    rdfs:comment 'Indicates whether billing occurs in advance (invoice before service period) or in arrears (invoice after service period). Critical for revenue recognition under ASC 606. | Column billing_timing (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the billing cycle (e.g., MONTHLY_01, QUARTERLY_Q1, ANNUAL_FY). Used in Zuora subscription billing engine for cycle identification. | Column cycle_code (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the billing cycle configuration. Active cycles are available for new subscriptions; inactive cycles are closed to new assignments but continue for existing subscribers; deprecated cycles are phased out; pending cycles are configured but not yet live. | Column cycle_status (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the billing cycle by revenue stream: subscription (SVOD/AVOD subscriber billing), advertising (ad campaign billing via Wide Orbit), carriage (MVPD/vMVPD distribution fees), syndication (content licensing fees), usage (pay-per-view/TVOD), or custom (non-standard arrangements). | Column cycle_type (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:day rdf:type rdf:Property ;
    rdfs:label 'Day' ;
    rdfs:comment 'Day of the month (1-31) when the billing cycle starts or billing run executes. For monthly cycles, this is the anchor date. Null for non-monthly frequencies. | Column day (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the billing cycle configuration, including business rules, special handling instructions, and usage notes for billing operations team. | Column cycle_description (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGenerationDay rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Day' ;
    rdfs:comment 'Specific day of the month (1-31) when invoices are generated for this cycle. Calculated from cycle_day and billing_run_day_offset. Null for non-monthly frequencies. | Column invoice_generation_day (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBillingDate rdf:type rdf:Property ;
    rdfs:label 'Last Billing Date' ;
    rdfs:comment 'Most recent date when a billing run was successfully completed for this cycle. Null if no billing run has occurred yet. | Column last_billing_date (DATE) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the billing cycle (e.g., Monthly Standard, Quarterly Advance, Annual Arrears). | Column cycle_name (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'Next date when a billing run will execute for accounts assigned to this cycle. Updated after each billing run completion. Used by Zuora billing engine for scheduling. | Column next_billing_date (DATE) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of days after invoice generation when payment is due. Used to calculate invoice due date. Standard terms are Net 30, Net 15, or immediate (0 days). | Column payment_due_days (INT) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationEnabled rdf:type rdf:Property ;
    rdfs:label 'Proration Enabled' ;
    rdfs:comment 'Indicates whether partial-period charges are prorated when subscription starts/ends mid-cycle. True enables proration calculation in Zuora. | Column proration_enabled (BOOLEAN) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for calculating prorated charges: daily (per-day calculation), monthly (per-month calculation), or none (no proration). Used when proration_enabled is true. | Column proration_method (STRING) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Enabled' ;
    rdfs:comment 'Indicates whether automatic tax calculation is enabled for invoices generated under this cycle. True triggers tax engine integration (e.g., Avalara, Vertex) during invoice generation. | Column tax_calculation_enabled (BOOLEAN) in billing.cycle' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Subscription Invoice Id' ;
    rdfs:comment 'Unique identifier for the subscription invoice record. Primary key for this entity. | Column subscription_invoice_id (BIGINT) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this invoice. True means payment will be attempted automatically on due date. | Column auto_pay_enabled (BOOLEAN) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceDue rdf:type rdf:Property ;
    rdfs:label 'Balance Due' ;
    rdfs:comment 'Outstanding amount remaining to be paid on this invoice. Calculated as total_amount minus amount_paid. | Column balance_due (DECIMAL(15,2)) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when the invoice was posted (finalized and made available to subscriber). Marks transition from draft to official invoice. | Column posted_timestamp (TIMESTAMP) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Amount' ;
    rdfs:comment 'Total discount amount applied from promotional campaigns, coupon codes, or special offers. Reduces the net amount due. | Column promotional_discount_amount (DECIMAL(15,2)) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalDiscountCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Code' ;
    rdfs:comment 'Coupon or promotion code applied to this invoice. Used for marketing campaign tracking and discount attribution analysis. | Column promotional_discount_code (STRING) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Indicates whether this invoice represents an automatic renewal, manual renewal, trial-to-paid conversion, plan upgrade, or plan downgrade. | Column renewal_type (STRING) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current status of revenue recognition for this invoice under ASC 606 accounting standards. Tracks whether revenue has been recognized in financial statements. | Column revenue_recognition_status (STRING) in billing.subscription_invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionPlanName rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Name' ;
    rdfs:comment 'Name of the subscription plan being billed (e.g., Premium Monthly, Basic Annual, Sports Bundle). Identifies the service tier and feature set. | Column subscription_plan_name (STRING) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPeriodCredit rdf:type rdf:Property ;
    rdfs:label 'Trial Period Credit' ;
    rdfs:comment 'Credit amount applied for free trial period. Typically offsets the full subscription charge during trial, resulting in zero net amount due. | Column trial_period_credit (DECIMAL(15,2)) in billing.subscription_invoice' ;
    rdfs:domain ind:SubscriptionInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyPartnerId rdf:type rdf:Property ;
    rdfs:label 'Agency Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Ad sales in broadcasting involve agency partners as intermediaries for commission splits, co-op advertising budgets, and consolidated billing. Agency relationship management requires partner domain li | Column agency_partner_id (BIGINT) in partner.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:billingContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ad orders have designated billing contacts within the broadcaster\'s billing team who coordinate with agencies on discrepancies, makegoods, and payment issues. Tracking billing contact employee is oper | Column billing_contact_employee_id (BIGINT) in workforce.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingDisputeId rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_dispute. Business justification: Ad billing order can have ONE formal billing dispute raised against it. Currently stores dispute_reason and dispute_date as STRING/DATE; need FK to the formal billing_dispute record for full dispute l | Column billing_dispute_id (BIGINT) in billing.ad_billing_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingDispute .

ind:affidavitStatus rdf:type rdf:Property ;
    rdfs:label 'Affidavit Status' ;
    rdfs:comment 'Status of proof-of-broadcast affidavit documentation for this order. Affidavits provide legal confirmation that contracted spots aired as scheduled. | Column affidavit_status (STRING) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Total amount invoiced to the advertiser or agency for this order, including any adjustments or makegoods. | Column billed_amount (DECIMAL(18,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Total contracted revenue amount for the advertising order as agreed in the sales contract, before any makegoods or adjustments. | Column contracted_amount (DECIMAL(18,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartBreakdown rdf:type rdf:Property ;
    rdfs:label 'Daypart Breakdown' ;
    rdfs:comment 'Distribution of advertising spots across broadcast dayparts (time segments of the broadcast day such as Prime Time, Early Morning, Late Night). Stored as structured text or JSON showing spot count and value per daypart. | Column daypart_breakdown (STRING) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpRate rdf:type rdf:Property ;
    rdfs:label 'Grp Rate' ;
    rdfs:comment 'Cost per gross rating point applied to this order, if GRP pricing is used. | Column grp_rate (DECIMAL(10,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodsValue rdf:type rdf:Property ;
    rdfs:label 'Makegoods Value' ;
    rdfs:comment 'Total value of compensatory ad spots provided to the advertiser due to underdelivery, technical issues, or audience guarantee shortfalls. | Column makegoods_value (DECIMAL(18,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on this billing order, calculated as billed amount minus paid amount. | Column outstanding_amount (DECIMAL(18,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount received in payment from the advertiser or agency against this billing order. | Column paid_amount (DECIMAL(18,2)) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Pricing model used for this advertising order. CPM (Cost Per Mille) = cost per thousand impressions, GRP (Gross Rating Point) = reach × frequency, CPRP (Cost Per Rating Point) = cost per single rating point, flat rate = fixed campaign price, cost per spot = per-unit pricing. | Column rate_basis (STRING) in billing.ad_billing_order' ;
    rdfs:domain ind:AdBillingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpotsAired rdf:type rdf:Property ;
    rdfs:label 'Total Spots Aired' ;
    rdfs:comment 'Total number of advertising spots that successfully aired as confirmed by affidavits and playout logs. | Column total_spots_aired (INT) in billing.ad_billing_order' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseCarriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Carriage Fee Amount' ;
    rdfs:comment 'Base carriage fee amount calculated as subscriber count multiplied by per-subscriber rate before adjustments. | Column base_carriage_fee_amount (DECIMAL(18,2)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Blackout Credit Amount' ;
    rdfs:comment 'Credit amount applied for geographic broadcast blackout periods where channel was unavailable to MVPD subscribers. | Column blackout_credit_amount (DECIMAL(18,2)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelLineupDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Lineup Description' ;
    rdfs:comment 'Description of the channel lineup or package included in this carriage fee invoice. | Column channel_lineup_description (STRING) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Adjustment Amount' ;
    rdfs:comment 'Adjustment amount applied due to billing disputes or makegoods for service level failures. | Column dispute_adjustment_amount (DECIMAL(18,2)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Escalation Adjustment Amount' ;
    rdfs:comment 'Adjustment amount applied due to contractual escalation clause (e.g., annual rate increase, CPI adjustment). | Column escalation_adjustment_amount (DECIMAL(18,2)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perSubscriberFeeRate rdf:type rdf:Property ;
    rdfs:label 'Per Subscriber Fee Rate' ;
    rdfs:comment 'Contractual per-subscriber fee rate applied to calculate the total carriage fee amount. | Column per_subscriber_fee_rate (DECIMAL(15,4)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retransmissionConsentType rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Type' ;
    rdfs:comment 'Type of regulatory framework governing this carriage fee: retransmission consent (negotiated) or must-carry (mandatory). | Column retransmission_consent_type (STRING) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Reference' ;
    rdfs:comment 'SAP S/4HANA financial posting document reference for revenue recognition and accounts receivable. | Column sap_posting_reference (STRING) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCountBasis rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Basis' ;
    rdfs:comment 'Number of MVPD subscribers used as the basis for calculating the carriage fee amount. | Column subscriber_count_basis (BIGINT) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCarriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Carriage Fee Amount' ;
    rdfs:comment 'Total carriage fee amount invoiced after all adjustments, credits, and escalations. | Column total_carriage_fee_amount (DECIMAL(18,2)) in billing.billing_carriage_fee_invoice' ;
    rdfs:domain ind:BillingCarriageFeeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:syndicationLicenseFeeId rdf:type rdf:Property ;
    rdfs:label 'Syndication License Fee Id' ;
    rdfs:comment 'Unique identifier for the syndication license fee billing record. | Column syndication_license_fee_id (BIGINT) in billing.syndication_license_fee' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syndicationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication Agreement Id' ;
    rdfs:comment 'Reference to the Rightsline contract governing this syndication license fee. | Column syndication_agreement_id (BIGINT) in partner.syndication_license_fee' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SyndicationAgreement .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for this syndication license agreement. | Column business_unit (STRING) in billing.syndication_license_fee' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Installment Due Date' ;
    rdfs:comment 'Due date for this specific installment or lump-sum payment. | Column installment_due_date (DATE) in billing.syndication_license_fee' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTerritory rdf:type rdf:Property ;
    rdfs:label 'License Territory' ;
    rdfs:comment 'Geographic territory covered by the syndication license (country, region, or market designation). | Column license_territory (STRING) in billing.syndication_license_fee' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeName rdf:type rdf:Property ;
    rdfs:label 'Licensee Name' ;
    rdfs:comment 'Legal name of the content licensee organization. | Column licensee_name (STRING) in billing.syndication_license_fee' ;
    rdfs:domain ind:SyndicationLicenseFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo. Primary key for the credit memo entity. | Column credit_memo_id (BIGINT) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:originalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being credited, adjusted, or written off. Null for credits not tied to a specific invoice. | Column original_invoice_id (BIGINT) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryCreditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the credit memo, for audit trail and SOX compliance. | Column primary_credit_employee_id (BIGINT) in workforce.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCreditModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Credit Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the credit memo record, for audit trail purposes. | Column tertiary_credit_modified_by_user_employee_id (BIGINT) in workforce.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:badDebtWriteOffFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Write Off Flag' ;
    rdfs:comment 'Indicates whether this credit memo represents a bad debt write-off for an uncollectable balance. True for write-offs, false for other credit types. | Column bad_debt_write_off_flag (BOOLEAN) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the third-party collection agency to which the debt was referred, if applicable. | Column collection_agency_name (STRING) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Referral Flag' ;
    rdfs:comment 'Indicates whether the original debt was referred to a collection agency before write-off. Used for tracking recovery potential. | Column collection_agency_referral_flag (BOOLEAN) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-visible business identifier for the credit memo, used in customer communications and financial reporting. Typically follows format CM-YYYYMMDD-NNNN. | Column credit_memo_number (STRING) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle status of the credit memo in the approval and application workflow. | Column credit_memo_status (STRING) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodSpotsQuantity rdf:type rdf:Property ;
    rdfs:label 'Makegood Spots Quantity' ;
    rdfs:comment 'Number of compensatory advertising spots to be provided as makegood for under-delivered campaigns. Null for non-makegood credits. | Column makegood_spots_quantity (INT) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Net Credit Amount' ;
    rdfs:comment 'Net credit amount after tax adjustments. Equals credit_amount minus tax_amount. | Column net_credit_amount (DECIMAL(18,2)) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount subsequently recovered from a written-off debt through collection efforts or customer payment. Null if no recovery occurred. | Column recovery_amount (DECIMAL(18,2)) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a previously written-off amount was recovered. Null if no recovery occurred. | Column recovery_date (DATE) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionImpact rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Impact' ;
    rdfs:comment 'Accounting period impact classification for revenue recognition under ASC 606. Indicates whether the credit affects current, prior, or future period revenue. | Column revenue_recognition_impact (STRING) in billing.credit_memo' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'Date the credit memo was posted to SAP S/4HANA general ledger for financial reporting. | Column sap_posting_date (DATE) in billing.credit_memo' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Foreign key linking to billing.write_off. Business justification: Billing dispute can be resolved via ONE write-off decision (when dispute is valid and amount is written off). Need FK to write_off for dispute resolution tracking. No redundant columns to remove. | Column write_off_id (BIGINT) in billing.billing_dispute' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WriteOff .

ind:assignedResolverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Name' ;
    rdfs:comment 'Name of the employee or team assigned to resolve the dispute, for operational tracking. | Column assigned_resolver_name (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Flag' ;
    rdfs:comment 'Indicates whether a credit memo was issued as part of the dispute resolution (True) or not (False). | Column credit_memo_issued_flag (BOOLEAN) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'Monetary amount being disputed' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative explanation of the dispute as provided by the disputing party, capturing the specific issue and context. | Column dispute_description (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute reason: amount_error (billing calculation error), service_not_received (content or service not delivered), makegood_claim (compensatory ad spot request), duplicate_charge (same charge billed twice), rate_discrepancy (incorrect pricing applied), contract_dispute (terms interpretation disagreement). | Column dispute_type (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputingPartyName rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Name' ;
    rdfs:comment 'Name of the organization or individual who raised the dispute, for reporting and communication purposes. | Column disputing_party_name (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputingPartyType rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Type' ;
    rdfs:comment 'Category of the entity raising the dispute: subscriber (end consumer), advertiser (ad campaign buyer), MVPD (Multichannel Video Programming Distributor), licensee (content license holder), distributor (content distribution partner). | Column disputing_party_type (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filedDate rdf:type rdf:Property ;
    rdfs:label 'Filed Date' ;
    rdfs:comment 'Date when the dispute was formally filed' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The date the dispute was formally raised and entered into the dispute management system. | Column open_date (DATE) in billing.billing_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Precise timestamp when the dispute was created in the system, used for SLA tracking and audit trail. | Column open_timestamp (TIMESTAMP) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline Date' ;
    rdfs:comment 'Target date by which the dispute must be resolved per Service Level Agreement (SLA) or contractual terms. | Column resolution_deadline_date (DATE) in billing.billing_dispute' ;
    rdfs:domain ind:BillingDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the dispute resolution: full_credit (entire disputed amount credited), partial_credit (portion credited), no_adjustment (dispute rejected, no change), makegood_issued (compensatory ad spot provided), contract_amendment (terms renegotiated), escalated_unresolved (sent to legal or executive review). | Column resolution_outcome (STRING) in billing.billing_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Unique identifier for the refund transaction. Primary key for the refund record. | Column refund_id (BIGINT) in billing.refund' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Projected date when the refund is expected to be settled and funds returned to the subscriber. Format: yyyy-MM-dd. | Column expected_settlement_date (DATE) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Any processing fee deducted from the refund amount, if applicable (e.g., payment gateway fees, administrative charges). | Column fee (DECIMAL(18,2)) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChargebackRelated rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Related' ;
    rdfs:comment 'Boolean flag indicating whether this refund is related to a payment chargeback or dispute initiated by the subscriber through their financial institution. | Column is_chargeback_related (BOOLEAN) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'Boolean flag indicating whether this is a partial refund (true) or a full refund (false) of the original payment amount. | Column is_partial_refund (BOOLEAN) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'The method by which the refund is being returned to the subscriber: back to original payment instrument, check, account credit, wire transfer, or other mechanism. [ENUM-REF-CANDIDATE: original_payment_method|credit_card|bank_transfer|check|account_credit|wire_transfer|paypal|other — 8 candidates stripped; promote to reference product] | Column refund_method (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'Net monetary amount actually returned to the subscriber or account after deducting any processing fees (refund_amount - refund_fee). | Column net_refund_amount (DECIMAL(18,2)) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Date when the refund was submitted for payment processing. Format: yyyy-MM-dd. | Column processing_date (DATE) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally-visible business identifier for the refund, used in customer communications and financial reconciliation. Format: RFD-XXXXXXXXXX. | Column refund_number (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction in the processing workflow. [ENUM-REF-CANDIDATE: pending_approval|approved|processing|completed|failed|cancelled|reversed — 7 candidates stripped; promote to reference product] | Column refund_status (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund based on the revenue stream being reversed: subscription billing, advertising billing, carriage fee, syndication license fee, overpayment, or other. | Column refund_type (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideorbitRefundReference rdf:type rdf:Property ;
    rdfs:label 'Wideorbit Refund Reference' ;
    rdfs:comment 'External identifier from Wide Orbit traffic and billing system for refunds originating from advertising revenue, used for system integration and reconciliation. | Column wideorbit_refund_reference (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraRefundReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Refund Reference' ;
    rdfs:comment 'External identifier from Zuora subscription billing system for refunds originating from subscription revenue, used for system integration and reconciliation. | Column zuora_refund_reference (STRING) in billing.refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningEventId rdf:type rdf:Property ;
    rdfs:label 'Dunning Event Id' ;
    rdfs:comment 'Unique identifier for the dunning event record. Primary key. | Column dunning_event_id (BIGINT) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountBalanceAtAction rdf:type rdf:Property ;
    rdfs:label 'Account Balance At Action' ;
    rdfs:comment 'Outstanding balance on the billing account at the time the dunning action was taken. | Column account_balance_at_action (DECIMAL(15,2)) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Account Termination Flag' ;
    rdfs:comment 'Indicates whether the billing account was terminated as a result of this dunning action. | Column account_termination_flag (BOOLEAN) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountTerminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Termination Timestamp' ;
    rdfs:comment 'Date and time when the billing account was terminated, if applicable. | Column account_termination_timestamp (TIMESTAMP) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Date and time when the dunning action was executed. | Column action_timestamp (TIMESTAMP) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of dunning action taken against the delinquent account. | Column action_type (STRING) in billing.dunning_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountRecovered rdf:type rdf:Property ;
    rdfs:label 'Amount Recovered' ;
    rdfs:comment 'Amount successfully recovered as a result of this dunning action, if any. | Column amount_recovered (DECIMAL(15,2)) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Channel through which the dunning communication was delivered to the subscriber. | Column communication_channel (STRING) in billing.dunning_event' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the account has been delinquent at the time of this dunning action. | Column days_past_due (INT) in billing.dunning_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningStepNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Step Number' ;
    rdfs:comment 'Sequential step number in the dunning workflow (e.g., 1 for first reminder, 2 for second reminder, 3 for suspension warning, 4 for service suspension). | Column dunning_step_number (INT) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDunningStepScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Dunning Step Scheduled Date' ;
    rdfs:comment 'Scheduled date for the next dunning action if this step did not resolve the delinquency. | Column next_dunning_step_scheduled_date (DATE) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Result or outcome of the dunning action taken. [ENUM-REF-CANDIDATE: payment_received|payment_failed|promise_to_pay|dispute_raised|no_response|account_suspended|account_terminated — 7 candidates stripped; promote to reference product] | Column outcome (STRING) in billing.dunning_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Address' ;
    rdfs:comment 'Email address, phone number, or postal address to which the dunning communication was sent. | Column recipient_address (STRING) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Indicates whether the subscriber responded to this dunning action (e.g., made a payment, contacted support, updated payment method). | Column response_received_flag (BOOLEAN) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Count' ;
    rdfs:comment 'Number of automated payment retry attempts made for this dunning event, if action type is payment retry. | Column retry_attempt_count (INT) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceSuspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Flag' ;
    rdfs:comment 'Indicates whether subscriber services were suspended as a result of this dunning action. | Column service_suspension_flag (BOOLEAN) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceSuspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Timestamp' ;
    rdfs:comment 'Date and time when subscriber services were suspended, if applicable. | Column service_suspension_timestamp (TIMESTAMP) in billing.dunning_event' ;
    rdfs:domain ind:DunningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueRecognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Schedule Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition schedule entry. Primary key for ASC 606 revenue recognition tracking. | Column revenue_recognition_schedule_id (BIGINT) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Distribution Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.distribution_agreement. Business justification: Multi-year carriage fee agreements require revenue recognition schedules for upfront payments or minimum guarantees. Links recognition schedules to distribution agreements for carriage fee amortizatio | Column distribution_agreement_id (BIGINT) in partner.revenue_recognition_schedule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionAgreement .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total revenue recognized to date from contract inception through the current reporting period. Increases each period as revenue is earned. Used for deferred revenue balance calculation and revenue assurance reconciliation. | Column cumulative_recognized_amount (DECIMAL(18,2)) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Current Period Recognized Amount' ;
    rdfs:comment 'Revenue amount recognized in the current accounting period (month or quarter). Posted to the SAP revenue account. May differ from monthly recognized amount for usage-based or milestone-based contracts. | Column current_period_recognized_amount (DECIMAL(18,2)) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'Remaining unearned revenue balance on the contract. Calculated as total contract value minus cumulative recognized amount. Represents the liability on the balance sheet under ASC 606. Decreases as revenue is recognized over time. | Column deferred_revenue_balance (DECIMAL(18,2)) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Last Recognition Date' ;
    rdfs:comment 'Date of the most recent revenue recognition posting. Used to track recognition progress and identify schedules requiring current-period processing. | Column last_recognition_date (DATE) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monthlyRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Recognized Amount' ;
    rdfs:comment 'Standard monthly revenue amount to be recognized under straight-line method. Calculated as total contract value divided by recognition period months. May vary for usage-based or milestone-based contracts. | Column monthly_recognized_amount (DECIMAL(18,2)) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Next Recognition Date' ;
    rdfs:comment 'Scheduled date for the next revenue recognition posting. Used by automated revenue recognition jobs to process monthly or quarterly recognition batches. | Column next_recognition_date (DATE) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Narrative description of the performance obligation under ASC 606 (e.g., \'Provide streaming access to content library for 12 months\', \'Deliver 52 episodes of syndicated series\', \'Deliver 1000 GRPs in Q4 upfront commitment\'). Documents the basis for revenue recognition timing. | Column performance_obligation_description (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'Date when revenue recognition is scheduled to complete. Corresponds to the contract expiration date or end of the performance obligation period. Null for evergreen contracts until termination notice. | Column recognition_end_date (DATE) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'ASC 606 revenue recognition method applied to this contract. Straight-Line (equal monthly recognition for subscriptions), Milestone-Based (triggered by delivery events for syndication), Usage-Based (actual consumption for AVOD/TVOD), Proportional Performance (percentage-of-completion for production contracts), Point-in-Time (immediate recognition for transactional sales). | Column recognition_method (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Months' ;
    rdfs:comment 'Total number of months over which revenue will be recognized. Calculated from recognition start date to end date. Used for straight-line recognition calculations and forecasting. | Column recognition_period_months (INT) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Date when revenue recognition begins. Corresponds to the contract effective date or service commencement date under ASC 606. Marks the beginning of the performance obligation period. | Column recognition_start_date (DATE) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the revenue recognition schedule. Scheduled (future start date), In Progress (actively recognizing), Completed (fully recognized), Suspended (temporarily paused), Terminated (contract cancelled early), Adjusted (modified due to contract amendment or makegood). | Column recognition_status (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDeferredRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Deferred Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) liability account code in SAP S/4HANA where deferred revenue balance is maintained. Decreases as revenue is recognized and transferred to the revenue account. | Column sap_deferred_revenue_account_code (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Sap Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) account code in SAP S/4HANA where recognized revenue is posted. Maps to the appropriate revenue account based on contract type and business unit (e.g., subscription revenue, advertising revenue, licensing revenue). | Column sap_revenue_account_code (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContractReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Reference' ;
    rdfs:comment 'Native contract identifier in the source system (e.g., Zuora subscription ID, Wide Orbit order number, Rightsline license agreement ID). Used for data lineage and reconciliation back to operational systems. | Column source_system_contract_reference (STRING) in billing.revenue_recognition_schedule' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Unique identifier for the tax calculation and reporting record. Primary key for the tax_record product. | Column tax_record_id (BIGINT) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerTaxClassification rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Classification' ;
    rdfs:comment 'Tax classification of the customer for determining applicable tax treatment. Business (B2B), Individual (B2C), Government, Non-Profit, Exempt Organization. | Column customer_tax_classification (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Number' ;
    rdfs:comment 'The customer\'s tax identification number (TIN, VAT number, GST number, EIN, etc.) used for tax reporting and validation. Format varies by jurisdiction. | Column customer_tax_number (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusCountry rdf:type rdf:Property ;
    rdfs:label 'Nexus Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where tax nexus is established (e.g., USA, GBR, FRA, CAN). | Column nexus_country (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusStateProvince rdf:type rdf:Property ;
    rdfs:label 'Nexus State Province' ;
    rdfs:comment 'State or province where the business has established tax nexus (physical or economic presence triggering tax obligation). Critical for US sales tax and Canadian GST/PST compliance. | Column nexus_state_province (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference Number' ;
    rdfs:comment 'Payment reference or confirmation number from the tax authority acknowledging receipt of the tax remittance. Used for audit trail and reconciliation. | Column remittance_reference_number (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Current status of tax payment to the tax authority. Pending (not yet paid), Remitted (paid in full), Partially Remitted (partial payment made), Disputed (under review or appeal), Waived (exempted or forgiven). | Column remittance_status (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies (True = customer is responsible for self-assessing and remitting VAT/GST, False = supplier charges and remits tax). Common in EU cross-border B2B transactions. | Column reverse_charge_flag (BOOLEAN) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemTaxReference rdf:type rdf:Property ;
    rdfs:label 'Source System Tax Reference' ;
    rdfs:comment 'The unique identifier for this tax record in the source operational system. Enables traceability and reconciliation back to the originating system. | Column source_system_tax_reference (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthority rdf:type rdf:Property ;
    rdfs:label 'Tax Authority' ;
    rdfs:comment 'Name of the governmental tax authority responsible for collection and enforcement (e.g., IRS, HMRC, California Department of Tax and Fee Administration, Direction Générale des Finances Publiques). | Column tax_authority (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method used to calculate the tax amount. Automated (system-calculated), Manual (finance team entry), Third-Party Service (Avalara, Vertex, TaxJar), Override (manual adjustment to automated calculation). | Column tax_calculation_method (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Business categorization of the taxable item or service (e.g., Subscription Services, Advertising Services, Content Licensing, Equipment Rental, Digital Downloads). Used for tax rate determination and reporting segmentation. | Column tax_category (STRING) in billing.tax_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether a tax exemption was applied to this transaction (True = exemption applied, False = no exemption). | Column tax_exemption_flag (BOOLEAN) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Reason' ;
    rdfs:comment 'Business reason or regulatory basis for the tax exemption (e.g., Non-profit organization, Government entity, Educational institution, Resale certificate, Export transaction). | Column tax_exemption_reason (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Due Date' ;
    rdfs:comment 'The statutory due date for filing the tax return that includes this transaction, based on the tax jurisdiction and filing period. | Column tax_filing_due_date (DATE) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxFilingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Period' ;
    rdfs:comment 'The tax reporting period to which this transaction applies, formatted as YYYY-Q# for quarterly or YYYY-M## for monthly (e.g., 2024-Q1, 2024-M03). Aligns with jurisdiction-specific filing schedules. | Column tax_filing_period (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, province, county, or municipality) where the tax obligation arises. Format: ISO country code optionally followed by subdivision code (e.g., US-CA, GB, FR-75). | Column tax_jurisdiction_code (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Full name of the tax jurisdiction (e.g., California, United Kingdom, Paris) for human-readable reporting and compliance documentation. | Column tax_jurisdiction_name (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Line Number' ;
    rdfs:comment 'Sequential line number for this tax record within the parent invoice, supporting multiple tax jurisdictions or tax types per invoice. | Column tax_line_number (INT) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxPointDate rdf:type rdf:Property ;
    rdfs:label 'Tax Point Date' ;
    rdfs:comment 'The date when the tax liability arises according to tax regulations (also known as time of supply). May differ from transaction_date based on jurisdiction-specific rules for services, advance payments, or continuous supplies. | Column tax_point_date (DATE) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate applied to the taxable amount, expressed as a decimal (e.g., 0.0825 for 8.25%). Supports precision to six decimal places for complex multi-jurisdictional calculations. | Column tax_rate (DECIMAL(10,6)) in billing.tax_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Internal or regulatory code defining the specific tax treatment applied (e.g., standard rate, reduced rate, zero-rated, exempt, out-of-scope). Maps to jurisdiction-specific tax rules. | Column tax_treatment_code (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Type of tax applied to the transaction. Sales Tax (US state/local), VAT (Value-Added Tax, EU/international), GST (Goods and Services Tax), Withholding Tax (international syndication/licensing), Excise Tax (specific content types), Use Tax (cross-border digital services). | Column tax_type (STRING) in billing.tax_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The portion of the invoice amount subject to taxation in this jurisdiction, after applying exemptions and exclusions. Denominated in the invoice currency. | Column taxable_amount (DECIMAL(18,2)) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyTaxService rdf:type rdf:Property ;
    rdfs:label 'Third Party Tax Service' ;
    rdfs:comment 'Name of the external tax calculation service provider if third-party method was used (e.g., Avalara AvaTax, Vertex Cloud, TaxJar, Thomson Reuters ONESOURCE). | Column third_party_tax_service (STRING) in billing.tax_record' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique identifier for the payment allocation record. Primary key. | Column payment_allocation_id (BIGINT) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'System user identifier of the person or automated process that created this allocation. Used for audit trails, accountability, and troubleshooting allocation errors. May be system account for automated allocations. | Column primary_payment_employee_id (BIGINT) in workforce.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that is allocated to this specific invoice. For partial payments, this represents the portion applied to this invoice. For full settlements, this equals the invoice outstanding balance. Critical for accounts receivable aging and revenue assurance calculations. | Column allocated_amount (DECIMAL(18,2)) in billing.payment_allocation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date when the payment allocation was executed and applied to the invoice. This date determines the accounting period for revenue recognition and accounts receivable aging. Critical for financial reporting and compliance with ASC 606. | Column allocation_date (DATE) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The business rule or algorithm used to determine this allocation. Manual indicates user-specified allocation; Automatic indicates system-applied based on aging rules; Prorated indicates proportional distribution across multiple invoices; FIFO (First In First Out) indicates oldest invoice paid first; LIFO (Last In First Out) indicates newest invoice paid first; Specific indicates customer-directed allocation to particular invoice. | Column allocation_method (STRING) in billing.payment_allocation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSequence rdf:type rdf:Property ;
    rdfs:label 'Allocation Sequence' ;
    rdfs:comment 'Sequential order number for this allocation within the parent payment transaction. When a single payment is split across multiple invoices, this field indicates the application order. Used for FIFO/LIFO allocation logic and audit trails. | Column allocation_sequence (INT) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the payment allocation was processed in the billing system. Used for audit trails and transaction sequencing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column allocation_timestamp (TIMESTAMP) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the payment allocation method. Full Settlement indicates payment completely satisfies invoice balance; Partial Payment indicates payment covers portion of invoice; Advance Deposit indicates payment received before invoice generation; Unapplied Credit indicates payment not yet matched to specific invoice; Overpayment indicates payment exceeds invoice amount; Prepayment indicates payment for future services. | Column allocation_type (STRING) in billing.payment_allocation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'The SAP S/4HANA general ledger document number generated when this allocation was posted to the financial system. Used for cross-system reconciliation and audit trails between billing and finance. | Column gl_document_number (STRING) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Business identifier of the invoice receiving this allocation. Denormalized from invoice table for quick reference and reporting without joins. Typically matches invoice_number from the invoice product. | Column invoice_reference_number (STRING) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date when this allocation was reversed or voided. Null if allocation is still active. Used for audit trails and accounts receivable reconciliation when allocations are corrected or disputed. | Column reversal_date (DATE) in billing.payment_allocation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Source System Allocation Reference' ;
    rdfs:comment 'The unique identifier for this allocation in the source system (Zuora, Wide Orbit, or SAP). Used for cross-system reconciliation, data lineage tracking, and troubleshooting integration issues. | Column source_system_allocation_reference (STRING) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'Remaining payment amount not allocated to any invoice after this allocation. Represents credit balance available for future invoice matching. Critical for cash application and accounts receivable management. | Column unapplied_balance (DECIMAL(18,2)) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeoffAmount rdf:type rdf:Property ;
    rdfs:label 'Writeoff Amount' ;
    rdfs:comment 'Portion of the invoice balance written off as uncollectible at the time of this allocation. Used when accepting partial payment as final settlement. Impacts bad debt reserves and revenue recognition adjustments. | Column writeoff_amount (DECIMAL(18,2)) in billing.payment_allocation' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRunApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Run Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this billing run for distribution. Null if approval not required or run not yet approved. | Column run_approved_by_user_employee_id (BIGINT) in workforce.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountsWithErrors rdf:type rdf:Property ;
    rdfs:label 'Accounts With Errors' ;
    rdfs:comment 'Count of customer accounts that failed to process successfully during this billing run. Used to identify accounts requiring manual intervention. | Column accounts_with_errors (INT) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The effective billing date applied to all invoices generated in this run. Determines invoice date, due date calculation, and revenue recognition period. | Column billing_date (DATE) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the billing run finished execution, whether successfully or with errors. Null for runs still in progress or suspended. | Column completion_timestamp (TIMESTAMP) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Completion Timestamp' ;
    rdfs:comment 'Date and time when invoice distribution to customers completed. Null for runs still distributing or not yet started. | Column distribution_completion_timestamp (TIMESTAMP) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Start Timestamp' ;
    rdfs:comment 'Date and time when invoice distribution to customers began. Used to track delivery SLA and customer communication timing. | Column distribution_start_timestamp (TIMESTAMP) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Total number of errors encountered during billing run execution. Includes account processing failures, invoice generation errors, and system exceptions. | Column error_count (INT) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDistributionStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Distribution Status' ;
    rdfs:comment 'Status of invoice delivery to customers. Pending runs await distribution; in-progress runs are actively sending; completed runs finished delivery; failed runs encountered distribution errors; cancelled runs were stopped. | Column invoice_distribution_status (STRING) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Primary revenue classification for this billing run. Subscription runs bill SVOD/linear subscribers; advertising runs bill CPM/GRP campaigns; carriage runs bill MVPD distribution fees; syndication runs bill content licensing; transactional runs bill TVOD purchases. | Column revenue_category (STRING) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-friendly identifier for the billing run, typically formatted as cycle-sequence (e.g., 2024-01-R001). Used for operational tracking and reporting. | Column run_number (STRING) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the billing run. Scheduled runs are queued; in-progress runs are actively generating invoices; completed runs finished successfully; failed runs encountered errors; cancelled runs were aborted; suspended runs are paused pending resolution. | Column run_status (STRING) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the billing run execution. Regular runs follow standard cycle schedules; off-cycle runs address mid-period changes; final runs close out terminated accounts; correction runs fix prior errors; makegood runs issue compensatory credits; adjustment runs apply manual corrections. | Column run_type (STRING) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingBatchReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Batch Reference' ;
    rdfs:comment 'SAP S/4HANA batch identifier for financial posting of billing run results. Links billing transactions to general ledger entries. | Column sap_posting_batch_reference (STRING) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccountsProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Accounts Processed' ;
    rdfs:comment 'Total count of customer accounts included in this billing run execution. Used for operational monitoring and reconciliation. | Column total_accounts_processed (INT) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAmountBilled rdf:type rdf:Property ;
    rdfs:label 'Total Amount Billed' ;
    rdfs:comment 'Sum of all invoice totals generated in this billing run, representing gross revenue before payments. Used for revenue assurance and financial reconciliation. | Column total_amount_billed (DECIMAL(18,2)) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceLinesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Lines Generated' ;
    rdfs:comment 'Total count of invoice line items created across all invoices in this billing run. Used for detailed processing metrics and performance analysis. | Column total_invoice_lines_generated (INT) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Total count of invoices successfully generated during this billing run. May differ from accounts processed if some accounts had zero charges or errors. | Column total_invoices_generated (INT) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Total number of warnings generated during billing run execution. Warnings indicate potential issues that did not prevent invoice generation but require review. | Column warning_count (INT) in billing.run' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitBatchReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Batch Reference' ;
    rdfs:comment 'External identifier from Wide Orbit traffic and billing system for advertising billing runs. Used for ad sales invoice reconciliation. | Column wide_orbit_batch_reference (STRING) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zuoraBillingRunReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Billing Run Reference' ;
    rdfs:comment 'External identifier from Zuora subscription billing system for this billing run. Used for cross-system reconciliation and audit trail. | Column zuora_billing_run_reference (STRING) in billing.run' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucketAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket At Write Off' ;
    rdfs:comment 'Accounts receivable aging category of the invoice at the time of write-off (e.g., current, 30 days, 60 days, 90 days, 120+ days). | Column aging_bucket_at_write_off (STRING) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collection Referral Date' ;
    rdfs:comment 'The date on which the debt was referred to the external collection agency. | Column collection_referral_date (DATE) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOutstandingAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding At Write Off' ;
    rdfs:comment 'Number of days the invoice was outstanding (from invoice date to write-off date) at the time the write-off decision was made. | Column days_outstanding_at_write_off (INT) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ebitdaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Impact Flag' ;
    rdfs:comment 'Indicates whether this write-off has a material impact on EBITDA reporting for the period (True/False). | Column ebitda_impact_flag (BOOLEAN) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The total amount originally invoiced before any payments, adjustments, or write-offs were applied. | Column original_invoice_amount (DECIMAL(18,2)) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance At Write Off' ;
    rdfs:comment 'The remaining unpaid balance on the invoice at the time the write-off decision was made. | Column outstanding_balance_at_write_off (DECIMAL(18,2)) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Gl Account Code' ;
    rdfs:comment 'SAP S/4HANA general ledger account code to which any recovered amount is posted (typically a bad debt recovery income account). | Column recovery_gl_account_code (STRING) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this write-off has been reversed due to subsequent payment or correction (True/False). | Column reversal_flag (BOOLEAN) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the bad debt write-off decision was executed and recorded in the financial system. | Column write_off_date (DATE) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Business-facing unique identifier for the write-off transaction, used for tracking and audit purposes. | Column write_off_number (STRING) in billing.write_off' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBillingReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Ad Billing Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the advertising billing reconciliation record. Primary key for this entity. | Column ad_billing_reconciliation_id (BIGINT) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAdBillingReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Original Ad Billing Reconciliation Id' ;
    rdfs:comment 'Self-referencing FK on ad_billing_reconciliation (original_ad_billing_reconciliation_id) | Column original_ad_billing_reconciliation_id (BIGINT) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdBillingReconciliation .

ind:affidavitCount rdf:type rdf:Property ;
    rdfs:label 'Affidavit Count' ;
    rdfs:comment 'The total number of proof-of-broadcast affidavits associated with this reconciliation record, documenting actual spot delivery. | Column affidavit_count (INT) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Affidavit Verification Status' ;
    rdfs:comment 'The status of affidavit verification indicating whether proof-of-broadcast documentation has been validated and accepted. | Column affidavit_verification_status (STRING) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredAmount rdf:type rdf:Property ;
    rdfs:label 'Delivered Amount' ;
    rdfs:comment 'The monetary value of advertising spots that were successfully delivered and verified through affidavits. | Column delivered_amount (DECIMAL(18,2)) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodValueAmount rdf:type rdf:Property ;
    rdfs:label 'Makegood Value Amount' ;
    rdfs:comment 'The monetary value of the makegood spots provided as compensation, calculated at the original contracted rate. | Column makegood_value_amount (DECIMAL(18,2)) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBillableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Billable Amount' ;
    rdfs:comment 'The final net amount billable to the advertiser after all reconciliation adjustments, makegoods, and credits have been applied. | Column net_billable_amount (DECIMAL(18,2)) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business-facing unique reference number for this reconciliation record, used for tracking and reporting purposes. | Column reconciliation_number (STRING) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Precise timestamp when the reconciliation record was finalized, used for audit trail and settlement timing. | Column reconciliation_timestamp (TIMESTAMP) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'The type of reconciliation record indicating whether this is a standard delivery verification, makegood settlement, credit issuance, or billing adjustment. | Column reconciliation_type (STRING) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpotsMissed rdf:type rdf:Property ;
    rdfs:label 'Total Spots Missed' ;
    rdfs:comment 'The number of ordered advertising spots that failed to air as scheduled, requiring makegood remediation. | Column total_spots_missed (INT) in billing.ad_billing_reconciliation' ;
    rdfs:domain ind:AdBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCommunicationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Parent Communication Template Id' ;
    rdfs:comment 'Reference to the previous version of this template, enabling version history tracking. Null for initial versions. | Column parent_template_id (BIGINT) in billing.communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommunicationTemplate .

ind:attachmentFileNamePattern rdf:type rdf:Property ;
    rdfs:label 'Attachment File Name Pattern' ;
    rdfs:comment 'Pattern or template for generating attachment file names. May contain merge field placeholders. | Column attachment_file_name_pattern (STRING) in billing.communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Attachment Required Flag' ;
    rdfs:comment 'Indicates whether this template requires an attachment (such as an invoice PDF or payment receipt) to be included when sent. | Column attachment_required_flag (BOOLEAN) in billing.communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bccRecipients rdf:type rdf:Property ;
    rdfs:label 'Bcc Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses to be blind copied on communications generated from this template. | Column bcc_recipients (STRING) in billing.communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Main content body of the communication template. May contain HTML markup and merge field placeholders for dynamic data insertion. | Column body_content (STRING) in billing.communication_template' ;
    rdfs:domain ind:CommunicationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'Classification of the communication for regulatory compliance purposes (e.g., CAN-SPAM, GDPR, TCPA). | Column compliance_category (STRING) in billing.communication_template' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
