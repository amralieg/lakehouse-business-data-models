    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the dispute should be resolved per contractual Service Level Agreement (SLA) or internal policy. | Column target_resolution_date (DATE) in partner.partner_dispute' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Business Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Windowing strategies require business owner tracking for activation decisions, performance monitoring, and renewal negotiations. Critical for accountability in SVOD/AVOD/TVOD window management and rev | Column business_owner_employee_id (BIGINT) in workforce.partner_content_window' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partnerRightsContentWindowId rdf:type rdf:Property ;
    rdfs:label 'Partner Rights Content Window Id' ;
    rdfs:comment 'FK to canonical rights content window | Column rights_content_window_id (BIGINT) in rights.partner_content_window' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsContentWindow .

ind:languageAvailability rdf:type rdf:Property ;
    rdfs:label 'Language Availability' ;
    rdfs:comment 'Languages in which the content must be made available during this window (e.g., English, Spanish, French). Comma-separated list of ISO 639-1 language codes. | Column language_availability (STRING) in partner.partner_content_window' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Rights Included Flag' ;
    rdfs:comment 'Indicates whether the platform has rights to use promotional materials, trailers, and marketing assets for this window (True) or must obtain separate clearance (False). | Column marketing_rights_included_flag (BOOLEAN) in partner.partner_content_window' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceGuaranteeDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Description' ;
    rdfs:comment 'Free-text description of any performance commitments tied to this window (e.g., minimum viewership targets, promotional spend requirements, platform placement guarantees). | Column performance_guarantee_description (STRING) in partner.partner_content_window' ;
    rdfs:domain ind:PartnerContentWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the partner renewal record. Primary key for tracking renewal lifecycle events across acquisition deals, distribution agreements, affiliate agreements, and syndication contracts. | Column renewal_id (BIGINT) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRenewalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Renewal Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing this partner relationship and driving the renewal process. Typically a content acquisition manager, distribution director, or partnership manager. | Column renewal_employee_id (BIGINT) in workforce.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRenewalLegalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Renewal Legal Reviewer Employee Id' ;
    rdfs:comment 'Reference to the legal counsel assigned to review renewal terms, assess risk, and ensure compliance with regulatory requirements and corporate policies. | Column renewal_legal_reviewer_employee_id (BIGINT) in workforce.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRenewalFinanceApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Renewal Finance Approver Employee Id' ;
    rdfs:comment 'Reference to the finance executive responsible for budget approval and financial impact assessment. Required approval level varies based on deal value thresholds. | Column renewal_finance_approver_employee_id (BIGINT) in workforce.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval process. Workflow stages and required approvers vary based on deal value thresholds, strategic importance, and organizational governance policies. [ENUM-REF-CANDIDATE: business_owner_review|legal_review|finance_review|executive_review|board_approval|final_approval|completed — 7 candidates stripped; promote to reference product] | Column approval_workflow_stage (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Clause Flag' ;
    rdfs:comment 'Indicates whether the original agreement contains an automatic renewal provision. When true, agreement renews automatically unless explicit non-renewal notice is provided by the decision due date. | Column auto_renewal_clause_flag (BOOLEAN) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalTerms rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Terms' ;
    rdfs:comment 'Detailed description of automatic renewal provisions including renewal term length, rate escalation clauses, and conditions under which auto-renewal applies. Critical for preventing unintended contract extensions. | Column auto_renewal_terms (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDueDate rdf:type rdf:Property ;
    rdfs:label 'Decision Due Date' ;
    rdfs:comment 'Deadline by which the organization must communicate renewal decision to the partner. Failure to meet this date may trigger auto-renewal clauses or result in unintended agreement lapse. | Column decision_due_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Terms Summary' ;
    rdfs:comment 'Executive summary of material changes and key provisions in the proposed renewal including pricing adjustments, rights modifications, performance guarantees, and strategic commitments. | Column key_terms_summary (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonRenewalReason rdf:type rdf:Property ;
    rdfs:label 'Non Renewal Reason' ;
    rdfs:comment 'Detailed explanation when renewal outcome is not_renewed or terminated. Captures business rationale such as poor content performance, unfavorable terms, strategic realignment, or partner performance issues. | Column non_renewal_reason (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAgreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Original Agreement End Date' ;
    rdfs:comment 'Expiration date of the current agreement term. Triggers renewal workflow initiation based on advance notice requirements specified in the contract. | Column original_agreement_end_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalAgreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Original Agreement Start Date' ;
    rdfs:comment 'Effective start date of the current agreement term being renewed. Provides historical context for relationship duration and performance evaluation. | Column original_agreement_start_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Original Deal Value Amount' ;
    rdfs:comment 'Total financial value of the current agreement term being renewed. Provides baseline for evaluating proposed renewal terms and calculating value change percentage. | Column original_deal_value_amount (DECIMAL(18,2)) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date when final renewal decision was communicated to the partner. Critical for audit trail, compliance verification, and preventing disputes over notice timing. | Column outcome_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Partner Performance Rating' ;
    rdfs:comment 'Overall assessment of partner performance during the current agreement term. Evaluates content quality, delivery timeliness, audience performance, rights compliance, and relationship collaboration. Key input to renewal decision. | Column partner_performance_rating (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedDealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value Amount' ;
    rdfs:comment 'Total financial value of the proposed renewed agreement over its full term. Used for budget planning, financial forecasting, and executive approval thresholds. | Column proposed_deal_value_amount (DECIMAL(18,2)) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDealValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Proposed Deal Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the proposed deal value. Essential for multi-currency contract management and financial consolidation. | Column proposed_deal_value_currency_code (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedEndDate rdf:type rdf:Property ;
    rdfs:label 'Proposed End Date' ;
    rdfs:comment 'Intended expiration date for the renewed agreement. Calculated from proposed start date plus proposed term length. | Column proposed_end_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Proposed Payment Terms' ;
    rdfs:comment 'Detailed payment schedule and terms for the renewed agreement including payment frequency, milestone-based payments, minimum guarantees, revenue share percentages, and payment methods. | Column proposed_payment_terms (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedRenewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Renewal Term Months' ;
    rdfs:comment 'Duration in months for the proposed renewed agreement. May differ from original term based on negotiation outcomes, market conditions, or strategic relationship objectives. | Column proposed_renewal_term_months (INT) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedRightsScope rdf:type rdf:Property ;
    rdfs:label 'Proposed Rights Scope' ;
    rdfs:comment 'Description of content rights, distribution territories, platform exclusivity, windowing strategies, and sublicensing provisions proposed for the renewed agreement. Critical for rights management and content strategy alignment. | Column proposed_rights_scope (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'Intended effective date for the renewed agreement. Typically aligns with original agreement end date to ensure continuity, but may include gap or overlap periods based on negotiation. | Column proposed_start_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renegotiationPriority rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Priority' ;
    rdfs:comment 'Business priority level for renegotiation efforts. Critical priority indicates strategic partnerships requiring executive involvement; low priority may allow standard renewal terms. | Column renegotiation_priority (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renegotiationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renegotiation Required Flag' ;
    rdfs:comment 'Indicates whether material terms must be renegotiated rather than simply renewed under existing terms. Set to true when market conditions, partner performance, or strategic priorities require substantive changes. | Column renegotiation_required_flag (BOOLEAN) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business identifier for this renewal instance. Typically follows a pattern incorporating the original agreement number plus renewal sequence (e.g., ACQ-2023-001-R02 for second renewal). | Column renewal_number (STRING) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle state of the renewal process. Tracks progression through review, negotiation, approval workflow stages, and final outcome determination. [ENUM-REF-CANDIDATE: pending_review|under_negotiation|legal_review|finance_approval|executive_approval|approved|declined|expired|cancelled — 9 candidates stripped; promote to reference product] | Column renewal_status (STRING) in partner.renewal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Evaluation of risks associated with renewal including financial exposure, rights clearance issues, regulatory compliance concerns, partner stability, and competitive threats. Informs approval requirements and contract protections. | Column risk_assessment (STRING) in partner.renewal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Assessment of the partners strategic value to the organizations content strategy, audience reach, and competitive positioning. Critical and high importance partners receive priority attention in renewal negotiations. | Column strategic_importance (STRING) in partner.renewal' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'Date when the renewal evaluation process was initiated. Typically calculated based on original agreement end date minus advance notice period (e.g., 90 days, 180 days) specified in contract terms. | Column trigger_date (DATE) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valueChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Value Change Percentage' ;
    rdfs:comment 'Percentage change between original deal value and proposed renewal value. Positive values indicate cost increases; negative values indicate cost reductions. Critical metric for financial impact assessment. | Column value_change_percentage (DECIMAL(5,2)) in partner.renewal' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerDealApprovalId rdf:type rdf:Property ;
    rdfs:label 'Partner Deal Approval Id' ;
    rdfs:comment 'Unique identifier for the deal approval record. Primary key for the deal approval workflow entity. | Column partner_deal_approval_id (BIGINT) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerSalesDealApprovalId rdf:type rdf:Property ;
    rdfs:label 'Partner Sales Deal Approval Id' ;
    rdfs:comment 'Foreign key to SSOT sales.sales_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesDealApproval .

ind:partnerSalesSalesDealApprovalId rdf:type rdf:Property ;
    rdfs:label 'Partner Sales Sales Deal Approval Id' ;
    rdfs:comment 'FK to SSOT sales.sales_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesDealApproval .

ind:submittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Approval workflow requires structured submitter tracking for audit trail and workload reporting. Has approver_employee_id FK but submitter is text fields - need FK for submission volume by employee, a | Column submitted_by_employee_id (BIGINT) in workforce.partner_deal_approval' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final determination rendered by the approver. Conditional approvals require fulfillment of specified conditions before execution. | Column approval_decision (STRING) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date after which the approval is no longer valid and must be resubmitted. Ensures approvals reflect current business conditions and deal terms. | Column approval_expiration_date (DATE) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational tier required for sign-off. Escalation level determined by deal value, risk profile, and strategic impact. | Column approval_level (STRING) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Request Number' ;
    rdfs:comment 'Business identifier for the approval request. Human-readable reference number used in communications and audit trails. | Column approval_request_number (STRING) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the deal value exceeds the monetary threshold requiring elevated approval. True triggers escalation to CFO or board per SOX authorization controls. | Column approval_threshold_exceeded_flag (BOOLEAN) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text field for additional context, clarifications, or audit annotations. Supports SOX compliance documentation and internal control testing. | Column audit_trail_notes (STRING) in partner.partner_deal_approval' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Commitment Amount' ;
    rdfs:comment 'Distribution payment obligation to Multichannel Video Programming Distributors (MVPD) or virtual Multichannel Video Programming Distributors (vMVPD). Material carriage fee agreements require CFO sign-off. | Column carriage_fee_commitment_amount (DECIMAL(18,2)) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Deal Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deal value. Required for multi-currency deal portfolio management. | Column deal_value_currency_code (STRING) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the approval decision was rendered. Critical for SOX audit trails and time-sensitive deal execution. | Column decision_timestamp (TIMESTAMP) in partner.partner_deal_approval' ;
    rdfs:domain ind:PartnerDealApproval ;
    rdf:type owl:DatatypeProperty ;
