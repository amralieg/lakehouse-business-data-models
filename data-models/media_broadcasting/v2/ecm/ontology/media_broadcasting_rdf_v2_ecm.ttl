    rdfs:domain ind:PartnerAuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Partner Response Summary' ;
    rdfs:comment 'Summary of the partners formal response to the audit findings, including their agreement, disagreement, explanations, or proposed corrective actions. | Column partner_response_summary (STRING) in partner.partner_audit_event' ;
