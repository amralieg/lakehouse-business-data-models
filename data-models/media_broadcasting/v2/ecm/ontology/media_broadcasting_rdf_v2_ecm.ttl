    rdfs:comment 'Employee\'s legal first name as it appears on government-issued identification documents. Used for payroll, tax reporting, and official HR records. | Column legal_first_name (STRING) in workforce.employee' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
