    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross margin calculated as total revenue minus total direct costs for the reporting period. | Column gross_margin_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percentage' ;
    rdfs:comment 'Gross margin expressed as a percentage of total revenue. | Column gross_margin_percentage (DECIMAL(5,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Operating expenses for marketing, advertising, and promotional activities during the reporting period. | Column marketing_expense_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
    rdfs:domain ind:EbitdaSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Other Direct Cost Amount' ;
    rdfs:comment 'Other direct costs not classified in the primary cost categories but directly attributable to revenue generation. | Column other_direct_cost_amount (DECIMAL(18,2)) in finance.ebitda_snapshot' ;
