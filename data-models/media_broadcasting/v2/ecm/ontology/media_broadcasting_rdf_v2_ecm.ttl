    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Whether corrective action is required' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstComplianceDate rdf:type rdf:Property ;
    rdfs:label 'First Compliance Date' ;
    rdfs:comment 'Date when this facility first achieved compliance with this obligation. Captures the historical start of the compliance relationship for audit trail and reporting purposes. | Column first_compliance_date (DATE) in compliance.facility_compliance' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date of last inspection' ;
    rdfs:domain ind:FacilityCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Result of inspection (pass, fail, conditional)' ;
