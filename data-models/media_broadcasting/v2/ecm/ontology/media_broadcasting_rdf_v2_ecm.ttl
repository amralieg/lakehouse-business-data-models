ind:substantiationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Substantiation Required Flag' ;
    rdfs:comment 'Indicates whether the ad creative makes claims requiring documented substantiation (e.g., scientific evidence, test results, endorsements). | Column substantiation_required_flag (BOOLEAN) in compliance.ad_standards_clearance' ;
    rdfs:domain ind:AdStandardsClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateFilePath rdf:type rdf:Property ;
    rdfs:label 'Certificate File Path' ;
    rdfs:comment 'File path or storage location of the digital certificate document. | Column certificate_file_path (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the organization or authority that issued the certification (e.g., ATSC, DVB Project, SCTE, ISO, independent testing lab). | Column certification_body (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Equipment Identifier' ;
    rdfs:comment 'Serial number, asset tag, or unique identifier of the equipment or system component being certified. | Column equipment_identifier (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'Number of non-conformance issues identified during the certification test. | Column non_conformance_count (INT) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformanceDetails rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Details' ;
    rdfs:comment 'Detailed description of any non-conformance issues, deviations, or exceptions identified during testing. | Column non_conformance_details (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which recertification must be completed to maintain compliance. | Column recertification_due_date (DATE) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Recertification Required' ;
    rdfs:comment 'Indicates whether recertification is required before the expiry date (true/false). | Column recertification_required (BOOLEAN) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific regulatory requirement or mandate that this certification fulfills (e.g., FCC Part 73, Ofcom Code). | Column regulatory_requirement (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Category of the technical standard (transmission, encoding, streaming, ad insertion, loudness normalization, accessibility, metadata, security). [ENUM-REF-CANDIDATE: transmission|encoding|streaming|ad_insertion|loudness|accessibility|metadata|security — 8 candidates stripped; promote to reference product] | Column standard_category (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the technical standard compliance test was conducted. | Column test_date (DATE) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference number or identifier of the official test report document. | Column test_report_reference (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScore rdf:type rdf:Property ;
    rdfs:label 'Test Score' ;
    rdfs:comment 'Numeric score or percentage achieved in the compliance test, if applicable. | Column test_score (DECIMAL(5,2)) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingLabName rdf:type rdf:Property ;
    rdfs:label 'Testing Lab Name' ;
    rdfs:comment 'Name of the independent testing laboratory or facility that conducted the compliance test. | Column testing_lab_name (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionSystem rdf:type rdf:Property ;
    rdfs:label 'Transmission System' ;
    rdfs:comment 'Specific transmission system or infrastructure component being certified (e.g., encoder model, playout server, CDN node, IRD). | Column transmission_system (STRING) in compliance.technical_standard_cert' ;
    rdfs:domain ind:TechnicalStandardCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCalendarId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Id' ;
    rdfs:comment 'Self-referencing FK on calendar (parent_calendar_id) | Column parent_calendar_id (BIGINT) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the compliance obligation in its lifecycle (not started, in progress, under review, completed, submitted to regulatory body, overdue, or deferred). [ENUM-REF-CANDIDATE: not_started|in_progress|under_review|completed|submitted|overdue|deferred — 7 candidates stripped; promote to reference product] | Column completion_status (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineDate rdf:type rdf:Property ;
    rdfs:label 'Deadline Date' ;
    rdfs:comment 'The final date by which the compliance obligation must be fulfilled. This is the hard deadline for regulatory submission, renewal, or completion. | Column deadline_date (DATE) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadlineDescription rdf:type rdf:Property ;
    rdfs:label 'Deadline Description' ;
    rdfs:comment 'Detailed description of the compliance deadline, including specific requirements, deliverables, and any special conditions or instructions. | Column deadline_description (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineType rdf:type rdf:Property ;
    rdfs:label 'Deadline Type' ;
    rdfs:comment 'Category of compliance deadline being tracked (filing, license renewal, audit schedule, certification expiry, reporting period, or inspection). | Column deadline_type (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationPath rdf:type rdf:Property ;
    rdfs:label 'Documentation Path' ;
    rdfs:comment 'File system path or document management system location where supporting documentation for this compliance deadline is stored. | Column documentation_path (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Defined escalation hierarchy or contact chain for at-risk deadlines (e.g., Manager → Director → VP → Chief Compliance Officer). | Column escalation_path (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'Date of the next scheduled occurrence of this recurring compliance obligation. Null for one-time obligations. | Column next_occurrence_date (DATE) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the regulatory body to this specific obligation or filing requirement. | Column obligation_reference_number (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Preparation Lead Time Days' ;
    rdfs:comment 'Number of days required in advance of the deadline to prepare, review, and submit the compliance deliverable. Used to calculate reminder triggers. | Column preparation_lead_time_days (INT) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Trigger Date' ;
    rdfs:comment 'Date when automated reminders or alerts should be sent to the responsible owner to begin preparation. Calculated as deadline_date minus preparation_lead_time_days. | Column reminder_trigger_date (DATE) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number provided by the regulatory body upon successful submission of the compliance deliverable. | Column submission_confirmation_number (STRING) in compliance.calendar' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededRegulatoryChangeId rdf:type rdf:Property ;
    rdfs:label 'Superseded Regulatory Change Id' ;
    rdfs:comment 'Self-referencing FK on regulatory_change (superseded_regulatory_change_id) | Column superseded_regulatory_change_id (BIGINT) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryChange .

ind:affectedBusinessUnits rdf:type rdf:Property ;
    rdfs:label 'Affected Business Units' ;
    rdfs:comment 'Comma-separated list of business units, departments, or divisions impacted by the regulatory change (e.g., Broadcasting Operations, Digital Platforms, Legal, Finance). | Column affected_business_units (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedObligationsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Obligations Count' ;
    rdfs:comment 'Number of existing regulatory obligations that are modified, superseded, or created by this change. | Column affected_obligations_count (INT) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this regulatory change by the compliance team or regulatory body. | Column change_number (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory change: proposed, under review, approved, effective (in force), deferred, or withdrawn. | Column change_status (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of the regulatory change\'s impact on the organization\'s operations, systems, and compliance posture: critical, high, medium, low, or minimal. | Column impact_assessment (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactDescription rdf:type rdf:Property ;
    rdfs:label 'Impact Description' ;
    rdfs:comment 'Detailed narrative describing how the regulatory change affects the organization, including operational, technical, and financial implications. | Column impact_description (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'The date when implementation was completed and the organization achieved full compliance. | Column implementation_completion_date (DATE) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Summary of the plan to implement the regulatory change, including key milestones, resource requirements, and system modifications. | Column implementation_plan (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'The date when implementation activities for this regulatory change began. | Column implementation_start_date (DATE) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the organization\'s implementation efforts: not started, planning, in progress, testing, completed, or deferred. | Column implementation_status (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The regulatory authority or governing body that issued the change (e.g., FCC, Ofcom, European Commission, MPA, ATSC). | Column issuing_body (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationCommentSubmitted rdf:type rdf:Property ;
    rdfs:label 'Organization Comment Submitted' ;
    rdfs:comment 'Indicates whether the organization submitted formal comments during the public comment period (True/False). | Column organization_comment_submitted (BOOLEAN) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Public Comment Period End' ;
    rdfs:comment 'End date of the public comment period for proposed regulatory changes, if applicable. | Column public_comment_period_end (DATE) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicCommentPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Public Comment Period Start' ;
    rdfs:comment 'Start date of the public comment period for proposed regulatory changes, if applicable. | Column public_comment_period_start (DATE) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedChanges rdf:type rdf:Property ;
    rdfs:label 'Related Changes' ;
    rdfs:comment 'Comma-separated list of related regulatory change identifiers or reference numbers that are connected to this change. | Column related_changes (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'The date when the compliance officer formally signed off on the implementation of this regulatory change. | Column sign_off_date (DATE) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersedesRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Supersedes Regulation Reference' ;
    rdfs:comment 'Reference number or identifier of the previous regulation that this change supersedes or replaces, if applicable. | Column supersedes_regulation_reference (STRING) in compliance.regulatory_change' ;
    rdfs:domain ind:RegulatoryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityComplianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Facility Compliance Obligation Id' ;
    rdfs:comment 'Unique identifier for this facility-obligation compliance tracking record. Primary key. | Column facility_compliance_obligation_id (BIGINT) in compliance.facility_compliance_obligation' ;
