ind:preventiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Taken' ;
    rdfs:comment 'Description of corrective or preventive actions implemented to avoid recurrence of similar disputes. | Column preventive_action_taken (STRING) in partner.partner_dispute' ;
    rdfs:domain ind:PartnerDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionSummary rdf:type rdf:Property ;
    rdfs:label 'Resolution Summary' ;
