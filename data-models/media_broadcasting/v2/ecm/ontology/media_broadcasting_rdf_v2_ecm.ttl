    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineupCode rdf:type rdf:Property ;
    rdfs:label 'Lineup Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the lineup within the partner\'s system (e.g., \'BASIC-01\', \'PREM-SPORTS\'). | Column lineup_code (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupName rdf:type rdf:Property ;
    rdfs:label 'Lineup Name' ;
    rdfs:comment 'Business name of the channel lineup or package (e.g., \'Basic Cable\', \'Premium Sports Tier\', \'Expanded Basic\'). | Column lineup_name (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupStatus rdf:type rdf:Property ;
    rdfs:label 'Lineup Status' ;
    rdfs:comment 'Current operational status of the channel lineup configuration. | Column lineup_status (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Geographic scope of the lineup: national (available across all markets), regional (multi-state region), local (single market), or DMA-specific (Designated Market Area). | Column market_applicability (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'Date when the promotional offering for this channel expires, after which standard pricing or availability rules apply. | Column promotional_end_date (DATE) in distribution.channel_lineup' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this channel is being offered as part of a promotional campaign or limited-time offer within the lineup. | Column promotional_flag (BOOLEAN) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriberCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count Estimate' ;
    rdfs:comment 'Estimated number of subscribers who have access to this channel through this lineup. Used for carriage fee calculation and audience reach estimation. | Column subscriber_count_estimate (INT) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the channel tier or package type offered to subscribers. [ENUM-REF-CANDIDATE: basic|expanded_basic|premium|sports|news|entertainment|international|a_la_carte — 8 candidates stripped; promote to reference product] | Column tier_type (STRING) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uhd4kAvailable rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Available' ;
    rdfs:comment 'Indicates whether the channel is available in 4K ultra high definition format within this lineup. | Column uhd_4k_available (BOOLEAN) in distribution.channel_lineup' ;
    rdfs:domain ind:ChannelLineup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodEnabled rdf:type rdf:Property ;
    rdfs:label 'Vod Enabled' ;
    rdfs:comment 'Indicates whether Video On Demand (VOD) content is available for this channel within the lineup. | Column vod_enabled (BOOLEAN) in distribution.channel_lineup' ;
