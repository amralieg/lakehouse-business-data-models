ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Target numeric value for the measured characteristic.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceLower rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower' ;
    rdfs:comment 'Maximum acceptable deviation below the target value.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpper rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper' ;
    rdfs:comment 'Maximum acceptable deviation above the target value.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ateConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Ate Configuration Id' ;
    rdfs:comment 'Foreign key linking to test.ate_configuration. Business justification: Test programs are executed on specific ATE configurations; many programs can share one configuration, so add FK from test_program to ate_configuration.' ;
    rdfs:domain ind:Test ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AteConfiguration .

ind:actualCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Actual Coverage Percent' ;
    rdfs:comment 'Measured fault-coverage achieved after program execution.' ;
