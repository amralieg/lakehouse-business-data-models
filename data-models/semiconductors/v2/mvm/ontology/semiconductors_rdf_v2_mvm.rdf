    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atePlatform rdf:type rdf:Property ;
    rdfs:label 'Ate Platform' ;
    rdfs:comment 'Automatic Test Equipment platform compatible with the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpgTool rdf:type rdf:Property ;
    rdfs:label 'Atpg Tool' ;
    rdfs:comment 'ATPG software used to generate the test vectors (e.g., Synopsys TestMAX, Mentor Tessent).' ;
