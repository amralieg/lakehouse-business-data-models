ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Each approved vendor record belongs to a single supplier; linking provides parent-child hierarchy and removes redundant supplier details that may exist in approved_vendor.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvedCommodityScope rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Scope' ;
    rdfs:comment 'List or description of material categories, chemical families, or process inputs the vendor is qualified to supply.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Status' ;
    rdfs:comment 'Overall operational status of the vendor within the enterprise.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTier rdf:type rdf:Property ;
    rdfs:label 'Quality Tier' ;
    rdfs:comment 'Internal quality classification assigned to the vendor based on performance and compliance.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the vendor\'s address.' ;
    rdfs:domain ind:ApprovedVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'Standard unit of measure used for inventory and procurement transactions (e.g., kg, L, pcs).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagement rdf:type rdf:Property ;
    rdfs:label 'Batch Management' ;
    rdfs:comment 'True if the material is managed in batches for traceability.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Classification' ;
    rdfs:comment 'Regulatory classification indicating the material\'s hazardous status under RoHS, REACH, and TSCA.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQty rdf:type rdf:Property ;
    rdfs:label 'Lot Size Qty' ;
    rdfs:comment 'Standard production or procurement lot size for the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable name or title of the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Business-visible alphanumeric code that uniquely identifies the material across the enterprise.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOrderQty rdf:type rdf:Property ;
    rdfs:label 'Max Order Qty' ;
    rdfs:comment 'Largest quantity that can be ordered in a single purchase order.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Smallest quantity that can be ordered from a supplier.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementGroup rdf:type rdf:Property ;
    rdfs:label 'Procurement Group' ;
    rdfs:comment 'Organizational group responsible for procuring the material.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'True if incoming or in-process inspection is mandatory for the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialManagement rdf:type rdf:Property ;
    rdfs:label 'Serial Management' ;
    rdfs:comment 'True if the material is tracked by serial numbers.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageHumidityMinPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Min Pct' ;
    rdfs:comment 'Lowest permissible relative humidity percentage for storage.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tscaCompliant rdf:type rdf:Property ;
    rdfs:label 'Tsca Compliant' ;
    rdfs:comment 'True if the material is compliant with the US Toxic Substances Control Act (TSCA).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryPurchaseSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Supplier Id' ;
    rdfs:comment 'Unique identifier of the supplier (vendor) to which the purchase order is issued.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Semicolon-separated list of compliance indicators (e.g., RoHS, REACH).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySchedule rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Free-text description of delivery windows or milestones.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned date for goods/services to be delivered.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Monetary cost of freight/shipping.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Responsibility for freight costs.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEarControlled rdf:type rdf:Property ;
    rdfs:label 'Is Ear Controlled' ;
    rdfs:comment 'Indicates whether the PO is subject to U.S. Export Administration Regulations.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'SAP plant code where the goods are to be received.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'External business identifier assigned to the purchase order by the procurement system.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseGroup rdf:type rdf:Property ;
    rdfs:label 'Purchase Group' ;
    rdfs:comment 'Organizational group responsible for the procurement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderType rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Type' ;
    rdfs:comment 'Classification of the PO based on its procurement strategy.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseSupplierFk rdf:type rdf:Property ;
    rdfs:label 'Purchase Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Every PO is issued TO a supplier. This is a day-1 mandatory FK.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP purchasing organization that owns the PO.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'Final payable amount after taxes, discounts, and freight.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Aggregate tax amount applied to the purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPoMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Po Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — Each PO line procures a specific material. Essential for material traceability and MRP consumption.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Order Id' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Header-line pattern: every PO line belongs to exactly one PO. Critical structural relationship.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:accountAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Code' ;
    rdfs:comment 'Identifier of the specific cost center, WBS element, or order linked to this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssignmentType rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Type' ;
    rdfs:comment 'Classification of the cost object (cost center, WBS element, or internal order).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date by which the supplier should deliver the material.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Current status of goods receipt for this line.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalInvoice rdf:type rdf:Property ;
    rdfs:label 'Is Final Invoice' ;
    rdfs:comment 'Indicates whether this line has been invoiced in its final form.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceLine rdf:type rdf:Property ;
    rdfs:label 'Is Service Line' ;
    rdfs:comment 'True if the line represents a service rather than a material.' ;
