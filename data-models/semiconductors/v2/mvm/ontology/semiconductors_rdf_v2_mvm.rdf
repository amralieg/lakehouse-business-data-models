# RDFS Schema for Business: Semiconductors

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/semiconductors#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Semiconductors ---
ind:Semiconductors rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Semiconductors' ;
    rdfs:comment 'semiconductors industry enterprise data model.' .

# --- Domain Classes ---
ind:Fabrication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Fabrication' ;
    rdfs:comment 'Core wafer fabrication and processing domain governing all FAB operations including FEOL, MOL, and BEOL process steps. Owns wafer lot tracking, WIP management, process recipe execution, and fab line scheduling across CVD, PVD, ALD, CMP, ion implantation, and EUV/DUV lithography operations. Authoritative source for wafer genealogy and lot disposition via MES integration.' .

ind:Design rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Design' ;
    rdfs:comment 'IC design and architecture lifecycle from RTL specification through GDS/GDSII tapeout. Manages IP cores, PDK libraries, EDA tool flows, DFM and DFT rule sets, logic synthesis, physical design, timing closure data, and MPW shuttle assignments. Integrates with Cadence Virtuoso, Synopsys Design Compiler, and PrimeTime for design data provenance.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative semiconductor product catalog encompassing ICs, SoCs, ASICs, FPGAs, IP cores, and discrete devices. SSOT for product specifications, SKUs, BOM, process node assignments, PPA metrics, product lifecycle status (NPI through EOL), PCN management, and LTB notifications. Integrates with PLM systems.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, account hierarchy, and relationship data. Manages OEM, fabless design house, ODM, distributor, and automotive customer profiles, contacts, segmentation, design-win engagement records, and customer qualification status. Integrates with Salesforce CRM.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Sales pipeline, opportunities, quotes, design-win campaigns, NRE agreements, pricing, and customer contracts. Manages sales territories, account assignments, forecast accuracy, revenue targets by product family, end market, and geography. Integrates with Salesforce CRM and SAP SD.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Order' ;
    rdfs:comment 'Customer orders, order fulfillment, delivery schedules, and shipment tracking. SSOT for order-to-cash lifecycle including order entry, wafer start authorizations, die bank orders, allocation, backlog management, and delivery confirmation. Manages MPW orders and production lot assignments.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Quality assurance, reliability testing, defect inspection, metrology, DPPM tracking, FMEA, and qualification programs. Manages KGD certification, yield analysis, customer quality notifications, and compliance with ISO 9001, IATF 16949, and JEDEC reliability standards. Integrates with KLA ICOS inspection systems.' .

ind:Test rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Test' ;
    rdfs:comment 'Wafer probing, die sort, final test, and reliability testing operations. Manages ATPG programs, ATE configurations, test coverage, bin mapping, test yield, parametric test data, and correlation studies between wafer-level and package-level test. Distinct from quality domain which focuses on QMS and compliance.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Semiconductor manufacturing equipment assets including lithography scanners, deposition systems, etchers, CMP tools, ATE platforms, and metrology/inspection systems. Manages equipment qualification, utilization, preventive/corrective maintenance schedules, calibration, and tool performance metrics supporting OEE.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Inventory management for WIP wafer lots, raw materials (silicon wafers, chemicals, gases, photomasks), finished goods (packaged chips), die banks, and consignment stock at OSAT partners. Tracks lot traceability, KGD status, bin classifications, shelf life, storage conditions, and inventory valuation.' .

ind:Packaging rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Packaging' ;
    rdfs:comment 'Die packaging and assembly operations covering all package types including WLCSP, InFO, CoWoS, TSV-based 3D-IC, flip-chip, wire bonding, and traditional leadframe/BGA formats. Manages OSAT partnerships, assembly process flows, substrate BOMs, package qualification, and assembly yield data.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Semiconductors ;
    rdfs:label 'Supply' ;
    rdfs:comment 'End-to-end semiconductor supply chain including supplier master data, raw material procurement, subcontractor management, OSAT vendor relationships, and inbound logistics. Owns supplier qualification records, approved vendor lists, lead time data, supply risk assessments, and material planning.' .

# --- Data Product Classes (Tables) ---
ind:FabricationWaferLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fabrication Wafer Lot' ;
    rdfs:comment 'Core master entity representing a wafer lot (batch of wafers) tracked through the FAB from wafer start to lot disposition. Authoritative source for lot identity, wafer count, lot type (production, engineering, qualification, MPW), process node, technology node, product code, priority class, WIP status, hold flags, and genealogy linkage. Sourced from Camstar MES and Applied Materials SmartFactory MES. SSOT for all WIP lot tracking across FEOL, MOL, and BEOL operations. Quality and metrology data for this lot is owned by the quality domain and referenced via cross-domain FK.' .

ind:Wafer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Wafer' ;
    rdfs:comment 'Individual silicon wafer entity within a lot, tracking wafer number, substrate type, diameter, orientation, resistivity, epitaxial layer specs, and current disposition. Enables per-wafer genealogy and yield tracking across all FAB process steps. Sourced from Camstar MES wafer tracking module.' .

ind:ProcessRecipe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Recipe' ;
    rdfs:comment 'Master record for a validated process recipe defining the exact sequence of process parameters, tool settings, gas flows, temperatures, pressures, and timing for a specific FAB operation (CVD, PVD, ALD, CMP, implant, etch, lithography). Includes recipe version history, approval status, change control reference, qualification status, and effective date range. Versioning managed within this entity via version number and effective dates. Sourced from Applied Materials SmartFactory MES recipe management and integrated with engineering change order workflow.' .

ind:ProcessStep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Individual process step definition within a process flow routing, specifying step sequence number, operation type (FEOL/MOL/BEOL), process category (lithography, etch, deposition, CMP, implant, anneal, clean, wet clean), target recipe reference, equipment class constraint, SPC control plan linkage, rework loop indicators, and step-level cycle time targets. Forms the authoritative step catalog for all FAB routing and is the granular unit of WIP tracking. Aligned with SEMI E40 process management standard for step-level definition.' .

ind:ProcessFlow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Process Flow' ;
    rdfs:comment 'Ordered sequence of process steps defining the complete manufacturing route for a product on a given technology node. Captures flow revision, node generation (e.g., 5nm, 7nm, 28nm), flow type (standard, MPW, engineering), effective dates, and approval status. SSOT for FAB routing and WIP scheduling. Aligned with SEMI E40 process management standard for flow-level routing definition.' .

ind:LotMove rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Lot Move' ;
    rdfs:comment 'Transactional record of each WIP lot movement through a process step in the FAB, capturing move-in timestamp, move-out timestamp, operator ID, equipment used, recipe executed, actual process parameters, pass/fail disposition, and quantity in/out. Core MES transaction sourced from Camstar MES and SmartFactory MES. Enables cycle time analysis and WIP genealogy.' .

ind:WaferStart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Wafer Start' ;
    rdfs:comment 'Transactional record authorizing and recording the initiation of a new wafer lot into the FAB line, capturing wafer start date, authorized quantity, product code, technology node, priority class, customer order reference, and wafer start type (production, engineering, qualification, MPW). SSOT for FAB capacity consumption and WIP entry.' .

ind:LotHold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Lot Hold' ;
    rdfs:comment 'Transactional record capturing all hold events placed on a wafer lot, including hold reason code, hold type (engineering, quality, process excursion, customer), initiating system or operator, hold placement timestamp, release timestamp, and disposition action taken. Enables hold cycle time tracking and excursion management.' .

ind:Photomask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Photomask' ;
    rdfs:comment 'Master record for photomasks (reticles) used in EUV and DUV lithography operations, capturing mask set ID, layer name, technology node, mask type (binary, PSM, EUV pellicle), OPC version, MEEF value, mask generation, pellicle status, inspection history summary, usage count, cleaning cycle count, and retirement threshold. SSOT for mask inventory, lithography step qualification, and reticle lifecycle management within the FAB.' .

ind:TechnologyNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Technology Node' ;
    rdfs:comment 'Reference master for semiconductor technology nodes supported in the FAB, capturing node name (e.g., 5nm, 7nm, 28nm, 65nm), node generation, transistor architecture (planar, FinFET, GAA), minimum feature size, metal layer count, PDK version reference, qualification status, and production readiness date. SSOT for node-level process and product classification.' .

ind:FabYieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fab Yield Record' ;
    rdfs:comment 'Transactional record capturing wafer-level and lot-level yield outcomes at key FAB inline checkpoints (post-FEOL, post-MOL, post-BEOL, pre-probe), recording gross die count, good die count, yield percentage, yield loss pareto by category (process, design, random defect, systematic), bin-level yield breakdown, and yield excursion flags. SSOT for FAB inline yield data distinct from final test yield (owned by test domain) and distinct from SPC/metrology analysis (owned by quality domain).' .

ind:FabFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Fab Facility' ;
    rdfs:comment 'Master reference table for fab_facility. Referenced by fab_facility_id.' .

ind:IcDesignProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Ic Design Project' ;
    rdfs:comment 'Master record for an IC design project lifecycle from RTL specification through GDS/GDSII tapeout. Captures project identity, target process node, design type (ASIC, SoC, FPGA), PPA targets (power budget, clock frequency, die area), tapeout milestone dates, NRE budget, design team assignments, EDA tool suite version, hierarchical block decomposition, and PLM integration references. SSOT for all design project metadata including block-level partitioning. Managed in Siemens Teamcenter PLM and Oracle Agile PLM.' .

ind:IpCore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Ip Core' ;
    rdfs:comment 'Master catalog of reusable Intellectual Property (IP) cores available for integration into IC designs. Tracks IP type (hard macro, soft IP, firm IP), function category (CPU, GPU, NPU, SerDes, PHY, memory controller, analog, RF), process node compatibility matrix, PPA characterization data, licensing terms and royalty structure, version history, silicon-proven status, EDA tool compatibility, and compliance with industry interface standards (AMBA, PCIe, USB). Sourced from internal IP library and third-party vendors (ARM, Synopsys DesignWare, Cadence Tensilica). SSOT for IP core definitions used across design projects.' .

ind:Pdk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Pdk' ;
    rdfs:comment 'Process Design Kit (PDK) master record defining the foundry-specific design rules, device models, standard cell libraries, and technology files required for IC design at a given process node. Captures PDK version, foundry name, process node (e.g., 3nm, 5nm, 7nm), SPICE model sets, DRC/LVS rule decks, layer stack definitions, and EDA tool compatibility matrix. SSOT for PDK versioning used in Cadence Virtuoso and Synopsys Design Compiler flows.' .

ind:RtlSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Rtl Specification' ;
    rdfs:comment 'Register Transfer Level (RTL) design specification and source record capturing the functional hardware description of a design block, IP subsystem, or full chip. Tracks RTL module hierarchy, HDL language (VHDL, Verilog, SystemVerilog, Chisel), design intent documentation, clock domain definitions and CDC boundary annotations, reset strategy, interface protocols (AXI, AHB, APB, Wishbone), power domain definitions (UPF/CPF), functional coverage model targets, lint rule compliance status, and linkage to the parent IC design project. For analog/mixed-signal blocks, captures behavioral model references (Verilog-AMS, VHDL-AMS) and links to transistor-level schematic source in Cadence Virtuoso where applicable. For FPGA targets, captures synthesis constraints, pin assignments, and target device family. Managed as a versioned artifact in revision control (Git, Perforce) with provenance tracking through Siemens Teamcenter PLM.' .

ind:Netlist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Netlist' ;
    rdfs:comment 'Synthesized netlist artifact produced by logic synthesis tools (Synopsys Design Compiler) from RTL. Captures netlist type (pre-synthesis, post-synthesis, post-layout), gate count, cell library version, synthesis constraints file reference, timing slack summary, power estimate, and linkage to the RTL specification and PDK version used. Tracks netlist versions across design iterations for design provenance.' .

ind:TimingAnalysisRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Timing Analysis Run' ;
    rdfs:comment 'Static Timing Analysis (STA) run record produced by Synopsys PrimeTime capturing timing closure status for a design at a specific design stage. Tracks worst negative slack (WNS), total negative slack (TNS), setup/hold violations count, operating corner (PVT), clock frequency targets, analysis mode (pre-CTS, post-CTS, post-route), and pass/fail status. Enables timing closure tracking across design iterations.' .

ind:PhysicalLayout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Physical Layout' ;
    rdfs:comment 'Physical design layout record representing the floorplan, placement, clock tree, and routing state of an IC design at a specific stage in the physical implementation flow. Captures die dimensions and core area, cell utilization percentage, routing congestion metrics by metal layer, DRC violation count and categories, LVS clean status, metal layer stack usage and fill density, power grid IR-drop analysis results, clock tree synthesis (CTS) metrics (skew, insertion delay), electromigration compliance status, antenna rule violations, and GDS/GDSII or OASIS file reference. Tracks physical design iterations from initial floorplan through final tapeout-ready layout in Cadence Innovus, Synopsys ICC2, or Siemens Aprisa. SSOT for physical design state at each iteration checkpoint.' .

ind:Tapeout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Tapeout' ;
    rdfs:comment 'Tapeout event record capturing the final design submission milestone for manufacturing. Records tapeout date, GDS/GDSII file version, mask set identifier, foundry submission reference, PDK version used, final DRC/LVS clean status, OPC/RET processing status, design sign-off checklist completion, NRE cost committed, and MPW shuttle assignment if applicable. SSOT for tapeout provenance linking design to fabrication domain.' .

ind:IpCoreUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Ip Core Usage' ;
    rdfs:comment 'Integration instance record capturing the deployment of a specific IP core version into an IC design project, with full lifecycle from selection through silicon validation. Tracks IP core version used, integration status (planned, in-progress, verified, silicon-proven), configuration parameters applied, interface connections and bus protocol mappings, timing constraints contributed to the top-level budget, physical area consumed, power contribution, licensing compliance status (royalty-bearing, perpetual, subscription), and silicon-proven flag for this design context. Enables IP reuse analytics, license compliance auditing across design projects, and IP qualification tracking. SSOT for the many-to-many relationship between IP cores and design projects.' .

ind:VerificationPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Verification Plan' ;
    rdfs:comment 'Design verification plan master record defining the pre-silicon verification strategy for an IC design project. Captures verification methodology (UVM, formal, emulation, FPGA prototyping), coverage goals (functional, code, toggle, assertion), testbench architecture, simulation environment configuration, DFT strategy (ATPG, BIST, scan chain, boundary scan), verification milestones and schedule, tool assignments, regression suite definitions, bug tracking integration, and sign-off criteria. For automotive and safety-critical designs, captures ISO 26262 functional safety verification requirements including ASIL decomposition, safety mechanism coverage targets, fault injection campaign plans, and FMEDA linkage. Ensures systematic verification coverage and regulatory compliance before tapeout.' .

ind:IcCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Ic Catalog' ;
    rdfs:comment 'Master record for all semiconductor products (ICs, SoCs, ASICs, FPGAs, discretes, licensable IP cores). SSOT for product identity, internal/external part numbers, product family assignment, process node, target market, and lifecycle state with full NPI→qualification→production→EOL transition history. Golden record integrated with PLM. Each entry represents a unique silicon design with one or more orderable SKU variants.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock-keeping unit records representing orderable, shippable variants of catalog products. Each SKU captures the specific combination of package type, speed grade, temperature range, voltage variant, and qualification level (commercial, industrial, automotive AEC-Q100/Q101) that constitutes a distinct orderable item. Links to ic_catalog for the parent product definition and to inventory for stock tracking.' .

ind:Family rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Family' ;
    rdfs:comment 'Hierarchical grouping of related IC products into product families and sub-families (e.g., Cortex-class SoCs, automotive MCU family, RF transceiver family). Manages the multi-level product taxonomy used for roadmap planning, pricing strategy, and customer design-in targeting. Supports up to five levels of hierarchy: portfolio → family → sub-family → product → variant.' .

ind:ProcessNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Process Node' ;
    rdfs:comment 'Reference master for semiconductor process technology nodes (e.g., 3nm GAA, 5nm FinFET, 7nm EUV, 28nm HKMG, 180nm BCD). Captures node name, lithography generation (EUV/DUV), foundry source, PDK version, minimum feature size, metal layer count, and qualification status. Used to assign products to manufacturing process capabilities and to track node-level yield and cost baselines.' .

ind:ProductSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Spec' ;
    rdfs:comment 'Detailed electrical, functional, and PPA (Power-Performance-Area) specifications for each IC product at given operating condition corners. Covers operating voltage range, temperature range, I/O count, interface protocols, memory configuration, security features, functional safety ratings (ISO 26262 ASIL, IEC 61508 SIL), plus target and achieved values for dynamic power, leakage power, maximum frequency, and die area. Supports multi-corner characterization and competitive PPA benchmarking.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Bill of Materials header records defining the hierarchical component structure of each IC product assembly. Captures BOM revision, effectivity dates, BOM type (engineering, manufacturing, service), approval status, and overall RoHS/REACH compliance rollup. Parent entity for bom_line detail records. Integrates with PLM and ERP systems for manufacturing execution and change management.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Line items within a product BOM, each representing a component or sub-assembly. Captures component part number, quantity per assembly, UoM, component type (die, package substrate, passive, interposer), approved substitutes, lead time, and compliance attributes (RoHS, REACH, conflict minerals). Supports multi-level BOM explosion for cost rollup and supply chain risk analysis.' .

ind:ComplianceCert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Compliance Cert' ;
    rdfs:comment 'Product compliance certification records tracking regulatory and standards certifications obtained for each product or SKU, including RoHS, REACH, TSCA, AEC-Q100/Q101, ISO 26262, IEC 61508, UL, CE, FCC, and ITAR classification. Captures certification body, certificate number, issue date, expiry date, applicable markets/regions, and re-certification trigger events. Supports export control screening and customer compliance documentation requests.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for all customer accounts in the semiconductor ecosystem, including OEMs, fabless design houses, ODMs, distributors, and automotive Tier-1 suppliers. SSOT for customer identity, legal entity name, DUNS number, account type, industry vertical, revenue tier, strategic classification, credit rating, payment terms, export control classification (EAR/ITAR), account status, preferred communication settings, packaging/labeling requirements, and Salesforce CRM account ID. Integrates with SAP S/4HANA SD module and Salesforce CRM Account object.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact persons associated with customer accounts, including design engineers, procurement managers, FAE (Field Application Engineers) counterparts, and executive sponsors. Captures full name, title, department, role type (technical, commercial, executive), email, phone, preferred communication channel, LinkedIn profile, GDPR consent status, and active/inactive status. Maps to Salesforce CRM Contact object.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child corporate hierarchy relationships between customer accounts, enabling roll-up of revenue, design-wins, and engagement metrics across global enterprise accounts. Captures parent account, child account, hierarchy level, relationship type (subsidiary, division, affiliate, distributor branch), effective date, and end date. Critical for global OEM and distributor account management.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with customer accounts and contacts, including headquarters, ship-to, bill-to, and design center locations. Captures address type, street lines, city, state/province, postal code, country (ISO 3166), region, time zone, and geolocation coordinates. Supports multi-site global accounts with multiple address records per account. Used for logistics, tax jurisdiction, and export control screening.' .

ind:DesignWin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Design Win' ;
    rdfs:comment 'Unified record tracking the full design-in lifecycle from initial registration through confirmed design-win for semiconductor products selected by customers. SSOT for the complete design-in pipeline from early registration through revenue forecasting — distinct from sales-domain opportunity records which track revenue probability and sales stage. Captures design project name, target end product/application (e.g., smartphone SoC, ADAS ECU, AI accelerator), platform generation, process node, package type, device/part number selected, design-win stage (registered, evaluating, sampling, won, lost, on-hold), registration date, design-win confirmation date, tapeout target date, production ramp date, estimated annual unit volume (AUV), estimated annual revenue, competitive displacement flag, associated distributor (if channel-sourced), FAE owner, and NRE requirements. Integrates with Salesforce CRM Opportunity. References SSOT: sales.sales_design_win' .

ind:DesignRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Design Registration' ;
    rdfs:comment 'Formal registration of a customer design project that uses a specific semiconductor product, capturing the design project name, target application, platform generation, process node, package type, design start date, tapeout target date, production target date, design registration status, and associated distributor (if applicable). Enables early pipeline visibility and NRE planning. Precedes and feeds into design_win records. References SSOT: sales.sales_design_registration' .

ind:NdaAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Nda Agreement' ;
    rdfs:comment 'Non-Disclosure Agreement records between the semiconductor company and customer accounts, capturing NDA type (mutual, one-way), execution date, expiry date, covered scope (product roadmap, process technology, pricing), signatory contacts, legal entity names, NDA status (active, expired, under renewal), and document reference ID. Required before sharing roadmap, PDK, or pre-production device information with customers.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Customer-facing credit and financial risk profile maintained by the customer domain as SSOT for customer creditworthiness assessment. Captures credit limit, credit rating (internal and external Dun & Bradstreet), payment terms (Net 30, Net 60, prepay), credit hold status, credit review date, outstanding balance, overdue amount, credit utilization percentage, currency, and credit analyst notes. Distinct from finance-domain AR aging and collections records — this product owns the customer\'s credit posture used for real-time order-to-cash credit checks. Integrates with SAP S/4HANA FI-AR (Accounts Receivable).' .

ind:PriceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Price Agreement' ;
    rdfs:comment 'Customer-specific pricing agreements and special price authorizations (SPAs) negotiated for specific part numbers. SSOT for customer-negotiated prices distinct from sales-domain standard list pricing and discount schedules. Captures agreed unit price, currency, minimum order quantity (MOQ), volume tiers, effective date, expiry date, approval chain, SPA reference number, and associated design-win or contract. These are customer-committed prices that flow into order entry — not sales pipeline pricing assumptions. Integrates with SAP S/4HANA SD pricing conditions.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Master record: Core sales opportunity tracking design-win campaigns, pipeline stages (Prospecting→Design-In→Design-Win→Production Ramp→Won/Lost), probability, and expected revenue for semiconductor IC, SoC, ASIC, and FPGA engagements. Sourced from Salesforce CRM Opportunity object. Captures end market (automotive, mobile, AI, IoT, computing), product family, target application, competitive landscape, NRE potential, design-win status, campaign grouping (campaign type, target segment, effectiveness metrics), and stage transition history for pipeline velocity analysis. SSOT for all sales pipeline activity including campaign-level aggregation for design-in programs, product launches, and competitive displacement initiatives.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Transaction record: Commercial price quotation issued to a customer or prospect for semiconductor products including ICs, packaged devices, wafer-level products, and IP licensing. Captures quoted unit price, volume tiers, lead time, validity period, incoterms, currency, and SAP SD quotation reference. Tracks quote-to-order conversion and win/loss outcomes.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Detail record: Individual line item within a sales quotation specifying a single semiconductor SKU, die, or IP core with its quoted quantity, unit price, discount, package type, lead time, and applicable pricing tier. Supports multi-line quotes covering mixed product families and end-market configurations.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Master record: Master pricing repository defining standard and customer-specific pricing for semiconductor products by product family, package type, volume tier, and end market. Supports list price, distributor price, OEM price, and spot price variants. Contains price adjustment records capturing negotiated deviations, special bids, volume rebate adjustments, design-win incentives, and distributor markdowns with adjustment type, approved deviation amount, approval authority, validity windows, and SAP SD pricing condition override references. Integrates with SAP SD condition records and Salesforce CRM pricing engine. Tracks effective dates, supersession history, and full adjustment audit trail. SSOT for all semiconductor product pricing and price deviations.' .

ind:CustomerContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Customer Contract' ;
    rdfs:comment 'Master record: Long-term commercial contract with a semiconductor customer covering supply commitments, pricing agreements, volume guarantees, last-time-buy (LTB) provisions, product change notification (PCN) obligations, and end-of-life (EOL) terms. Distinct from NRE agreements — governs ongoing product supply rather than development services. Linked to SAP SD outline agreements.' .

ind:Forecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Forecast' ;
    rdfs:comment 'Transaction record: Sales demand forecast capturing expected unit volume and revenue by product family, customer, end market, geography, and fiscal period. Supports rolling 12-month and 18-month forecast horizons used in semiconductor S&OP and wafer-start authorization processes. Tracks forecast version (commit, upside, best-case), submission date, confidence level, and variance against actuals. Integrates with SAP APO/IBP demand planning. Enables forecast accuracy KPI tracking (MAPE, bias) critical for fab capacity planning decisions.' .

ind:Booking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Booking' ;
    rdfs:comment 'Transaction record: Confirmed sales booking representing a firm customer purchase order commitment for semiconductor devices. Captures booking date, booked revenue, booked units, device part number, customer account, ship-to location, requested delivery date, backlog status, and SAP SD sales order reference. Represents the commercial booking event — distinct from shipment or invoice. SSOT for bookings-to-billings (B2B) ratio, book-to-ship analysis, and revenue waterfall reporting critical to semiconductor quarterly earnings.' .

ind:ChannelPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Channel Partner' ;
    rdfs:comment 'Master record: Authorized semiconductor sales channel partner including distributors (Arrow, Avnet, WPG), rep firms, value-added resellers (VARs), and system integrators. Captures partner type, authorized product lines, territory coverage, tier classification (authorized, preferred, elite), contract status, inventory reporting obligations (stock on hand, weeks of supply, sell-through, hub/consignment levels), and SAP SD partner function reference. SSOT for channel partner identity and distributor inventory visibility within the sales domain. Supports ship-from-stock-and-debit (SFSD) processing and price protection claim management.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order' ;
    rdfs:comment 'Master record for all customer sales orders in the semiconductor order-to-cash lifecycle. Captures order header information including customer identity, order type (standard IC, ASIC, FPGA, MPW, NRE), order date, requested delivery date, priority, incoterms, payment terms, currency, total order value, and order status. SSOT for all customer-placed orders including wafer start authorizations, die bank orders, and production lot assignments. Sourced from SAP S/4HANA SD module.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Line' ;
    rdfs:comment 'Individual line items within a customer sales order, each representing a distinct semiconductor product SKU, quantity, unit price, requested ship date, confirmed ship date, and line-level status. Captures product configuration details such as package type, speed grade, temperature range, and special handling requirements. Supports partial shipments and line-level allocation tracking. Sourced from SAP S/4HANA SD order line items.' .

ind:DeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Schedule' ;
    rdfs:comment 'Planned and confirmed delivery schedule for customer orders, capturing multiple delivery windows per order line. Records scheduled delivery date, confirmed quantity, ship-from location (fab, OSAT, warehouse), ship-to customer location, carrier, incoterms, and schedule line status. Supports rolling delivery schedules for high-volume customers with blanket orders and periodic call-offs. Sourced from SAP S/4HANA SD schedule lines.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical shipment record tracking the outbound movement of semiconductor products from origin (fab, OSAT, distribution center) to customer destination. Header captures shipment number, carrier, tracking number, ship date, estimated and actual arrival dates, package count, gross weight, HS tariff codes, export license reference, and shipment status. Line-level detail captures shipped quantity per order line, lot numbers, wafer lot IDs, package types, serial numbers, unit of measure, and inspection certificate references. Delivery confirmation section captures proof of delivery (POD) including confirmed receipt date, receiving location, confirmed quantity, customer PO reference, discrepancy flags (quantity shortage, wrong part, damaged goods), and customer signoff reference. POD receipt triggers downstream invoice release and revenue recognition. Supports multi-leg shipments, cross-border trade compliance (EAR, ITAR), RMA dispute resolution, and full traceability from order line through physical delivery. Sourced from SAP S/4HANA SD outbound delivery, carrier POD data, and customer EDI 856 ASN acknowledgements.' .

ind:ShipmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Shipment Line' ;
    rdfs:comment 'Line-level detail of a shipment record, linking specific order lines and quantities to a physical shipment. Captures shipped quantity, unit of measure, lot number, wafer lot ID, package type, serial numbers (where applicable), and inspection certificate references. Enables traceability from customer order line to physical shipment and supports RMA and quality dispute resolution.' .

ind:BacklogPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Backlog Position' ;
    rdfs:comment 'Point-in-time snapshot of open order backlog for a specific order line, capturing unshipped committed quantity, backlog value, original promise date, current commit date, and backlog aging in days. Used for backlog management, revenue forecasting, customer escalation prioritization, and quarterly book-to-bill ratio reporting. Tracks push-outs, pull-ins, and cancellations affecting committed backlog. Critical for semiconductor revenue recognition, quarterly close processes, and investor guidance on backlog coverage.' .

ind:AllocationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Allocation Record' ;
    rdfs:comment 'Inventory, capacity, and lot allocation record that reserves specific wafer lots, die bank inventory, finished goods, or fab capacity against a customer order line. Captures allocated quantity, allocation type (hard/soft), allocated lot or inventory batch, lot number, lot type (wafer lot, die lot, packaged goods lot), assignment status (tentative, confirmed, shipped), assignment date, lot-specific quality disposition notes, allocation expiry date, and priority rank. SSOT for all allocation and lot-to-order assignment decisions in the order fulfillment process. Manages constrained supply allocation across competing customer orders during supply shortages. Supports automotive (IATF 16949) and aerospace lot-level traceability requirements from order through shipment.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Rma' ;
    rdfs:comment 'RMA (Return Material Authorization) record managing customer returns of semiconductor products for quality issues, shipping damage, or end-of-life returns. Captures RMA number, return reason code, defect description, returned product and quantity, original order reference, disposition instruction (scrap, rework, credit, replacement), credit memo reference, and failure analysis request flag. SSOT for customer return workflows and DPPM tracking inputs.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Master record for a quality inspection lot representing a batch of wafers, dies, or packaged units submitted for quality inspection at any stage. Covers all inspection types: incoming material (IQC for raw wafers, chemicals, photomasks, gases, OSAT subassemblies with supplier and PO reference), in-process (FEOL, BEOL, packaging), and final outgoing. Captures lot origin, supplier ID (for IQC), inspection type, inspection stage, lot size, sampling plan parameters (AQL, sample size, acceptance/rejection numbers), inspection results, measured parameters, and disposition decision (accept, reject, hold, rework). Integrates with SAP QM and Camstar MES for lot status management and goods receipt inspection. SSOT for all quality inspection activities across the fab-to-finish flow including incoming quality control.' .

ind:DefectRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Defect Record' ;
    rdfs:comment 'Transactional record capturing individual defect events, wafer-level defect maps, and spatial bin distributions detected during wafer inspection, die sort, or final test. At the defect event level: stores defect classification code, defect coordinates (X/Y on wafer map), defect size, defect layer (FEOL/MOL/BEOL), detection method (KLA ICOS optical, e-beam, SEM), severity rating, and disposition (scrap, rework, accept). At the wafer map level: captures per-wafer die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Enables yield spatial analysis, systematic defect pattern detection (repeater analysis, cluster detection), and wafer-level bin map visualization. Integrates directly with KLA ICOS inspection system output and ATE wafer probing systems. SSOT for all defect events, spatial defect analysis, and wafer-level quality maps.' .

ind:WaferMap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Wafer Map' ;
    rdfs:comment 'Spatial defect and bin distribution map for an individual wafer within an inspection lot. Captures wafer ID, lot ID, die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Sourced from KLA ICOS and ATE wafer probing systems. Enables yield spatial analysis and systematic defect pattern detection.' .

ind:YieldRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Yield Record' ;
    rdfs:comment 'Transactional record capturing yield measurement outcomes at each quality gate: wafer probe (die sort yield), final test yield, and packaged unit yield. Stores wafer lot ID, process node, product SKU, total die count, good die count, yield percentage, bin distribution summary, yield loss category (random defect, systematic, parametric, test escape), and measurement timestamp. SSOT for yield tracking across the fab-to-finish flow.' .

ind:ReliabilityTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Reliability Test' ;
    rdfs:comment 'Master record for reliability qualification programs and individual test execution, encompassing program definition, test planning, stress test execution, and failure event tracking. At the program level: captures qualification type (new product, process change, OSAT qualification, PCN-driven), applicable standards (AEC-Q100, JEDEC JESD47, ISO 9001), qualification plan version, milestone schedule, overall qualification status, and approval authority. At the test level: captures test type (HTOL, HAST, TC, ESD, JEDEC stress tests), test conditions (temperature, voltage, humidity, duration), sample size, device type, pass/fail criteria, and individual failure details including failed unit serial number, failure time (hours), failure mode, failure analysis method (SEM, FIB, EMMI, curve trace), root cause classification, and failure mechanism (electromigration, TDDB, HCI, NBTI). SSOT for JEDEC JESD47 and AEC-Q100/Q101 qualification lifecycle from program initiation through test execution to final disposition, FIT rate calculations, and Weibull reliability modeling.' .

ind:KgdCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Kgd Certification' ;
    rdfs:comment 'Known Good Die certification record attesting that a specific die lot has passed all required electrical, parametric, and reliability screens for bare-die shipment to customers. Captures die lot ID, product part number, certification standard (JEDEC JESD49), test coverage percentage, burn-in status, parametric screen results, certification date, expiry date, certifying engineer, and customer-specific KGD requirements. Critical for advanced packaging and MCM customers.' .

ind:DppmRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Dppm Record' ;
    rdfs:comment 'Customer quality performance and communication record encompassing DPPM tracking, formal quality notifications (8D, SCAR, customer complaints), field return management, and customer-facing quality communications. Captures product part number, customer account, shipment period, total units shipped, defective units returned, DPPM value, notification type, failure description, containment actions, root cause, corrective/preventive actions, 8D report reference, response due date, and closure status. SSOT for all customer-facing quality metrics, notifications, and communications per IATF 16949 customer satisfaction monitoring. Integrates with Salesforce CRM for customer communication tracking.' .

ind:CapaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa Record' ;
    rdfs:comment 'Corrective and Preventive Action record managing the full lifecycle of a quality improvement action triggered by a defect, customer complaint, audit finding, or reliability failure. Captures problem statement, root cause analysis method (5-Why, Ishikawa, FTA), root cause description, corrective action plan, preventive action plan, implementation owner, target and actual completion dates, effectiveness verification criteria, and closure approval. Supports ISO 9001 clause 10.2 and IATF 16949 CAPA requirements.' .

ind:NonconformanceReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Nonconformance Report' ;
    rdfs:comment 'Non-Conformance Report (NCR) and quality hold management record documenting product or process deviations from specification, managing lot hold/release lifecycle, and tracking material review board dispositions. Captures NCR number, affected lot/wafer/unit range, non-conformance description, specification violated, detection point, hold type (process excursion, SPC out-of-control, customer complaint, reliability failure), hold initiation and release timestamps, hold reason, hold release conditions with approver, disposition decision (use-as-is, rework, scrap, return to supplier), material review board (MRB) decision, responsible quality engineer, required disposition actions, and financial impact assessment. SSOT for all in-process quality escapes, quality holds, MRB dispositions, and lot release management. Integrates with Camstar MES and SAP QM for lot status management.' .

ind:QualitySpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Spec' ;
    rdfs:comment 'Master record defining the quality specification for a product SKU or process step, including all acceptance criteria, parametric limits, visual inspection standards, and test coverage requirements. Captures spec version, applicable product family, process node, specification type (electrical, dimensional, visual, reliability), parameter name, nominal value, upper and lower spec limits, measurement units, and approval status. SSOT for quality acceptance criteria referenced by inspection lots and test programs.' .

ind:FailureAnalysisReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Failure Analysis Report' ;
    rdfs:comment 'Formal failure analysis report documenting the investigation of a failed device, wafer, or component. Captures FA request source (reliability test, customer return, in-process failure), sample description, analysis techniques used (SEM, FIB cross-section, EMMI, TEM, EDX), failure site location, identified failure mechanism, root cause conclusion, supporting evidence references, analyst name, and report approval status. Links to reliability_failure, nonconformance_report, and capa_record.' .

ind:ControlPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Control Plan' ;
    rdfs:comment 'Master reference table for control_plan. Referenced by control_plan_id.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master record for ATPG-generated and manually authored test programs used on ATE platforms, with full version lifecycle management. Captures program name, target device family, test type (wafer probe, die sort, final test, burn-in, SLT), ATE platform compatibility, ATPG tool used, coverage targets, and program lifecycle status. Includes version-level tracking: version number, change description, changed test flows or limits, validation status, release date, approved-by engineer, associated PCN/ECO reference, and change impact assessment. SSOT for all test program definitions and their complete evolution history across test operations.' .

ind:AteConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Ate Configuration' ;
    rdfs:comment 'Master configuration record for Automatic Test Equipment (ATE) platform setups used across wafer probe and final test operations. Captures tester model and platform type (e.g., Advantest V93000, Teradyne UltraFlex), hardware configuration revision, pin electronics card map, load board/DIB (Device Interface Board) revision and qualification status, instrument resource allocation, calibration status and due date, supported device families, maximum parallel site count, and configuration effective dates. SSOT for ATE setup definitions that test runs reference for full equipment traceability. Links to equipment domain for physical asset and maintenance tracking.' .

ind:ProbeCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Probe Card' ;
    rdfs:comment 'Master record for probe cards used in wafer probing operations, owned by test engineering for qualification, assignment, and performance tracking. Captures probe card type (cantilever, vertical, MEMS, advanced), needle/pin count, pitch, technology node compatibility, die site layout, touchdown count, maintenance cycle, current condition status, and assigned prober tool. Tracks probe card lifecycle from incoming qualification through active use to retirement, including needle replacement history and contact resistance trending. Links to equipment domain for physical asset management while test domain owns operational qualification and assignment decisions.' .

ind:BinDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Bin Definition' ;
    rdfs:comment 'Reference master defining all test bin codes used in wafer sort and final test. Captures bin number, bin name, bin category (pass, functional fail, parametric fail, contact fail, leakage fail), disposition rule (ship, scrap, rework, hold), yield impact classification, and associated failure mode. Provides standardized bin taxonomy across all test programs and device families per JEDEC and internal standards.' .

ind:WaferProbeRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Wafer Probe Run' ;
    rdfs:comment 'Transactional record capturing each wafer probing execution event. Records wafer lot ID, wafer sequence number, probe card used, ATE configuration, test program version, prober tool, start and end timestamps, total die count, pass die count, fail die count, contact yield, gross die count, and operator ID. Core operational event for wafer-level electrical test and die sort operations.' .

ind:UnitTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Unit Test Result' ;
    rdfs:comment 'Transactional record capturing individual unit-level test results from all test insertions including wafer probing, die sort, final test, and system-level test (SLT). Records unit identifier (X/Y die coordinates for wafer-level or device serial/unit position for package-level), test insertion stage discriminator, assigned hard-bin and soft-bin codes per bin_definition, pass/fail status, total test time, parametric measurement summary flags, retest indicator and retest count, KGD (Known Good Die) qualification status, multi-die/chiplet assembly position, and test temperature/voltage condition. Serves as the single source of truth for all unit-level test outcomes across the entire test flow, enabling wafer map generation, unit-level yield analysis, full lot traceability, and die-to-package correlation. Aligns with STDF PTR/FTR/MPR record concepts.' .

ind:FinalTestRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Final Test Run' ;
    rdfs:comment 'Transactional record for package-level test execution events on ATE including final test and system-level test (SLT). Captures device lot ID, package type, test type discriminator (final_test, SLT), test configuration (socket, ATE, handler, SLT board), test program version, test temperature, test time, pass/fail counts, bin distribution, power consumption (SLT), boot success (SLT), and test site count. Covers all post-packaging test operations distinct from wafer-level probing.' .

ind:ParametricMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Parametric Measurement' ;
    rdfs:comment 'Transactional record storing individual parametric test measurements captured during wafer probe and final test. Records test parameter name, measured value, lower specification limit (LSL), upper specification limit (USL), pass/fail status, measurement unit, test condition (voltage, temperature, frequency), and associated die or device result. Enables SPC analysis, parametric yield optimization, and process-test correlation studies.' .

ind:Limit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Limit' ;
    rdfs:comment 'Master record defining parametric test limits for each test parameter by device type, product revision, and test condition. Captures parameter name, LSL, USL, target value, measurement unit, test condition set, limit revision history, effective date, and approval status. SSOT for all test specification limits used across ATPG programs and ATE test flows. Supports limit change management and PCN-driven limit updates.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Case' ;
    rdfs:comment 'Master reference table for test_case. Referenced by test_case_id.' .

ind:FabTool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fab Tool' ;
    rdfs:comment 'Master record for all semiconductor manufacturing equipment assets including lithography scanners (EUV/DUV), CVD/PVD/ALD deposition systems, etch chambers, CMP tools, ion implanters, ATE platforms, and metrology/inspection systems. Authoritative SSOT for tool identity, classification, OEM specifications, process node compatibility, FAB location, install date, and asset lifecycle status. Sourced from Applied Materials SmartFactory MES and SAP S/4HANA Fixed Assets.' .

ind:ToolChamber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Chamber' ;
    rdfs:comment 'Individual process chamber or module within a multi-chamber fab tool (e.g., a CVD cluster tool with 4 deposition chambers, or an etch system with multiple etch modules). Tracks chamber-level qualification status, process recipe assignments, chamber-specific utilization, and maintenance history independently from the parent tool. Essential for chamber-level SPC and yield correlation in multi-chamber tools.' .

ind:ToolQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Qualification' ;
    rdfs:comment 'Qualification and certification records for fab tools and chambers against specific process nodes, recipes, and product families. Captures qualification type (initial qual, re-qual, process change qual), qualification protocol, pass/fail criteria, baseline metrology results, approving process engineer, and qualification validity period. A tool must be qualified before it can run production wafer lots. Sourced from Oracle Agile PLM and SmartFactory MES.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Preventive maintenance (PM) schedule master defining planned PM activities for each fab tool or chamber. Specifies PM type (daily, weekly, monthly, wafer-count-based, run-count-based), PM procedure reference, estimated downtime window, required spare parts, required technician skill level, and scheduling constraints relative to production WIP. Drives the PM work order generation cadence in SAP PM module.' .

ind:MaintenanceEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Event' ;
    rdfs:comment 'Transactional record of every maintenance activity executed on a fab tool or chamber, including preventive maintenance (PM), corrective maintenance (CM), emergency breakdown repair, engineering-driven modifications, tool upgrades/retrofits, and hardware/software modifications. Captures event type, trigger (scheduled PM, alarm, operator-reported, FDC event, ECO), start/end timestamps, actual downtime duration, root cause classification (5-why, fishbone), repair actions taken, spare parts and consumables consumed (part ID, quantity, unit cost, planned vs unplanned), technician IDs, upgrade/retrofit details (upgrade type, ECO reference, pre/post configuration, performance improvement targets, baseline change flag), and return-to-service sign-off including re-qualification requirements. SSOT for tool downtime attribution, MTTR/MTBF calculation, parts consumption tracking, upgrade history, and total cost of ownership. Sourced from SAP S/4HANA PM and SmartFactory MES.' .

ind:ToolDowntime rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Tool Downtime' ;
    rdfs:comment 'Granular downtime records for each fab tool and chamber classified per SEMI E10 equipment state model (Productive, Standby, Engineering, Scheduled Downtime, Unscheduled Downtime, Non-Scheduled). Captures state transition timestamps, downtime reason code, responsible party (maintenance, engineering, facilities, scheduling), and impact on WIP lots. Feeds OEE (Overall Equipment Effectiveness) calculation and capacity planning models.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Calibration and metrology verification records for fab tools and measurement instruments. Tracks calibration type (in-situ, offline, periodic), calibration standard used, measured vs. nominal values, calibration pass/fail result, calibration interval, next due date, calibrating technician, and traceability to NIST or SEMI standards. Mandatory for ISO 9001 and IATF 16949 compliance. Sourced from KLA ICOS and SmartFactory MES calibration modules.' .

ind:OeeRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Oee Record' ;
    rdfs:comment 'Periodic equipment productivity measurement and state tracking records for each fab tool combining SEMI E10 equipment state model data and OEE (Overall Equipment Effectiveness) metrics. Captures granular state transitions (Productive, Standby, Engineering, Scheduled Downtime, Unscheduled Downtime, Non-Scheduled), state transition timestamps, downtime reason codes, responsible party attribution (maintenance, engineering, facilities, scheduling), WIP lot impact, measurement period (shift, day, week), availability rate, performance rate, quality rate, composite OEE percentage, productive hours, available hours, idle hours, engineering hours, wafer throughput (WPH), and downtime breakdown. SSOT for all equipment state tracking, downtime attribution, productivity reporting, capacity consumption analysis, bottleneck identification, and fab scheduling inputs. Sourced from SmartFactory MES run data and OEE calculation engine.' .

ind:SparePart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Spare Part' ;
    rdfs:comment 'Master record for spare parts and consumables inventory specific to fab tool maintenance, including critical spare parts (e.g., focus rings, edge rings, quartz liners, lamp assemblies, pump kits), their OEM part numbers, compatible tool types, minimum stock levels, lead times, and storage location in the FAB stockroom. Supports PM planning and emergency repair readiness. Sourced from SAP S/4HANA MM module.' .

ind:InventoryWaferLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Wafer Lot' ;
    rdfs:comment 'Master record for a wafer lot (batch of wafers) moving through the FAB as work-in-process inventory. Tracks lot ID, wafer count, process node, product code, lot type (production/engineering/qualification), priority class, current operation step, WIP status (active/hold/complete/scrapped), start date, target completion date, hold flags, cumulative scrap count, good wafer count, and MES lot reference. SSOT for WIP lot identity and traceability across FEOL, MOL, and BEOL process stages within the inventory domain. References SSOT: fabrication.fabrication_wafer_lot' .

ind:RawMaterial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Raw Material' ;
    rdfs:comment 'Master record for raw materials consumed in semiconductor manufacturing including silicon wafers (bare and epitaxial), process chemicals, specialty gases, photomasks, CMP slurries, and ALD precursors. Captures material code, description, material class, unit of measure, supplier part number, shelf life, storage temperature range, hazard classification (RoHS/REACH), reorder point, and safety stock level. SSOT for raw material identity in the inventory domain.' .

ind:FinishedGood rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Finished Good' ;
    rdfs:comment 'Master record for packaged semiconductor finished goods held in inventory including ICs, SoCs, ASICs, FPGAs, and discrete devices in final package form. Tracks SKU, product family, package type (WLCSP, BGA, QFN, CoWoS), device marking, date code, lot traceability code, HTS classification, RoHS compliance status, ECCN number for export control, and shelf life. Links to product domain SKU catalog.' .

ind:DieBank rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Die Bank' ;
    rdfs:comment 'Master record for die bank inventory — singulated known-good dies (KGD) stored in waffle packs, gel packs, or tape-and-reel awaiting packaging or direct shipment. Tracks die bank ID, product code, process node, die revision, KGD certification status, bin classification, quantity available, storage location, storage temperature, wafer lot origin, tapeout version, and die bank creation date. Critical for fabless and OSAT-model inventory management.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master record for physical and logical storage locations within FAB cleanrooms, chemical warehouses, gas cabinets, die bank vaults, and OSAT partner facilities. Captures location code, location name, facility type (cleanroom/warehouse/cold-storage/gas-cabinet/nitrogen-cabinet/die-vault), building, bay, row, shelf, temperature range, humidity range, ESD protection class, nitrogen purge capability, hazmat classification, maximum capacity, current utilization, and location status (active/blocked/decommissioned). Enables precise inventory placement, environmental compliance tracking, and MSD floor life management.' .

ind:StockBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Balance' ;
    rdfs:comment 'Transactional snapshot of on-hand inventory quantities by material, storage location, lot, and stock type (unrestricted, quality inspection, blocked, consignment). Captures quantity on hand, quantity available (unreserved), quantity reserved (linked to active inventory_reservation records), quantity in transit, quantity in WIP, unit of measure, last physical count date, and stock aging days. Supports real-time inventory visibility, ATP calculations, and production planning decisions. Financial valuation fields are maintained in stock_valuation.' .

ind:GoodsMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Movement' ;
    rdfs:comment 'Transactional record for every inventory movement event: goods receipts from suppliers, goods issues to production, inter-location transfers, scrap disposals, returns, and posting reversals. Captures movement type, date, material, quantity, UoM, source/destination locations, reference document (PO/production order/delivery note), posting date, and document number. Provides the complete inventory audit trail required for SOX Section 404 controls, IATF 16949 traceability, and real-time stock balance updates.' .

ind:PhysicalInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Inventory' ;
    rdfs:comment 'Transactional record of physical inventory count events including cycle counts, annual wall-to-wall counts, and triggered counts (post-movement discrepancy or system exception). Captures count document number, count date, material/lot reference, storage location, system book quantity, physically counted quantity, variance quantity, variance value, count status (planned/in-progress/completed/posted), recount flag, counter ID, supervisor approval, and posting date. Supports SOX Section 404 financial controls, IATF 16949 inventory accuracy requirements, and ISO 9001 documented evidence of stock verification.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Transactional record for inventory allocation and reservation events that earmark specific quantities of WIP lots, die bank dies, raw materials, or finished goods for a designated demand source (customer order, production order, packaging run, engineering sample request). Captures reservation ID, material/lot reference, reserved quantity, UoM, demand source type and ID, reservation date, requested delivery date, priority, reservation status (active/consumed/cancelled/expired), consuming goods_movement reference, and reserving user. Enables ATP (available-to-promise) calculations, prevents double-allocation of scarce KGD inventory, and supports OSAT packaging run scheduling.' .

ind:AssemblyOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Assembly Order' ;
    rdfs:comment 'Primary transactional record for die packaging and assembly work orders issued to OSAT partners or internal assembly lines. Captures assembly order number, package type (WLCSP, InFO, CoWoS, flip-chip, wire bond, BGA, leadframe), die lot reference, substrate lot, quantity ordered, target ship date, assembly site, process flow revision, and order status lifecycle (released, in-process, completed, on-hold). SSOT for all assembly execution events in the packaging domain. Shipment logistics and delivery tracking are owned by the order domain; cost accounting is owned by the finance domain.' .

ind:PackageType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Reference master for all semiconductor package formats supported by Semiconductors, including WLCSP, InFO, CoWoS, TSV-based 3D-IC, flip-chip BGA, wire-bond QFN, leadframe DIP/QFP, and advanced heterogeneous integration formats. Stores package family, body dimensions, pin/ball count range, thermal resistance specs, moisture sensitivity level (MSL), JEDEC outline code, and qualification status. SSOT for package format classification used across assembly, product catalog, and qualification domains.' .

ind:OsatVendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Osat Vendor' ;
    rdfs:comment 'Master record for Outsourced Semiconductor Assembly and Test (OSAT) partners and internal assembly sites used by Semiconductors. Captures vendor legal name, site locations, approved package type capabilities, quality certifications (IATF 16949, ISO 9001, AEC-Q100), historical DPPM performance, capacity tiers, standard lead times, NDA/IP protection status, export control classification (EAR/ITAR), and approved/preferred/probation status. SSOT for OSAT partner identity and qualification status within the packaging domain.' .

ind:AssemblyProcessFlow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Assembly Process Flow' ;
    rdfs:comment 'Master definition of the step-by-step assembly process flow for each package type and product combination. Captures flow revision, process steps (die attach, wire bond/flip-chip bump, underfill, molding, singulation, marking, final inspection), equipment class per step, material specifications, and DFM constraints. Linked to package type and product SKU. Enables traceability from assembly order to process specification.' .

ind:SubstrateBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Substrate Bom' ;
    rdfs:comment 'Bill of Materials for packaging substrates and interposers used in advanced semiconductor packages. Captures substrate part number, layer count, core material (ABF, BT resin, silicon interposer, glass core), redistribution layer (RDL) specs, bump pitch, pad finish (ENIG, OSP, immersion tin), supplier, AVL status, unit cost reference, RoHS/REACH compliance flag, and revision history with ECO traceability. SSOT for substrate material specifications enabling procurement and assembly execution.' .

ind:AssemblyLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Assembly Lot' ;
    rdfs:comment 'Master tracking entity for an assembly lot progressing through OSAT or internal packaging operations. Captures lot number, parent wafer lot reference, die count, package type, assembly site (OSAT vendor), current process step, WIP status (queued, in-process, hold, complete), start/target/actual completion dates, cumulative yield, and hold flags. Central WIP identity that all step records, yield results, inspections, and defects reference. SSOT for assembly lot identity and real-time WIP status within the packaging domain. Equipment asset records are owned by the equipment domain; SPC charting is owned by the quality domain.' .

ind:AssemblyYield rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Assembly Yield' ;
    rdfs:comment 'Transactional record capturing assembly yield data at each major process step and at final assembly completion for each lot. Stores lot ID, process step, units in, units out, units scrapped, scrap reason codes, yield percentage, cumulative assembly yield, and DPPM. Also serves as the authoritative record for scrap quantities and loss reasons within the packaging domain. Feeds assembly yield trending, OSAT scorecard, cost of poor quality (COPQ) analysis, and product cost calculations. Distinct from wafer probe yield (owned by test domain).' .

ind:PackageQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Package Qualification' ;
    rdfs:comment 'Master record for package qualification programs executed to certify a new package type, package-product combination, or OSAT site for production release. Captures qualification plan ID, package type, product SKU, qualification standard (JEDEC JESD47, AEC-Q100/Q101, MIL-STD-883), stress test matrix (HTOL, TC, HAST, ESD, latch-up), pass/fail criteria, qualification status, and approval date. SSOT for package qualification certification.' .

ind:MaterialLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Packaging ;
    rdfs:label 'Material Lot' ;
    rdfs:comment 'Master record for incoming packaging material lots received at the assembly site, including substrates, lead frames, mold compounds, bond wires, solder paste, underfill, and marking inks. Captures material part number, supplier lot number, quantity received, incoming inspection status, Certificate of Conformance (CoC) reference, shelf life expiry, storage conditions, and quarantine/release status. SSOT for packaging-specific material lot identity and incoming quality status. General inventory management is owned by the inventory domain; supplier master data is owned by the supply domain; RoHS/REACH compliance declarations are owned by the compliance domain.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all semiconductor supply chain vendors including raw material suppliers, chemical suppliers, gas suppliers, photomask vendors, OSAT partners, and subcontractors. Captures supplier identity, classification (Tier 1/2/3), business registration, DUNS number, geographic footprint, financial health rating, strategic importance, and ITAR/EAR export control classification. SSOT for supplier identity across the supply domain. Sourced from SAP S/4HANA MM Vendor Master.' .

ind:ApprovedVendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Approved Vendor' ;
    rdfs:comment 'Approved Vendor List (AVL) records establishing which suppliers are qualified and authorized to supply specific material categories, chemical families, or process inputs to the fab. Tracks qualification status, approval date, expiry date, approved commodity scope, quality tier, and the engineering/procurement authority who granted approval. Supports DFM and process qualification gating. Sourced from Oracle Agile PLM and SAP MM.' .

ind:MaterialMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Master' ;
    rdfs:comment 'Authoritative master record for all procured materials used in semiconductor manufacturing: silicon wafer substrates, process chemicals (slurries, etchants, photoresists), specialty gases (silane, nitrogen, argon), photomasks, packaging substrates, lead frames, bonding wire, and consumables. Captures material number, description, material type, base unit of measure, hazardous material classification (RoHS/REACH/TSCA), storage conditions, shelf life, procurement lead time, safety stock levels, reorder points, and lot sizing parameters. SSOT for material identity and procurement parameters within the supply domain.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Procurement purchase orders issued to qualified suppliers for raw materials, process chemicals, gases, photomasks, equipment spare parts, and subcontracted services (OSAT assembly/test). Captures PO number, supplier, line items, ordered quantities, agreed unit price, currency, delivery schedule, Incoterms, payment terms, and export control classification (EAR/ITAR). Represents the legally binding procurement commitment. Sourced from SAP S/4HANA MM (EKKO/EKPO).' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items within a purchase order, each representing a distinct material or service being procured. Captures line number, material number, ordered quantity, unit of measure, net price, delivery date, plant/storage location destination, account assignment (cost center or WBS element), and goods receipt status. Enables granular tracking of multi-material POs and partial deliveries. Sourced from SAP S/4HANA MM (EKPO).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of materials and goods at the fab or warehouse against a purchase order. Captures GR document number, posting date, received quantity, unit of measure, storage location, batch number, quality inspection lot reference, and movement type. Triggers inventory update and initiates incoming quality inspection. Sourced from SAP S/4HANA MM (MSEG/MKPF — movement type 101).' .

ind:SupplierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Qualification' ;
    rdfs:comment 'Formal supplier qualification lifecycle records encompassing the full assessment, audit, and approval process for onboarding new suppliers or re-qualifying existing ones. Captures qualification program type (initial, periodic, change-triggered), assessment scope (quality system audit, process capability, material certification review), on-site and remote audit execution details (audit type — initial qualification, surveillance, for-cause; audit team composition; findings by severity — critical/major/minor; corrective action plans and closure tracking; overall audit rating), qualification criteria and pass/fail results, validity period, and approving engineer. SSOT for all supplier audit and qualification activity within the supply domain. Supports IATF 16949, ISO 9001, and SEMI standards supplier approval requirements.' .

ind:MaterialRequirementPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Requirement Plan' ;
    rdfs:comment 'Material Requirements Planning (MRP) run outputs defining planned procurement quantities and timing for all fab materials based on production schedules, wafer start plans, safety stock levels, and reorder points. Captures planning run date, material, plant, planned order quantity, planned delivery date, MRP type, lot sizing procedure, and exception messages (shortfall, excess, rescheduling). Sourced from SAP S/4HANA PP-MRP (MDKP/MDTB).' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Inbound logistics records tracking the physical movement of procured materials from supplier origin to fab or warehouse destination. Captures shipment number, carrier, mode of transport (air, sea, road, courier), origin country, destination plant, estimated and actual arrival dates, freight cost, customs declaration number, Incoterms, hazardous goods classification, and cold chain requirements for temperature-sensitive chemicals. Supports landed cost calculation and supply continuity monitoring.' .

ind:MaterialCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material Certification' ;
    rdfs:comment 'Supplier-originated material compliance documents including quality certifications and product change notifications. Captures Certificate of Conformance (CoC), Certificate of Analysis (CoA), RoHS compliance declarations, REACH SVHC declarations, TSCA certifications, and Product Change Notifications (PCNs). For certifications: certification type, issuing supplier, material lot number, test results, compliance standard, issue date, expiry date, and document reference. For PCNs: PCN number, supplier, affected material or component, change type (process, material, site, EOL), change description, effective date, impact assessment, required customer notification obligation, and re-qualification decision. SSOT for all supplier-originated material compliance and change documentation within the supply domain. Required for regulatory compliance, incoming quality release, process stability, and customer PCN pass-through obligations.' .

ind:LotMaskExposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fabrication ;
    rdfs:label 'Lot Mask Exposure' ;
    rdfs:comment 'This association product represents the Exposure Event between a photomask (reticle) and a fabrication wafer lot. It captures each instance where a specific photomask was used to expose a specific wafer lot at a specific process layer step. Each record links one photomask to one fabrication_wafer_lot with attributes — layer_name, exposure_count, exposure_timestamp, lot_sequence_number — that exist only in the context of this specific mask-lot exposure event and are essential for yield management, mask maintenance scheduling, and lot genealogy traceability.. Existence Justification: In semiconductor FAB operations, a photomask (reticle) is used to expose multiple wafer lots across its operational lifetime, and a single wafer lot requires multiple photomasks — one per process layer (POLY, METAL1, VIA, etc.) — as it progresses through FEOL, MOL, and BEOL lithography steps. The MES system actively tracks each mask-to-lot exposure event as an operational record for yield management, mask maintenance scheduling, and lot genealogy. This is not an analytical correlation; FAB engineers and process integration teams actively create, query, and manage these exposure records as part of daily operations.' .

ind:ProbeCardQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Test ;
    rdfs:label 'Probe Card Qualification' ;
    rdfs:comment 'This association product represents the formal Qualification event between a probe_card and an ate_configuration in semiconductor test operations. It captures the engineering qualification record that certifies a specific probe card as compatible and approved for use with a specific ATE configuration. Each record links one probe_card to one ate_configuration and carries qualification lifecycle attributes — status, date, touchdown limits, and compatibility notes — that exist only in the context of this specific pairing and cannot be stored on either parent entity.. Existence Justification: In semiconductor test operations, probe cards must be formally qualified against specific ATE configurations before production use — a probe card may be qualified for multiple ATE configurations (e.g., different tester platforms or hardware revisions), and a single ATE configuration may be qualified with multiple probe cards (e.g., different probe card types for different device families). This qualification process is a formal, actively managed engineering activity with its own lifecycle, status, and traceability data that belongs to neither the probe card nor the ATE configuration alone.' .

# --- Attribute Properties ---
ind:fabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Wafer Lot Id' ;
    rdfs:comment 'Unique identifier for the wafer lot tracked through the FAB from wafer start to lot disposition. Primary key for all WIP lot tracking across FEOL, MOL, and BEOL operations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Required for lot-level billing and customer account reporting; each wafer lot is charged to a specific customer account.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Foreign key linking to sales.booking. Business justification: Fab planners prioritize and track wafer lots against confirmed customer bookings for on-time delivery reporting and revenue recognition. A booking is the confirmed demand event that a hot lot or prior' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.control_plan. Business justification: A wafer lot is processed under a specific control plan version active at production time. IATF 16949 and customer quality agreements require lot-to-control-plan traceability for quality audits and cus' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlPlan .

ind:customerContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.customer_contract. Business justification: Wafer lots manufactured under long-term supply agreements (LTSAs) must reference the governing customer contract to validate volume commitments, technology node compliance, and PCN obligations. Fab op' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerContract .

ind:fabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Fab Facility Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fab_facility. Business justification: A wafer lot is processed at a specific fab facility. fabrication_wafer_lot currently stores fab_facility_code as a denormalized string with no FK to fab_facility. Adding fab_facility_id normalizes thi' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabFacility .

ind:icCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: Required for Production Planning Report linking each wafer lot to the specific IC catalog item being manufactured.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:icDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Ic Design Project Id' ;
    rdfs:comment 'Foreign key linking to design.ic_design_project. Business justification: Required for lot-level cost and yield reporting per design project, enabling profitability analysis and project KPI dashboards.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:parentLotFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Fabrication Wafer Lot Id' ;
    rdfs:comment 'Reference to the parent lot from which this lot was split or derived. Null for original lots. Enables wafer genealogy tracking and traceability.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:processFlowId rdf:type rdf:Property ;
    rdfs:label 'Process Flow Id' ;
    rdfs:comment 'Unique identifier for the process route (recipe sequence) assigned to this lot. Defines the complete sequence of operations from wafer start to completion.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessFlow .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Production planning and order fulfillment track wafer lots against specific SKUs (speed grade, voltage, temperature bin) to calculate commit quantities and manage process splits. Semiconductor fabs re' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:tapeoutId rdf:type rdf:Property ;
    rdfs:label 'Tapeout Id' ;
    rdfs:comment 'Foreign key linking to design.tapeout. Business justification: A wafer lot is produced from a specific tapeout\'s mask set. Foundry production tracking links lots to tapeouts for mask set identification, NRE billing, re-spin management, and export control complian' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tapeout .

ind:technologyNodeId rdf:type rdf:Property ;
    rdfs:label 'Technology Node Id' ;
    rdfs:comment 'Foreign key linking to fabrication.technology_node. Business justification: Wafer lot references a technology node; replace string column with FK to technology_node for normalization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnologyNode .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the lot completed all FAB processing operations and was dispositioned. Null for lots still in WIP.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentOperationName rdf:type rdf:Property ;
    rdfs:label 'Current Operation Name' ;
    rdfs:comment 'Descriptive name of the current process operation (e.g., CVD_OXIDE_DEP, EUV_LITHO, CMP_POLISH). Provides human-readable context for lot location.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Current Operation Number' ;
    rdfs:comment 'Sequential operation step number in the process route where the lot is currently located. Used for tracking lot position in the manufacturing flow.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentProcessArea rdf:type rdf:Property ;
    rdfs:label 'Current Process Area' ;
    rdfs:comment 'High-level FAB area classification where the lot is currently located: FEOL (front-end-of-line transistor formation), MOL (middle-of-line contacts), BEOL (back-end-of-line interconnect), metrology (inspection), or test (electrical probe).' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Days' ;
    rdfs:comment 'Total elapsed time in days from wafer start to lot completion. Key performance metric for manufacturing efficiency and customer responsiveness.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target completion date for the lot to meet customer delivery commitments. Used for scheduling and on-time-delivery tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether the lot is currently on hold and prevented from processing. True when lot is held for quality, engineering, or disposition review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for lot hold (e.g., QUAL_FAIL, ENG_REVIEW, EQUIP_DOWN, MATL_ISSUE). Null when hold_flag is false.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Timestamp' ;
    rdfs:comment 'Date and time when the lot was placed on hold. Used to calculate hold duration and impact on cycle time. Null when lot is not on hold.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initialWaferCount rdf:type rdf:Property ;
    rdfs:label 'Initial Wafer Count' ;
    rdfs:comment 'Original number of wafers when the lot was started. Used to calculate yield loss and scrap rate during processing.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHotLot rdf:type rdf:Property ;
    rdfs:label 'Is Hot Lot' ;
    rdfs:comment 'Indicates whether this lot is designated as a hot lot requiring expedited processing and priority resource allocation. True for urgent customer orders.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Created Timestamp' ;
    rdfs:comment 'Date and time when the lot record was first created in the MES system. May precede wafer start for planning purposes.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotDisposition rdf:type rdf:Property ;
    rdfs:label 'Lot Disposition' ;
    rdfs:comment 'Final disposition decision for the completed lot: pass (released to next stage), fail (rejected), partial (some wafers pass), rework (reprocess), scrap (discard), or engineering_hold (pending review).' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNotes rdf:type rdf:Property ;
    rdfs:label 'Lot Notes' ;
    rdfs:comment 'Free-text field for operators and engineers to record important observations, special handling instructions, or process deviations for this lot.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Externally-known unique business identifier for the wafer lot assigned by MES at wafer start. Used for tracking and traceability across all FAB operations and external communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOnNode rdf:type rdf:Property ;
    rdfs:label 'Lot On Node' ;
    rdfs:comment 'FK to fabrication.technology_node.technology_node_id — Every lot is manufactured on a specific technology node. This is fundamental for WIP classification and routing.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the wafer lot purpose: production (revenue-generating), engineering (process development), qualification (product validation), MPW (multi-project wafer shuttle), pilot (pre-production), or rework (reprocessed lot).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lot Updated Timestamp' ;
    rdfs:comment 'Date and time when the lot record was last modified in the MES system. Tracks most recent status or attribute change.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSystemSource rdf:type rdf:Property ;
    rdfs:label 'Mes System Source' ;
    rdfs:comment 'Identifies the source MES system that created and manages this lot record: Camstar MES, Applied Materials SmartFactory MES, or other. Used for data lineage and system integration.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Forecasted completion date based on current WIP position, remaining operations, and standard cycle times. Updated dynamically as lot progresses.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityClass rdf:type rdf:Property ;
    rdfs:label 'Priority Class' ;
    rdfs:comment 'Scheduling priority assigned to the lot for FAB resource allocation. Hot and expedite lots receive preferential processing to meet urgent customer commitments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processNodeNm rdf:type rdf:Property ;
    rdfs:label 'Process Node Nm' ;
    rdfs:comment 'Technology node of the semiconductor process measured in nanometers (e.g., 7nm, 5nm, 3nm). Defines the minimum feature size and process complexity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTimeHours rdf:type rdf:Property ;
    rdfs:label 'Process Time Hours' ;
    rdfs:comment 'Cumulative time in hours the lot has spent in active processing on equipment. Excludes queue and hold time. Used for capacity planning.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the IC product being manufactured. Used for reporting and customer communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeHours rdf:type rdf:Property ;
    rdfs:label 'Queue Time Hours' ;
    rdfs:comment 'Cumulative time in hours the lot has spent waiting in queue between operations. Excludes active processing time. Used to identify bottlenecks.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkCount rdf:type rdf:Property ;
    rdfs:label 'Rework Count' ;
    rdfs:comment 'Number of times the lot has been reworked or reprocessed through specific operations. Tracks process stability and quality issues.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeVersion rdf:type rdf:Property ;
    rdfs:label 'Route Version' ;
    rdfs:comment 'Version number of the process route. Tracks recipe changes and process improvements over time for traceability and yield analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlanCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Code' ;
    rdfs:comment 'Code identifying the quality sampling and inspection plan applied to this lot. Defines which wafers are sampled and at which operations for metrology and defect inspection.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapWaferCount rdf:type rdf:Property ;
    rdfs:label 'Scrap Wafer Count' ;
    rdfs:comment 'Total number of wafers scrapped during processing due to defects, breakage, or sampling. Used to calculate yield loss and process capability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Split Sequence Number' ;
    rdfs:comment 'Sequential number assigned when a lot is split into multiple child lots. Used with parent_lot_id to track lot genealogy and wafer provenance.' ;
    rdfs:domain ind:FabricationWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCount rdf:type rdf:Property ;
    rdfs:label 'Wafer Count' ;
    rdfs:comment 'Current number of wafers in the lot. May decrease due to scraps, breakage, or sampling during processing. Initial count typically 25 wafers per lot for standard production.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferSizeMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Size Mm' ;
    rdfs:comment 'Diameter of the silicon wafers in the lot measured in millimeters. Standard sizes include 200mm (8-inch) and 300mm (12-inch).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Timestamp' ;
    rdfs:comment 'Date and time when the wafer lot was officially started in the FAB and entered WIP tracking. Represents the beginning of the lot\'s manufacturing lifecycle.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle status of the wafer lot in the FAB workflow. Tracks lot progression from queue through processing to final disposition.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferId rdf:type rdf:Property ;
    rdfs:label 'Wafer Id' ;
    rdfs:comment 'Unique identifier for the individual silicon wafer within the fabrication facility. Primary key for wafer tracking across all FAB (Fabrication Facility) process steps.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to supply.material_master. Business justification: Individual wafer substrate traceability to the procured material master is required for RoHS/REACH compliance reporting, yield-by-material-source analysis, and semiconductor quality management. A fab ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:belongsToLot rdf:type rdf:Property ;
    rdfs:label 'Belongs To Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Every wafer must reference its parent lot. This is the most fundamental relationship in FAB WIP tracking - wafers are always tracked within the context of their lot.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Timestamp when the wafer completed all FAB (Fabrication Facility) process steps and is ready for wafer probing or shipment to OSAT (Outsourced Semiconductor Assembly and Test). Null for in-process wafers.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical defects that are likely to cause die failure. Subset of total defect count, used for yield prediction and SPC (Statistical Process Control).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crystalOrientation rdf:type rdf:Property ;
    rdfs:label 'Crystal Orientation' ;
    rdfs:comment 'Crystallographic orientation of the silicon wafer surface, specified using Miller indices. <100> is most common for CMOS (Complementary Metal-Oxide-Semiconductor) fabrication.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentProcessStep rdf:type rdf:Property ;
    rdfs:label 'Current Process Step' ;
    rdfs:comment 'Name or code of the current fabrication process step the wafer is at or has completed. Examples: lithography, CVD (Chemical Vapor Deposition), CMP (Chemical Mechanical Planarization), ion implantation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects detected on the wafer surface through inspection systems. Tracked across process steps to monitor yield and process control.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Diameter of the wafer in millimeters. Standard sizes include 150mm (6 inch), 200mm (8 inch), and 300mm (12 inch). Larger diameters enable more dies per wafer.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current disposition status of the wafer in the FAB (Fabrication Facility) workflow. Tracks lifecycle state from WIP (Work in Process) through completion or scrap.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dopingType rdf:type rdf:Property ;
    rdfs:label 'Doping Type' ;
    rdfs:comment 'Electrical doping type of the substrate. P-type (boron-doped) or N-type (phosphorus/arsenic-doped) determines the majority carrier type. Intrinsic wafers are undoped.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epitaxialLayerFlag rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Layer Flag' ;
    rdfs:comment 'Indicates whether the wafer has an epitaxial layer grown on the substrate. Epitaxial wafers have a thin crystalline layer with controlled properties for advanced device fabrication.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epitaxialResistivityOhmCm rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Resistivity Ohm Cm' ;
    rdfs:comment 'Electrical resistivity of the epitaxial layer in ohm-centimeters, if present. Null for non-epitaxial wafers. Often differs from substrate resistivity.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epitaxialThicknessUm rdf:type rdf:Property ;
    rdfs:label 'Epitaxial Thickness Um' ;
    rdfs:comment 'Thickness of the epitaxial layer in micrometers, if present. Null for non-epitaxial wafers. Typical range: 1-20 micrometers.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedDieCount rdf:type rdf:Property ;
    rdfs:label 'Expected Die Count' ;
    rdfs:comment 'Expected number of dies (individual chips) on this wafer based on die size and wafer diameter. Used for yield calculation and planning.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genealogyPath rdf:type rdf:Property ;
    rdfs:label 'Genealogy Path' ;
    rdfs:comment 'Hierarchical path tracking the wafer lineage from ingot to lot to wafer. Enables traceability for quality investigations and compliance. Format varies by MES (Manufacturing Execution System).' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodDieCount rdf:type rdf:Property ;
    rdfs:label 'Good Die Count' ;
    rdfs:comment 'Actual number of dies that passed electrical testing and quality inspection. Populated after wafer probing and testing. Used to calculate wafer yield.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Timestamp of the most recent defect inspection or metrology measurement performed on this wafer. Null if no inspection has been performed yet.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastProcessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Process Timestamp' ;
    rdfs:comment 'Timestamp of the most recent process step or operation performed on this wafer. Used for WIP (Work in Process) tracking and cycle time analysis.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notchOrientationDegrees rdf:type rdf:Property ;
    rdfs:label 'Notch Orientation Degrees' ;
    rdfs:comment 'Angular position of the wafer notch in degrees, used for wafer alignment and orientation during automated processing. Standard is 0 degrees for <110> direction.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Processing priority level for this wafer. Critical and high priority wafers receive expedited processing to meet customer commitments or TTM (Time to Market) requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this wafer record was first created in the data system. Audit field for data lineage and compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this wafer record was last updated in the data system. Audit field for data lineage and change tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resistivityOhmCm rdf:type rdf:Property ;
    rdfs:label 'Resistivity Ohm Cm' ;
    rdfs:comment 'Electrical resistivity of the wafer substrate in ohm-centimeters. Indicates doping concentration and electrical properties. Typical range: 0.001 to 100+ ohm-cm.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Code indicating the reason for wafer scrap, if applicable. Examples: excessive defects, process excursion, handling damage, contamination. Null for non-scrapped wafers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPosition rdf:type rdf:Property ;
    rdfs:label 'Slot Position' ;
    rdfs:comment 'Physical slot position of the wafer within the carrier or cassette during processing. Used for tracking and automation.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Timestamp when the wafer entered the FAB (Fabrication Facility) and began processing. Marks the beginning of the wafer lifecycle for cycle time tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substrateType rdf:type rdf:Property ;
    rdfs:label 'Substrate Type' ;
    rdfs:comment 'Material composition of the wafer substrate. Silicon is most common, but compound semiconductors like GaAs (Gallium Arsenide), SiC (Silicon Carbide), and GaN (Gallium Nitride) are used for specialized applications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thicknessUm rdf:type rdf:Property ;
    rdfs:label 'Thickness Um' ;
    rdfs:comment 'Thickness of the wafer in micrometers. Typical range is 500-800 micrometers depending on diameter and application. Critical for mechanical stability and process control.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Number' ;
    rdfs:comment 'Business identifier for the wafer within its lot. Typically a sequential number or alphanumeric code assigned during lot creation.' ;
    rdfs:domain ind:Wafer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processRecipeId rdf:type rdf:Property ;
    rdfs:label 'Process Recipe Id' ;
    rdfs:comment 'Unique identifier for the fabrication process recipe. Primary key for this entity.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessRecipe .

ind:approvedVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.approved_vendor. Business justification: Semiconductor process recipes are qualified against materials from specific approved vendors. This link enables process qualification scope management — when an approved vendor status changes or expir' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendor .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the recipe was formally approved for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Engineering approval status indicating whether the recipe has been reviewed and authorized for use by process engineering and quality teams.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the process engineer or quality manager who approved this recipe for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chamberConfiguration rdf:type rdf:Property ;
    rdfs:label 'Chamber Configuration' ;
    rdfs:comment 'Specific chamber or module configuration within the equipment where the recipe is executed, enabling multi-chamber tool recipe management.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlReference rdf:type rdf:Property ;
    rdfs:label 'Change Control Reference' ;
    rdfs:comment 'Reference to the Engineering Change Order (ECO) or Product Change Notification (PCN) that authorized the creation or modification of this recipe.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Cool Duration Seconds' ;
    rdfs:comment 'Specified cooling duration.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coolTargetTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Cool Target Temperature Celsius' ;
    rdfs:comment 'Target cooldown temperature in recipe.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantFlowRateLpm rdf:type rdf:Property ;
    rdfs:label 'Coolant Flow Rate Lpm' ;
    rdfs:comment 'Coolant flow rate in liters per minute.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantRecirculationFlag rdf:type rdf:Property ;
    rdfs:label 'Coolant Recirculation Flag' ;
    rdfs:comment 'Whether coolant is recirculated to reduce waste.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolantReclaimRatePercent rdf:type rdf:Property ;
    rdfs:label 'Coolant Reclaim Rate Percent' ;
    rdfs:comment 'Percentage of coolant reclaimed/recycled.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantRecyclingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Coolant Recycling Enabled Flag' ;
    rdfs:comment 'Whether coolant recycling (waste elimination) is enabled.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolantWasteVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Coolant Waste Volume Liters' ;
    rdfs:comment 'Volume of coolant waste generated.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cooldownRateCelsiusPerMin rdf:type rdf:Property ;
    rdfs:label 'Cooldown Rate Celsius Per Min' ;
    rdfs:comment 'Specified cooldown rate.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Cooling Duration Seconds' ;
    rdfs:comment 'Duration of the cooling stage.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingEnergyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Cooling Energy Consumption Kwh' ;
    rdfs:comment 'Energy consumed by the cooling process.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingEnergyRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Cooling Energy Recovery Flag' ;
    rdfs:comment 'Whether waste-heat / energy recovery is enabled for the recipe cooling step.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingEnergyTargetKwh rdf:type rdf:Property ;
    rdfs:label 'Cooling Energy Target Kwh' ;
    rdfs:comment 'Target cooling energy consumption.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingMedium rdf:type rdf:Property ;
    rdfs:label 'Cooling Medium' ;
    rdfs:comment 'Cooling medium used (e.g., DI water, helium backside, chilled nitrogen).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingMethod rdf:type rdf:Property ;
    rdfs:label 'Cooling Method' ;
    rdfs:comment 'Cooling method defined by the recipe.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingOptimizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cooling Optimization Enabled Flag' ;
    rdfs:comment 'Whether cooling optimization is enabled for this step/recipe.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingOptimizationMode rdf:type rdf:Property ;
    rdfs:label 'Cooling Optimization Mode' ;
    rdfs:comment 'Cooling optimization option for the recipe.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingOptimizationOption rdf:type rdf:Property ;
    rdfs:label 'Cooling Optimization Option' ;
    rdfs:comment 'Cooling optimization option applied during the recipe cooling step.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingProcessFlag rdf:type rdf:Property ;
    rdfs:label 'Cooling Process Flag' ;
    rdfs:comment 'Indicates whether this step/recipe includes a cooling process stage.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingRampRateCelsiusPerMin rdf:type rdf:Property ;
    rdfs:label 'Cooling Ramp Rate Celsius Per Min' ;
    rdfs:comment 'Controlled cooling ramp-down rate.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingStepRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cooling Step Required Flag' ;
    rdfs:comment 'Whether the recipe includes a cooling step.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolingTargetTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Cooling Target Temperature Celsius' ;
    rdfs:comment 'Target wafer/chamber temperature after cooling.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolingWasteEliminationOption rdf:type rdf:Property ;
    rdfs:label 'Cooling Waste Elimination Option' ;
    rdfs:comment 'Waste-elimination option applied during the recipe cooling step.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this recipe record was first created in the MES system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectDensityTargetPerCm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Density Target Per Cm2' ;
    rdfs:comment 'Target defect density in defects per square centimeter for wafers processed with this recipe, critical for yield management.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this recipe version is superseded or retired. Null indicates the recipe is currently active with no planned end date.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this recipe version becomes effective and available for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this recipe complies with environmental regulations including RoHS, REACH, and TSCA for chemical usage and emissions.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type or model of fabrication equipment (tool) for which this recipe is designed, such as Applied Materials Centura, Lam Research Flex, or ASML NXT scanner.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Reference to the Failure Mode and Effects Analysis (FMEA) document that identifies potential failure modes and mitigation strategies for this recipe.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gasFlowParameters rdf:type rdf:Property ;
    rdfs:label 'Gas Flow Parameters' ;
    rdfs:comment 'Detailed gas flow settings including gas types, flow rates (sccm), and ratios for CVD, PVD, ALD, and etch processes. Stored as structured text or JSON.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itarControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Itar Controlled Flag' ;
    rdfs:comment 'Boolean flag indicating whether this recipe is subject to International Traffic in Arms Regulations (ITAR) export control restrictions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this recipe record was last modified, supporting change tracking and audit requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:powerSettingsWatts rdf:type rdf:Property ;
    rdfs:label 'Power Settings Watts' ;
    rdfs:comment 'RF or DC power settings in watts for plasma-based processes such as PVD, etch, and plasma-enhanced CVD.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Process Duration Seconds' ;
    rdfs:comment 'Total duration in seconds for the recipe execution from start to completion.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processLayerType rdf:type rdf:Property ;
    rdfs:label 'Process Layer Type' ;
    rdfs:comment 'Fabrication layer classification: Front End of Line (FEOL) for transistor formation, Middle of Line (MOL) for contacts, or Back End of Line (BEOL) for interconnects.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processOperationType rdf:type rdf:Property ;
    rdfs:label 'Process Operation Type' ;
    rdfs:comment 'Type of FAB operation this recipe defines: Chemical Vapor Deposition (CVD), Physical Vapor Deposition (PVD), Atomic Layer Deposition (ALD), Chemical Mechanical Planarization (CMP), etch, lithography (EUV/DUV), ion implantation, diffusion, oxidation, annealing, or cleaning. [ENUM-REF-CANDIDATE: CVD|PVD|ALD|CMP|etch|lithography|ion_implantation|diffusion|oxidation|annealing|cleaning — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Process Pressure Torr' ;
    rdfs:comment 'Target chamber pressure in Torr for the recipe execution, critical for CVD, PVD, and ALD processes.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Celsius' ;
    rdfs:comment 'Target process temperature in degrees Celsius for the recipe execution.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Product family or IC design family for which this recipe is optimized (e.g., mobile processors, automotive chips, AI accelerators).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the recipe successfully completed qualification testing and was certified for production.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Qualification state indicating whether the recipe has passed validation testing and is certified for production use.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeCode rdf:type rdf:Property ;
    rdfs:label 'Recipe Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the recipe for system identification and traceability across MES and ERP systems.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeDescription rdf:type rdf:Property ;
    rdfs:label 'Recipe Description' ;
    rdfs:comment 'Detailed textual description of the recipes purpose, process objectives, and special considerations for operators and engineers.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeName rdf:type rdf:Property ;
    rdfs:label 'Recipe Name' ;
    rdfs:comment 'Human-readable name of the process recipe used for identification and reference by FAB operators and process engineers.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeStatus rdf:type rdf:Property ;
    rdfs:label 'Recipe Status' ;
    rdfs:comment 'Current lifecycle status of the recipe: draft (under development), under_review (pending approval), approved (validated but not yet active), active (in production use), suspended (temporarily disabled), or obsolete (retired).' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'Version identifier for the recipe enabling change control and traceability of recipe evolution over time.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which the recipe must be requalified to remain in active production status, per quality management requirements.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety classification indicating special handling requirements: standard, hazardous_material, high_temperature, high_pressure, or toxic_gas.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcControlPlanReference rdf:type rdf:Property ;
    rdfs:label 'Spc Control Plan Reference' ;
    rdfs:comment 'Reference to the Statistical Process Control (SPC) plan that monitors this recipes performance and detects process drift.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceDefinition rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Definition' ;
    rdfs:comment 'Ordered sequence of process steps within the recipe, including step names, durations, and parameter transitions. Stored as structured text or JSON.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMaterial rdf:type rdf:Property ;
    rdfs:label 'Target Material' ;
    rdfs:comment 'Material being deposited, etched, or processed by this recipe (e.g., silicon dioxide, tungsten, copper, photoresist, low-k dielectric).' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThicknessNm rdf:type rdf:Property ;
    rdfs:label 'Target Thickness Nm' ;
    rdfs:comment 'Target thickness in nanometers for deposition or remaining thickness after etch/CMP operations.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniformityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Uniformity Target Percent' ;
    rdfs:comment 'Target uniformity percentage for thickness, composition, or other critical parameters across the wafer surface.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteEliminationStrategy rdf:type rdf:Property ;
    rdfs:label 'Waste Elimination Strategy' ;
    rdfs:comment 'Waste elimination strategy (e.g., heat_recovery, coolant_reclaim, lean_idle_shutdown).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteHeatRecoveryEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Heat Recovery Enabled Flag' ;
    rdfs:comment 'Whether waste-heat recovery is enabled.' ;
    rdfs:domain ind:ProcessRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteHeatRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Heat Recovery Flag' ;
    rdfs:comment 'Whether waste heat is recovered/reused.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Target Percent' ;
    rdfs:comment 'Target yield percentage for wafers processed using this recipe, used for performance monitoring and continuous improvement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStepId rdf:type rdf:Property ;
    rdfs:label 'Process Step Id' ;
    rdfs:comment 'Unique identifier for the process step within the FAB routing. Primary key for the process step entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:reworkReturnToStepProcessStepId rdf:type rdf:Property ;
    rdfs:label 'Rework Return To Step Process Step Id' ;
    rdfs:comment 'Reference to the target process step to which lots are routed when rework is triggered from this step. Null if no rework loop exists.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStep .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Number of wafers or lots that can be processed together in a single batch at this step. Null for single-wafer processing steps.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Engineering change order or change control number associated with the creation or modification of this process step. Links to formal change management process.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingConditionReference rdf:type rdf:Property ;
    rdfs:label 'Cooling Condition Reference' ;
    rdfs:comment 'Reference code to the applicable cooling condition specification.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cooling Required Flag' ;
    rdfs:comment 'Indicates whether a cooling step is required after this process step.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Financial cost center to which this process step is allocated for cost accounting and budgeting purposes.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalStepFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Step Flag' ;
    rdfs:comment 'Boolean flag indicating whether this step is critical to product quality or yield. Critical steps require enhanced monitoring, control, and approval workflows.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Constraint specifying the class or type of equipment required to execute this process step. Used by MES for equipment qualification and dispatching.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether inline inspection or metrology is required after this step. True if inspection is mandatory before proceeding to the next step.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier of the person who last modified this process step record. Used for accountability and audit trails.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQueueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Queue Time Minutes' ;
    rdfs:comment 'Maximum allowable queue time in minutes before the step must be processed or the lot is flagged for hold. Critical for time-sensitive processes.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBatchSize rdf:type rdf:Property ;
    rdfs:label 'Min Batch Size' ;
    rdfs:comment 'Minimum number of wafers or lots required to start processing at this step. Used for batch tool optimization and scheduling.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'High-level classification of the process step into Front End of Line (FEOL), Middle of Line (MOL), or Back End of Line (BEOL) manufacturing phases.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCategory rdf:type rdf:Property ;
    rdfs:label 'Process Category' ;
    rdfs:comment 'Detailed classification of the process step by operation category such as lithography, etch, deposition (CVD/PVD/ALD), Chemical Mechanical Planarization (CMP), ion implant, thermal anneal, clean, wet clean, inspection, or metrology. [ENUM-REF-CANDIDATE: lithography|etch|deposition|CMP|implant|anneal|clean|wet_clean|inspection|metrology — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processSubcategory rdf:type rdf:Property ;
    rdfs:label 'Process Subcategory' ;
    rdfs:comment 'Granular subcategory within the process category, such as EUV lithography, DUV lithography, plasma etch, reactive ion etch, CVD, PVD, ALD, etc. Provides detailed process technology classification.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkLoopIndicator rdf:type rdf:Property ;
    rdfs:label 'Rework Loop Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this step is part of a rework loop. True if the step can route back to an earlier step for defect correction or reprocessing.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate Percent' ;
    rdfs:comment 'Percentage of lots or wafers that must be sampled for inspection or metrology at this step. Used for statistical quality control.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skipAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Allowed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this step can be skipped under certain conditions (e.g., engineering wafers, test lots). True if skip is permitted.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardQueueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Queue Time Minutes' ;
    rdfs:comment 'Expected queue time in minutes before the step begins processing. Used for scheduling and WIP prediction.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the step type across all FAB operations. Used for cross-facility consistency and reporting.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCostPerWafer rdf:type rdf:Property ;
    rdfs:label 'Step Cost Per Wafer' ;
    rdfs:comment 'Standard cost per wafer for executing this process step. Used for product costing, yield analysis, and financial planning. Business-confidential financial data.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed textual description of the process step, including purpose, key parameters, and special handling instructions for operators and engineers.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name or identifier for the process step. Used for operator reference and MES display.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'Sequential ordering of this step within the process flow routing. Determines the execution order of operations in the FAB.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle status of the process step definition. Active steps are in production use; inactive or obsolete steps are retired; engineering steps are under development; pending approval steps await qualification.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Cycle Time Minutes' ;
    rdfs:comment 'Step-level target cycle time in minutes. Used for capacity planning, scheduling, and WIP flow optimization.' ;
    rdfs:domain ind:ProcessStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version identifier for the process step definition. Incremented with each engineering change. Supports change control and traceability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Customer-specific process flows (is_customer_specific flag exists) require direct customer account linkage for IP protection, NDA compliance enforcement, and customer-specific capacity allocation repo' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Foreign key linking to product.family. Business justification: Process flows are qualified and dedicated to specific product families for NPI readiness gates, technology qualification reports, and capacity allocation decisions. The existing plain \'product_family\'' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:beolStepCount rdf:type rdf:Property ;
    rdfs:label 'Beol Step Count' ;
    rdfs:comment 'Number of process steps in the Back End Of Line (BEOL) phase covering metal interconnect layers and passivation.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental and chemical safety classification for materials and processes used in this flow (e.g., RoHS compliant, REACH registered).' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Cycle Time Days' ;
    rdfs:comment 'Estimated total manufacturing cycle time in days for a wafer lot to complete this entire process flow under normal conditions.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'Export control classification number (ECCN) or ITAR designation governing international transfer and use of this process technology.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabricationProcessFlowDescription rdf:type rdf:Property ;
    rdfs:label 'Fabrication Process Flow Description' ;
    rdfs:comment 'Detailed textual description of the process flow including its purpose, key characteristics, and intended applications.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feolStepCount rdf:type rdf:Property ;
    rdfs:label 'Feol Step Count' ;
    rdfs:comment 'Number of process steps in the Front End Of Line (FEOL) phase covering transistor formation and active device fabrication.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowCode rdf:type rdf:Property ;
    rdfs:label 'Flow Code' ;
    rdfs:comment 'Unique business identifier code for the process flow used across FAB operations and MES systems.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowName rdf:type rdf:Property ;
    rdfs:label 'Flow Name' ;
    rdfs:comment 'Human-readable name of the process flow identifying the manufacturing route.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRevision rdf:type rdf:Property ;
    rdfs:label 'Flow Revision' ;
    rdfs:comment 'Revision identifier tracking version changes to the process flow definition.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowStatus rdf:type rdf:Property ;
    rdfs:label 'Flow Status' ;
    rdfs:comment 'Current lifecycle status of the process flow indicating its approval and usage state in FAB operations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowType rdf:type rdf:Property ;
    rdfs:label 'Flow Type' ;
    rdfs:comment 'Classification of the process flow indicating its purpose: standard production, Multi-Project Wafer (MPW), engineering evaluation, qualification, or research and development (R&D).' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Customer Specific' ;
    rdfs:comment 'Boolean flag indicating whether this process flow is customized for a specific customer or represents a standard foundry offering.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lithographyTechnology rdf:type rdf:Property ;
    rdfs:label 'Lithography Technology' ;
    rdfs:comment 'Primary lithography technology used in critical patterning steps: EUV (Extreme Ultraviolet), DUV (Deep Ultraviolet), immersion, or dry lithography.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalLayerCount rdf:type rdf:Property ;
    rdfs:label 'Metal Layer Count' ;
    rdfs:comment 'Total number of metal interconnect layers defined in the BEOL portion of this process flow.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:molStepCount rdf:type rdf:Property ;
    rdfs:label 'Mol Step Count' ;
    rdfs:comment 'Number of process steps in the Middle Of Line (MOL) phase covering contact formation and local interconnect.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Date' ;
    rdfs:comment 'Date when the process flow successfully completed qualification testing and was certified for production use.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresNre rdf:type rdf:Property ;
    rdfs:label 'Requires Nre' ;
    rdfs:comment 'Boolean flag indicating whether this process flow requires Non-Recurring Engineering (NRE) investment for setup and qualification.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Target Yield Percent' ;
    rdfs:comment 'Target yield percentage (good dies per wafer) expected for wafer lots processed through this flow. Business-sensitive manufacturing performance metric.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProcessSteps rdf:type rdf:Property ;
    rdfs:label 'Total Process Steps' ;
    rdfs:comment 'Total number of discrete process steps defined in this flow spanning FEOL, MOL, and BEOL operations.' ;
    rdfs:domain ind:ProcessFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transistorArchitecture rdf:type rdf:Property ;
    rdfs:label 'Transistor Architecture' ;
    rdfs:comment 'Transistor device architecture employed in this process flow: planar MOSFET, FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), or nanosheet.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotMoveId rdf:type rdf:Property ;
    rdfs:label 'Lot Move Id' ;
    rdfs:comment 'Unique identifier for the lot move transaction. Primary key for this WIP (Work in Process) lot movement event through a FAB (Fabrication Facility) process step.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabToolId rdf:type rdf:Property ;
    rdfs:label 'Fab Tool Id' ;
    rdfs:comment 'Identifier for the FAB (Fabrication Facility) equipment or tool used to process this lot move (e.g., ATE (Automatic Test Equipment), lithography stepper, etcher, deposition chamber). Links to equipment master data.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: In MES-driven semiconductor fabs, lot moves at inspection steps directly trigger or reference an inspection lot. This is a core MES-to-QMS integration point — the lot_move records the physical step ex' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:primaryFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Fabrication Wafer Lot Id' ;
    rdfs:comment 'Unique identifier for the WIP (Work in Process) lot being moved. References the wafer lot entity tracked through the FAB (Fabrication Facility).' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:toolChamberId rdf:type rdf:Property ;
    rdfs:label 'Tool Chamber Id' ;
    rdfs:comment 'Identifier for the specific process chamber or module within the equipment used for this lot move. Relevant for multi-chamber tools (e.g., CVD (Chemical Vapor Deposition), PVD (Physical Vapor Deposition), ALD (Atomic Layer Deposition) systems).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Identifier for the manufacturing work order or production order associated with this lot move. Links to ERP (Enterprise Resource Planning) or MES (Manufacturing Execution System) work order master data.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualFlowRateSccm rdf:type rdf:Property ;
    rdfs:label 'Actual Flow Rate Sccm' ;
    rdfs:comment 'Actual gas flow rate in SCCM (Standard Cubic Centimeters per Minute) for process gases during this lot move. Critical parameter for deposition and etch processes.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Actual Power Watts' ;
    rdfs:comment 'Actual RF (Radio Frequency) or DC power in watts applied during this lot move. Critical parameter for plasma processes (etch, PVD (Physical Vapor Deposition), PECVD (Plasma-Enhanced Chemical Vapor Deposition)).' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPressureTorr rdf:type rdf:Property ;
    rdfs:label 'Actual Pressure Torr' ;
    rdfs:comment 'Actual process chamber pressure in Torr recorded during this lot move. Critical parameter for vacuum processes (PVD (Physical Vapor Deposition), CVD (Chemical Vapor Deposition), etch, implant).' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual process temperature in degrees Celsius recorded during this lot move. Critical parameter for thermal processes (CVD (Chemical Vapor Deposition), diffusion, anneal, oxidation).' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the operator or engineer regarding this lot move. Captures contextual information, issues, or special handling instructions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlJobCode rdf:type rdf:Property ;
    rdfs:label 'Control Job Code' ;
    rdfs:comment 'Identifier for the MES (Manufacturing Execution System) control job that orchestrated this lot move. Links to the higher-level job or batch execution context in Camstar MES or SmartFactory MES.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Quality disposition or pass/fail outcome of the lot move. Determines whether the lot proceeds to the next step, requires rework, is scrapped, or is placed on hold for further inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredCoolingTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Measured Cooling Temperature Celsius' ;
    rdfs:comment 'Measured temperature during/after cooling.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the measurement_value field (e.g., nm (nanometers), um (micrometers), angstrom, ohm-cm (resistivity), percent, ppm (parts per million)).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'Primary metrology measurement value captured during this lot move (e.g., film thickness, CD (Critical Dimension), overlay, resistivity). Unit of measure is context-dependent on the operation type.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moveInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Move In Timestamp' ;
    rdfs:comment 'Timestamp when the lot was moved into the process step or equipment. Marks the start of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moveOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Move Out Timestamp' ;
    rdfs:comment 'Timestamp when the lot was moved out of the process step or equipment. Marks the completion of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moveStatus rdf:type rdf:Property ;
    rdfs:label 'Move Status' ;
    rdfs:comment 'Current lifecycle status of the lot move transaction. Indicates whether the move completed successfully, is still in progress, was aborted, held for review, or skipped.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Scheduling priority level for this lot move. Hot and expedite lots receive preferential processing to meet urgent customer commitments or TTM (Time to Market) targets.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processLayer rdf:type rdf:Property ;
    rdfs:label 'Process Layer' ;
    rdfs:comment 'Manufacturing layer classification for this process step. FEOL (Front End of Line) covers transistor formation, MOL (Middle of Line) covers contacts, BEOL (Back End of Line) covers interconnects and metallization.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processModule rdf:type rdf:Property ;
    rdfs:label 'Process Module' ;
    rdfs:comment 'High-level process module category for this operation (e.g., lithography, etch, deposition, ion implantation, CMP (Chemical Mechanical Planarization), diffusion, metrology, inspection, test). [ENUM-REF-CANDIDATE: lithography|etch|deposition|implant|CMP|diffusion|metrology|inspection|test — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Process Time Seconds' ;
    rdfs:comment 'Actual processing time in seconds for this lot move, calculated as the duration between move-in and move-out timestamps. Used for cycle time analysis and equipment utilization tracking.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityIn rdf:type rdf:Property ;
    rdfs:label 'Quantity In' ;
    rdfs:comment 'Number of wafers or units in the lot at move-in. Represents the starting quantity before processing.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOut rdf:type rdf:Property ;
    rdfs:label 'Quantity Out' ;
    rdfs:comment 'Number of wafers or units in the lot at move-out. Represents the ending quantity after processing. May differ from quantity_in due to scrap, breakage, or sampling.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queueTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Queue Time Seconds' ;
    rdfs:comment 'Time in seconds the lot spent waiting in queue before move-in. Measures WIP (Work in Process) wait time and identifies bottlenecks in the FAB (Fabrication Facility) flow.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Boolean flag indicating whether this lot move is a rework operation (True) or a first-pass operation (False). Rework lots are reprocessed due to defects or out-of-spec conditions.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingFlag rdf:type rdf:Property ;
    rdfs:label 'Sampling Flag' ;
    rdfs:comment 'Boolean flag indicating whether wafers were sampled from this lot during this move (True) for destructive testing, metrology, or inspection. False if no sampling occurred.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Number of wafers or units scrapped during this lot move due to breakage, defects, or process failures. Used for yield loss tracking and DPPM (Defective Parts Per Million) calculation.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyNode rdf:type rdf:Property ;
    rdfs:label 'Technology Node' ;
    rdfs:comment 'Process technology node for this lot (e.g., 5nm, 7nm, 14nm, 28nm, 180nm). Defines the minimum feature size and process generation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tracksLot rdf:type rdf:Property ;
    rdfs:label 'Tracks Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Every lot move transaction must reference the lot being moved. Core MES transaction integrity — cannot track WIP without this FK.' ;
    rdfs:domain ind:LotMove ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferStartId rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Id' ;
    rdfs:comment 'Unique identifier for the wafer start transaction. Primary key for the wafer start record.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdFabricationWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Created Fabrication Wafer Lot Id' ;
    rdfs:comment 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: A wafer start authorization creates exactly one wafer lot in the FAB. wafer_start currently has creates_lot and start_creates_lot as BIGINT columns that semantically reference the fabrication_wafer_lo' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabricationWaferLot .

ind:designWinId rdf:type rdf:Property ;
    rdfs:label 'Design Win Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_design_win. Business justification: A wafer start is the physical execution of a customer design win authorization. This link supports design-win-to-production traceability, NRE milestone tracking, and production ramp reporting — core s' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignWin .

ind:fabricationPhotomaskId rdf:type rdf:Property ;
    rdfs:label 'Fabrication Photomask Id' ;
    rdfs:comment 'Identifier for the photomask set (reticle set) used for lithography steps in this wafer lot. Links to the physical layout and GDS data.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Photomask .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: In semiconductor foundry ops, wafer starts are authorized against a specific order line (not just the order header) to ensure the correct SKU, quantity, and spec are manufactured. This supports wafer ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:productSpecId rdf:type rdf:Property ;
    rdfs:label 'Product Spec Id' ;
    rdfs:comment 'Foreign key linking to product.product_spec. Business justification: Wafer starts are initiated against specific product specifications defining target electrical parameters, process corners, and yield requirements. NPI and production ramp workflows require traceabilit' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSpec .

ind:rawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Raw Material Id' ;
    rdfs:comment 'Foreign key linking to inventory.raw_material. Business justification: Wafer starts consume specific raw silicon wafer inventory. Linking wafer_start to raw_material enables raw material consumption tracking, goods issue posting, and substrate traceability required for p' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to order.order. Business justification: Required for Wafer Start Planning report linking each wafer start to its originating sales order, enabling traceability from order to production schedule.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Date and time when the wafer start was formally authorized in the MES system. Precedes the actual release to the FAB line.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:earClassification rdf:type rdf:Property ;
    rdfs:label 'Ear Classification' ;
    rdfs:comment 'Export Control Classification Number (ECCN) under EAR for this product. Format: 5-character code (e.g., 3A001). Null if not export-controlled.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreProjectCode rdf:type rdf:Property ;
    rdfs:label 'Nre Project Code' ;
    rdfs:comment 'Reference to the NRE project if this wafer start is part of a customer-funded development program. Used for cost tracking and milestone billing.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Number' ;
    rdfs:comment 'Lot number of the parent lot if this wafer start is a split or rework from an existing lot. Null for original starts. Enables wafer genealogy tracking.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Specific production line or bay within the FAB facility assigned to this wafer start. Determines equipment set and process capability.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Date and time when the wafer lot was physically released into the FAB line and began processing. Marks the start of cycle time measurement.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Customer-requested delivery date for finished wafers or packaged units. Drives priority and scheduling decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for any special handling instructions, process deviations, or notes that operators and engineers should be aware of for this wafer lot.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitReason rdf:type rdf:Property ;
    rdfs:label 'Split Reason' ;
    rdfs:comment 'Free-text explanation of why this lot was split from a parent lot, if applicable. Examples: process experiment, capacity balancing, quality segregation.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferQuantity rdf:type rdf:Property ;
    rdfs:label 'Wafer Quantity' ;
    rdfs:comment 'Number of wafers authorized and started in this lot. Represents the initial wafer count at FAB entry before any processing losses.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferStartDate rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Date' ;
    rdfs:comment 'Calendar date when the wafer lot was authorized and initiated into the FAB line. Principal business event timestamp for capacity planning and WIP tracking.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Number' ;
    rdfs:comment 'Business identifier for the wafer start transaction, externally visible and used for tracking and reporting. Format: WS followed by 10 digits.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Status' ;
    rdfs:comment 'Current lifecycle status of the wafer start transaction. Authorized: approved but not yet released; Released: entered FAB line; In Process: active WIP; Completed: all steps finished; Cancelled: terminated before completion; On Hold: temporarily suspended.' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartType rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Type' ;
    rdfs:comment 'Classification of the wafer start purpose: production (customer orders), engineering (process development), qualification (product validation), MPW (multi-project wafer), pilot (pre-production), or rework (reprocessing).' ;
    rdfs:domain ind:WaferStart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenter rdf:type rdf:Property ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'SAP work center code representing the initial processing area for this wafer start. Used for capacity planning and cost allocation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotHoldId rdf:type rdf:Property ;
    rdfs:label 'Lot Hold Id' ;
    rdfs:comment 'Unique identifier for the fabrication lot hold event record.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaRecordId rdf:type rdf:Property ;
    rdfs:label 'Capa Record Id' ;
    rdfs:comment 'Foreign key linking to quality.capa_record. Business justification: Lot holds placed as containment actions within a CAPA workflow must reference the governing CAPA record. IATF 16949 requires traceability of containment actions to the CAPA. Quality engineers use this' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapaRecord .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: fabrication_lot_hold explicitly models customer_notification_required and customer_notification_timestamp, requiring a specific customer contact for disposition decisions and hold notifications. Role-' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: When a material non-conformance triggers a lot hold, the NCR must reference the specific incoming goods receipt (batch/lot) that caused it. This direct traceability from production hold to incoming in' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:inventoryWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Inventory Wafer Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: When a fabrication hold is placed on a wafer lot, the corresponding inventory wafer lot record must be blocked to prevent allocation or shipment. This link supports the hold-to-inventory blocking proc' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryWaferLot .

ind:maintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Event Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_event. Business justification: Lot holds are frequently triggered by maintenance events revealing contamination or tool excursions. Linking holds to causative maintenance events is required for root cause analysis, CAPA documentati' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:nonconformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Report Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance_report. Business justification: Lot holds are initiated by or linked to NCRs documenting the quality event causing the hold. fabrication_lot_hold.ncr_number is a denormalized reference to nonconformance_report.ncr_number. Replacing ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NonconformanceReport .

ind:triggeringBinDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Bin Definition Id' ;
    rdfs:comment 'Foreign key linking to test.bin_definition. Business justification: Lot holds triggered by bin yield failures reference the specific bin definition that caused the hold. Linking enables yield-based hold disposition rules, bin-specific corrective actions, and quality r' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:triggeringParametricMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Triggering Parametric Measurement Id' ;
    rdfs:comment 'Foreign key linking to test.parametric_measurement. Business justification: fabrication_lot_hold has spc_rule_violation flag indicating holds triggered by parametric SPC excursions. Linking to the specific parametric measurement that triggered the hold is required for SPC-dri' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParametricMeasurement .

ind:triggeringWaferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Triggering Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: Lot holds are frequently triggered by wafer probe yield failures. Linking the hold to the triggering probe run enables root cause analysis, hold disposition workflows, and regulatory traceability — a ' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicator whether management or engineering approval is required before the hold can be released.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the hold release was approved.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required' ;
    rdfs:comment 'Indicator whether the customer must be notified of this hold event per contractual or quality agreement terms.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified of the hold event.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectDensityThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Defect Density Threshold Exceeded' ;
    rdfs:comment 'Indicator whether the hold was triggered by defect density exceeding acceptable limits.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Action taken upon hold release or closure (resume normal processing, rework, scrap, quarantine, return to customer, engineering review).' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting the disposition decision, corrective actions taken, or investigation findings.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicator whether the hold has been escalated to senior engineering or management for resolution.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdCycleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Hold Cycle Time Hours' ;
    rdfs:comment 'Duration in hours between hold placement and release, used for cycle time tracking and excursion management KPIs.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Timestamp' ;
    rdfs:comment 'Date and time when the hold automatically expires if not explicitly released or extended, used for time-bound holds.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdPlacementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placement Timestamp' ;
    rdfs:comment 'Date and time when the hold was placed on the lot, representing the principal business event timestamp.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Detailed textual description of the reason for the hold, providing additional context beyond the reason code.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Release Timestamp' ;
    rdfs:comment 'Date and time when the hold was released and the lot was cleared to resume processing. Null if hold is still active.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold event (active, released, cancelled, expired).' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold event by functional area or trigger source (engineering, quality, process excursion, customer, equipment, material, safety). [ENUM-REF-CANDIDATE: engineering|quality|process_excursion|customer|equipment|material|safety — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'Name or identifier of the system that triggered the hold event (e.g., MES, SPC, ATE, manual entry).' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Code' ;
    rdfs:comment 'Unique transaction identifier from the MES system that recorded this hold event.' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause determined during investigation (e.g., equipment malfunction, operator error, material defect).' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcRuleViolation rdf:type rdf:Property ;
    rdfs:label 'Spc Rule Violation' ;
    rdfs:comment 'Specific SPC rule that was violated and triggered the hold (e.g., Western Electric Rule 1, 2, 3, 4).' ;
    rdfs:domain ind:LotHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photomaskId rdf:type rdf:Property ;
    rdfs:label 'Photomask Id' ;
    rdfs:comment 'Primary key for photomask' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Photomask .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Photomask.purchase_order_number is a denormalized PO reference. Replacing with a proper FK to supply.purchase_order enables full PO lifecycle tracking for mask procurement, links mask cost to PO finan' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:qualitySpecId rdf:type rdf:Property ;
    rdfs:label 'Quality Spec Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_spec. Business justification: Photomasks must conform to quality specs for critical dimension, defect density, and registration error. The quality_spec defines acceptance criteria for mask qualification and ongoing use. Mask quali' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualitySpec .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Photomasks are high-value assets stored in specialized inventory locations (storage_location has photomask_storage_capable flag). Proper FK normalizes the existing storage_location_code plain-text col' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Ensures Photomask Supplier Traceability required by mask qualification and export control audits linking each mask to its supplier record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost paid to acquire this photomask including mask fabrication, OPC, inspection, and shipping. Denominated in USD. Used for asset valuation and depreciation.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdUniformitySpecification rdf:type rdf:Property ;
    rdfs:label 'Cd Uniformity Specification' ;
    rdfs:comment 'Maximum allowed CD variation across the mask field in nanometers (3-sigma). Tighter specifications required for advanced nodes. Typical range 1-5nm.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningCycleCount rdf:type rdf:Property ;
    rdfs:label 'Cleaning Cycle Count' ;
    rdfs:comment 'Number of times this mask has undergone wet or dry cleaning to remove particles and contamination. Excessive cleaning can damage mask patterns.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalDimensionTargetNm rdf:type rdf:Property ;
    rdfs:label 'Critical Dimension Target Nm' ;
    rdfs:comment 'Target critical dimension (minimum feature size) for this mask layer in nanometers. Used to verify mask pattern fidelity and wafer print quality.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeExposureHours rdf:type rdf:Property ;
    rdfs:label 'Cumulative Exposure Hours' ;
    rdfs:comment 'Total hours this mask has been exposed to lithography light source (EUV or DUV). Tracks photochemical degradation and pellicle aging.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeUsageCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Usage Count' ;
    rdfs:comment 'Total number of wafer exposures performed with this mask since first use. Primary metric for mask wear tracking and lifecycle management.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountLastInspection rdf:type rdf:Property ;
    rdfs:label 'Defect Count Last Inspection' ;
    rdfs:comment 'Number of defects detected during the most recent mask inspection. Tracked to monitor mask degradation and determine cleaning or retirement needs.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRetirementThreshold rdf:type rdf:Property ;
    rdfs:label 'Defect Retirement Threshold' ;
    rdfs:comment 'Maximum critical defect count allowed before mask must be retired or sent for repair. Typically 1-5 defects depending on technology node and layer criticality.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsFileChecksum rdf:type rdf:Property ;
    rdfs:label 'Gds File Checksum' ;
    rdfs:comment 'MD5 or SHA-256 checksum of the GDSII file used to generate this mask. Ensures mask-to-design traceability and detects unauthorized pattern changes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCleaningDate rdf:type rdf:Property ;
    rdfs:label 'Last Cleaning Date' ;
    rdfs:comment 'Date when the mask was last cleaned. Used to schedule preventive cleaning and correlate defect growth with cleaning intervals.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent mask inspection performed by KLA or equivalent metrology tool. Used to enforce periodic inspection schedules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:layerName rdf:type rdf:Property ;
    rdfs:label 'Layer Name' ;
    rdfs:comment 'Process layer designation for which this photomask is used (e.g., POLY, METAL1, VIA2, CONTACT). Corresponds to the GDS layer in the design database.' ;
    rdfs:domain ind:Fabrication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithographyWavelength rdf:type rdf:Property ;
    rdfs:label 'Lithography Wavelength' ;
    rdfs:comment 'Exposure wavelength for which this mask is optimized: EUV (13.5nm), DUV ArF (193nm), DUV KrF (248nm), or i-line (365nm).' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskGeneration rdf:type rdf:Property ;
    rdfs:label 'Mask Generation' ;
    rdfs:comment 'Generation number of this mask within the mask set. Incremented when a mask is replaced due to defects, pattern revisions, or wear-out. Generation 1 is the original mask.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maskSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Mask Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the mask shop vendor for traceability and warranty purposes. Engraved on the reticle substrate.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskStatus rdf:type rdf:Property ;
    rdfs:label 'Mask Status' ;
    rdfs:comment 'Current lifecycle status of the photomask: qualified (ready for production), in production (actively used), in inspection, in cleaning, in repair, quarantined (defect investigation), retired (end of life), or scrapped (disposed). [ENUM-REF-CANDIDATE: qualified|in_production|in_inspection|in_cleaning|in_repair|quarantined|retired|scrapped — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskType rdf:type rdf:Property ;
    rdfs:label 'Mask Type' ;
    rdfs:comment 'Classification of photomask technology: binary (chrome on glass), attenuated phase shift mask (PSM), alternating PSM, EUV with pellicle, EUV without pellicle, or OPC-enhanced mask.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meefValue rdf:type rdf:Property ;
    rdfs:label 'Meef Value' ;
    rdfs:comment 'Mask Error Enhancement Factor quantifying how mask pattern errors are amplified on the wafer. Higher MEEF indicates greater sensitivity to mask defects. Typical range 1.0 to 8.0.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory mask inspection. Calculated based on usage count, exposure hours, or calendar interval per mask management policy.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for recording mask-specific observations, special handling instructions, repair history, or other contextual information not captured in structured fields.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opcVersion rdf:type rdf:Property ;
    rdfs:label 'Opc Version' ;
    rdfs:comment 'Version identifier of the OPC software and recipe used to generate the mask pattern. Critical for mask-to-mask consistency and reticle enhancement technology tracking.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pellicleInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Pellicle Installation Date' ;
    rdfs:comment 'Date when the current pellicle was installed on the mask. Used to track pellicle aging and replacement cycles.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pellicleStatus rdf:type rdf:Property ;
    rdfs:label 'Pellicle Status' ;
    rdfs:comment 'Current status of the protective pellicle membrane: installed (protecting mask surface), removed (for inspection or repair), damaged (requires replacement), or not applicable (EUV masks without pellicle).' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the mask was received from the vendor and logged into the FAB inventory system. Marks the start of the masks asset lifecycle.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationErrorSpecificationNm rdf:type rdf:Property ;
    rdfs:label 'Registration Error Specification Nm' ;
    rdfs:comment 'Maximum allowed pattern placement error relative to alignment marks in nanometers. Critical for layer-to-layer overlay accuracy. Typical range 2-10nm.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the mask was retired from production due to reaching usage threshold, excessive defects, or process obsolescence. Null if mask is still active.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Primary reason for mask retirement: usage limit reached, defect limit exceeded, pattern revision required, process obsolescence, physical damage, or lost/missing.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRetirementThreshold rdf:type rdf:Property ;
    rdfs:label 'Usage Retirement Threshold' ;
    rdfs:comment 'Maximum cumulative usage count allowed before mask must be retired from production. Defined per technology node and mask type to ensure yield protection.' ;
    rdfs:domain ind:Photomask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the vendor warranty for this mask expires. After this date, repair or replacement costs are borne by the FAB.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processNodeId rdf:type rdf:Property ;
    rdfs:label 'Process Node Id' ;
    rdfs:comment 'Foreign key linking to product.process_node. Business justification: product.fabrication_technology_node and product.process_node represent the same real-world technology node from fab and product domain perspectives. Linking them enables cross-domain node reconcil' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this technology node record is currently active and available for use in manufacturing and design operations. False indicates archived or deprecated nodes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designRuleComplexity rdf:type rdf:Property ;
    rdfs:label 'Design Rule Complexity' ;
    rdfs:comment 'Complexity level of Design for Manufacturability (DFM) rules required for this node. Higher complexity nodes require more sophisticated Optical Proximity Correction (OPC) and restricted design rules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dfm Enabled Flag' ;
    rdfs:comment 'Indicates whether Design for Manufacturability (DFM) checks and optimizations are mandatory for designs targeting this node. True for advanced nodes requiring OPC, dummy fill, and restricted design rules.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dftEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dft Enabled Flag' ;
    rdfs:comment 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, ATPG patterns) are required for designs on this node. Ensures adequate test coverage for quality assurance.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eolAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Eol Announcement Date' ;
    rdfs:comment 'Date when the technology node was officially announced for end-of-life phase-out. Triggers Product Change Notification (PCN) and Last Time Buy (LTB) processes for customers.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iatf16949CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iatf16949 Certified Flag' ;
    rdfs:comment 'Indicates whether this technology node is certified under IATF 16949 Automotive Quality Management standards, required for automotive-grade semiconductor production.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the manufacturing process for this technology node is certified under ISO 9001 Quality Management System standards.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskSetCostUsd rdf:type rdf:Property ;
    rdfs:label 'Mask Set Cost Usd' ;
    rdfs:comment 'Cost of a full photomask set for this technology node in US dollars. Significant cost driver for advanced nodes using EUV lithography. Business-confidential pricing data.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFeatureSizeNm rdf:type rdf:Property ;
    rdfs:label 'Minimum Feature Size Nm' ;
    rdfs:comment 'The smallest feature dimension that can be reliably manufactured in this technology node, measured in nanometers. Critical dimension for lithography and patterning capability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Identifier of the user or system process that last modified this technology node record. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Internal alphanumeric code used to uniquely identify the technology node in manufacturing execution systems and product lifecycle management systems.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeGeneration rdf:type rdf:Property ;
    rdfs:label 'Node Generation' ;
    rdfs:comment 'Generation classification of the node (e.g., Leading Edge, Mature, Legacy). Indicates the relative maturity and market positioning of the process technology.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the technology node (e.g., 5nm, 7nm, 14nm, 28nm, 65nm, 90nm). Industry-standard designation for the process generation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nreCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Estimate Usd' ;
    rdfs:comment 'Estimated Non-Recurring Engineering (NRE) cost in US dollars for a typical design tapeout on this technology node. Includes mask set costs, design services, and qualification expenses. Business-confidential pricing data.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerPerformanceAreaRating rdf:type rdf:Property ;
    rdfs:label 'Power Performance Area Rating' ;
    rdfs:comment 'Qualitative or quantitative assessment of the node\'s Power, Performance, and Area (PPA) characteristics relative to prior generations. Critical metric for competitive positioning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowVersion rdf:type rdf:Property ;
    rdfs:label 'Process Flow Version' ;
    rdfs:comment 'Version identifier of the manufacturing process flow (sequence of FEOL, MOL, BEOL steps) defined for this technology node. Tracks process recipe evolution and engineering changes.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReadinessDate rdf:type rdf:Property ;
    rdfs:label 'Production Readiness Date' ;
    rdfs:comment 'Date when the technology node was certified as production-ready and available for high-volume manufacturing (HVM). Null if still in development or qualification.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant Flag' ;
    rdfs:comment 'Indicates whether the chemicals and materials used in this technology node comply with EU REACH Regulation for chemical safety and substance registration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rohsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant Flag' ;
    rdfs:comment 'Indicates whether the manufacturing process for this technology node complies with EU RoHS Directive restrictions on hazardous substances (lead, mercury, cadmium, etc.).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedApplicationTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Application Types' ;
    rdfs:comment 'Comma-separated list of target application domains optimized for this node (e.g., Mobile, Automotive, AI/ML, IoT, High-Performance Computing, Networking). Guides product design-in decisions.' ;
    rdfs:domain ind:TechnologyNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabYieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Fab Yield Record Id' ;
    rdfs:comment 'Unique identifier for the FAB yield record. Primary key for this transactional yield capture event.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Bin Definition Id' ;
    rdfs:comment 'Foreign key linking to test.bin_definition. Business justification: Yield records track bin-level die counts (bin_1_die_count, bin_2_die_count, bin_3_die_count). Linking to bin_definition enables structured yield analysis by bin category, disposition rules, and yield ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:physicalLayoutId rdf:type rdf:Property ;
    rdfs:label 'Physical Layout Id' ;
    rdfs:comment 'Foreign key linking to design.physical_layout. Business justification: DFM yield correlation analysis links yield data to physical layout attributes (metal density, routing congestion, cell utilization) to identify layout-induced yield loss. This is a standard semiconduc' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalLayout .

ind:primaryFabWaferId rdf:type rdf:Property ;
    rdfs:label 'Primary Fab Wafer Id' ;
    rdfs:comment 'Reference to the specific wafer for which yield is being recorded. Links to the wafer master record in the fabrication domain.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wafer .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Yield records are generated by specific test programs. Knowing which test program produced the yield data is essential for yield learning, test program optimization, and correlating test program versi' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:waferProbeRunId rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Run Id' ;
    rdfs:comment 'Foreign key linking to test.wafer_probe_run. Business justification: Fab yield records are directly populated from wafer probe run results. Referencing the probe run that generated the yield data is essential for yield learning, excursion investigation, and audit trace' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferProbeRun .

ind:bin1DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 1 Die Count' ;
    rdfs:comment 'Number of die classified into bin 1 (typically highest quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin2DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 2 Die Count' ;
    rdfs:comment 'Number of die classified into bin 2 (typically second-tier quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bin3DieCount rdf:type rdf:Property ;
    rdfs:label 'Bin 3 Die Count' ;
    rdfs:comment 'Number of die classified into bin 3 (typically third-tier quality/performance bin). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binYield rdf:type rdf:Property ;
    rdfs:label 'Bin Yield' ;
    rdfs:comment 'Bin yield percentage' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointCode rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Code' ;
    rdfs:comment 'The FAB inline checkpoint at which this yield measurement was captured. Distinguishes FEOL, MOL, BEOL, and pre-probe stages. [ENUM-REF-CANDIDATE: POST_FEOL|POST_MOL|POST_BEOL|PRE_PROBE|POST_CMP|POST_LITHO|POST_ETCH|POST_IMPLANT|INLINE_INSPECTION — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlLimitLower rdf:type rdf:Property ;
    rdfs:label 'Control Limit Lower' ;
    rdfs:comment 'Lower control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Control Limit Upper' ;
    rdfs:comment 'Upper control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectRate rdf:type rdf:Property ;
    rdfs:label 'Defect Rate' ;
    rdfs:comment 'Defect rate per wafer as a decimal ratio' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designLossDieCount rdf:type rdf:Property ;
    rdfs:label 'Design Loss Die Count' ;
    rdfs:comment 'Number of die lost due to design-related issues (DFM violations, timing failures, functional failures). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Excursion Severity Level' ;
    rdfs:comment 'Severity classification of the yield excursion event. Determines escalation path and response urgency.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossDieCount rdf:type rdf:Property ;
    rdfs:label 'Gross Die Count' ;
    rdfs:comment 'Total number of die on the wafer before yield screening. Represents the theoretical maximum die count based on wafer size and die layout.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The date and time when the yield measurement was captured at the inline checkpoint. Represents the business event time of the yield observation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processLossDieCount rdf:type rdf:Property ;
    rdfs:label 'Process Loss Die Count' ;
    rdfs:comment 'Number of die lost due to process-related defects (CVD, PVD, ALD, CMP, etch, implant issues). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomDefectDieCount rdf:type rdf:Property ;
    rdfs:label 'Random Defect Die Count' ;
    rdfs:comment 'Number of die lost due to random defects (particles, contamination, handling damage). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectBinDieCount rdf:type rdf:Property ;
    rdfs:label 'Reject Bin Die Count' ;
    rdfs:comment 'Number of die classified into reject bins (failed die that do not meet minimum specifications). Part of bin-level yield breakdown.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapFlag rdf:type rdf:Property ;
    rdfs:label 'Scrap Flag' ;
    rdfs:comment 'Boolean indicator that this wafer should be scrapped based on yield results. Triggers scrap disposition and cost accounting.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationLimitLower rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Lower' ;
    rdfs:comment 'Lower specification limit for yield percentage at this checkpoint. Represents minimum acceptable yield threshold.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systematicDefectDieCount rdf:type rdf:Property ;
    rdfs:label 'Systematic Defect Die Count' ;
    rdfs:comment 'Number of die lost due to systematic defects (OPC errors, MEEF issues, lithography hotspots). Part of yield loss pareto analysis.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Yield Excursion Flag' ;
    rdfs:comment 'Boolean indicator that this yield record represents an excursion event (yield below control limits or specification). Triggers root cause analysis and corrective action.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldForLot rdf:type rdf:Property ;
    rdfs:label 'Yield For Lot' ;
    rdfs:comment 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Yield records are captured at lot level at key FAB checkpoints.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Calculated yield percentage at this checkpoint (good_die_count / gross_die_count * 100). Primary yield metric for FAB inline performance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRate rdf:type rdf:Property ;
    rdfs:label 'Yield Rate' ;
    rdfs:comment 'Yield rate as a decimal ratio' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRecordForLot rdf:type rdf:Property ;
    rdfs:label 'Yield Record For Lot' ;
    rdfs:comment 'FK to fabrication.wafer_lot.wafer_lot_id — Yield records reference the lot measured. Required for lot-level yield tracking and excursion detection.' ;
    rdfs:domain ind:FabYieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentFabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Parent Fab Facility Id' ;
    rdfs:comment 'Self-referencing FK on fab_facility (parent_fab_facility_id)' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabFacility .

ind:capacityWaferPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Wafer Per Month' ;
    rdfs:comment 'Maximum number of wafers the facility can process in a calendar month.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonFootprintKgco2e rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kgco2e' ;
    rdfs:comment 'Monthly greenhouse-gas emissions expressed in kilograms CO₂ equivalent.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the facility is located.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanroomClass rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Class' ;
    rdfs:comment 'ISO cleanroom classification of the facility\'s most stringent environment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance standing with regulatory and industry standards.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for facility communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for facility communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the facility location.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Free-form description of the facility\'s capabilities and role.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the facility ceased operations (null if still active).' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Mwh' ;
    rdfs:comment 'Average monthly energy consumption measured in megawatt-hours.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCertifications rdf:type rdf:Property ;
    rdfs:label 'Environmental Certifications' ;
    rdfs:comment 'Comma-separated list of environmental certifications (e.g., ISO 14001).' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSummary rdf:type rdf:Property ;
    rdfs:label 'Equipment Summary' ;
    rdfs:comment 'Free-text summary of key equipment types and models present.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fabAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Fab Area Sqft' ;
    rdfs:comment 'Total usable floor area of the fab in square feet.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'External business code or identifier used to reference the facility in enterprise systems.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Human-readable name of the fabrication facility.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Category of the facility based on its primary function.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude of the facility (decimal degrees).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle stage of the facility.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithographyType rdf:type rdf:Property ;
    rdfs:label 'Lithography Type' ;
    rdfs:comment 'Primary lithography technology employed at the fab.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Location Address Line1' ;
    rdfs:comment 'Primary street address of the facility.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Location Address Line2' ;
    rdfs:comment 'Secondary address information (suite, building, etc.).' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude of the facility (decimal degrees).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window' ;
    rdfs:comment 'Typical time window (e.g., weekly, monthly) allocated for planned maintenance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the person responsible for overall facility management.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDue rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due' ;
    rdfs:comment 'Scheduled date for the next compliance audit.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfCleanrooms rdf:type rdf:Property ;
    rdfs:label 'Number Of Cleanrooms' ;
    rdfs:comment 'Count of cleanroom spaces within the facility.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfEquipmentUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Equipment Units' ;
    rdfs:comment 'Total number of major equipment units (e.g., lithography, etch, deposition) installed.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational condition of the facility.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTechnologyNode rdf:type rdf:Property ;
    rdfs:label 'Process Technology Node' ;
    rdfs:comment 'Primary semiconductor process node supported (e.g., 7nm, 5nm).' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedAccess rdf:type rdf:Property ;
    rdfs:label 'Restricted Access' ;
    rdfs:comment 'Indicates whether the facility requires restricted (security-cleared) access.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyCertifications rdf:type rdf:Property ;
    rdfs:label 'Safety Certifications' ;
    rdfs:comment 'Comma-separated list of safety certifications held (e.g., ISO 45001).' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftSchedule rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule' ;
    rdfs:comment 'Number of production shifts operated per day.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the facility began operations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the facility location.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGeneratedTons rdf:type rdf:Property ;
    rdfs:label 'Waste Generated Tons' ;
    rdfs:comment 'Total waste generated per month measured in metric tons.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterUsageM3 rdf:type rdf:Property ;
    rdfs:label 'Water Usage M3' ;
    rdfs:comment 'Average monthly water usage in cubic meters.' ;
    rdfs:domain ind:FabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundryApprovedVendorId rdf:type rdf:Property ;
    rdfs:label 'Foundry Approved Vendor Id' ;
    rdfs:comment 'Foreign key linking to supply.approved_vendor. Business justification: Foundry qualification gate before design commitment: design program managers must confirm the target foundry\'s approved vendor status and audit score before committing NRE spend to a process node. Rol' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedVendor .

ind:foundrySupplierId rdf:type rdf:Property ;
    rdfs:label 'Foundry Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Foundry selection contract for each design project; required for manufacturing cost tracking and compliance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:pdkId rdf:type rdf:Property ;
    rdfs:label 'Pdk Id' ;
    rdfs:comment 'FK to design.pdk.pdk_id — Every IC design project targets a specific PDK version. This determines all design rules, standard cells, and device models available. Fundamental design constraint.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pdk .

ind:blockCount rdf:type rdf:Property ;
    rdfs:label 'Block Count' ;
    rdfs:comment 'Number of top-level hierarchical design blocks (partitions) in the IC design. Reflects the block decomposition strategy used for parallel design team assignments and hierarchical physical design in Cadence Innovus.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designPhase rdf:type rdf:Property ;
    rdfs:label 'Design Phase' ;
    rdfs:comment 'Indicates the primary fabrication phase scope of the design: Front End of Line (FEOL), Middle of Line (MOL), Back End of Line (BEOL), or full-flow. Governs which process modules and DFM rules are active.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Classification of the integrated circuit design type. Drives NRE cost structure, EDA tool selection, and tapeout process. [ENUM-REF-CANDIDATE: ASIC|SoC|FPGA|ASSP|MCU|GPU|DSP|RFIC|MEMS|Analog — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Dfm Rule Set Version' ;
    rdfs:comment 'Version identifier of the Design for Manufacturability (DFM) rule set applied to this project. Governs OPC recipe selection, MEEF corrections, and yield-enhancement layout guidelines provided by the foundry PDK.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftEnabled rdf:type rdf:Property ;
    rdfs:label 'Dft Enabled' ;
    rdfs:comment 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, boundary scan) are included in this design. Drives ATPG flow activation, ATE program generation, and KGD qualification planning.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edaToolSuite rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Suite' ;
    rdfs:comment 'Primary EDA tool suite vendor used for this IC design project (e.g., Cadence Virtuoso/Innovus, Synopsys Design Compiler/PrimeTime, Siemens EDA). Governs tool license allocation and design flow configuration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edaToolVersion rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Version' ;
    rdfs:comment 'Version string of the primary EDA tool suite certified for this project (e.g., \'Cadence Innovus 21.1\', \'Synopsys DC 2022.03\'). Ensures design reproducibility and supports audit trails for sign-off certification.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCountTargetK rdf:type rdf:Property ;
    rdfs:label 'Gate Count Target K' ;
    rdfs:comment 'Target logic gate count in thousands of equivalent gates (Kilo-Gates) for the design. Used for complexity estimation, EDA tool capacity planning, and synthesis runtime forecasting in Synopsys Design Compiler.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsFilePath rdf:type rdf:Property ;
    rdfs:label 'Gds File Path' ;
    rdfs:comment 'Storage path or URI of the final GDS/GDSII design database file submitted for tapeout. Provides traceability to the authoritative design artifact in the EDA data management system.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatfAutomotiveGrade rdf:type rdf:Property ;
    rdfs:label 'Iatf Automotive Grade' ;
    rdfs:comment 'Indicates whether this IC design project targets automotive-grade qualification per IATF 16949 and AEC-Q100/Q101 standards. Triggers additional FMEA, reliability testing, and DPPM requirements in the quality management workflow.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCoreCount rdf:type rdf:Property ;
    rdfs:label 'Ip Core Count' ;
    rdfs:comment 'Total number of licensed or internally developed Intellectual Property (IP) cores integrated into this IC design project. Drives IP license cost tracking, third-party IP compliance review, and BOM management in Oracle Agile PLM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the IC design project record in the source system of record. Used for incremental data pipeline processing, change detection, and audit compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nreActualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual NRE expenditure incurred to date for the IC design project in US dollars, as recorded in SAP S/4HANA FI/CO. Compared against nre_budget_usd for variance analysis and financial reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nreBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Budget Usd' ;
    rdfs:comment 'Total approved Non-Recurring Engineering (NRE) budget for the IC design project in US dollars. Covers EDA tool licensing, mask set costs, engineering labor, and MPW shuttle fees. Managed in SAP S/4HANA CO cost center planning.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Target die packaging technology for this IC design project (e.g., WLCSP, BGA, CoWoS, InFO, flip-chip). Influences die size constraints, I/O pad ring design, and OSAT partner selection. [ENUM-REF-CANDIDATE: WLCSP|BGA|QFN|CoWoS|InFO|flip_chip|TSV|SiP|LGA — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdkVersion rdf:type rdf:Property ;
    rdfs:label 'Pdk Version' ;
    rdfs:comment 'Version of the Process Design Kit (PDK) certified for use in this IC design project. Ensures reproducibility of design rule checks (DRC), layout versus schematic (LVS) verification, and parasitic extraction across the design lifecycle.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmItemReference rdf:type rdf:Property ;
    rdfs:label 'Plm Item Reference' ;
    rdfs:comment 'Native item/object identifier in Siemens Teamcenter PLM or Oracle Agile PLM for this IC design project. Enables bidirectional traceability between the Databricks Silver Layer and the authoritative PLM system of record.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier assigned at project initiation in Siemens Teamcenter PLM and Oracle Agile PLM. Used across EDA tool flows, NRE contracts, and cross-functional communications as the canonical project reference.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Free-text description of the IC design project scope, target application domain (e.g., AI accelerator, automotive MCU, IoT SoC), and key design objectives. Supports search, discovery, and executive reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the IC design project (e.g., \'Orion SoC Rev2\'). Used in PLM dashboards, design reviews, and executive reporting.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Official start date of the IC design project, corresponding to project kick-off and initial resource allocation in Siemens Teamcenter PLM and SAP S/4HANA CO.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the IC design project from concept through GDS/GDSII tapeout. Drives milestone tracking, resource allocation, and PLM workflow gates. [ENUM-REF-CANDIDATE: concept|rtl_design|synthesis|physical_design|verification|tapeout|post_tapeout|cancelled — promote to reference product]' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSvhcAssessed rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Assessed' ;
    rdfs:comment 'Indicates whether a REACH Substances of Very High Concern (SVHC) assessment has been completed for materials used in this IC design and packaging. Required for EU chemical safety compliance and customer disclosure obligations.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Design revision identifier (e.g., \'A\', \'B1\', \'C\') tracking major design iterations managed through Oracle Agile PLM change control. Incremented upon significant design changes, ECO incorporation, or re-tapeout events.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Rohs Compliant' ;
    rdfs:comment 'Indicates whether the IC design and associated packaging materials comply with the EU RoHS Directive (2011/65/EU) restricting hazardous substances. Required for EU market access and customer compliance declarations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtlFreezeDate rdf:type rdf:Property ;
    rdfs:label 'Rtl Freeze Date' ;
    rdfs:comment 'Planned or actual date on which the Register Transfer Level (RTL) specification is frozen and handed off to logic synthesis. A key milestone in the IC design schedule tracked in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA CO Work Breakdown Structure (WBS) element code assigned to this IC design project for NRE cost collection, budget tracking, and financial reporting under SOX controls.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutActualDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Actual Date' ;
    rdfs:comment 'Actual date on which the final GDS/GDSII design database was submitted to the foundry for mask generation. Compared against tapeout_target_date to measure schedule adherence and Time to Market (TTM) performance.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tapeoutTargetDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Target Date' ;
    rdfs:comment 'Planned date for final GDS/GDSII tapeout submission to the foundry. Drives the master project schedule, NRE milestone payments, and MPW shuttle slot reservations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetClockFreqMhz rdf:type rdf:Property ;
    rdfs:label 'Target Clock Freq Mhz' ;
    rdfs:comment 'Target operating clock frequency in megahertz (MHz) as defined in the Power Performance Area (PPA) specification. Used by Synopsys Design Compiler and PrimeTime for timing closure constraints and sign-off.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDieAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Die Area Mm2' ;
    rdfs:comment 'Target silicon die area in square millimeters (mm²) as defined in the PPA specification. Constrains floorplanning, block partitioning, and IP core placement in Cadence Innovus physical design flow.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPowerBudgetMw rdf:type rdf:Property ;
    rdfs:label 'Target Power Budget Mw' ;
    rdfs:comment 'Maximum allowable total power consumption in milliwatts (mW) as specified in the PPA targets. Drives power-aware synthesis, clock gating strategies, and multi-voltage domain planning in Cadence Innovus and Synopsys Design Compiler.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsvRequired rdf:type rdf:Property ;
    rdfs:label 'Tsv Required' ;
    rdfs:comment 'Indicates whether Through-Silicon Via (TSV) interconnects are required for 3D stacking or advanced packaging (e.g., CoWoS, HBM integration). Triggers specialized process module planning and OSAT coordination.' ;
    rdfs:domain ind:IcDesignProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCoreId rdf:type rdf:Property ;
    rdfs:label 'Ip Core Id' ;
    rdfs:comment 'Unique surrogate identifier for each IP core record in the master catalog. Primary key for the ip_core data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpCore .

ind:areaUm2 rdf:type rdf:Property ;
    rdfs:label 'Area Um2' ;
    rdfs:comment 'Physical silicon area occupied by the IP core in square micrometers (µm²) for the characterized process node. Part of the PPA characterization data used for die size estimation and floorplanning in Cadence Innovus.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the IP core in the internal IP library and vendor catalogs (e.g., ARM Cortex-A55, SNPS-PCIE-GEN5). Used as the business key across EDA tool flows, PLM, and design project references.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasheetUrl rdf:type rdf:Property ;
    rdfs:label 'Datasheet Url' ;
    rdfs:comment 'URL link to the official IP core datasheet or technical reference manual stored in the PLM document management system or vendor portal. Provides design teams with access to integration guidelines, timing specifications, and interface documentation.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designIpCoreName rdf:type rdf:Property ;
    rdfs:label 'Design Ip Core Name' ;
    rdfs:comment 'Human-readable name of the IP core as used in design documentation, EDA tool libraries, and vendor datasheets (e.g., \'Cortex-A55 CPU Cluster\', \'DesignWare PCIe Gen5 Controller\').' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dfmCompliant rdf:type rdf:Property ;
    rdfs:label 'Dfm Compliant' ;
    rdfs:comment 'Indicates whether the IP core has passed Design for Manufacturability (DFM) rule checks for the target process node (True = DFM-compliant; False = DFM issues present or not checked). DFM compliance reduces yield risk during wafer fabrication.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dftCompliant rdf:type rdf:Property ;
    rdfs:label 'Dft Compliant' ;
    rdfs:comment 'Indicates whether the IP core includes Design for Testability (DFT) structures (scan chains, BIST, boundary scan) compliant with the project\'s DFT architecture (True = DFT-compliant; False = not compliant or not applicable). Affects ATPG test coverage and ATE test time.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edaToolCompatibility rdf:type rdf:Property ;
    rdfs:label 'Eda Tool Compatibility' ;
    rdfs:comment 'Comma-separated list of EDA tools and versions with which this IP core has been validated (e.g., \'Cadence Virtuoso 23.1, Synopsys DC 2023.03, Cadence Innovus 22.1\'). Ensures design teams select compatible tool versions for integration.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundryCompatibility rdf:type rdf:Property ;
    rdfs:label 'Foundry Compatibility' ;
    rdfs:comment 'Comma-separated list of semiconductor foundries for which this IP core has been qualified and is available (e.g., \'TSMC, Samsung, GlobalFoundries\'). Determines which fabrication facilities can manufacture designs incorporating this IP.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionCategory rdf:type rdf:Property ;
    rdfs:label 'Function Category' ;
    rdfs:comment 'Functional classification of the IP core indicating its primary design purpose (e.g., CPU, GPU, NPU, SerDes, PHY, memory_controller, analog, RF, security, interconnect, IO). Used for IP portfolio management and design-in selection. [ENUM-REF-CANDIDATE: CPU|GPU|NPU|SerDes|PHY|memory_controller|analog|RF|security|interconnect|IO|other — promote to reference product]' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalDescription rdf:type rdf:Property ;
    rdfs:label 'Functional Description' ;
    rdfs:comment 'Detailed technical description of the IP core\'s functionality, architecture, and key features as documented in the IP datasheet. Provides design engineers with the information needed to evaluate IP suitability for a given SoC design.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCount rdf:type rdf:Property ;
    rdfs:label 'Gate Count' ;
    rdfs:comment 'Equivalent gate count of the IP core representing its logic complexity, expressed in number of 2-input NAND gate equivalents. Used for die area estimation, synthesis resource planning, and complexity benchmarking in Synopsys Design Compiler.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsAvailable rdf:type rdf:Property ;
    rdfs:label 'Gds Available' ;
    rdfs:comment 'Indicates whether a GDSII (Graphic Data System II) physical layout file is available for this IP core (True = GDSII provided; False = not available). GDSII availability is required for hard macro integration and tapeout submission.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interfaceStandard rdf:type rdf:Property ;
    rdfs:label 'Interface Standard' ;
    rdfs:comment 'Industry interface protocol standards supported by this IP core (e.g., AMBA AXI4, PCIe Gen5, USB 3.2, DDR5, MIPI CSI-2). Ensures interoperability with SoC interconnect fabric and system-level integration. [ENUM-REF-CANDIDATE: AMBA_AXI4|PCIe_Gen5|USB3.2|DDR5|MIPI_CSI2|Ethernet|CAN|I2C|SPI|other — promote to reference product]' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipType rdf:type rdf:Property ;
    rdfs:label 'Ip Type' ;
    rdfs:comment 'Classification of the IP core by its delivery form: hard_macro (fixed physical layout, process-specific GDS), soft_ip (synthesizable RTL, process-portable), or firm_ip (partially optimized netlist, semi-portable). Determines integration methodology and EDA tool flow requirements.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lefAvailable rdf:type rdf:Property ;
    rdfs:label 'Lef Available' ;
    rdfs:comment 'Indicates whether a Library Exchange Format (LEF) abstract view is available for this IP core (True = LEF provided; False = not available). LEF files are required for place-and-route integration in Cadence Innovus and Synopsys IC Compiler.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date on which the IP core license agreement expires or must be renewed. Null for perpetual licenses. Critical for license renewal planning and ensuring design projects do not use expired IP licenses.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Usd' ;
    rdfs:comment 'One-time or annual license fee paid to the IP vendor in US Dollars (USD). Represents the NRE or access cost component of the IP licensing agreement. Null for open-source or internally developed IP.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of licensing arrangement governing use of this IP core: perpetual (one-time fee, unlimited use), subscription (time-limited access), royalty_bearing (per-unit royalty on shipped products), royalty_free (no per-unit royalty after license fee), open_source (governed by open-source license terms). Drives financial planning and legal compliance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Mhz' ;
    rdfs:comment 'Maximum achievable operating frequency of the IP core in megahertz (MHz) at the characterized process corner (typical/worst-case) for the target process node. Part of the PPA characterization data used for timing closure planning in Synopsys Design Compiler and PrimeTime.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwEligible rdf:type rdf:Property ;
    rdfs:label 'Mpw Eligible' ;
    rdfs:comment 'Indicates whether this IP core is eligible for inclusion in Multi-Project Wafer (MPW) shuttle runs for cost-effective silicon validation (True = MPW eligible; False = not eligible, e.g., due to NDA restrictions or hard macro size constraints).' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) must be in place before design teams can access the IP core documentation, RTL source, or GDSII files (True = NDA required; False = no NDA required). Governs IP access control and legal compliance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerUw rdf:type rdf:Property ;
    rdfs:label 'Power Uw' ;
    rdfs:comment 'Characterized typical power consumption of the IP core in microwatts (µW) at the nominal operating voltage and frequency for the target process node. Part of the Power-Performance-Area (PPA) characterization data used for SoC power budget analysis.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which this version of the IP core was officially released and made available for design-in use in the internal IP library or vendor catalog. Used for version history tracking and design project planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'Per-unit royalty rate expressed as a percentage of the net selling price of the end product incorporating this IP core. Applicable only for royalty_bearing license types. Used for royalty accrual and financial reporting in SAP S/4HANA.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtlLanguage rdf:type rdf:Property ;
    rdfs:label 'Rtl Language' ;
    rdfs:comment 'Hardware description language used for the RTL source code of the IP core (Verilog, SystemVerilog, VHDL, or mixed). Relevant only for soft IP and firm IP types. Determines EDA tool compatibility and synthesis flow requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Scan Coverage Pct' ;
    rdfs:comment 'Percentage of internal logic nodes covered by scan-based DFT test structures, as reported by ATPG tools. Higher coverage reduces DPPM risk. Null if DFT is not applicable (e.g., analog IP).' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siliconProven rdf:type rdf:Property ;
    rdfs:label 'Silicon Proven' ;
    rdfs:comment 'Indicates whether this IP core has been successfully validated in a fabricated silicon device (True = silicon-proven; False = simulation-only or pre-silicon). Silicon-proven status is a critical risk factor in IP selection for production designs.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siliconProvenDate rdf:type rdf:Property ;
    rdfs:label 'Silicon Proven Date' ;
    rdfs:comment 'Date on which the IP core achieved silicon-proven status through successful tape-out and functional validation in fabricated silicon. Null if not yet silicon-proven.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Indicates whether the IP core originates from the internal IP development team, a third-party vendor (e.g., ARM, Synopsys DesignWare, Cadence Tensilica), or an open-source library. Determines licensing obligations, support model, and NRE cost applicability.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'Level of technical support available for this IP core: standard (community/documentation support), premium (dedicated FAE support with SLA), end_of_support (no active support, use at own risk). Influences design-in risk assessment and vendor engagement planning.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingModelAvailable rdf:type rdf:Property ;
    rdfs:label 'Timing Model Available' ;
    rdfs:comment 'Indicates whether Liberty (.lib) timing models are available for this IP core for static timing analysis (True = Liberty models provided; False = not available). Required for timing closure analysis in Synopsys PrimeTime and Cadence Tempus.' ;
    rdfs:domain ind:IpCore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this IP core record was most recently modified in the master catalog (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change tracking, data lineage, and incremental ETL processing in the Databricks Lakehouse.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the third-party IP vendor or licensor (e.g., ARM Holdings, Synopsys, Cadence Design Systems, CEVA). Null for internally developed IP cores. Used for vendor management, license tracking, and procurement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the IP core release following semantic versioning (e.g., 2.1.0, r0p4). Tracks revision history and ensures design projects reference the correct IP release.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Product Process Node Id' ;
    rdfs:comment 'Foreign key linking to product.process_node. Business justification: Ensures alignment of PDKs with official process-node definitions for compliance, cost, and yield analysis in engineering reports.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:agilePlmPartNumber rdf:type rdf:Property ;
    rdfs:label 'Agile Plm Part Number' ;
    rdfs:comment 'Part number assigned to this PDK in Oracle Agile PLM for product data and change management. Used to track PDK-related Engineering Change Orders (ECOs) and Product Change Notifications (PCNs).' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash of the PDK distribution archive. Used to verify PDK file integrity after download or transfer, ensuring no corruption or unauthorized modification of foundry-provided design rule files.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'Date on which this PDK version was deprecated and superseded by a newer release. Designs in progress must migrate to the active version by this date. Null if the PDK is still active.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dftRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Dft Rule Deck Version' ;
    rdfs:comment 'Version of the Design for Testability (DFT) rule deck included in this PDK. DFT rules govern scan chain insertion, ATPG (Automatic Test Pattern Generation) compatibility, and boundary scan requirements for post-fabrication testing.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drcRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Drc Rule Deck Version' ;
    rdfs:comment 'Version identifier of the Design Rule Check (DRC) rule deck included in this PDK. The DRC rule deck enforces foundry-mandated physical design rules to ensure manufacturability. Used in Cadence Innovus and KLA ICOS inspection correlation.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Canonical file system or object storage path to the PDK installation directory or archive (e.g., \'/pdk/tsmc/n5/v1.3.2\' or \'s3://pdk-repo/tsmc/n5/v1.3.2\'). Used by EDA tool setup scripts to locate PDK assets in Cadence Virtuoso and Synopsys Design Compiler environments.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsFormat rdf:type rdf:Property ;
    rdfs:label 'Gds Format' ;
    rdfs:comment 'Layout data format supported by this PDK for tapeout submission to the foundry. GDSII (Graphic Data System II) is the legacy industry standard; OASIS is the modern compressed alternative. Determines the final tapeout file format.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioLibraryName rdf:type rdf:Property ;
    rdfs:label 'Io Library Name' ;
    rdfs:comment 'Name of the I/O pad cell library included in this PDK, providing ESD-protected interface cells for chip-to-package signal routing. Required for full-chip physical design and package co-design.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Ip Library Version' ;
    rdfs:comment 'Version of the foundry-provided hard IP library (e.g., PLLs, SerDes, PHYs) bundled with this PDK. IP cores are pre-characterized and validated for the specific process node.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layerStackDefinition rdf:type rdf:Property ;
    rdfs:label 'Layer Stack Definition' ;
    rdfs:comment 'Identifier or reference name for the metal layer stack definition included in this PDK, specifying the number of metal layers, dielectric materials, and interconnect hierarchy (FEOL/MOL/BEOL). Governs routing resources available to physical design tools.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lvsRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Lvs Rule Deck Version' ;
    rdfs:comment 'Version identifier of the Layout Versus Schematic (LVS) rule deck included in this PDK. LVS verifies that the physical layout matches the circuit schematic. Mandatory for tapeout sign-off in Cadence Virtuoso flows.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Max Supply Voltage V' ;
    rdfs:comment 'Maximum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Exceeding this value risks device reliability and oxide breakdown.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryCompilerSupported rdf:type rdf:Property ;
    rdfs:label 'Memory Compiler Supported' ;
    rdfs:comment 'Indicates whether this PDK includes or is compatible with a foundry-provided memory compiler for generating SRAM, ROM, or register file macros. True = memory compiler available; False = memory macros must be sourced separately.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Min Supply Voltage V' ;
    rdfs:comment 'Minimum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Used for low-power design optimization and multi-voltage domain planning.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpwShuttleSupported rdf:type rdf:Property ;
    rdfs:label 'Mpw Shuttle Supported' ;
    rdfs:comment 'Indicates whether this PDK version is qualified and approved for use in Multi-Project Wafer (MPW) shuttle runs, enabling cost-shared prototyping across multiple design projects on a single wafer.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable descriptive name of the PDK (e.g., \'TSMC 5nm N5 PDK v1.3\'). Used in EDA tool selection menus, design review documentation, and PLM records in Siemens Teamcenter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalSupplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Nominal Supply Voltage V' ;
    rdfs:comment 'Nominal (typical) operating supply voltage in volts for this process node as specified in the PDK. Used as the reference voltage for standard timing and power characterization.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opcRuleDeckVersion rdf:type rdf:Property ;
    rdfs:label 'Opc Rule Deck Version' ;
    rdfs:comment 'Version of the Optical Proximity Correction (OPC) rule deck included in this PDK. OPC rules compensate for photolithographic distortions during mask writing, critical for sub-10nm nodes using EUV or DUV lithography.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Max C' ;
    rdfs:comment 'Maximum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the hot corner for timing sign-off and reliability qualification.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTempMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temp Min C' ;
    rdfs:comment 'Minimum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the cold corner for timing sign-off.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdkStatus rdf:type rdf:Property ;
    rdfs:label 'Pdk Status' ;
    rdfs:comment 'Current lifecycle state of the PDK version. \'draft\' = under development; \'active\' = qualified and approved for production design starts; \'deprecated\' = superseded by newer version but still supported; \'retired\' = no longer supported; \'restricted\' = limited access pending NDA or export control review.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCornerSet rdf:type rdf:Property ;
    rdfs:label 'Process Corner Set' ;
    rdfs:comment 'Comma-separated list of process corners (PVT corners) defined in this PDK for timing and power sign-off (e.g., \'TT, FF, SS, FS, SF\'). Each corner represents a combination of process, voltage, and temperature variation for worst/best-case analysis in Synopsys PrimeTime.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFamily rdf:type rdf:Property ;
    rdfs:label 'Process Family' ;
    rdfs:comment 'Foundry-specific process family or platform name within a node (e.g., \'N5\', \'N5P\', \'N4\', \'SF3E\'). Distinguishes performance-optimized, power-optimized, or cost-optimized variants within the same technology node.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Release Notes Url' ;
    rdfs:comment 'URL pointing to the official PDK release notes document, detailing changes, bug fixes, and known issues relative to the previous version. Essential for design teams evaluating PDK upgrade impact on in-progress designs.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiceModelSet rdf:type rdf:Property ;
    rdfs:label 'Spice Model Set' ;
    rdfs:comment 'Identifier or name of the SPICE (Simulation Program with Integrated Circuit Emphasis) device model set bundled with this PDK (e.g., \'BSIM-CMG v110\', \'PSP v103\'). Used by Synopsys PrimeTime and Cadence Virtuoso for circuit simulation and timing analysis.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Spice Model Version' ;
    rdfs:comment 'Version identifier of the SPICE model set included in this PDK. Critical for simulation reproducibility and sign-off correlation between design teams and the foundry.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stdCellLibraryName rdf:type rdf:Property ;
    rdfs:label 'Std Cell Library Name' ;
    rdfs:comment 'Name of the primary standard cell library bundled with this PDK (e.g., \'SC9MC_HD\', \'SC7P5T_HD\'). Standard cell libraries provide pre-characterized logic gates used in RTL-to-GDS synthesis flows in Synopsys Design Compiler.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stdCellLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Std Cell Library Version' ;
    rdfs:comment 'Version of the standard cell library included in this PDK release. Version changes may affect timing, power, and area (PPA) characteristics of synthesized designs.' ;
    rdfs:domain ind:Pdk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamcenterItemReference rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Item Reference' ;
    rdfs:comment 'Item identifier assigned to this PDK record in Siemens Teamcenter PLM, enabling traceability between the PDK master record and associated design projects, change orders, and release workflows.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtlSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Rtl Specification Id' ;
    rdfs:comment 'Unique surrogate identifier for the RTL specification record in the lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtlSpecification .

ind:primaryIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — RTL specifications are created within the context of an IC design project. This is a mandatory parent-child relationship required for design hierarchy navigation.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:toIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'To Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Every RTL specification belongs to exactly one IC design project. This is the fundamental parent-child relationship for design artifacts. Engineers navigate from project to RTL modules daily.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:amsBehavioralModelRef rdf:type rdf:Property ;
    rdfs:label 'Ams Behavioral Model Ref' ;
    rdfs:comment 'Reference identifier or path to the Verilog-AMS or VHDL-AMS behavioral model associated with this analog/mixed-signal RTL block. Populated only when is_analog_mixed_signal is True. Links to the Cadence Virtuoso schematic source.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdcAnnotationStatus rdf:type rdf:Property ;
    rdfs:label 'Cdc Annotation Status' ;
    rdfs:comment 'Completion status of Clock Domain Crossing (CDC) boundary annotations within the RTL specification. CDC annotation is mandatory for multi-clock designs prior to synthesis sign-off to prevent metastability failures.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockDomainCount rdf:type rdf:Property ;
    rdfs:label 'Clock Domain Count' ;
    rdfs:comment 'Number of distinct clock domains defined within this RTL design block. Drives Clock Domain Crossing (CDC) analysis requirements and verification complexity estimation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitHash rdf:type rdf:Property ;
    rdfs:label 'Commit Hash' ;
    rdfs:comment 'The specific commit hash or changelist number in the revision control system corresponding to the approved version of this RTL specification. Provides immutable provenance linkage to the exact source snapshot.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBlockName rdf:type rdf:Property ;
    rdfs:label 'Design Block Name' ;
    rdfs:comment 'Human-readable name of the RTL design block, IP subsystem, or full-chip entity described by this specification (e.g., \'USB3_PHY_Controller\', \'DDR5_Memory_Interface\', \'Top_Level_SoC\'). Serves as the primary identity label for the design artifact.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designBlockType rdf:type rdf:Property ;
    rdfs:label 'Design Block Type' ;
    rdfs:comment 'Classification of the RTL design block scope. Determines applicable design rules, verification methodology, and integration requirements. \'ip_core\' blocks are subject to IP licensing tracking; \'fpga_target\' blocks require device-specific synthesis constraints. [ENUM-REF-CANDIDATE: full_chip|subsystem|ip_core|interface_block|analog_mixed_signal|fpga_target — promote to reference product]' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designIntentDescription rdf:type rdf:Property ;
    rdfs:label 'Design Intent Description' ;
    rdfs:comment 'Narrative description of the functional design intent, architectural decisions, and key requirements captured in this RTL specification. Provides context for design reviews, IP reuse assessments, and new engineer onboarding.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftStrategy rdf:type rdf:Property ;
    rdfs:label 'Dft Strategy' ;
    rdfs:comment 'Design for Testability (DFT) methodology applied to this RTL block. Defines the test insertion approach used to enable Automatic Test Pattern Generation (ATPG) and silicon test coverage on Automatic Test Equipment (ATE).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earEccnCode rdf:type rdf:Property ;
    rdfs:label 'Ear Eccn Code' ;
    rdfs:comment 'Export Control Classification Number (ECCN) assigned to this RTL specification under the Export Administration Regulations (EAR). Determines export licensing requirements for cross-border transfer of design data.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpgaDeviceFamily rdf:type rdf:Property ;
    rdfs:label 'Fpga Device Family' ;
    rdfs:comment 'Target FPGA device family for synthesis and implementation (e.g., \'Xilinx Ultrascale+\', \'Intel Agilex\', \'Lattice ECP5\'). Populated only when is_fpga_target is True. Determines device-specific synthesis constraints and IP primitives.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Functional Coverage Target Pct' ;
    rdfs:comment 'Target functional coverage percentage defined in the verification plan for this RTL specification. Expressed as a percentage (0.00–100.00). Used to gate simulation sign-off and tapeout readiness reviews.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hdlLanguage rdf:type rdf:Property ;
    rdfs:label 'Hdl Language' ;
    rdfs:comment 'Primary Hardware Description Language used to author the RTL source code for this design block. Determines EDA tool compatibility, lint rule sets, and synthesis flow configuration in Synopsys Design Compiler.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interfaceProtocols rdf:type rdf:Property ;
    rdfs:label 'Interface Protocols' ;
    rdfs:comment 'Comma-separated list of hardware interface protocols implemented in this RTL block (e.g., \'AXI4, AHB5, APB3, Wishbone, PCIe, USB3\'). Used for integration compatibility checks and IP reuse assessments.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipReuseSource rdf:type rdf:Property ;
    rdfs:label 'Ip Reuse Source' ;
    rdfs:comment 'Origin classification of the IP content in this RTL specification. \'licensed_third_party\' requires IP license compliance tracking; \'open_source\' requires license obligation management (e.g., GPL, Apache); \'internal\' indicates proprietary reuse. Classified confidential due to IP licensing sensitivity.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnalogMixedSignal rdf:type rdf:Property ;
    rdfs:label 'Is Analog Mixed Signal' ;
    rdfs:comment 'Indicates whether this RTL specification includes analog or mixed-signal content requiring behavioral model references (Verilog-AMS, VHDL-AMS) and linkage to transistor-level schematic source in Cadence Virtuoso.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFpgaTarget rdf:type rdf:Property ;
    rdfs:label 'Is Fpga Target' ;
    rdfs:comment 'Indicates whether this RTL specification is intended for FPGA implementation rather than ASIC tapeout. When True, synthesis constraints, pin assignments, and target device family fields are applicable.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itarControlled rdf:type rdf:Property ;
    rdfs:label 'Itar Controlled' ;
    rdfs:comment 'Indicates whether this RTL specification is subject to International Traffic in Arms Regulations (ITAR) export controls. When True, access must be restricted to authorized US persons and export license requirements apply.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lintComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Lint Compliance Status' ;
    rdfs:comment 'Status of RTL lint rule compliance checks for this specification. Lint tools (e.g., Synopsys SpyGlass, Cadence HAL) enforce coding guidelines and detect potential design errors. \'clean\' is required before synthesis sign-off.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logicGateCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Logic Gate Count Estimate' ;
    rdfs:comment 'Estimated number of equivalent logic gates for this RTL design block, derived from synthesis estimation runs in Synopsys Design Compiler. Used for area budgeting, floorplanning, and Power-Performance-Area (PPA) target setting.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nreCostUsd rdf:type rdf:Property ;
    rdfs:label 'Nre Cost Usd' ;
    rdfs:comment 'Estimated Non-Recurring Engineering (NRE) cost in US dollars associated with developing this RTL specification. Used for project budgeting, customer design-in pricing, and financial reporting in SAP S/4HANA CO module.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which this RTL specification was marked obsolete, typically superseded by a newer version or upon product End of Life (EOL). Supports Product Change Notification (PCN) and Last Time Buy (LTB) processes.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerDomainCount rdf:type rdf:Property ;
    rdfs:label 'Power Domain Count' ;
    rdfs:comment 'Number of distinct power domains defined in the Unified Power Format (UPF) or Common Power Format (CPF) specification for this RTL block. Drives low-power verification and power intent analysis.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerIntentFormat rdf:type rdf:Property ;
    rdfs:label 'Power Intent Format' ;
    rdfs:comment 'Standard format used to specify power intent for this RTL design block. UPF (IEEE 1801) and CPF (Cadence) are the two industry standards. \'none\' indicates no multi-voltage power management is implemented.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repositoryPath rdf:type rdf:Property ;
    rdfs:label 'Repository Path' ;
    rdfs:comment 'Full path or URL to the revision control repository location where the RTL source files for this specification are stored (e.g., Git remote URL or Perforce depot path). Classified confidential as it reveals internal IP infrastructure.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetStrategy rdf:type rdf:Property ;
    rdfs:label 'Reset Strategy' ;
    rdfs:comment 'Reset architecture employed in this RTL design block. Defines whether resets are synchronous, asynchronous, or mixed, which impacts timing closure, DFT scan insertion, and silicon reliability.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionControlSystem rdf:type rdf:Property ;
    rdfs:label 'Revision Control System' ;
    rdfs:comment 'Version control system in which the RTL source files for this specification are managed. Enables provenance tracking and audit trail for design changes.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Specification Approved Date' ;
    rdfs:comment 'Date on which this RTL specification was formally approved through the PLM design review process. Marks the effective start of the specification as a binding design baseline. Required for ISO 9001 and IATF 16949 design record compliance.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the RTL specification artifact as tracked in Siemens Teamcenter PLM and revision control systems (Git, Perforce). Used for cross-system traceability and design review references.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Specification Released Date' ;
    rdfs:comment 'Date on which this RTL specification was released for downstream use (synthesis, physical design, verification). Distinct from approval date; release may follow approval after additional sign-off steps.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle state of the RTL specification artifact within the PLM workflow. Controls downstream design activities: \'draft\' allows edits; \'approved\' gates synthesis; \'released\' permits tapeout submission; \'obsolete\' marks superseded versions.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClockFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Target Clock Frequency Mhz' ;
    rdfs:comment 'Target operating clock frequency in megahertz (MHz) for the primary clock domain of this RTL design block. Drives timing constraint definition in Synopsys PrimeTime and synthesis optimization targets.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProcessNode rdf:type rdf:Property ;
    rdfs:label 'Target Process Node' ;
    rdfs:comment 'Semiconductor fabrication process node for which this RTL design is targeted (e.g., \'5nm\', \'7nm\', \'28nm\', \'180nm\'). Determines applicable PDK, design rules, and standard cell libraries used in synthesis and physical design.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Semantic version label of this RTL specification revision (e.g., \'v1.0\', \'v2.3.1\'). Tracks design evolution through revision control (Git, Perforce) and PLM change management. Incremented on each approved change.' ;
    rdfs:domain ind:RtlSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netlistId rdf:type rdf:Property ;
    rdfs:label 'Netlist Id' ;
    rdfs:comment 'Unique surrogate identifier for the synthesized netlist artifact record in the design domain. Primary key for this data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Netlist .

ind:primaryNetlistIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Netlist Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design project or block to which this netlist belongs. Links the netlist artifact to its design hierarchy context within the PLM system.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:toPdkId rdf:type rdf:Property ;
    rdfs:label 'To Pdk Id' ;
    rdfs:comment 'FK to design.pdk.pdk_id — Synthesis uses PDK standard cell libraries. The netlist must reference which PDK version was used for synthesis.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pdk .

ind:toRtlSpecificationId rdf:type rdf:Property ;
    rdfs:label 'To Rtl Specification Id' ;
    rdfs:comment 'FK to design.rtl_specification.rtl_specification_id — A netlist is synthesized from an RTL specification. This is the core design flow linkage (RTL -> synthesis -> netlist) required for design provenance.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtlSpecification .

ind:areaEstimateUm2 rdf:type rdf:Property ;
    rdfs:label 'Area Estimate Um2' ;
    rdfs:comment 'Estimated silicon area of the synthesized netlist in square micrometers (µm²) as reported by the synthesis tool. Represents the combinational and sequential cell area before physical placement. A key PPA (Power-Performance-Area) metric.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellInstanceCount rdf:type rdf:Property ;
    rdfs:label 'Cell Instance Count' ;
    rdfs:comment 'Total number of standard cell instances instantiated in the synthesized netlist. Distinct from gate count — counts actual cell placements including sequential elements (flip-flops, latches) and combinational cells.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellLibraryName rdf:type rdf:Property ;
    rdfs:label 'Cell Library Name' ;
    rdfs:comment 'Name of the standard cell library used during logic synthesis (e.g., \'TSMC_N5_SC_HD_v1.2\'). Defines the set of logic gates, flip-flops, and combinational cells mapped during synthesis from the PDK.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Cell Library Version' ;
    rdfs:comment 'Version identifier of the standard cell library used during synthesis. Critical for design reproducibility and provenance — different library versions may have different timing, power, or area characteristics.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationalCellCount rdf:type rdf:Property ;
    rdfs:label 'Combinational Cell Count' ;
    rdfs:comment 'Number of combinational logic cells (AND, OR, MUX, inverters, etc.) in the synthesized netlist. Used for area estimation and logic optimization analysis during PPA (Power-Performance-Area) evaluation.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintsFileRef rdf:type rdf:Property ;
    rdfs:label 'Constraints File Ref' ;
    rdfs:comment 'File path or repository reference to the Synopsys Design Constraints (SDC) file used during synthesis. The SDC file specifies timing constraints, clock definitions, input/output delays, and false paths that govern synthesis optimization.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathDelayPs rdf:type rdf:Property ;
    rdfs:label 'Critical Path Delay Ps' ;
    rdfs:comment 'Propagation delay of the longest (critical) timing path in the synthesized netlist, measured in picoseconds (ps). Determines the maximum achievable operating frequency and is a key PPA (Power-Performance-Area) metric for design optimization.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designIteration rdf:type rdf:Property ;
    rdfs:label 'Design Iteration' ;
    rdfs:comment 'Sequential iteration counter for synthesis runs on the same design block. Increments with each new synthesis attempt, enabling tracking of design convergence progress and comparison of PPA metrics across iterations.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dfmRuleCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Dfm Rule Check Status' ;
    rdfs:comment 'Status of Design for Manufacturability (DFM) rule checks applied to this netlist. DFM rules ensure the synthesized design is compatible with the target fabrication process constraints to maximize yield.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftScanCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Dft Scan Coverage Pct' ;
    rdfs:comment 'Percentage of sequential elements covered by DFT (Design for Testability) scan chains in the synthesized netlist. Higher coverage improves defect detection during Automatic Test Equipment (ATE) testing. Target is typically ≥95% for production designs.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Mw' ;
    rdfs:comment 'Estimated dynamic (switching) power consumption in milliwatts (mW) from the synthesis power analysis report. Represents power consumed by logic transitions and is activity-dependent. Used for thermal and battery life analysis.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format of the synthesized netlist artifact (e.g., Verilog gate-level netlist, VHDL, SPICE, EDIF, Liberty). Determines compatibility with downstream EDA tools for physical design, simulation, and verification flows.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakagePowerUw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Uw' ;
    rdfs:comment 'Estimated static leakage power consumption in microwatts (µW) from the synthesis power analysis report. Represents power consumed when the circuit is idle due to sub-threshold leakage currents. Critical for low-power and IoT product designs.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netlistType rdf:type rdf:Property ;
    rdfs:label 'Netlist Type' ;
    rdfs:comment 'Classification of the netlist stage in the IC design flow: pre_synthesis (RTL-level functional netlist before synthesis), post_synthesis (gate-level netlist after logic synthesis by Synopsys Design Compiler), or post_layout (netlist annotated with parasitic extraction data after physical design in Cadence Innovus).' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequentialCellCount rdf:type rdf:Property ;
    rdfs:label 'Sequential Cell Count' ;
    rdfs:comment 'Number of sequential logic cells (flip-flops, latches, registers) in the synthesized netlist. Used for Design for Testability (DFT) scan chain planning and power analysis of dynamic switching activity.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:synthesisRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Synthesis Run Timestamp' ;
    rdfs:comment 'Date and time when the logic synthesis run that produced this netlist was executed. Provides the principal business event timestamp for design provenance, audit trails, and design iteration tracking.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:synthesisRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Synthesis Runtime Minutes' ;
    rdfs:comment 'Wall-clock runtime of the synthesis job in minutes. Used for EDA compute resource planning, license utilization tracking, and identifying synthesis runs that exceed expected runtimes due to design complexity or tool issues.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisStatus rdf:type rdf:Property ;
    rdfs:label 'Synthesis Status' ;
    rdfs:comment 'Current lifecycle status of the netlist artifact within the design flow. Tracks progression from initial synthesis run through completion, failure, archival, or supersession by a newer version.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingClosureAchieved rdf:type rdf:Property ;
    rdfs:label 'Timing Closure Achieved' ;
    rdfs:comment 'Indicates whether timing closure has been achieved for this netlist (True = all timing paths meet constraints with non-negative slack; False = timing violations remain). A prerequisite gate for advancing to physical design and tapeout.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timingSlackHoldPs rdf:type rdf:Property ;
    rdfs:label 'Timing Slack Hold Ps' ;
    rdfs:comment 'Worst-case hold timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative hold slack indicates a hold violation requiring buffer insertion or path adjustment.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingSlackSetupPs rdf:type rdf:Property ;
    rdfs:label 'Timing Slack Setup Ps' ;
    rdfs:comment 'Worst-case setup timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative slack indicates a timing violation (setup violation) that must be resolved before tapeout. Critical PPA metric.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingViolationCount rdf:type rdf:Property ;
    rdfs:label 'Timing Violation Count' ;
    rdfs:comment 'Total number of timing path violations (setup and hold combined) reported in the synthesis timing analysis. A value of zero indicates timing closure has been achieved. Used to track synthesis convergence progress across iterations.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPowerEstimateMw rdf:type rdf:Property ;
    rdfs:label 'Total Power Estimate Mw' ;
    rdfs:comment 'Estimated total power consumption of the synthesized netlist in milliwatts (mW), as reported by the synthesis tool. Includes dynamic switching power and static leakage power. A key PPA (Power-Performance-Area) metric for product qualification.' ;
    rdfs:domain ind:Netlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingAnalysisRunId rdf:type rdf:Property ;
    rdfs:label 'Timing Analysis Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each Static Timing Analysis (STA) run record in the Databricks Silver Layer. Primary key for the timing_analysis_run data product.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimingIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Timing Ic Design Project Id' ;
    rdfs:comment 'Reference to the IC design or SoC/ASIC design entity for which this STA run was executed. Links the timing analysis result to the parent design record managed in Cadence Virtuoso/Innovus or Siemens Teamcenter PLM.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:timingBaselineIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Timing Baseline Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Timing runs belong to a project for aggregated timing closure tracking across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:analysisMode rdf:type rdf:Property ;
    rdfs:label 'Analysis Mode' ;
    rdfs:comment 'Timing analysis mode applied in this STA run. Setup checks for maximum path delay violations; hold checks for minimum path delay violations; OCV (On-Chip Variation), AOCV (Advanced OCV), and POCV (Parametric OCV) modes apply statistical derating for silicon variation modeling. Determines which slack metrics are applicable.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockFrequencyTargetMhz rdf:type rdf:Property ;
    rdfs:label 'Clock Frequency Target Mhz' ;
    rdfs:comment 'Target clock frequency in megahertz (MHz) specified for this STA run, representing the design\'s PPA (Power Performance Area) performance goal. Used to evaluate whether timing closure is achieved at the required operating frequency.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clockPeriodTargetPs rdf:type rdf:Property ;
    rdfs:label 'Clock Period Target Ps' ;
    rdfs:comment 'Target clock period in picoseconds (ps) corresponding to the clock frequency target. Directly used by Synopsys PrimeTime as the timing constraint for setup/hold analysis. Derived from clock_frequency_target_mhz but stored independently as the authoritative STA constraint value.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathCount rdf:type rdf:Property ;
    rdfs:label 'Critical Path Count' ;
    rdfs:comment 'Number of critical timing paths (paths with negative or near-zero slack) identified in this STA run. Used by design engineers to prioritize optimization efforts in Synopsys Design Compiler or Cadence Innovus for timing closure.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deratingFactorHold rdf:type rdf:Property ;
    rdfs:label 'Derating Factor Hold' ;
    rdfs:comment 'On-Chip Variation (OCV) derating factor applied to hold timing paths in this STA run. Represents the percentage by which cell delays are derated for hold analysis. Typically different from setup derating to model the asymmetric nature of process variation effects on min/max paths.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deratingFactorSetup rdf:type rdf:Property ;
    rdfs:label 'Derating Factor Setup' ;
    rdfs:comment 'On-Chip Variation (OCV) derating factor applied to setup timing paths in this STA run. Represents the percentage by which cell delays are derated to model process variation (e.g., 0.95 = 5% derating). Used in OCV/AOCV/POCV analysis modes for silicon-accurate sign-off.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designStage rdf:type rdf:Property ;
    rdfs:label 'Design Stage' ;
    rdfs:comment 'Physical design stage at which this STA run was performed, reflecting the state of the netlist and parasitics. Values: pre_synthesis (RTL-level), post_synthesis (gate-level), pre_cts (before Clock Tree Synthesis), post_cts (after CTS), post_route (after detailed routing), signoff (final tapeout signoff). Drives interpretation of WNS/TNS results.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVersion rdf:type rdf:Property ;
    rdfs:label 'Design Version' ;
    rdfs:comment 'Version or revision label of the IC design netlist or GDS/GDSII database at the time this STA run was executed (e.g., \'v2.3.1\', \'tapeout_rc2\'). Enables timing closure tracking across design iterations and correlates with PLM change records.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdViolationCount rdf:type rdf:Property ;
    rdfs:label 'Hold Violation Count' ;
    rdfs:comment 'Total number of hold timing violations (negative hold slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full hold timing closure. Critical for designs with multi-cycle paths, clock domain crossings, and post-CTS analysis.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMultiCornerRun rdf:type rdf:Property ;
    rdfs:label 'Is Multi Corner Run' ;
    rdfs:comment 'Indicates whether this STA run covers multiple PVT corners simultaneously (True) or a single corner (False). Multi-corner runs are used for comprehensive sign-off coverage across all operating conditions required by the PDK and target application specifications.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignoffRun rdf:type rdf:Property ;
    rdfs:label 'Is Signoff Run' ;
    rdfs:comment 'Indicates whether this STA run is designated as an official tapeout signoff run (True) or an intermediate/exploratory analysis run (False). Signoff runs are subject to formal design review, PLM change control, and foundry submission requirements.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libertyLibraryVersion rdf:type rdf:Property ;
    rdfs:label 'Liberty Library Version' ;
    rdfs:comment 'Version of the Liberty (.lib) timing library files used in this STA run. Liberty libraries contain cell timing models, power models, and operating condition data from the PDK. Library version directly affects timing analysis accuracy and sign-off validity.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacitanceViolationCount rdf:type rdf:Property ;
    rdfs:label 'Max Capacitance Violation Count' ;
    rdfs:comment 'Number of maximum capacitance violations reported in this STA run. Capacitance violations indicate nets with excessive load that degrade timing and signal integrity. Must be resolved through buffer insertion or net splitting before tapeout.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTransitionViolationCount rdf:type rdf:Property ;
    rdfs:label 'Max Transition Violation Count' ;
    rdfs:comment 'Number of maximum transition time violations reported in this STA run. Transition violations indicate signal edges that are too slow, potentially causing functional failures or increased power consumption. Must be resolved before tapeout signoff per PDK design rules.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primetimeVersion rdf:type rdf:Property ;
    rdfs:label 'Primetime Version' ;
    rdfs:comment 'Version of Synopsys PrimeTime used to execute this STA run (e.g., \'PrimeTime 2023.12-SP3\'). Critical for result reproducibility, audit trails, and identifying version-specific timing model differences that may affect sign-off validity.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pvtCorner rdf:type rdf:Property ;
    rdfs:label 'Pvt Corner' ;
    rdfs:comment 'Operating corner (Process-Voltage-Temperature) under which this STA run was performed (e.g., \'ss_0p72v_125c\' for slow-slow worst-case, \'ff_1p08v_m40c\' for fast-fast best-case). Defined by the PDK (Process Design Kit) and critical for sign-off coverage across all operating conditions.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the STA run results were formally reviewed and approved by the responsible design engineer or timing closure lead. Null if the run has not yet been reviewed. Required for tapeout sign-off audit trail.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Username or employee identifier of the senior design engineer or timing closure lead who reviewed and approved the results of this STA run. Required for signoff runs as part of the formal design review process before tapeout submission.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completion Timestamp' ;
    rdfs:comment 'Date and time when this Static Timing Analysis run completed execution in Synopsys PrimeTime. Used to calculate run duration and assess EDA compute resource utilization. Null if the run is still in progress or was aborted.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
    rdfs:comment 'Wall-clock duration of this STA run in seconds, from job submission to completion. Used for EDA compute resource planning, license utilization tracking, and identifying unusually long runs that may indicate tool or design issues.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runIdentifier rdf:type rdf:Property ;
    rdfs:label 'Run Identifier' ;
    rdfs:comment 'Externally-known alphanumeric run identifier assigned by the EDA tool flow or MES integration (e.g., \'PT-RUN-20240315-0042\'). Used for cross-referencing with Synopsys PrimeTime job logs, Cadence Innovus signoff reports, and Siemens Teamcenter PLM design records.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runIteration rdf:type rdf:Property ;
    rdfs:label 'Run Iteration' ;
    rdfs:comment 'Sequential iteration number of this STA run within the current design stage and PVT corner. Enables tracking of timing closure convergence across multiple optimization-analysis cycles (e.g., iteration 1 through N until timing closure is achieved).' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name or label assigned to this Static Timing Analysis run, typically encoding the design name, corner, and iteration (e.g., \'soc_top_ss_0p72v_125c_postroute_iter3\'). Used for identification in Synopsys PrimeTime run logs and design review meetings.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the design engineer describing the purpose, context, or key findings of this STA run (e.g., \'Post-ECO run after fixing 3 critical paths in clock tree\', \'Baseline run for tapeout corner coverage\'). Supports design review and knowledge transfer.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Execution lifecycle status of this STA run job in the EDA tool flow. \'submitted\' indicates the job is queued, \'running\' indicates active execution, \'completed\' indicates successful completion, \'failed\' indicates tool error or license failure, \'aborted\' indicates user-cancelled run. Distinct from timing_closure_status which reflects the timing result.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Date and time when this Static Timing Analysis run was initiated in Synopsys PrimeTime. Represents the principal business event timestamp for this record. Used for tracking timing closure progress over time and correlating with design iteration milestones.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdcConstraintsVersion rdf:type rdf:Property ;
    rdfs:label 'Sdc Constraints Version' ;
    rdfs:comment 'Version or identifier of the Synopsys Design Constraints (SDC) file used in this STA run. SDC files define clock definitions, input/output delays, and timing exceptions. Versioning ensures traceability of constraint changes across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupViolationCount rdf:type rdf:Property ;
    rdfs:label 'Setup Violation Count' ;
    rdfs:comment 'Total number of setup timing violations (negative setup slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full setup timing closure. Tracked across iterations to measure convergence progress toward tapeout readiness.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spefVersion rdf:type rdf:Property ;
    rdfs:label 'Spef Version' ;
    rdfs:comment 'Version or identifier of the SPEF (Standard Parasitic Exchange Format) file used for parasitic extraction in this STA run. SPEF files contain RC parasitics from the routed layout and directly impact timing accuracy. Null for pre-route analysis stages.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyVoltageV rdf:type rdf:Property ;
    rdfs:label 'Supply Voltage V' ;
    rdfs:comment 'Nominal supply voltage in volts (V) applied for this STA run\'s PVT corner. Defined by the PDK operating conditions and UPF (Unified Power Format) power intent. Directly impacts cell delay models and timing analysis results.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Operating temperature in degrees Celsius (°C) for this STA run\'s PVT corner. Temperature affects transistor characteristics and cell delays. Typical corners range from -40°C (automotive cold) to 125°C (worst-case hot). Defined by the PDK and target application requirements.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timingClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Timing Closure Status' ;
    rdfs:comment 'Overall timing closure pass/fail status for this STA run. \'pass\' indicates all setup and hold violations are resolved and the design meets timing at the specified PVT corner and clock frequency. \'waived\' indicates known violations accepted with engineering sign-off. \'pending_review\' indicates results awaiting design team review. Primary KPI for tapeout readiness.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoldNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Total Hold Negative Slack Ps' ;
    rdfs:comment 'Total Hold Negative Slack (THNS) in picoseconds — the sum of all negative hold slack values across all violating hold endpoints in this STA run. Complements TNS (setup) to provide a complete picture of hold timing closure status.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Total Negative Slack Ps' ;
    rdfs:comment 'Total Negative Slack (TNS) in picoseconds — the sum of all negative slack values across all violating timing endpoints in this STA run. Indicates the overall magnitude of timing violations in the design. Used alongside WNS to assess timing closure convergence across design iterations.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverCount rdf:type rdf:Property ;
    rdfs:label 'Waiver Count' ;
    rdfs:comment 'Number of timing violations formally waived with engineering sign-off in this STA run. Waivers are granted for violations on non-critical paths, test-mode-only paths, or paths with functional justification. Tracked for tapeout risk assessment and compliance with design review processes.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:worstHoldSlackPs rdf:type rdf:Property ;
    rdfs:label 'Worst Hold Slack Ps' ;
    rdfs:comment 'Worst Hold Slack (WHS) in picoseconds for hold timing analysis in this STA run. Represents the most critical hold violation — the largest shortfall in minimum path delay. Negative values indicate hold violations that must be fixed before tapeout. Applicable when analysis_mode includes hold or setup_hold.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:worstNegativeSlackPs rdf:type rdf:Property ;
    rdfs:label 'Worst Negative Slack Ps' ;
    rdfs:comment 'Worst Negative Slack (WNS) in picoseconds reported by Synopsys PrimeTime for this STA run. Represents the most critical timing violation — the largest shortfall between required and actual signal arrival time. A value of 0 or positive indicates no setup/hold violation on the worst path. Key metric for timing closure tracking.' ;
    rdfs:domain ind:TimingAnalysisRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Physical Ic Design Project Id' ;
    rdfs:comment 'FK to design.ic_design_project.ic_design_project_id — Physical layouts belong to a specific IC design project. Required for design artifact management.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:primaryPhysicalIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design record for which this physical layout iteration was produced. Links the layout to its originating design project.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:antennaViolationCount rdf:type rdf:Property ;
    rdfs:label 'Antenna Violation Count' ;
    rdfs:comment 'Number of antenna rule violations detected in the layout. Antenna violations occur when metal segments accumulate charge during plasma etching that can damage gate oxide. Must be resolved or mitigated with antenna diodes before tapeout.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Cell Utilization Pct' ;
    rdfs:comment 'Percentage of the core area occupied by placed standard cells, expressed as a decimal percentage (e.g., 72.500 = 72.5%). High utilization (>85%) may indicate routing congestion risk; low utilization (<50%) may indicate oversized floorplan.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coreAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Core Area Mm2' ;
    rdfs:comment 'Area of the core logic region in square millimeters (mm²), excluding I/O ring, power ring, and seal ring. Used to assess logic density and available routing resources.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctsInsertionDelayPs rdf:type rdf:Property ;
    rdfs:label 'Cts Insertion Delay Ps' ;
    rdfs:comment 'Clock insertion delay in picoseconds (ps) from the clock source to the farthest clock sink in the clock tree. Impacts setup timing margin and must be accounted for in static timing analysis (STA).' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctsSkewPs rdf:type rdf:Property ;
    rdfs:label 'Cts Skew Ps' ;
    rdfs:comment 'Clock skew in picoseconds (ps) achieved by the Clock Tree Synthesis (CTS) engine at this layout iteration. Measures the maximum difference in clock arrival times across all sink flip-flops. Lower skew improves timing closure margin.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dfmScore rdf:type rdf:Property ;
    rdfs:label 'Dfm Score' ;
    rdfs:comment 'Quantitative DFM (Design for Manufacturability) score assigned to this layout iteration by the DFM analysis tool (e.g., Mentor Calibre YieldAnalyzer). Higher scores indicate better manufacturability and expected yield; used to guide layout optimization before tapeout.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dftCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Dft Coverage Pct' ;
    rdfs:comment 'Fault coverage percentage achieved by the DFT (Design for Testability) implementation at this layout stage, as reported by ATPG (Automatic Test Pattern Generation) tools. Typically required to exceed 95% for production test qualification.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieAreaMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Mm2' ;
    rdfs:comment 'Total die area in square millimeters (mm²) computed from the floorplan boundary. A primary PPA (Power, Performance, Area) metric used for cost estimation, yield modeling, and competitive benchmarking.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieHeightUm rdf:type rdf:Property ;
    rdfs:label 'Die Height Um' ;
    rdfs:comment 'Height of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Together with die width, determines die area for yield and cost analysis.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieWidthUm rdf:type rdf:Property ;
    rdfs:label 'Die Width Um' ;
    rdfs:comment 'Width of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Used for package selection, wafer yield estimation, and cost modeling.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drcCriticalViolationCount rdf:type rdf:Property ;
    rdfs:label 'Drc Critical Violation Count' ;
    rdfs:comment 'Number of DRC violations classified as critical (yield-impacting or functionality-blocking) as opposed to waivable violations. Critical DRC violations must be resolved before tapeout; waivable violations may be accepted with foundry approval.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drcViolationCount rdf:type rdf:Property ;
    rdfs:label 'Drc Violation Count' ;
    rdfs:comment 'Total number of Design Rule Check (DRC) violations detected in this layout iteration by the signoff DRC tool (e.g., Mentor Calibre, Synopsys IC Validator). A value of zero is required for tapeout approval.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edaTool rdf:type rdf:Property ;
    rdfs:label 'Eda Tool' ;
    rdfs:comment 'EDA tool used to produce this physical layout iteration. Identifies the physical implementation platform (Cadence Innovus, Synopsys IC Compiler 2, Siemens Aprisa, or Cadence Virtuoso for custom layouts) for provenance and reproducibility.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emCompliant rdf:type rdf:Property ;
    rdfs:label 'Em Compliant' ;
    rdfs:comment 'Indicates whether all metal interconnects in the layout comply with electromigration (EM) current density limits specified by the foundry PDK. TRUE = EM compliant; FALSE = EM violations present requiring wire widening or rerouting.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsFileFormat rdf:type rdf:Property ;
    rdfs:label 'Gds File Format' ;
    rdfs:comment 'Format of the layout database file referenced in gds_file_path. GDSII is the traditional foundry submission format; OASIS (Open Artwork System Interchange Standard) is the modern compressed alternative; LEF/DEF is used for abstract/physical exchange.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStage rdf:type rdf:Property ;
    rdfs:label 'Implementation Stage' ;
    rdfs:comment 'Current stage in the physical implementation flow for this layout iteration. Stages progress from initial floorplan through placement, clock tree synthesis (CTS), routing, signoff, and final tapeout submission. [ENUM-REF-CANDIDATE: floorplan|placement|cts|routing|signoff|tapeout — promote to reference product if additional stages are needed]' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irDropMaxMv rdf:type rdf:Property ;
    rdfs:label 'Ir Drop Max Mv' ;
    rdfs:comment 'Maximum static IR drop in millivolts (mV) observed in the power grid analysis at this layout iteration. Excessive IR drop degrades circuit performance and reliability; must remain within foundry-specified limits for tapeout approval.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iterationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Iteration Timestamp' ;
    rdfs:comment 'Timestamp when this physical layout iteration checkpoint was captured and committed to the design database. Represents the principal business event time for this layout record, enabling chronological tracking of design progress.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:layoutName rdf:type rdf:Property ;
    rdfs:label 'Layout Name' ;
    rdfs:comment 'Human-readable name identifying this physical layout iteration, typically including the design name and iteration label (e.g., \'SoC_v3_floorplan_iter2\'). Used in Cadence Innovus and Synopsys ICC2 project naming conventions.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutStatus rdf:type rdf:Property ;
    rdfs:label 'Layout Status' ;
    rdfs:comment 'Lifecycle status of this physical layout record. Tracks whether the layout is actively being worked on, under design review, approved for next stage, rejected requiring rework, or archived as a historical iteration.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutVersion rdf:type rdf:Property ;
    rdfs:label 'Layout Version' ;
    rdfs:comment 'Version identifier for this physical layout iteration following semantic versioning (e.g., \'1.0.0\', \'2.3.1\'). Tracks incremental changes through the physical implementation flow from floorplan to tapeout.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lvsClean rdf:type rdf:Property ;
    rdfs:label 'Lvs Clean' ;
    rdfs:comment 'Indicates whether the physical layout passes Layout Versus Schematic (LVS) verification with zero errors, confirming that the layout netlist matches the schematic netlist. TRUE = LVS clean (required for tapeout); FALSE = LVS errors present.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metalFillDensityPct rdf:type rdf:Property ;
    rdfs:label 'Metal Fill Density Pct' ;
    rdfs:comment 'Average metal fill density percentage across all metal layers after dummy metal fill insertion. Foundry CMP (Chemical Mechanical Planarization) processes require metal density to remain within specified min/max bounds to ensure planar surfaces.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerConsumptionMw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Mw' ;
    rdfs:comment 'Estimated total power consumption in milliwatts (mW) from power analysis at this layout iteration, including dynamic switching power and static leakage power. A key PPA (Power, Performance, Area) metric for product specification compliance.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingCongestionLayer rdf:type rdf:Property ;
    rdfs:label 'Routing Congestion Layer' ;
    rdfs:comment 'Metal layer identifier (e.g., \'M4\', \'M7\') where the maximum routing congestion was observed. Used to guide targeted floorplan or placement adjustments to relieve congestion on the most constrained layer.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCongestionMaxPct rdf:type rdf:Property ;
    rdfs:label 'Routing Congestion Max Pct' ;
    rdfs:comment 'Maximum routing congestion percentage observed across all metal layers in the layout, expressed as overflow percentage. Values above 5% typically indicate routing closure risk requiring floorplan or placement adjustment.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Tapeout Date' ;
    rdfs:comment 'Date on which the final GDSII/OASIS layout was submitted to the foundry for mask generation (tapeout). A critical milestone in the IC design lifecycle tracked against the product TTM (Time to Market) schedule.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tnsPs rdf:type rdf:Property ;
    rdfs:label 'Tns Ps' ;
    rdfs:comment 'Total Negative Slack (TNS) in picoseconds (ps), representing the sum of all negative slack values across all timing paths. Indicates the overall magnitude of timing violations in the design; must reach zero for tapeout signoff.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCellCount rdf:type rdf:Property ;
    rdfs:label 'Total Cell Count' ;
    rdfs:comment 'Total number of standard cells placed in the core area at this layout iteration. Includes combinational logic, sequential elements, buffers, and inverters. Used to assess design complexity and placement density.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wnsPs rdf:type rdf:Property ;
    rdfs:label 'Wns Ps' ;
    rdfs:comment 'Worst Negative Slack (WNS) in picoseconds (ps) from static timing analysis at this layout iteration. Negative values indicate timing violations; zero or positive values indicate timing closure. A key metric for tapeout readiness.' ;
    rdfs:domain ind:PhysicalLayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTapeoutIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Tapeout Ic Design Project Id' ;
    rdfs:comment 'Reference to the parent IC design record from which this tapeout was generated. Links tapeout provenance back to the design lifecycle in the design domain.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:verificationPlanId rdf:type rdf:Property ;
    rdfs:label 'Verification Plan Id' ;
    rdfs:comment 'Foreign key linking to design.verification_plan. Business justification: Tapeout is the final design submission milestone and requires full verification sign-off as a prerequisite. Linking tapeout to the verification_plan that was completed and signed off provides end-to-e' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VerificationPlan .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable name of the IC design being taped out (e.g., product code name or internal design designation). Used for identification in design review meetings and foundry communications.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRevision rdf:type rdf:Property ;
    rdfs:label 'Design Revision' ;
    rdfs:comment 'Revision identifier of the design at the time of tapeout (e.g., A0, B1, C2). Distinguishes successive tapeout iterations of the same design, critical for mask set versioning and silicon bring-up tracking.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieSizeMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Size Mm2' ;
    rdfs:comment 'Physical area of the die in square millimeters as defined in the final GDS layout at tapeout. A key Power-Performance-Area (PPA) metric used for cost modeling, yield estimation, and wafer utilization planning.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drcClean rdf:type rdf:Property ;
    rdfs:label 'Drc Clean' ;
    rdfs:comment 'Indicates whether the final GDS layout passed all Design Rule Check (DRC) violations with zero errors at the time of tapeout submission. A TRUE value is a mandatory tapeout sign-off criterion per foundry requirements.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ercClean rdf:type rdf:Property ;
    rdfs:label 'Erc Clean' ;
    rdfs:comment 'Indicates whether the design passed Electrical Rule Check (ERC) with no violations at tapeout. ERC validates electrical connectivity integrity including floating nodes, antenna violations, and electromigration rules.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedYieldPct rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Pct' ;
    rdfs:comment 'Predicted die yield percentage (good dies per wafer as a percentage of total dies per wafer) at the time of tapeout, based on DFM analysis and process node historical yield data. Used for production planning and cost-per-die estimation.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundryName rdf:type rdf:Property ;
    rdfs:label 'Foundry Name' ;
    rdfs:comment 'Name of the semiconductor fabrication facility (FAB) or foundry to which the tapeout was submitted (e.g., TSMC, Samsung Foundry, GlobalFoundries, Intel Foundry Services). Used for supply chain and vendor management reporting.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundrySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Foundry Submission Ref' ;
    rdfs:comment 'Foundry-assigned reference number or confirmation code for the tapeout submission. Used to track the submission status with the external foundry partner and cross-reference with foundry manufacturing orders.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsFileVersion rdf:type rdf:Property ;
    rdfs:label 'Gds File Version' ;
    rdfs:comment 'Version identifier of the final GDS/GDSII layout file submitted for tapeout. Provides design data provenance linking the physical layout file to the tapeout event. Sourced from Cadence Virtuoso or equivalent EDA tool.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipSignOffComplete rdf:type rdf:Property ;
    rdfs:label 'Ip Sign Off Complete' ;
    rdfs:comment 'Indicates whether all third-party and internal Intellectual Property (IP) cores integrated in the design have received sign-off approval for inclusion in the tapeout. Ensures IP licensing compliance and integration verification are complete.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskCostUsd rdf:type rdf:Property ;
    rdfs:label 'Mask Cost Usd' ;
    rdfs:comment 'Cost of the photolithography mask set fabrication for this tapeout in US dollars. A major component of NRE cost, tracked separately for cost accounting and foundry invoice reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maskCount rdf:type rdf:Property ;
    rdfs:label 'Mask Count' ;
    rdfs:comment 'Total number of photolithography masks in the mask set for this tapeout. Directly drives NRE mask cost and is a key input to tapeout cost modeling. Includes FEOL, MOL, and BEOL layers.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRetStatus rdf:type rdf:Property ;
    rdfs:label 'Opc Ret Status' ;
    rdfs:comment 'Processing status of Optical Proximity Correction (OPC) and Resolution Enhancement Technology (RET) applied to the GDS data prior to mask tape-out. OPC/RET is mandatory for sub-28nm nodes to compensate for photolithographic distortion effects.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processNode rdf:type rdf:Property ;
    rdfs:label 'Process Node' ;
    rdfs:comment 'Semiconductor manufacturing process node used for this tapeout, expressed as a technology node designation (e.g., 5nm, 7nm, 28nm, 65nm). Defines the lithography generation and transistor geometry for the fabricated IC.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTechnology rdf:type rdf:Property ;
    rdfs:label 'Process Technology' ;
    rdfs:comment 'Transistor architecture and process technology type used for this tapeout. Distinguishes between planar CMOS, FinFET, Gate-All-Around (GAA), and specialty process technologies relevant to device performance and yield modeling. [ENUM-REF-CANDIDATE: CMOS|FinFET|GAA|BiCMOS|SiGe|GaN|SiC|SOI — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Signoff Checklist Complete' ;
    rdfs:comment 'Indicates whether all items on the design sign-off checklist have been completed and approved prior to tapeout submission. The checklist covers DRC, LVS, ERC, timing closure, power analysis, DFT, and IP sign-off milestones.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tapeoutNumber rdf:type rdf:Property ;
    rdfs:label 'Tapeout Number' ;
    rdfs:comment 'Externally-known business identifier for the tapeout event, used in communications with the foundry, mask house, and internal design teams. Follows the format TO-<DESIGN_CODE>-<YEAR>.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Tapeout Status' ;
    rdfs:comment 'Current lifecycle state of the tapeout event. Tracks progression from internal preparation through foundry acceptance or rejection. [ENUM-REF-CANDIDATE: draft|pending_signoff|submitted|accepted|rejected|cancelled — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeoutType rdf:type rdf:Property ;
    rdfs:label 'Tapeout Type' ;
    rdfs:comment 'Classification of the tapeout run type. Distinguishes full custom dedicated wafer tapeouts, Multi-Project Wafer (MPW) shuttle runs, engineering sample tapeouts, and production tapeouts. Drives cost allocation and foundry scheduling.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary market segment for which the taped-out IC is designed. Used for business reporting, revenue forecasting, and strategic portfolio analysis. [ENUM-REF-CANDIDATE: mobile|automotive|datacenter|IoT|industrial|consumer|aerospace_defense|networking — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTapeoutDate rdf:type rdf:Property ;
    rdfs:label 'Target Tapeout Date' ;
    rdfs:comment 'Originally planned tapeout date as committed in the project schedule. Used to measure schedule adherence and Time to Market (TTM) variance against the actual tapeout date.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferCountOrdered rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Ordered' ;
    rdfs:comment 'Number of wafers ordered from the foundry for this tapeout run. Used for production planning, yield forecasting, and supply chain management. Applicable for dedicated tapeouts; for MPW runs, this reflects the allocated wafer share.' ;
    rdfs:domain ind:Tapeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipCoreUsageId rdf:type rdf:Property ;
    rdfs:label 'Ip Core Usage Id' ;
    rdfs:comment 'Unique surrogate identifier for each IP core integration instance record within a design project. Primary key for the ip_core_usage entity.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIpCoreId rdf:type rdf:Property ;
    rdfs:label 'Primary Ip Core Id' ;
    rdfs:comment 'Reference to the specific IP core being integrated. Identifies the IP block (e.g., PCIe controller, DDR PHY, USB subsystem) from the IP catalog.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpCore .

ind:primaryIpIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Ip Ic Design Project Id' ;
    rdfs:comment 'Reference to the IC design project (SoC, ASIC, or FPGA design) into which this IP core version is being integrated. Links the usage record to the parent design context.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:sourceDesignProjectIcDesignProjectId rdf:type rdf:Property ;
    rdfs:label 'Source Design Project Ic Design Project Id' ;
    rdfs:comment 'Reference to the original design project from which this IP core integration was reused, when ip_reuse_flag is True. Enables IP reuse lineage tracking and qualification inheritance assessment.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcDesignProject .

ind:areaConsumedUm2 rdf:type rdf:Property ;
    rdfs:label 'Area Consumed Um2' ;
    rdfs:comment 'Physical silicon area consumed by this IP core integration in square micrometers (µm²). Used for die area budget tracking, PPA (Power, Performance, Area) analysis, and cost estimation.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clockFrequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Clock Frequency Mhz' ;
    rdfs:comment 'Target operating clock frequency in megahertz (MHz) for this IP core integration in the design context. Used for timing closure planning and STA (Static Timing Analysis) constraint setup.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationParameters rdf:type rdf:Property ;
    rdfs:label 'Configuration Parameters' ;
    rdfs:comment 'Serialized key-value string of configuration parameters applied to this IP core instance (e.g., data_width=64, num_channels=8, fifo_depth=512). Captures the specific parameterization used in this design context for reproducibility and IP reuse analytics.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designHierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Design Hierarchy Path' ;
    rdfs:comment 'Full hierarchical path of the IP core instance within the design netlist (e.g., \'top/subsystem_a/pcie_ctrl_0\'). Enables precise identification of the IP instance location in the design hierarchy for debug, ECO, and physical implementation.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCoveragePct rdf:type rdf:Property ;
    rdfs:label 'Functional Coverage Pct' ;
    rdfs:comment 'Functional verification coverage percentage achieved for this IP core integration, as reported by the verification environment. Used for sign-off readiness assessment and quality gate enforcement.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instanceCount rdf:type rdf:Property ;
    rdfs:label 'Instance Count' ;
    rdfs:comment 'Number of times this IP core is instantiated within the design project (e.g., 4 instances of a SERDES PHY). Drives royalty calculation for royalty-bearing IP and area budget planning.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationStartDate rdf:type rdf:Property ;
    rdfs:label 'Integration Start Date' ;
    rdfs:comment 'Calendar date on which integration of this IP core into the design project was initiated. Used for project timeline tracking, TTM (Time to Market) analysis, and design schedule management.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current lifecycle state of the IP core integration within the design project. Tracks progression from initial selection through silicon validation: planned (selected but not yet integrated), in_progress (integration underway), verified (simulation/emulation verified), silicon_proven (validated on fabricated silicon).' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interfaceProtocol rdf:type rdf:Property ;
    rdfs:label 'Interface Protocol' ;
    rdfs:comment 'Primary bus or interface protocol used to connect this IP core to the SoC interconnect fabric (e.g., AXI4, AHB, APB, CHI, TileLink, OCP). Critical for integration verification and bus protocol compliance checking. [ENUM-REF-CANDIDATE: AXI4|AHB|APB|CHI|TileLink|OCP|AXI4-Lite|AXI4-Stream|Wishbone|AMBA — promote to reference product]' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCoreVersion rdf:type rdf:Property ;
    rdfs:label 'Ip Core Version' ;
    rdfs:comment 'Specific version identifier of the IP core being integrated (e.g., 2.1.0, 3.0.0-rc1). Tracks which release of the IP block is used in this design context to support IP lifecycle and change management.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipReuseFlag rdf:type rdf:Property ;
    rdfs:label 'Ip Reuse Flag' ;
    rdfs:comment 'Indicates whether this IP core integration is a reuse of a previously silicon-proven instance from another design project (True = reused IP, False = first-time integration). Enables IP reuse analytics and NRE cost avoidance tracking.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDfmCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Dfm Compliant' ;
    rdfs:comment 'Indicates whether this IP core integration has passed DFM (Design for Manufacturability) rule checks for the target process node (True = DFM compliant). Critical for yield optimization and tapeout readiness sign-off.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDftEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Dft Enabled' ;
    rdfs:comment 'Indicates whether DFT (Design for Testability) structures such as scan chains, BIST, or JTAG boundary scan are enabled for this IP core integration (True = DFT enabled). Impacts ATPG test pattern generation and ATE test coverage.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSiliconProven rdf:type rdf:Property ;
    rdfs:label 'Is Silicon Proven' ;
    rdfs:comment 'Indicates whether this IP core version has been validated on fabricated silicon within this specific design project context (True = silicon-proven, False = not yet silicon-proven). Key qualifier for IP reuse qualification and KGD (Known Good Die) assessments.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdkNode rdf:type rdf:Property ;
    rdfs:label 'Pdk Node' ;
    rdfs:comment 'Semiconductor process technology node for which this IP core version is qualified (e.g., \'5nm\', \'7nm\', \'28nm\'). Ensures IP-PDK compatibility and is critical for physical design sign-off and DFM compliance.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerContributionMw rdf:type rdf:Property ;
    rdfs:label 'Power Contribution Mw' ;
    rdfs:comment 'Estimated power consumption contributed by this IP core integration in milliwatts (mW), covering dynamic and static power. Used for top-level power budget analysis and PPA optimization.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Per Unit' ;
    rdfs:comment 'Per-unit royalty rate in US dollars payable to the IP licensor for each chip shipped containing this IP core. Applicable only for royalty_bearing license types. Used for royalty obligation forecasting and financial accruals.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Calendar date on which the formal design sign-off for this IP core integration was granted or last updated. Used for tapeout readiness tracking and audit trail.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Design sign-off status for this IP core integration, reflecting the outcome of formal design review and approval gates (pending, approved, rejected, waived). Required for tapeout readiness and quality gate compliance.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siliconValidationDate rdf:type rdf:Property ;
    rdfs:label 'Silicon Validation Date' ;
    rdfs:comment 'Calendar date on which silicon validation of this IP core integration was completed, confirming silicon-proven status. Null if silicon validation has not yet occurred.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timingBudgetNs rdf:type rdf:Property ;
    rdfs:label 'Timing Budget Ns' ;
    rdfs:comment 'Timing budget allocated to this IP core integration in nanoseconds (ns), representing its contribution to the top-level timing closure budget. Derived from Synopsys PrimeTime timing analysis and used for STA sign-off.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageToCore rdf:type rdf:Property ;
    rdfs:label 'Usage To Core' ;
    rdfs:comment 'FK to design.ip_core.ip_core_id — IP core usage records which IP core is being integrated. This is the fundamental FK for the association record.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Verification Completion Date' ;
    rdfs:comment 'Calendar date on which functional verification of this IP core integration was completed and signed off. Marks the transition from in_progress to verified integration status.' ;
    rdfs:domain ind:IpCoreUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethodology rdf:type rdf:Property ;
    rdfs:label 'Verification Methodology' ;
    rdfs:comment 'Verification methodology applied to validate this IP core integration (e.g., UVM, OVM, formal verification, emulation, FPGA prototype). Determines verification coverage and sign-off criteria. [ENUM-REF-CANDIDATE: UVM|OVM|VMM|formal|emulation|FPGA_prototype|mixed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assertionCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Assertion Coverage Target Pct' ;
    rdfs:comment 'Target percentage of SystemVerilog Assertions (SVA) or PSL assertions that must be exercised and pass during simulation. Assertion coverage is a key metric for protocol compliance and corner-case verification completeness.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bugTrackingProjectKey rdf:type rdf:Property ;
    rdfs:label 'Bug Tracking Project Key' ;
    rdfs:comment 'Project key or identifier in the bug tracking system corresponding to this verification plan (e.g., \'SOC-X5-VER\'). Used to hyperlink verification failures to the defect management workflow.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bugTrackingSystem rdf:type rdf:Property ;
    rdfs:label 'Bug Tracking System' ;
    rdfs:comment 'Name of the defect/bug tracking system integrated with this verification plan for logging simulation failures and RTL bugs (e.g., \'Jira\', \'Bugzilla\', \'Synopsys Serenity\'). Enables traceability from verification failures to RTL fixes.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Code Coverage Target Pct' ;
    rdfs:comment 'Target code coverage closure percentage (line, branch, condition, expression, FSM) required for sign-off. Complements functional coverage to ensure structural completeness of the RTL simulation. Tracked against EDA tool-reported actuals.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emulationPlatform rdf:type rdf:Property ;
    rdfs:label 'Emulation Platform' ;
    rdfs:comment 'Hardware emulation platform used for pre-silicon software bring-up and system-level verification (e.g., \'Cadence Palladium Z2\', \'Synopsys ZeBu\', \'Mentor Veloce\'). Null if emulation is not in scope for this plan.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fault Coverage Target Pct' ;
    rdfs:comment 'Target stuck-at and transition fault coverage percentage for ATPG-generated test patterns. Typically 99%+ for automotive/safety-critical designs per IATF 16949 and ISO 26262. Drives DFT insertion effort and scan chain architecture decisions.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultInjectionCampaignPlanned rdf:type rdf:Property ;
    rdfs:label 'Fault Injection Campaign Planned' ;
    rdfs:comment 'Indicates whether a structured fault injection campaign is planned as part of this verification plan to validate safety mechanisms per ISO 26262. True for ASIL-B and above designs. Drives resource allocation for fault simulation infrastructure.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmedaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Fmeda Document Reference' ;
    rdfs:comment 'Reference identifier of the linked FMEDA document in the PLM system. The FMEDA quantifies diagnostic coverage and safe failure fraction for ISO 26262 hardware metrics compliance. Null for non-safety designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formalVerificationTool rdf:type rdf:Property ;
    rdfs:label 'Formal Verification Tool' ;
    rdfs:comment 'EDA tool used for formal property checking and equivalence checking (e.g., \'Synopsys VC Formal\', \'Cadence JasperGold\', \'OneSpin 360\'). Null if formal verification is not part of the plan methodology.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpgaPrototypePlatform rdf:type rdf:Property ;
    rdfs:label 'Fpga Prototype Platform' ;
    rdfs:comment 'FPGA prototyping board or platform used for early software validation and system integration testing (e.g., \'Xilinx VCU128\', \'Intel Stratix 10 GX\', \'Aldec HES-US-440\'). Null if FPGA prototyping is not in scope.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipReuseCount rdf:type rdf:Property ;
    rdfs:label 'Ip Reuse Count' ;
    rdfs:comment 'Number of third-party or internal IP cores integrated into this design that require verification waivers or pre-verified IP sign-off. Impacts the scope of the verification plan and the testbench architecture for IP interface compliance.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso26262AsilDecomposition rdf:type rdf:Property ;
    rdfs:label 'Iso26262 Asil Decomposition' ;
    rdfs:comment 'Description of the ASIL decomposition strategy applied to this design per ISO 26262 Part 9. Documents how a higher ASIL requirement is decomposed into two independent lower-ASIL sub-elements (e.g., \'ASIL D decomposed to ASIL B + ASIL B\'). Mandatory for automotive safety-critical IC designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Planned completion date for all verification activities and sign-off, aligned with the tapeout schedule. A key TTM (Time to Market) planning date. Slippage triggers NRE (Non-Recurring Engineering) cost impact analysis.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive human-readable name for the verification plan, typically including the IC design project name and verification phase (e.g., \'SoC-X5 Full-Chip Functional Verification Plan v2.1\'). Used in dashboards, reports, and PLM document management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the verification plan, typically assigned by the PLM system (e.g., Oracle Agile PLM or Siemens Teamcenter). Format: DVP-<PROJECT_CODE>-<YEAR>-<SEQ>. Used in cross-functional communications, tapeout checklists, and audit trails.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Planned start date for verification activities as defined in the project schedule. Used for milestone tracking, resource planning, and TTM (Time to Market) analysis.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the verification plan document. Drives workflow approvals and tapeout gate readiness. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|on_hold|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the verification plan document following semantic versioning (e.g., \'1.0\', \'2.3\', \'3.1.2\'). Incremented upon each approved revision cycle in the PLM system. Critical for traceability to tapeout sign-off.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionRunFrequency rdf:type rdf:Property ;
    rdfs:label 'Regression Run Frequency' ;
    rdfs:comment 'Planned frequency at which the regression suite is executed. Continuous integration runs on every RTL commit; nightly runs are scheduled overnight; milestone-triggered runs occur at defined project gates; on-demand runs are manually initiated.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regressionSuiteName rdf:type rdf:Property ;
    rdfs:label 'Regression Suite Name' ;
    rdfs:comment 'Name of the primary regression test suite defined in this verification plan (e.g., \'SoC_Full_Regression_v3\', \'CPU_Smoke_Suite\'). The regression suite defines the set of simulation tests run nightly or at milestone gates to track coverage progress.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Criticality Level' ;
    rdfs:comment 'Functional safety classification of the IC design per ISO 26262 (automotive ASIL) or IEC 61508 (industrial SIL). Drives the rigor of fault injection campaigns, FMEDA linkage, and safety mechanism coverage targets within the verification plan. Non-safety designs are tagged \'non_safety\'. [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|non_safety — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyMechanismCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Safety Mechanism Coverage Target Pct' ;
    rdfs:comment 'Target percentage of identified safety mechanisms that must be verified through simulation, formal analysis, or fault injection campaigns. Required for ISO 26262 hardware verification sign-off. Null for non-safety designs.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scanChainCount rdf:type rdf:Property ;
    rdfs:label 'Scan Chain Count' ;
    rdfs:comment 'Number of scan chains defined in the DFT architecture for this design. Determines ATPG test time, test data volume, and ATE (Automatic Test Equipment) channel requirements. A key DFT planning parameter.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signoffApproved rdf:type rdf:Property ;
    rdfs:label 'Signoff Approved' ;
    rdfs:comment 'Indicates whether all verification sign-off criteria have been met and formal approval has been granted to proceed to tapeout. True only after all coverage targets, regression pass rates, and safety requirements are satisfied.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signoffCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Signoff Criteria Description' ;
    rdfs:comment 'Textual description of the complete set of criteria that must be satisfied before verification sign-off is granted and tapeout is authorized. Includes coverage closure thresholds, zero-open-critical-bug requirement, regression pass rate, and formal proof completion.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffDate rdf:type rdf:Property ;
    rdfs:label 'Signoff Date' ;
    rdfs:comment 'Actual date on which verification sign-off was formally approved. Null until sign-off is granted. Used for tapeout readiness confirmation and post-silicon correlation analysis.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulationTool rdf:type rdf:Property ;
    rdfs:label 'Simulation Tool' ;
    rdfs:comment 'Primary EDA simulation tool assigned for RTL and gate-level simulation (e.g., \'Synopsys VCS\', \'Cadence Xcelium\', \'Mentor Questa\'). Determines the simulation environment configuration, license requirements, and regression infrastructure.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testbenchArchitecture rdf:type rdf:Property ;
    rdfs:label 'Testbench Architecture' ;
    rdfs:comment 'Structural architecture of the simulation testbench. UVM_layered follows the standard UVM agent/scoreboard/coverage hierarchy; directed uses manually written test vectors; constrained_random uses SystemVerilog randomization; cocotb uses Python-based co-simulation; SystemC uses transaction-level modeling. [ENUM-REF-CANDIDATE: UVM_layered|directed|constrained_random|hybrid|cocotb|SystemC — promote to reference product]' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toggleCoverageTargetPct rdf:type rdf:Property ;
    rdfs:label 'Toggle Coverage Target Pct' ;
    rdfs:comment 'Target toggle coverage percentage for all RTL signals, ensuring each net transitions both 0→1 and 1→0 during simulation. Used as a DFT readiness indicator and a structural verification completeness metric.' ;
    rdfs:domain ind:VerificationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Packaging Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:primaryIcProcessNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Process Node Id' ;
    rdfs:comment 'FK to product.process_node.process_node_id — Every IC product is manufactured on a specific process node. This is a fundamental product attribute that references the process node master.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessNode .

ind:aecQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Aec Qualification Level' ;
    rdfs:comment 'Specific AEC qualification standard met. Q100: ICs, Q101: Discretes, Q102: Optoelectronics, Q200: Passives. Set to NA if not automotive qualified.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveQualified rdf:type rdf:Property ;
    rdfs:label 'Automotive Qualified' ;
    rdfs:comment 'Indicates whether the product has passed automotive-grade qualification testing per AEC-Q standards. Required for automotive market. Includes extended temperature, reliability, and quality requirements.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogToFamily rdf:type rdf:Property ;
    rdfs:label 'Catalog To Family' ;
    rdfs:comment 'FK to product.product_family.product_family_id — Every IC product belongs to a product family in the taxonomy hierarchy. This is the primary classification FK.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the IC was manufactured or substantially transformed. Used for trade compliance, tariffs, and country-of-origin marking requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartNumber rdf:type rdf:Property ;
    rdfs:label 'External Part Number' ;
    rdfs:comment 'Customer-facing orderable part number published in datasheets and used for commercial transactions. May differ from internal part number for marketing or legacy reasons.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSiliconDate rdf:type rdf:Property ;
    rdfs:label 'First Silicon Date' ;
    rdfs:comment 'Date when first fabricated silicon wafers were received from the fab for initial testing and validation. Marks start of silicon bring-up phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'US Harmonized Tariff Schedule classification code for customs and import duty determination. Format: 8542.31.0000 for electronic integrated circuits.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPartNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Part Number' ;
    rdfs:comment 'Company-assigned unique part number for internal identification, tracking, and PLM integration. Primary business identifier for the IC design.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this catalog entry is currently active and available for business operations. False indicates archived or soft-deleted record retained for historical reference.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Ship Date' ;
    rdfs:comment 'Final date when product shipments will be made. Marks complete discontinuation of the product. Typically 6-12 months after last-time-buy date to allow for manufacturing lead time.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'Final date for customers to place orders before product is discontinued. Typically 6-12 months after EOL announcement. After this date, no new orders are accepted.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadFreeCompliant rdf:type rdf:Property ;
    rdfs:label 'Lead Free Compliant' ;
    rdfs:comment 'Indicates whether the product meets RoHS (Restriction of Hazardous Substances) lead-free requirements. True if compliant with EU RoHS Directive for lead-free solder and materials.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this IC catalog record was last updated. Tracks data currency and change history for audit and synchronization purposes.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:npiPhase rdf:type rdf:Property ;
    rdfs:label 'Npi Phase' ;
    rdfs:comment 'Detailed phase within NPI lifecycle for products in pre-production stages. Tracks progress from concept through design, tapeout, silicon bring-up, and qualification. Set to NA for production products. [ENUM-REF-CANDIDATE: Concept|Design|Tapeout|Silicon_Validation|Qualification|Ramp|Production|NA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingFrequencyMaxMhz rdf:type rdf:Property ;
    rdfs:label 'Operating Frequency Max Mhz' ;
    rdfs:comment 'Maximum clock frequency in MHz at which the IC can reliably operate. Key performance metric for processors, SoCs, and high-speed digital circuits. Part of PPA metrics.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMaxV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Max V' ;
    rdfs:comment 'Maximum supply voltage in volts for safe operation. Defines upper bound of operating voltage range. Exceeding this may cause device damage or reliability issues.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageMinV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Min V' ;
    rdfs:comment 'Minimum supply voltage in volts for guaranteed operation. Defines lower bound of operating voltage range for power optimization and battery operation.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pinCount rdf:type rdf:Property ;
    rdfs:label 'Pin Count' ;
    rdfs:comment 'Total number of external pins or balls on the package. Determines PCB routing complexity, package cost, and I/O capability.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerMaxMw rdf:type rdf:Property ;
    rdfs:label 'Power Max Mw' ;
    rdfs:comment 'Maximum power consumption in milliwatts under worst-case operating conditions. Used for thermal design, power supply sizing, and system integration planning.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerTypicalMw rdf:type rdf:Property ;
    rdfs:label 'Power Typical Mw' ;
    rdfs:comment 'Typical operating power consumption in milliwatts under nominal conditions. Critical PPA metric for mobile, IoT, and battery-powered applications. Measured at specified voltage and frequency.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the semiconductor product type. Determines design flow, manufacturing process, and business model (silicon vs. licensable IP). [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Memory|Analog|Mixed_Signal|RF — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Production Release Date' ;
    rdfs:comment 'Date when product was officially released to production status and made available for volume manufacturing and customer orders. Marks end of qualification phase.' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reachCompliant rdf:type rdf:Property ;
    rdfs:label 'Reach Compliant' ;
    rdfs:comment 'Indicates compliance with EU REACH (Registration, Evaluation, Authorization and Restriction of Chemicals) regulation. Confirms no Substances of Very High Concern (SVHC) above threshold.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Primary market segment or application domain for which the IC is designed. Determines qualification requirements, reliability standards, and regulatory compliance needs. [ENUM-REF-CANDIDATE: Automotive|Consumer|Industrial|Medical|Aerospace|Defense|Telecom|Computing|IoT|AI_ML — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureGrade rdf:type rdf:Property ;
    rdfs:label 'Temperature Grade' ;
    rdfs:comment 'Temperature range classification determining qualified operating environment. Commercial: 0-70C, Industrial: -40-85C, Automotive: -40-125C, Military: -55-125C. Critical for market qualification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transistorCount rdf:type rdf:Property ;
    rdfs:label 'Transistor Count' ;
    rdfs:comment 'Total number of transistors on the die. Key complexity metric for digital ICs and SoCs. Used for design effort estimation and manufacturing complexity assessment.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Reference to the recommended replacement SKU for customers when this SKU reaches end of life. Facilitates design migration and continuity planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:toIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'To Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Every SKU is an orderable variant of a catalog product. This is the most fundamental FK in the domain — without it, SKUs are orphaned from their parent product definition.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:customerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Part Number' ;
    rdfs:comment 'Optional customer-specific part number assigned to this SKU for custom or design-win scenarios. Facilitates customer BOM alignment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eccnCode rdf:type rdf:Property ;
    rdfs:label 'Eccn Code' ;
    rdfs:comment 'US Bureau of Industry and Security (BIS) Export Administration Regulations (EAR) classification code. Determines export licensing requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halogenFree rdf:type rdf:Property ;
    rdfs:label 'Halogen Free' ;
    rdfs:comment 'Indicates whether this SKU is manufactured without halogen-containing materials (chlorine, bromine compounds). Required for certain environmental certifications.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this SKU was first made available for customer orders. Marks the transition from NPI to Active lifecycle status.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeWeeks rdf:type rdf:Property ;
    rdfs:label 'Lead Time Weeks' ;
    rdfs:comment 'Typical manufacturing and delivery lead time in weeks from order placement to shipment. Subject to capacity allocation and supply chain conditions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Published list price in US dollars for this SKU at 1000-unit quantity. Actual transaction prices subject to volume discounts and customer agreements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Official manufacturer part number assigned to this SKU. Used for cross-reference with distributor catalogs and customer Bill of Materials (BOM).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Smallest quantity that can be ordered for this SKU in a single purchase order line. Driven by packaging constraints and economic order quantities.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moistureSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitivity Level' ;
    rdfs:comment 'JEDEC moisture sensitivity classification indicating required storage and handling conditions before reflow soldering. MSL1 (unlimited floor life) to MSL6 (mandatory bake before use). [ENUM-REF-CANDIDATE: MSL1|MSL2|MSL2a|MSL3|MSL4|MSL5|MSL5a|MSL6 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently available for new customer orders. May be false during allocation, quality holds, or phase-out periods.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcn Required Flag' ;
    rdfs:comment 'Indicates whether any changes to this SKU specification, manufacturing process, or supply chain require formal Product Change Notification (PCN) to customers per contractual or regulatory requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Qualification Level' ;
    rdfs:comment 'Reliability and qualification standard met by this SKU. AEC-Q100 for automotive ICs, AEC-Q101 for discrete automotive, MIL-STD-883 for military/aerospace.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippableFlag rdf:type rdf:Property ;
    rdfs:label 'Shippable Flag' ;
    rdfs:comment 'Indicates whether this SKU is currently authorized for shipment. May be false during quality holds, regulatory blocks, or export restrictions.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speedGrade rdf:type rdf:Property ;
    rdfs:label 'Speed Grade' ;
    rdfs:comment 'Performance binning classification indicating maximum operating frequency or timing specification. Higher grades command premium pricing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Fully-loaded standard manufacturing cost in US dollars including wafer fabrication, assembly, test, and allocated overhead. Used for margin analysis and inventory valuation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPackQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Pack Quantity' ;
    rdfs:comment 'Number of units in a standard shipping container (tape and reel, tray, tube). Orders are typically placed in multiples of this quantity.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRange rdf:type rdf:Property ;
    rdfs:label 'Temperature Range' ;
    rdfs:comment 'Qualified operating temperature range classification. Commercial (0-70C), Industrial (-40-85C), Automotive (-40-125C), Military (-55-125C), Extended (-40-105C).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitWeightGrams rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Grams' ;
    rdfs:comment 'Weight of a single packaged unit in grams. Used for shipping cost calculation and logistics planning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltageVariant rdf:type rdf:Property ;
    rdfs:label 'Voltage Variant' ;
    rdfs:comment 'Core or I/O voltage specification variant for this SKU. Defines power supply requirements and compatibility with system voltage rails.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatVendorId rdf:type rdf:Property ;
    rdfs:label 'Osat Vendor Id' ;
    rdfs:comment 'Foreign key linking to packaging.osat_vendor. Business justification: Product families have a designated preferred OSAT partner for strategic sourcing and capacity planning. Used in roadmap planning, OSAT capacity allocation, and supplier qualification decisions. The pl' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OsatVendor .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family in the hierarchy. Supports multi-level taxonomy: portfolio → family → sub-family → product → variant. Null for top-level portfolio entries.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:activePcnCount rdf:type rdf:Property ;
    rdfs:label 'Active Pcn Count' ;
    rdfs:comment 'Number of active PCNs currently in effect for this product family. Indicates ongoing changes to process, materials, or design that require customer notification and approval.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDomain rdf:type rdf:Property ;
    rdfs:label 'Application Domain' ;
    rdfs:comment 'Specific application domain or use case this product family addresses (e.g., Advanced Driver Assistance Systems, Edge AI Inference, 5G Baseband Processing). Used for technical marketing and customer solution mapping.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for this product family (e.g., Automotive Solutions, Mobile Computing, IoT and Embedded). Aligns with organizational structure and P&L responsibility.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Design Center Location' ;
    rdfs:comment 'Primary design center location responsible for this product family (e.g., San Jose CA, Austin TX, Bangalore India). Used for resource planning and IP ownership tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dftCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Dft Coverage Percent' ;
    rdfs:comment 'Design for Testability coverage percentage indicating the proportion of circuit nodes accessible for ATPG (Automatic Test Pattern Generation). Higher coverage enables better defect detection during wafer test.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when this product family was fully discontinued and removed from active catalog. No further production or shipments after this date.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fabSiteCode rdf:type rdf:Property ;
    rdfs:label 'Fab Site Code' ;
    rdfs:comment 'Code identifying the primary fabrication facility for this product family. Links to fab capacity planning, process capability, and supply chain routing.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the product family by semiconductor device type. Aligns with industry standard device categories for design, fabrication, and test planning. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Mixed_Signal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the product family hierarchy (1=portfolio, 2=family, 3=sub-family, 4=product, 5=variant). Supports up to five levels of product taxonomy as defined in the product domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltbDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Date' ;
    rdfs:comment 'Final date for customers to place orders before product family is discontinued. Part of EOL process and customer lifecycle management.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npiStartDate rdf:type rdf:Property ;
    rdfs:label 'Npi Start Date' ;
    rdfs:comment 'Date when this product family entered NPI phase. Marks the beginning of qualification, ramp, and early customer shipments. Used for TTM (Time to Market) tracking.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Primary packaging technology for this product family (e.g., WLCSP Wafer-Level Chip Scale Package, BGA Ball Grid Array, QFN Quad Flat No-Lead, CoWoS Chip on Wafer on Substrate, InFO Integrated Fan-Out). Defines assembly process and thermal/electrical characteristics.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineManager rdf:type rdf:Property ;
    rdfs:label 'Product Line Manager' ;
    rdfs:comment 'Name of the product line manager responsible for roadmap, positioning, and lifecycle management of this product family. Business owner for strategic decisions.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStandard rdf:type rdf:Property ;
    rdfs:label 'Qualification Standard' ;
    rdfs:comment 'Industry qualification standard this product family must meet (e.g., AEC-Q100 for automotive, MIL-STD-883 for military, JEDEC JESD47 for stress testing). Defines reliability testing requirements.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPerformanceMetric rdf:type rdf:Property ;
    rdfs:label 'Target Performance Metric' ;
    rdfs:comment 'Key performance metric and target value for this product family (e.g., 3.5 GHz clock frequency, 100 TOPS AI performance, 10 Gbps throughput). Used for competitive analysis and roadmap planning.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPowerMw rdf:type rdf:Property ;
    rdfs:label 'Target Power Mw' ;
    rdfs:comment 'Target typical power consumption in milliwatts for this product family. Part of PPA (Power Performance Area) metrics used for competitive positioning and customer design-in evaluation.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalDieSizeMm2 rdf:type rdf:Property ;
    rdfs:label 'Typical Die Size Mm2' ;
    rdfs:comment 'Representative die size in square millimeters for products in this family. Used for wafer yield modeling, cost estimation, and capacity planning. Actual die sizes may vary by specific product variant.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeProductionDate rdf:type rdf:Property ;
    rdfs:label 'Volume Production Date' ;
    rdfs:comment 'Date when this product family achieved volume production status (Active lifecycle). Indicates full manufacturing qualification and capacity availability.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeProductCount rdf:type rdf:Property ;
    rdfs:label 'Active Product Count' ;
    rdfs:comment 'Current count of active product SKUs (ICs, SoCs, ASICs, FPGAs) assigned to this process node. Used for capacity planning and node utilization analysis.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Baseline Yield Percent' ;
    rdfs:comment 'Expected baseline yield percentage (good dies per wafer) for this process node under standard manufacturing conditions. Used for cost modeling and capacity planning. Confidential manufacturing metric.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerWaferUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Wafer Usd' ;
    rdfs:comment 'Standard manufacturing cost per wafer in USD for this process node. Includes FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs. Confidential financial data used for product costing and NRE (Non-Recurring Engineering) estimation.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Status' ;
    rdfs:comment 'Compliance status with environmental regulations including RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), and TSCA (Toxic Substances Control Act). Compliant indicates full adherence; Non-Compliant indicates violations; Under Review indicates pending assessment.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current lifecycle stage of the process node. NPI (New Product Introduction) indicates initial ramp; Growth indicates volume expansion; Mature indicates stable production; Decline indicates phasing out; EOL (End of Life) indicates discontinued with LTB (Last Time Buy) notifications issued.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Deadline Date' ;
    rdfs:comment 'Final date for customers to place orders for products manufactured on this process node before complete discontinuation. Null if node is not in EOL status.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiPatterningLayers rdf:type rdf:Property ;
    rdfs:label 'Multi Patterning Layers' ;
    rdfs:comment 'Number of critical layers requiring multi-patterning techniques (double, triple, or quad patterning) to achieve target feature sizes. Zero indicates single-exposure capability. Higher counts increase mask costs and cycle time.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opcRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opc Required Flag' ;
    rdfs:comment 'Indicates whether OPC (Optical Proximity Correction) is mandatory for mask preparation at this process node. True for advanced nodes where lithography effects require computational correction.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdkReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Pdk Release Date' ;
    rdfs:comment 'Date when the current PDK version was officially released and made available to design teams. Tracks PDK maturity and design enablement timeline.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Device Types' ;
    rdfs:comment 'Comma-separated list of device types and IP (Intellectual Property Core) categories supported by this process node (e.g., Logic, SRAM, Analog, RF, High-Voltage, IO). Defines the breadth of design capabilities.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Readiness Level' ;
    rdfs:comment 'TRL score from 1 (basic research) to 9 (full production deployment) indicating the maturity of the process node technology. Used for R&D planning and risk assessment.' ;
    rdfs:domain ind:ProcessNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageTypeId rdf:type rdf:Property ;
    rdfs:label 'Package Type Id' ;
    rdfs:comment 'Foreign key linking to packaging.package_type. Business justification: Product specs (thermal resistance, pin count, operating conditions) are package-specific. Used in datasheet generation, AEC-Q qualification reports, and customer design-in support. The plain \'package_' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:primaryProductIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Product Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent product (IC, SoC, ASIC, FPGA, IP core, or discrete device) for which this specification applies.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:productReferenceIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Product Reference Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Product specifications describe a specific IC product. Must reference the catalog entry.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:automotiveGrade rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade' ;
    rdfs:comment 'AEC-Q100 automotive qualification grade indicating temperature range and reliability requirements (Grade 0: -40°C to 150°C, Grade 1: -40°C to 125°C, Grade 2: -40°C to 105°C, Grade 3: -40°C to 85°C).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterizationDate rdf:type rdf:Property ;
    rdfs:label 'Characterization Date' ;
    rdfs:comment 'Date when this specification was characterized and validated through silicon testing or simulation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Years' ;
    rdfs:comment 'Guaranteed data retention period in years for non-volatile memory components at specified temperature.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieAreaAchievedMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Achieved Mm2' ;
    rdfs:comment 'Actual measured silicon die area in square millimeters (mm²) from physical layout. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dieAreaTargetMm2 rdf:type rdf:Property ;
    rdfs:label 'Die Area Target Mm2' ;
    rdfs:comment 'Target silicon die area in square millimeters (mm²). Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Dynamic Power Target Mw' ;
    rdfs:comment 'Target dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enduranceCycles rdf:type rdf:Property ;
    rdfs:label 'Endurance Cycles' ;
    rdfs:comment 'Number of program/erase cycles guaranteed for non-volatile memory components (applicable to flash, EEPROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:esdProtectionLevelKv rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Level Kv' ;
    rdfs:comment 'Electrostatic discharge protection rating in kilovolts (kV) per JEDEC standards (e.g., HBM, CDM models).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Rating' ;
    rdfs:comment 'Functional safety certification level achieved by the product. ISO 26262 ASIL (Automotive Safety Integrity Level) A through D for automotive applications; IEC 61508 SIL (Safety Integrity Level) 1 through 4 for industrial applications. [ENUM-REF-CANDIDATE: none|iso_26262_asil_a|iso_26262_asil_b|iso_26262_asil_c|iso_26262_asil_d|iec_61508_sil_1|iec_61508_sil_2|iec_61508_sil_3|iec_61508_sil_4 — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ioCount rdf:type rdf:Property ;
    rdfs:label 'Io Count' ;
    rdfs:comment 'Total number of input/output pins or pads available on the integrated circuit for signal connectivity.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leakagePowerAchievedMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Achieved Mw' ;
    rdfs:comment 'Actual measured or characterized static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakagePowerTargetMw rdf:type rdf:Property ;
    rdfs:label 'Leakage Power Target Mw' ;
    rdfs:comment 'Target static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyAchievedMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Achieved Mhz' ;
    rdfs:comment 'Actual measured or characterized maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFrequencyTargetMhz rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Target Mhz' ;
    rdfs:comment 'Target maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryConfiguration rdf:type rdf:Property ;
    rdfs:label 'Memory Configuration' ;
    rdfs:comment 'Description of on-chip memory architecture including SRAM, cache, ROM, and embedded flash sizes and organization (e.g., 256KB L2 Cache, 2MB SRAM, 512KB ROM).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingConditionCorner rdf:type rdf:Property ;
    rdfs:label 'Operating Condition Corner' ;
    rdfs:comment 'Process-voltage-temperature (PVT) corner at which this specification is characterized. Typical represents nominal conditions; best/worst case represent performance extremes; slow/fast combinations represent process variation corners. [ENUM-REF-CANDIDATE: typical|best_case|worst_case|slow_slow|fast_fast|slow_fast|fast_slow — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'Maximum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'Minimum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingVoltageNominalV rdf:type rdf:Property ;
    rdfs:label 'Operating Voltage Nominal V' ;
    rdfs:comment 'Nominal (typical) operating voltage in volts (V) for standard operation.' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityFeatures rdf:type rdf:Property ;
    rdfs:label 'Security Features' ;
    rdfs:comment 'Comma-separated list of implemented hardware security features (e.g., Secure Boot, TrustZone, AES-256, SHA-256, Hardware Root of Trust, Anti-Tamper).' ;
    rdfs:domain ind:ProductSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of this product specification (Draft: under development, Preliminary: pre-silicon or early silicon, Final: production-qualified, Obsolete: superseded by newer version).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials header record. Primary key for the BOM entity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyProcessFlowId rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Flow Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_process_flow. Business justification: In semiconductor PLM, a product BOM is authored against a specific assembly process flow — the flow determines step sequence, materials, and yield targets. Used in NPI BOM validation, process change i' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyProcessFlow .

ind:primaryBomIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Ic Catalog Id' ;
    rdfs:comment 'Reference to the parent IC product or assembly that this BOM defines. Links to the product master catalog.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:substrateBomId rdf:type rdf:Property ;
    rdfs:label 'Substrate Bom Id' ;
    rdfs:comment 'Foreign key linking to packaging.substrate_bom. Business justification: A product BOM references a substrate BOM as its primary packaging material component. Standard semiconductor PLM hierarchy used in material requirements planning, cost rollup, and supply chain risk as' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubstrateBom .

ind:alternativeBomIndicator rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Indicator' ;
    rdfs:comment 'Identifier for alternative BOM configurations for the same product. Used when multiple valid component combinations exist (e.g., different suppliers, different process nodes, or design variants).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The quantity of the parent product that this BOM defines. Typically 1 for single-unit BOMs, but may be higher for batch or lot-based manufacturing. All component quantities in BOM lines are relative to this base quantity.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the base quantity, such as EA (each), LOT, WAFER, or other semiconductor-specific units. Must align with product master UOM.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM, typically a human-readable code used across PLM and ERP systems for tracking and reference.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Draft indicates work in progress, in_review indicates pending approval, approved indicates ready for use, active indicates currently in production, frozen indicates locked for manufacturing, obsolete indicates no longer valid, superseded indicates replaced by newer revision. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|frozen|obsolete|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use: engineering BOM (EBOM) for design, manufacturing BOM (MBOM) for production, service BOM for maintenance, planning BOM for forecasting, as-designed for original specification, or as-built for actual production configuration.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Compliant Flag' ;
    rdfs:comment 'Indicates whether the BOM and all its components are free from conflict minerals (tin, tantalum, tungsten, gold) sourced from conflict regions, per Dodd-Frank Act Section 1502 requirements.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total material cost. Typically USD for semiconductor industry but may vary by region.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Material Flag' ;
    rdfs:comment 'Indicates whether this BOM contains components classified as critical materials (long lead time, single source, strategic importance). Used for supply chain risk management.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineeringChangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Order Number' ;
    rdfs:comment 'Reference to the engineering change order that created or last modified this BOM revision. Critical for change traceability and audit compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eolDate rdf:type rdf:Property ;
    rdfs:label 'Eol Date' ;
    rdfs:comment 'Planned or actual end-of-life date for this BOM. After this date, the product is no longer manufactured or supported.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM should be exploded for planning and costing: single-level shows only immediate children, multi-level shows full hierarchy, summarized shows consolidated component totals.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBomReference rdf:type rdf:Property ;
    rdfs:label 'External Bom Reference' ;
    rdfs:comment 'Original BOM identifier from the source PLM or ERP system. Maintains traceability to upstream systems and enables cross-system reconciliation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production lot size for which this BOM is optimized. Used in material requirements planning (MRP) and capacity planning calculations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltbNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Ltb Notification Date' ;
    rdfs:comment 'Date when Last Time Buy notification was issued for this BOM, indicating the product is approaching end-of-life and customers should place final orders.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcnNumber rdf:type rdf:Property ;
    rdfs:label 'Pcn Number' ;
    rdfs:comment 'Product Change Notification number issued to customers when this BOM revision represents a material change to the product. Required for customer communication and approval.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Manufacturing plant or fabrication facility (FAB) where this BOM is applicable. Different plants may have different BOMs for the same product due to process variations or equipment differences.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Production version identifier linking this BOM to a specific routing or process flow. Enables coordination between BOM and manufacturing process definitions.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or yield loss percentage at the BOM level. Used to adjust material requirements and costing. Typical semiconductor yield losses are factored here.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'Total number of distinct component line items in this BOM. Provides quick visibility into BOM complexity without querying detail records.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost' ;
    rdfs:comment 'Rolled-up total material cost for all components in this BOM, calculated from component costs and quantities. Used for product costing and margin analysis.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Intended usage context for this BOM: production for manufacturing execution, costing for financial analysis, engineering for design reference, maintenance for service operations, or sales for customer quotations.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Component Ic Catalog Id' ;
    rdfs:comment 'Foreign key linking to product.ic_catalog. Business justification: In semiconductor BOMs, sub-components are frequently ICs from the same product catalog (e.g., a SoC BOM may include memory ICs, power management ICs, or interface ICs that are themselves catalog produ' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:parentLineBomLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Line Bom Line Id' ;
    rdfs:comment 'Reference to the parent BOM line in a multi-level BOM structure. Null for top-level components. Enables recursive BOM explosion and indented BOM reports.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomLine .

ind:primaryBomId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Id' ;
    rdfs:comment 'Reference to the parent BOM header that this line belongs to. Links the line item to the overall product BOM structure.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:toBomId rdf:type rdf:Property ;
    rdfs:label 'To Bom Id' ;
    rdfs:comment 'FK to product.bom.bom_id — Classic header-line relationship. BOM lines are meaningless without their parent BOM header.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:approvedSubstitutePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Approved Substitute Part Numbers' ;
    rdfs:comment 'Comma-separated list of approved alternate or substitute part numbers that can be used in place of the primary component. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyProcessCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Code' ;
    rdfs:comment 'Code identifying the assembly or packaging process used to integrate this component (e.g., wirebond, flip-chip, CoWoS, InFO). Links to process routing and manufacturing execution.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'The hierarchical level of this component in the multi-level BOM structure. Level 0 is the finished product, level 1 is direct sub-assembly, level 2 is sub-component of level 1, and so on. Supports BOM explosion for cost rollup and supply chain analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component, including technical specifications, material properties, and functional purpose within the assembly.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'The unique part number or SKU of the component material used in this BOM line. May reference die, package substrate, passive components, interposer, or other materials.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component by its functional role in the semiconductor assembly. Includes die (silicon chip), package substrate, passive components (resistors, capacitors), interposer, leadframe, wirebond, solder ball, underfill material, and mold compound. [ENUM-REF-CANDIDATE: die|package_substrate|passive|interposer|leadframe|wirebond|solder_ball|underfill|mold_compound — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Status' ;
    rdfs:comment 'Compliance status for conflict minerals (tin, tantalum, tungsten, gold) sourcing per Dodd-Frank Act Section 1502. Tracks whether component supply chain is free from conflict region sourcing.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product functionality, quality, or supply chain continuity. Used for risk assessment and inventory planning.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date on which this BOM line becomes obsolete or is replaced. Null for currently active components. Supports phase-in/phase-out scenarios and Product Change Notification (PCN) tracking.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this BOM line becomes effective. Supports date-based BOM versioning and engineering change management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent BOM, used for ordering and referencing specific components in the assembly hierarchy.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makeOrBuyIndicator rdf:type rdf:Property ;
    rdfs:label 'Make Or Buy Indicator' ;
    rdfs:comment 'Indicates whether the component is manufactured in-house (make), procured externally (buy), or transferred from another plant (transfer). Drives procurement and production planning logic.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The name of the original equipment manufacturer (OEM) or component manufacturer. May differ from the supplier if purchased through distributors.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomBomFlag rdf:type rdf:Property ;
    rdfs:label 'Phantom Bom Flag' ;
    rdfs:comment 'Indicates whether this is a phantom or transient sub-assembly that is not stocked or tracked as inventory. Phantom BOMs are exploded through during MRP but not manufactured as discrete items.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'The typical lead time in days required to procure this component from suppliers. Used for material requirements planning (MRP) and supply chain risk analysis.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerAssembly rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Assembly' ;
    rdfs:comment 'The quantity of this component required to produce one unit of the parent assembly. Supports fractional quantities for materials measured by weight or volume.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'The reference designator or location identifier for the component on the physical layout or assembly drawing (e.g., U1, C23, R45). Links BOM to physical design.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected scrap or yield loss percentage for this component during manufacturing. Used to calculate net material requirements accounting for process losses.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this component is available from only one supplier, representing a supply chain risk. Triggers dual-sourcing initiatives and risk mitigation strategies.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The standard unit cost of the component in the base currency. Used for BOM cost rollup, product costing, and margin analysis.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the component quantity is expressed. Common values include EA (each), KG (kilogram), G (gram), L (liter), ML (milliliter), M (meter), MM (millimeter), WAFER, DIE. [ENUM-REF-CANDIDATE: EA|KG|G|L|ML|M|MM|WAFER|DIE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertId rdf:type rdf:Property ;
    rdfs:label 'Compliance Cert Id' ;
    rdfs:comment 'Unique identifier for the product compliance certification record.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certFamilyId rdf:type rdf:Property ;
    rdfs:label 'Cert Family Id' ;
    rdfs:comment 'Foreign key linking to product.family. Business justification: Compliance certifications in the semiconductor industry frequently apply at the product family level. Automotive qualifications (AEC-Q100/Q101/Q200), functional safety certifications (ISO 26262, IEC 6' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:certSkuId rdf:type rdf:Property ;
    rdfs:label 'Cert Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Compliance certifications in the semiconductor industry can be specific to orderable SKU variants, not just the base IC catalog product. For example, a lead-free (RoHS) certification may apply to a sp' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:certSupplierId rdf:type rdf:Property ;
    rdfs:label 'Cert Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Compliance certificates (RoHS, REACH, conflict minerals, AEC-Q) in semiconductors are issued by or validated against specific suppliers. Regulatory audits and customer compliance declarations require ' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:finalTestRunId rdf:type rdf:Property ;
    rdfs:label 'Final Test Run Id' ;
    rdfs:comment 'Foreign key linking to test.final_test_run. Business justification: AEC-Q100/Q101 and automotive compliance certifications require reference to the specific final test run that generated qualification evidence. test_report_number is a denormalized reference to final_t' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinalTestRun .

ind:kgdCertificationId rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_kgd_certification. Business justification: KGD compliance certifications reference the KGD certification record for die-level shipment compliance and customer-facing certification documentation — essential for bare-die supply chain traceabilit' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KgdCertification .

ind:primaryIcCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Ic Catalog Id' ;
    rdfs:comment 'FK to product.ic_catalog.ic_catalog_id — Compliance certifications are obtained for specific products or SKUs. Required for export control screening and customer documentation.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcCatalog .

ind:reliabilityTestId rdf:type rdf:Property ;
    rdfs:label 'Reliability Test Id' ;
    rdfs:comment 'Foreign key linking to quality.reliability_test. Business justification: AEC-Q100/JEDEC compliance certifications are substantiated by specific reliability test results — the cert must reference the qualifying reliability test for audit traceability, recertification tracki' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReliabilityTest .

ind:applicableMarkets rdf:type rdf:Property ;
    rdfs:label 'Applicable Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets, regions, or countries where this compliance certification is recognized and valid (e.g., USA, EU, CHN, JPN, KOR). Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of regulatory regions or jurisdictions where this certification applies (e.g., North America, European Union, Asia-Pacific, EMEA).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or assessor from the certification body who conducted the compliance assessment.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automotiveGradeCertified rdf:type rdf:Property ;
    rdfs:label 'Automotive Grade Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product has achieved automotive-grade qualification certification (e.g., AEC-Q100 for ICs, AEC-Q101 for discrete semiconductors) for use in automotive applications.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited third-party organization or regulatory authority that issued the compliance certification (e.g., TÜV, UL, Intertek, SGS, Bureau Veritas).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certificate number or identifier issued by the certification body for this compliance certification.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the scope of the certification, including specific product variants, process nodes, package types, or application domains covered by this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the compliance certification indicating whether it is active and valid, expired, pending approval, suspended, revoked, or under review.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of regulatory or standards certification obtained. RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), AEC-Q100/Q101 (Automotive Electronics Council qualification standards), ISO 26262 (Automotive Functional Safety), IEC 61508 (Functional Safety), UL (Underwriters Laboratories), CE (Conformité Européenne), FCC (Federal Communications Commission), ITAR (International Traffic in Arms Regulations), EAR (Export Administration Regulations). [ENUM-REF-CANDIDATE: RoHS|REACH|TSCA|AEC-Q100|AEC-Q101|ISO 26262|IEC 61508|UL|CE|FCC|ITAR|EAR — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for additional notes, exceptions, conditions, or special handling instructions related to this compliance certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictMineralsDeclaration rdf:type rdf:Property ;
    rdfs:label 'Conflict Minerals Declaration' ;
    rdfs:comment 'Declaration of conflict minerals (tin, tantalum, tungsten, gold - 3TG) sourcing and compliance status with Dodd-Frank Act Section 1502 and OECD Due Diligence Guidance.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificRequirement rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Requirement' ;
    rdfs:comment 'Description of any customer-specific compliance requirements or certifications that this record addresses beyond standard regulatory requirements.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earControlled rdf:type rdf:Property ;
    rdfs:label 'Ear Controlled' ;
    rdfs:comment 'Boolean flag indicating whether the product is subject to EAR (Export Administration Regulations) export controls administered by the Bureau of Industry and Security.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the compliance certification becomes valid and enforceable for the product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalStandard rdf:type rdf:Property ;
    rdfs:label 'Environmental Standard' ;
    rdfs:comment 'Environmental management system standard under which this certification was issued (e.g., ISO 14001, ISO 50001 for energy management).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the compliance certification expires and requires renewal or re-certification. Nullable for certifications without expiration.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalSafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Functional Safety Level' ;
    rdfs:comment 'Functional safety integrity level achieved by the product under ISO 26262 (ASIL A/B/C/D for automotive) or IEC 61508 (SIL 1/2/3/4 for industrial) standards. ASIL (Automotive Safety Integrity Level), SIL (Safety Integrity Level). [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|SIL_4|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousSubstanceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Hazardous Substance Declaration' ;
    rdfs:comment 'Detailed declaration of hazardous substances present in the product, including substance names, CAS (Chemical Abstracts Service) numbers, concentration levels, and compliance status with RoHS, REACH, and TSCA regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Owner' ;
    rdfs:comment 'Name or employee identifier of the internal compliance manager or product quality engineer responsible for maintaining this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the compliance certification was officially issued by the certification body.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pcn Reference Number' ;
    rdfs:comment 'Reference number of the Product Change Notification (PCN) that triggered this certification or recertification, if applicable.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Management Standard' ;
    rdfs:comment 'Quality management system standard under which this certification was issued (e.g., ISO 9001, IATF 16949, AS9100, ISO 13485).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification cycles. Null if recertification is not required or is event-driven rather than time-based.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Recertification Required' ;
    rdfs:comment 'Boolean flag indicating whether this certification requires periodic recertification or renewal (True) or is a one-time certification (False).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationTriggerEvents rdf:type rdf:Property ;
    rdfs:label 'Recertification Trigger Events' ;
    rdfs:comment 'Comma-separated list of business events that trigger mandatory recertification (e.g., design change, process node migration, package change, supplier change, PCN issuance, material substitution).' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes to which export or sale of this product is restricted or prohibited under applicable export control regulations.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Url' ;
    rdfs:comment 'URL or file path to the repository location containing supporting documentation, test reports, certificates, and compliance declarations for this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testLaboratory rdf:type rdf:Property ;
    rdfs:label 'Test Laboratory' ;
    rdfs:comment 'Name of the accredited testing laboratory that performed the compliance testing and analysis supporting this certification.' ;
    rdfs:domain ind:ComplianceCert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the account within the semiconductor ecosystem.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Result of the most recent compliance audit for the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the account was closed or deactivated, if applicable.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred channel for account communications.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating of the account. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|C|D — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for billing. [ENUM-REF-CANDIDATE: USD|EUR|JPY|CNY|KRW|... — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data classification level applied to the account record.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet unique identifier for the legal entity.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic region of the account\'s operations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'Primary industry vertical the account operates in (e.g., automotive, consumer electronics). [ENUM-REF-CANDIDATE: automotive|consumer|industrial|communications|computing|... — promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelRequirements rdf:type rdf:Property ;
    rdfs:label 'Label Requirements' ;
    rdfs:comment 'Labeling format required on products delivered to the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent interaction or transaction with the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent order placed by the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the corporate entity as registered.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingRequirements rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirements' ;
    rdfs:comment 'Special packaging or labeling requirements for shipments to the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms agreed with the account.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Preferred language for communications with the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressCode rdf:type rdf:Property ;
    rdfs:label 'Primary Address Code' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Normalize primary address fields by referencing address table.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Main email address used for account communications.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Main telephone number for the account point of contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the account record was first created.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the account record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueTier rdf:type rdf:Property ;
    rdfs:label 'Revenue Tier' ;
    rdfs:comment 'Revenue bracket of the account based on annual sales.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numerical risk rating (0-100) based on credit, compliance, and transaction history.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region assigned to the account.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicClassification rdf:type rdf:Property ;
    rdfs:label 'Strategic Classification' ;
    rdfs:comment 'Strategic importance of the account to the company.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the account is tax-exempt.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identifier for the account.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when the account was first created in the system.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique system-generated identifier for the contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'FK to customer.address' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:primaryContactAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Connect contact to its parent customer account for hierarchy and reporting.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Birth date of the contact, used for age verification where required.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Department within the organization where the contact works.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for the contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier of the contact in external systems (e.g., Salesforce ID).' ;
