    rdfs:range xsd:string .

ind:primaryGoodsPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Purchase Order Id' ;
    rdfs:comment 'System identifier of the purchase order associated with the receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Any external system reference linked to this receipt (e.g., logistics tracking ID).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsPurchaseOrderFk rdf:type rdf:Property ;
    rdfs:label 'Goods Purchase Order Fk' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Goods receipts are posted against a purchase order. Core three-way match requirement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total monetary value of the receipt before taxes and discounts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Reference to the quality inspection lot created for this receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Business identifier assigned to the receipt document (e.g., GR number).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Exact date and time when the receipt was recorded in the system.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedBy rdf:type rdf:Property ;
    rdfs:label 'Received By' ;
    rdfs:comment 'Name or employee identifier of the person who logged the receipt.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numeric score representing supply risk for the received material (higher = higher risk).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierBatchReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Reference' ;
    rdfs:comment 'Reference supplied by the vendor for the batch (e.g., vendor lot number).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Valuation category for the material (e.g., S = standard, U = moving average, V = special).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Identifier of the supplier being qualified, linking to the supplier master record.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:tertiarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Supplier Id' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Qualification records assess a specific supplier. Cannot exist without supplier reference.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Calendar date on which the audit was performed.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditTeam rdf:type rdf:Property ;
    rdfs:label 'Audit Team' ;
    rdfs:comment 'Comma-separated list of auditors and subject-matter experts who conducted the audit.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit execution: initial qualification, routine surveillance, or for-cause audit.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandards rdf:type rdf:Property ;
    rdfs:label 'Compliance Standards' ;
    rdfs:comment 'Semicolon-separated list of regulatory or industry standards the qualification satisfies.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSeverity rdf:type rdf:Property ;
    rdfs:label 'Findings Severity' ;
    rdfs:comment 'Highest severity level of audit findings identified during the assessment.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Narrative summary of audit observations, non-conformances, and strengths.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Result of the qualification audit after considering findings and corrective actions.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'External reference number assigned to the qualification program for tracking and audit purposes.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationProgramType rdf:type rdf:Property ;
    rdfs:label 'Qualification Program Type' ;
    rdfs:comment 'Type of qualification program: initial onboarding, scheduled periodic review, or change-triggered re-qualification.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScope rdf:type rdf:Property ;
    rdfs:label 'Qualification Scope' ;
    rdfs:comment 'Scope of the qualification assessment covering quality system audit, process capability, material certification, or a combination.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedBy rdf:type rdf:Property ;
    rdfs:label 'Qualified By' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequirementPlanId rdf:type rdf:Property ;
    rdfs:label 'Material Requirement Plan Id' ;
    rdfs:comment 'Unique surrogate key for each material requirement plan record.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Demand Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: MRP gross requirements in semiconductors are driven by customer order line demand. Linking MRP to the originating order line enables S&OP demand-supply gap analysis, backlog-to-plan reconciliation, an' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:primaryMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Master Id' ;
    rdfs:comment 'Surrogate key referencing the material master record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:tertiaryMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Material Master Id' ;
    rdfs:comment 'FK to supply.material_master.material_master_id — MRP outputs are calculated for specific materials.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Flag indicating if the material requires batch tracking (Y) or not (N).' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandDate rdf:type rdf:Property ;
    rdfs:label 'Demand Date' ;
    rdfs:comment 'Date on which the underlying demand (e.g., production start) is scheduled.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demandQuantity rdf:type rdf:Property ;
    rdfs:label 'Demand Quantity' ;
    rdfs:comment 'Quantity of the material required by production orders or forecasts.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionMessage rdf:type rdf:Property ;
    rdfs:label 'Exception Message' ;
    rdfs:comment 'Textual description of any planning exception (e.g., shortfall, excess).' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRequirementQty rdf:type rdf:Property ;
    rdfs:label 'Gross Requirement Qty' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFixedLot rdf:type rdf:Property ;
    rdfs:label 'Is Fixed Lot' ;
    rdfs:comment 'True if the lot size is fixed by engineering, otherwise False.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizingProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Procedure' ;
    rdfs:comment 'Algorithm used to calculate the lot size for the planned order.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequirementPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Material Requirement Plan Status' ;
    rdfs:comment 'Operational status indicating whether the line is still in planning, released to procurement, or flagged.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Code of the person or system that owns the MRP parameters for the material.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'Classification of the planning method used for this line.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRequirementQty rdf:type rdf:Property ;
    rdfs:label 'Net Requirement Qty' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planPeriod rdf:type rdf:Property ;
    rdfs:label 'Plan Period' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Estimated monetary cost of the planned quantity based on standard price.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Target date by which the material must be available for production.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderQty rdf:type rdf:Property ;
    rdfs:label 'Planned Order Qty' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Quantity of material that the MRP run recommends procuring.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEnd rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End' ;
    rdfs:comment 'Last day of the time window considered by the MRP run.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStart rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start' ;
    rdfs:comment 'First day of the time window considered by the MRP run.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningRunDate rdf:type rdf:Property ;
    rdfs:label 'Planning Run Date' ;
    rdfs:comment 'Calendar date on which the MRP calculation was performed.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningRunNumber rdf:type rdf:Property ;
    rdfs:label 'Planning Run Number' ;
    rdfs:comment 'Identifier of the MRP execution that generated this plan.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level that triggers a new procurement recommendation.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requirementDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Date' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Quantity kept as buffer to protect against demand or supply variability.' ;
    rdfs:domain ind:MaterialRequirementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryInboundPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Purchase Order Id' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Inbound shipments deliver against purchase orders. Required for logistics tracking and landed cost.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Reference number of the bill of lading document.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether temperature-controlled handling is required.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Identifier of the customs entry for the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'End date of the agreed delivery window.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Start date of the agreed delivery window.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationPlant rdf:type rdf:Property ;
    rdfs:label 'Destination Plant' ;
    rdfs:comment 'Identifier of the fab or warehouse receiving the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total cost charged by the carrier for transporting the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousGoodsClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Classification' ;
    rdfs:comment 'Classification code for hazardous materials per UN/ADR.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundPoFk rdf:type rdf:Property ;
    rdfs:label 'Inbound Po Fk' ;
    rdfs:comment 'FK to supply.purchase_order.purchase_order_id — Inbound shipments deliver materials against purchase orders. Required for supply continuity monitoring and landed cost calculation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the inbound shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountry rdf:type rdf:Property ;
    rdfs:label 'Origin Country' ;
    rdfs:comment 'Three-letter ISO country code of the shipment origin.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipment Timestamp' ;
    rdfs:comment 'Timestamp of the primary shipment event (e.g., departure from supplier).' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum allowable temperature for the shipment when cold chain is required.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum allowable temperature for the shipment when cold chain is required.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transport used for the inbound shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Total weight of the shipment in kilograms.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryMaterialSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Supplier Id' ;
    rdfs:comment 'Identifier of the supplier that issued the certification.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Path or URL to the electronic certification document.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier of the certification document.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization or department that issued the certification.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialLotNumber rdf:type rdf:Property ;
    rdfs:label 'Material Lot Number' ;
    rdfs:comment 'Lot identifier assigned to the batch of material covered by the certification.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSupplierFk rdf:type rdf:Property ;
    rdfs:label 'Material Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Certifications are issued by a specific supplier. Required to trace compliance evidence to its source.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcnChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Pcn Change Description' ;
    rdfs:comment 'Detailed description of the change communicated in the PCN.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnChangeType rdf:type rdf:Property ;
    rdfs:label 'Pcn Change Type' ;
    rdfs:comment 'Category of change described in the PCN.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnCustomerNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Pcn Customer Notification Required' ;
    rdfs:comment 'Indicates whether the PCN must be communicated to customers.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcnEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Pcn Effective Date' ;
    rdfs:comment 'Date when the PCN change becomes effective.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcnImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Pcn Impact Assessment' ;
    rdfs:comment 'Summary of the impact of the PCN on downstream processes and customers.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnRequalificationDecision rdf:type rdf:Property ;
    rdfs:label 'Pcn Requalification Decision' ;
    rdfs:comment 'Decision on whether the material requires re-qualification after the PCN.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierFk rdf:type rdf:Property ;
    rdfs:label 'Supplier Fk' ;
    rdfs:comment 'FK to supply.supplier.supplier_id — Certifications are issued BY a specific supplier for their material lots.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testUnits rdf:type rdf:Property ;
    rdfs:label 'Test Units' ;
    rdfs:comment 'Units of measurement for the test value, such as ppm, mg/kg, or %.' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testValue rdf:type rdf:Property ;
    rdfs:label 'Test Value' ;
    rdfs:comment 'Quantitative result of the test (e.g., concentration, impurity level).' ;
    rdfs:domain ind:MaterialCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotMaskExposureId rdf:type rdf:Property ;
    rdfs:label 'Lot Mask Exposure Id' ;
    rdfs:comment 'Primary key for the lot_mask_exposure association' ;
    rdfs:domain ind:LotMaskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureCount rdf:type rdf:Property ;
    rdfs:label 'Exposure Count' ;
    rdfs:comment 'Number of wafer exposures this photomask performed on this specific wafer lot during this process step. Used to update cumulative_usage_count on the photomask and to track per-lot mask utilization for yield correlation.' ;
    rdfs:domain ind:LotMaskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exposure Timestamp' ;
    rdfs:comment 'Date and time when this mask exposure event occurred on the wafer lot. Belongs to the exposure event, not to the mask or lot independently. Used for mask maintenance scheduling, lot genealogy, and yield timeline analysis.' ;
    rdfs:domain ind:LotMaskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Sequence Number' ;
    rdfs:comment 'The sequential operation step number in the lot\'s process route at which this mask exposure was performed. Corresponds to current_operation_number on the lot at time of exposure. Enables precise genealogy reconstruction of which mask was used at which step.' ;
    rdfs:domain ind:LotMaskExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probeCardQualificationId rdf:type rdf:Property ;
    rdfs:label 'Probe Card Qualification Id' ;
    rdfs:comment 'Primary key for the probe_card_qualification association' ;
    rdfs:domain ind:ProbeCardQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compatibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Compatibility Notes' ;
    rdfs:comment 'Free-text engineering notes documenting compatibility observations, constraints, or conditions specific to this probe card and ATE configuration pairing. Sourced from detection phase relationship_data: compatibility_notes.' ;
    rdfs:domain ind:ProbeCardQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTouchdownCountForConfig rdf:type rdf:Property ;
    rdfs:label 'Max Touchdown Count For Config' ;
    rdfs:comment 'Maximum number of touchdowns permitted for this probe card when used with this specific ATE configuration. This limit varies by configuration and cannot be stored on the probe card alone. Sourced from detection phase relationship_data: max_touchdown_count_for_config.' ;
    rdfs:domain ind:ProbeCardQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:probeCardQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Probe Card Qualification Status' ;
    rdfs:comment 'Current lifecycle state of the qualification for this specific probe card and ATE configuration pairing. Sourced from detection phase relationship_data: qualification_status.' ;
    rdfs:domain ind:ProbeCardQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
