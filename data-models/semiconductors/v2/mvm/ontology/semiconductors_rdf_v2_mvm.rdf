ind:inspectionTool rdf:type rdf:Property ;
    rdfs:label 'Inspection Tool' ;
    rdfs:comment 'Equipment or system used to perform the inspection (e.g., KLA ICOS).' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementCriteria rdf:type rdf:Property ;
    rdfs:label 'Measurement Criteria' ;
    rdfs:comment 'Key measurement or characteristic monitored by the control plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'External code or number used to reference the control plan in manufacturing systems.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Category describing the nature of the control plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Manufacturing process step(s) covered by the control plan.' ;
