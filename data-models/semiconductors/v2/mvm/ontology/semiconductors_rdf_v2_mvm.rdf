ind:primaryQuoteOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Opportunity Id' ;
    rdfs:comment 'FK to sales.opportunity.opportunity_id — Quotes are generated in the context of an opportunity. This is the core pipeline-to-commercial link. Required for quote-to-win conversion tracking.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:sourceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Source Opportunity Id' ;
    rdfs:comment 'FK to sales.opportunity.opportunity_id — Every quote is generated in context of an opportunity — this is the core pipeline-to-commercial conversion link. Engineers need this to trace quote→opportunity for pipeline reporting.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Timestamp when the quote was converted to an order, if applicable.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quote amounts.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Additional delivery conditions beyond Incoterms, such as FOB destination or DAP warehouse.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Monetary discount applied to the gross amount.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International commercial terms defining delivery responsibilities. [ENUM-REF-CANDIDATE: EXW|FCA|FOB|CFR|CIF|DAP|DDP — promote to reference product]' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Indicates whether the quote has been converted to a sales order.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order receipt to delivery.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount payable after discount and tax.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Timestamp when the quote was issued to the customer.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Human-readable business identifier for the quotation, often used in communications and tracking.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle state of the quote.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonLost rdf:type rdf:Property ;
    rdfs:label 'Reason Lost' ;
    rdfs:comment 'Textual reason provided when a quote is marked as lost.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax calculated on the gross amount after discount.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total quoted amount before discounts, taxes, or adjustments.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Date after which the quote is no longer valid.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winLossStatus rdf:type rdf:Property ;
    rdfs:label 'Win Loss Status' ;
    rdfs:comment 'Outcome of the quote after the decision period.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which the quoted terms become effective.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique identifier for the quote line record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QuoteLine .

ind:dieBankId rdf:type rdf:Property ;
    rdfs:label 'Die Bank Id' ;
    rdfs:comment 'Foreign key linking to inventory.die_bank. Business justification: KGD quote lines reference specific die bank lots for pricing (unit cost, bin class) and availability confirmation. Semiconductor KGD sales require quoting against actual die bank inventory to confirm ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:finishedGoodId rdf:type rdf:Property ;
    rdfs:label 'Finished Good Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_good. Business justification: Quote line pricing and availability require linking to the specific finished good inventory record for SKU, enabling real-time stock checks during quoting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGood .

ind:primaryQuoteId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Id' ;
    rdfs:comment 'Identifier of the parent sales quote to which this line belongs.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:tertiaryQuoteId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quote Id' ;
    rdfs:comment 'FK to sales.quote.quote_id — Header-detail relationship: quote_line cannot exist without its parent quote. Critical for quote value calculation and line-level pricing analysis.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost center to which the line\'s revenue is allocated.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRequestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Delivery Date' ;
    rdfs:comment 'Date the customer expects delivery of the quoted items.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Status' ;
    rdfs:comment 'Status of internal sales or finance approval for the line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustom rdf:type rdf:Property ;
    rdfs:label 'Is Custom' ;
    rdfs:comment 'True if the quoted SKU is a custom or engineered product.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineComment rdf:type rdf:Property ;
    rdfs:label 'Line Comment' ;
    rdfs:comment 'Free-form comment entered by the sales rep for this line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Unit price after discount, before tax.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier classification that determines discount levels.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the product requested in this line.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteLineStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Line Status' ;
    rdfs:comment 'Current lifecycle status of the quote line.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any customer-specific handling, packaging, or shipping notes.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate expressed as a percentage.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Gross amount for the line (unit_price * quantity) before tax.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Measurement unit for quantity, typically \'pcs\' for pieces.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyYears rdf:type rdf:Property ;
    rdfs:label 'Warranty Years' ;
    rdfs:comment 'Number of years of warranty offered for the product.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price List Id' ;
    rdfs:comment 'Reference to a newer price list that supersedes this one.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary amount of the price adjustment.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Business reason or justification for the price adjustment.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Type of price adjustment applied to the base price.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Append-only log of changes to the price list record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating if this price list is the default for its scope.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle status of the price list.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Category of pricing defined by the list (e.g., standard list, distributor, OEM, spot).' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Code' ;
    rdfs:comment 'SAP SD pricing condition record identifier.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code applicable to the price.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEnd rdf:type rdf:Property ;
    rdfs:label 'Validity End' ;
    rdfs:comment 'End date of the price list\'s validity window.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStart rdf:type rdf:Property ;
    rdfs:label 'Validity Start' ;
    rdfs:comment 'Start date of the price list\'s validity window.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volumeTierMax rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Max' ;
    rdfs:comment 'Maximum quantity for the volume pricing tier.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierMin rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Min' ;
    rdfs:comment 'Minimum quantity for the volume pricing tier.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCustomerOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Opportunity Id' ;
    rdfs:comment 'FK to sales.opportunity.opportunity_id — Long-term supply contracts often originate from won opportunities. Links contract terms back to the originating sales engagement.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of times the contract has been amended.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualValue rdf:type rdf:Property ;
    rdfs:label 'Annual Value' ;
    rdfs:comment 'Average yearly revenue expected from the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationClause rdf:type rdf:Property ;
    rdfs:label 'Arbitration Clause' ;
    rdfs:comment 'Indicates whether disputes are resolved via arbitration.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates if the contract will auto-renew at the end of its term.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClause rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause' ;
    rdfs:comment 'Indicates whether a confidentiality clause is present.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive title of the contract for easy identification.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'External contract number assigned by the customer or sales organization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Aggregate monetary value of the contract over its full term.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit exposure allowed for the customer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerContractStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Status' ;
    rdfs:comment 'Current lifecycle status of the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the base unit price.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eolClause rdf:type rdf:Property ;
    rdfs:label 'Eol Clause' ;
    rdfs:comment 'Indicates whether an End-of-Life provision is part of the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'How often invoices are issued under the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent contract amendment.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltbProvision rdf:type rdf:Property ;
    rdfs:label 'Ltb Provision' ;
    rdfs:comment 'Indicates whether a Last-Time-Buy clause is included.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Order Quantity' ;
    rdfs:comment 'Maximum quantity per order allowed under the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'Minimum quantity per order required by the contract.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcnObligation rdf:type rdf:Property ;
    rdfs:label 'Pcn Obligation' ;
    rdfs:comment 'Specifies if the supplier must notify the customer of product changes.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTerms rdf:type rdf:Property ;
    rdfs:label 'Pricing Terms' ;
    rdfs:comment 'Narrative description of pricing structure, discounts, and rebates.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Specifies whether the contract renews automatically, manually, or not at all.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyScope rdf:type rdf:Property ;
    rdfs:label 'Supply Scope' ;
    rdfs:comment 'Scope of supply coverage: exclusive, multi-source, or global.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which the contract is formally terminated.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days notice required before contract termination.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment' ;
    rdfs:comment 'Total quantity of units the customer commits to purchase over the contract term.' ;
    rdfs:domain ind:CustomerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'System-generated unique identifier for the forecast record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:bias rdf:type rdf:Property ;
    rdfs:label 'Bias' ;
    rdfs:comment 'Average signed deviation of forecast from actuals.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'High-level category of the forecast (demand, supply, or capacity).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Confidence rating assigned to the forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEnd rdf:type rdf:Property ;
    rdfs:label 'Effective End' ;
    rdfs:comment 'Last day of the period the forecast covers.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStart rdf:type rdf:Property ;
    rdfs:label 'Effective Start' ;
    rdfs:comment 'First day of the period the forecast covers.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period identifier (e.g., FY2025Q1).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Business identifier assigned to the forecast (e.g., F2025Q1-001).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast scenario (commit, upside, or best-case).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'Three-letter ISO country code representing the forecast geography.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizonMonths rdf:type rdf:Property ;
    rdfs:label 'Horizon Months' ;
    rdfs:comment 'Length of the forecast horizon expressed in months.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether the forecast is locked from further edits.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewer rdf:type rdf:Property ;
    rdfs:label 'Last Reviewer' ;
    rdfs:comment 'User identifier who performed the last review.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Statistical measure of forecast accuracy.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenue rdf:type rdf:Property ;
    rdfs:label 'Revenue' ;
    rdfs:comment 'Projected revenue amount for the forecast period.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Named scenario associated with the forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the forecast was submitted for review.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceToActual rdf:type rdf:Property ;
    rdfs:label 'Variance To Actual' ;
    rdfs:comment 'Percentage variance between forecast and actual results.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBookingOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Booking Opportunity Id' ;
    rdfs:comment 'FK to sales.opportunity.opportunity_id — Bookings fulfill opportunities. This link closes the pipeline-to-revenue loop essential for forecast accuracy measurement.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:backlogFlag rdf:type rdf:Property ;
    rdfs:label 'Backlog Flag' ;
    rdfs:comment 'True if the booking is currently in backlog (unfulfilled).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookedQuantity rdf:type rdf:Property ;
    rdfs:label 'Booked Quantity' ;
    rdfs:comment 'Number of units (dies) committed in the booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedRevenueGross rdf:type rdf:Property ;
    rdfs:label 'Booked Revenue Gross' ;
    rdfs:comment 'Total revenue amount before discounts and taxes, in the booking currency.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedRevenueNet rdf:type rdf:Property ;
    rdfs:label 'Booked Revenue Net' ;
    rdfs:comment 'Revenue after discounts and before tax.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Number' ;
    rdfs:comment 'External business number assigned to the booking, used in sales and finance processes.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle state of the booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Timestamp when the booking was created in the source system.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Preferred logistics mode for shipment.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalOrderRef rdf:type rdf:Property ;
    rdfs:label 'External Order Ref' ;
    rdfs:comment 'Reference to the original sales order in SAP SD.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastFlag rdf:type rdf:Property ;
    rdfs:label 'Forecast Flag' ;
    rdfs:comment 'True if the booking is included in the sales forecast.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'True if the booking is deemed critical for product launch or revenue targets.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the booking (e.g., standard sale, NRE, design-win).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'True if the booking must be reported under specific regulatory frameworks (e.g., CHIPS Act).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when the booked revenue is recognized for accounting.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipToCountry rdf:type rdf:Property ;
    rdfs:label 'Ship To Country' ;
    rdfs:comment 'Three-letter country code of the ship-to location.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTaxCode rdf:type rdf:Property ;
    rdfs:label 'Total Tax Code' ;
    rdfs:comment 'Tax code used for calculating tax_amount.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Warranty duration provided to the customer, in months.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the partner\'s primary business address.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the partner\'s primary business address (optional).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedProductLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Lines' ;
    rdfs:comment 'Comma-separated list of product families the partner may sell.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Partner Status' ;
    rdfs:comment 'Current operational status of the partner relationship.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Contract Effective From' ;
    rdfs:comment 'Date on which the partner contract becomes effective.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Until' ;
    rdfs:comment 'Date on which the partner contract expires or is scheduled to terminate (null if open-ended).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalPartnerCode rdf:type rdf:Property ;
    rdfs:label 'External Partner Code' ;
    rdfs:comment 'Identifier used for the partner in external systems (e.g., third-party distributor portal).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubConsignmentLevel rdf:type rdf:Property ;
    rdfs:label 'Hub Consignment Level' ;
    rdfs:comment 'Level of consignment inventory maintained at partner hubs.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryReportingObligation rdf:type rdf:Property ;
    rdfs:label 'Inventory Reporting Obligation' ;
    rdfs:comment 'Indicates whether the partner must provide regular inventory visibility to Semiconductors.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Date-time when the record was last reviewed for compliance or data quality.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Legal or trade name of the channel partner organization.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Category of the partner based on its business model and relationship to Semiconductors.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionClaimsAllowed rdf:type rdf:Property ;
    rdfs:label 'Price Protection Claims Allowed' ;
    rdfs:comment 'Indicates if the partner can submit price-protection claims under the agreement.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementType rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Type' ;
    rdfs:comment 'Pricing model governing the partner\'s purchase terms.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address used for official communications with the partner.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the main business contact for the partner.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Telephone number for the primary partner contact.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPartnerFunctionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Partner Function Code' ;
    rdfs:comment 'SAP SD code that classifies the partner\'s functional role (e.g., sold-to, ship-to, bill-to).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of partner inventory sold to end customers over a defined period.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockOnHand rdf:type rdf:Property ;
    rdfs:label 'Stock On Hand' ;
    rdfs:comment 'Current quantity of semiconductor units physically held by the partner.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCoverage rdf:type rdf:Property ;
    rdfs:label 'Territory Coverage' ;
    rdfs:comment 'Geographic or market territories the partner is authorized to sell within.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Strategic tier assigned to the partner reflecting level of authorization and performance expectations.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Estimated number of weeks the current stock will satisfy forecasted demand.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Primary key for order' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:originatingBookingId rdf:type rdf:Property ;
    rdfs:label 'Originating Booking Id' ;
    rdfs:comment 'Foreign key linking to sales.booking. Business justification: In semiconductors, a booking event (demand signal confirming customer intent) directly creates a sales order. Linking order back to its originating booking is essential for booking-to-revenue reconcil' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Shipping Execution process stores the exact customer address for each order; the Shipping Manifest and compliance checks depend on this link.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual date on which the ordered products were delivered to the customer or ship-to location. Used for on-time delivery (OTD) performance analysis and customer satisfaction reporting.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current inventory or production capacity allocation status of the order. Indicates whether sufficient die, wafer, or finished goods inventory has been reserved to fulfill the order. Critical for backlog management and supply-demand balancing.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Business reason code or description for order cancellation. Populated only when order_status is CANCELLED. Used for lost revenue analysis, demand forecasting accuracy, and customer relationship management.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chipsActEligible rdf:type rdf:Property ;
    rdfs:label 'Chips Act Eligible' ;
    rdfs:comment 'Indicates whether this order is associated with products or programs eligible for US CHIPS and Science Act incentives or reporting requirements. Used for government reporting and subsidy tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the semiconductor manufacturer based on production capacity, wafer fab scheduling, and logistics. May differ from the requested delivery date. Used for backlog management and customer commitment tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'The purchase order number provided by the customer at the time of order placement. Used for cross-referencing with the customer\'s procurement system and required for invoice matching. Corresponds to SAP VBAK.BSTNK.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The sales channel through which the order was placed. Determines pricing tiers, commission structures, and revenue reporting by channel. Corresponds to SAP VBAK.VTWEG.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endMarketSegment rdf:type rdf:Property ;
    rdfs:label 'End Market Segment' ;
    rdfs:comment 'The end-market application segment for which the ordered semiconductor products are destined. Used for market segmentation analysis, revenue reporting by vertical, and strategic planning. [ENUM-REF-CANDIDATE: COMPUTING|MOBILE|AUTOMOTIVE|AI_ML|IOT|INDUSTRIAL|NETWORKING|CONSUMER|DEFENSE|MEDICAL — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license is required for this order based on the destination country, end-user, and product ECCN classification. True triggers export compliance review workflow before shipment authorization.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossOrderValue rdf:type rdf:Property ;
    rdfs:label 'Gross Order Value' ;
    rdfs:comment 'Total gross value of the sales order before application of discounts, taxes, or surcharges, expressed in the order currency. Represents the sum of all line item gross values. Used for revenue forecasting and backlog valuation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Reason code or description for placing the order on hold. Populated when order_status is ON_HOLD. Common reasons include credit hold, export compliance review, customer request, or supply shortage.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the responsibilities of buyer and seller for delivery, risk transfer, and cost allocation. Corresponds to SAP VBAK.INCO1. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code, specifying where risk and cost transfer between buyer and seller (e.g., \'Shanghai Port\', \'Customer Dock\'). Corresponds to SAP VBAK.INCO2.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net value of the sales order after application of all discounts and pricing conditions but before tax. Represents the contractually agreed revenue amount. Corresponds to SAP VBAK.NETWR. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the customer placed the sales order. Represents the principal business event date for the order-to-cash lifecycle. Corresponds to SAP VBAK.AUDAT.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the sales order within the order-to-cash process. Drives workflow routing, backlog reporting, and revenue recognition. [ENUM-REF-CANDIDATE: DRAFT|OPEN|IN_FULFILLMENT|SHIPPED|DELIVERED|CLOSED|CANCELLED|ON_HOLD — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key defining the payment due date, early payment discount conditions, and cash discount percentages applicable to this order. Corresponds to SAP VBAK.ZTERM (e.g., NT30, NT60, 2/10NET30).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the order, influencing production scheduling, wafer start queue position, and allocation decisions. Critical orders may trigger expedite fees or override standard allocation rules.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the destination country for shipment. Critical for export compliance screening (EAR/ITAR/BIS), trade sanctions checks, and logistics routing. Corresponds to SAP ship-to party country.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soNumber rdf:type rdf:Property ;
    rdfs:label 'So Number' ;
    rdfs:comment 'Externally visible sales order number as assigned by SAP S/4HANA SD module. Used in all customer-facing communications, shipping documents, and invoices. Corresponds to the VBELN field in SAP VBAK table.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferStartAuthorization rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization' ;
    rdfs:comment 'Indicates whether this order has triggered a wafer start authorization in the fabrication facility (FAB). When True, the MES (Manufacturing Execution System) has been instructed to initiate wafer lot processing for this order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The date on which the semiconductor units for this order line were physically shipped from the warehouse or OSAT facility. Populated upon goods issue posting in SAP S/4HANA. Used for on-time delivery (OTD) performance measurement.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the supply allocation method applied to this order line. Standard = normal backlog allocation; Priority = customer-priority or design-win protected allocation; Strategic = long-term agreement allocation; Spot = spot market fulfillment; Buffer = safety stock draw.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity of semiconductor units confirmed by supply chain for delivery on this order line, reflecting available inventory, wafer start authorizations, and die bank allocations. May differ from ordered quantity due to allocation constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'The date confirmed by supply chain and manufacturing for shipment of this order line, based on available inventory, die bank status, and OSAT packaging capacity. May differ from requested ship date due to supply constraints.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateEntered rdf:type rdf:Property ;
    rdfs:label 'Date Entered' ;
    rdfs:comment 'The business date on which this order line was entered into the SAP S/4HANA SD system. Represents the commercial event date for backlog aging calculations and order-to-cash cycle time measurement.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP SD item category classification for this order line, indicating the business nature of the line (e.g., standard product sale, consignment fill-up, customer return, engineering sample, NRE charge, MPW service, evaluation unit). Drives pricing, delivery, and billing behavior. [ENUM-REF-CANDIDATE: standard|consignment|returns|sample|nre|mpw|evaluation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of this order line item within the order-to-cash lifecycle. Drives backlog management, allocation decisions, and revenue recognition. Corresponds to SAP S/4HANA SD overall delivery status at item level.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrder rdf:type rdf:Property ;
    rdfs:label 'Mpw Order' ;
    rdfs:comment 'Indicates whether this order line is associated with a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE costs. True = MPW order; False = dedicated production lot order.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value of this order line calculated as confirmed quantity multiplied by unit price in the transaction currency. Used for backlog reporting, revenue forecasting, and SOX-compliant revenue recognition. Corresponds to SAP S/4HANA SD NETWR (Net Value of the Order Item).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of semiconductor units (dies, packaged ICs, wafers, or reels) requested by the customer on this order line. Expressed in the sales unit of measure (e.g., pieces, wafers, reels). Corresponds to SAP S/4HANA SD KWMENG (Cumulative Order Quantity).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether the customer permits partial shipments against this order line. True = partial shipments accepted; False = complete order line quantity must ship together. Drives delivery scheduling and backlog management decisions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productRevision rdf:type rdf:Property ;
    rdfs:label 'Product Revision' ;
    rdfs:comment 'The silicon revision or stepping of the ordered semiconductor product (e.g., A0, B1, C2). Critical for tracking product change notifications (PCNs), errata management, and ensuring customers receive the correct silicon revision per their qualification.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'The date on which the customer has requested shipment of this order line. Drives production scheduling, wafer start authorization timelines, and OSAT packaging commitments. Corresponds to SAP S/4HANA SD WUNSK (Customer\'s Requested Delivery Date at Item Level).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'The native SAP S/4HANA SD six-digit item number (POSNR) for this order line, used for traceability back to the system of record and for EDI/customer portal reconciliation.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Cumulative quantity of semiconductor units actually shipped against this order line across all partial shipments. Used for backlog calculation and revenue recognition. Sourced from SAP S/4HANA SD delivery documents.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating special handling, storage, or shipping requirements for this order line (e.g., ESD-sensitive, moisture-sensitive level (MSL), controlled humidity, ITAR-controlled, hazmat). Drives warehouse and logistics instructions. [ENUM-REF-CANDIDATE: ESD|MSL1|MSL2|MSL3|ITAR|HAZMAT|CONTROLLED_TEMP|FRAGILE — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each delivery schedule line record in the SAP S/4HANA SD schedule line table (VBEP). Primary key for the delivery_schedule data product in the Silver layer.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyLotId rdf:type rdf:Property ;
    rdfs:label 'Assembly Lot Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_lot. Business justification: Delivery schedule lines in semiconductor ops are committed against specific assembly lots. Lot-level delivery commit tracking — used in customer commit reports and supply chain visibility dashboards —' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyLot .

ind:assemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Assembly Order Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_order. Business justification: In semiconductor make-to-order manufacturing, delivery schedule lines are driven by assembly orders. Production-to-delivery commit visibility — used in S&OP planning and customer promise date manageme' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:fulfillingShipmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfilling Shipment Id' ;
    rdfs:comment 'Foreign key linking to order.shipment. Business justification: A delivery schedule line represents a planned delivery commitment; a shipment represents the physical execution of that commitment. Linking delivery_schedule to shipment via fulfilling_shipment_id ena' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:originStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Storage Location Id' ;
    rdfs:comment 'Reference to the originating ship-from location for this delivery schedule line. May be a wafer fabrication facility (FAB), OSAT (Outsourced Semiconductor Assembly and Test) site, or finished goods warehouse.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryDeliveryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Order Line Id' ;
    rdfs:comment 'Reference to the specific sales order line item (order item) for which this delivery schedule line is created. A single order line may have multiple schedule lines representing different delivery windows.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:shipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Delivery schedules in semiconductors specify the exact customer destination address per schedule line (fab, warehouse, or consignment hub). Required for incoterms application, export control screening' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:toOrderLineId rdf:type rdf:Property ;
    rdfs:label 'To Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Delivery schedules define delivery windows per order line. delivery_schedule.order_line_id → order_line.order_line_id.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Numeric priority rank assigned to this delivery schedule line during constrained supply allocation. Lower values indicate higher priority. Used by supply chain planners to allocate limited wafer or die inventory across competing customer orders.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blanketOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is part of a blanket (framework) order with periodic call-offs. Blanket orders are common for high-volume semiconductor customers with rolling delivery schedules.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callOffNumber rdf:type rdf:Property ;
    rdfs:label 'Call Off Number' ;
    rdfs:comment 'The specific call-off or release number issued by the customer against a blanket order for this delivery schedule line. Identifies the periodic release instruction within the blanket order framework.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'The actual quantity of units shipped and delivered against this schedule line. Populated from goods issue and proof-of-delivery confirmation. Used to compute open backlog.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'SAP outbound delivery document number (SD delivery order) created against this schedule line. Links the schedule line to the physical goods issue and shipping execution documents.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment for this delivery schedule line contains hazardous materials (e.g., certain chemical compounds in semiconductor packaging). Triggers special handling, labeling, and documentation requirements per RoHS and REACH regulations.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Last Reschedule Reason' ;
    rdfs:comment 'Free-text or coded reason for the most recent rescheduling of this delivery schedule line (e.g., \'wafer yield shortfall\', \'OSAT capacity constraint\', \'customer push-out request\', \'export hold\'). Supports root cause analysis for delivery performance.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpwOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Mpw Order Flag' ;
    rdfs:comment 'Indicates whether this delivery schedule line is associated with a Multi-Project Wafer (MPW) order, where multiple customer designs share a single wafer run. MPW orders have distinct lead times and delivery constraints.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for all quantity fields on this schedule line. Common semiconductor units include PC (pieces/individual ICs), WF (wafers), KGD (Known Good Die), LOT (production lot), REEL (tape-and-reel packaging), TRAY (tray packaging).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapScheduleLineCategory rdf:type rdf:Property ;
    rdfs:label 'Sap Schedule Line Category' ;
    rdfs:comment 'SAP SD schedule line category code controlling the delivery and goods movement behavior of this schedule line (e.g., CP = standard delivery with transfer of requirements, CN = no goods movement). Sourced from SAP VBEP-ETTYP.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number of this delivery schedule entry within the parent order line item. Used to order multiple delivery windows for the same order line (e.g., line 1 = 500 units on date A, line 2 = 500 units on date B).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineRevision rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Revision' ;
    rdfs:comment 'Revision counter tracking how many times this delivery schedule line has been modified (date changes, quantity adjustments, rescheduling). Supports audit trail requirements and customer change notification (PCN) tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Status' ;
    rdfs:comment 'Current fulfillment lifecycle status of this delivery schedule line. Drives backlog management, delivery performance reporting, and customer communication. \'blocked\' indicates an export control or credit hold.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'The planned date on which the shipment is expected to leave the ship-from location (fab, OSAT, or warehouse). Calculated by subtracting transit lead time from the confirmed delivery date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waferStartAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Wafer Start Authorization Number' ;
    rdfs:comment 'Wafer Start Authorization number linking this delivery schedule line to the authorized wafer fab start that will produce the units for this delivery. Critical for semiconductor order-to-cash lifecycle management and fab capacity planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Unique system-generated identifier for the shipment record. Primary key for the shipment data product in the order domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:primaryShipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Order Id' ;
    rdfs:comment 'Reference to the parent sales order that initiated this shipment. Links the shipment back to the order-to-cash lifecycle.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:receivingContactId rdf:type rdf:Property ;
    rdfs:label 'Receiving Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Semiconductor shipments require a named customer receiving contact for ASN delivery notifications, customs clearance coordination, and proof-of-delivery confirmation. This contact is distinct from the' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:shipmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Shipment Order Id' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:toOrderId rdf:type rdf:Property ;
    rdfs:label 'To Order Id' ;
    rdfs:comment 'FK to order.order.order_id — Shipments fulfill customer orders. shipment.sales_order_id → order.sales_order_id. Critical for order-to-cash traceability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Confirmed date the shipment physically arrived at the customer receiving location. Populated from carrier proof of delivery (POD) or customer EDI 856 acknowledgement.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Advance Shipment Notice (ASN) number transmitted to the customer via EDI 856 prior to physical delivery. Enables customer warehouse receiving preparation and automated goods receipt.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the freight carrier or logistics service provider responsible for transporting the shipment (e.g., FedEx, DHL, UPS, Nippon Express). Used for carrier performance analytics and claims management.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment. Enables real-time shipment visibility and customer self-service tracking via carrier portals.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Damaged Goods Flag' ;
    rdfs:comment 'Indicates whether the customer reported damaged goods upon delivery. Triggers carrier claims process, RMA initiation, and DPPM (Defective Parts Per Million) quality reporting.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Declared value of the shipment contents in US dollars for customs and insurance purposes. Required for import duty calculation and export documentation under EAR/ITAR.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the customer delivery destination. Required for export compliance screening under EAR and ITAR regulations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Carrier-provided estimated date of arrival at the customer destination. Used for delivery scheduling, customer communication, and on-time delivery (OTD) performance tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Usd' ;
    rdfs:comment 'Total freight and logistics cost for this shipment in US dollars. Used for cost allocation, customer billing (if freight is charged), and supply chain cost analytics.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms including packaging. Required for carrier freight billing, customs declarations, and dangerous goods compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the semiconductor products in this shipment. Required for customs declarations, import duties, and cross-border trade compliance.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Reference number of the quality inspection certificate (Certificate of Conformance or Certificate of Analysis) accompanying the shipment. Required for automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiLeg rdf:type rdf:Property ;
    rdfs:label 'Is Multi Leg' ;
    rdfs:comment 'Indicates whether this shipment involves multiple transportation legs (e.g., fab to OSAT to customer, or cross-border transshipment). Enables multi-leg shipment tracking and compliance documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumbers rdf:type rdf:Property ;
    rdfs:label 'Lot Numbers' ;
    rdfs:comment 'Comma-separated list of manufacturing lot numbers (wafer lot IDs) included in this shipment. Enables full traceability from customer delivery back to wafer fabrication and process engineering records in Camstar MES.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Total number of physical packages (boxes, reels, trays, tubes) included in this shipment. Used for carrier manifest, customs declaration, and receiving verification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podConfirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed as received by the customer at the delivery location per the proof of delivery (POD). Compared against shipped_quantity to identify shortages or overages.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Pod Receipt Date' ;
    rdfs:comment 'Date the customer confirmed receipt of the shipment as captured in the proof of delivery (POD). Triggers downstream invoice release and revenue recognition in SAP S/4HANA FI.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podSignoffReference rdf:type rdf:Property ;
    rdfs:label 'Pod Signoff Reference' ;
    rdfs:comment 'Customer signoff reference or electronic signature identifier from the proof of delivery document. Serves as legal evidence of delivery completion for dispute resolution and revenue recognition.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityShortageFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Shortage Flag' ;
    rdfs:comment 'Indicates whether the customer reported a quantity shortage at delivery (POD confirmed quantity less than shipped quantity). Triggers discrepancy investigation and potential credit memo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'Code identifying the specific customer receiving dock, warehouse, or facility where the shipment was delivered. Used for multi-site customer delivery routing and POD reconciliation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Reference Number' ;
    rdfs:comment 'Return Merchandise Authorization (RMA) number associated with this shipment if a return or dispute has been initiated. Links shipment to the RMA and reverse logistics process.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Carrier service tier selected for this shipment (e.g., overnight, express, standard ground). Determines transit time commitment and freight cost.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Actual date the shipment physically departed the origin facility (fab, OSAT, or distribution center). Principal business event date for the shipment transaction.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible, human-readable shipment identifier used in carrier communications, customer EDI 856 ASN, and logistics documentation. Sourced from SAP S/4HANA SD outbound delivery number.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the shipment. Drives downstream processes including invoice release and revenue recognition upon delivery confirmation.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Unique tracking identifier provided by the carrier.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wrongPartFlag rdf:type rdf:Property ;
    rdfs:label 'Wrong Part Flag' ;
    rdfs:comment 'Indicates whether the customer reported receipt of an incorrect part number or product. Triggers RMA process, root cause analysis, and corrective action in the quality management system.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line record in the Silver Layer lakehouse. Primary key for the shipment_line data product.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillingAllocationRecordId rdf:type rdf:Property ;
    rdfs:label 'Fulfilling Allocation Record Id' ;
    rdfs:comment 'Foreign key linking to order.allocation_record. Business justification: In semiconductor order fulfillment, a shipment line is the physical execution of an allocation record — the allocation reserves specific wafer lots or die bank inventory, and the shipment line records' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRecord .

ind:primaryShipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Id' ;
    rdfs:comment 'Reference to the parent shipment header record. Links this line to the physical shipment event (HEADER_REFERENCE per TRANSACTION_LINE role).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:primaryShipmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Order Line Id' ;
    rdfs:comment 'Reference to the customer order line that this shipment line fulfills. Enables traceability from physical shipment back to the originating sales order line in the order-to-cash lifecycle.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:toShipmentId rdf:type rdf:Property ;
    rdfs:label 'To Shipment Id' ;
    rdfs:comment 'FK to order.shipment.shipment_id — Fundamental header-to-line relationship. Every shipment line must belong to exactly one shipment.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:advanceShipNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Number' ;
    rdfs:comment 'EDI Advance Ship Notice (ASN/856) document number transmitted to the customer prior to shipment. Enables customer receiving automation and inventory planning.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this shipment line represents a partial fulfillment of a backordered quantity, where the full ordered quantity could not be shipped due to inventory allocation constraints.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Number' ;
    rdfs:comment 'Document number of the Certificate of Conformance issued by quality assurance, attesting that the shipped product meets all specified requirements. Required for automotive (IATF 16949) and aerospace customers.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateCode rdf:type rdf:Property ;
    rdfs:label 'Date Code' ;
    rdfs:comment 'Manufacturing date code in YYWW format (year + work week) indicating when the product was fabricated or assembled. Required for shelf-life management, FIFO inventory rotation, and customer quality audits.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when goods issue was posted in SAP, marking the transfer of ownership and triggering revenue recognition and inventory reduction. BUSINESS_EVENT_TIMESTAMP for this transaction line.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value of this shipment line (shipped_quantity × unit_selling_price after applicable discounts). Used for revenue recognition, invoice generation, and SOX financial reporting.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Physical packaging configuration used for the shipped semiconductor units. Determines handling requirements, moisture sensitivity level (MSL), and customer SMT assembly compatibility.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer part number (MPN) for the shipped semiconductor product as listed in the product catalog and on the shipping documentation. Used for customer identification and BOM matching.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Flag' ;
    rdfs:comment 'Indicates whether this line represents a partial shipment against the order line quantity. When true, additional shipment lines are expected to fulfill the remaining ordered quantity.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Committed delivery date for this shipment line as agreed with the customer at order entry. Used for on-time delivery (OTD) performance measurement and customer SLA tracking.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Hardware or mask revision level of the shipped IC (e.g., A0, B1, C2). Critical for customer compatibility verification, PCN (Product Change Notification) compliance, and field failure analysis.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range End' ;
    rdfs:comment 'Ending serial number of the serialized unit range included in this shipment line. Used with serial_number_range_start to define the complete set of serialized units shipped.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range Start' ;
    rdfs:comment 'Starting serial number of the serialized unit range included in this shipment line. Applicable for high-value or security-sensitive ICs requiring individual unit traceability (e.g., automotive, military-grade).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Agreed selling price per unit for this shipment line as invoiced to the customer. LINE_VALUE_OR_RESULT per TRANSACTION_LINE role. Sensitive commercial pricing data.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldGrade rdf:type rdf:Property ;
    rdfs:label 'Yield Grade' ;
    rdfs:comment 'Quality or speed grade assigned to the shipped product based on wafer test (probe) results and final test binning. Indicates performance tier (e.g., commercial, industrial, automotive, military grade) for the shipped units.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogPositionId rdf:type rdf:Property ;
    rdfs:label 'Backlog Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each backlog position snapshot record in the order-to-cash lifecycle. Primary key for the backlog_position data product.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BacklogPosition .

ind:primaryOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Line Id' ;
    rdfs:comment 'FK to order.order_line.order_line_id — Backlog positions track unshipped quantities for specific order lines. Without this FK, backlog cannot be reconciled to orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity from available inventory or in-process production lots that has been formally allocated to fulfill this backlog position. May be less than committed_quantity in constrained supply scenarios.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backlogAgingDays rdf:type rdf:Property ;
    rdfs:label 'Backlog Aging Days' ;
    rdfs:comment 'Number of calendar days this order line has been in open backlog as of the snapshot date, calculated from order_entry_date. Used for customer escalation prioritization and aged backlog reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backlogQuantity rdf:type rdf:Property ;
    rdfs:label 'Backlog Quantity' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backlogStatus rdf:type rdf:Property ;
    rdfs:label 'Backlog Status' ;
    rdfs:comment 'Current workflow state of this backlog position. \'open\' = unshipped committed order; \'committed\' = confirmed with delivery date; \'at_risk\' = delivery commitment in jeopardy; \'pushed_out\' = delivery date deferred; \'cancelled\' = order line cancelled; \'fulfilled\' = shipped and closed.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogValue rdf:type rdf:Property ;
    rdfs:label 'Backlog Value' ;
    rdfs:comment 'The monetary value of the unshipped committed backlog quantity, calculated as committed_quantity multiplied by the net selling price. Used for revenue forecasting, quarterly guidance, and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cancelled Quantity' ;
    rdfs:comment 'Quantity cancelled from the original order line. Tracks cancellation impact on backlog coverage and book-to-bill ratio reporting.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The unshipped quantity (in units) that remains committed in backlog for this order line as of the snapshot date. Core metric for backlog management and production planning.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentCommitDate rdf:type rdf:Property ;
    rdfs:label 'Current Commit Date' ;
    rdfs:comment 'The most recent confirmed delivery date committed to the customer, reflecting any push-outs or pull-ins from the original promise date. Used for revenue forecasting and quarterly close planning.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designWinFlag rdf:type rdf:Property ;
    rdfs:label 'Design Win Flag' ;
    rdfs:comment 'Indicates whether this backlog position is associated with a strategic design-win account tracked in Salesforce CRM. Design-win orders receive elevated fulfillment priority to protect long-term revenue relationships.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether this order line is subject to export control regulations (EAR/ITAR). When true, shipment requires validated export license or license exception before fulfillment.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'The export license number issued by the Bureau of Industry and Security (BIS) or State Department authorizing shipment of controlled semiconductor products. Required when export_control_flag is true.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'Code indicating the reason this backlog position is on hold and cannot be shipped. Examples include credit hold, export license pending, quality hold, or customer-requested hold. Null when no hold is active. [ENUM-REF-CANDIDATE: credit_hold|export_hold|quality_hold|customer_hold|compliance_hold|capacity_hold — promote to reference product]' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Net Selling Price' ;
    rdfs:comment 'The agreed net unit selling price for this order line after all applicable discounts and price adjustments. Used to compute backlog value and support revenue recognition under ASC 606.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderEntryDate rdf:type rdf:Property ;
    rdfs:label 'Order Entry Date' ;
    rdfs:comment 'The date on which the customer order was originally entered into the order management system. Used to calculate backlog aging and time-in-backlog metrics.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Order Quantity' ;
    rdfs:comment 'The total quantity originally ordered by the customer on this order line. Used to calculate fulfillment percentage and track cancellation or reduction impacts on backlog.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPromiseDate rdf:type rdf:Property ;
    rdfs:label 'Original Promise Date' ;
    rdfs:comment 'The initial delivery date committed to the customer at the time of order entry. Baseline for measuring push-outs and delivery performance against original commitment.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking assigned to this backlog position for allocation and fulfillment sequencing. Lower values indicate higher priority. Used during supply-constrained periods to prioritize strategic customers and design-win accounts.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pushOutDays rdf:type rdf:Property ;
    rdfs:label 'Push Out Days' ;
    rdfs:comment 'Number of calendar days the current_commit_date has been deferred beyond the original_promise_date. Positive value indicates a push-out (delay); negative value indicates a pull-in (acceleration). Key metric for delivery performance and customer satisfaction.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pushOutReasonCode rdf:type rdf:Property ;
    rdfs:label 'Push Out Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the delivery commitment was pushed out or pulled in. Examples include wafer yield issue, capacity constraint, material shortage, customer request, or logistics delay. [ENUM-REF-CANDIDATE: yield_issue|capacity_constraint|material_shortage|customer_request|logistics_delay|design_change|export_hold — promote to reference product]' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Flag' ;
    rdfs:comment 'Indicates whether this backlog position meets the criteria for revenue recognition upon shipment under ASC 606 / IFRS 15. False indicates revenue deferral conditions apply (e.g., consignment, bill-and-hold arrangements).' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date on which this point-in-time backlog position snapshot was captured. Enables time-series backlog trending, quarterly close reporting, and book-to-bill ratio calculation.' ;
    rdfs:domain ind:BacklogPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationRecordId rdf:type rdf:Property ;
    rdfs:label 'Allocation Record Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a single inventory, capacity, or lot allocation record within the order fulfillment process.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedDieBankId rdf:type rdf:Property ;
    rdfs:label 'Allocated Die Bank Id' ;
    rdfs:comment 'Foreign key linking to inventory.die_bank. Business justification: KGD (Known Good Die) and bare die orders are allocated directly from die bank inventory. Semiconductor companies serving flip-chip or bare die customers must link allocation records to die bank to tra' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DieBank .

ind:allocatedFinishedGoodId rdf:type rdf:Property ;
    rdfs:label 'Allocated Finished Good Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_good. Business justification: Finished goods allocation to customer orders is a core semiconductor order fulfillment process. Allocation records must reference the specific finished goods inventory record being committed to a cust' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGood .

ind:allocatedInventoryWaferLotId rdf:type rdf:Property ;
    rdfs:label 'Allocated Inventory Wafer Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Semiconductor allocation planning explicitly ties wafer lot WIP inventory to allocation records for supply commit decisions. Allocation managers need to know which specific wafer lot backs each custom' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryWaferLot .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date on which the allocation was created and the inventory or capacity was reserved against the order line. Principal business event date for this transaction.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this allocation record. Used in customer communications, ERP transactions, and supply chain coordination.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'Identifies the inventory or capacity pool from which this allocation is drawn: \'finished_goods\' (packaged inventory), \'die_bank\' (singulated die inventory), \'wafer_lot\' (in-process wafer inventory), \'fab_capacity\' (reserved fab production capacity), \'mpw_pool\' (Multi-Project Wafer shared pool).' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the allocation assignment: \'tentative\' (preliminary hold), \'confirmed\' (firm allocation committed to order), \'shipped\' (goods dispatched against this allocation), \'cancelled\' (allocation voided), \'expired\' (allocation lapsed past expiry date), \'on_hold\' (allocation suspended pending resolution). [ENUM-REF-CANDIDATE: tentative|confirmed|shipped|cancelled|expired|on_hold — promote to reference product]' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The date on which the allocation was formally confirmed, transitioning from tentative or soft to confirmed status. Triggers downstream shipment scheduling.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constrainedSupplyFlag rdf:type rdf:Property ;
    rdfs:label 'Constrained Supply Flag' ;
    rdfs:comment 'Indicates whether this allocation was made under constrained supply conditions, where demand exceeded available inventory or fab capacity. Triggers priority-based allocation logic.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryBatchCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Batch Code' ;
    rdfs:comment 'SAP batch management identifier for the specific inventory batch being allocated. Enables batch-level traceability and quality disposition linkage within SAP S/4HANA MM.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatSiteCode rdf:type rdf:Property ;
    rdfs:label 'Osat Site Code' ;
    rdfs:comment 'Code identifying the Outsourced Semiconductor Assembly and Test (OSAT) facility responsible for packaging and testing the allocated lot. Relevant for packaged goods lot allocations.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDisposition rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition' ;
    rdfs:comment 'Quality disposition status of the allocated lot or inventory batch: \'accepted\' (meets all quality specifications), \'rejected\' (fails quality criteria), \'conditionally_accepted\' (accepted with documented deviations), \'under_review\' (quality evaluation in progress), \'scrapped\' (lot destroyed). Supports IATF 16949 lot-level quality traceability.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting lot-specific quality disposition findings, deviations, or conditions associated with this allocation. Supports automotive and aerospace traceability requirements.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the allocated quantity: \'EA\' (each, for packaged units), \'WFR\' (wafers), \'DIE\' (individual die), \'KPC\' (thousand pieces). Aligns with SAP base unit of measure.' ;
    rdfs:domain ind:AllocationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Primary key for rma' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:failureAnalysisReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Report Id' ;
    rdfs:comment 'Reference to the failure analysis record if FA was performed. Links RMA to detailed root cause investigation and corrective action.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureAnalysisReport .

ind:originalShipmentId rdf:type rdf:Property ;
    rdfs:label 'Original Shipment Id' ;
    rdfs:comment 'Foreign key linking to order.shipment. Business justification: An RMA is initiated because a customer received defective or incorrect product via a specific shipment. Linking rma.original_shipment_id to shipment.shipment_id enables direct traceability from the re' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:primaryRmaOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Rma Order Id' ;
    rdfs:comment 'FK to order.order.order_id — RMAs reference the original sales order for the returned product. rma.sales_order_id → order.sales_order_id.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:receivingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Returned goods are received at a specific quarantine or receiving storage location. receiving_facility_code is a denormalized plain text field on rma. Linking to storage_location enables quarantine in' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:returnFromAddressId rdf:type rdf:Property ;
    rdfs:label 'Return From Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: RMA logistics require the customer ship-from address for carrier pickup scheduling, export control re-screening of returned goods, and credit memo processing. In semiconductors, returned parts may be ' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:returnInspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Return Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Returned material in semiconductor RMA processes undergoes incoming inspection, creating an inspection_lot for disposition (scrap, rework, return to stock). Role-prefix \'return_\' distinguishes incomin' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:returnedFinishedGoodId rdf:type rdf:Property ;
    rdfs:label 'Returned Finished Good Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_good. Business justification: RMA disposition processing requires linking returned parts to the finished goods inventory record for restock, scrap, or rework decisions. Quality teams need to match returned goods to the original fi' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGood .

ind:rmaOrderId rdf:type rdf:Property ;
    rdfs:label 'Rma Order Id' ;
    rdfs:comment 'FK to order.sales_order.sales_order_id — RMAs reference the original sales order for the returned product. Required for credit processing and quality traceability.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:tertiaryRmaSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rma Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order from which the returned product was shipped. Links RMA to the originating order transaction.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:unitTestResultId rdf:type rdf:Property ;
    rdfs:label 'Unit Test Result Id' ;
    rdfs:comment 'Foreign key linking to test.unit_test_result. Business justification: Unit-level RMA failure analysis requires linking the returned device to its specific unit_test_result to identify test escapes and correlate parametric data with field failures. Semiconductor FA engin' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitTestResult .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the RMA was fully closed after disposition action completed (credit issued, replacement shipped, or material scrapped).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a formal corrective action (CAPA) is required based on the RMA findings. True triggers CAPA workflow per ISO 9001 and IATF 16949.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of the credit issued to the customer in the transaction currency. Nullable if no credit is issued.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued to the customer for the returned material. Nullable if no credit is issued (e.g., customer error returns).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the defect or issue reported by the customer. Captures detailed failure symptoms, visual observations, or functional anomalies.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Action to be taken with the returned material. Determines downstream workflow (credit memo, replacement order, FA request, or scrap authorization).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Dppm Impact Flag' ;
    rdfs:comment 'Indicates whether this RMA should be counted in DPPM calculations. True if the defect is attributable to manufacturing or design (excludes customer-induced damage).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureAnalysisRequested rdf:type rdf:Property ;
    rdfs:label 'Failure Analysis Requested' ;
    rdfs:comment 'Indicates whether a formal failure analysis (FA) has been requested for the returned units. True triggers FA workflow and lab assignment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the incoming inspection. Determines whether the return claim is valid and informs disposition and credit decisions.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments for cross-functional coordination (quality, engineering, customer service). Not shared with customer.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the customer initiated the RMA request. Principal business event timestamp for the RMA lifecycle.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnReason rdf:type rdf:Property ;
    rdfs:label 'Return Reason' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for the return. Used for root cause analysis, DPPM tracking, and warranty claim classification.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCarrier rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Carrier' ;
    rdfs:comment 'Name of the logistics carrier used to ship the returned material (e.g., FedEx, UPS, DHL, regional freight forwarder).' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the return shipment. Used for shipment visibility and proof of receipt.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Number of units (dies, packaged chips, or wafers) returned under this RMA. Used for DPPM calculation and inventory adjustment.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaDate rdf:type rdf:Property ;
    rdfs:label 'Rma Date' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the RMA. Used in customer communications, shipping labels, and cross-system tracking.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks progression from customer request through receipt, inspection, and final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause identified during inspection or FA. Used for DPPM trending and corrective action prioritization.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this RMA is being processed as a warranty claim. True if the return is within warranty period and defect is covered.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Foreign key linking to equipment.calibration_record. Business justification: IATF 16949 requires traceability of measurement equipment calibration status at the time of inspection. Linking inspection_lot to the active calibration_record of the inspection tool enables auditors ' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationRecord .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Maximum defect count allowed for acceptance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensity rdf:type rdf:Property ;
    rdfs:label 'Defect Density' ;
    rdfs:comment 'Defects per unit area metric for the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Explanation for the chosen disposition.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLotCode rdf:type rdf:Property ;
    rdfs:label 'External Lot Code' ;
    rdfs:comment 'External reference code used by suppliers or customers.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatf16949Compliant rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Compliant' ;
    rdfs:comment 'Indicates compliance with IATF 16949 automotive quality standards.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionLotStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Process stage at which the inspection occurs.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Category of inspection performed on the lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Compliant rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Compliant' ;
    rdfs:comment 'Indicates compliance with ISO 9001 quality management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jedecReliabilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Jedec Reliability Compliant' ;
    rdfs:comment 'Indicates compliance with JEDEC reliability specifications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Date' ;
    rdfs:comment 'Date when KGD certification was granted.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kgdCertified rdf:type rdf:Property ;
    rdfs:label 'Kgd Certified' ;
    rdfs:comment 'Flag indicating whether the lot contains KGD-certified dies.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Type of material the lot consists of.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityEngineer rdf:type rdf:Property ;
    rdfs:label 'Quality Engineer' ;
    rdfs:comment 'Name of the quality engineer responsible for the lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Rejection Criteria' ;
    rdfs:comment 'Defect count threshold that triggers rejection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of units sampled from the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingPlanAql rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Aql' ;
    rdfs:comment 'AQL value defined for the sampling plan.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Percent' ;
    rdfs:comment 'Percentage of good units produced from the lot.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Unique identifier for the defect record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:primaryWaferMapId rdf:type rdf:Property ;
    rdfs:label 'Primary Wafer Map Id' ;
    rdfs:comment 'FK to quality.wafer_map.wafer_map_id — Defects with X/Y coordinates must link to the wafer map for spatial analysis. This is critical for systematic defect pattern detection.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:binAssignment rdf:type rdf:Property ;
    rdfs:label 'Bin Assignment' ;
    rdfs:comment 'Pass/fail bin code assigned to the die (e.g., P, F1, F2).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Planned or executed action to remediate the defect.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectAreaUm2 rdf:type rdf:Property ;
    rdfs:label 'Defect Area Um2' ;
    rdfs:comment 'Calculated area of the defect in square micrometers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'High-level classification of the defect (e.g., particle, patterning, etch).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code representing the defect type (e.g., D001, D002).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDensityPerZone rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Zone' ;
    rdfs:comment 'Number of defects per unit area within the zone.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectLayer rdf:type rdf:Property ;
    rdfs:label 'Defect Layer' ;
    rdfs:comment 'Process layer where the defect was found.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Severity rating indicating impact on yield.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSizeNm rdf:type rdf:Property ;
    rdfs:label 'Defect Size Nm' ;
    rdfs:comment 'Measured size of the defect in nanometers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current workflow status of the defect record.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Technique used to detect the defect.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieX rdf:type rdf:Property ;
    rdfs:label 'Die X' ;
    rdfs:comment 'Column index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieY rdf:type rdf:Property ;
    rdfs:label 'Die Y' ;
    rdfs:comment 'Row index of the die containing the defect on the wafer grid.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edgeExclusionZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Edge Exclusion Zone Flag' ;
    rdfs:comment 'Indicates whether the defect lies within the defined edge exclusion area.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the defect was detected during inspection.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flatNotchOrientation rdf:type rdf:Property ;
    rdfs:label 'Flat Notch Orientation' ;
    rdfs:comment 'Orientation of wafer flat or notch relative to the defect.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRecipe rdf:type rdf:Property ;
    rdfs:label 'Inspection Recipe' ;
    rdfs:comment 'Name of the inspection recipe or parameter set used.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Repeatability Flag' ;
    rdfs:comment 'True if the defect pattern repeats across multiple wafers.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Narrative description of the identified root cause.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical position of the defect on the wafer map (millimeters).' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferMapId rdf:type rdf:Property ;
    rdfs:label 'Wafer Map Id' ;
    rdfs:comment 'Primary key for wafer_map' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaferMap .

ind:binCountTotal rdf:type rdf:Property ;
    rdfs:label 'Bin Count Total' ;
    rdfs:comment 'Total number of distinct bins used in the map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIatf16949 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iatf16949' ;
    rdfs:comment 'Flag indicating compliance with IATF 16949 for this wafer map.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceIso9001 rdf:type rdf:Property ;
    rdfs:label 'Compliance Iso9001' ;
    rdfs:comment 'Flag indicating compliance with ISO 9001 for this wafer map.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectDensityPerSqmm rdf:type rdf:Property ;
    rdfs:label 'Defect Density Per Sqmm' ;
    rdfs:comment 'Average defect density across the wafer measured in defects per square millimeter.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Primary defect type identified on the wafer.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectZone rdf:type rdf:Property ;
    rdfs:label 'Defect Zone' ;
    rdfs:comment 'Region of the wafer where defects are concentrated.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieGridColumns rdf:type rdf:Property ;
    rdfs:label 'Die Grid Columns' ;
    rdfs:comment 'Number of die columns in the wafer grid.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieGridRows rdf:type rdf:Property ;
    rdfs:label 'Die Grid Rows' ;
    rdfs:comment 'Number of die rows in the wafer grid.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Die Yield Percentage' ;
    rdfs:comment 'Yield percentage calculated from passing dies over total dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:edgeExclusionZoneMm rdf:type rdf:Property ;
    rdfs:label 'Edge Exclusion Zone Mm' ;
    rdfs:comment 'Width of the edge exclusion zone in millimeters where dies are not counted.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failBinCode rdf:type rdf:Property ;
    rdfs:label 'Fail Bin Code' ;
    rdfs:comment 'Bin code representing failing (defective) dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failingDieCount rdf:type rdf:Property ;
    rdfs:label 'Failing Die Count' ;
    rdfs:comment 'Number of dies classified as failing.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatOrientation rdf:type rdf:Property ;
    rdfs:label 'Flat Orientation' ;
    rdfs:comment 'Orientation of the wafer flat/notch relative to the map coordinate system.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKgdCertified rdf:type rdf:Property ;
    rdfs:label 'Is Kgd Certified' ;
    rdfs:comment 'Indicates whether the wafer passed Known Good Die certification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdCertificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kgd Certification Timestamp' ;
    rdfs:comment 'Timestamp when KGD certification was applied.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mapChecksum rdf:type rdf:Property ;
    rdfs:label 'Map Checksum' ;
    rdfs:comment 'Checksum (e.g., SHA-256) of the map file for integrity verification.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapFilePath rdf:type rdf:Property ;
    rdfs:label 'Map File Path' ;
    rdfs:comment 'File system path or URI where the wafer map image/file is stored.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Map Generation Timestamp' ;
    rdfs:comment 'Date and time when the wafer map was generated.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mapStatus rdf:type rdf:Property ;
    rdfs:label 'Map Status' ;
    rdfs:comment 'Current processing status of the wafer map.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapVersion rdf:type rdf:Property ;
    rdfs:label 'Map Version' ;
    rdfs:comment 'Version identifier of the map generation algorithm or software.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passBinCode rdf:type rdf:Property ;
    rdfs:label 'Pass Bin Code' ;
    rdfs:comment 'Bin code representing passing (good) dies.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingDieCount rdf:type rdf:Property ;
    rdfs:label 'Passing Die Count' ;
    rdfs:comment 'Number of dies classified as passing.' ;
    rdfs:domain ind:WaferMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text comments or notes about the wafer map.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDieCount rdf:type rdf:Property ;
    rdfs:label 'Total Die Count' ;
    rdfs:comment 'Total number of dies evaluated on the wafer.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'System-generated unique identifier for the yield record.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolQualificationId rdf:type rdf:Property ;
    rdfs:label 'Tool Qualification Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_qualification. Business justification: Yield records from qualification wafer runs are the primary evidence for tool qualification acceptance. Process engineers reference the tool qualification to contextualize yield data, distinguish qual' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolQualification .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier of the data acquisition batch.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
