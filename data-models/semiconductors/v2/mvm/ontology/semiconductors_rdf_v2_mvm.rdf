    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingRate rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate' ;
    rdfs:comment 'Frequency or method of sampling for the control plan.' ;
