ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Number of units that the net price applies to (e.g., price per 1000 pieces).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which the goods were received.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Receipt Quantity' ;
    rdfs:comment 'Quantity of material that has been received against this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'Risk rating (0-100) assessing supplier and material availability risk.' ;
