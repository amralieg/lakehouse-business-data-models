ind:limitId rdf:type rdf:Property ;
    rdfs:label 'Limit Id' ;
    rdfs:comment 'Foreign key linking to test.limit. Business justification: Quality specs define engineering acceptance criteria that test limits must implement. Quality engineers must verify that test limits conform to quality specs during product qualification and spec chan' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Limit .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
