    rdfs:comment 'Last calendar date of the shipment period covered by this DPPM record.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Start Date' ;
    rdfs:comment 'First calendar date of the shipment period covered by this DPPM record.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalUnitsShipped rdf:type rdf:Property ;
    rdfs:label 'Total Units Shipped' ;
    rdfs:comment 'Total number of units shipped to the customer during the shipment period.' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsShipped rdf:type rdf:Property ;
    rdfs:label 'Units Shipped' ;
    rdfs:domain ind:DppmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredMaintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Required Maintenance Event Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_event. Business justification: CAPA corrective actions in semiconductor fabs frequently require specific maintenance events (tool repair, chamber replacement, recalibration). Quality engineers link the CAPA to the maintenance event' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when the action was actually completed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attachmentReference rdf:type rdf:Property ;
    rdfs:label 'Attachment Reference' ;
    rdfs:comment 'Reference (e.g., URL or file ID) to supporting documents or images.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business identifier or code assigned to the CAPA for tracking and reference.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Record Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the action is corrective or preventive.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Approval Status' ;
    rdfs:comment 'Approval status of the CAPA closure after verification.' ;
    rdfs:domain ind:CapaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference' ;
    rdfs:comment 'Reference to the specific compliance clause or standard (e.g., ISO 9001, IATF 16949) governing the CAPA.' ;
