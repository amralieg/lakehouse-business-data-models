    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The work order number of the maintenance event record in the equipment domain.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolDowntimeId rdf:type rdf:Property ;
    rdfs:label 'Tool Downtime Id' ;
    rdfs:comment 'System-generated unique identifier for each downtime event record.' ;
    rdfs:domain ind:ToolDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Foreign key linking to equipment.oee_record. Business justification: Granular downtime records (tool_downtime) contribute to OEE calculations in a specific measurement period. Linking tool_downtime to the oee_record for the period in which the downtime occurred enables' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OeeRecord .

ind:primaryToolMaintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Tool Maintenance Event Id' ;
    rdfs:comment 'Reference to the maintenance work order associated with the downtime, if any.' ;
    rdfs:domain ind:ToolDowntime ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:toMaintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'To Maintenance Event Id' ;
    rdfs:comment 'FK to equipment.maintenance_event.maintenance_event_id — Downtime events caused by maintenance must link to the maintenance event for root cause tracing and planned vs unplanned analysis.' ;
    rdfs:domain ind:ToolDowntime ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Brief description of the corrective action performed to resolve the issue.' ;
