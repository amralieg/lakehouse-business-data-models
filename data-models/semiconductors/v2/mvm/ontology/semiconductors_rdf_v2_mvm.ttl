ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Alphanumeric code used in test programs to reference the bin.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Definition Status' ;
    rdfs:comment 'Current lifecycle status of the bin definition.' ;
