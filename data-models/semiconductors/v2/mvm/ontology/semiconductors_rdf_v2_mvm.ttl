    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Account Number' ;
    rdfs:comment 'Bank account number of the payer.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBankCode rdf:type rdf:Property ;
    rdfs:label 'Payer Bank Code' ;
    rdfs:comment 'Identifier (e.g., SWIFT/BIC) of the payer\'s bank.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Legal name of the entity making the payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The payment amount of the payment receipt record in the invoice domain.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which the payment was processed.' ;
