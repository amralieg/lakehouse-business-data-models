    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'The ncr number of the nonconformance report record in the quality domain.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'The ncr status of the nonconformance report record in the quality domain.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceDescription rdf:type rdf:Property ;
