    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'Percentage of good units produced out of total units processed.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the OEE record.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Downtime Hours' ;
    rdfs:comment 'Planned downtime (e.g., maintenance, changeover) duration in hours.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date of the production shift associated with the OEE record.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Label of the shift (e.g., A, B, C, D) during which the OEE data was collected.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCurrent rdf:type rdf:Property ;
    rdfs:label 'State Current' ;
    rdfs:comment 'Equipment state at the end of the measurement period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLastChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'State Last Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent state transition within the period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stateTransitionCount rdf:type rdf:Property ;
    rdfs:label 'State Transition Count' ;
    rdfs:comment 'Number of equipment state changes recorded in the period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'The total units of the oee record record in the equipment domain.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unscheduledDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Unscheduled Downtime Hours' ;
    rdfs:comment 'Unplanned downtime (e.g., breakdown) duration in hours.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uptimeHours rdf:type rdf:Property ;
    rdfs:label 'Uptime Hours' ;
    rdfs:comment 'The uptime hours of the oee record record in the equipment domain.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferThroughput rdf:type rdf:Property ;
    rdfs:label 'Wafer Throughput' ;
    rdfs:comment 'Number of good wafers produced per hour (WPH) during the period.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Unique surrogate key for each spare part record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'True if the part must be calibrated periodically (e.g., sensors, metrology tools).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of regulatory or industry certifications applicable to the part (e.g., RoHS, REACH).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticality rdf:type rdf:Property ;
    rdfs:label 'Criticality' ;
    rdfs:comment 'The criticality of the spare part record in the equipment domain.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business impact rating if the part is unavailable (high = production-stop risk).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStockQty rdf:type rdf:Property ;
    rdfs:label 'Current Stock Qty' ;
    rdfs:comment 'Number of units of the part currently available in the fab stockroom.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Preferred method for disposing of excess or expired parts.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the part is classified as hazardous under safety regulations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date the most recent shipment of this part was received into inventory.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date the part was last issued for equipment maintenance or repair.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle End Date' ;
    rdfs:comment 'Date the part was officially retired or marked obsolete.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Start Date' ;
    rdfs:comment 'Date the part was first introduced into the inventory catalog.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific storage bin or area within the fab stockroom.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Minimum quantity that must be on hand to avoid stock-out situations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level equipment domain the part supports. [ENUM-REF-CANDIDATE: lithography|deposition|etch|cmp|metrology|ate|assembly|test|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'The part description of the spare part record in the equipment domain.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partImageUrl rdf:type rdf:Property ;
    rdfs:label 'Part Image Url' ;
    rdfs:comment 'Link to a digital image or drawing of the spare part.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable name of the spare part used in inventory and work orders.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'The part status of the spare part record in the equipment domain.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the part based on its usage and criticality to fab operations.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partVolumeCm3 rdf:type rdf:Property ;
    rdfs:label 'Part Volume Cm3' ;
    rdfs:comment 'Physical volume of a single unit of the part in cubic centimeters.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partWeightKg rdf:type rdf:Property ;
    rdfs:label 'Part Weight Kg' ;
    rdfs:comment 'Physical weight of a single unit of the part in kilograms.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The quantity on hand of the spare part record in the equipment domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory quantity threshold that triggers a replenishment order.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Buffer quantity kept to protect against demand variability and supply delays.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartStatus rdf:type rdf:Property ;
    rdfs:label 'Spare Part Status' ;
    rdfs:comment 'Current lifecycle status of the part within the inventory system.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockQuantity rdf:type rdf:Property ;
    rdfs:label 'Stock Quantity' ;
    rdfs:comment 'The stock quantity of the spare part record in the equipment domain.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Environmental condition required for safe storage of the part.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'The storage location of the spare part record in the equipment domain.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard purchase cost per individual unit of the part.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Usd' ;
    rdfs:comment 'The unit cost usd of the spare part record in the equipment domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentProcessStepId rdf:type rdf:Property ;
    rdfs:label 'Current Process Step Id' ;
    rdfs:comment 'Foreign key linking to process.process_step. Business justification: Real-time WIP location: current_operation_step is a denormalized text field; replacing with current_process_step_id FK enables queue-depth-by-step reports, bottleneck analysis, and cycle time tracking' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Step .

ind:goodWaferCount rdf:type rdf:Property ;
    rdfs:label 'Good Wafer Count' ;
    rdfs:comment 'Number of wafers in the lot that have passed all in-line inspection and metrology checks to date. Represents the current count of wafers expected to yield good die. Updated after each inspection or disposition event.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Current standard cost valuation of the wafer lot in the inventory ledger, expressed in the functional currency. Calculated based on the number of wafers and the standard cost per wafer at the current process step. Used for WIP inventory valuation in SAP FI/CO and financial reporting under SOX.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotStartDate rdf:type rdf:Property ;
    rdfs:label 'Lot Start Date' ;
    rdfs:comment 'Calendar date on which the wafer lot was officially started (wafer start authorization executed) in the FAB. Used for cycle time measurement, WIP aging analysis, and on-time delivery tracking. This is the BUSINESS_EVENT_TIMESTAMP (date precision) category field.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesLotReference rdf:type rdf:Property ;
    rdfs:label 'Mes Lot Reference' ;
    rdfs:comment 'Native lot reference number as recorded in the Applied Materials SmartFactory or Camstar MES system. Enables direct cross-reference to the operational system of record for lot tracking, dispatch, and WIP management.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'High-level semiconductor fabrication stage classification: FEOL (Front End of Line) covers transistor formation; MOL (Middle of Line) covers local interconnects; BEOL (Back End of Line) covers metal interconnect layers. Used for WIP stage-gate reporting and cycle time decomposition.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this wafer lot record was sourced (e.g., CAMSTAR for Camstar MES, SMARTFACTORY for Applied Materials SmartFactory, SAP_PP for SAP Production Planning). Supports data lineage and multi-system reconciliation in the Databricks Silver layer.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the inventory valuation amount (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferCountCurrent rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Current' ;
    rdfs:comment 'Current number of wafers remaining in the lot after accounting for any scrapped or split wafers during processing. Reflects real-time WIP inventory quantity for this lot.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferCountStart rdf:type rdf:Property ;
    rdfs:label 'Wafer Count Start' ;
    rdfs:comment 'Number of wafers in the lot at the time of lot creation (wafer start). Typically 25 wafers per FOUP/cassette for standard lots. Used as the baseline denominator for yield and scrap rate calculations. This is the QUANTITATIVE_RESULT / principal measured quantity for this WIP transaction.' ;
    rdfs:domain ind:InventoryWaferLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Wafer Diameter Mm' ;
    rdfs:comment 'Physical diameter of the silicon wafers in this lot, in millimeters. Standard values are 200mm (8-inch) and 300mm (12-inch). Determines equipment compatibility, cassette type, and cost per wafer.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Indicates whether the raw material is managed at the batch/lot level in SAP inventory management. Batch management is mandatory for silicon wafers, photomasks, and shelf-life-controlled chemicals to enable full lot traceability from receipt through consumption. Corresponds to SAP MARA.XCHPF.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'The unique CAS Registry Number assigned by the American Chemical Society to identify chemical substances. Mandatory for process chemicals, specialty gases, CMP slurries, and ALD precursors for REACH, RoHS, and TSCA regulatory compliance reporting.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'The certificate of analysis number of the raw material record in the inventory domain.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedLotQty rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Qty' ;
    rdfs:comment 'Fixed order quantity used when lot_size_type is \'fixed\'. Represents the standard purchase order quantity per replenishment cycle, often aligned with supplier minimum order quantities or packaging units. Corresponds to SAP MARC.BSTFE.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'GHS/UN hazard classification of the raw material for safe storage, handling, and transport. Drives storage location assignment, PPE requirements, and emergency response procedures. [ENUM-REF-CANDIDATE: non_hazardous|flammable|corrosive|toxic|oxidizer|pyrophoric|compressed_gas|carcinogen — promote to reference product]' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Flag' ;
    rdfs:comment 'The hazardous flag of the raw material record in the inventory domain.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether incoming quality inspection (IQC) is mandatory upon goods receipt for this raw material. When true, received lots are placed in quality inspection stock in SAP QM before being released to unrestricted use. Corresponds to SAP MARC.QKZUL.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeType rdf:type rdf:Property ;
    rdfs:label 'Lot Size Type' ;
    rdfs:comment 'SAP MRP lot-sizing procedure that determines how replenishment quantities are calculated. \'fixed\' orders a fixed quantity, \'lot_for_lot\' orders exact requirement, \'min_max\' uses min/max boundaries, \'periodic\' groups requirements by period. Corresponds to SAP MARC.DISMM.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialClass rdf:type rdf:Property ;
    rdfs:label 'Material Class' ;
    rdfs:comment 'High-level classification of the raw material type used in semiconductor manufacturing. Drives storage, handling, and compliance rules. [ENUM-REF-CANDIDATE: silicon_wafer|photomask|process_chemical|specialty_gas|cmp_slurry|ald_precursor|packaging_material|other — promote to reference product]' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the raw material in SAP S/4HANA MM (Material Master number / MATNR). Used across procurement, inventory, and manufacturing systems as the primary business identifier for the material.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGrade rdf:type rdf:Property ;
    rdfs:label 'Material Grade' ;
    rdfs:comment 'The material grade of the raw material record in the inventory domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group code (MARA.MATKL) used to categorize raw materials for procurement, reporting, and spend analytics. Examples: \'WAFER-SI\', \'CHEM-ETCH\', \'GAS-SPEC\', \'MASK-EUV\'.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Human-readable short description or name of the raw material (e.g., \'Silicon Wafer 300mm P-Type\', \'HMDS Adhesion Promoter\', \'ArF Photomask Layer 1\'). Corresponds to SAP MARA.MAKTX (material description).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the raw material master record. Controls whether the material can be procured, consumed in production, or is subject to end-of-life (EOL) restrictions. Aligns with SAP MARA.MMSTA (plant-level material status).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable inventory quantity for the raw material, used to prevent overstocking of hazardous materials, shelf-life-limited chemicals, or high-cost items. Corresponds to SAP MARC.MABST (maximum stock level).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Min Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum number of days of remaining shelf life required at the time of goods receipt for the material to be accepted into inventory. Materials received with less than this remaining shelf life are rejected or placed in restricted use. Corresponds to SAP MARA.MHDLP.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movingAvgPrice rdf:type rdf:Property ;
    rdfs:label 'Moving Avg Price' ;
    rdfs:comment 'Current moving average price per base unit of measure, recalculated with each goods receipt based on actual purchase prices. Used for inventory valuation under the moving average price control method. Corresponds to SAP MBEW.VERPR.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlType rdf:type rdf:Property ;
    rdfs:label 'Price Control Type' ;
    rdfs:comment 'Determines the inventory valuation method for the material: \'standard\' uses a fixed standard price, \'moving_average\' recalculates price with each goods movement. Corresponds to SAP MBEW.VPRSV (price control indicator: S or V).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard price and moving average price fields (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityPct rdf:type rdf:Property ;
    rdfs:label 'Purity Pct' ;
    rdfs:comment 'Chemical purity of the raw material expressed as a percentage (e.g., 99.9999 for 6N-grade specialty gases, 99.99 for ultra-high-purity chemicals). Critical quality specification for process chemicals, specialty gases, and ALD precursors where trace contamination causes yield loss.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityPercent rdf:type rdf:Property ;
    rdfs:label 'Purity Percent' ;
    rdfs:comment 'The purity percent of the raw material record in the inventory domain.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawMaterialStatus rdf:type rdf:Property ;
    rdfs:label 'Raw Material Status' ;
    rdfs:comment 'The status of the raw material record in the inventory domain.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSvhcFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Flag' ;
    rdfs:comment 'Indicates whether the raw material contains or is classified as a Substance of Very High Concern (SVHC) under the EU REACH Regulation. Triggers mandatory disclosure obligations when SVHC concentration exceeds 0.1% w/w in articles.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The receipt date associated with the raw material inventory record.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment purchase requisition is automatically triggered in SAP MRP. When on-hand stock falls to or below this quantity, procurement is initiated to prevent production line stoppages. Corresponds to SAP MARC.MINBE (reorder point).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialized rdf:type rdf:Property ;
    rdfs:label 'Serialized' ;
    rdfs:comment 'Indicates whether individual units of the raw material are tracked by unique serial number. Applicable to high-value items such as photomasks and reticles where individual unit traceability is required for defect root cause analysis and reticle qualification tracking.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the raw material can be stored from the date of manufacture or receipt before it is considered expired and must be quarantined or disposed of. Critical for photoresists, ALD precursors, and specialty chemicals with time-sensitive stability. Corresponds to SAP MARA.MHDRZ (shelf life in days).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Standard cost price per base unit of measure used for inventory valuation in SAP CO (Controlling) and FI (Financial Accounting). Used for WIP costing, variance analysis, and financial reporting. Corresponds to SAP MBEW.STPRS (standard price).' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage for storage of the raw material. Particularly critical for silicon wafers, photomasks, and hygroscopic chemicals where moisture exposure causes defects or degradation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for the raw material. Exceeding this threshold may degrade material quality, trigger safety hazards, or invalidate process qualification. Used for warehouse environmental compliance monitoring.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for the raw material. Used to configure environmental monitoring alerts in the warehouse management system and ensure compliance with material safety data sheet (SDS) requirements.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'The storage temperature c of the raw material record in the inventory domain.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The part number or catalog number assigned by the primary supplier to this raw material. Used for purchase order creation, supplier communication, and incoming inspection cross-referencing. Stored in SAP INFO record (EINE.IDNLF).' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferType rdf:type rdf:Property ;
    rdfs:label 'Wafer Type' ;
    rdfs:comment 'Specifies the silicon wafer substrate type: bare_silicon (polished CZ), epitaxial (epi-layer deposited), soi (Silicon-on-Insulator), fz (Float Zone), or cz (Czochralski). Determines process compatibility and electrical characteristics. Null for non-wafer materials.' ;
    rdfs:domain ind:RawMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatVendorId rdf:type rdf:Property ;
    rdfs:label 'Osat Vendor Id' ;
    rdfs:comment 'Reference to the Outsourced Semiconductor Assembly and Test (OSAT) partner responsible for packaging and assembly of this finished good. Used for consignment stock tracking and supplier quality management.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OsatVendor .

ind:aecQQualified rdf:type rdf:Property ;
    rdfs:label 'Aec Q Qualified' ;
    rdfs:comment 'Indicates whether the finished good has been qualified to AEC-Q100 (IC), AEC-Q101 (discrete), or AEC-Q200 (passive) automotive reliability standards. Required for automotive supply chain design-in.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceMarking rdf:type rdf:Property ;
    rdfs:label 'Device Marking' ;
    rdfs:comment 'Alphanumeric marking laser-inscribed or printed on the physical package surface. Includes part number, speed grade, temperature grade, and manufacturer code. Used for traceability and counterfeit detection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppmTarget rdf:type rdf:Property ;
    rdfs:label 'Dppm Target' ;
    rdfs:comment 'Quality target expressed as Defective Parts Per Million (DPPM) for outgoing quality of this finished good. Used in customer quality agreements and SPC monitoring. Automotive-grade typically requires <10 DPPM.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eccnNumber rdf:type rdf:Property ;
    rdfs:label 'Eccn Number' ;
    rdfs:comment 'Export Control Classification Number (ECCN) assigned under the US Export Administration Regulations (EAR) administered by BIS. Determines export licensing requirements and restricted country applicability. Sensitive for trade compliance purposes.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishedGoodStatus rdf:type rdf:Property ;
    rdfs:label 'Finished Good Status' ;
    rdfs:comment 'The status of the finished good record in the inventory domain.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current inventory disposition status of the finished good lot. \'available\' indicates unrestricted stock; \'quarantine\' indicates pending quality review; \'reserved\' indicates allocated to an order; \'consignment\' indicates stock held at OSAT or customer site; \'hold\' indicates engineering or compliance hold.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this finished good inventory in the general ledger. \'standard\' = standard cost; \'moving_average\' = moving average price (MAP); \'fifo\' = First In First Out; \'lifo\' = Last In First Out.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValueUsd rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Usd' ;
    rdfs:comment 'The inventory value usd of the finished good record in the inventory domain.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotTraceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Code' ;
    rdfs:comment 'Unique lot or batch identifier linking the finished good back to the wafer fabrication lot, enabling full forward and backward traceability through the manufacturing supply chain. Aligns with Camstar MES lot number.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'The manufacture date associated with the finished good inventory record.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The manufacturing date associated with the finished good inventory record.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msdLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Level' ;
    rdfs:comment 'Moisture Sensitivity Level (MSL) classification per IPC/JEDEC J-STD-020 indicating the device\'s sensitivity to ambient moisture during storage and handling. Level 1 = unlimited floor life; Level 6 = must be baked immediately before use. [ENUM-REF-CANDIDATE: 1|2|2a|3|4|5|5a|6 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageBodySizeMm rdf:type rdf:Property ;
    rdfs:label 'Package Body Size Mm' ;
    rdfs:comment 'Physical body dimensions of the semiconductor package expressed as length x width in millimeters (e.g., \'10x10\', \'5.5x5.5\'). Used for PCB design, handling equipment setup, and storage tray selection.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnReference rdf:type rdf:Property ;
    rdfs:label 'Pcn Reference' ;
    rdfs:comment 'Reference number of the most recent Product Change Notification (PCN) affecting this finished good. PCNs document changes to materials, processes, or package that may impact customer qualification status.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Product family grouping to which this finished good belongs (e.g., high-performance compute SoC family, automotive microcontroller family). Used for portfolio reporting and demand planning.' ;
    rdfs:domain ind:FinishedGood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'The quality status of the finished good record in the inventory domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Calculated date on which the shelf life of this finished good lot expires, derived from the manufacturing date code plus shelf life days. Triggers re-bake or scrap workflow in SAP MM.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this finished good. Exceeding this threshold may degrade device reliability or void qualification. Used to configure warehouse environmental monitoring alerts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDieStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Die Storage Location Id' ;
    rdfs:comment 'Reference to the physical storage location (warehouse bin, cold storage unit, or OSAT vault) where the die bank is currently stored. Managed in SAP WM/EWM.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'The available quantity of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankCode rdf:type rdf:Property ;
    rdfs:label 'Bank Code' ;
    rdfs:comment 'Coded value representing the bank code of the die bank inventory record.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Status' ;
    rdfs:comment 'The bank status of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Physical carrier medium in which the singulated dies are stored (e.g., waffle pack, gel pack, tape-and-reel, JEDEC tray). Determines handling requirements, automated pick-and-place compatibility, and storage density.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieBankStatus rdf:type rdf:Property ;
    rdfs:label 'Die Bank Status' ;
    rdfs:comment 'Current lifecycle status of the die bank inventory record. \'Available\' indicates dies are ready for allocation; \'Reserved\' indicates committed to an order; \'Consumed\' indicates fully used in packaging; \'Quarantined\' indicates hold pending quality investigation; \'Scrapped\' indicates disposed; \'Expired\' indicates shelf life exceeded.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieCount rdf:type rdf:Property ;
    rdfs:label 'Die Count' ;
    rdfs:comment 'The die count of the die bank record in the inventory domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diePartNumber rdf:type rdf:Property ;
    rdfs:label 'Die Part Number' ;
    rdfs:comment 'The die part number of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieQuantity rdf:type rdf:Property ;
    rdfs:label 'Die Quantity' ;
    rdfs:comment 'The die quantity of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieRevision rdf:type rdf:Property ;
    rdfs:label 'Die Revision' ;
    rdfs:comment 'Silicon revision or stepping identifier for the die (e.g., A0, B1, C2). Tracks design iterations post-tapeout; critical for distinguishing engineering samples from production silicon.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieValueUsd rdf:type rdf:Property ;
    rdfs:label 'Die Value Usd' ;
    rdfs:comment 'The die value usd of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The entry date associated with the die bank inventory record.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esdSensitivityClass rdf:type rdf:Property ;
    rdfs:label 'Esd Sensitivity Class' ;
    rdfs:comment 'JEDEC Human Body Model (HBM) or Charged Device Model (CDM) ESD sensitivity classification for the dies. Determines handling precautions, packaging requirements, and ESD-protected area (EPA) storage mandates.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsignment rdf:type rdf:Property ;
    rdfs:label 'Is Consignment' ;
    rdfs:comment 'Indicates whether this die bank is held as consignment stock at an OSAT partner or customer site (True) versus owned and stored at an internal facility (False). Affects inventory ownership, liability, and financial reporting.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEngineeringSample rdf:type rdf:Property ;
    rdfs:label 'Is Engineering Sample' ;
    rdfs:comment 'Indicates whether the dies in this bank are engineering samples (True) or production-qualified silicon (False). Engineering samples may have restricted use, limited warranty, and different pricing terms.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kgd Certified Flag' ;
    rdfs:comment 'The kgd certified flag of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdFlag rdf:type rdf:Property ;
    rdfs:label 'Kgd Flag' ;
    rdfs:comment 'The kgd flag of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processNode rdf:type rdf:Property ;
    rdfs:label 'Process Node' ;
    rdfs:comment 'Semiconductor fabrication process technology node at which the dies were manufactured (e.g., 5nm, 7nm, 28nm, 65nm). Critical for yield benchmarking, packaging compatibility, and customer qualification.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldReason rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason' ;
    rdfs:comment 'Free-text or coded reason for placing this die bank on quality hold or quarantine status. Populated when die_bank_status is \'quarantined\'. Examples: parametric excursion, contamination event, ESD damage suspected.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current count of dies available for allocation or shipment in this die bank record. Decremented upon reservation or consumption. Expressed in units of individual dies.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInitial rdf:type rdf:Property ;
    rdfs:label 'Quantity Initial' ;
    rdfs:comment 'Original count of dies placed into this die bank at the time of creation, before any consumption, scrap, or reservation. Used as the baseline for yield and consumption tracking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Count of dies in this die bank that are currently reserved against open orders or packaging work orders but not yet physically consumed. Supports ATP (Available-to-Promise) calculations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityScrapped rdf:type rdf:Property ;
    rdfs:label 'Quantity Scrapped' ;
    rdfs:comment 'Cumulative count of dies from this die bank that have been scrapped due to handling damage, quality failures, or shelf life expiry. Used for loss tracking and yield analysis.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'The reserved quantity of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageForm rdf:type rdf:Property ;
    rdfs:label 'Storage Form' ;
    rdfs:comment 'The storage form of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this die bank. Violations may cause electrostatic or material degradation. Enforced by warehouse management system.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapeoutVersion rdf:type rdf:Property ;
    rdfs:label 'Tapeout Version' ;
    rdfs:comment 'Identifier of the tapeout submission (GDSII release version) from which the wafers in this die bank were fabricated. Enables traceability back to the design release in EDA and PLM systems.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferForm rdf:type rdf:Property ;
    rdfs:label 'Wafer Form' ;
    rdfs:comment 'The wafer form of the die bank record in the inventory domain.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferProbeYieldPct rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Yield Pct' ;
    rdfs:comment 'Electrical test yield percentage from wafer probe/sort for the parent wafer lot, representing the fraction of dies that passed all probe tests. Expressed as a decimal percentage (e.g., 92.5000). Used for cost modeling and quality benchmarking.' ;
    rdfs:domain ind:DieBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentAccountId rdf:type rdf:Property ;
    rdfs:label 'Consignment Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Storage locations can be customer-dedicated consignment warehouses or VMI hubs. The existing is_osat_partner_location flag and denormalized osat_partner_name indicate partner-owned locations; a proper' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:parentStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Storage Location Id' ;
    rdfs:comment 'Unique identifier for the parent storage location record within the storage location inventory entity.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Physical access control level for this storage location. unrestricted — open access; badge-access — requires valid facility badge; authorized-personnel — restricted to named personnel list (e.g., for ITAR-controlled materials); security-vault — highest security for KGD die banks, photomask vaults, and ITAR-controlled IP. Supports ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'The aisle of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay designation within the building or cleanroom where this storage location is physically situated (e.g., \'BAY-03\', \'A-WEST\'). Used for precise physical navigation, equipment layout planning, and cleanroom zone management per SEMI E187.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'The bin of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Identifier for the physical building within the facility where this storage location resides (e.g., \'FAB1\', \'CHEM-WH-B\', \'OSAT-PKG-C\'). Supports facility layout mapping, emergency response planning, and environmental zone management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to express the maximum capacity and current utilization of this storage location. Varies by facility type: cassette (wafer storage), pod (photomask storage), tray (packaged chip storage), container (chemical storage), box (die bank storage), pallet (bulk warehouse storage).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'The capacity units of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleanroomIsoClass rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Iso Class' ;
    rdfs:comment 'ISO 14644-1 cleanroom classification for this storage location, defining the maximum allowable airborne particulate concentration. Critical for wafer, photomask, and KGD die storage compliance. Applicable only to cleanroom facility types; null for non-cleanroom locations. Values: ISO-1 (cleanest) through ISO-6.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which this storage location was formally commissioned and made available for inventory use. Marks the start of the location\'s operational lifecycle. Used for asset age tracking, depreciation scheduling, and facility capacity planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Pct' ;
    rdfs:comment 'The current utilization pct of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Percent' ;
    rdfs:comment 'The current utilization percent of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationUnits rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Units' ;
    rdfs:comment 'Current number of inventory units occupying this storage location at the time of last inventory update. Compared against max_capacity_units to compute utilization percentage for capacity planning and inventory placement decisions. Updated by MES and SAP MM inventory movements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which this storage location was permanently decommissioned and removed from active inventory use. Populated only when location_status is \'decommissioned\'. Supports facility lifecycle management and historical inventory traceability.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esdProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Esd Protected Flag' ;
    rdfs:comment 'The esd protected flag of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esdProtectionClass rdf:type rdf:Property ;
    rdfs:label 'Esd Protection Class' ;
    rdfs:comment 'ESD protection classification of this storage location per ANSI/ESD S20.20 and JEDEC JESD625 standards. Determines suitability for storing ESD-sensitive devices (ICs, dies, packaged chips). class-0 (most sensitive, <250V HBM) through class-3 (>2000V HBM); unprotected for non-ESD-controlled areas.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the physical facility type housing this storage location. Drives environmental compliance rules, MSD floor life management, and hazmat handling procedures. Valid values: cleanroom (ISO-classified FAB area), warehouse (general materials storage), cold-storage (temperature-controlled for chemicals/biologics), gas-cabinet (pressurized specialty gas storage), nitrogen-cabinet (nitrogen-purged dry storage for moisture-sensitive devices), die-vault (secure KGD die bank storage).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed at this storage location. Critical for chemical warehouse and gas cabinet locations storing flammable or reactive materials. Drives emergency response planning and insurance compliance. Values: sprinkler, halon (legacy), fm200 (clean agent), co2, dry-powder, none.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used for multi-site supply chain mapping, emergency response planning, and regulatory jurisdiction determination for ITAR/EAR export control compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used in conjunction with geo_latitude for multi-site supply chain mapping and regulatory jurisdiction determination.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'The hazmat approved flag of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN/DOT hazardous materials classification code applicable to materials stored at this location (e.g., \'UN1170\' for ethanol, \'UN2014\' for hydrogen peroxide, \'FLAMMABLE-LIQUID\', \'CORROSIVE\', \'COMPRESSED-GAS\', \'NON-HAZMAT\'). Governs storage segregation, emergency response, and regulatory reporting under REACH, RoHS, and TSCA. [ENUM-REF-CANDIDATE: flammable-liquid|corrosive|compressed-gas|oxidizer|toxic|non-hazmat|pyrophoric — promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled Flag' ;
    rdfs:comment 'The humidity controlled flag of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOsatPartnerLocation rdf:type rdf:Property ;
    rdfs:label 'Is Osat Partner Location' ;
    rdfs:comment 'Indicates whether this storage location is physically situated at an OSAT (Outsourced Semiconductor Assembly and Test) partner facility rather than an internal company site. True for consignment stock locations at OSAT partners. Drives consignment inventory valuation, ownership tracking, and inter-company transfer accounting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kgdStorageCertified rdf:type rdf:Property ;
    rdfs:label 'Kgd Storage Certified' ;
    rdfs:comment 'Indicates whether this storage location is certified for KGD (Known Good Die) die bank storage, meeting requirements for ESD protection, nitrogen purge, temperature/humidity control, and access security. KGD storage certification is required for high-value tested dies awaiting packaging or shipment.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the storage location (e.g., \'Bay 3 Shelf 12 — EUV Photomask Vault\', \'Cleanroom A Chemical Cabinet Row 5\'). Used in operational reports, MES screens, and inventory placement instructions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle status of the storage location. \'active\' — available for inventory placement; \'blocked\' — temporarily unavailable due to maintenance, contamination, or audit hold; \'decommissioned\' — permanently retired from use. Controls whether new inventory can be assigned to this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'The location type of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Max Capacity Units' ;
    rdfs:comment 'Maximum number of inventory units (wafer cassettes, chemical containers, photomask pods, chip trays, or die boxes) that can be physically stored at this location. Used for capacity planning, inventory placement optimization, and utilization reporting.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Max Humidity Pct' ;
    rdfs:comment 'Maximum allowable relative humidity percentage (0–100%) for this storage location. Exceedance above maximum triggers MSD floor life reset, inventory quarantine, and environmental non-conformance reporting per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Min Humidity Pct' ;
    rdfs:comment 'Minimum allowable relative humidity percentage (0–100%) for this storage location. Critical for MSD floor life management, photomask storage, and chemical stability. Exceedance below minimum may cause ESD risk or material degradation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this location. Defines the lower bound of the acceptable temperature range for stored materials (chemicals, photoresists, gases, packaged devices). Used for environmental compliance monitoring and MSD (Moisture Sensitive Device) floor life management per IPC/JEDEC J-STD-033.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msdFloorLifeCapable rdf:type rdf:Property ;
    rdfs:label 'Msd Floor Life Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped and certified to manage MSD floor life tracking per IPC/JEDEC J-STD-033. True for nitrogen-purged cabinets, dry-storage cabinets, and controlled-humidity cleanroom locations. Enables automatic floor life clock suspension for stored MSDs.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msdSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Msd Sensitivity Level' ;
    rdfs:comment 'Maximum Moisture Sensitivity Level (MSL) of devices that can be safely stored at this location per IPC/JEDEC J-STD-020. MSL-1 (unlimited floor life at ≤30°C/85%RH) through MSL-5 (most sensitive, 24-hour floor life). Determines which packaged semiconductor devices are eligible for placement at this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenPurgeCapable rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Purge Capable' ;
    rdfs:comment 'Indicates whether this storage location is equipped with nitrogen purge capability to maintain an inert, moisture-free atmosphere. True for nitrogen-cabinet and die-vault locations used for long-term KGD die storage, photomask preservation, and moisture-sensitive chemical storage. Drives MSD floor life management decisions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photomaskStorageCapable rdf:type rdf:Property ;
    rdfs:label 'Photomask Storage Capable' ;
    rdfs:comment 'Indicates whether this storage location meets the environmental and cleanliness requirements for photomask (reticle) storage, including ISO cleanroom class, nitrogen purge, and ESD protection. Photomasks are high-value assets used in EUV/DUV lithography and require specialized storage conditions.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rack rdf:type rdf:Property ;
    rdfs:label 'Rack' ;
    rdfs:comment 'The rack of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:row rdf:type rdf:Property ;
    rdfs:label 'Row' ;
    rdfs:comment 'Row designation within the bay for this storage location (e.g., \'R-12\', \'ROW-A\'). Provides granular physical addressing for inventory placement, pick-and-put-away operations, and automated storage/retrieval system (ASRS) integration.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelf rdf:type rdf:Property ;
    rdfs:label 'Shelf' ;
    rdfs:comment 'Shelf or bin designation within the row for this storage location (e.g., \'S-04\', \'BIN-002\'). Lowest level of the physical location hierarchy, enabling precise inventory placement and retrieval for wafer cassettes, chemical containers, photomasks, and packaged chip trays.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Tracking Enabled' ;
    rdfs:comment 'Indicates whether shelf life expiry tracking is enabled for materials stored at this location. True for chemical storage, photoresist storage, and gas cabinet locations where materials have defined shelf lives. Enables automated expiry alerts and FEFO (First Expired First Out) inventory management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'The storage conditions of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'The status of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'The temperature controlled flag of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Coded value representing the warehouse code of the storage location inventory record.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseZone rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone' ;
    rdfs:comment 'The warehouse zone of the storage location record in the inventory domain.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum allowable total weight in kilograms for materials stored at this location. Critical for shelf structural integrity compliance, particularly for heavy chemical drums, gas cylinders, and bulk wafer cassette storage. Enforced per facility safety standards.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipStagingArea rdf:type rdf:Property ;
    rdfs:label 'Wip Staging Area' ;
    rdfs:comment 'Indicates whether this storage location is designated as a WIP (Work in Process) staging area for wafer lots between process steps. True for inter-bay buffers, equipment load ports, and process queue areas within the FAB cleanroom. Enables WIP flow tracking and cycle time analysis in the MES.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryStockRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Raw Material Id' ;
    rdfs:comment 'Foreign key linking to inventory.raw_material. Business justification: raw_material is a master for raw materials; linking stock_balance to raw_material via raw_material_id replaces generic material_master references and enables direct lookup of raw material attributes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:primaryStockStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Storage Location Id' ;
    rdfs:comment 'Reference to the physical or logical storage location (e.g., FAB cleanroom bay, chemical storage vault, finished goods warehouse, OSAT consignment location) where this inventory is held.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:toRawMaterialId rdf:type rdf:Property ;
    rdfs:label 'To Raw Material Id' ;
    rdfs:comment 'FK to inventory.raw_material.raw_material_id — Stock balance for raw materials must reference the raw_material master record. This is the core master-transaction relationship for material inventory visibility.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RawMaterial .

ind:balanceDate rdf:type rdf:Property ;
    rdfs:label 'Balance Date' ;
    rdfs:comment 'The balance date associated with the stock balance inventory record.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'The balance type of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchClassification rdf:type rdf:Property ;
    rdfs:label 'Batch Classification' ;
    rdfs:comment 'Quality grade classification of the wafer or material batch. \'prime\' = meets all specifications for production; \'test\' = test wafers used for process qualification; \'engineering\' = engineering samples not for production; \'monitor\' = process monitor wafers; \'reject\' = failed quality inspection and not usable.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binClassification rdf:type rdf:Property ;
    rdfs:label 'Bin Classification' ;
    rdfs:comment 'Die or wafer bin classification code assigned during wafer sort or final test, indicating the performance grade or speed bin of the die (e.g., \'BIN1_HIGH_PERF\', \'BIN2_STD\', \'BIN3_LOW_SPEED\', \'REJECT\'). Used for die bank management, customer order fulfillment by grade, and yield analysis. [ENUM-REF-CANDIDATE: promote to reference product as bin classifications vary by product family]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Consignment Partner Code' ;
    rdfs:comment 'Identifier of the Outsourced Semiconductor Assembly and Test (OSAT) partner or external consignee at whose facility this consignment stock is physically held. Populated only for stock_type = \'consignment\'. Used for consignment reconciliation and OSAT partner performance tracking.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue (GI) posting for this material from this storage location. Used to identify dormant inventory, assess consumption velocity, and support slow-moving inventory analysis.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (GR) posting for this material at this storage location. Used to calculate stock aging, assess replenishment lead times, and support FIFO/FEFO inventory consumption sequencing.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The last movement date associated with the stock balance inventory record.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'The last movement timestamp of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count performed for this material at this storage location. Used to assess inventory accuracy, schedule next count, and support SOX financial reporting requirements for inventory valuation.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qtyAvailable rdf:type rdf:Property ;
    rdfs:label 'Qty Available' ;
    rdfs:comment 'Quantity of unrestricted stock that is not committed to any open reservation or production order. Represents the net available quantity for Available-to-Promise (ATP) calculations and new production planning decisions. Computed as unrestricted stock minus open reservations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyBlocked rdf:type rdf:Property ;
    rdfs:label 'Qty Blocked' ;
    rdfs:comment 'Quantity of material placed in blocked stock due to quality rejection, ITAR/EAR export control restrictions, supplier non-conformance, or regulatory hold. Blocked stock is not available for production or shipment until formally released.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInTransit rdf:type rdf:Property ;
    rdfs:label 'Qty In Transit' ;
    rdfs:comment 'Quantity of material that has been shipped from a source location but has not yet been received at the destination location. Includes inter-plant transfers, OSAT shipments, and inbound supplier deliveries in transit.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyInWip rdf:type rdf:Property ;
    rdfs:label 'Qty In Wip' ;
    rdfs:comment 'Quantity of material currently consumed into active production orders and undergoing fabrication processing (e.g., wafer lots in FEOL/BEOL processing, die in packaging). Tracked by the MES and reflected in SAP PP WIP accounts.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyOnHand rdf:type rdf:Property ;
    rdfs:label 'Qty On Hand' ;
    rdfs:comment 'Total physical quantity of the material present at the storage location across all stock types, expressed in the base unit of measure. Represents the gross inventory position before reservations or quality holds are considered.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyQualityInspection rdf:type rdf:Property ;
    rdfs:label 'Qty Quality Inspection' ;
    rdfs:comment 'Quantity of material currently held in SAP QM quality inspection stock, pending disposition decision (accept, reject, rework). Includes incoming inspection lots, in-process inspection holds, and post-process quality holds.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qtyReserved rdf:type rdf:Property ;
    rdfs:label 'Qty Reserved' ;
    rdfs:comment 'Total quantity committed to active inventory reservations linked to open production orders, sales orders, or transfer orders. Corresponds to open inventory_reservation records and reduces the available quantity for new demand.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBlocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Blocked' ;
    rdfs:comment 'The quantity blocked of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'The quantity in transit of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQualityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Quality Hold' ;
    rdfs:comment 'The quantity quality hold of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'The safety stock of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'The safety stock level of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slowMovingFlag rdf:type rdf:Property ;
    rdfs:label 'Slow Moving Flag' ;
    rdfs:comment 'Indicates whether this stock balance has been flagged as slow-moving (True) based on the stock_aging_days exceeding the material-specific slow-moving threshold. Used for inventory write-down risk assessment, EOL (End of Life) planning, and LTB (Last Time Buy) decision support.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The principal business event timestamp indicating when this stock balance snapshot was captured from the source system (SAP MM or MES). Represents the point-in-time inventory position and is the primary temporal key for real-time inventory visibility and ATP calculations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock indicator identifying non-standard stock ownership or custody arrangements. \'E\' = sales order stock; \'K\' = consignment stock at customer; \'Q\' = project stock; \'W\' = consignment stock from vendor; \'O\' = stock at subcontractor (OSAT). Empty value indicates standard own stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAgingDays rdf:type rdf:Property ;
    rdfs:label 'Stock Aging Days' ;
    rdfs:comment 'Number of days the current on-hand stock has been held at this storage location since the oldest receipt date. Used for slow-moving inventory identification, shelf-life monitoring, and obsolescence risk assessment. Critical for chemicals, gases, and photoresists with defined shelf lives.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'SAP stock category indicating the usability status of the inventory. \'unrestricted\' is available for production or shipment; \'quality_inspection\' is under QM hold pending disposition; \'blocked\' is rejected or quarantined; \'consignment\' is held at OSAT partner sites; \'restricted\' is subject to export control or ITAR/EAR restrictions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Required storage environment classification for this material. Drives warehouse management system (WMS) slotting and compliance with SEMI, REACH, and OSHA storage requirements. \'nitrogen_purge\' for moisture-sensitive devices (MSD); \'cold_storage\' for temperature-sensitive chemicals; \'cleanroom_class1/10\' for wafers and photomasks; \'hazmat\' for regulated chemicals.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Value Usd' ;
    rdfs:comment 'The total value usd of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrestrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Use Flag' ;
    rdfs:comment 'Indicates whether this stock balance record represents inventory that is fully available for unrestricted use in production or shipment (True), or whether it is subject to any hold, restriction, or quality disposition (False). Derived from stock_type but maintained as an explicit flag for rapid ATP query performance.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The valuation amount of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct balance sheet accounts for financial reporting. Detailed financial valuation fields are maintained in the stock_valuation data product.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The valuation method of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueUsd rdf:type rdf:Property ;
    rdfs:label 'Value Usd' ;
    rdfs:comment 'The value usd of the stock balance record in the inventory domain.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waferProcessNode rdf:type rdf:Property ;
    rdfs:label 'Wafer Process Node' ;
    rdfs:comment 'The semiconductor process technology node at which the wafer lot or die was fabricated (e.g., \'7nm\', \'14nm\', \'28nm\', \'180nm\'). Critical for inventory segregation, process compatibility checks, and customer design-in alignment.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Unique identifier for the goods movement transaction. Primary key for the goods movement record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromLocationId rdf:type rdf:Property ;
    rdfs:label 'From Location Id' ;
    rdfs:comment 'Unique identifier for the from location record within the goods movement inventory entity.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:fromStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'From Storage Location Id' ;
    rdfs:comment 'Unique identifier for the from storage location record within the goods movement inventory entity.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryGoodsStockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Stock Balance Id' ;
    rdfs:comment 'FK to inventory.stock_balance.stock_balance_id — Every goods movement posting updates the stock balance. This is the fundamental inventory equation: stock_balance = sum(goods_movements). Critical for reconciliation and audit.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:primaryGoodsStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement must reference source location for audit trail and inventory reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'FK to inventory.storage_location.storage_location_id — Every goods movement has a source location (for issues, transfers) or destination location (for receipts). Location reference is mandatory for movement posting and audit trail.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:toStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'To Storage Location Id' ;
    rdfs:comment 'Unique identifier for the to storage location record within the goods movement inventory entity.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Delivery note or packing slip number from the supplier or shipping carrier. Used for goods receipt matching and three-way match (PO, goods receipt, invoice) reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material was moved to. Used for inter-plant transfers and multi-site inventory tracking. Critical for global supply chain visibility.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved to. Represents warehouse, stockroom, or FAB storage area. Empty for goods issues to external customers or scrap.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique material document number generated by the ERP system for this goods movement. Primary business identifier for the transaction, used for audit trail and reversal references.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'The document type of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Status' ;
    rdfs:comment 'The status of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementDate rdf:type rdf:Property ;
    rdfs:label 'Movement Date' ;
    rdfs:comment 'Date when the physical goods movement occurred. Business event date for inventory transaction, distinct from posting date. Critical for SOX Section 404 audit trail and inventory valuation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'The movement number of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The movement quantity of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Coded value representing the movement reason code of the goods movement inventory record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'The movement status of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'The movement timestamp of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction: goods receipt from supplier, goods issue to production, inter-location transfer, scrap disposal, return from production, or posting reversal. Aligns with SAP MM movement type codes.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementValueUsd rdf:type rdf:Property ;
    rdfs:label 'Movement Value Usd' ;
    rdfs:comment 'The movement value usd of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date when the goods movement was posted to the financial ledger. Used for period-end closing and financial reporting. May differ from movement date for backdated or delayed postings.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Production order number for goods issues to manufacturing or goods receipts from production. Links inventory movements to wafer fabrication, die packaging, or assembly operations.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'The reference document of the goods movement record in the inventory domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Item' ;
    rdfs:comment 'Line item number within the reference document. Provides precise linkage to the specific line of the purchase order, production order, or delivery note.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Number of the source document that triggered this goods movement. Links to purchase order, production order, delivery note, or other originating transaction for full traceability.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered this goods movement: purchase order (PO) for receipts, production order for manufacturing issues/receipts, delivery note for shipments, transfer order for inter-location moves, sales order for customer shipments, or reservation for planned consumption.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Material reservation number for planned goods issues. Links to production order or maintenance order reservations for material requirements planning (MRP) and allocation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this goods movement is a reversal of a previous transaction. True for cancellation or correction postings. Used for audit trail and error correction tracking.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Material document number of the original transaction being reversed. Populated only when reversal_indicator is true. Provides linkage for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Expiration date for time-sensitive materials such as photoresists, chemicals, or adhesives. Used for shelf-life management and FIFO (First In First Out) inventory control.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcePlantCode rdf:type rdf:Property ;
    rdfs:label 'Source Plant Code' ;
    rdfs:comment 'Plant or FAB site code where the material originated. Used for inter-plant transfers and multi-site inventory tracking. Aligns with SEMI E120 traceability requirements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location' ;
    rdfs:comment 'Storage location code where the material was moved from. Represents warehouse, stockroom, or FAB storage area. Empty for goods receipts from external suppliers.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the goods movement transaction was recorded in the system. Used for audit trail, sequence verification, and real-time inventory updates.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryAssemblyOsatVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Osat Vendor Id' ;
    rdfs:comment 'Identifier of the outsourced assembly partner responsible for execution.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OsatVendor .

ind:primaryAssemblyPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Every assembly order specifies a package type. This FK is essential for filtering orders by package format, capacity planning, and routing to qualified OSAT sites.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:assemblyOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Order Status' ;
    rdfs:comment 'Current lifecycle state of the assembly order.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblySite rdf:type rdf:Property ;
    rdfs:label 'Assembly Site' ;
    rdfs:comment 'Code of the facility where the assembly is performed.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedQuantity rdf:type rdf:Property ;
    rdfs:label 'Completed Quantity' ;
    rdfs:comment 'The completed quantity of the assembly order record in the packaging domain.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the assembly work was completed.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Adjustment Amount' ;
    rdfs:comment 'Any cost adjustments (e.g., discounts, fees) applied to the gross amount.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Gross Amount' ;
    rdfs:comment 'Estimated total cost before any adjustments.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costNetAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Net Amount' ;
    rdfs:comment 'Final cost after adjustments, representing the amount to be billed.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percent' ;
    rdfs:comment 'Target yield percentage expected for the assembly run.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent status transition.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-visible alphanumeric identifier assigned to the assembly order.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Timestamp when the assembly order was initially placed.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The order quantity of the assembly order record in the packaging domain.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'Origin of the order request.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The planned start date associated with the assembly order packaging record.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of die units requested for assembly.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetShipDate rdf:type rdf:Property ;
    rdfs:label 'Target Ship Date' ;
    rdfs:comment 'Planned date for shipment of the completed assembly.' ;
    rdfs:domain ind:AssemblyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ballCount rdf:type rdf:Property ;
    rdfs:label 'Ball Count' ;
    rdfs:comment 'The ball count of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ballCountMax rdf:type rdf:Property ;
    rdfs:label 'Ball Count Max' ;
    rdfs:comment 'Maximum number of solder balls for BGA-type packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ballCountMin rdf:type rdf:Property ;
    rdfs:label 'Ball Count Min' ;
    rdfs:comment 'Minimum number of solder balls for BGA-type packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodySizeMm rdf:type rdf:Property ;
    rdfs:label 'Body Size Mm' ;
    rdfs:comment 'The body size mm of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is3dIc rdf:type rdf:Property ;
    rdfs:label 'Is 3d Ic' ;
    rdfs:comment 'True if the package incorporates through-silicon vias or other 3-D stacking.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdvancedPackage rdf:type rdf:Property ;
    rdfs:label 'Is Advanced Package' ;
    rdfs:comment 'True for cutting-edge or specialty package formats.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBallGridArray rdf:type rdf:Property ;
    rdfs:label 'Is Ball Grid Array' ;
    rdfs:comment 'True if the package is a ball-grid array type.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFlipChip rdf:type rdf:Property ;
    rdfs:label 'Is Flip Chip' ;
    rdfs:comment 'True if the package utilizes flip-chip interconnect technology.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHeterogeneousIntegration rdf:type rdf:Property ;
    rdfs:label 'Is Heterogeneous Integration' ;
    rdfs:comment 'Indicates whether the package supports heterogeneous integration (e.g., chip-on-wafer).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isItarControlled rdf:type rdf:Property ;
    rdfs:label 'Is Itar Controlled' ;
    rdfs:comment 'True if the package is subject to International Traffic in Arms Regulations.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadframe rdf:type rdf:Property ;
    rdfs:label 'Is Leadframe' ;
    rdfs:comment 'True if the package uses a traditional leadframe.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOsatSupported rdf:type rdf:Property ;
    rdfs:label 'Is Osat Supported' ;
    rdfs:comment 'True if the package type is commonly offered by outsourced assembly providers.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReachCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Reach Compliant' ;
    rdfs:comment 'True if the package complies with REACH chemical safety regulations.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRohsCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Rohs Compliant' ;
    rdfs:comment 'True if the package meets RoHS restriction requirements.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWireBond rdf:type rdf:Property ;
    rdfs:label 'Is Wire Bond' ;
    rdfs:comment 'True if the package uses wire-bond interconnects.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jedecOutlineCode rdf:type rdf:Property ;
    rdfs:label 'Jedec Outline Code' ;
    rdfs:comment 'Official JEDEC outline identifier for the package (e.g., 5x5-1mm).' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jedecStandard rdf:type rdf:Property ;
    rdfs:label 'Jedec Standard' ;
    rdfs:comment 'The jedec standard of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadCount rdf:type rdf:Property ;
    rdfs:label 'Lead Count' ;
    rdfs:comment 'The lead count of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadFree rdf:type rdf:Property ;
    rdfs:label 'Lead Free' ;
    rdfs:comment 'The lead free of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadFreeFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Free Flag' ;
    rdfs:comment 'The lead free flag of the package type record in the packaging domain.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCurrentA rdf:type rdf:Property ;
    rdfs:label 'Max Current A' ;
    rdfs:comment 'Maximum continuous current rating for the package.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDiePitchUm rdf:type rdf:Property ;
    rdfs:label 'Max Die Pitch Um' ;
    rdfs:comment 'Maximum center-to-center spacing between dies for multi-die packages.' ;
    rdfs:domain ind:PackageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

