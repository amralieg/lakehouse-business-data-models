    rdfs:range xsd:string .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: NCRs with customer_notification_required=true need a specific customer contact for notification. The existing account_id identifies the company but not the individual. Semiconductor quality teams must' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:sourceFabToolId rdf:type rdf:Property ;
    rdfs:label 'Source Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: NCRs raised for equipment-induced nonconformances must reference the specific fab tool that caused the nonconformance. No existing FK from nonconformance_report to fab_tool exists. Equipment-level NCR' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:attachedDocumentIds rdf:type rdf:Property ;
    rdfs:label 'Attached Document Ids' ;
    rdfs:comment 'Comma-separated list of document identifiers attached to the report.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-form notes capturing audit trail details.' ;
