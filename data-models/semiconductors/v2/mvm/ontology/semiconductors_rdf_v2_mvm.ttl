    rdfs:range xsd:string .

ind:testTimeMs rdf:type rdf:Property ;
    rdfs:label 'Test Time Ms' ;
    rdfs:comment 'The test time ms of the unit test result record in the test domain.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Timestamp' ;
    rdfs:comment 'Date and time when the test was performed.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testYieldFlag rdf:type rdf:Property ;
    rdfs:label 'Test Yield Flag' ;
    rdfs:comment 'Indicates if the unit is counted towards lot yield calculations.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Unit Identifier' ;
    rdfs:comment 'Identifier of the tested unit, expressed as wafer X/Y coordinates for wafer-level or serial number for package-level.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Serial Number' ;
    rdfs:comment 'The unit serial number of the unit test result record in the test domain.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFinalTestProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Final Test Program Id' ;
    rdfs:comment 'Foreign key linking to test.test_program. Business justification: Final test runs are generated by a specific test program; add FK to capture this relationship.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:ateName rdf:type rdf:Property ;
    rdfs:label 'Ate Name' ;
    rdfs:comment 'Name or model of the ATE system executing the test.' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binDistribution rdf:type rdf:Property ;
    rdfs:label 'Bin Distribution' ;
    rdfs:comment 'Compact representation of test bin counts (e.g., JSON or delimited string).' ;
    rdfs:domain ind:FinalTestRun ;
    rdf:type owl:DatatypeProperty ;
