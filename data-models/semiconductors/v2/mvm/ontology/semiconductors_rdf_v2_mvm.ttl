ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'The unit count of the assembly lot record in the packaging domain.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCountIn rdf:type rdf:Property ;
    rdfs:label 'Unit Count In' ;
    rdfs:comment 'The unit count in of the assembly lot record in the packaging domain.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCountOut rdf:type rdf:Property ;
    rdfs:label 'Unit Count Out' ;
    rdfs:comment 'The unit count out of the assembly lot record in the packaging domain.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyYieldId rdf:type rdf:Property ;
    rdfs:label 'Assembly Yield Id' ;
    rdfs:comment 'Primary key for assembly_yield' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssemblyLotId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Lot Id' ;
    rdfs:comment 'Identifier of the parent assembly run or batch to which this yield step belongs.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyLot .

ind:assemblyYieldStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Yield Status' ;
    rdfs:comment 'Current lifecycle status of the step record.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dppm rdf:type rdf:Property ;
    rdfs:label 'Dppm' ;
    rdfs:comment 'Defective parts per million metric for the step.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstPassYieldPercent rdf:type rdf:Property ;
    rdfs:label 'First Pass Yield Percent' ;
    rdfs:comment 'The first pass yield percent of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'The input quantity of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lossQuantity rdf:type rdf:Property ;
    rdfs:label 'Loss Quantity' ;
    rdfs:comment 'The loss quantity of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'The output quantity of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Name of the specific packaging process step for which the yield data is recorded.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectQuantity rdf:type rdf:Property ;
    rdfs:label 'Reject Quantity' ;
    rdfs:comment 'The reject quantity of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Rework Yield Percent' ;
    rdfs:comment 'The rework yield percent of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step End Timestamp' ;
    rdfs:comment 'Date and time when the process step completed.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepSequence rdf:type rdf:Property ;
    rdfs:label 'Step Sequence' ;
    rdfs:comment 'Ordinal position of the step within the overall assembly run.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when the process step began.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:topDefectCategory rdf:type rdf:Property ;
    rdfs:label 'Top Defect Category' ;
    rdfs:comment 'The top defect category of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsIn rdf:type rdf:Property ;
    rdfs:label 'Units In' ;
    rdfs:comment 'Number of dies or packages entering the process step.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsOut rdf:type rdf:Property ;
    rdfs:label 'Units Out' ;
    rdfs:comment 'Number of good dies or packages exiting the process step.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsScrapped rdf:type rdf:Property ;
    rdfs:label 'Units Scrapped' ;
    rdfs:comment 'Number of dies or packages discarded during the step.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldCategory rdf:type rdf:Property ;
    rdfs:label 'Yield Category' ;
    rdfs:comment 'The yield category of the assembly yield record in the packaging domain.' ;
    rdfs:domain ind:AssemblyYield ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyDefectId rdf:type rdf:Property ;
    rdfs:label 'Assembly Defect Id' ;
    rdfs:comment 'Primary key for assembly_defect' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fabLotProcessRunId rdf:type rdf:Property ;
    rdfs:label 'Fab Lot Process Run Id' ;
    rdfs:comment 'Foreign key linking to process.lot_process_run. Business justification: Assembly defects traced to incoming die quality require direct reference to the originating fab lot_process_run for root-cause analysis and CAPA. Semiconductor failure analysis reports and 8D investig' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotProcessRun .

ind:qualityDefectRecordId rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Enables Defect Traceability across wafer and package stages, required for Root Cause Analysis report that correlates wafer defects to package defects.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:assemblyDefectStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Defect Status' ;
    rdfs:comment 'Current processing status of the defect record.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-form notes entered by the inspector.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectImageUri rdf:type rdf:Property ;
    rdfs:label 'Defect Image Uri' ;
    rdfs:comment 'Link to the image captured for the defect.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The detected timestamp of the assembly defect record in the packaging domain.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionBatchCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Batch Code' ;
    rdfs:comment 'Identifier of the inspection batch (transaction header) to which this defect belongs.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionTool rdf:type rdf:Property ;
    rdfs:label 'Inspection Tool' ;
    rdfs:comment 'Name or model of the inspection tool used.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Line sequence number of the defect within the inspection batch.' ;
    rdfs:domain ind:AssemblyDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageQualificationId rdf:type rdf:Property ;
    rdfs:label 'Package Qualification Id' ;
    rdfs:comment 'Primary key for package_qualification' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageQualification .

ind:primaryPackagingPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packaging Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:qualificationAssemblyLotId rdf:type rdf:Property ;
    rdfs:label 'Qualification Assembly Lot Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_lot. Business justification: Package qualification programs use specific assembly lots as qualification vehicles — the actual production lots built and tested to certify the package type and process flow. Linking package_qualific' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyLot .

ind:qualificationFabToolId rdf:type rdf:Property ;
    rdfs:label 'Qualification Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Package qualification (JEDEC/AEC-Q100 compliance) must record the specific fab tool used during qualification testing for regulatory traceability and requalification triggers. test_equipment_code is a' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:tertiaryPackageTypeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Package Type Id' ;
    rdfs:comment 'FK to packaging.package_type.package_type_id — Qualifications certify specific package types for production. Essential for determining which package types are production-released.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackageType .

ind:defectRatePpm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Ppm' ;
    rdfs:comment 'Defective parts per million observed in the qualification samples.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAuditDate rdf:type rdf:Property ;
    rdfs:label 'External Audit Date' ;
    rdfs:comment 'Scheduled date for the external audit, if required.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Indicates whether an external audit is mandated for this qualification.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Package Qualification Status' ;
    rdfs:comment 'The status of the package qualification record in the packaging domain.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Coded value representing the qualification code of the package qualification packaging record.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Qualification Cost Usd' ;
    rdfs:comment 'Total cost incurred for the qualification program, expressed in US dollars.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Document Number' ;
    rdfs:comment 'Reference to the document that contains the full qualification report.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'Approach used for qualification testing.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationOwner rdf:type rdf:Property ;
    rdfs:label 'Qualification Owner' ;
    rdfs:comment 'Name of the person responsible for managing the qualification program.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCompliance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance' ;
    rdfs:comment 'Regulatory framework(s) the qualification adheres to.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Number of sample units tested during qualification.' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stressTestMatrix rdf:type rdf:Property ;
    rdfs:label 'Stress Test Matrix' ;
    rdfs:comment 'Set of stress tests applied during qualification (e.g., High Temperature Operating Life, Temperature Cycling).' ;
    rdfs:domain ind:PackageQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Links invoice to a normalized address record for tax jurisdiction and export-control validation; required by regulatory reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:billingContactId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Required for Accounts Receivable to send invoice notices to the designated billing contact; standard practice in semiconductor B2B invoicing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:pkgAssemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Pkg Assembly Order Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_order. Business justification: Required for the Packaging Service Billing Report, which matches each invoice to the underlying assembly order that generated the packaged product.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:primaryArPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Payment Term Id' ;
    rdfs:comment 'Foreign key linking to invoice.payment_term. Business justification: Invoices reference a payment-term master; adding payment_term_id FK normalizes payment terms and removes the redundant free-text payment_terms column.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:toPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'To Payment Term Id' ;
    rdfs:comment 'FK to invoice.payment_term.payment_term_id — Every invoice must reference its applicable payment terms to calculate due date and discount eligibility. Required for AR aging and cash forecasting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was approved for posting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorNotes rdf:type rdf:Property ;
    rdfs:label 'Auditor Notes' ;
    rdfs:comment 'Comments added by internal auditors during review.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled, if applicable.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current state of the collections process for the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal name of the invoicing customer.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount' ;
    rdfs:comment 'Percentage discount offered for early settlement, if applicable.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecnClassification rdf:type rdf:Property ;
    rdfs:label 'Ecn Classification' ;
    rdfs:comment 'Classification used for export control compliance.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Customs classification code for the shipped product.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was generated and sent to the customer.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'External business identifier assigned to the invoice by the billing system.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCreditMemo rdf:type rdf:Property ;
    rdfs:label 'Is Credit Memo' ;
    rdfs:comment 'True if the document is a credit memo rather than a standard invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProforma rdf:type rdf:Property ;
    rdfs:label 'Is Proforma' ;
    rdfs:comment 'True if the document is a pro-forma invoice used for customs or advance payment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Penalty amount applied when payment is received after the due date.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Number of line items included on the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Means by which the customer intends to settle the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment collection for the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was posted to the general ledger.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingAddress rdf:type rdf:Property ;
    rdfs:label 'Shipping Address' ;
    rdfs:comment 'Delivery location for the goods or services covered by the invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'System-generated unique identifier for each invoice line item.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:primaryArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Invoice Id' ;
    rdfs:comment 'Identifier of the parent invoice to which this line belongs.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:toArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'To Ar Invoice Id' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Fundamental header-to-line relationship. Every invoice line must reference its parent invoice. Without this FK, the domain cannot function — you cannot construct an invoice document.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the billing period covered by this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the billing period covered by this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Category of the charge (e.g., product sale, service, NRE milestone, royalty, wafer lot, packaging).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Identifier from an external system (e.g., ERP or billing platform) for traceability.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Is Discount Applied' ;
    rdfs:comment 'True if a discount was applied to this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'Indicates whether tax is exempt for this line.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-form description of the billed item or service.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Manufacturer-assigned SKU for the billed product.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting treatment for revenue timing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Percentage rate applied for royalty-based charges.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential order of the line within the invoice.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentReceiptId rdf:type rdf:Property ;
    rdfs:label 'Payment Receipt Id' ;
    rdfs:comment 'System-generated unique identifier for the payment receipt record.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalReferencePaymentReceiptId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Payment Receipt Id' ;
    rdfs:comment 'Reference to the original payment receipt being reversed.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentReceipt .

ind:allocatedAmountTotal rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Total' ;
    rdfs:comment 'Sum of amounts allocated to invoices from this payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountReceived rdf:type rdf:Property ;
    rdfs:label 'Amount Received' ;
    rdfs:comment 'The amount received of the payment receipt record in the invoice domain.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'Reference number provided by the bank for the transaction.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Result of compliance checks (e.g., sanctions, AML) for the payment.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp when compliance check was performed.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID of the person who created the receipt record.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied if payment currency differs from functional currency.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company\'s functional currency.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfAllocations rdf:type rdf:Property ;
    rdfs:label 'Number Of Allocations' ;
    rdfs:comment 'Count of invoice allocations linked to this payment receipt.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onAccountPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'On Account Payment Flag' ;
    rdfs:comment 'True if the payment is recorded as an on-account credit not yet allocated to specific invoices.' ;
    rdfs:domain ind:PaymentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Overpayment Flag' ;
    rdfs:comment 'Indicates if the payment amount exceeds the total invoiced amount.' ;
