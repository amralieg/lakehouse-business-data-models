ind:holdPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'Hold Payment Term Id' ;
    rdfs:comment 'Foreign key linking to invoice.payment_term. Business justification: credit_hold stores payment_terms as a free-text STRING, which is a denormalization. Credit holds in semiconductor AR are often associated with specific payment term violations (e.g., a customer on net' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:primaryCreditCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Customer Account Id' ;
    rdfs:comment 'Unique identifier of the customer to whom the credit hold applies.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryCustomerCreditLimitId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Credit Limit Id' ;
    rdfs:comment 'FK to invoice.customer_credit_limit.customer_credit_limit_id — Credit holds are triggered by credit limit breaches. The hold must reference the credit limit record that was exceeded for analyst review and release decisions.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerCreditLimit .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Unique identifier for the sales order record within the credit hold invoice entity.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:blockLevel rdf:type rdf:Property ;
    rdfs:label 'Block Level' ;
    rdfs:comment 'Scope of the hold: order creation, delivery release, or billing.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Status' ;
    rdfs:comment 'Current lifecycle state of the credit hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount approved for the customer.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdAmount rdf:type rdf:Property ;
    rdfs:label 'Hold Amount' ;
    rdfs:comment 'Monetary amount that is blocked due to the credit hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Placed Timestamp' ;
    rdfs:comment 'Exact date and time when the credit hold was placed.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The hold release date associated with the credit hold invoice record.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStartDate rdf:type rdf:Property ;
    rdfs:label 'Hold Start Date' ;
    rdfs:comment 'The hold start date associated with the credit hold invoice record.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the customer was notified about the credit hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Indicates whether the customer has been notified of the hold.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedDate rdf:type rdf:Property ;
    rdfs:label 'Placed Date' ;
    rdfs:comment 'The placed date associated with the credit hold invoice record.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'The released by of the credit hold record in the invoice domain.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedDate rdf:type rdf:Property ;
    rdfs:label 'Released Date' ;
    rdfs:comment 'The released date associated with the credit hold invoice record.' ;
    rdfs:domain ind:CreditHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputedInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Disputed Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to invoice.invoice_line. Business justification: Customer disputes in semiconductor billing are frequently raised against specific line items (e.g., disputing a unit price on a wafer lot line, or an NRE milestone charge) rather than the entire invoi' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'Date on which the settlement amount was actually paid.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attachedDocumentsFlag rdf:type rdf:Property ;
    rdfs:label 'Attached Documents Flag' ;
    rdfs:comment 'True if supporting documents are attached to the dispute record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Communication channel used to submit the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Timestamp when the dispute record was closed in the system.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle state of the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Category describing the nature of the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total monetary amount being contested in the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Target date for completing the settlement.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the dispute was initially recorded.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'The opened date associated with the dispute invoice record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Number' ;
    rdfs:comment 'External invoice number from the source billing system.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The resolved date associated with the dispute invoice record.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final monetary amount agreed upon to resolve the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Currency used for the settlement amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'System-generated unique identifier for the revenue recognition event record.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRevenueArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Ar Invoice Id' ;
    rdfs:comment 'Identifier of the invoice that generated this revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:sourceArInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Source Ar Invoice Id' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Revenue recognition events are triggered by billing events (invoices). The link to the source invoice is mandatory for ASC 606 compliance and audit.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:sourceInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Source Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to invoice.invoice_line. Business justification: Revenue recognition under ASC 606 must be tracked at the performance obligation level, which maps to individual invoice line items in semiconductor billing (product shipments, NRE milestones, royalty ' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (e.g., FY2023Q2) to which the recognized revenue is booked.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Direct cost attributable to the recognized revenue for this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'Portion of the invoice amount that remains deferred after this recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether the revenue recognition event has been reversed (true) or not (false).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitAmount rdf:type rdf:Property ;
    rdfs:label 'Profit Amount' ;
    rdfs:comment 'Gross profit derived from the recognized revenue (revenue minus COGS).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The recognition date associated with the revenue recognition event invoice record.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue: point-in-time or over-time.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Date and time when the revenue was recognized according to the schedule.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The recognized amount of the revenue recognition event record in the invoice domain.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Monetary amount of revenue recognized in this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Business category of the revenue (e.g., product sale, service, IP licensing, royalty, maintenance).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRevRecEventToArInvoice rdf:type rdf:Property ;
    rdfs:label 'Revenue Rev Rec Event To Ar Invoice' ;
    rdfs:comment 'FK to invoice.ar_invoice.ar_invoice_id — Revenue recognition events must reference the billing document (invoice) that triggered recognition. Required for ASC 606/IFRS 15 compliance audit.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source Record Key' ;
    rdfs:comment 'Unique key of the source record in the originating system.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Id' ;
    rdfs:comment 'System-generated unique identifier for each tax determination record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reverseChargeMechanism rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Mechanism' ;
    rdfs:comment 'Description of the reverse charge method used.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount' ;
    rdfs:comment 'Monetary amount on which the tax rate is applied.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method used to compute the tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Classification of tax (standard, reduced, zero).' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'Monetary value of the tax credit, if applicable.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Eligible' ;
    rdfs:comment 'True if the line qualifies for a tax credit.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Currency' ;
    rdfs:comment 'Three-letter ISO currency code of the tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Reference number of supporting tax document (e.g., certificate, exemption letter).' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentType rdf:type rdf:Property ;
    rdfs:label 'Tax Document Type' ;
    rdfs:comment 'Type of supporting tax document.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason or code for tax exemption, if applicable.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIsReverseCharge rdf:type rdf:Property ;
    rdfs:label 'Tax Is Reverse Charge' ;
    rdfs:comment 'True if reverse charge mechanism applies.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'The tax jurisdiction of the tax determination record in the invoice domain.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the tax jurisdiction.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Type' ;
    rdfs:comment 'Level of the jurisdiction that the tax applies to.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLiabilityParty rdf:type rdf:Property ;
    rdfs:label 'Tax Liability Party' ;
    rdfs:comment 'Entity responsible for remitting the tax.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineDescription rdf:type rdf:Property ;
    rdfs:label 'Tax Line Description' ;
    rdfs:comment 'Free-form description of the tax line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Line Status' ;
    rdfs:comment 'Current processing status of the tax line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Effective Date' ;
    rdfs:comment 'Date from which the tax rate is applicable.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Expiration Date' ;
    rdfs:comment 'Date after which the tax rate is no longer valid.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'The tax rate percent of the tax determination record in the invoice domain.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRecordCreated rdf:type rdf:Property ;
    rdfs:label 'Tax Record Created' ;
    rdfs:comment 'Date-time when the tax determination record was created.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxRecordUpdated rdf:type rdf:Property ;
    rdfs:label 'Tax Record Updated' ;
    rdfs:comment 'Date-time of the most recent update to the tax record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxRegionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Region Code' ;
    rdfs:comment 'Code representing the tax region within the jurisdiction.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period' ;
    rdfs:comment 'Fiscal period for which the tax is reported.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Tax Source System' ;
    rdfs:comment 'Originating ERP or tax engine that generated the record.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Tax Source System Code' ;
    rdfs:comment 'Unique identifier of the tax record in the source system.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Category of tax applied to the transaction line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Flag' ;
    rdfs:comment 'Indicates whether withholding tax applies to this line.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The taxable amount of the tax determination record in the invoice domain.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxableQuantity rdf:type rdf:Property ;
    rdfs:label 'Taxable Quantity' ;
    rdfs:comment 'Quantity of goods or services subject to tax.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Calculated withholding tax amount.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Rate' ;
    rdfs:comment 'Withholding tax rate expressed as a percentage.' ;
    rdfs:domain ind:TaxDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Ip Integration Id' ;
    rdfs:comment 'Primary key uniquely identifying each IP core integration instance within a design project' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designIpCoreId rdf:type rdf:Property ;
    rdfs:label 'Design Ip Core Id' ;
    rdfs:comment 'Foreign key to the IP core being integrated' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpCore .

ind:instanceCount rdf:type rdf:Property ;
    rdfs:label 'Instance Count' ;
    rdfs:comment 'Number of instances of this IP core instantiated within the design project. Affects area, power, and licensing calculations.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationDate rdf:type rdf:Property ;
    rdfs:label 'Integration Date' ;
    rdfs:comment 'Date when the IP core was integrated into the design project. Used for milestone tracking and schedule management.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationEngineerName rdf:type rdf:Property ;
    rdfs:label 'Integration Engineer Name' ;
    rdfs:comment 'Engineer responsible for integrating and verifying this IP core instance within the design project' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current status of the IP integration workflow (planned, in_progress, integrated, verified, signed_off, failed). Tracks progression through integration gates.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseUsageCount rdf:type rdf:Property ;
    rdfs:label 'License Usage Count' ;
    rdfs:comment 'Number of license seats consumed by this integration instance. Used for royalty calculation and license compliance tracking.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Design review sign-off status for this IP integration (pending, approved, rejected, conditional). Required for tapeout gate progression.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Verification Completion Pct' ;
    rdfs:comment 'Percentage of verification test cases completed for this IP integration instance' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionUsed rdf:type rdf:Property ;
    rdfs:label 'Version Used' ;
    rdfs:comment 'Specific version of the IP core integrated into this design project. Critical for silicon-proven status tracking and tapeout documentation.' ;
    rdfs:domain ind:IpIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osatPackageCapabilityId rdf:type rdf:Property ;
    rdfs:label 'Osat Package Capability Id' ;
    rdfs:comment 'Unique surrogate key for the OSAT package capability association record' ;
    rdfs:domain ind:OsatPackageCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitsPerWeek rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Week' ;
    rdfs:comment 'The capacity units per week of the osat vendor record in the packaging domain. [Moved from osat_vendor: Similar to monthly capacity, weekly capacity is allocated per package type based on line configuration and package complexity.]' ;
    rdfs:domain ind:OsatPackageCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCapabilities rdf:type rdf:Property ;
    rdfs:label 'Package Capabilities' ;
    rdfs:comment 'Comma-separated list of package types the vendor is qualified to assemble (e.g., WLCSP, InFO, CoWoS, TSV, flip-chip, BGA). [Moved from osat_vendor: This is a denormalized comma-separated list of package types the vendor is qualified for. This is M:N relationship data that should be represented as individual capability records, not as a string attribute on the vendor.]' ;
    rdfs:domain ind:OsatPackageCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Flag' ;
    rdfs:comment 'Indicates whether this vendor is a preferred source for this package type. Explicitly identified in detection reasoning as relationship-specific data. Supports dual-sourcing and preferred vendor strategies.' ;
    rdfs:domain ind:OsatPackageCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredPackageTypes rdf:type rdf:Property ;
    rdfs:label 'Preferred Package Types' ;
    rdfs:comment 'Comma-separated list of package types the vendor is preferred for. [Moved from osat_vendor: This is a denormalized STRING list that represents M:N relationship data. The detection reasoning explicitly identifies this as \'direct evidence that the current 1:N model is insufficient.\' Each preferred status belongs to a specific vendor-package combination, not to the vendor alone.]' ;
    rdfs:domain ind:OsatPackageCapability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processFlowStepRecipeId rdf:type rdf:Property ;
    rdfs:label 'Process Flow Step Recipe Id' ;
    rdfs:comment 'Unique identifier for this process flow step recipe assignment. Primary key for the association entity.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMandatoryStep rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Step' ;
    rdfs:comment 'Boolean flag indicating whether this recipe step is mandatory for all wafer lots following this flow, or optional based on product variant or engineering requirements.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Name or identifier of the process engineer who last modified this recipe assignment, supporting accountability and change control workflows.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed textual description of this specific step within the flow context, including its purpose, critical parameters, and any step-specific notes for process engineers or operators.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'Ordered position of this recipe within the process flow. Defines the execution order for FAB routing and WIP scheduling. Critical for SEMI E40 compliance.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the process step within the manufacturing flow: Front End Of Line (FEOL), Middle Of Line (MOL), Back End Of Line (BEOL), metrology checkpoint, or inspection gate.' ;
    rdfs:domain ind:ProcessFlowStepRecipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePartsConsumedId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Parts Consumed Id' ;
    rdfs:comment 'System-generated unique identifier for each parts consumption record' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'Date-time when the part was consumed or issued from inventory during the maintenance event.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partConditionAfter rdf:type rdf:Property ;
    rdfs:label 'Part Condition After' ;
    rdfs:comment 'Disposition of the part after the maintenance activity, tracking whether it was installed, removed for refurbishment, disposed, or returned.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partConditionBefore rdf:type rdf:Property ;
    rdfs:label 'Part Condition Before' ;
    rdfs:comment 'Condition assessment of the part being replaced or removed, used for root cause analysis and warranty claim validation.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedVsUnplanned rdf:type rdf:Property ;
    rdfs:label 'Planned Vs Unplanned' ;
    rdfs:comment 'Indicates whether this part consumption was planned (scheduled PM with parts list) or unplanned (emergency repair, discovered during maintenance).' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUsed rdf:type rdf:Property ;
    rdfs:label 'Quantity Used' ;
    rdfs:comment 'Number of units of the spare part consumed during this maintenance event. Supports fractional quantities for consumables measured in non-integer units (e.g., liters, kilograms).' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementReason rdf:type rdf:Property ;
    rdfs:label 'Replacement Reason' ;
    rdfs:comment 'Free-form or coded explanation for why the part was replaced or consumed, supporting root cause analysis and preventive maintenance optimization.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCode rdf:type rdf:Property ;
    rdfs:label 'Technician Code' ;
    rdfs:comment 'Identifier of the technician who recorded or performed the parts consumption, supporting accountability and training needs analysis.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCostAtTimeOfUse rdf:type rdf:Property ;
    rdfs:label 'Unit Cost At Time Of Use' ;
    rdfs:comment 'The unit cost of the spare part at the time it was consumed, captured for accurate maintenance cost accounting and variance analysis against current catalog prices.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Eligible' ;
    rdfs:comment 'Flag indicating whether this parts consumption is eligible for warranty claim against the OEM or supplier.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Line Number' ;
    rdfs:comment 'Sequential line number within the maintenance event work order, supporting integration with CMMS and ERP systems.' ;
    rdfs:domain ind:MaintenancePartsConsumed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolSparePartCompatibilityId rdf:type rdf:Property ;
    rdfs:label 'Tool Spare Part Compatibility Id' ;
    rdfs:comment 'Unique surrogate key for each tool-spare part compatibility record' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compatibilityType rdf:type rdf:Property ;
    rdfs:label 'Compatibility Type' ;
    rdfs:comment 'Classification of the compatibility relationship: primary (OEM-recommended), alternate (approved substitute), emergency (temporary use only), or consumable (routine replacement item). Identified in detection phase relationship data.' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityForTool rdf:type rdf:Property ;
    rdfs:label 'Criticality For Tool' ;
    rdfs:comment 'Business impact rating if this specific part is unavailable for this specific tool. A part may be critical for one tool type but low criticality for another. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCompatible rdf:type rdf:Property ;
    rdfs:label 'Equipment Compatible' ;
    rdfs:comment 'List of equipment models or tool families that can use this spare part. [Moved from spare_part: This denormalized STRING field (list of compatible equipment models) is direct evidence that the data model needs a proper M:N association. This field should be decomposed into individual tool_spare_part_compatibility records, enabling proper querying, maintenance planning, and compatibility matrix management.]' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Installation Procedure Reference' ;
    rdfs:comment 'Reference to the tool-specific installation or replacement procedure document (e.g., work instruction ID, SOP number) for installing this part on this tool' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeForTool rdf:type rdf:Property ;
    rdfs:label 'Lead Time For Tool' ;
    rdfs:comment 'Tool-specific lead time in days for procuring this part for this tool, which may differ from the general part lead time due to tool-specific certifications or supplier agreements. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequiredPerPm rdf:type rdf:Property ;
    rdfs:label 'Quantity Required Per Pm' ;
    rdfs:comment 'Number of units of this spare part required for one preventive maintenance cycle on this specific tool. Varies by tool type and maintenance procedure. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ToolSparePartCompatibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
