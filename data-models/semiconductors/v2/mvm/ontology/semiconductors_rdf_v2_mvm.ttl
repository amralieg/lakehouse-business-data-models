ind:sematechState rdf:type rdf:Property ;
    rdfs:label 'Sematech State' ;
    rdfs:comment 'The sematech state of the tool downtime record in the equipment domain.' ;
    rdfs:domain ind:ToolDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAfter rdf:type rdf:Property ;
    rdfs:label 'State After' ;
    rdfs:comment 'Equipment state after the downtime event concluded.' ;
    rdfs:domain ind:ToolDowntime ;
