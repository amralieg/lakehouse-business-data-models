    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'The run timestamp of the wafer probe run record in the test domain.' ;
    rdfs:domain ind:Test ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Test Coverage Percent' ;
    rdfs:comment 'Proportion of functional tests executed relative to the total test plan.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDieTested rdf:type rdf:Property ;
    rdfs:label 'Total Die Tested' ;
    rdfs:comment 'The total die tested of the wafer probe run record in the test domain.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waferProbeRunStatus rdf:type rdf:Property ;
    rdfs:label 'Wafer Probe Run Status' ;
    rdfs:comment 'Current lifecycle status of the probe run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waferSequenceNumber rdf:type rdf:Property ;
