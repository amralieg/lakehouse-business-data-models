ind:testToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Test Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: JEDEC qualification requires chamber-level traceability for reliability tests (HTOL, ELFR, burn-in). Specific test chambers (e.g., oven chambers) must be identified in qualification documentation. Exi' ;
    rdfs:domain ind:ReliabilityTest ;
