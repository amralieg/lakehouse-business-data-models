    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactAmount rdf:type rdf:Property ;
    rdfs:label 'Impact Amount' ;
    rdfs:comment 'Estimated monetary impact of the non-conformance.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactCurrencyCode rdf:type rdf:Property ;
