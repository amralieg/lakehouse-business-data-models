    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:assemblyPosition rdf:type rdf:Property ;
    rdfs:label 'Assembly Position' ;
    rdfs:comment 'Position identifier for multi-die or chiplet assemblies.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Serial number of the packaged device, if applicable.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dieXCoordinate rdf:type rdf:Property ;
    rdfs:label 'Die X Coordinate' ;
    rdfs:comment 'The die x coordinate of the unit test result record in the test domain.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dieYCoordinate rdf:type rdf:Property ;
    rdfs:label 'Die Y Coordinate' ;
    rdfs:comment 'The die y coordinate of the unit test result record in the test domain.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardBin rdf:type rdf:Property ;
    rdfs:label 'Hard Bin' ;
    rdfs:comment 'The hard bin of the unit test result record in the test domain.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardBinCode rdf:type rdf:Property ;
    rdfs:label 'Hard Bin Code' ;
    rdfs:comment 'Hard bin classification assigned to the unit based on test outcome.' ;
