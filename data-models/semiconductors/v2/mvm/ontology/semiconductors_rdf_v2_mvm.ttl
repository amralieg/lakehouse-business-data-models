    rdfs:range xsd:string .

ind:nonconformanceReportStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Report Status' ;
    rdfs:comment 'Current lifecycle status of the report.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceType rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Type' ;
    rdfs:comment 'The nonconformance type of the nonconformance report record in the quality domain.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business-visible identifier (NCR number) assigned to the report.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Timestamp' ;
    rdfs:comment 'Date-time when the non-conformance was initially recorded.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis identifying the underlying cause of the non-conformance.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitId rdf:type rdf:Property ;
    rdfs:label 'Limit Id' ;
    rdfs:comment 'Foreign key linking to test.limit. Business justification: Quality specs define acceptance criteria that must align with test limits. Linking quality_spec to test limit enables spec-to-limit alignment verification, required for test limit validation and quali' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Limit .

ind:measurementFabToolId rdf:type rdf:Property ;
    rdfs:label 'Measurement Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Specification Measurement Traceability links each spec to the Fab Tool that performs the measurement, required for ISO 9001 compliance.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Level of the product hierarchy the spec applies to.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Technique used to inspect or measure the parameter.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'Date of the most recent validation activity.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for the parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Value' ;
    rdfs:comment 'Target nominal value for the parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitySpecStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Spec Status' ;
    rdfs:comment 'Current lifecycle state of the specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which the specification is reviewed.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Unique business code assigned to the specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specName rdf:type rdf:Property ;
    rdfs:label 'Spec Name' ;
    rdfs:comment 'Human-readable name of the quality specification.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specNumber rdf:type rdf:Property ;
    rdfs:label 'Spec Number' ;
    rdfs:comment 'The spec number of the quality spec record in the quality domain.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specType rdf:type rdf:Property ;
    rdfs:label 'Spec Type' ;
    rdfs:comment 'Category of the specification such as electrical, dimensional, visual, or reliability.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for the parameter.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedFlag rdf:type rdf:Property ;
    rdfs:label 'Validated Flag' ;
    rdfs:comment 'Indicates whether the specification has been validated against actual parts.' ;
    rdfs:domain ind:QualitySpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heldFabToolId rdf:type rdf:Property ;
    rdfs:label 'Held Fab Tool Id' ;
    rdfs:comment 'Foreign key linking to equipment.fab_tool. Business justification: Tool-level quality holds (equipment quarantine) are a standard fab practice when a tool is suspected of causing product nonconformance. Linking quality_hold to fab_tool enables direct tool hold manage' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FabTool .

ind:heldToolChamberId rdf:type rdf:Property ;
    rdfs:label 'Held Tool Chamber Id' ;
    rdfs:comment 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level quality holds are placed when a specific chamber is suspected of contamination or process excursion while other chambers on the same tool remain qualified. This chamber-specific hold man' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolChamber .

ind:affectedEntityRef rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Ref' ;
    rdfs:comment 'Identifier of the specific lot, die bank, or inventory batch under hold.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of entity that the hold applies to.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Number of units (dies, wafers, or pieces) impacted by the hold.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

