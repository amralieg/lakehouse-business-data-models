    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Assembly Order Id' ;
    rdfs:comment 'Foreign key linking to packaging.assembly_order. Business justification: Wafer probe run results (KGD yield, pass die count) directly gate die release to assembly orders. Operations teams plan assembly orders against probe run outcomes; this link enables die supply traceab' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:toProbeCardId rdf:type rdf:Property ;
    rdfs:label 'To Probe Card Id' ;
    rdfs:comment 'FK to test.probe_card.probe_card_id — Probe card assignment is critical for wafer probe operations — probe card condition directly impacts yield and contact quality.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProbeCard .

ind:toTestProgramId rdf:type rdf:Property ;
    rdfs:label 'To Test Program Id' ;
    rdfs:comment 'FK to test.test_program.test_program_id — Every wafer probe execution must reference the specific test program (and version) being run. This is the fundamental operational link between test execution and test definition.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:ateConfiguration rdf:type rdf:Property ;
    rdfs:label 'Ate Configuration' ;
    rdfs:comment 'Configuration identifier for the Automatic Test Equipment used in the run.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binMapVersion rdf:type rdf:Property ;
    rdfs:label 'Bin Map Version' ;
    rdfs:comment 'Version identifier of the binning map used to classify die test results.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Contact Yield Percent' ;
    rdfs:comment 'Percentage of dies that made electrical contact during probing.' ;
    rdfs:domain ind:WaferProbeRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Timestamp when the wafer probing run completed or was terminated.' ;
    rdfs:domain ind:Semiconductors ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failDieCount rdf:type rdf:Property ;
    rdfs:label 'Fail Die Count' ;
    rdfs:comment 'Number of dies that failed one or more test criteria.' ;
