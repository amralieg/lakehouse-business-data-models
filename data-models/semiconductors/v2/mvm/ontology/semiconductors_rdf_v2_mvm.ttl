    rdfs:range xsd:integer .

ind:primaryBinDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Bin Definition Id' ;
    rdfs:comment 'FK to test.bin_definition.bin_definition_id — Every unit test result is assigned a bin code from the bin_definition master. This is the core yield classification link.' ;
    rdfs:domain ind:UnitTestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinDefinition .

ind:unitAssignedBinDefinitionId rdf:type rdf:Property ;
