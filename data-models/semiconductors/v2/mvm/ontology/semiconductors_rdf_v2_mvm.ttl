    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeYieldPercent rdf:type rdf:Property ;
    rdfs:label 'Cumulative Yield Percent' ;
    rdfs:comment 'Overall percentage of good dies produced from the lot after each process step.' ;
    rdfs:domain ind:Packaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodUnitCount rdf:type rdf:Property ;
    rdfs:label 'Good Unit Count' ;
    rdfs:comment 'The good unit count of the assembly lot record in the packaging domain.' ;
