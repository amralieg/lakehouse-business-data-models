ind:planarityUm rdf:type rdf:Property ;
    rdfs:label 'Planarity Um' ;
    rdfs:comment 'The planarity um of the probe card record in the test domain.' ;
    rdfs:domain ind:ProbeCard ;
    rdf:type owl:DatatypeProperty ;
