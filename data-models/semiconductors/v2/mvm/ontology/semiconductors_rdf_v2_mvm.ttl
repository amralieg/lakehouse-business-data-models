    rdfs:comment 'Specific actions required to implement the chosen disposition.' ;
    rdfs:domain ind:NonconformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
