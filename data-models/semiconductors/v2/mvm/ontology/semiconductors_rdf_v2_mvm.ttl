    rdfs:range xsd:string .

ind:passFailFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Flag' ;
    rdfs:comment 'The pass fail flag of the bin definition record in the test domain.' ;
    rdfs:domain ind:Test ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testLevel rdf:type rdf:Property ;
    rdfs:label 'Test Level' ;
    rdfs:comment 'Stage of testing where the bin is applied.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Category' ;
    rdfs:comment 'The yield impact category of the bin definition record in the test domain.' ;
    rdfs:domain ind:BinDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Yield Impact Classification' ;
