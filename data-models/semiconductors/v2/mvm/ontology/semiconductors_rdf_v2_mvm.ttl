    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateSupplierName rdf:type rdf:Property ;
    rdfs:label 'Substrate Supplier Name' ;
    rdfs:comment 'The substrate supplier name of the substrate bom record in the packaging domain.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substrateSupplierPart rdf:type rdf:Property ;
    rdfs:label 'Substrate Supplier Part' ;
    rdfs:comment 'The substrate supplier part of the substrate bom record in the packaging domain.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thermalConductivityWPerMk rdf:type rdf:Property ;
    rdfs:label 'Thermal Conductivity W Per Mk' ;
    rdfs:comment 'Thermal conductivity of the substrate material.' ;
    rdfs:domain ind:SubstrateBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAssemblyOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Order Id' ;
    rdfs:comment 'FK to packaging.assembly_order.assembly_order_id — Assembly lots are created under an assembly order. This is the primary parent-child relationship for WIP tracking.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssemblyOrder .

ind:assemblyLotStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Lot Status' ;
    rdfs:comment 'The status of the assembly lot record in the packaging domain.' ;
    rdfs:domain ind:AssemblyLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
