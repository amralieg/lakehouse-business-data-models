// DBML Schema for Business: Semiconductors
// Version: 2
// Generated on: 2026-06-24 01:59:25

Project {
  database_type: 'Databricks Unity Catalog'
  Note: 'Lakehouse data model for Semiconductors - Version 2'
}

Table fabrication.fabrication_wafer_lot {
  fabrication_wafer_lot_id varchar [pk, note: 'Unique identifier for the wafer lot tracked through the FAB from wafer start to lot disposition. Primary key for all WIP lot tracking across FEOL, MOL, and BEOL operations.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Required for lot‑level billing and customer account reporting; each wafer lot is charged to a specific customer account.']
  booking_id varchar [note: 'Foreign key linking to sales.booking. Business justification: Fab planners prioritize and track wafer lots against confirmed customer bookings for on-time delivery reporting and revenue recognition. A booking is the confirmed demand event that a hot lot or prior']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: A wafer lot is processed under a specific control plan version active at production time. IATF 16949 and customer quality agreements require lot-to-control-plan traceability for quality audits and cus']
  customer_contract_id varchar [note: 'Foreign key linking to sales.customer_contract. Business justification: Wafer lots manufactured under long-term supply agreements (LTSAs) must reference the governing customer contract to validate volume commitments, technology node compliance, and PCN obligations. Fab op']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: A wafer lot is processed at a specific fab facility. fabrication_wafer_lot currently stores fab_facility_code as a denormalized string with no FK to fab_facility. Adding fab_facility_id normalizes thi']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Required for Production Planning Report linking each wafer lot to the specific IC catalog item being manufactured.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Required for lot‑level cost and yield reporting per design project, enabling profitability analysis and project KPI dashboards.']
  parent_lot_fabrication_wafer_lot_id varchar [note: 'Reference to the parent lot from which this lot was split or derived. Null for original lots. Enables wafer genealogy tracking and traceability.']
  process_flow_id varchar [note: 'Unique identifier for the process route (recipe sequence) assigned to this lot. Defines the complete sequence of operations from wafer start to completion.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Production planning and order fulfillment track wafer lots against specific SKUs (speed grade, voltage, temperature bin) to calculate commit quantities and manage process splits. Semiconductor fabs re']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: A wafer lot is produced from a specific tapeout\'s mask set. Foundry production tracking links lots to tapeouts for mask set identification, NRE billing, re-spin management, and export control complian']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.technology_node. Business justification: Wafer lot references a technology node; replace string column with FK to technology_node for normalization.']
  actual_completion_timestamp timestamp [note: 'Date and time when the lot completed all FAB processing operations and was dispositioned. Null for lots still in WIP.']
  current_operation_name varchar [note: 'Descriptive name of the current process operation (e.g., CVD_OXIDE_DEP, EUV_LITHO, CMP_POLISH). Provides human-readable context for lot location.']
  current_operation_number varchar [note: 'Sequential operation step number in the process route where the lot is currently located. Used for tracking lot position in the manufacturing flow.']
  current_process_area varchar [note: 'High-level FAB area classification where the lot is currently located: FEOL (front-end-of-line transistor formation), MOL (middle-of-line contacts), BEOL (back-end-of-line interconnect), metrology (inspection), or test (electrical probe).']
  cycle_time_days decimal(10,2) [note: 'Total elapsed time in days from wafer start to lot completion. Key performance metric for manufacturing efficiency and customer responsiveness.']
  due_date date [note: 'Target completion date for the lot to meet customer delivery commitments. Used for scheduling and on-time-delivery tracking.']
  hold_flag boolean [note: 'Indicates whether the lot is currently on hold and prevented from processing. True when lot is held for quality, engineering, or disposition review.']
  hold_reason_code varchar [note: 'Standardized code indicating the reason for lot hold (e.g., QUAL_FAIL, ENG_REVIEW, EQUIP_DOWN, MATL_ISSUE). Null when hold_flag is false.']
  hold_timestamp timestamp [note: 'Date and time when the lot was placed on hold. Used to calculate hold duration and impact on cycle time. Null when lot is not on hold.']
  initial_wafer_count varchar [note: 'Original number of wafers when the lot was started. Used to calculate yield loss and scrap rate during processing.']
  is_hot_lot boolean [note: 'Indicates whether this lot is designated as a hot lot requiring expedited processing and priority resource allocation. True for urgent customer orders.']
  lot_created_timestamp timestamp [note: 'Date and time when the lot record was first created in the MES system. May precede wafer start for planning purposes.']
  lot_disposition varchar [note: 'Final disposition decision for the completed lot: pass (released to next stage), fail (rejected), partial (some wafers pass), rework (reprocess), scrap (discard), or engineering_hold (pending review).']
  lot_notes varchar [note: 'Free-text field for operators and engineers to record important observations, special handling instructions, or process deviations for this lot.']
  lot_number varchar [note: 'Externally-known unique business identifier for the wafer lot assigned by MES at wafer start. Used for tracking and traceability across all FAB operations and external communications.']
  lot_on_node varchar [note: 'FK to fabrication.technology_node.technology_node_id — Every lot is manufactured on a specific technology node. This is fundamental for WIP classification and routing.']
  lot_type varchar [note: 'Classification of the wafer lot purpose: production (revenue-generating), engineering (process development), qualification (product validation), MPW (multi-project wafer shuttle), pilot (pre-production), or rework (reprocessed lot).']
  lot_updated_timestamp timestamp [note: 'Date and time when the lot record was last modified in the MES system. Tracks most recent status or attribute change.']
  mes_system_source varchar [note: 'Identifies the source MES system that created and manages this lot record: Camstar MES, Applied Materials SmartFactory MES, or other. Used for data lineage and system integration.']
  planned_completion_date date [note: 'Forecasted completion date based on current WIP position, remaining operations, and standard cycle times. Updated dynamically as lot progresses.']
  priority_class varchar [note: 'Scheduling priority assigned to the lot for FAB resource allocation. Hot and expedite lots receive preferential processing to meet urgent customer commitments.']
  process_node_nm varchar [note: 'Technology node of the semiconductor process measured in nanometers (e.g., 7nm, 5nm, 3nm). Defines the minimum feature size and process complexity.']
  process_time_hours decimal(10,2) [note: 'Cumulative time in hours the lot has spent in active processing on equipment. Excludes queue and hold time. Used for capacity planning.']
  product_name varchar [note: 'Human-readable name of the IC product being manufactured. Used for reporting and customer communications.']
  queue_time_hours decimal(10,2) [note: 'Cumulative time in hours the lot has spent waiting in queue between operations. Excludes active processing time. Used to identify bottlenecks.']
  rework_count varchar [note: 'Number of times the lot has been reworked or reprocessed through specific operations. Tracks process stability and quality issues.']
  route_version varchar [note: 'Version number of the process route. Tracks recipe changes and process improvements over time for traceability and yield analysis.']
  sampling_plan_code varchar [note: 'Code identifying the quality sampling and inspection plan applied to this lot. Defines which wafers are sampled and at which operations for metrology and defect inspection.']
  scrap_wafer_count varchar [note: 'Total number of wafers scrapped during processing due to defects, breakage, or sampling. Used to calculate yield loss and process capability.']
  split_sequence_number varchar [note: 'Sequential number assigned when a lot is split into multiple child lots. Used with parent_lot_id to track lot genealogy and wafer provenance.']
  wafer_count varchar [note: 'Current number of wafers in the lot. May decrease due to scraps, breakage, or sampling during processing. Initial count typically 25 wafers per lot for standard production.']
  wafer_size_mm varchar [note: 'Diameter of the silicon wafers in the lot measured in millimeters. Standard sizes include 200mm (8-inch) and 300mm (12-inch).']
  wafer_start_timestamp timestamp [note: 'Date and time when the wafer lot was officially started in the FAB and entered WIP tracking. Represents the beginning of the lot\'s manufacturing lifecycle.']
  wip_status varchar [note: 'Current lifecycle status of the wafer lot in the FAB workflow. Tracks lot progression from queue through processing to final disposition.']

  Note: 'Core master entity representing a wafer lot (batch of wafers) tracked through the FAB from wafer start to lot disposition. Authoritative source for lot identity, wafer count, lot type (production, engineering, qualification, MPW), process node, technology node, product code, priority class, WIP status, hold flags, and genealogy linkage. Sourced from Camstar MES and Applied Materials SmartFactory MES. SSOT for all WIP lot tracking across FEOL, MOL, and BEOL operations. Quality and metrology data for this lot is owned by the quality domain and referenced via cross-domain FK.'
}

Table fabrication.wafer {
  wafer_id varchar [pk, note: 'Unique identifier for the individual silicon wafer within the fabrication facility. Primary key for wafer tracking across all FAB (Fabrication Facility) process steps.']
  fab_facility_id varchar [note: 'Reference to the fabrication facility where this wafer is being processed. Supports multi-site operations and capacity planning.']
  fabrication_wafer_lot_id varchar [note: 'Reference to the parent wafer lot that this wafer belongs to. Wafers are processed in lots through the FAB (Fabrication Facility).']
  ic_design_project_id varchar [note: 'Reference to the IC (Integrated Circuit) design project that this wafer is fabricating. Links to design specifications, GDS (Graphic Data System) files, and tapeout records.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Individual wafer substrate traceability to the procured material master is required for RoHS/REACH compliance reporting, yield-by-material-source analysis, and semiconductor quality management. A fab ']
  process_flow_id varchar [note: 'Reference to the process route or recipe that defines the sequence of fabrication steps for this wafer. Routes vary by product technology node and design.']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.technology_node. Business justification: Wafer references a technology node; add FK to technology_node and remove numeric node column.']
  belongs_to_lot varchar [note: 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Every wafer must reference its parent lot. This is the most fundamental relationship in FAB WIP tracking - wafers are always tracked within the context of their lot.']
  completion_timestamp timestamp [note: 'Timestamp when the wafer completed all FAB (Fabrication Facility) process steps and is ready for wafer probing or shipment to OSAT (Outsourced Semiconductor Assembly and Test). Null for in-process wafers.']
  critical_defect_count varchar [note: 'Number of critical defects that are likely to cause die failure. Subset of total defect count, used for yield prediction and SPC (Statistical Process Control).']
  crystal_orientation varchar [note: 'Crystallographic orientation of the silicon wafer surface, specified using Miller indices. <100> is most common for CMOS (Complementary Metal-Oxide-Semiconductor) fabrication.']
  current_operation_number varchar [note: 'Sequential operation number in the process route that the wafer is currently at. Used for tracking progress through the hundreds of steps in IC (Integrated Circuit) fabrication.']
  current_process_step varchar [note: 'Name or code of the current fabrication process step the wafer is at or has completed. Examples: lithography, CVD (Chemical Vapor Deposition), CMP (Chemical Mechanical Planarization), ion implantation.']
  defect_count varchar [note: 'Total number of defects detected on the wafer surface through inspection systems. Tracked across process steps to monitor yield and process control.']
  diameter_mm varchar [note: 'Diameter of the wafer in millimeters. Standard sizes include 150mm (6 inch), 200mm (8 inch), and 300mm (12 inch). Larger diameters enable more dies per wafer.']
  disposition_status varchar [note: 'Current disposition status of the wafer in the FAB (Fabrication Facility) workflow. Tracks lifecycle state from WIP (Work in Process) through completion or scrap.']
  doping_type varchar [note: 'Electrical doping type of the substrate. P-type (boron-doped) or N-type (phosphorus/arsenic-doped) determines the majority carrier type. Intrinsic wafers are undoped.']
  epitaxial_layer_flag boolean [note: 'Indicates whether the wafer has an epitaxial layer grown on the substrate. Epitaxial wafers have a thin crystalline layer with controlled properties for advanced device fabrication.']
  epitaxial_resistivity_ohm_cm decimal(12,6) [note: 'Electrical resistivity of the epitaxial layer in ohm-centimeters, if present. Null for non-epitaxial wafers. Often differs from substrate resistivity.']
  epitaxial_thickness_um decimal(10,3) [note: 'Thickness of the epitaxial layer in micrometers, if present. Null for non-epitaxial wafers. Typical range: 1-20 micrometers.']
  expected_die_count varchar [note: 'Expected number of dies (individual chips) on this wafer based on die size and wafer diameter. Used for yield calculation and planning.']
  genealogy_path varchar [note: 'Hierarchical path tracking the wafer lineage from ingot to lot to wafer. Enables traceability for quality investigations and compliance. Format varies by MES (Manufacturing Execution System).']
  good_die_count varchar [note: 'Actual number of dies that passed electrical testing and quality inspection. Populated after wafer probing and testing. Used to calculate wafer yield.']
  hold_reason_code varchar [note: 'Code indicating the reason for wafer hold or quarantine, if applicable. Examples: out-of-spec measurement, equipment issue, quality investigation. Null for non-held wafers.']
  inspection_timestamp timestamp [note: 'Timestamp of the most recent defect inspection or metrology measurement performed on this wafer. Null if no inspection has been performed yet.']
  last_process_timestamp timestamp [note: 'Timestamp of the most recent process step or operation performed on this wafer. Used for WIP (Work in Process) tracking and cycle time analysis.']
  notch_orientation_degrees varchar [note: 'Angular position of the wafer notch in degrees, used for wafer alignment and orientation during automated processing. Standard is 0 degrees for <110> direction.']
  priority_level varchar [note: 'Processing priority level for this wafer. Critical and high priority wafers receive expedited processing to meet customer commitments or TTM (Time to Market) requirements.']
  record_created_timestamp timestamp [note: 'Timestamp when this wafer record was first created in the data system. Audit field for data lineage and compliance.']
  record_updated_timestamp timestamp [note: 'Timestamp when this wafer record was last updated in the data system. Audit field for data lineage and change tracking.']
  resistivity_ohm_cm decimal(12,6) [note: 'Electrical resistivity of the wafer substrate in ohm-centimeters. Indicates doping concentration and electrical properties. Typical range: 0.001 to 100+ ohm-cm.']
  rework_count varchar [note: 'Number of times this wafer has been reworked or reprocessed due to process excursions or quality issues. Tracked for yield analysis and process improvement.']
  scrap_reason_code varchar [note: 'Code indicating the reason for wafer scrap, if applicable. Examples: excessive defects, process excursion, handling damage, contamination. Null for non-scrapped wafers.']
  slot_position varchar [note: 'Physical slot position of the wafer within the carrier or cassette during processing. Used for tracking and automation.']
  start_timestamp timestamp [note: 'Timestamp when the wafer entered the FAB (Fabrication Facility) and began processing. Marks the beginning of the wafer lifecycle for cycle time tracking.']
  substrate_type varchar [note: 'Material composition of the wafer substrate. Silicon is most common, but compound semiconductors like GaAs (Gallium Arsenide), SiC (Silicon Carbide), and GaN (Gallium Nitride) are used for specialized applications.']
  thickness_um decimal(10,3) [note: 'Thickness of the wafer in micrometers. Typical range is 500-800 micrometers depending on diameter and application. Critical for mechanical stability and process control.']
  wafer_number varchar [note: 'Business identifier for the wafer within its lot. Typically a sequential number or alphanumeric code assigned during lot creation.']

  Note: 'Individual silicon wafer entity within a lot, tracking wafer number, substrate type, diameter, orientation, resistivity, epitaxial layer specs, and current disposition. Enables per-wafer genealogy and yield tracking across all FAB process steps. Sourced from Camstar MES wafer tracking module.'
}

Table fabrication.process_recipe {
  process_recipe_id varchar [pk, note: 'Unique identifier for the fabrication process recipe. Primary key for this entity.']
  approved_vendor_id varchar [note: 'Foreign key linking to supply.approved_vendor. Business justification: Semiconductor process recipes are qualified against materials from specific approved vendors. This link enables process qualification scope management — when an approved vendor status changes or expir']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Process recipes specify qualified consumable materials (deposition targets, etch gases, CMP slurries). Linking recipe to material_master enables PCN impact analysis — when a supplier changes a materia']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: A process recipe is validated and qualified for a specific technology node (e.g., 5nm, 7nm, 28nm). fabrication_process_recipe currently stores process_node_nm as a denormalized integer with no FK to f']
  approval_date date [note: 'Date when the recipe was formally approved for production use.']
  approval_status varchar [note: 'Engineering approval status indicating whether the recipe has been reviewed and authorized for use by process engineering and quality teams.']
  approved_by varchar [note: 'Name or identifier of the process engineer or quality manager who approved this recipe for production use.']
  chamber_configuration varchar [note: 'Specific chamber or module configuration within the equipment where the recipe is executed, enabling multi-chamber tool recipe management.']
  change_control_reference varchar [note: 'Reference to the Engineering Change Order (ECO) or Product Change Notification (PCN) that authorized the creation or modification of this recipe.']
  cool_duration_seconds varchar [note: 'Specified cooling duration.']
  cool_target_temperature_celsius decimal(8,2) [note: 'Target cooldown temperature in recipe.']
  coolant_flow_rate_lpm decimal(10,4) [note: 'Coolant flow rate in liters per minute.']
  coolant_recirculation_flag boolean [note: 'Whether coolant is recirculated to reduce waste.']
  coolant_reclaim_rate_percent decimal(5,2) [note: 'Percentage of coolant reclaimed/recycled.']
  coolant_recycling_enabled_flag boolean [note: 'Whether coolant recycling (waste elimination) is enabled.']
  coolant_waste_volume_liters decimal(12,4) [note: 'Volume of coolant waste generated.']
  cooldown_rate_celsius_per_min decimal(10,4) [note: 'Specified cooldown rate.']
  cooling_duration_seconds decimal(12,2) [note: 'Duration of the cooling stage.']
  cooling_energy_consumption_kwh decimal(12,4) [note: 'Energy consumed by the cooling process.']
  cooling_energy_recovery_flag boolean [note: 'Whether waste-heat / energy recovery is enabled for the recipe cooling step.']
  cooling_energy_target_kwh decimal(12,4) [note: 'Target cooling energy consumption.']
  cooling_medium varchar [note: 'Cooling medium used (e.g., DI water, helium backside, chilled nitrogen).']
  cooling_method varchar [note: 'Cooling method defined by the recipe.']
  cooling_optimization_enabled_flag boolean [note: 'Whether cooling optimization is enabled for this step/recipe.']
  cooling_optimization_mode varchar [note: 'Cooling optimization option for the recipe.']
  cooling_optimization_option varchar [note: 'Cooling optimization option applied during the recipe cooling step.']
  cooling_process_flag boolean [note: 'Indicates whether this step/recipe includes a cooling process stage.']
  cooling_ramp_rate_celsius_per_min decimal(10,4) [note: 'Controlled cooling ramp-down rate.']
  cooling_step_required_flag boolean [note: 'Whether the recipe includes a cooling step.']
  cooling_target_temperature_celsius decimal(8,2) [note: 'Target wafer/chamber temperature after cooling.']
  cooling_waste_elimination_option varchar [note: 'Waste-elimination option applied during the recipe cooling step.']
  created_timestamp timestamp [note: 'Timestamp when this recipe record was first created in the MES system.']
  defect_density_target_per_cm2 decimal(10,4) [note: 'Target defect density in defects per square centimeter for wafers processed with this recipe, critical for yield management.']
  effective_end_date date [note: 'Date when this recipe version is superseded or retired. Null indicates the recipe is currently active with no planned end date.']
  effective_start_date date [note: 'Date when this recipe version becomes effective and available for production use.']
  environmental_compliance_flag boolean [note: 'Boolean flag indicating whether this recipe complies with environmental regulations including RoHS, REACH, and TSCA for chemical usage and emissions.']
  equipment_type varchar [note: 'Type or model of fabrication equipment (tool) for which this recipe is designed, such as Applied Materials Centura, Lam Research Flex, or ASML NXT scanner.']
  fmea_reference varchar [note: 'Reference to the Failure Mode and Effects Analysis (FMEA) document that identifies potential failure modes and mitigation strategies for this recipe.']
  gas_flow_parameters varchar [note: 'Detailed gas flow settings including gas types, flow rates (sccm), and ratios for CVD, PVD, ALD, and etch processes. Stored as structured text or JSON.']
  itar_controlled_flag boolean [note: 'Boolean flag indicating whether this recipe is subject to International Traffic in Arms Regulations (ITAR) export control restrictions.']
  last_modified_timestamp timestamp [note: 'Timestamp when this recipe record was last modified, supporting change tracking and audit requirements.']
  power_settings_watts decimal(10,2) [note: 'RF or DC power settings in watts for plasma-based processes such as PVD, etch, and plasma-enhanced CVD.']
  process_duration_seconds varchar [note: 'Total duration in seconds for the recipe execution from start to completion.']
  process_layer_type varchar [note: 'Fabrication layer classification: Front End of Line (FEOL) for transistor formation, Middle of Line (MOL) for contacts, or Back End of Line (BEOL) for interconnects.']
  process_operation_type varchar [note: 'Type of FAB operation this recipe defines: Chemical Vapor Deposition (CVD), Physical Vapor Deposition (PVD), Atomic Layer Deposition (ALD), Chemical Mechanical Planarization (CMP), etch, lithography (EUV/DUV), ion implantation, diffusion, oxidation, annealing, or cleaning. [ENUM-REF-CANDIDATE: CVD|PVD|ALD|CMP|etch|lithography|ion_implantation|diffusion|oxidation|annealing|cleaning — 11 candidates stripped; promote to reference product]']
  process_pressure_torr decimal(10,4) [note: 'Target chamber pressure in Torr for the recipe execution, critical for CVD, PVD, and ALD processes.']
  process_temperature_celsius decimal(8,2) [note: 'Target process temperature in degrees Celsius for the recipe execution.']
  product_family varchar [note: 'Product family or IC design family for which this recipe is optimized (e.g., mobile processors, automotive chips, AI accelerators).']
  qualification_date date [note: 'Date when the recipe successfully completed qualification testing and was certified for production.']
  qualification_status varchar [note: 'Qualification state indicating whether the recipe has passed validation testing and is certified for production use.']
  recipe_code varchar [note: 'Unique alphanumeric code assigned to the recipe for system identification and traceability across MES and ERP systems.']
  recipe_description varchar [note: 'Detailed textual description of the recipes purpose, process objectives, and special considerations for operators and engineers.']
  recipe_name varchar [note: 'Human-readable name of the process recipe used for identification and reference by FAB operators and process engineers.']
  recipe_status varchar [note: 'Current lifecycle status of the recipe: draft (under development), under_review (pending approval), approved (validated but not yet active), active (in production use), suspended (temporarily disabled), or obsolete (retired).']
  recipe_version varchar [note: 'Version identifier for the recipe enabling change control and traceability of recipe evolution over time.']
  requalification_due_date date [note: 'Date by which the recipe must be requalified to remain in active production status, per quality management requirements.']
  safety_classification varchar [note: 'Safety classification indicating special handling requirements: standard, hazardous_material, high_temperature, high_pressure, or toxic_gas.']
  spc_control_plan_reference varchar [note: 'Reference to the Statistical Process Control (SPC) plan that monitors this recipes performance and detects process drift.']
  step_sequence_definition varchar [note: 'Ordered sequence of process steps within the recipe, including step names, durations, and parameter transitions. Stored as structured text or JSON.']
  target_material varchar [note: 'Material being deposited, etched, or processed by this recipe (e.g., silicon dioxide, tungsten, copper, photoresist, low-k dielectric).']
  target_thickness_nm decimal(10,3) [note: 'Target thickness in nanometers for deposition or remaining thickness after etch/CMP operations.']
  uniformity_target_percent decimal(5,2) [note: 'Target uniformity percentage for thickness, composition, or other critical parameters across the wafer surface.']
  waste_elimination_strategy varchar [note: 'Waste elimination strategy (e.g., heat_recovery, coolant_reclaim, lean_idle_shutdown).']
  waste_heat_recovery_enabled_flag boolean [note: 'Whether waste-heat recovery is enabled.']
  waste_heat_recovery_flag boolean [note: 'Whether waste heat is recovered/reused.']
  yield_target_percent decimal(5,2) [note: 'Target yield percentage for wafers processed using this recipe, used for performance monitoring and continuous improvement.']

  Note: 'Master record for a validated process recipe defining the exact sequence of process parameters, tool settings, gas flows, temperatures, pressures, and timing for a specific FAB operation (CVD, PVD, ALD, CMP, implant, etch, lithography). Includes recipe version history, approval status, change control reference, qualification status, and effective date range. Versioning managed within this entity via version number and effective dates. Sourced from Applied Materials SmartFactory MES recipe management and integrated with engineering change order workflow.'
}

Table fabrication.process_step {
  process_step_id varchar [pk, note: 'Unique identifier for the process step within the FAB routing. Primary key for the process step entity.']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Each fabrication process step is governed by a control plan specifying inspection frequency, measurement criteria, and acceptance limits. IATF 16949 mandates explicit traceability from process steps t']
  process_flow_id varchar [note: 'Reference to the parent process flow routing that contains this step. Links the step to its overall manufacturing route.']
  process_recipe_id varchar [note: 'Reference to the target process recipe that defines the detailed parameters, settings, and control logic for executing this step on the equipment.']
  rework_return_to_step_process_step_id varchar [note: 'Reference to the target process step to which lots are routed when rework is triggered from this step. Null if no rework loop exists.']
  approval_date date [note: 'Date when the process step was approved for production use. Used for change control and audit trails.']
  approval_status varchar [note: 'Approval workflow status for the process step definition. Tracks engineering change control and qualification approval.']
  approved_by varchar [note: 'Name or identifier of the engineer or manager who approved this process step for production use. Used for traceability and accountability.']
  batch_size varchar [note: 'Number of wafers or lots that can be processed together in a single batch at this step. Null for single-wafer processing steps.']
  change_control_number varchar [note: 'Engineering change order or change control number associated with the creation or modification of this process step. Links to formal change management process.']
  coolant_flow_rate_lpm decimal(10,4) [note: 'Coolant flow rate in liters per minute.']
  coolant_recirculation_flag boolean [note: 'Whether coolant is recirculated to reduce waste.']
  coolant_reclaim_rate_percent decimal(5,2) [note: 'Percentage of coolant reclaimed/recycled.']
  coolant_waste_volume_liters decimal(12,4) [note: 'Volume of coolant waste generated.']
  cooling_condition_reference varchar [note: 'Reference code to the applicable cooling condition specification.']
  cooling_duration_seconds decimal(12,2) [note: 'Duration of the cooling stage.']
  cooling_energy_consumption_kwh decimal(12,4) [note: 'Energy consumed by the cooling process.']
  cooling_medium varchar [note: 'Cooling medium used (e.g., DI water, helium backside, chilled nitrogen).']
  cooling_method varchar [note: 'Cooling method applied (e.g., convective, conductive, cryogenic, water-cooled chuck).']
  cooling_optimization_enabled_flag boolean [note: 'Whether cooling optimization is enabled for this step/recipe.']
  cooling_optimization_mode varchar [note: 'Cooling optimization option selected (e.g., energy_min, throughput_max, balanced).']
  cooling_process_flag boolean [note: 'Indicates whether this step/recipe includes a cooling process stage.']
  cooling_ramp_rate_celsius_per_min decimal(10,4) [note: 'Controlled cooling ramp-down rate.']
  cooling_required_flag boolean [note: 'Indicates whether a cooling step is required after this process step.']
  cooling_target_temperature_celsius decimal(8,2) [note: 'Target wafer/chamber temperature after cooling.']
  cost_center varchar [note: 'Financial cost center to which this process step is allocated for cost accounting and budgeting purposes.']
  created_timestamp timestamp [note: 'Timestamp when this process step record was first created in the system. Used for audit trails and data lineage.']
  critical_step_flag boolean [note: 'Boolean flag indicating whether this step is critical to product quality or yield. Critical steps require enhanced monitoring, control, and approval workflows.']
  effective_end_date date [note: 'Date when this process step definition is retired or superseded. Null for currently active steps. Supports historical tracking and version control.']
  effective_start_date date [note: 'Date when this process step definition becomes effective and can be used in production routing. Supports time-based version control.']
  equipment_class varchar [note: 'Constraint specifying the class or type of equipment required to execute this process step. Used by MES for equipment qualification and dispatching.']
  inspection_required_flag boolean [note: 'Boolean flag indicating whether inline inspection or metrology is required after this step. True if inspection is mandatory before proceeding to the next step.']
  last_modified_by varchar [note: 'User identifier of the person who last modified this process step record. Used for accountability and audit trails.']
  last_modified_timestamp timestamp [note: 'Timestamp when this process step record was last modified. Used for change tracking and audit trails.']
  max_queue_time_minutes decimal(10,2) [note: 'Maximum allowable queue time in minutes before the step must be processed or the lot is flagged for hold. Critical for time-sensitive processes.']
  min_batch_size varchar [note: 'Minimum number of wafers or lots required to start processing at this step. Used for batch tool optimization and scheduling.']
  operation_type varchar [note: 'High-level classification of the process step into Front End of Line (FEOL), Middle of Line (MOL), or Back End of Line (BEOL) manufacturing phases.']
  process_category varchar [note: 'Detailed classification of the process step by operation category such as lithography, etch, deposition (CVD/PVD/ALD), Chemical Mechanical Planarization (CMP), ion implant, thermal anneal, clean, wet clean, inspection, or metrology. [ENUM-REF-CANDIDATE: lithography|etch|deposition|CMP|implant|anneal|clean|wet_clean|inspection|metrology — 10 candidates stripped; promote to reference product]']
  process_subcategory varchar [note: 'Granular subcategory within the process category, such as EUV lithography, DUV lithography, plasma etch, reactive ion etch, CVD, PVD, ALD, etc. Provides detailed process technology classification.']
  rework_loop_indicator boolean [note: 'Boolean flag indicating whether this step is part of a rework loop. True if the step can route back to an earlier step for defect correction or reprocessing.']
  sampling_rate_percent decimal(5,2) [note: 'Percentage of lots or wafers that must be sampled for inspection or metrology at this step. Used for statistical quality control.']
  skip_allowed_flag boolean [note: 'Boolean flag indicating whether this step can be skipped under certain conditions (e.g., engineering wafers, test lots). True if skip is permitted.']
  standard_queue_time_minutes decimal(10,2) [note: 'Expected queue time in minutes before the step begins processing. Used for scheduling and WIP prediction.']
  step_code varchar [note: 'Standardized alphanumeric code uniquely identifying the step type across all FAB operations. Used for cross-facility consistency and reporting.']
  step_cost_per_wafer decimal(12,4) [note: 'Standard cost per wafer for executing this process step. Used for product costing, yield analysis, and financial planning. Business-confidential financial data.']
  step_description varchar [note: 'Detailed textual description of the process step, including purpose, key parameters, and special handling instructions for operators and engineers.']
  step_name varchar [note: 'Human-readable name or identifier for the process step. Used for operator reference and MES display.']
  step_sequence_number varchar [note: 'Sequential ordering of this step within the process flow routing. Determines the execution order of operations in the FAB.']
  step_status varchar [note: 'Current lifecycle status of the process step definition. Active steps are in production use; inactive or obsolete steps are retired; engineering steps are under development; pending approval steps await qualification.']
  target_cycle_time_minutes decimal(10,2) [note: 'Step-level target cycle time in minutes. Used for capacity planning, scheduling, and WIP flow optimization.']
  version_number varchar [note: 'Version identifier for the process step definition. Incremented with each engineering change. Supports change control and traceability.']
  waste_elimination_strategy varchar [note: 'Waste elimination strategy (e.g., heat_recovery, coolant_reclaim, lean_idle_shutdown).']
  waste_heat_recovery_flag boolean [note: 'Whether waste heat is recovered/reused.']

  Note: 'Individual process step definition within a process flow routing, specifying step sequence number, operation type (FEOL/MOL/BEOL), process category (lithography, etch, deposition, CMP, implant, anneal, clean, wet clean), target recipe reference, equipment class constraint, SPC control plan linkage, rework loop indicators, and step-level cycle time targets. Forms the authoritative step catalog for all FAB routing and is the granular unit of WIP tracking. Aligned with SEMI E40 process management standard for step-level definition.'
}

Table fabrication.process_flow {
  process_flow_id varchar [pk, note: 'Unique identifier for the process flow. Primary key for the process flow entity.']
  customer_account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Customer-specific process flows (is_customer_specific flag exists) require direct customer account linkage for IP protection, NDA compliance enforcement, and customer-specific capacity allocation repo']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: A process flow routing is defined for execution at a specific fab facility, as different facilities may have different equipment configurations and process capabilities. fabrication_process_flow curre']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: Process flows are qualified and dedicated to specific product families for NPI readiness gates, technology qualification reports, and capacity allocation decisions. The existing plain \'product_family\'']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: A process flow is defined for a specific technology node — the complete manufacturing route (FEOL/MOL/BEOL steps) is node-specific. fabrication_process_flow currently stores technology_node as a denor']
  approval_date date [note: 'Date when this process flow received formal approval for use in FAB operations.']
  approved_by varchar [note: 'Name or identifier of the process engineer or manager who approved this process flow for production use.']
  beol_step_count varchar [note: 'Number of process steps in the Back End Of Line (BEOL) phase covering metal interconnect layers and passivation.']
  coolant_flow_rate_lpm decimal(10,4) [note: 'Coolant flow rate in liters per minute.']
  coolant_recirculation_flag boolean [note: 'Whether coolant is recirculated to reduce waste.']
  coolant_reclaim_rate_percent decimal(5,2) [note: 'Percentage of coolant reclaimed/recycled.']
  coolant_waste_volume_liters decimal(12,4) [note: 'Volume of coolant waste generated.']
  cooling_duration_seconds decimal(12,2) [note: 'Duration of the cooling stage.']
  cooling_energy_consumption_kwh decimal(12,4) [note: 'Energy consumed by the cooling process.']
  cooling_medium varchar [note: 'Cooling medium used (e.g., DI water, helium backside, chilled nitrogen).']
  cooling_method varchar [note: 'Cooling method applied (e.g., convective, conductive, cryogenic, water-cooled chuck).']
  cooling_optimization_enabled_flag boolean [note: 'Whether cooling optimization is enabled for this step/recipe.']
  cooling_optimization_mode varchar [note: 'Cooling optimization option selected (e.g., energy_min, throughput_max, balanced).']
  cooling_process_flag boolean [note: 'Indicates whether this step/recipe includes a cooling process stage.']
  cooling_ramp_rate_celsius_per_min decimal(10,4) [note: 'Controlled cooling ramp-down rate.']
  cooling_target_temperature_celsius decimal(8,2) [note: 'Target wafer/chamber temperature after cooling.']
  created_timestamp timestamp [note: 'Timestamp when this process flow record was first created in the system.']
  effective_end_date date [note: 'Date when this process flow is no longer valid for new wafer lot starts. Nullable for flows with indefinite validity.']
  effective_start_date date [note: 'Date when this process flow becomes valid and available for wafer lot routing and WIP scheduling.']
  environmental_classification varchar [note: 'Environmental and chemical safety classification for materials and processes used in this flow (e.g., RoHS compliant, REACH registered).']
  estimated_cycle_time_days decimal(10,2) [note: 'Estimated total manufacturing cycle time in days for a wafer lot to complete this entire process flow under normal conditions.']
  export_control_classification varchar [note: 'Export control classification number (ECCN) or ITAR designation governing international transfer and use of this process technology.']
  fabrication_process_flow_description varchar [note: 'Detailed textual description of the process flow including its purpose, key characteristics, and intended applications.']
  feol_step_count varchar [note: 'Number of process steps in the Front End Of Line (FEOL) phase covering transistor formation and active device fabrication.']
  flow_code varchar [note: 'Unique business identifier code for the process flow used across FAB operations and MES systems.']
  flow_name varchar [note: 'Human-readable name of the process flow identifying the manufacturing route.']
  flow_revision varchar [note: 'Revision identifier tracking version changes to the process flow definition.']
  flow_status varchar [note: 'Current lifecycle status of the process flow indicating its approval and usage state in FAB operations.']
  flow_type varchar [note: 'Classification of the process flow indicating its purpose: standard production, Multi-Project Wafer (MPW), engineering evaluation, qualification, or research and development (R&D).']
  is_customer_specific boolean [note: 'Boolean flag indicating whether this process flow is customized for a specific customer or represents a standard foundry offering.']
  last_modified_by varchar [note: 'Name or identifier of the user who last modified this process flow record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this process flow record was last updated or modified.']
  lithography_technology varchar [note: 'Primary lithography technology used in critical patterning steps: EUV (Extreme Ultraviolet), DUV (Deep Ultraviolet), immersion, or dry lithography.']
  metal_layer_count varchar [note: 'Total number of metal interconnect layers defined in the BEOL portion of this process flow.']
  mol_step_count varchar [note: 'Number of process steps in the Middle Of Line (MOL) phase covering contact formation and local interconnect.']
  qualification_completion_date date [note: 'Date when the process flow successfully completed qualification testing and was certified for production use.']
  qualification_status varchar [note: 'Status of the process flow qualification indicating whether it has passed reliability and performance validation testing.']
  requires_nre boolean [note: 'Boolean flag indicating whether this process flow requires Non-Recurring Engineering (NRE) investment for setup and qualification.']
  substrate_type varchar [note: 'Type of substrate material used in this process flow (e.g., silicon, silicon-on-insulator, gallium arsenide, silicon carbide).']
  target_yield_percent decimal(5,2) [note: 'Target yield percentage (good dies per wafer) expected for wafer lots processed through this flow. Business-sensitive manufacturing performance metric.']
  total_process_steps varchar [note: 'Total number of discrete process steps defined in this flow spanning FEOL, MOL, and BEOL operations.']
  transistor_architecture varchar [note: 'Transistor device architecture employed in this process flow: planar MOSFET, FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), or nanosheet.']
  wafer_size_mm varchar [note: 'Wafer diameter in millimeters that this process flow is designed for (e.g., 200mm, 300mm, 450mm).']
  waste_elimination_strategy varchar [note: 'Waste elimination strategy (e.g., heat_recovery, coolant_reclaim, lean_idle_shutdown).']
  waste_heat_recovery_flag boolean [note: 'Whether waste heat is recovered/reused.']

  Note: 'Ordered sequence of process steps defining the complete manufacturing route for a product on a given technology node. Captures flow revision, node generation (e.g., 5nm, 7nm, 28nm), flow type (standard, MPW, engineering), effective dates, and approval status. SSOT for FAB routing and WIP scheduling. Aligned with SEMI E40 process management standard for flow-level routing definition.'
}

Table fabrication.lot_move {
  lot_move_id varchar [pk, note: 'Unique identifier for the lot move transaction. Primary key for this WIP (Work in Process) lot movement event through a FAB (Fabrication Facility) process step.']
  fab_tool_id varchar [note: 'Identifier for the FAB (Fabrication Facility) equipment or tool used to process this lot move (e.g., ATE (Automatic Test Equipment), lithography stepper, etcher, deposition chamber). Links to equipment master data.']
  ic_catalog_id varchar [note: 'Identifier for the IC (Integrated Circuit) product or device being manufactured in this lot. Links to product master data (e.g., SoC (System on Chip), ASIC (Application-Specific Integrated Circuit), FPGA (Field-Programmable Gate Array)).']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: In MES-driven semiconductor fabs, lot moves at inspection steps directly trigger or reference an inspection lot. This is a core MES-to-QMS integration point — the lot_move records the physical step ex']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Lot moves record actual material consumption per process execution. Linking to material_master enables actual-vs-planned material consumption reporting, supplier quality correlation with yield excursi']
  primary_fabrication_wafer_lot_id varchar [note: 'Unique identifier for the WIP (Work in Process) lot being moved. References the wafer lot entity tracked through the FAB (Fabrication Facility).']
  process_step_id varchar [note: 'Foreign key linking to fabrication.fabrication_process_step. Business justification: A lot move transaction records the specific process step at which the lot is being moved (move-in/move-out). lot_move currently has at_step as a BIGINT that semantically represents the process step bu']
  tool_chamber_id varchar [note: 'Identifier for the specific process chamber or module within the equipment used for this lot move. Relevant for multi-chamber tools (e.g., CVD (Chemical Vapor Deposition), PVD (Physical Vapor Deposition), ALD (Atomic Layer Deposition) systems).']
  work_order_id varchar [note: 'Identifier for the manufacturing work order or production order associated with this lot move. Links to ERP (Enterprise Resource Planning) or MES (Manufacturing Execution System) work order master data.']
  actual_flow_rate_sccm decimal(10,2) [note: 'Actual gas flow rate in SCCM (Standard Cubic Centimeters per Minute) for process gases during this lot move. Critical parameter for deposition and etch processes.']
  actual_power_watts decimal(10,2) [note: 'Actual RF (Radio Frequency) or DC power in watts applied during this lot move. Critical parameter for plasma processes (etch, PVD (Physical Vapor Deposition), PECVD (Plasma-Enhanced Chemical Vapor Deposition)).']
  actual_pressure_torr decimal(10,4) [note: 'Actual process chamber pressure in Torr recorded during this lot move. Critical parameter for vacuum processes (PVD (Physical Vapor Deposition), CVD (Chemical Vapor Deposition), etch, implant).']
  actual_temperature_c decimal(8,2) [note: 'Actual process temperature in degrees Celsius recorded during this lot move. Critical parameter for thermal processes (CVD (Chemical Vapor Deposition), diffusion, anneal, oxidation).']
  comments varchar [note: 'Free-text comments or notes entered by the operator or engineer regarding this lot move. Captures contextual information, issues, or special handling instructions.']
  control_job_code varchar [note: 'Identifier for the MES (Manufacturing Execution System) control job that orchestrated this lot move. Links to the higher-level job or batch execution context in Camstar MES or SmartFactory MES.']
  coolant_flow_rate_lpm decimal(10,4) [note: 'Coolant flow rate observed.']
  coolant_reclaim_rate_percent decimal(5,2) [note: 'Coolant reclaim percentage.']
  coolant_waste_volume_liters decimal(12,4) [note: 'Coolant waste volume generated.']
  cooling_duration_seconds decimal(12,2) [note: 'Duration of cooling observed.']
  cooling_energy_consumption_kwh decimal(12,4) [note: 'Energy consumed by cooling.']
  cooling_method varchar [note: 'Cooling method applied.']
  cooling_optimization_enabled_flag boolean [note: 'Whether cooling optimization was active.']
  cooling_optimization_mode varchar [note: 'Cooling optimization option in effect.']
  cooling_process_flag boolean [note: 'Indicates whether a cooling process is associated.']
  cooling_ramp_rate_celsius_per_min decimal(10,4) [note: 'Measured cooling ramp-down rate.']
  created_timestamp timestamp [note: 'Timestamp when this lot move record was first created in the source system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for data lineage and audit trail.']
  defect_count varchar [note: 'Number of defects detected during or after this lot move, as reported by inline inspection or metrology systems. Used for yield analysis and SPC (Statistical Process Control).']
  disposition varchar [note: 'Quality disposition or pass/fail outcome of the lot move. Determines whether the lot proceeds to the next step, requires rework, is scrapped, or is placed on hold for further inspection.']
  hold_reason_code varchar [note: 'Code indicating the reason for a lot hold, if applicable (e.g., quality issue, equipment failure, engineering review, customer request). Empty if lot is not on hold.']
  last_modified_timestamp timestamp [note: 'Timestamp when this lot move record was last updated in the source system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for change tracking and data synchronization.']
  measured_cooling_temperature_celsius decimal(8,2) [note: 'Measured temperature during/after cooling.']
  measurement_unit varchar [note: 'Unit of measure for the measurement_value field (e.g., nm (nanometers), um (micrometers), angstrom, ohm-cm (resistivity), percent, ppm (parts per million)).']
  measurement_value decimal(15,6) [note: 'Primary metrology measurement value captured during this lot move (e.g., film thickness, CD (Critical Dimension), overlay, resistivity). Unit of measure is context-dependent on the operation type.']
  move_in_timestamp timestamp [note: 'Timestamp when the lot was moved into the process step or equipment. Marks the start of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  move_out_timestamp timestamp [note: 'Timestamp when the lot was moved out of the process step or equipment. Marks the completion of processing for this operation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  move_status varchar [note: 'Current lifecycle status of the lot move transaction. Indicates whether the move completed successfully, is still in progress, was aborted, held for review, or skipped.']
  priority_code varchar [note: 'Scheduling priority level for this lot move. Hot and expedite lots receive preferential processing to meet urgent customer commitments or TTM (Time to Market) targets.']
  process_layer varchar [note: 'Manufacturing layer classification for this process step. FEOL (Front End of Line) covers transistor formation, MOL (Middle of Line) covers contacts, BEOL (Back End of Line) covers interconnects and metallization.']
  process_module varchar [note: 'High-level process module category for this operation (e.g., lithography, etch, deposition, ion implantation, CMP (Chemical Mechanical Planarization), diffusion, metrology, inspection, test). [ENUM-REF-CANDIDATE: lithography|etch|deposition|implant|CMP|diffusion|metrology|inspection|test — 9 candidates stripped; promote to reference product]']
  process_time_seconds varchar [note: 'Actual processing time in seconds for this lot move, calculated as the duration between move-in and move-out timestamps. Used for cycle time analysis and equipment utilization tracking.']
  quantity_in varchar [note: 'Number of wafers or units in the lot at move-in. Represents the starting quantity before processing.']
  quantity_out varchar [note: 'Number of wafers or units in the lot at move-out. Represents the ending quantity after processing. May differ from quantity_in due to scrap, breakage, or sampling.']
  queue_time_seconds varchar [note: 'Time in seconds the lot spent waiting in queue before move-in. Measures WIP (Work in Process) wait time and identifies bottlenecks in the FAB (Fabrication Facility) flow.']
  recipe_version varchar [note: 'Version number of the process recipe executed. Tracks recipe revisions and enables traceability for process changes and yield analysis.']
  rework_flag boolean [note: 'Boolean flag indicating whether this lot move is a rework operation (True) or a first-pass operation (False). Rework lots are reprocessed due to defects or out-of-spec conditions.']
  sampling_flag boolean [note: 'Boolean flag indicating whether wafers were sampled from this lot during this move (True) for destructive testing, metrology, or inspection. False if no sampling occurred.']
  scrap_quantity varchar [note: 'Number of wafers or units scrapped during this lot move due to breakage, defects, or process failures. Used for yield loss tracking and DPPM (Defective Parts Per Million) calculation.']
  technology_node varchar [note: 'Process technology node for this lot (e.g., 5nm, 7nm, 14nm, 28nm, 180nm). Defines the minimum feature size and process generation.']
  tracks_lot varchar [note: 'FK to fabrication.wafer_lot.wafer_lot_id — Every lot move transaction must reference the lot being moved. Core MES transaction integrity — cannot track WIP without this FK.']
  wafer_size_mm varchar [note: 'Diameter of the wafers in this lot in millimeters (e.g., 200mm, 300mm, 450mm). Standard wafer size for the FAB (Fabrication Facility).']
  waste_elimination_strategy varchar [note: 'Waste elimination strategy applied.']
  waste_heat_recovery_flag boolean [note: 'Whether waste heat was recovered.']

  Note: 'Transactional record of each WIP lot movement through a process step in the FAB, capturing move-in timestamp, move-out timestamp, operator ID, equipment used, recipe executed, actual process parameters, pass/fail disposition, and quantity in/out. Core MES transaction sourced from Camstar MES and SmartFactory MES. Enables cycle time analysis and WIP genealogy.'
}

Table fabrication.wafer_start {
  wafer_start_id varchar [pk, note: 'Unique identifier for the wafer start transaction. Primary key for the wafer start record.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Wafer starts are customer-initiated production authorizations. Linking to the customer account enables customer-specific capacity planning, production tracking, and billing reconciliation. A foundry o']
  booking_id varchar [note: 'Foreign key linking to sales.booking. Business justification: Wafer starts are authorized against confirmed bookings in demand-driven semiconductor fabs. The booking_id on wafer_start enables capacity planners to validate that each wafer start is backed by a con']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Wafer starts are authorized under a specific control plan version governing quality controls for that product/technology. APQP and IATF 16949 require that production releases reference the approved co']
  created_fabrication_wafer_lot_id varchar [note: 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: A wafer start authorization creates exactly one wafer lot in the FAB. wafer_start currently has creates_lot and start_creates_lot as BIGINT columns that semantically reference the fabrication_wafer_lo']
  customer_contract_id varchar [note: 'Foreign key linking to sales.customer_contract. Business justification: Wafer starts under long-term supply agreements must be validated against contracted volume commitments and technology scope. Contract compliance teams audit wafer starts against customer contracts to ']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: A wafer start is the physical execution of a customer design win authorization. This link supports design-win-to-production traceability, NRE milestone tracking, and production ramp reporting — core s']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: A wafer start is authorized for execution at a specific fab facility. wafer_start currently stores fab_facility_code as a denormalized string. Adding fab_facility_id normalizes this to a proper FK to ']
  fabrication_photomask_id varchar [note: 'Identifier for the photomask set (reticle set) used for lithography steps in this wafer lot. Links to the physical layout and GDS data.']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Supports Wafer Start Scheduling report tying start orders to the IC catalog entry.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Wafer start authorization is the production release event for a specific IC design project. Foundry production planning teams directly reference the design project during wafer start approval, NRE bil']
  line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: In semiconductor foundry ops, wafer starts are authorized against a specific order line (not just the order header) to ensure the correct SKU, quantity, and spec are manufactured. This supports wafer ']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Needed for Wafer Start Material Certification process, tying each wafer start to the supplied material master record for quality and compliance tracking.']
  process_flow_id varchar [note: 'Identifier for the manufacturing process flow (recipe sequence) that this wafer lot will follow. Defines the FEOL, MOL, and BEOL steps.']
  product_spec_id varchar [note: 'Foreign key linking to product.product_spec. Business justification: Wafer starts are initiated against specific product specifications defining target electrical parameters, process corners, and yield requirements. NPI and production ramp workflows require traceabilit']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: Wafer starts consume specific raw silicon wafer inventory. Linking wafer_start to raw_material enables raw material consumption tracking, goods issue posting, and substrate traceability required for p']
  sales_order_id varchar [note: 'Foreign key linking to order.order. Business justification: Required for Wafer Start Planning report linking each wafer start to its originating sales order, enabling traceability from order to production schedule.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Wafer starts are authorized against specific SKU commitments — production schedulers release starts per SKU to ensure correct process splits for speed/voltage/temperature bins. SKU-level wafer start t']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Wafer starts are directly authorized by an approved tapeout — the tapeout defines the mask set, GDS version, and NRE scope that governs production. Foundries track tapeout-to-wafer-start traceability ']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: A wafer start is authorized for a specific technology node, which determines the process flow, mask set, and equipment requirements. wafer_start currently stores technology_node as a denormalized stri']
  authorization_timestamp timestamp [note: 'Date and time when the wafer start was formally authorized in the MES system. Precedes the actual release to the FAB line.']
  created_timestamp timestamp [note: 'System timestamp when this wafer start record was first created in the MES database. Used for audit trail and data lineage.']
  crystal_orientation varchar [note: 'Crystallographic orientation of the silicon wafer, expressed in Miller indices (e.g., <100>, <111>). Affects electrical properties and process compatibility.']
  doping_type varchar [note: 'Electrical doping type of the starting wafer substrate: p-type (boron-doped), n-type (phosphorus or arsenic-doped), or intrinsic (undoped).']
  ear_classification varchar [note: 'Export Control Classification Number (ECCN) under EAR for this product. Format: 5-character code (e.g., 3A001). Null if not export-controlled.']
  estimated_cycle_time_days decimal(6,2) [note: 'Planned total cycle time from wafer start to completion, measured in days. Based on standard process flow duration and current FAB loading.']
  hold_reason_code varchar [note: 'Code indicating the reason for placing this wafer start on hold, if applicable. Examples: quality issue, material shortage, engineering review, customer request.']
  itar_controlled_flag boolean [note: 'Boolean indicator of whether this wafer lot contains ITAR-controlled technology requiring export compliance controls. True if ITAR applies; False otherwise.']
  last_modified_timestamp timestamp [note: 'System timestamp when this wafer start record was last updated. Tracks the most recent change to any field in the record.']
  lot_number varchar [note: 'Manufacturing lot identifier assigned to the wafer batch at start. This is the primary tracking identifier throughout FAB operations.']
  nre_project_code varchar [note: 'Reference to the NRE project if this wafer start is part of a customer-funded development program. Used for cost tracking and milestone billing.']
  parent_lot_number varchar [note: 'Lot number of the parent lot if this wafer start is a split or rework from an existing lot. Null for original starts. Enables wafer genealogy tracking.']
  planned_completion_date date [note: 'Target date for completing all FAB processing steps and releasing the lot to wafer test. Based on standard cycle time for the process flow.']
  priority_class varchar [note: 'Scheduling priority for this wafer lot in the FAB line. Hot lots receive expedited processing; engineering lots may have flexible timing; standard and low follow normal queue discipline.']
  production_line varchar [note: 'Specific production line or bay within the FAB facility assigned to this wafer start. Determines equipment set and process capability.']
  release_timestamp timestamp [note: 'Date and time when the wafer lot was physically released into the FAB line and began processing. Marks the start of cycle time measurement.']
  requested_delivery_date date [note: 'Customer-requested delivery date for finished wafers or packaged units. Drives priority and scheduling decisions.']
  resistivity_ohm_cm decimal(10,4) [note: 'Electrical resistivity of the starting wafer substrate, measured in ohm-centimeters. Indicates doping concentration and electrical characteristics.']
  special_instructions varchar [note: 'Free-text field for any special handling instructions, process deviations, or notes that operators and engineers should be aware of for this wafer lot.']
  split_reason varchar [note: 'Free-text explanation of why this lot was split from a parent lot, if applicable. Examples: process experiment, capacity balancing, quality segregation.']
  substrate_type varchar [note: 'Type of semiconductor substrate material used for this wafer lot. Silicon is standard; SOI (Silicon on Insulator), GaAs (Gallium Arsenide), GaN (Gallium Nitride), and SiC (Silicon Carbide) are specialty materials.']
  wafer_quantity varchar [note: 'Number of wafers authorized and started in this lot. Represents the initial wafer count at FAB entry before any processing losses.']
  wafer_size_mm varchar [note: 'Diameter of the silicon wafer in millimeters. Standard values are 200mm or 300mm. Determines compatible equipment and process chambers.']
  wafer_start_date date [note: 'Calendar date when the wafer lot was authorized and initiated into the FAB line. Principal business event timestamp for capacity planning and WIP tracking.']
  wafer_start_number varchar [note: 'Business identifier for the wafer start transaction, externally visible and used for tracking and reporting. Format: WS followed by 10 digits.']
  wafer_start_status varchar [note: 'Current lifecycle status of the wafer start transaction. Authorized: approved but not yet released; Released: entered FAB line; In Process: active WIP; Completed: all steps finished; Cancelled: terminated before completion; On Hold: temporarily suspended.']
  wafer_start_timestamp timestamp [note: 'Precise date and time when the wafer lot was released into the FAB line, including time zone. Used for detailed cycle time analysis and shift-level tracking.']
  wafer_start_type varchar [note: 'Classification of the wafer start purpose: production (customer orders), engineering (process development), qualification (product validation), MPW (multi-project wafer), pilot (pre-production), or rework (reprocessing).']
  work_center varchar [note: 'SAP work center code representing the initial processing area for this wafer start. Used for capacity planning and cost allocation.']

  Note: 'Transactional record authorizing and recording the initiation of a new wafer lot into the FAB line, capturing wafer start date, authorized quantity, product code, technology node, priority class, customer order reference, and wafer start type (production, engineering, qualification, MPW). SSOT for FAB capacity consumption and WIP entry.'
}

Table fabrication.lot_hold {
  lot_hold_id varchar [pk, note: 'Unique identifier for the fabrication lot hold event record.']
  account_id varchar [note: 'Reference to the customer for whom the lot is being fabricated, relevant for customer-initiated holds or customer notification.']
  capa_record_id varchar [note: 'Foreign key linking to quality.capa_record. Business justification: Lot holds placed as containment actions within a CAPA workflow must reference the governing CAPA record. IATF 16949 requires traceability of containment actions to the CAPA. Quality engineers use this']
  customer_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: fabrication_lot_hold explicitly models customer_notification_required and customer_notification_timestamp, requiring a specific customer contact for disposition decisions and hold notifications. Role-']
  fab_facility_id varchar [note: 'Reference to the fabrication facility where the hold event occurred.']
  fab_tool_id varchar [note: 'Reference to the equipment unit associated with the hold event, if applicable (e.g., tool that triggered the excursion).']
  goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: When a material non-conformance triggers a lot hold, the NCR must reference the specific incoming goods receipt (batch/lot) that caused it. This direct traceability from production hold to incoming in']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Lot holds are frequently triggered by failed inspection lot results. Direct FK from hold to the triggering inspection lot enables hold disposition tracking and root cause analysis. Quality engineers n']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: When a fabrication hold is placed on a wafer lot, the corresponding inventory wafer lot record must be blocked to prevent allocation or shipment. This link supports the hold-to-inventory blocking proc']
  maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: Lot holds are frequently triggered by maintenance events revealing contamination or tool excursions. Linking holds to causative maintenance events is required for root cause analysis, CAPA documentati']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Material non-conformance is a primary cause of lot holds in semiconductor fabs. Linking fabrication_lot_hold to material_master enables material-triggered hold management, supplier corrective action t']
  nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: Lot holds are initiated by or linked to NCRs documenting the quality event causing the hold. fabrication_lot_hold.ncr_number is a denormalized reference to nonconformance_report.ncr_number. Replacing ']
  primary_fabrication_wafer_lot_id varchar [note: 'Reference to the wafer lot that is placed on hold.']
  process_step_id varchar [note: 'Reference to the specific process step (FEOL, MOL, BEOL operation) where the lot was held.']
  sku_id varchar [note: 'Reference to the product (IC design, SoC, ASIC) being fabricated in the lot under hold.']
  tool_chamber_id varchar [note: 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level lot holds are a real fab operation — when a specific chamber fails qualification or shows contamination, lots processed in that chamber are placed on hold. This chamber-to-hold traceabil']
  triggering_bin_definition_id varchar [note: 'Foreign key linking to test.bin_definition. Business justification: Lot holds triggered by bin yield failures reference the specific bin definition that caused the hold. Linking enables yield-based hold disposition rules, bin-specific corrective actions, and quality r']
  triggering_parametric_measurement_id varchar [note: 'Foreign key linking to test.parametric_measurement. Business justification: fabrication_lot_hold has spc_rule_violation flag indicating holds triggered by parametric SPC excursions. Linking to the specific parametric measurement that triggered the hold is required for SPC-dri']
  triggering_wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: Lot holds are frequently triggered by wafer probe yield failures. Linking the hold to the triggering probe run enables root cause analysis, hold disposition workflows, and regulatory traceability — a ']
  approval_required boolean [note: 'Indicator whether management or engineering approval is required before the hold can be released.']
  approval_timestamp timestamp [note: 'Date and time when the hold release was approved.']
  created_timestamp timestamp [note: 'Timestamp when this hold record was first created in the data system.']
  customer_notification_required boolean [note: 'Indicator whether the customer must be notified of this hold event per contractual or quality agreement terms.']
  customer_notification_timestamp timestamp [note: 'Date and time when the customer was notified of the hold event.']
  defect_density_threshold_exceeded boolean [note: 'Indicator whether the hold was triggered by defect density exceeding acceptable limits.']
  disposition_action varchar [note: 'Action taken upon hold release or closure (resume normal processing, rework, scrap, quarantine, return to customer, engineering review).']
  disposition_notes varchar [note: 'Free-text notes documenting the disposition decision, corrective actions taken, or investigation findings.']
  escalation_flag boolean [note: 'Indicator whether the hold has been escalated to senior engineering or management for resolution.']
  hold_cycle_time_hours decimal(10,2) [note: 'Duration in hours between hold placement and release, used for cycle time tracking and excursion management KPIs.']
  hold_expiration_timestamp timestamp [note: 'Date and time when the hold automatically expires if not explicitly released or extended, used for time-bound holds.']
  hold_placement_timestamp timestamp [note: 'Date and time when the hold was placed on the lot, representing the principal business event timestamp.']
  hold_reason_code varchar [note: 'Standardized code indicating the reason for placing the lot on hold (e.g., process excursion, quality issue, engineering investigation, customer request).']
  hold_reason_description varchar [note: 'Detailed textual description of the reason for the hold, providing additional context beyond the reason code.']
  hold_release_timestamp timestamp [note: 'Date and time when the hold was released and the lot was cleared to resume processing. Null if hold is still active.']
  hold_status varchar [note: 'Current lifecycle status of the hold event (active, released, cancelled, expired).']
  hold_type varchar [note: 'Classification of the hold event by functional area or trigger source (engineering, quality, process excursion, customer, equipment, material, safety). [ENUM-REF-CANDIDATE: engineering|quality|process_excursion|customer|equipment|material|safety — 7 candidates stripped; promote to reference product]']
  initiating_system varchar [note: 'Name or identifier of the system that triggered the hold event (e.g., MES, SPC, ATE, manual entry).']
  last_modified_timestamp timestamp [note: 'Timestamp when this hold record was last updated in the data system.']
  lot_number varchar [note: 'Business identifier for the wafer lot under hold, typically assigned by MES system.']
  mes_transaction_code varchar [note: 'Unique transaction identifier from the MES system that recorded this hold event.']
  priority_level varchar [note: 'Urgency classification for resolving the hold (critical, high, medium, low), used for escalation and resource allocation.']
  root_cause_code varchar [note: 'Standardized code identifying the root cause determined during investigation (e.g., equipment malfunction, operator error, material defect).']
  spc_rule_violation varchar [note: 'Specific SPC rule that was violated and triggered the hold (e.g., Western Electric Rule 1, 2, 3, 4).']
  wafer_count varchar [note: 'Number of wafers in the lot at the time the hold was placed.']

  Note: 'Transactional record capturing all hold events placed on a wafer lot, including hold reason code, hold type (engineering, quality, process excursion, customer), initiating system or operator, hold placement timestamp, release timestamp, and disposition action taken. Enables hold cycle time tracking and excursion management.'
}

Table fabrication.photomask {
  photomask_id varchar [pk, note: 'Primary key for photomask']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: In foundry models, photomask sets are customer-owned assets paid via NRE. Tracking the owning customer account is essential for mask asset management, NRE billing, IP protection, and export control co']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Mask management systems track which catalog parts use which mask sets for NRE amortization across wafer starts, PCN impact analysis, and mask reuse planning. photomask links to ic_design_project (desi']
  ic_design_project_id varchar [note: 'Foreign key reference to the IC design project for which this mask was created. Links mask to product design lineage and tapeout records.']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Photomasks undergo periodic defect inspection and CD measurement that generate inspection lots. Traceability from photomask to its inspection lot records is required for mask qualification, retirement']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Photomasks are procured items requiring ERP material master records for inventory management, cost accounting, and compliance tracking. Linking photomask to material_master enables standard ERP-integr']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Photomask.purchase_order_number is a denormalized PO reference. Replacing with a proper FK to supply.purchase_order enables full PO lifecycle tracking for mask procurement, links mask cost to PO finan']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Photomasks must conform to quality specs for critical dimension, defect density, and registration error. The quality_spec defines acceptance criteria for mask qualification and ongoing use. Mask quali']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Photomasks are high-value assets stored in specialized inventory locations (storage_location has photomask_storage_capable flag). Proper FK normalizes the existing storage_location_code plain-text col']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Ensures Photomask Supplier Traceability required by mask qualification and export control audits linking each mask to its supplier record.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Photomasks are manufactured directly from a tapeout\'s GDS data. Mask-to-tapeout traceability is a fundamental semiconductor manufacturing requirement for mask qualification, re-spin tracking, IP sign-']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: A photomask is designed and qualified for a specific technology node — the critical dimension targets, OPC version, and lithography wavelength are all node-specific. photomask currently stores technol']
  acquisition_cost decimal(12,2) [note: 'Total cost paid to acquire this photomask including mask fabrication, OPC, inspection, and shipping. Denominated in USD. Used for asset valuation and depreciation.']
  cd_uniformity_specification decimal(6,3) [note: 'Maximum allowed CD variation across the mask field in nanometers (3-sigma). Tighter specifications required for advanced nodes. Typical range 1-5nm.']
  cleaning_cycle_count varchar [note: 'Number of times this mask has undergone wet or dry cleaning to remove particles and contamination. Excessive cleaning can damage mask patterns.']
  created_timestamp timestamp [note: 'Timestamp when this photomask record was first created in the system. Audit trail for data governance and compliance.']
  critical_defect_count varchar [note: 'Number of critical (killer) defects that will print on wafer and cause yield loss. Subset of total defect count. Mask must be retired or repaired when this exceeds threshold.']
  critical_dimension_target_nm decimal(8,3) [note: 'Target critical dimension (minimum feature size) for this mask layer in nanometers. Used to verify mask pattern fidelity and wafer print quality.']
  cumulative_exposure_hours decimal(10,2) [note: 'Total hours this mask has been exposed to lithography light source (EUV or DUV). Tracks photochemical degradation and pellicle aging.']
  cumulative_usage_count varchar [note: 'Total number of wafer exposures performed with this mask since first use. Primary metric for mask wear tracking and lifecycle management.']
  defect_count_last_inspection varchar [note: 'Number of defects detected during the most recent mask inspection. Tracked to monitor mask degradation and determine cleaning or retirement needs.']
  defect_retirement_threshold varchar [note: 'Maximum critical defect count allowed before mask must be retired or sent for repair. Typically 1-5 defects depending on technology node and layer criticality.']
  gds_file_checksum varchar [note: 'MD5 or SHA-256 checksum of the GDSII file used to generate this mask. Ensures mask-to-design traceability and detects unauthorized pattern changes.']
  last_cleaning_date date [note: 'Date when the mask was last cleaned. Used to schedule preventive cleaning and correlate defect growth with cleaning intervals.']
  last_inspection_date date [note: 'Date of the most recent mask inspection performed by KLA or equivalent metrology tool. Used to enforce periodic inspection schedules.']
  last_modified_timestamp timestamp [note: 'Timestamp when this photomask record was last updated. Tracks data currency and supports change auditing.']
  layer_name varchar [note: 'Process layer designation for which this photomask is used (e.g., POLY, METAL1, VIA2, CONTACT). Corresponds to the GDS layer in the design database.']
  lithography_wavelength varchar [note: 'Exposure wavelength for which this mask is optimized: EUV (13.5nm), DUV ArF (193nm), DUV KrF (248nm), or i-line (365nm).']
  mask_generation varchar [note: 'Generation number of this mask within the mask set. Incremented when a mask is replaced due to defects, pattern revisions, or wear-out. Generation 1 is the original mask.']
  mask_serial_number varchar [note: 'Unique serial number assigned by the mask shop vendor for traceability and warranty purposes. Engraved on the reticle substrate.']
  mask_status varchar [note: 'Current lifecycle status of the photomask: qualified (ready for production), in production (actively used), in inspection, in cleaning, in repair, quarantined (defect investigation), retired (end of life), or scrapped (disposed). [ENUM-REF-CANDIDATE: qualified|in_production|in_inspection|in_cleaning|in_repair|quarantined|retired|scrapped — 8 candidates stripped; promote to reference product]']
  mask_type varchar [note: 'Classification of photomask technology: binary (chrome on glass), attenuated phase shift mask (PSM), alternating PSM, EUV with pellicle, EUV without pellicle, or OPC-enhanced mask.']
  meef_value decimal(5,2) [note: 'Mask Error Enhancement Factor quantifying how mask pattern errors are amplified on the wafer. Higher MEEF indicates greater sensitivity to mask defects. Typical range 1.0 to 8.0.']
  next_inspection_due_date date [note: 'Scheduled date for the next mandatory mask inspection. Calculated based on usage count, exposure hours, or calendar interval per mask management policy.']
  notes varchar [note: 'Free-text field for recording mask-specific observations, special handling instructions, repair history, or other contextual information not captured in structured fields.']
  opc_version varchar [note: 'Version identifier of the OPC software and recipe used to generate the mask pattern. Critical for mask-to-mask consistency and reticle enhancement technology tracking.']
  pellicle_installation_date date [note: 'Date when the current pellicle was installed on the mask. Used to track pellicle aging and replacement cycles.']
  pellicle_status varchar [note: 'Current status of the protective pellicle membrane: installed (protecting mask surface), removed (for inspection or repair), damaged (requires replacement), or not applicable (EUV masks without pellicle).']
  qualification_date date [note: 'Date when the mask passed final qualification inspection and was approved for production use. Marks the start of the masks production lifecycle.']
  received_date date [note: 'Date when the mask was received from the vendor and logged into the FAB inventory system. Marks the start of the masks asset lifecycle.']
  registration_error_specification_nm decimal(6,3) [note: 'Maximum allowed pattern placement error relative to alignment marks in nanometers. Critical for layer-to-layer overlay accuracy. Typical range 2-10nm.']
  retirement_date date [note: 'Date when the mask was retired from production due to reaching usage threshold, excessive defects, or process obsolescence. Null if mask is still active.']
  retirement_reason varchar [note: 'Primary reason for mask retirement: usage limit reached, defect limit exceeded, pattern revision required, process obsolescence, physical damage, or lost/missing.']
  usage_retirement_threshold varchar [note: 'Maximum cumulative usage count allowed before mask must be retired from production. Defined per technology node and mask type to ensure yield protection.']
  warranty_expiration_date date [note: 'Date when the vendor warranty for this mask expires. After this date, repair or replacement costs are borne by the FAB.']

  Note: 'Master record for photomasks (reticles) used in EUV and DUV lithography operations, capturing mask set ID, layer name, technology node, mask type (binary, PSM, EUV pellicle), OPC version, MEEF value, mask generation, pellicle status, inspection history summary, usage count, cleaning cycle count, and retirement threshold. SSOT for mask inventory, lithography step qualification, and reticle lifecycle management within the FAB.'
}

Table fabrication.technology_node {
  technology_node_id varchar [pk, note: 'Unique identifier for the semiconductor technology node record. Primary key.']
  fab_facility_id varchar [note: 'Identifier of the primary fabrication facility where this technology node is manufactured. Links to the fab facility master data.']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: product.fabrication_technology_node and product.process_node represent the same real-world technology node from fab and product domain perspectives. Linking them enables cross-domain node reconcil']
  active_flag boolean [note: 'Indicates whether this technology node record is currently active and available for use in manufacturing and design operations. False indicates archived or deprecated nodes.']
  created_timestamp timestamp [note: 'Timestamp when this technology node record was first created in the system. Audit trail for data lineage and compliance.']
  design_rule_complexity varchar [note: 'Complexity level of Design for Manufacturability (DFM) rules required for this node. Higher complexity nodes require more sophisticated Optical Proximity Correction (OPC) and restricted design rules.']
  dfm_enabled_flag boolean [note: 'Indicates whether Design for Manufacturability (DFM) checks and optimizations are mandatory for designs targeting this node. True for advanced nodes requiring OPC, dummy fill, and restricted design rules.']
  dft_enabled_flag boolean [note: 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, ATPG patterns) are required for designs on this node. Ensures adequate test coverage for quality assurance.']
  ear_classification varchar [note: 'Export Control Classification Number (ECCN) under US Export Administration Regulations (EAR) for this technology node. Determines export licensing requirements to restricted countries.']
  eol_announcement_date date [note: 'Date when the technology node was officially announced for end-of-life phase-out. Triggers Product Change Notification (PCN) and Last Time Buy (LTB) processes for customers.']
  iatf16949_certified_flag boolean [note: 'Indicates whether this technology node is certified under IATF 16949 Automotive Quality Management standards, required for automotive-grade semiconductor production.']
  iso9001_certified_flag boolean [note: 'Indicates whether the manufacturing process for this technology node is certified under ISO 9001 Quality Management System standards.']
  itar_controlled_flag boolean [note: 'Indicates whether this technology node is subject to ITAR (International Traffic in Arms Regulations) export controls due to defense or aerospace applications. Restricts international technology transfer.']
  last_modified_timestamp timestamp [note: 'Timestamp when this technology node record was last updated. Tracks data currency and change history for audit and compliance purposes.']
  lithography_technology varchar [note: 'Primary lithography technology used for patterning in this node. DUV (Deep Ultraviolet) for mature nodes, EUV (Extreme Ultraviolet) for advanced nodes below 7nm.']
  mask_set_cost_usd decimal(15,2) [note: 'Cost of a full photomask set for this technology node in US dollars. Significant cost driver for advanced nodes using EUV lithography. Business-confidential pricing data.']
  metal_layer_count varchar [note: 'Total number of metal interconnect layers available in the Back End of Line (BEOL) stack for this technology node. Typically ranges from 6 to 15+ layers depending on node complexity.']
  minimum_feature_size_nm decimal(10,3) [note: 'The smallest feature dimension that can be reliably manufactured in this technology node, measured in nanometers. Critical dimension for lithography and patterning capability.']
  modified_by_user varchar [note: 'Identifier of the user or system process that last modified this technology node record. Supports audit trail and accountability requirements.']
  node_code varchar [note: 'Internal alphanumeric code used to uniquely identify the technology node in manufacturing execution systems and product lifecycle management systems.']
  node_generation varchar [note: 'Generation classification of the node (e.g., Leading Edge, Mature, Legacy). Indicates the relative maturity and market positioning of the process technology.']
  node_name varchar [note: 'Human-readable name of the technology node (e.g., 5nm, 7nm, 14nm, 28nm, 65nm, 90nm). Industry-standard designation for the process generation.']
  nre_cost_estimate_usd decimal(15,2) [note: 'Estimated Non-Recurring Engineering (NRE) cost in US dollars for a typical design tapeout on this technology node. Includes mask set costs, design services, and qualification expenses. Business-confidential pricing data.']
  power_performance_area_rating varchar [note: 'Qualitative or quantitative assessment of the node\'s Power, Performance, and Area (PPA) characteristics relative to prior generations. Critical metric for competitive positioning.']
  process_flow_version varchar [note: 'Version identifier of the manufacturing process flow (sequence of FEOL, MOL, BEOL steps) defined for this technology node. Tracks process recipe evolution and engineering changes.']
  production_readiness_date date [note: 'Date when the technology node was certified as production-ready and available for high-volume manufacturing (HVM). Null if still in development or qualification.']
  qualification_status varchar [note: 'Current lifecycle status of the technology node. Development: R&D phase. Qualification: undergoing reliability and yield validation. Qualified: approved for production. Production: active manufacturing. Mature: stable high-volume. EOL (End of Life): phase-out planned.']
  reach_compliant_flag boolean [note: 'Indicates whether the chemicals and materials used in this technology node comply with EU REACH Regulation for chemical safety and substance registration.']
  rohs_compliant_flag boolean [note: 'Indicates whether the manufacturing process for this technology node complies with EU RoHS Directive restrictions on hazardous substances (lead, mercury, cadmium, etc.).']
  supported_application_types varchar [note: 'Comma-separated list of target application domains optimized for this node (e.g., Mobile, Automotive, AI/ML, IoT, High-Performance Computing, Networking). Guides product design-in decisions.']
  target_yield_percent decimal(5,2) [note: 'Target percentage of good dies per wafer for this technology node at maturity. Key performance indicator for manufacturing efficiency and cost competitiveness.']
  transistor_architecture varchar [note: 'Type of transistor structure used in this technology node. Planar for older nodes, FinFET (Fin Field-Effect Transistor) for 22nm-7nm, GAA (Gate All Around) for 3nm and below.']
  wafer_size_mm varchar [note: 'Standard wafer diameter supported by this technology node, typically 200mm (8-inch) or 300mm (12-inch). Determines fab equipment compatibility and die yield economics.']

  Note: 'Reference master for semiconductor technology nodes supported in the FAB, capturing node name (e.g., 5nm, 7nm, 28nm, 65nm), node generation, transistor architecture (planar, FinFET, GAA), minimum feature size, metal layer count, PDK version reference, qualification status, and production readiness date. SSOT for node-level process and product classification.'
}

Table fabrication.fab_yield_record {
  fab_yield_record_id varchar [pk, note: 'Unique identifier for the FAB yield record. Primary key for this transactional yield capture event.']
  bin_definition_id varchar [note: 'Foreign key linking to test.bin_definition. Business justification: Yield records track bin-level die counts (bin_1_die_count, bin_2_die_count, bin_3_die_count). Linking to bin_definition enables structured yield analysis by bin category, disposition rules, and yield ']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Fab yield records are collected under a specific control plan governing sampling rates and measurement criteria. IATF 16949 requires traceability from measurement records to the control plan. Quality ']
  fab_facility_id varchar [note: 'Reference to the FAB facility where this yield measurement was captured. Enables multi-site yield comparison and benchmarking.']
  fab_tool_id varchar [note: 'Reference to the inspection or metrology equipment used to capture this yield measurement (e.g., KLA ICOS system). Enables equipment-specific yield correlation.']
  fabrication_photomask_id varchar [note: 'Reference to the photomask set used for lithography on this wafer. Enables correlation of yield to mask quality and OPC effectiveness.']
  fabrication_wafer_lot_id varchar [note: 'Reference to the wafer lot to which this yield record belongs. Enables lot-level yield aggregation and genealogy tracking.']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Enables Yield Dashboard to aggregate yields per IC catalog product.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Yield analysis reports are aggregated per design project; direct FK enables automated project‑level yield dashboards and root‑cause tracking.']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Fab yield records are captured at inline inspection checkpoints that correspond to formal inspection lots. SPC and yield excursion analysis require direct traceability from fab yield records to the in']
  maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: Yield-maintenance correlation is a named semiconductor engineering analysis — yield excursions are investigated against concurrent maintenance events to identify root causes. fab_yield_record has yiel']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Yield excursion analysis by material source is a standard semiconductor fab practice. Linking fab_yield_record to material_master enables supplier quality scorecards, yield-by-material-lot correlation']
  nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: When fab yield records trigger yield excursions (yield_excursion_flag=true), a nonconformance report is initiated. Direct FK enables yield excursion management workflow — quality engineers must trace ']
  physical_layout_id varchar [note: 'Foreign key linking to design.physical_layout. Business justification: DFM yield correlation analysis links yield data to physical layout attributes (metal density, routing congestion, cell utilization) to identify layout-induced yield loss. This is a standard semiconduc']
  primary_fab_wafer_id varchar [note: 'Reference to the specific wafer for which yield is being recorded. Links to the wafer master record in the fabrication domain.']
  process_flow_id varchar [note: 'Reference to the process route or recipe used for this wafer. Links yield outcomes to specific process flows.']
  process_step_id varchar [note: 'Foreign key linking to fabrication.fabrication_process_step. Business justification: A fab yield record captures yield outcomes at key FAB inline checkpoints, which correspond to specific process steps. fab_yield_record currently has no FK to fabrication_process_step despite the produ']
  program_id varchar [note: 'Foreign key linking to test.test_program. Business justification: Yield records are generated by specific test programs. Knowing which test program produced the yield data is essential for yield learning, test program optimization, and correlating test program versi']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Fab yield records are measured against quality specs defining control limits and yield targets. SPC monitoring and yield excursion detection require direct reference to the governing quality spec. Thi']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: SKU-level yield reporting is the primary input for bin split analysis, SKU availability commitments, and pricing decisions. fab_yield_record has ic_catalog_id but not sku_id — SKU-level yield (by spee']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Yield records are analyzed per tapeout version to distinguish design-induced vs. process-induced yield loss. Design and process teams jointly review yield by tapeout for re-spin decisions and design i']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.technology_node. Business justification: Yield record captures technology node; add FK to technology_node and remove redundant numeric column.']
  tool_chamber_id varchar [note: 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level yield correlation is a standard semiconductor engineering process — yield engineers identify chamber-specific defect signatures (chamber matching analysis) to isolate systematic yield lo']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: Fab yield records are directly populated from wafer probe run results. Referencing the probe run that generated the yield data is essential for yield learning, excursion investigation, and audit trace']
  bin_1_die_count varchar [note: 'Number of die classified into bin 1 (typically highest quality/performance bin). Part of bin-level yield breakdown.']
  bin_2_die_count varchar [note: 'Number of die classified into bin 2 (typically second-tier quality/performance bin). Part of bin-level yield breakdown.']
  bin_3_die_count varchar [note: 'Number of die classified into bin 3 (typically third-tier quality/performance bin). Part of bin-level yield breakdown.']
  bin_yield varchar [note: 'Bin yield percentage']
  checkpoint_code varchar [note: 'The FAB inline checkpoint at which this yield measurement was captured. Distinguishes FEOL, MOL, BEOL, and pre-probe stages. [ENUM-REF-CANDIDATE: POST_FEOL|POST_MOL|POST_BEOL|PRE_PROBE|POST_CMP|POST_LITHO|POST_ETCH|POST_IMPLANT|INLINE_INSPECTION — 9 candidates stripped; promote to reference product]']
  comments varchar [note: 'Free-text comments or notes about this yield measurement, including observations, anomalies, or contextual information for root cause analysis.']
  control_limit_lower decimal(5,2) [note: 'Lower control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.']
  control_limit_upper decimal(5,2) [note: 'Upper control limit for yield percentage at this checkpoint. Part of Statistical Process Control (SPC) monitoring.']
  defect_rate decimal(18,2) [note: 'Defect rate per wafer as a decimal ratio']
  design_loss_die_count varchar [note: 'Number of die lost due to design-related issues (DFM violations, timing failures, functional failures). Part of yield loss pareto analysis.']
  disposition_status varchar [note: 'The disposition decision for the wafer or lot based on this yield measurement. Determines next processing step or lot hold.']
  excursion_severity_level varchar [note: 'Severity classification of the yield excursion event. Determines escalation path and response urgency.']
  good_die_count varchar [note: 'Number of die that passed yield criteria at this checkpoint. Represents the actual usable die count after defect screening and binning.']
  gross_die_count varchar [note: 'Total number of die on the wafer before yield screening. Represents the theoretical maximum die count based on wafer size and die layout.']
  hold_reason_code varchar [note: 'The reason code if the wafer or lot was placed on hold due to yield excursion. Links to hold reason reference data.']
  measurement_timestamp timestamp [note: 'The date and time when the yield measurement was captured at the inline checkpoint. Represents the business event time of the yield observation.']
  process_loss_die_count varchar [note: 'Number of die lost due to process-related defects (CVD, PVD, ALD, CMP, etch, implant issues). Part of yield loss pareto analysis.']
  random_defect_die_count varchar [note: 'Number of die lost due to random defects (particles, contamination, handling damage). Part of yield loss pareto analysis.']
  record_created_timestamp timestamp [note: 'The timestamp when this yield record was first created in the data platform. Audit trail for data lineage and compliance.']
  record_updated_timestamp timestamp [note: 'The timestamp when this yield record was last updated in the data platform. Audit trail for data lineage and compliance.']
  reject_bin_die_count varchar [note: 'Number of die classified into reject bins (failed die that do not meet minimum specifications). Part of bin-level yield breakdown.']
  rework_flag boolean [note: 'Boolean indicator that this wafer is eligible for rework based on yield results. Drives rework routing decisions.']
  scrap_flag boolean [note: 'Boolean indicator that this wafer should be scrapped based on yield results. Triggers scrap disposition and cost accounting.']
  specification_limit_lower decimal(5,2) [note: 'Lower specification limit for yield percentage at this checkpoint. Represents minimum acceptable yield threshold.']
  systematic_defect_die_count varchar [note: 'Number of die lost due to systematic defects (OPC errors, MEEF issues, lithography hotspots). Part of yield loss pareto analysis.']
  yield_excursion_flag boolean [note: 'Boolean indicator that this yield record represents an excursion event (yield below control limits or specification). Triggers root cause analysis and corrective action.']
  yield_for_lot varchar [note: 'FK to fabrication.fabrication_wafer_lot.fabrication_wafer_lot_id — Yield records are captured at lot level at key FAB checkpoints.']
  yield_percentage decimal(5,2) [note: 'Calculated yield percentage at this checkpoint (good_die_count / gross_die_count * 100). Primary yield metric for FAB inline performance tracking.']
  yield_rate decimal(18,2) [note: 'Yield rate as a decimal ratio']
  yield_record_for_lot varchar [note: 'FK to fabrication.wafer_lot.wafer_lot_id — Yield records reference the lot measured. Required for lot-level yield tracking and excursion detection.']

  Note: 'Transactional record capturing wafer-level and lot-level yield outcomes at key FAB inline checkpoints (post-FEOL, post-MOL, post-BEOL, pre-probe), recording gross die count, good die count, yield percentage, yield loss pareto by category (process, design, random defect, systematic), bin-level yield breakdown, and yield excursion flags. SSOT for FAB inline yield data distinct from final test yield (owned by test domain) and distinct from SPC/metrology analysis (owned by quality domain).'
}

Table fabrication.fab_facility {
  fab_facility_id varchar [pk, note: 'Primary key for fab_facility']
  parent_fab_facility_id varchar [note: 'Self-referencing FK on fab_facility (parent_fab_facility_id)']
  capacity_wafer_per_month varchar [note: 'Maximum number of wafers the facility can process in a calendar month.']
  carbon_footprint_kgco2e decimal(12,2) [note: 'Monthly greenhouse‑gas emissions expressed in kilograms CO₂ equivalent.']
  city varchar [note: 'City where the facility is located.']
  cleanroom_class varchar [note: 'ISO cleanroom classification of the facility\'s most stringent environment.']
  compliance_status varchar [note: 'Current compliance standing with regulatory and industry standards.']
  contact_email varchar [note: 'Primary email address for facility communications.']
  contact_phone varchar [note: 'Primary telephone number for facility communications.']
  country_code varchar [note: 'Three‑letter ISO country code of the facility location.']
  description varchar [note: 'Free‑form description of the facility\'s capabilities and role.']
  end_date date [note: 'Date when the facility ceased operations (null if still active).']
  energy_consumption_mwh decimal(12,2) [note: 'Average monthly energy consumption measured in megawatt‑hours.']
  environmental_certifications varchar [note: 'Comma‑separated list of environmental certifications (e.g., ISO 14001).']
  equipment_summary varchar [note: 'Free‑text summary of key equipment types and models present.']
  fab_area_sqft decimal(12,2) [note: 'Total usable floor area of the fab in square feet.']
  facility_code varchar [note: 'External business code or identifier used to reference the facility in enterprise systems.']
  facility_name varchar [note: 'Human‑readable name of the fabrication facility.']
  facility_type varchar [note: 'Category of the facility based on its primary function.']
  last_audit_date date [note: 'Date of the most recent compliance audit.']
  latitude decimal(9,6) [note: 'Geographic latitude of the facility (decimal degrees).']
  lifecycle_status varchar [note: 'Current lifecycle stage of the facility.']
  lithography_type varchar [note: 'Primary lithography technology employed at the fab.']
  location_address_line1 varchar [note: 'Primary street address of the facility.']
  location_address_line2 varchar [note: 'Secondary address information (suite, building, etc.).']
  longitude decimal(9,6) [note: 'Geographic longitude of the facility (decimal degrees).']
  maintenance_window varchar [note: 'Typical time window (e.g., weekly, monthly) allocated for planned maintenance.']
  manager_name varchar [note: 'Full name of the person responsible for overall facility management.']
  next_audit_due date [note: 'Scheduled date for the next compliance audit.']
  notes varchar [note: 'Any supplemental information or remarks about the facility.']
  number_of_cleanrooms varchar [note: 'Count of cleanroom spaces within the facility.']
  number_of_equipment_units varchar [note: 'Total number of major equipment units (e.g., lithography, etch, deposition) installed.']
  operational_status varchar [note: 'Current operational condition of the facility.']
  process_technology_node varchar [note: 'Primary semiconductor process node supported (e.g., 7nm, 5nm).']
  restricted_access boolean [note: 'Indicates whether the facility requires restricted (security‑cleared) access.']
  safety_certifications varchar [note: 'Comma‑separated list of safety certifications held (e.g., ISO 45001).']
  shift_schedule varchar [note: 'Number of production shifts operated per day.']
  start_date date [note: 'Date when the facility began operations.']
  state_province varchar [note: 'State or province of the facility location.']
  waste_generated_tons decimal(12,2) [note: 'Total waste generated per month measured in metric tons.']
  water_usage_m3 decimal(12,2) [note: 'Average monthly water usage in cubic meters.']

  Note: 'Master reference table for fab_facility. Referenced by fab_facility_id.'
}

Table fabrication.lot_mask_exposure {
  lot_mask_exposure_id varchar [pk, note: 'Primary key for the lot_mask_exposure association']
  fabrication_wafer_lot_id varchar [note: 'Foreign key linking to the wafer lot that was exposed using this photomask']
  photomask_id varchar [note: 'Foreign key linking to the photomask (reticle) used in this exposure event']
  exposure_count varchar [note: 'Number of wafer exposures this photomask performed on this specific wafer lot during this process step. Used to update cumulative_usage_count on the photomask and to track per-lot mask utilization for yield correlation.']
  exposure_timestamp timestamp [note: 'Date and time when this mask exposure event occurred on the wafer lot. Belongs to the exposure event, not to the mask or lot independently. Used for mask maintenance scheduling, lot genealogy, and yield timeline analysis.']
  layer_name varchar [note: 'The process layer designation for which this mask exposure was performed on this lot (e.g., POLY, METAL1, VIA2). Belongs to the exposure event because the same mask may be used at the same layer across many lots, and the same lot passes through many layers with different masks.']
  lot_sequence_number varchar [note: 'The sequential operation step number in the lot\'s process route at which this mask exposure was performed. Corresponds to current_operation_number on the lot at time of exposure. Enables precise genealogy reconstruction of which mask was used at which step.']

  Note: 'This association product represents the Exposure Event between a photomask (reticle) and a fabrication wafer lot. It captures each instance where a specific photomask was used to expose a specific wafer lot at a specific process layer step. Each record links one photomask to one fabrication_wafer_lot with attributes — layer_name, exposure_count, exposure_timestamp, lot_sequence_number — that exist only in the context of this specific mask-lot exposure event and are essential for yield management, mask maintenance scheduling, and lot genealogy traceability.. Existence Justification: In semiconductor FAB operations, a photomask (reticle) is used to expose multiple wafer lots across its operational lifetime, and a single wafer lot requires multiple photomasks — one per process layer (POLY, METAL1, VIA, etc.) — as it progresses through FEOL, MOL, and BEOL lithography steps. The MES system actively tracks each mask-to-lot exposure event as an operational record for yield management, mask maintenance scheduling, and lot genealogy. This is not an analytical correlation; FAB engineers and process integration teams actively create, query, and manage these exposure records as part of daily operations.'
}

Table design.ic_design_project {
  ic_design_project_id varchar [pk, note: 'Unique surrogate identifier for the IC design project record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Required for project accounting and billing reports linking each design project to the commissioning customer account.']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: IC design projects belong to a product family for NPI portfolio management, family-level NRE budget rollups, and roadmap planning. A program manager expects every design project to be assigned to a pr']
  foundry_approved_vendor_id varchar [note: 'Foreign key linking to supply.approved_vendor. Business justification: Foundry qualification gate before design commitment: design program managers must confirm the target foundry\'s approved vendor status and audit score before committing NRE spend to a process node. Rol']
  foundry_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Foundry selection contract for each design project; required for manufacturing cost tracking and compliance.']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Required for Product Lifecycle Management: design project outcome is recorded as a catalog entry for sales, production planning, and compliance reporting.']
  pdk_id varchar [note: 'FK to design.pdk.pdk_id — Every IC design project targets a specific PDK version. This determines all design rules, standard cells, and device models available. Fundamental design constraint.']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Design projects are assigned to a process node for fab planning, cost estimation, and PDK selection. process_node_nm is a denormalized plain attribute on ic_design_project; replacing it with a proper ']
  block_count varchar [note: 'Number of top-level hierarchical design blocks (partitions) in the IC design. Reflects the block decomposition strategy used for parallel design team assignments and hierarchical physical design in Cadence Innovus.']
  created_timestamp timestamp [note: 'Timestamp when the IC design project record was first created in the system of record (Siemens Teamcenter PLM or Oracle Agile PLM), propagated to the Databricks Silver Layer. Supports audit trail and data lineage requirements.']
  design_phase varchar [note: 'Indicates the primary fabrication phase scope of the design: Front End of Line (FEOL), Middle of Line (MOL), Back End of Line (BEOL), or full-flow. Governs which process modules and DFM rules are active.']
  design_type varchar [note: 'Classification of the integrated circuit design type. Drives NRE cost structure, EDA tool selection, and tapeout process. [ENUM-REF-CANDIDATE: ASIC|SoC|FPGA|ASSP|MCU|GPU|DSP|RFIC|MEMS|Analog — promote to reference product if additional types are needed]']
  dfm_rule_set_version varchar [note: 'Version identifier of the Design for Manufacturability (DFM) rule set applied to this project. Governs OPC recipe selection, MEEF corrections, and yield-enhancement layout guidelines provided by the foundry PDK.']
  dft_enabled boolean [note: 'Indicates whether Design for Testability (DFT) structures (scan chains, BIST, boundary scan) are included in this design. Drives ATPG flow activation, ATE program generation, and KGD qualification planning.']
  eda_tool_suite varchar [note: 'Primary EDA tool suite vendor used for this IC design project (e.g., Cadence Virtuoso/Innovus, Synopsys Design Compiler/PrimeTime, Siemens EDA). Governs tool license allocation and design flow configuration.']
  eda_tool_version varchar [note: 'Version string of the primary EDA tool suite certified for this project (e.g., \'Cadence Innovus 21.1\', \'Synopsys DC 2022.03\'). Ensures design reproducibility and supports audit trails for sign-off certification.']
  export_control_classification varchar [note: 'Export control classification of the IC design project under US Export Administration Regulations (EAR) or International Traffic in Arms Regulations (ITAR). Governs technology transfer restrictions, foreign national access controls, and license requirements. [ENUM-REF-CANDIDATE: EAR99|ECCN_3E001|ECCN_3E002|ECCN_3E003|ITAR|no_restriction — promote to reference product]']
  gate_count_target_k decimal(12,2) [note: 'Target logic gate count in thousands of equivalent gates (Kilo-Gates) for the design. Used for complexity estimation, EDA tool capacity planning, and synthesis runtime forecasting in Synopsys Design Compiler.']
  gds_file_path varchar [note: 'Storage path or URI of the final GDS/GDSII design database file submitted for tapeout. Provides traceability to the authoritative design artifact in the EDA data management system.']
  iatf_automotive_grade boolean [note: 'Indicates whether this IC design project targets automotive-grade qualification per IATF 16949 and AEC-Q100/Q101 standards. Triggers additional FMEA, reliability testing, and DPPM requirements in the quality management workflow.']
  ip_core_count varchar [note: 'Total number of licensed or internally developed Intellectual Property (IP) cores integrated into this IC design project. Drives IP license cost tracking, third-party IP compliance review, and BOM management in Oracle Agile PLM.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the IC design project record in the source system of record. Used for incremental data pipeline processing, change detection, and audit compliance.']
  lithography_type varchar [note: 'Primary lithography technology used for critical layer patterning: Extreme Ultraviolet (EUV), Deep Ultraviolet (DUV), multi-patterning DUV, or nanoimprint. Impacts mask cost, OPC complexity, and MEEF considerations.']
  metal_layer_count varchar [note: 'Number of metal interconnect layers in the BEOL stack for this design. Determines routing resource availability, RC parasitics, and mask set cost. Specified in the PDK and foundry process design rules.']
  nre_actual_spend_usd decimal(18,2) [note: 'Cumulative actual NRE expenditure incurred to date for the IC design project in US dollars, as recorded in SAP S/4HANA FI/CO. Compared against nre_budget_usd for variance analysis and financial reporting.']
  nre_budget_usd decimal(18,2) [note: 'Total approved Non-Recurring Engineering (NRE) budget for the IC design project in US dollars. Covers EDA tool licensing, mask set costs, engineering labor, and MPW shuttle fees. Managed in SAP S/4HANA CO cost center planning.']
  packaging_type varchar [note: 'Target die packaging technology for this IC design project (e.g., WLCSP, BGA, CoWoS, InFO, flip-chip). Influences die size constraints, I/O pad ring design, and OSAT partner selection. [ENUM-REF-CANDIDATE: WLCSP|BGA|QFN|CoWoS|InFO|flip_chip|TSV|SiP|LGA — promote to reference product]']
  pdk_version varchar [note: 'Version of the Process Design Kit (PDK) certified for use in this IC design project. Ensures reproducibility of design rule checks (DRC), layout versus schematic (LVS) verification, and parasitic extraction across the design lifecycle.']
  plm_item_reference varchar [note: 'Native item/object identifier in Siemens Teamcenter PLM or Oracle Agile PLM for this IC design project. Enables bidirectional traceability between the Databricks Silver Layer and the authoritative PLM system of record.']
  project_code varchar [note: 'Externally-known alphanumeric project identifier assigned at project initiation in Siemens Teamcenter PLM and Oracle Agile PLM. Used across EDA tool flows, NRE contracts, and cross-functional communications as the canonical project reference.']
  project_description varchar [note: 'Free-text description of the IC design project scope, target application domain (e.g., AI accelerator, automotive MCU, IoT SoC), and key design objectives. Supports search, discovery, and executive reporting.']
  project_name varchar [note: 'Human-readable name of the IC design project (e.g., \'Orion SoC Rev2\'). Used in PLM dashboards, design reviews, and executive reporting.']
  project_start_date date [note: 'Official start date of the IC design project, corresponding to project kick-off and initial resource allocation in Siemens Teamcenter PLM and SAP S/4HANA CO.']
  project_status varchar [note: 'Current lifecycle state of the IC design project from concept through GDS/GDSII tapeout. Drives milestone tracking, resource allocation, and PLM workflow gates. [ENUM-REF-CANDIDATE: concept|rtl_design|synthesis|physical_design|verification|tapeout|post_tapeout|cancelled — promote to reference product]']
  reach_svhc_assessed boolean [note: 'Indicates whether a REACH Substances of Very High Concern (SVHC) assessment has been completed for materials used in this IC design and packaging. Required for EU chemical safety compliance and customer disclosure obligations.']
  revision varchar [note: 'Design revision identifier (e.g., \'A\', \'B1\', \'C\') tracking major design iterations managed through Oracle Agile PLM change control. Incremented upon significant design changes, ECO incorporation, or re-tapeout events.']
  rohs_compliant boolean [note: 'Indicates whether the IC design and associated packaging materials comply with the EU RoHS Directive (2011/65/EU) restricting hazardous substances. Required for EU market access and customer compliance declarations.']
  rtl_freeze_date date [note: 'Planned or actual date on which the Register Transfer Level (RTL) specification is frozen and handed off to logic synthesis. A key milestone in the IC design schedule tracked in Siemens Teamcenter PLM.']
  sap_wbs_element varchar [note: 'SAP S/4HANA CO Work Breakdown Structure (WBS) element code assigned to this IC design project for NRE cost collection, budget tracking, and financial reporting under SOX controls.']
  tapeout_actual_date date [note: 'Actual date on which the final GDS/GDSII design database was submitted to the foundry for mask generation. Compared against tapeout_target_date to measure schedule adherence and Time to Market (TTM) performance.']
  tapeout_target_date date [note: 'Planned date for final GDS/GDSII tapeout submission to the foundry. Drives the master project schedule, NRE milestone payments, and MPW shuttle slot reservations.']
  target_clock_freq_mhz decimal(10,3) [note: 'Target operating clock frequency in megahertz (MHz) as defined in the Power Performance Area (PPA) specification. Used by Synopsys Design Compiler and PrimeTime for timing closure constraints and sign-off.']
  target_die_area_mm2 decimal(10,4) [note: 'Target silicon die area in square millimeters (mm²) as defined in the PPA specification. Constrains floorplanning, block partitioning, and IP core placement in Cadence Innovus physical design flow.']
  target_power_budget_mw decimal(10,3) [note: 'Maximum allowable total power consumption in milliwatts (mW) as specified in the PPA targets. Drives power-aware synthesis, clock gating strategies, and multi-voltage domain planning in Cadence Innovus and Synopsys Design Compiler.']
  tsv_required boolean [note: 'Indicates whether Through-Silicon Via (TSV) interconnects are required for 3D stacking or advanced packaging (e.g., CoWoS, HBM integration). Triggers specialized process module planning and OSAT coordination.']

  Note: 'Master record for an IC design project lifecycle from RTL specification through GDS/GDSII tapeout. Captures project identity, target process node, design type (ASIC, SoC, FPGA), PPA targets (power budget, clock frequency, die area), tapeout milestone dates, NRE budget, design team assignments, EDA tool suite version, hierarchical block decomposition, and PLM integration references. SSOT for all design project metadata including block-level partitioning. Managed in Siemens Teamcenter PLM and Oracle Agile PLM.'
}

Table design.ip_core {
  ip_core_id varchar [pk, note: 'Unique surrogate identifier for each IP core record in the master catalog. Primary key for the ip_core data product.']
  pdk_id varchar [note: 'Foreign key linking to design.pdk. Business justification: An IP core is defined for a specific Process Design Kit; linking ip_core to pdk eliminates redundant version fields and enables direct lookup of process details.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: IP core licensing vendor relationship; needed for royalty tracking, compliance, and supplier risk assessment.']
  area_um2 decimal(18,4) [note: 'Physical silicon area occupied by the IP core in square micrometers (µm²) for the characterized process node. Part of the PPA characterization data used for die size estimation and floorplanning in Cadence Innovus.']
  code varchar [note: 'Externally-known unique alphanumeric code identifying the IP core in the internal IP library and vendor catalogs (e.g., ARM Cortex-A55, SNPS-PCIE-GEN5). Used as the business key across EDA tool flows, PLM, and design project references.']
  created_timestamp timestamp [note: 'Timestamp when this IP core record was first created in the master catalog (yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for data governance and lineage tracking in the Databricks Silver Layer.']
  datasheet_url varchar [note: 'URL link to the official IP core datasheet or technical reference manual stored in the PLM document management system or vendor portal. Provides design teams with access to integration guidelines, timing specifications, and interface documentation.']
  design_ip_core_name varchar [note: 'Human-readable name of the IP core as used in design documentation, EDA tool libraries, and vendor datasheets (e.g., \'Cortex-A55 CPU Cluster\', \'DesignWare PCIe Gen5 Controller\').']
  dfm_compliant boolean [note: 'Indicates whether the IP core has passed Design for Manufacturability (DFM) rule checks for the target process node (True = DFM-compliant; False = DFM issues present or not checked). DFM compliance reduces yield risk during wafer fabrication.']
  dft_compliant boolean [note: 'Indicates whether the IP core includes Design for Testability (DFT) structures (scan chains, BIST, boundary scan) compliant with the project\'s DFT architecture (True = DFT-compliant; False = not compliant or not applicable). Affects ATPG test coverage and ATE test time.']
  eda_tool_compatibility varchar [note: 'Comma-separated list of EDA tools and versions with which this IP core has been validated (e.g., \'Cadence Virtuoso 23.1, Synopsys DC 2023.03, Cadence Innovus 22.1\'). Ensures design teams select compatible tool versions for integration.']
  export_control_classification varchar [note: 'Export control classification of the IP core under US Export Administration Regulations (EAR) or International Traffic in Arms Regulations (ITAR). Determines licensing requirements for cross-border IP transfers and design collaboration with foreign nationals. EAR99 = no license required; ECCN codes require BIS license review; ITAR_controlled = State Dept. license required.']
  foundry_compatibility varchar [note: 'Comma-separated list of semiconductor foundries for which this IP core has been qualified and is available (e.g., \'TSMC, Samsung, GlobalFoundries\'). Determines which fabrication facilities can manufacture designs incorporating this IP.']
  function_category varchar [note: 'Functional classification of the IP core indicating its primary design purpose (e.g., CPU, GPU, NPU, SerDes, PHY, memory_controller, analog, RF, security, interconnect, IO). Used for IP portfolio management and design-in selection. [ENUM-REF-CANDIDATE: CPU|GPU|NPU|SerDes|PHY|memory_controller|analog|RF|security|interconnect|IO|other — promote to reference product]']
  functional_description varchar [note: 'Detailed technical description of the IP core\'s functionality, architecture, and key features as documented in the IP datasheet. Provides design engineers with the information needed to evaluate IP suitability for a given SoC design.']
  gate_count varchar [note: 'Equivalent gate count of the IP core representing its logic complexity, expressed in number of 2-input NAND gate equivalents. Used for die area estimation, synthesis resource planning, and complexity benchmarking in Synopsys Design Compiler.']
  gds_available boolean [note: 'Indicates whether a GDSII (Graphic Data System II) physical layout file is available for this IP core (True = GDSII provided; False = not available). GDSII availability is required for hard macro integration and tapeout submission.']
  interface_standard varchar [note: 'Industry interface protocol standards supported by this IP core (e.g., AMBA AXI4, PCIe Gen5, USB 3.2, DDR5, MIPI CSI-2). Ensures interoperability with SoC interconnect fabric and system-level integration. [ENUM-REF-CANDIDATE: AMBA_AXI4|PCIe_Gen5|USB3.2|DDR5|MIPI_CSI2|Ethernet|CAN|I2C|SPI|other — promote to reference product]']
  ip_type varchar [note: 'Classification of the IP core by its delivery form: hard_macro (fixed physical layout, process-specific GDS), soft_ip (synthesizable RTL, process-portable), or firm_ip (partially optimized netlist, semi-portable). Determines integration methodology and EDA tool flow requirements.']
  lef_available boolean [note: 'Indicates whether a Library Exchange Format (LEF) abstract view is available for this IP core (True = LEF provided; False = not available). LEF files are required for place-and-route integration in Cadence Innovus and Synopsys IC Compiler.']
  license_expiry_date date [note: 'Date on which the IP core license agreement expires or must be renewed. Null for perpetual licenses. Critical for license renewal planning and ensuring design projects do not use expired IP licenses.']
  license_fee_usd decimal(18,2) [note: 'One-time or annual license fee paid to the IP vendor in US Dollars (USD). Represents the NRE or access cost component of the IP licensing agreement. Null for open-source or internally developed IP.']
  license_type varchar [note: 'Type of licensing arrangement governing use of this IP core: perpetual (one-time fee, unlimited use), subscription (time-limited access), royalty_bearing (per-unit royalty on shipped products), royalty_free (no per-unit royalty after license fee), open_source (governed by open-source license terms). Drives financial planning and legal compliance.']
  lifecycle_status varchar [note: 'Current lifecycle state of the IP core in the catalog: active (available for new designs), deprecated (supported but not recommended for new designs), obsolete (no longer supported), under_development (not yet released), qualification (in silicon validation). Drives IP selection eligibility and EOL planning.']
  max_frequency_mhz decimal(12,3) [note: 'Maximum achievable operating frequency of the IP core in megahertz (MHz) at the characterized process corner (typical/worst-case) for the target process node. Part of the PPA characterization data used for timing closure planning in Synopsys Design Compiler and PrimeTime.']
  mpw_eligible boolean [note: 'Indicates whether this IP core is eligible for inclusion in Multi-Project Wafer (MPW) shuttle runs for cost-effective silicon validation (True = MPW eligible; False = not eligible, e.g., due to NDA restrictions or hard macro size constraints).']
  nda_required boolean [note: 'Indicates whether a Non-Disclosure Agreement (NDA) must be in place before design teams can access the IP core documentation, RTL source, or GDSII files (True = NDA required; False = no NDA required). Governs IP access control and legal compliance.']
  power_uw decimal(18,6) [note: 'Characterized typical power consumption of the IP core in microwatts (µW) at the nominal operating voltage and frequency for the target process node. Part of the Power-Performance-Area (PPA) characterization data used for SoC power budget analysis.']
  qualification_status varchar [note: 'Current qualification status of the IP core against the target process node and foundry: not_started, in_progress (characterization underway), qualified (passed all qualification criteria), failed (qualification failed, remediation required). Distinct from silicon_proven status.']
  release_date date [note: 'Date on which this version of the IP core was officially released and made available for design-in use in the internal IP library or vendor catalog. Used for version history tracking and design project planning.']
  rohs_compliant boolean [note: 'Indicates whether the IP core and its associated physical implementation materials comply with the EU RoHS Directive restricting hazardous substances (True = RoHS compliant; False = non-compliant or not assessed). Required for products sold in the EU market.']
  royalty_rate_pct decimal(8,4) [note: 'Per-unit royalty rate expressed as a percentage of the net selling price of the end product incorporating this IP core. Applicable only for royalty_bearing license types. Used for royalty accrual and financial reporting in SAP S/4HANA.']
  rtl_language varchar [note: 'Hardware description language used for the RTL source code of the IP core (Verilog, SystemVerilog, VHDL, or mixed). Relevant only for soft IP and firm IP types. Determines EDA tool compatibility and synthesis flow requirements.']
  scan_coverage_pct decimal(5,2) [note: 'Percentage of internal logic nodes covered by scan-based DFT test structures, as reported by ATPG tools. Higher coverage reduces DPPM risk. Null if DFT is not applicable (e.g., analog IP).']
  silicon_proven boolean [note: 'Indicates whether this IP core has been successfully validated in a fabricated silicon device (True = silicon-proven; False = simulation-only or pre-silicon). Silicon-proven status is a critical risk factor in IP selection for production designs.']
  silicon_proven_date date [note: 'Date on which the IP core achieved silicon-proven status through successful tape-out and functional validation in fabricated silicon. Null if not yet silicon-proven.']
  source_type varchar [note: 'Indicates whether the IP core originates from the internal IP development team, a third-party vendor (e.g., ARM, Synopsys DesignWare, Cadence Tensilica), or an open-source library. Determines licensing obligations, support model, and NRE cost applicability.']
  support_tier varchar [note: 'Level of technical support available for this IP core: standard (community/documentation support), premium (dedicated FAE support with SLA), end_of_support (no active support, use at own risk). Influences design-in risk assessment and vendor engagement planning.']
  timing_model_available boolean [note: 'Indicates whether Liberty (.lib) timing models are available for this IP core for static timing analysis (True = Liberty models provided; False = not available). Required for timing closure analysis in Synopsys PrimeTime and Cadence Tempus.']
  updated_timestamp timestamp [note: 'Timestamp when this IP core record was most recently modified in the master catalog (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change tracking, data lineage, and incremental ETL processing in the Databricks Lakehouse.']
  vendor_name varchar [note: 'Name of the third-party IP vendor or licensor (e.g., ARM Holdings, Synopsys, Cadence Design Systems, CEVA). Null for internally developed IP cores. Used for vendor management, license tracking, and procurement.']
  version varchar [note: 'Version identifier of the IP core release following semantic versioning (e.g., 2.1.0, r0p4). Tracks revision history and ensures design projects reference the correct IP release.']

  Note: 'Master catalog of reusable Intellectual Property (IP) cores available for integration into IC designs. Tracks IP type (hard macro, soft IP, firm IP), function category (CPU, GPU, NPU, SerDes, PHY, memory controller, analog, RF), process node compatibility matrix, PPA characterization data, licensing terms and royalty structure, version history, silicon-proven status, EDA tool compatibility, and compliance with industry interface standards (AMBA, PCIe, USB). Sourced from internal IP library and third-party vendors (ARM, Synopsys DesignWare, Cadence Tensilica). SSOT for IP core definitions used across design projects.'
}

Table design.pdk {
  pdk_id varchar [pk, note: 'Unique surrogate identifier for the PDK master record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.']
  product_process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Ensures alignment of PDKs with official process‑node definitions for compliance, cost, and yield analysis in engineering reports.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: PDK procurement and NDA management: design teams must track which supplier delivers each PDK version for license compliance, NDA enforcement, and supplier qualification audits. foundry_name is a denor']
  agile_plm_part_number varchar [note: 'Part number assigned to this PDK in Oracle Agile PLM for product data and change management. Used to track PDK-related Engineering Change Orders (ECOs) and Product Change Notifications (PCNs).']
  checksum_sha256 varchar [note: 'SHA-256 cryptographic hash of the PDK distribution archive. Used to verify PDK file integrity after download or transfer, ensuring no corruption or unauthorized modification of foundry-provided design rule files.']
  code varchar [note: 'Externally-known alphanumeric code uniquely identifying this PDK release, as assigned by the foundry or internal PDK management team (e.g., TSMC_N5_PDK_2023Q4). Used as the business-facing identifier in Cadence Virtuoso and Synopsys Design Compiler tool configurations.']
  deprecation_date date [note: 'Date on which this PDK version was deprecated and superseded by a newer release. Designs in progress must migrate to the active version by this date. Null if the PDK is still active.']
  description varchar [note: 'Free-text description of the PDK, including key features, intended use cases, known limitations, and any special design guidelines. Provides context for design engineers selecting the appropriate PDK for a new IC design project.']
  dft_rule_deck_version varchar [note: 'Version of the Design for Testability (DFT) rule deck included in this PDK. DFT rules govern scan chain insertion, ATPG (Automatic Test Pattern Generation) compatibility, and boundary scan requirements for post-fabrication testing.']
  drc_rule_deck_version varchar [note: 'Version identifier of the Design Rule Check (DRC) rule deck included in this PDK. The DRC rule deck enforces foundry-mandated physical design rules to ensure manufacturability. Used in Cadence Innovus and KLA ICOS inspection correlation.']
  eda_tool_compatibility varchar [note: 'Comma-separated list or reference identifier describing the EDA tool versions certified for use with this PDK (e.g., \'Cadence Virtuoso 23.1, Synopsys IC Compiler II 2023.03, Mentor Calibre 2023.1\'). Ensures design teams use validated tool-PDK combinations for tapeout sign-off.']
  export_control_classification varchar [note: 'Export control classification of this PDK under US Export Administration Regulations (EAR) or ITAR. Determines which countries and entities may receive this PDK. Critical for compliance with BIS/EAR and CHIPS Act requirements.']
  file_path varchar [note: 'Canonical file system or object storage path to the PDK installation directory or archive (e.g., \'/pdk/tsmc/n5/v1.3.2\' or \'s3://pdk-repo/tsmc/n5/v1.3.2\'). Used by EDA tool setup scripts to locate PDK assets in Cadence Virtuoso and Synopsys Design Compiler environments.']
  gds_format varchar [note: 'Layout data format supported by this PDK for tapeout submission to the foundry. GDSII (Graphic Data System II) is the legacy industry standard; OASIS is the modern compressed alternative. Determines the final tapeout file format.']
  io_library_name varchar [note: 'Name of the I/O pad cell library included in this PDK, providing ESD-protected interface cells for chip-to-package signal routing. Required for full-chip physical design and package co-design.']
  ip_library_version varchar [note: 'Version of the foundry-provided hard IP library (e.g., PLLs, SerDes, PHYs) bundled with this PDK. IP cores are pre-characterized and validated for the specific process node.']
  layer_stack_definition varchar [note: 'Identifier or reference name for the metal layer stack definition included in this PDK, specifying the number of metal layers, dielectric materials, and interconnect hierarchy (FEOL/MOL/BEOL). Governs routing resources available to physical design tools.']
  license_type varchar [note: 'Type of licensing agreement under which this PDK is distributed to design teams. \'foundry_standard\' = included with foundry engagement; \'nre_included\' = bundled with NRE (Non-Recurring Engineering) agreement; \'subscription\' = annual license fee; \'evaluation\' = time-limited trial.']
  lithography_type varchar [note: 'Primary lithography technology used in this process node as reflected in the PDK design rules. EUV (Extreme Ultraviolet) is used for leading-edge nodes (≤7nm); DUV (Deep Ultraviolet) with multi-patterning for older nodes. Impacts mask cost and design rule complexity.']
  lvs_rule_deck_version varchar [note: 'Version identifier of the Layout Versus Schematic (LVS) rule deck included in this PDK. LVS verifies that the physical layout matches the circuit schematic. Mandatory for tapeout sign-off in Cadence Virtuoso flows.']
  max_supply_voltage_v decimal(6,4) [note: 'Maximum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Exceeding this value risks device reliability and oxide breakdown.']
  memory_compiler_supported boolean [note: 'Indicates whether this PDK includes or is compatible with a foundry-provided memory compiler for generating SRAM, ROM, or register file macros. True = memory compiler available; False = memory macros must be sourced separately.']
  metal_layer_count varchar [note: 'Total number of metal interconnect layers defined in the PDK layer stack. Determines routing density, signal integrity characteristics, and manufacturing cost. Typical values range from 6 to 20+ for advanced nodes.']
  min_supply_voltage_v decimal(6,4) [note: 'Minimum operating supply voltage (Vdd) in volts supported by this process node as defined in the PDK. Used for low-power design optimization and multi-voltage domain planning.']
  mpw_shuttle_supported boolean [note: 'Indicates whether this PDK version is qualified and approved for use in Multi-Project Wafer (MPW) shuttle runs, enabling cost-shared prototyping across multiple design projects on a single wafer.']
  name varchar [note: 'Human-readable descriptive name of the PDK (e.g., \'TSMC 5nm N5 PDK v1.3\'). Used in EDA tool selection menus, design review documentation, and PLM records in Siemens Teamcenter.']
  nda_required boolean [note: 'Indicates whether access to this PDK requires a signed Non-Disclosure Agreement (NDA) with the foundry. True = NDA mandatory before distribution; False = PDK is available under standard licensing terms. Governs access control in Siemens Teamcenter PLM.']
  nominal_supply_voltage_v decimal(6,4) [note: 'Nominal (typical) operating supply voltage in volts for this process node as specified in the PDK. Used as the reference voltage for standard timing and power characterization.']
  opc_rule_deck_version varchar [note: 'Version of the Optical Proximity Correction (OPC) rule deck included in this PDK. OPC rules compensate for photolithographic distortions during mask writing, critical for sub-10nm nodes using EUV or DUV lithography.']
  operating_temp_max_c decimal(6,2) [note: 'Maximum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the hot corner for timing sign-off and reliability qualification.']
  operating_temp_min_c decimal(6,2) [note: 'Minimum junction operating temperature in degrees Celsius for which the PDK device models and timing libraries are characterized. Defines the cold corner for timing sign-off.']
  pdk_status varchar [note: 'Current lifecycle state of the PDK version. \'draft\' = under development; \'active\' = qualified and approved for production design starts; \'deprecated\' = superseded by newer version but still supported; \'retired\' = no longer supported; \'restricted\' = limited access pending NDA or export control review.']
  process_corner_set varchar [note: 'Comma-separated list of process corners (PVT corners) defined in this PDK for timing and power sign-off (e.g., \'TT, FF, SS, FS, SF\'). Each corner represents a combination of process, voltage, and temperature variation for worst/best-case analysis in Synopsys PrimeTime.']
  process_family varchar [note: 'Foundry-specific process family or platform name within a node (e.g., \'N5\', \'N5P\', \'N4\', \'SF3E\'). Distinguishes performance-optimized, power-optimized, or cost-optimized variants within the same technology node.']
  qualification_date date [note: 'Date on which the PDK version was internally qualified and approved for production IC design starts at Semiconductors. Distinct from the foundry release date; reflects internal DRC/LVS and SPICE model validation completion.']
  release_date date [note: 'Date on which this PDK version was officially released by the foundry and made available for design use. Used for design start eligibility checks and tapeout qualification timelines.']
  release_notes_url varchar [note: 'URL pointing to the official PDK release notes document, detailing changes, bug fixes, and known issues relative to the previous version. Essential for design teams evaluating PDK upgrade impact on in-progress designs.']
  spice_model_set varchar [note: 'Identifier or name of the SPICE (Simulation Program with Integrated Circuit Emphasis) device model set bundled with this PDK (e.g., \'BSIM-CMG v110\', \'PSP v103\'). Used by Synopsys PrimeTime and Cadence Virtuoso for circuit simulation and timing analysis.']
  spice_model_version varchar [note: 'Version identifier of the SPICE model set included in this PDK. Critical for simulation reproducibility and sign-off correlation between design teams and the foundry.']
  std_cell_library_name varchar [note: 'Name of the primary standard cell library bundled with this PDK (e.g., \'SC9MC_HD\', \'SC7P5T_HD\'). Standard cell libraries provide pre-characterized logic gates used in RTL-to-GDS synthesis flows in Synopsys Design Compiler.']
  std_cell_library_version varchar [note: 'Version of the standard cell library included in this PDK release. Version changes may affect timing, power, and area (PPA) characteristics of synthesized designs.']
  teamcenter_item_reference varchar [note: 'Item identifier assigned to this PDK record in Siemens Teamcenter PLM, enabling traceability between the PDK master record and associated design projects, change orders, and release workflows.']
  transistor_architecture varchar [note: 'Transistor architecture type used in this process node (e.g., FinFET, Gate-All-Around (GAA), Planar, FDSOI). Determines device modeling approach, SPICE model complexity, and applicable EDA tool flows.']
  version varchar [note: 'Version string of the PDK release following semantic versioning conventions (e.g., \'1.3.2\', \'2.0.0-beta\'). Critical for design reproducibility, tapeout qualification, and EDA tool compatibility validation. Managed in Oracle Agile PLM and Siemens Teamcenter.']

  Note: 'Process Design Kit (PDK) master record defining the foundry-specific design rules, device models, standard cell libraries, and technology files required for IC design at a given process node. Captures PDK version, foundry name, process node (e.g., 3nm, 5nm, 7nm), SPICE model sets, DRC/LVS rule decks, layer stack definitions, and EDA tool compatibility matrix. SSOT for PDK versioning used in Cadence Virtuoso and Synopsys Design Compiler flows.'
}

Table design.rtl_specification {
  rtl_specification_id varchar [pk, note: 'Unique surrogate identifier for the RTL specification record in the lakehouse. Primary key for this data product.']
  primary_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — RTL specifications are created within the context of an IC design project. This is a mandatory parent-child relationship required for design hierarchy navigation.']
  product_spec_id varchar [note: 'Foreign key linking to product.product_spec. Business justification: Supports validation and regulatory compliance: ties each RTL spec to the authoritative product specification used in safety and performance certification.']
  to_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — Every RTL specification belongs to exactly one IC design project. This is the fundamental parent-child relationship for design artifacts. Engineers navigate from project to RTL modules daily.']
  ams_behavioral_model_ref varchar [note: 'Reference identifier or path to the Verilog-AMS or VHDL-AMS behavioral model associated with this analog/mixed-signal RTL block. Populated only when is_analog_mixed_signal is True. Links to the Cadence Virtuoso schematic source.']
  cdc_annotation_status varchar [note: 'Completion status of Clock Domain Crossing (CDC) boundary annotations within the RTL specification. CDC annotation is mandatory for multi-clock designs prior to synthesis sign-off to prevent metastability failures.']
  clock_domain_count varchar [note: 'Number of distinct clock domains defined within this RTL design block. Drives Clock Domain Crossing (CDC) analysis requirements and verification complexity estimation.']
  commit_hash varchar [note: 'The specific commit hash or changelist number in the revision control system corresponding to the approved version of this RTL specification. Provides immutable provenance linkage to the exact source snapshot.']
  created_timestamp timestamp [note: 'Timestamp when this RTL specification record was first created in the system of record. Provides audit trail for design provenance and compliance with ISO 9001 design record retention requirements.']
  design_block_name varchar [note: 'Human-readable name of the RTL design block, IP subsystem, or full-chip entity described by this specification (e.g., \'USB3_PHY_Controller\', \'DDR5_Memory_Interface\', \'Top_Level_SoC\'). Serves as the primary identity label for the design artifact.']
  design_block_type varchar [note: 'Classification of the RTL design block scope. Determines applicable design rules, verification methodology, and integration requirements. \'ip_core\' blocks are subject to IP licensing tracking; \'fpga_target\' blocks require device-specific synthesis constraints. [ENUM-REF-CANDIDATE: full_chip|subsystem|ip_core|interface_block|analog_mixed_signal|fpga_target — promote to reference product]']
  design_intent_description varchar [note: 'Narrative description of the functional design intent, architectural decisions, and key requirements captured in this RTL specification. Provides context for design reviews, IP reuse assessments, and new engineer onboarding.']
  dfm_rule_set_version varchar [note: 'Version identifier of the Design for Manufacturability (DFM) rule set applied to this RTL specification. DFM rules ensure the design can be reliably manufactured at the target process node with acceptable yield.']
  dft_strategy varchar [note: 'Design for Testability (DFT) methodology applied to this RTL block. Defines the test insertion approach used to enable Automatic Test Pattern Generation (ATPG) and silicon test coverage on Automatic Test Equipment (ATE).']
  ear_eccn_code varchar [note: 'Export Control Classification Number (ECCN) assigned to this RTL specification under the Export Administration Regulations (EAR). Determines export licensing requirements for cross-border transfer of design data.']
  fpga_device_family varchar [note: 'Target FPGA device family for synthesis and implementation (e.g., \'Xilinx Ultrascale+\', \'Intel Agilex\', \'Lattice ECP5\'). Populated only when is_fpga_target is True. Determines device-specific synthesis constraints and IP primitives.']
  functional_coverage_target_pct decimal(5,2) [note: 'Target functional coverage percentage defined in the verification plan for this RTL specification. Expressed as a percentage (0.00–100.00). Used to gate simulation sign-off and tapeout readiness reviews.']
  hdl_language varchar [note: 'Primary Hardware Description Language used to author the RTL source code for this design block. Determines EDA tool compatibility, lint rule sets, and synthesis flow configuration in Synopsys Design Compiler.']
  interface_protocols varchar [note: 'Comma-separated list of hardware interface protocols implemented in this RTL block (e.g., \'AXI4, AHB5, APB3, Wishbone, PCIe, USB3\'). Used for integration compatibility checks and IP reuse assessments.']
  ip_reuse_source varchar [note: 'Origin classification of the IP content in this RTL specification. \'licensed_third_party\' requires IP license compliance tracking; \'open_source\' requires license obligation management (e.g., GPL, Apache); \'internal\' indicates proprietary reuse. Classified confidential due to IP licensing sensitivity.']
  is_analog_mixed_signal boolean [note: 'Indicates whether this RTL specification includes analog or mixed-signal content requiring behavioral model references (Verilog-AMS, VHDL-AMS) and linkage to transistor-level schematic source in Cadence Virtuoso.']
  is_fpga_target boolean [note: 'Indicates whether this RTL specification is intended for FPGA implementation rather than ASIC tapeout. When True, synthesis constraints, pin assignments, and target device family fields are applicable.']
  itar_controlled boolean [note: 'Indicates whether this RTL specification is subject to International Traffic in Arms Regulations (ITAR) export controls. When True, access must be restricted to authorized US persons and export license requirements apply.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent modification to this RTL specification record. Used for change tracking, incremental data pipeline processing, and audit compliance.']
  lint_compliance_status varchar [note: 'Status of RTL lint rule compliance checks for this specification. Lint tools (e.g., Synopsys SpyGlass, Cadence HAL) enforce coding guidelines and detect potential design errors. \'clean\' is required before synthesis sign-off.']
  logic_gate_count_estimate varchar [note: 'Estimated number of equivalent logic gates for this RTL design block, derived from synthesis estimation runs in Synopsys Design Compiler. Used for area budgeting, floorplanning, and Power-Performance-Area (PPA) target setting.']
  nre_cost_usd decimal(18,2) [note: 'Estimated Non-Recurring Engineering (NRE) cost in US dollars associated with developing this RTL specification. Used for project budgeting, customer design-in pricing, and financial reporting in SAP S/4HANA CO module.']
  obsolescence_date date [note: 'Date on which this RTL specification was marked obsolete, typically superseded by a newer version or upon product End of Life (EOL). Supports Product Change Notification (PCN) and Last Time Buy (LTB) processes.']
  pdk_version varchar [note: 'Version identifier of the Process Design Kit (PDK) library set used for this RTL specification. The PDK defines technology-specific design rules, device models, and standard cell libraries. Critical for reproducibility and tapeout readiness.']
  power_domain_count varchar [note: 'Number of distinct power domains defined in the Unified Power Format (UPF) or Common Power Format (CPF) specification for this RTL block. Drives low-power verification and power intent analysis.']
  power_intent_format varchar [note: 'Standard format used to specify power intent for this RTL design block. UPF (IEEE 1801) and CPF (Cadence) are the two industry standards. \'none\' indicates no multi-voltage power management is implemented.']
  repository_path varchar [note: 'Full path or URL to the revision control repository location where the RTL source files for this specification are stored (e.g., Git remote URL or Perforce depot path). Classified confidential as it reveals internal IP infrastructure.']
  reset_strategy varchar [note: 'Reset architecture employed in this RTL design block. Defines whether resets are synchronous, asynchronous, or mixed, which impacts timing closure, DFT scan insertion, and silicon reliability.']
  revision_control_system varchar [note: 'Version control system in which the RTL source files for this specification are managed. Enables provenance tracking and audit trail for design changes.']
  specification_approved_date date [note: 'Date on which this RTL specification was formally approved through the PLM design review process. Marks the effective start of the specification as a binding design baseline. Required for ISO 9001 and IATF 16949 design record compliance.']
  specification_number varchar [note: 'Externally-known, human-readable unique identifier for the RTL specification artifact as tracked in Siemens Teamcenter PLM and revision control systems (Git, Perforce). Used for cross-system traceability and design review references.']
  specification_released_date date [note: 'Date on which this RTL specification was released for downstream use (synthesis, physical design, verification). Distinct from approval date; release may follow approval after additional sign-off steps.']
  specification_status varchar [note: 'Current lifecycle state of the RTL specification artifact within the PLM workflow. Controls downstream design activities: \'draft\' allows edits; \'approved\' gates synthesis; \'released\' permits tapeout submission; \'obsolete\' marks superseded versions.']
  tapeout_target_date date [note: 'Planned date for final GDS/GDSII design submission (tapeout) to the fabrication facility. Tapeout is the milestone at which the RTL design is frozen and submitted for mask generation. Drives program schedule and supply chain commitments.']
  target_clock_frequency_mhz decimal(10,3) [note: 'Target operating clock frequency in megahertz (MHz) for the primary clock domain of this RTL design block. Drives timing constraint definition in Synopsys PrimeTime and synthesis optimization targets.']
  target_process_node varchar [note: 'Semiconductor fabrication process node for which this RTL design is targeted (e.g., \'5nm\', \'7nm\', \'28nm\', \'180nm\'). Determines applicable PDK, design rules, and standard cell libraries used in synthesis and physical design.']
  teamcenter_item_reference varchar [note: 'Native item identifier assigned to this RTL specification within Siemens Teamcenter PLM. Enables direct cross-system traceability between the lakehouse silver layer record and the authoritative PLM system of record.']
  version_label varchar [note: 'Semantic version label of this RTL specification revision (e.g., \'v1.0\', \'v2.3.1\'). Tracks design evolution through revision control (Git, Perforce) and PLM change management. Incremented on each approved change.']

  Note: 'Register Transfer Level (RTL) design specification and source record capturing the functional hardware description of a design block, IP subsystem, or full chip. Tracks RTL module hierarchy, HDL language (VHDL, Verilog, SystemVerilog, Chisel), design intent documentation, clock domain definitions and CDC boundary annotations, reset strategy, interface protocols (AXI, AHB, APB, Wishbone), power domain definitions (UPF/CPF), functional coverage model targets, lint rule compliance status, and linkage to the parent IC design project. For analog/mixed-signal blocks, captures behavioral model references (Verilog-AMS, VHDL-AMS) and links to transistor-level schematic source in Cadence Virtuoso where applicable. For FPGA targets, captures synthesis constraints, pin assignments, and target device family. Managed as a versioned artifact in revision control (Git, Perforce) with provenance tracking through Siemens Teamcenter PLM.'
}

Table design.netlist {
  netlist_id varchar [pk, note: 'Unique surrogate identifier for the synthesized netlist artifact record in the design domain. Primary key for this data product.']
  ip_core_id varchar [note: 'Reference to an IP (Intellectual Property) core incorporated in this netlist, if applicable. Links to licensed third-party or internally developed IP blocks (e.g., PCIe PHY, USB controller, ARM Cortex core) for IP usage tracking and license compliance.']
  primary_netlist_ic_design_project_id varchar [note: 'Reference to the parent IC design project or block to which this netlist belongs. Links the netlist artifact to its design hierarchy context within the PLM system.']
  to_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — Netlist belongs to a design project. Required for project-level artifact tracking and version management.']
  to_pdk_id varchar [note: 'FK to design.pdk.pdk_id — Synthesis uses PDK standard cell libraries. The netlist must reference which PDK version was used for synthesis.']
  to_rtl_specification_id varchar [note: 'FK to design.rtl_specification.rtl_specification_id — A netlist is synthesized from an RTL specification. This is the core design flow linkage (RTL -> synthesis -> netlist) required for design provenance.']
  approval_timestamp timestamp [note: 'Date and time when the netlist was formally approved for promotion to the next design stage. Supports design review audit trails and milestone tracking for tapeout schedule management.']
  area_estimate_um2 decimal(16,4) [note: 'Estimated silicon area of the synthesized netlist in square micrometers (µm²) as reported by the synthesis tool. Represents the combinational and sequential cell area before physical placement. A key PPA (Power-Performance-Area) metric.']
  cell_instance_count varchar [note: 'Total number of standard cell instances instantiated in the synthesized netlist. Distinct from gate count — counts actual cell placements including sequential elements (flip-flops, latches) and combinational cells.']
  cell_library_name varchar [note: 'Name of the standard cell library used during logic synthesis (e.g., \'TSMC_N5_SC_HD_v1.2\'). Defines the set of logic gates, flip-flops, and combinational cells mapped during synthesis from the PDK.']
  cell_library_version varchar [note: 'Version identifier of the standard cell library used during synthesis. Critical for design reproducibility and provenance — different library versions may have different timing, power, or area characteristics.']
  checksum_sha256 varchar [note: 'SHA-256 cryptographic hash of the netlist file content. Used to verify file integrity, detect unauthorized modifications, and ensure design provenance authenticity across EDA tool handoffs and IP delivery.']
  combinational_cell_count varchar [note: 'Number of combinational logic cells (AND, OR, MUX, inverters, etc.) in the synthesized netlist. Used for area estimation and logic optimization analysis during PPA (Power-Performance-Area) evaluation.']
  constraints_file_ref varchar [note: 'File path or repository reference to the Synopsys Design Constraints (SDC) file used during synthesis. The SDC file specifies timing constraints, clock definitions, input/output delays, and false paths that govern synthesis optimization.']
  created_timestamp timestamp [note: 'Date and time when this netlist record was first created in the data platform. Supports audit trail, data lineage, and Silver layer ingestion tracking for the design domain.']
  critical_path_delay_ps decimal(12,3) [note: 'Propagation delay of the longest (critical) timing path in the synthesized netlist, measured in picoseconds (ps). Determines the maximum achievable operating frequency and is a key PPA (Power-Performance-Area) metric for design optimization.']
  design_block_name varchar [note: 'Name of the IC design block or module represented by this netlist (e.g., \'ALU\', \'memory_controller\', \'pcie_phy\'). Corresponds to the top-level module name in the RTL hierarchy submitted to the synthesis tool.']
  design_iteration varchar [note: 'Sequential iteration counter for synthesis runs on the same design block. Increments with each new synthesis attempt, enabling tracking of design convergence progress and comparison of PPA metrics across iterations.']
  dfm_rule_check_status varchar [note: 'Status of Design for Manufacturability (DFM) rule checks applied to this netlist. DFM rules ensure the synthesized design is compatible with the target fabrication process constraints to maximize yield.']
  dft_scan_coverage_pct decimal(5,2) [note: 'Percentage of sequential elements covered by DFT (Design for Testability) scan chains in the synthesized netlist. Higher coverage improves defect detection during Automatic Test Equipment (ATE) testing. Target is typically ≥95% for production designs.']
  dynamic_power_mw decimal(12,4) [note: 'Estimated dynamic (switching) power consumption in milliwatts (mW) from the synthesis power analysis report. Represents power consumed by logic transitions and is activity-dependent. Used for thermal and battery life analysis.']
  file_path varchar [note: 'Repository or file system path to the synthesized netlist artifact file (e.g., \'/design/proj/cpu_core/syn/v3/cpu_core_top.v\'). Enables EDA tool flows and downstream physical design steps to locate and consume the netlist.']
  format varchar [note: 'File format of the synthesized netlist artifact (e.g., Verilog gate-level netlist, VHDL, SPICE, EDIF, Liberty). Determines compatibility with downstream EDA tools for physical design, simulation, and verification flows.']
  gate_count varchar [note: 'Total number of logic gates (expressed in equivalent 2-input NAND gate equivalents) in the synthesized netlist. A primary measure of design complexity and silicon area consumption used for Power-Performance-Area (PPA) analysis.']
  leakage_power_uw decimal(12,4) [note: 'Estimated static leakage power consumption in microwatts (µW) from the synthesis power analysis report. Represents power consumed when the circuit is idle due to sub-threshold leakage currents. Critical for low-power and IoT product designs.']
  name varchar [note: 'Human-readable name assigned to the netlist artifact, typically reflecting the design block name and synthesis iteration (e.g., \'cpu_core_top_postsyn_v3\'). Used for identification in EDA tool flows and design review sessions.']
  netlist_type varchar [note: 'Classification of the netlist stage in the IC design flow: pre_synthesis (RTL-level functional netlist before synthesis), post_synthesis (gate-level netlist after logic synthesis by Synopsys Design Compiler), or post_layout (netlist annotated with parasitic extraction data after physical design in Cadence Innovus).']
  process_node_nm varchar [note: 'Target semiconductor fabrication process node in nanometers (nm) for which this netlist was synthesized (e.g., \'5nm\', \'7nm\', \'28nm\'). Determines the standard cell library and timing models used during synthesis.']
  sequential_cell_count varchar [note: 'Number of sequential logic cells (flip-flops, latches, registers) in the synthesized netlist. Used for Design for Testability (DFT) scan chain planning and power analysis of dynamic switching activity.']
  synthesis_run_timestamp timestamp [note: 'Date and time when the logic synthesis run that produced this netlist was executed. Provides the principal business event timestamp for design provenance, audit trails, and design iteration tracking.']
  synthesis_runtime_minutes decimal(10,2) [note: 'Wall-clock runtime of the synthesis job in minutes. Used for EDA compute resource planning, license utilization tracking, and identifying synthesis runs that exceed expected runtimes due to design complexity or tool issues.']
  synthesis_status varchar [note: 'Current lifecycle status of the netlist artifact within the design flow. Tracks progression from initial synthesis run through completion, failure, archival, or supersession by a newer version.']
  tapeout_target_date date [note: 'Planned tapeout date for the IC design project associated with this netlist. Used to assess synthesis schedule adherence and Time-to-Market (TTM) risk. Tapeout is the final design submission milestone for manufacturing.']
  target_clock_freq_mhz decimal(10,3) [note: 'Target operating clock frequency in megahertz (MHz) specified in the synthesis constraints (SDC). Defines the timing closure goal for the synthesis run and is used to evaluate whether timing slack objectives are met.']
  timing_closure_achieved boolean [note: 'Indicates whether timing closure has been achieved for this netlist (True = all timing paths meet constraints with non-negative slack; False = timing violations remain). A prerequisite gate for advancing to physical design and tapeout.']
  timing_slack_hold_ps decimal(12,3) [note: 'Worst-case hold timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative hold slack indicates a hold violation requiring buffer insertion or path adjustment.']
  timing_slack_setup_ps decimal(12,3) [note: 'Worst-case setup timing slack in picoseconds (ps) across all timing paths in the synthesized netlist, as reported by Synopsys PrimeTime. Negative slack indicates a timing violation (setup violation) that must be resolved before tapeout. Critical PPA metric.']
  timing_violation_count varchar [note: 'Total number of timing path violations (setup and hold combined) reported in the synthesis timing analysis. A value of zero indicates timing closure has been achieved. Used to track synthesis convergence progress across iterations.']
  total_power_estimate_mw decimal(12,4) [note: 'Estimated total power consumption of the synthesized netlist in milliwatts (mW), as reported by the synthesis tool. Includes dynamic switching power and static leakage power. A key PPA (Power-Performance-Area) metric for product qualification.']
  updated_timestamp timestamp [note: 'Date and time when this netlist record was last modified in the data platform. Used for incremental data pipeline processing, change detection, and audit trail maintenance in the Databricks Silver layer.']
  version varchar [note: 'Version identifier for the netlist artifact following semantic versioning conventions (e.g., \'v1.0\', \'v2.3.1\'). Tracks netlist iterations across design synthesis runs to support design provenance and change management.']

  Note: 'Synthesized netlist artifact produced by logic synthesis tools (Synopsys Design Compiler) from RTL. Captures netlist type (pre-synthesis, post-synthesis, post-layout), gate count, cell library version, synthesis constraints file reference, timing slack summary, power estimate, and linkage to the RTL specification and PDK version used. Tracks netlist versions across design iterations for design provenance.'
}

Table design.timing_analysis_run {
  timing_analysis_run_id varchar [pk, note: 'Unique surrogate identifier for each Static Timing Analysis (STA) run record in the Databricks Silver Layer. Primary key for the timing_analysis_run data product.']
  netlist_id varchar [note: 'FK to design.netlist.netlist_id — STA runs analyze timing on a specific netlist version. This linkage is required for timing closure tracking.']
  pdk_id varchar [note: 'Foreign key linking to design.pdk. Business justification: A timing analysis run (STA via Synopsys PrimeTime) is fundamentally tied to a specific PDK version — the liberty libraries, process corners (PVT), SPICE models, and derating factors used in the analys']
  physical_layout_id varchar [note: 'FK to design.physical_layout.physical_layout_id — Post-route STA runs reference a specific physical layout version for parasitic-annotated timing. Critical for post-layout timing closure.']
  primary_timing_ic_design_project_id varchar [note: 'Reference to the IC design or SoC/ASIC design entity for which this STA run was executed. Links the timing analysis result to the parent design record managed in Cadence Virtuoso/Innovus or Siemens Teamcenter PLM.']
  product_spec_id varchar [note: 'Foreign key linking to product.product_spec. Business justification: Timing signoff runs validate that achieved frequency and slack meet product spec targets. Timing closure reports are filed against the product spec; a timing engineer expects this link for signoff doc']
  timing_baseline_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — Timing runs belong to a project for aggregated timing closure tracking across design iterations.']
  analysis_mode varchar [note: 'Timing analysis mode applied in this STA run. Setup checks for maximum path delay violations; hold checks for minimum path delay violations; OCV (On-Chip Variation), AOCV (Advanced OCV), and POCV (Parametric OCV) modes apply statistical derating for silicon variation modeling. Determines which slack metrics are applicable.']
  clock_domain_count varchar [note: 'Number of distinct clock domains analyzed in this STA run. Multi-clock domain designs require careful CDC (Clock Domain Crossing) analysis. Relevant for SoC and ASIC designs with multiple functional blocks operating at different frequencies.']
  clock_frequency_target_mhz decimal(10,3) [note: 'Target clock frequency in megahertz (MHz) specified for this STA run, representing the design\'s PPA (Power Performance Area) performance goal. Used to evaluate whether timing closure is achieved at the required operating frequency.']
  clock_period_target_ps decimal(12,4) [note: 'Target clock period in picoseconds (ps) corresponding to the clock frequency target. Directly used by Synopsys PrimeTime as the timing constraint for setup/hold analysis. Derived from clock_frequency_target_mhz but stored independently as the authoritative STA constraint value.']
  created_timestamp timestamp [note: 'Date and time when this STA run record was first created in the Databricks Silver Layer data product. Represents the audit trail creation timestamp for data lineage and compliance purposes.']
  critical_path_count varchar [note: 'Number of critical timing paths (paths with negative or near-zero slack) identified in this STA run. Used by design engineers to prioritize optimization efforts in Synopsys Design Compiler or Cadence Innovus for timing closure.']
  derating_factor_hold decimal(6,4) [note: 'On-Chip Variation (OCV) derating factor applied to hold timing paths in this STA run. Represents the percentage by which cell delays are derated for hold analysis. Typically different from setup derating to model the asymmetric nature of process variation effects on min/max paths.']
  derating_factor_setup decimal(6,4) [note: 'On-Chip Variation (OCV) derating factor applied to setup timing paths in this STA run. Represents the percentage by which cell delays are derated to model process variation (e.g., 0.95 = 5% derating). Used in OCV/AOCV/POCV analysis modes for silicon-accurate sign-off.']
  design_stage varchar [note: 'Physical design stage at which this STA run was performed, reflecting the state of the netlist and parasitics. Values: pre_synthesis (RTL-level), post_synthesis (gate-level), pre_cts (before Clock Tree Synthesis), post_cts (after CTS), post_route (after detailed routing), signoff (final tapeout signoff). Drives interpretation of WNS/TNS results.']
  design_version varchar [note: 'Version or revision label of the IC design netlist or GDS/GDSII database at the time this STA run was executed (e.g., \'v2.3.1\', \'tapeout_rc2\'). Enables timing closure tracking across design iterations and correlates with PLM change records.']
  hold_violation_count varchar [note: 'Total number of hold timing violations (negative hold slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full hold timing closure. Critical for designs with multi-cycle paths, clock domain crossings, and post-CTS analysis.']
  is_multi_corner_run boolean [note: 'Indicates whether this STA run covers multiple PVT corners simultaneously (True) or a single corner (False). Multi-corner runs are used for comprehensive sign-off coverage across all operating conditions required by the PDK and target application specifications.']
  is_signoff_run boolean [note: 'Indicates whether this STA run is designated as an official tapeout signoff run (True) or an intermediate/exploratory analysis run (False). Signoff runs are subject to formal design review, PLM change control, and foundry submission requirements.']
  liberty_library_version varchar [note: 'Version of the Liberty (.lib) timing library files used in this STA run. Liberty libraries contain cell timing models, power models, and operating condition data from the PDK. Library version directly affects timing analysis accuracy and sign-off validity.']
  max_capacitance_violation_count varchar [note: 'Number of maximum capacitance violations reported in this STA run. Capacitance violations indicate nets with excessive load that degrade timing and signal integrity. Must be resolved through buffer insertion or net splitting before tapeout.']
  max_transition_violation_count varchar [note: 'Number of maximum transition time violations reported in this STA run. Transition violations indicate signal edges that are too slow, potentially causing functional failures or increased power consumption. Must be resolved before tapeout signoff per PDK design rules.']
  primetime_version varchar [note: 'Version of Synopsys PrimeTime used to execute this STA run (e.g., \'PrimeTime 2023.12-SP3\'). Critical for result reproducibility, audit trails, and identifying version-specific timing model differences that may affect sign-off validity.']
  process_node_nm varchar [note: 'Semiconductor process technology node in nanometers at which the design is implemented (e.g., \'5nm\', \'7nm\', \'28nm\'). Determines PDK library characteristics, timing model accuracy, and applicable EUV/DUV lithography constraints relevant to STA sign-off.']
  pvt_corner varchar [note: 'Operating corner (Process-Voltage-Temperature) under which this STA run was performed (e.g., \'ss_0p72v_125c\' for slow-slow worst-case, \'ff_1p08v_m40c\' for fast-fast best-case). Defined by the PDK (Process Design Kit) and critical for sign-off coverage across all operating conditions.']
  review_timestamp timestamp [note: 'Date and time when the STA run results were formally reviewed and approved by the responsible design engineer or timing closure lead. Null if the run has not yet been reviewed. Required for tapeout sign-off audit trail.']
  reviewed_by varchar [note: 'Username or employee identifier of the senior design engineer or timing closure lead who reviewed and approved the results of this STA run. Required for signoff runs as part of the formal design review process before tapeout submission.']
  run_completion_timestamp timestamp [note: 'Date and time when this Static Timing Analysis run completed execution in Synopsys PrimeTime. Used to calculate run duration and assess EDA compute resource utilization. Null if the run is still in progress or was aborted.']
  run_duration_seconds varchar [note: 'Wall-clock duration of this STA run in seconds, from job submission to completion. Used for EDA compute resource planning, license utilization tracking, and identifying unusually long runs that may indicate tool or design issues.']
  run_identifier varchar [note: 'Externally-known alphanumeric run identifier assigned by the EDA tool flow or MES integration (e.g., \'PT-RUN-20240315-0042\'). Used for cross-referencing with Synopsys PrimeTime job logs, Cadence Innovus signoff reports, and Siemens Teamcenter PLM design records.']
  run_iteration varchar [note: 'Sequential iteration number of this STA run within the current design stage and PVT corner. Enables tracking of timing closure convergence across multiple optimization-analysis cycles (e.g., iteration 1 through N until timing closure is achieved).']
  run_name varchar [note: 'Human-readable name or label assigned to this Static Timing Analysis run, typically encoding the design name, corner, and iteration (e.g., \'soc_top_ss_0p72v_125c_postroute_iter3\'). Used for identification in Synopsys PrimeTime run logs and design review meetings.']
  run_notes varchar [note: 'Free-text notes or comments entered by the design engineer describing the purpose, context, or key findings of this STA run (e.g., \'Post-ECO run after fixing 3 critical paths in clock tree\', \'Baseline run for tapeout corner coverage\'). Supports design review and knowledge transfer.']
  run_status varchar [note: 'Execution lifecycle status of this STA run job in the EDA tool flow. \'submitted\' indicates the job is queued, \'running\' indicates active execution, \'completed\' indicates successful completion, \'failed\' indicates tool error or license failure, \'aborted\' indicates user-cancelled run. Distinct from timing_closure_status which reflects the timing result.']
  run_timestamp timestamp [note: 'Date and time when this Static Timing Analysis run was initiated in Synopsys PrimeTime. Represents the principal business event timestamp for this record. Used for tracking timing closure progress over time and correlating with design iteration milestones.']
  sdc_constraints_version varchar [note: 'Version or identifier of the Synopsys Design Constraints (SDC) file used in this STA run. SDC files define clock definitions, input/output delays, and timing exceptions. Versioning ensures traceability of constraint changes across design iterations.']
  setup_violation_count varchar [note: 'Total number of setup timing violations (negative setup slack endpoints) reported by Synopsys PrimeTime in this STA run. A value of zero indicates full setup timing closure. Tracked across iterations to measure convergence progress toward tapeout readiness.']
  spef_version varchar [note: 'Version or identifier of the SPEF (Standard Parasitic Exchange Format) file used for parasitic extraction in this STA run. SPEF files contain RC parasitics from the routed layout and directly impact timing accuracy. Null for pre-route analysis stages.']
  supply_voltage_v decimal(8,4) [note: 'Nominal supply voltage in volts (V) applied for this STA run\'s PVT corner. Defined by the PDK operating conditions and UPF (Unified Power Format) power intent. Directly impacts cell delay models and timing analysis results.']
  temperature_c decimal(7,2) [note: 'Operating temperature in degrees Celsius (°C) for this STA run\'s PVT corner. Temperature affects transistor characteristics and cell delays. Typical corners range from -40°C (automotive cold) to 125°C (worst-case hot). Defined by the PDK and target application requirements.']
  timing_closure_status varchar [note: 'Overall timing closure pass/fail status for this STA run. \'pass\' indicates all setup and hold violations are resolved and the design meets timing at the specified PVT corner and clock frequency. \'waived\' indicates known violations accepted with engineering sign-off. \'pending_review\' indicates results awaiting design team review. Primary KPI for tapeout readiness.']
  total_hold_negative_slack_ps decimal(16,4) [note: 'Total Hold Negative Slack (THNS) in picoseconds — the sum of all negative hold slack values across all violating hold endpoints in this STA run. Complements TNS (setup) to provide a complete picture of hold timing closure status.']
  total_negative_slack_ps decimal(16,4) [note: 'Total Negative Slack (TNS) in picoseconds — the sum of all negative slack values across all violating timing endpoints in this STA run. Indicates the overall magnitude of timing violations in the design. Used alongside WNS to assess timing closure convergence across design iterations.']
  updated_timestamp timestamp [note: 'Date and time when this STA run record was last modified in the Databricks Silver Layer data product. Tracks updates such as status changes, waiver additions, or review approvals for audit trail and data lineage compliance.']
  waiver_count varchar [note: 'Number of timing violations formally waived with engineering sign-off in this STA run. Waivers are granted for violations on non-critical paths, test-mode-only paths, or paths with functional justification. Tracked for tapeout risk assessment and compliance with design review processes.']
  worst_hold_slack_ps decimal(12,4) [note: 'Worst Hold Slack (WHS) in picoseconds for hold timing analysis in this STA run. Represents the most critical hold violation — the largest shortfall in minimum path delay. Negative values indicate hold violations that must be fixed before tapeout. Applicable when analysis_mode includes hold or setup_hold.']
  worst_negative_slack_ps decimal(12,4) [note: 'Worst Negative Slack (WNS) in picoseconds reported by Synopsys PrimeTime for this STA run. Represents the most critical timing violation — the largest shortfall between required and actual signal arrival time. A value of 0 or positive indicates no setup/hold violation on the worst path. Key metric for timing closure tracking.']

  Note: 'Static Timing Analysis (STA) run record produced by Synopsys PrimeTime capturing timing closure status for a design at a specific design stage. Tracks worst negative slack (WNS), total negative slack (TNS), setup/hold violations count, operating corner (PVT), clock frequency targets, analysis mode (pre-CTS, post-CTS, post-route), and pass/fail status. Enables timing closure tracking across design iterations.'
}

Table design.physical_layout {
  physical_layout_id varchar [pk, note: 'Unique surrogate identifier for each physical design layout record in the Databricks Silver Layer. Serves as the primary key for the physical_layout data product.']
  netlist_id varchar [note: 'FK to design.netlist.netlist_id — Physical layout (place and route) takes a netlist as input. This is the core PnR flow linkage required for design provenance.']
  pdk_id varchar [note: 'Reference to the Process Design Kit (PDK) version used for this physical layout. The PDK defines the technology node rules, design rule checks (DRC), and layer stack for the target fabrication process.']
  physical_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — Physical layouts belong to a specific IC design project. Required for design artifact management.']
  primary_physical_ic_design_project_id varchar [note: 'Reference to the parent IC design record for which this physical layout iteration was produced. Links the layout to its originating design project.']
  antenna_violation_count varchar [note: 'Number of antenna rule violations detected in the layout. Antenna violations occur when metal segments accumulate charge during plasma etching that can damage gate oxide. Must be resolved or mitigated with antenna diodes before tapeout.']
  cell_utilization_pct decimal(6,3) [note: 'Percentage of the core area occupied by placed standard cells, expressed as a decimal percentage (e.g., 72.500 = 72.5%). High utilization (>85%) may indicate routing congestion risk; low utilization (<50%) may indicate oversized floorplan.']
  core_area_mm2 decimal(12,6) [note: 'Area of the core logic region in square millimeters (mm²), excluding I/O ring, power ring, and seal ring. Used to assess logic density and available routing resources.']
  created_timestamp timestamp [note: 'Timestamp when this physical layout record was first created in the data platform. Used for audit trail and data lineage tracking in the Databricks Silver Layer.']
  cts_insertion_delay_ps decimal(10,3) [note: 'Clock insertion delay in picoseconds (ps) from the clock source to the farthest clock sink in the clock tree. Impacts setup timing margin and must be accounted for in static timing analysis (STA).']
  cts_skew_ps decimal(10,3) [note: 'Clock skew in picoseconds (ps) achieved by the Clock Tree Synthesis (CTS) engine at this layout iteration. Measures the maximum difference in clock arrival times across all sink flip-flops. Lower skew improves timing closure margin.']
  dfm_score decimal(6,3) [note: 'Quantitative DFM (Design for Manufacturability) score assigned to this layout iteration by the DFM analysis tool (e.g., Mentor Calibre YieldAnalyzer). Higher scores indicate better manufacturability and expected yield; used to guide layout optimization before tapeout.']
  dft_coverage_pct decimal(6,3) [note: 'Fault coverage percentage achieved by the DFT (Design for Testability) implementation at this layout stage, as reported by ATPG (Automatic Test Pattern Generation) tools. Typically required to exceed 95% for production test qualification.']
  die_area_mm2 decimal(12,6) [note: 'Total die area in square millimeters (mm²) computed from the floorplan boundary. A primary PPA (Power, Performance, Area) metric used for cost estimation, yield modeling, and competitive benchmarking.']
  die_height_um decimal(12,4) [note: 'Height of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Together with die width, determines die area for yield and cost analysis.']
  die_width_um decimal(12,4) [note: 'Width of the die boundary in micrometers (µm) as defined in the physical layout floorplan. Used for package selection, wafer yield estimation, and cost modeling.']
  drc_critical_violation_count varchar [note: 'Number of DRC violations classified as critical (yield-impacting or functionality-blocking) as opposed to waivable violations. Critical DRC violations must be resolved before tapeout; waivable violations may be accepted with foundry approval.']
  drc_violation_count varchar [note: 'Total number of Design Rule Check (DRC) violations detected in this layout iteration by the signoff DRC tool (e.g., Mentor Calibre, Synopsys IC Validator). A value of zero is required for tapeout approval.']
  eda_tool varchar [note: 'EDA tool used to produce this physical layout iteration. Identifies the physical implementation platform (Cadence Innovus, Synopsys IC Compiler 2, Siemens Aprisa, or Cadence Virtuoso for custom layouts) for provenance and reproducibility.']
  eda_tool_version varchar [note: 'Version string of the EDA tool used to generate this layout (e.g., \'Innovus 21.1\', \'ICC2 2022.03\'). Critical for design reproducibility and debugging layout-specific tool behavior.']
  em_compliant boolean [note: 'Indicates whether all metal interconnects in the layout comply with electromigration (EM) current density limits specified by the foundry PDK. TRUE = EM compliant; FALSE = EM violations present requiring wire widening or rerouting.']
  gds_file_checksum varchar [note: 'SHA-256 cryptographic checksum of the GDSII/OASIS layout file for integrity verification. Used to confirm that the submitted tapeout file has not been corrupted or tampered with during transfer to the foundry.']
  gds_file_format varchar [note: 'Format of the layout database file referenced in gds_file_path. GDSII is the traditional foundry submission format; OASIS (Open Artwork System Interchange Standard) is the modern compressed alternative; LEF/DEF is used for abstract/physical exchange.']
  gds_file_path varchar [note: 'File system or object storage path to the GDSII (Graphic Data System II) or OASIS layout database file for this physical layout iteration. The GDSII file is the primary deliverable submitted to the foundry for mask generation at tapeout.']
  implementation_stage varchar [note: 'Current stage in the physical implementation flow for this layout iteration. Stages progress from initial floorplan through placement, clock tree synthesis (CTS), routing, signoff, and final tapeout submission. [ENUM-REF-CANDIDATE: floorplan|placement|cts|routing|signoff|tapeout — promote to reference product if additional stages are needed]']
  ir_drop_max_mv decimal(10,4) [note: 'Maximum static IR drop in millivolts (mV) observed in the power grid analysis at this layout iteration. Excessive IR drop degrades circuit performance and reliability; must remain within foundry-specified limits for tapeout approval.']
  iteration_timestamp timestamp [note: 'Timestamp when this physical layout iteration checkpoint was captured and committed to the design database. Represents the principal business event time for this layout record, enabling chronological tracking of design progress.']
  layout_name varchar [note: 'Human-readable name identifying this physical layout iteration, typically including the design name and iteration label (e.g., \'SoC_v3_floorplan_iter2\'). Used in Cadence Innovus and Synopsys ICC2 project naming conventions.']
  layout_status varchar [note: 'Lifecycle status of this physical layout record. Tracks whether the layout is actively being worked on, under design review, approved for next stage, rejected requiring rework, or archived as a historical iteration.']
  layout_version varchar [note: 'Version identifier for this physical layout iteration following semantic versioning (e.g., \'1.0.0\', \'2.3.1\'). Tracks incremental changes through the physical implementation flow from floorplan to tapeout.']
  leakage_power_uw decimal(12,4) [note: 'Static leakage power in microwatts (µW) estimated for this layout at the target operating conditions. Critical for battery-powered and low-power IoT/mobile applications; tracked separately from dynamic power for PPA optimization.']
  lvs_clean boolean [note: 'Indicates whether the physical layout passes Layout Versus Schematic (LVS) verification with zero errors, confirming that the layout netlist matches the schematic netlist. TRUE = LVS clean (required for tapeout); FALSE = LVS errors present.']
  metal_fill_density_pct decimal(6,3) [note: 'Average metal fill density percentage across all metal layers after dummy metal fill insertion. Foundry CMP (Chemical Mechanical Planarization) processes require metal density to remain within specified min/max bounds to ensure planar surfaces.']
  metal_layer_count varchar [note: 'Number of metal routing layers used in this physical layout, as defined by the PDK technology node stack (e.g., 12 for advanced FinFET nodes). Determines routing resource availability and BEOL (Back End of Line) complexity.']
  notes varchar [note: 'Free-text notes capturing design decisions, known issues, waiver justifications, or iteration-specific observations recorded by the physical design engineer. Supports design review documentation and knowledge transfer.']
  power_consumption_mw decimal(12,4) [note: 'Estimated total power consumption in milliwatts (mW) from power analysis at this layout iteration, including dynamic switching power and static leakage power. A key PPA (Power, Performance, Area) metric for product specification compliance.']
  routing_congestion_layer varchar [note: 'Metal layer identifier (e.g., \'M4\', \'M7\') where the maximum routing congestion was observed. Used to guide targeted floorplan or placement adjustments to relieve congestion on the most constrained layer.']
  routing_congestion_max_pct decimal(6,3) [note: 'Maximum routing congestion percentage observed across all metal layers in the layout, expressed as overflow percentage. Values above 5% typically indicate routing closure risk requiring floorplan or placement adjustment.']
  tapeout_date date [note: 'Date on which the final GDSII/OASIS layout was submitted to the foundry for mask generation (tapeout). A critical milestone in the IC design lifecycle tracked against the product TTM (Time to Market) schedule.']
  tns_ps decimal(14,3) [note: 'Total Negative Slack (TNS) in picoseconds (ps), representing the sum of all negative slack values across all timing paths. Indicates the overall magnitude of timing violations in the design; must reach zero for tapeout signoff.']
  total_cell_count varchar [note: 'Total number of standard cells placed in the core area at this layout iteration. Includes combinational logic, sequential elements, buffers, and inverters. Used to assess design complexity and placement density.']
  updated_timestamp timestamp [note: 'Timestamp when this physical layout record was last modified in the data platform. Supports incremental data processing, change detection, and audit compliance in the Databricks Silver Layer.']
  wns_ps decimal(10,3) [note: 'Worst Negative Slack (WNS) in picoseconds (ps) from static timing analysis at this layout iteration. Negative values indicate timing violations; zero or positive values indicate timing closure. A key metric for tapeout readiness.']

  Note: 'Physical design layout record representing the floorplan, placement, clock tree, and routing state of an IC design at a specific stage in the physical implementation flow. Captures die dimensions and core area, cell utilization percentage, routing congestion metrics by metal layer, DRC violation count and categories, LVS clean status, metal layer stack usage and fill density, power grid IR-drop analysis results, clock tree synthesis (CTS) metrics (skew, insertion delay), electromigration compliance status, antenna rule violations, and GDS/GDSII or OASIS file reference. Tracks physical design iterations from initial floorplan through final tapeout-ready layout in Cadence Innovus, Synopsys ICC2, or Siemens Aprisa. SSOT for physical design state at each iteration checkpoint.'
}

Table design.tapeout {
  tapeout_id varchar [pk, note: 'Unique system-generated surrogate identifier for the tapeout event record. Primary key for the tapeout data product in the design domain.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Tapeout directly triggers NRE invoicing, export control screening, and customer sign-off — all requiring a direct account reference. Semiconductor operations teams bill NRE costs and perform ECCN/EAR ']
  approved_vendor_id varchar [note: 'Foreign key linking to supply.approved_vendor. Business justification: Foundry AVL compliance for tapeout sign-off: quality and compliance teams must verify the foundry used for each tapeout is on the Approved Vendor List before sign-off. This is a mandatory gate in IATF']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: Enables tracking of each tapeout against its originating design win for NRE cost recovery and warranty reporting.']
  foundry_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Tapeout submission must specify the foundry supplier to coordinate mask set delivery and wafer fab.']
  pdk_id varchar [note: 'Reference to the Process Design Kit (PDK) version used for this tapeout. The PDK defines the foundry-specific design rules, device models, and layer stack used during physical design.']
  physical_layout_id varchar [note: 'FK to design.physical_layout.physical_layout_id — Tapeout submits a final physical layout (GDS) to the foundry. Must reference which layout version was taped out.']
  primary_tapeout_ic_design_project_id varchar [note: 'Reference to the parent IC design record from which this tapeout was generated. Links tapeout provenance back to the design lifecycle in the design domain.']
  to_ic_design_project_id varchar [note: 'FK to design.ic_design_project.ic_design_project_id — A tapeout event is the culmination of an IC design project. This is the critical milestone linkage.']
  verification_plan_id varchar [note: 'Foreign key linking to design.verification_plan. Business justification: Tapeout is the final design submission milestone and requires full verification sign-off as a prerequisite. Linking tapeout to the verification_plan that was completed and signed off provides end-to-e']
  created_timestamp timestamp [note: 'Timestamp when the tapeout record was first created in the system. Used for audit trail and data lineage tracking.']
  design_name varchar [note: 'Human-readable name of the IC design being taped out (e.g., product code name or internal design designation). Used for identification in design review meetings and foundry communications.']
  design_revision varchar [note: 'Revision identifier of the design at the time of tapeout (e.g., A0, B1, C2). Distinguishes successive tapeout iterations of the same design, critical for mask set versioning and silicon bring-up tracking.']
  design_type varchar [note: 'Classification of the IC design type being taped out. Distinguishes ASIC, SoC, FPGA, analog, mixed-signal, RF, memory, and photonic designs, which have different EDA flows, PDK requirements, and sign-off criteria. [ENUM-REF-CANDIDATE: ASIC|SoC|FPGA|analog|mixed_signal|RF|memory|photonic — promote to reference product]']
  dfm_score decimal(5,2) [note: 'Quantitative Design for Manufacturability (DFM) score assigned to the layout at tapeout, reflecting predicted yield sensitivity to process variation. Higher scores indicate better manufacturability. Sourced from DFM analysis tools integrated with the EDA flow.']
  dft_coverage_pct decimal(5,2) [note: 'Percentage of logic nodes covered by Design for Testability (DFT) structures (scan chains, BIST) as measured by Automatic Test Pattern Generation (ATPG) at tapeout sign-off. Directly impacts post-silicon test quality and DPPM targets.']
  die_size_mm2 decimal(10,4) [note: 'Physical area of the die in square millimeters as defined in the final GDS layout at tapeout. A key Power-Performance-Area (PPA) metric used for cost modeling, yield estimation, and wafer utilization planning.']
  drc_clean boolean [note: 'Indicates whether the final GDS layout passed all Design Rule Check (DRC) violations with zero errors at the time of tapeout submission. A TRUE value is a mandatory tapeout sign-off criterion per foundry requirements.']
  erc_clean boolean [note: 'Indicates whether the design passed Electrical Rule Check (ERC) with no violations at tapeout. ERC validates electrical connectivity integrity including floating nodes, antenna violations, and electromigration rules.']
  expected_yield_pct decimal(5,2) [note: 'Predicted die yield percentage (good dies per wafer as a percentage of total dies per wafer) at the time of tapeout, based on DFM analysis and process node historical yield data. Used for production planning and cost-per-die estimation.']
  export_control_classification varchar [note: 'Export control classification of the tapeout design under US Export Administration Regulations (EAR) or International Traffic in Arms Regulations (ITAR). Determines licensing requirements for foundry submission to foreign entities. [ENUM-REF-CANDIDATE: EAR99|ECCN_3E001|ECCN_3A001|ITAR_controlled|not_classified — promote to reference product]']
  foundry_name varchar [note: 'Name of the semiconductor fabrication facility (FAB) or foundry to which the tapeout was submitted (e.g., TSMC, Samsung Foundry, GlobalFoundries, Intel Foundry Services). Used for supply chain and vendor management reporting.']
  foundry_submission_ref varchar [note: 'Foundry-assigned reference number or confirmation code for the tapeout submission. Used to track the submission status with the external foundry partner and cross-reference with foundry manufacturing orders.']
  gds_file_path varchar [note: 'Storage path or URI of the final GDS/GDSII layout file in the design data repository. Enables traceability from the tapeout record to the physical design artifact. Classified confidential as it contains proprietary IP location data.']
  gds_file_version varchar [note: 'Version identifier of the final GDS/GDSII layout file submitted for tapeout. Provides design data provenance linking the physical layout file to the tapeout event. Sourced from Cadence Virtuoso or equivalent EDA tool.']
  ip_sign_off_complete boolean [note: 'Indicates whether all third-party and internal Intellectual Property (IP) cores integrated in the design have received sign-off approval for inclusion in the tapeout. Ensures IP licensing compliance and integration verification are complete.']
  lithography_type varchar [note: 'Photolithography exposure technology used for the critical layers in this tapeout. Distinguishes Extreme Ultraviolet (EUV), Deep Ultraviolet (DUV), and legacy lithography types, which impact mask cost, yield, and process complexity.']
  lvs_clean boolean [note: 'Indicates whether the final GDS layout passed Layout Versus Schematic (LVS) verification with zero discrepancies. Confirms that the physical layout matches the intended circuit schematic, a mandatory tapeout sign-off criterion.']
  mask_cost_usd decimal(18,2) [note: 'Cost of the photolithography mask set fabrication for this tapeout in US dollars. A major component of NRE cost, tracked separately for cost accounting and foundry invoice reconciliation in SAP S/4HANA.']
  mask_count varchar [note: 'Total number of photolithography masks in the mask set for this tapeout. Directly drives NRE mask cost and is a key input to tapeout cost modeling. Includes FEOL, MOL, and BEOL layers.']
  metal_layer_count varchar [note: 'Total number of metal interconnect layers in the Back End of Line (BEOL) stack for this tapeout. Determines routing density, RC parasitics, and mask count, directly impacting NRE cost and manufacturing complexity.']
  notes varchar [note: 'Free-text field for capturing tapeout-specific notes, known issues, approved waivers, or special foundry instructions that do not fit structured fields. Used by design and process engineering teams for context during silicon bring-up.']
  nre_cost_usd decimal(18,2) [note: 'Total Non-Recurring Engineering (NRE) cost committed for this tapeout in US dollars, including mask set fabrication, EDA tool licenses, and foundry engineering charges. A critical financial commitment recorded at tapeout sign-off. Classified confidential as it contains proprietary cost data.']
  opc_ret_status varchar [note: 'Processing status of Optical Proximity Correction (OPC) and Resolution Enhancement Technology (RET) applied to the GDS data prior to mask tape-out. OPC/RET is mandatory for sub-28nm nodes to compensate for photolithographic distortion effects.']
  packaging_type varchar [note: 'Intended die packaging technology for the taped-out design (e.g., WLCSP, CoWoS, InFO, flip-chip BGA, QFN). Informs OSAT engagement, assembly NRE planning, and downstream packaging domain linkage. [ENUM-REF-CANDIDATE: WLCSP|CoWoS|InFO|flip_chip_BGA|QFN|BGA|LGA|SiP — promote to reference product]']
  process_node varchar [note: 'Semiconductor manufacturing process node used for this tapeout, expressed as a technology node designation (e.g., 5nm, 7nm, 28nm, 65nm). Defines the lithography generation and transistor geometry for the fabricated IC.']
  process_technology varchar [note: 'Transistor architecture and process technology type used for this tapeout. Distinguishes between planar CMOS, FinFET, Gate-All-Around (GAA), and specialty process technologies relevant to device performance and yield modeling. [ENUM-REF-CANDIDATE: CMOS|FinFET|GAA|BiCMOS|SiGe|GaN|SiC|SOI — 8 candidates stripped; promote to reference product]']
  signoff_checklist_complete boolean [note: 'Indicates whether all items on the design sign-off checklist have been completed and approved prior to tapeout submission. The checklist covers DRC, LVS, ERC, timing closure, power analysis, DFT, and IP sign-off milestones.']
  tapeout_date date [note: 'The principal real-world business event date on which the final GDS/GDSII design data was submitted to the foundry or mask house for manufacturing. This is the definitive tapeout milestone date used in project tracking and TTM reporting.']
  tapeout_number varchar [note: 'Externally-known business identifier for the tapeout event, used in communications with the foundry, mask house, and internal design teams. Follows the format TO-<DESIGN_CODE>-<YEAR>.']
  tapeout_status varchar [note: 'Current lifecycle state of the tapeout event. Tracks progression from internal preparation through foundry acceptance or rejection. [ENUM-REF-CANDIDATE: draft|pending_signoff|submitted|accepted|rejected|cancelled — promote to reference product if additional states are needed]']
  tapeout_type varchar [note: 'Classification of the tapeout run type. Distinguishes full custom dedicated wafer tapeouts, Multi-Project Wafer (MPW) shuttle runs, engineering sample tapeouts, and production tapeouts. Drives cost allocation and foundry scheduling.']
  target_market_segment varchar [note: 'Primary market segment for which the taped-out IC is designed. Used for business reporting, revenue forecasting, and strategic portfolio analysis. [ENUM-REF-CANDIDATE: mobile|automotive|datacenter|IoT|industrial|consumer|aerospace_defense|networking — promote to reference product]']
  target_tapeout_date date [note: 'Originally planned tapeout date as committed in the project schedule. Used to measure schedule adherence and Time to Market (TTM) variance against the actual tapeout date.']
  timing_closure_status varchar [note: 'Status of static timing analysis (STA) sign-off at tapeout. Indicates whether all timing paths met setup and hold constraints (clean), had approved waivers (waived), or had unresolved violations (failed). Sourced from Synopsys PrimeTime or Cadence Tempus.']
  updated_timestamp timestamp [note: 'Timestamp when the tapeout record was last modified. Used for change tracking, audit compliance, and incremental data pipeline processing.']
  wafer_count_ordered varchar [note: 'Number of wafers ordered from the foundry for this tapeout run. Used for production planning, yield forecasting, and supply chain management. Applicable for dedicated tapeouts; for MPW runs, this reflects the allocated wafer share.']

  Note: 'Tapeout event record capturing the final design submission milestone for manufacturing. Records tapeout date, GDS/GDSII file version, mask set identifier, foundry submission reference, PDK version used, final DRC/LVS clean status, OPC/RET processing status, design sign-off checklist completion, NRE cost committed, and MPW shuttle assignment if applicable. SSOT for tapeout provenance linking design to fabrication domain.'
}

Table design.ip_core_usage {
  ip_core_usage_id varchar [pk, note: 'Unique surrogate identifier for each IP core integration instance record within a design project. Primary key for the ip_core_usage entity.']
  primary_ip_core_id varchar [note: 'Reference to the specific IP core being integrated. Identifies the IP block (e.g., PCIe controller, DDR PHY, USB subsystem) from the IP catalog.']
  primary_ip_ic_design_project_id varchar [note: 'Reference to the IC design project (SoC, ASIC, or FPGA design) into which this IP core version is being integrated. Links the usage record to the parent design context.']
  source_design_project_ic_design_project_id varchar [note: 'Reference to the original design project from which this IP core integration was reused, when ip_reuse_flag is True. Enables IP reuse lineage tracking and qualification inheritance assessment.']
  tapeout_id varchar [note: 'Reference to the tapeout event (final GDSII submission for manufacturing) in which this IP core integration was included. Links IP usage to the specific fabrication submission for traceability.']
  area_consumed_um2 decimal(18,4) [note: 'Physical silicon area consumed by this IP core integration in square micrometers (µm²). Used for die area budget tracking, PPA (Power, Performance, Area) analysis, and cost estimation.']
  clock_frequency_mhz decimal(12,4) [note: 'Target operating clock frequency in megahertz (MHz) for this IP core integration in the design context. Used for timing closure planning and STA (Static Timing Analysis) constraint setup.']
  configuration_parameters varchar [note: 'Serialized key-value string of configuration parameters applied to this IP core instance (e.g., data_width=64, num_channels=8, fifo_depth=512). Captures the specific parameterization used in this design context for reproducibility and IP reuse analytics.']
  created_timestamp timestamp [note: 'Timestamp when this IP core usage record was first created in the system. Used for audit trail, data lineage, and record provenance tracking in the Databricks Silver Layer.']
  design_hierarchy_path varchar [note: 'Full hierarchical path of the IP core instance within the design netlist (e.g., \'top/subsystem_a/pcie_ctrl_0\'). Enables precise identification of the IP instance location in the design hierarchy for debug, ECO, and physical implementation.']
  export_control_classification varchar [note: 'Export control classification of this IP core under US EAR (Export Administration Regulations) or ITAR (International Traffic in Arms Regulations). Determines permissible countries and end-users for design sharing and IP transfer. Critical for regulatory compliance.']
  functional_coverage_pct decimal(5,2) [note: 'Functional verification coverage percentage achieved for this IP core integration, as reported by the verification environment. Used for sign-off readiness assessment and quality gate enforcement.']
  instance_count varchar [note: 'Number of times this IP core is instantiated within the design project (e.g., 4 instances of a SERDES PHY). Drives royalty calculation for royalty-bearing IP and area budget planning.']
  integration_start_date date [note: 'Calendar date on which integration of this IP core into the design project was initiated. Used for project timeline tracking, TTM (Time to Market) analysis, and design schedule management.']
  integration_status varchar [note: 'Current lifecycle state of the IP core integration within the design project. Tracks progression from initial selection through silicon validation: planned (selected but not yet integrated), in_progress (integration underway), verified (simulation/emulation verified), silicon_proven (validated on fabricated silicon).']
  interface_protocol varchar [note: 'Primary bus or interface protocol used to connect this IP core to the SoC interconnect fabric (e.g., AXI4, AHB, APB, CHI, TileLink, OCP). Critical for integration verification and bus protocol compliance checking. [ENUM-REF-CANDIDATE: AXI4|AHB|APB|CHI|TileLink|OCP|AXI4-Lite|AXI4-Stream|Wishbone|AMBA — promote to reference product]']
  ip_core_version varchar [note: 'Specific version identifier of the IP core being integrated (e.g., 2.1.0, 3.0.0-rc1). Tracks which release of the IP block is used in this design context to support IP lifecycle and change management.']
  ip_reuse_flag boolean [note: 'Indicates whether this IP core integration is a reuse of a previously silicon-proven instance from another design project (True = reused IP, False = first-time integration). Enables IP reuse analytics and NRE cost avoidance tracking.']
  is_dfm_compliant boolean [note: 'Indicates whether this IP core integration has passed DFM (Design for Manufacturability) rule checks for the target process node (True = DFM compliant). Critical for yield optimization and tapeout readiness sign-off.']
  is_dft_enabled boolean [note: 'Indicates whether DFT (Design for Testability) structures such as scan chains, BIST, or JTAG boundary scan are enabled for this IP core integration (True = DFT enabled). Impacts ATPG test pattern generation and ATE test coverage.']
  is_silicon_proven boolean [note: 'Indicates whether this IP core version has been validated on fabricated silicon within this specific design project context (True = silicon-proven, False = not yet silicon-proven). Key qualifier for IP reuse qualification and KGD (Known Good Die) assessments.']
  last_updated_timestamp timestamp [note: 'Timestamp when this IP core usage record was most recently modified. Used for change tracking, incremental data pipeline processing, and audit compliance.']
  license_type varchar [note: 'Licensing model under which the IP core is used in this design: royalty_bearing (per-unit royalty owed on production), perpetual (one-time NRE fee, unlimited use), subscription (time-limited access), internal (internally developed IP, no external license), open_source (open-source licensed IP). Critical for license compliance auditing and cost accounting.']
  notes varchar [note: 'Free-text field for capturing integration-specific observations, known issues, workarounds, or deviations from standard integration procedures. Supports design review documentation and knowledge transfer.']
  nre_cost_usd decimal(18,2) [note: 'Non-Recurring Engineering cost in US dollars associated with licensing or customizing this IP core for the design project. Includes one-time integration fees, customization charges, and support costs. Used for design project cost accounting.']
  pdk_node varchar [note: 'Semiconductor process technology node for which this IP core version is qualified (e.g., \'5nm\', \'7nm\', \'28nm\'). Ensures IP-PDK compatibility and is critical for physical design sign-off and DFM compliance.']
  power_contribution_mw decimal(12,4) [note: 'Estimated power consumption contributed by this IP core integration in milliwatts (mW), covering dynamic and static power. Used for top-level power budget analysis and PPA optimization.']
  royalty_rate_per_unit decimal(12,6) [note: 'Per-unit royalty rate in US dollars payable to the IP licensor for each chip shipped containing this IP core. Applicable only for royalty_bearing license types. Used for royalty obligation forecasting and financial accruals.']
  sign_off_date date [note: 'Calendar date on which the formal design sign-off for this IP core integration was granted or last updated. Used for tapeout readiness tracking and audit trail.']
  sign_off_status varchar [note: 'Design sign-off status for this IP core integration, reflecting the outcome of formal design review and approval gates (pending, approved, rejected, waived). Required for tapeout readiness and quality gate compliance.']
  silicon_validation_date date [note: 'Calendar date on which silicon validation of this IP core integration was completed, confirming silicon-proven status. Null if silicon validation has not yet occurred.']
  supply_voltage_v decimal(8,4) [note: 'Operating supply voltage in volts (V) for this IP core integration. Used for power domain planning, multi-voltage design verification, and UPF (Unified Power Format) constraint generation.']
  timing_budget_ns decimal(12,6) [note: 'Timing budget allocated to this IP core integration in nanoseconds (ns), representing its contribution to the top-level timing closure budget. Derived from Synopsys PrimeTime timing analysis and used for STA sign-off.']
  usage_to_core varchar [note: 'FK to design.ip_core.ip_core_id — IP core usage records which IP core is being integrated. This is the fundamental FK for the association record.']
  verification_completion_date date [note: 'Calendar date on which functional verification of this IP core integration was completed and signed off. Marks the transition from in_progress to verified integration status.']
  verification_methodology varchar [note: 'Verification methodology applied to validate this IP core integration (e.g., UVM, OVM, formal verification, emulation, FPGA prototype). Determines verification coverage and sign-off criteria. [ENUM-REF-CANDIDATE: UVM|OVM|VMM|formal|emulation|FPGA_prototype|mixed — 7 candidates stripped; promote to reference product]']

  Note: 'Integration instance record capturing the deployment of a specific IP core version into an IC design project, with full lifecycle from selection through silicon validation. Tracks IP core version used, integration status (planned, in-progress, verified, silicon-proven), configuration parameters applied, interface connections and bus protocol mappings, timing constraints contributed to the top-level budget, physical area consumed, power contribution, licensing compliance status (royalty-bearing, perpetual, subscription), and silicon-proven flag for this design context. Enables IP reuse analytics, license compliance auditing across design projects, and IP qualification tracking. SSOT for the many-to-many relationship between IP cores and design projects.'
}

Table design.verification_plan {
  verification_plan_id varchar [pk, note: 'Unique surrogate identifier for the design verification plan record within the Databricks Silver Layer lakehouse. Primary key for this entity.']
  ic_design_project_id varchar [note: 'Reference to the parent IC design project for which this verification plan is authored. Links the plan to the RTL-to-GDSII design project record managed in Cadence Virtuoso/Innovus or Siemens Teamcenter PLM.']
  rtl_specification_id varchar [note: 'Foreign key linking to design.rtl_specification. Business justification: A verification plan is created to verify a specific RTL specification — the plan defines functional coverage targets, DFT strategy, and simulation methodology for the RTL design block. Linking verific']
  assertion_coverage_target_pct decimal(5,2) [note: 'Target percentage of SystemVerilog Assertions (SVA) or PSL assertions that must be exercised and pass during simulation. Assertion coverage is a key metric for protocol compliance and corner-case verification completeness.']
  bug_tracking_project_key varchar [note: 'Project key or identifier in the bug tracking system corresponding to this verification plan (e.g., \'SOC-X5-VER\'). Used to hyperlink verification failures to the defect management workflow.']
  bug_tracking_system varchar [note: 'Name of the defect/bug tracking system integrated with this verification plan for logging simulation failures and RTL bugs (e.g., \'Jira\', \'Bugzilla\', \'Synopsys Serenity\'). Enables traceability from verification failures to RTL fixes.']
  code_coverage_target_pct decimal(5,2) [note: 'Target code coverage closure percentage (line, branch, condition, expression, FSM) required for sign-off. Complements functional coverage to ensure structural completeness of the RTL simulation. Tracked against EDA tool-reported actuals.']
  created_timestamp timestamp [note: 'Timestamp when this design verification plan record was first created in the system. Supports audit trail, data lineage, and compliance reporting requirements.']
  design_type varchar [note: 'Classification of the IC design type under verification. Determines the applicable verification strategies, IP reuse policies, and regulatory requirements. [ENUM-REF-CANDIDATE: ASIC|SoC|FPGA|IP_core|ASSP|MCU|GPU|DSP — promote to reference product]']
  dft_strategy varchar [note: 'Primary DFT strategy defined in the verification plan for post-silicon test coverage. Scan chain inserts flip-flop chains for structural test; BIST (Built-In Self-Test) embeds test logic on-chip; ATPG (Automatic Test Pattern Generation) generates test vectors; boundary scan (JTAG per IEEE 1149.1) tests board-level interconnects. [ENUM-REF-CANDIDATE: scan_chain|BIST|ATPG|boundary_scan|JTAG|combined|none — promote to reference product]']
  emulation_platform varchar [note: 'Hardware emulation platform used for pre-silicon software bring-up and system-level verification (e.g., \'Cadence Palladium Z2\', \'Synopsys ZeBu\', \'Mentor Veloce\'). Null if emulation is not in scope for this plan.']
  fault_coverage_target_pct decimal(5,2) [note: 'Target stuck-at and transition fault coverage percentage for ATPG-generated test patterns. Typically 99%+ for automotive/safety-critical designs per IATF 16949 and ISO 26262. Drives DFT insertion effort and scan chain architecture decisions.']
  fault_injection_campaign_planned boolean [note: 'Indicates whether a structured fault injection campaign is planned as part of this verification plan to validate safety mechanisms per ISO 26262. True for ASIL-B and above designs. Drives resource allocation for fault simulation infrastructure.']
  fmeda_document_reference varchar [note: 'Reference identifier of the linked FMEDA document in the PLM system. The FMEDA quantifies diagnostic coverage and safe failure fraction for ISO 26262 hardware metrics compliance. Null for non-safety designs.']
  formal_verification_tool varchar [note: 'EDA tool used for formal property checking and equivalence checking (e.g., \'Synopsys VC Formal\', \'Cadence JasperGold\', \'OneSpin 360\'). Null if formal verification is not part of the plan methodology.']
  fpga_prototype_platform varchar [note: 'FPGA prototyping board or platform used for early software validation and system integration testing (e.g., \'Xilinx VCU128\', \'Intel Stratix 10 GX\', \'Aldec HES-US-440\'). Null if FPGA prototyping is not in scope.']
  functional_coverage_target_pct decimal(5,2) [note: 'Target functional coverage closure percentage required for verification sign-off (e.g., 99.50 for 99.5%). Defined in the verification plan and tracked against actual coverage results from simulation regression runs. A key tapeout readiness gate metric.']
  ip_reuse_count varchar [note: 'Number of third-party or internal IP cores integrated into this design that require verification waivers or pre-verified IP sign-off. Impacts the scope of the verification plan and the testbench architecture for IP interface compliance.']
  iso26262_asil_decomposition varchar [note: 'Description of the ASIL decomposition strategy applied to this design per ISO 26262 Part 9. Documents how a higher ASIL requirement is decomposed into two independent lower-ASIL sub-elements (e.g., \'ASIL D decomposed to ASIL B + ASIL B\'). Mandatory for automotive safety-critical IC designs.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this design verification plan record. Used for change tracking, PLM synchronization, and incremental data pipeline processing in the Databricks Silver Layer.']
  pdk_version varchar [note: 'Version of the foundry-provided PDK used in this design and verification environment. The PDK defines the design rules, device models, and standard cell libraries. Verification must be validated against the correct PDK version to ensure DFM compliance.']
  plan_end_date date [note: 'Planned completion date for all verification activities and sign-off, aligned with the tapeout schedule. A key TTM (Time to Market) planning date. Slippage triggers NRE (Non-Recurring Engineering) cost impact analysis.']
  plan_name varchar [note: 'Descriptive human-readable name for the verification plan, typically including the IC design project name and verification phase (e.g., \'SoC-X5 Full-Chip Functional Verification Plan v2.1\'). Used in dashboards, reports, and PLM document management.']
  plan_number varchar [note: 'Externally-known, human-readable identifier for the verification plan, typically assigned by the PLM system (e.g., Oracle Agile PLM or Siemens Teamcenter). Format: DVP-<PROJECT_CODE>-<YEAR>-<SEQ>. Used in cross-functional communications, tapeout checklists, and audit trails.']
  plan_start_date date [note: 'Planned start date for verification activities as defined in the project schedule. Used for milestone tracking, resource planning, and TTM (Time to Market) analysis.']
  plan_status varchar [note: 'Current lifecycle state of the verification plan document. Drives workflow approvals and tapeout gate readiness. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|on_hold|closed|cancelled — promote to reference product]']
  plan_version varchar [note: 'Version identifier of the verification plan document following semantic versioning (e.g., \'1.0\', \'2.3\', \'3.1.2\'). Incremented upon each approved revision cycle in the PLM system. Critical for traceability to tapeout sign-off.']
  regression_run_frequency varchar [note: 'Planned frequency at which the regression suite is executed. Continuous integration runs on every RTL commit; nightly runs are scheduled overnight; milestone-triggered runs occur at defined project gates; on-demand runs are manually initiated.']
  regression_suite_name varchar [note: 'Name of the primary regression test suite defined in this verification plan (e.g., \'SoC_Full_Regression_v3\', \'CPU_Smoke_Suite\'). The regression suite defines the set of simulation tests run nightly or at milestone gates to track coverage progress.']
  safety_criticality_level varchar [note: 'Functional safety classification of the IC design per ISO 26262 (automotive ASIL) or IEC 61508 (industrial SIL). Drives the rigor of fault injection campaigns, FMEDA linkage, and safety mechanism coverage targets within the verification plan. Non-safety designs are tagged \'non_safety\'. [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|non_safety — promote to reference product]']
  safety_mechanism_coverage_target_pct decimal(5,2) [note: 'Target percentage of identified safety mechanisms that must be verified through simulation, formal analysis, or fault injection campaigns. Required for ISO 26262 hardware verification sign-off. Null for non-safety designs.']
  scan_chain_count varchar [note: 'Number of scan chains defined in the DFT architecture for this design. Determines ATPG test time, test data volume, and ATE (Automatic Test Equipment) channel requirements. A key DFT planning parameter.']
  signoff_approved boolean [note: 'Indicates whether all verification sign-off criteria have been met and formal approval has been granted to proceed to tapeout. True only after all coverage targets, regression pass rates, and safety requirements are satisfied.']
  signoff_criteria_description varchar [note: 'Textual description of the complete set of criteria that must be satisfied before verification sign-off is granted and tapeout is authorized. Includes coverage closure thresholds, zero-open-critical-bug requirement, regression pass rate, and formal proof completion.']
  signoff_date date [note: 'Actual date on which verification sign-off was formally approved. Null until sign-off is granted. Used for tapeout readiness confirmation and post-silicon correlation analysis.']
  simulation_tool varchar [note: 'Primary EDA simulation tool assigned for RTL and gate-level simulation (e.g., \'Synopsys VCS\', \'Cadence Xcelium\', \'Mentor Questa\'). Determines the simulation environment configuration, license requirements, and regression infrastructure.']
  tapeout_target_date date [note: 'Target date for GDSII tapeout submission to the foundry. The verification plan must achieve all sign-off criteria before this date. Drives the verification schedule and milestone gate definitions.']
  target_process_node varchar [note: 'Semiconductor fabrication process node for which this design is targeted (e.g., \'5nm\', \'7nm\', \'28nm\', \'180nm\'). Influences PDK selection, timing constraints, and DFM rule applicability within the verification plan.']
  testbench_architecture varchar [note: 'Structural architecture of the simulation testbench. UVM_layered follows the standard UVM agent/scoreboard/coverage hierarchy; directed uses manually written test vectors; constrained_random uses SystemVerilog randomization; cocotb uses Python-based co-simulation; SystemC uses transaction-level modeling. [ENUM-REF-CANDIDATE: UVM_layered|directed|constrained_random|hybrid|cocotb|SystemC — promote to reference product]']
  toggle_coverage_target_pct decimal(5,2) [note: 'Target toggle coverage percentage for all RTL signals, ensuring each net transitions both 0→1 and 1→0 during simulation. Used as a DFT readiness indicator and a structural verification completeness metric.']
  verification_methodology varchar [note: 'Primary pre-silicon verification methodology employed for this plan. UVM (Universal Verification Methodology) is the industry-standard constrained-random simulation approach; formal uses mathematical property checking; emulation uses hardware accelerators; FPGA_prototyping uses field-programmable gate arrays for early software bring-up. [ENUM-REF-CANDIDATE: UVM|formal|emulation|FPGA_prototyping|hybrid|mixed_signal — promote to reference product]']

  Note: 'Design verification plan master record defining the pre-silicon verification strategy for an IC design project. Captures verification methodology (UVM, formal, emulation, FPGA prototyping), coverage goals (functional, code, toggle, assertion), testbench architecture, simulation environment configuration, DFT strategy (ATPG, BIST, scan chain, boundary scan), verification milestones and schedule, tool assignments, regression suite definitions, bug tracking integration, and sign-off criteria. For automotive and safety-critical designs, captures ISO 26262 functional safety verification requirements including ASIL decomposition, safety mechanism coverage targets, fault injection campaign plans, and FMEDA linkage. Ensures systematic verification coverage and regulatory compliance before tapeout.'
}

Table product.ic_catalog {
  ic_catalog_id varchar [pk, note: 'Unique identifier for the IC catalog entry. Primary key for the master record of semiconductor products including ICs, SoCs, ASICs, FPGAs, discretes, and licensable IP cores.']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Each IC catalog entry references its governing control plan defining production monitoring, inspection frequency, and quality gates — standard IATF 16949 requirement linking product definition to manu']
  family_id varchar [note: 'FK to product.product_family']
  packaging_package_type_id varchar [note: 'FK to packaging.package_type']
  primary_ic_process_node_id varchar [note: 'FK to product.process_node.process_node_id — Every IC product is manufactured on a specific process node. This is a fundamental product attribute that references the process node master.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Procurement process requires linking each IC catalog entry to its primary supplier for sourcing, cost analysis, and compliance tracking.']
  aec_qualification_level varchar [note: 'Specific AEC qualification standard met. Q100: ICs, Q101: Discretes, Q102: Optoelectronics, Q200: Passives. Set to NA if not automotive qualified.']
  automotive_qualified boolean [note: 'Indicates whether the product has passed automotive-grade qualification testing per AEC-Q standards. Required for automotive market. Includes extended temperature, reliability, and quality requirements.']
  catalog_to_family varchar [note: 'FK to product.product_family.product_family_id — Every IC product belongs to a product family in the taxonomy hierarchy. This is the primary classification FK.']
  country_of_origin varchar [note: 'Three-letter ISO country code indicating where the IC was manufactured or substantially transformed. Used for trade compliance, tariffs, and country-of-origin marking requirements.']
  created_timestamp timestamp [note: 'Timestamp when this IC catalog record was first created in the PLM system. Audit trail for data governance and lineage tracking.']
  design_type varchar [note: 'Design methodology used for IC development. Determines NRE cost, time to market, and flexibility. Full custom offers maximum optimization; standard cell balances speed and cost.']
  die_size_mm2 decimal(10,4) [note: 'Physical die area in square millimeters after final layout. Critical cost driver as it determines dies per wafer and manufacturing yield economics. Part of PPA metrics.']
  ear_eccn_code varchar [note: 'ECCN code assigned under US Export Administration Regulations. Determines export licensing requirements for dual-use items. Format: 3A001.a. EAR99 indicates no specific ECCN.']
  eol_announcement_date date [note: 'Date when EOL was formally announced to customers via Product Change Notification (PCN). Triggers last-time-buy (LTB) planning and customer transition activities.']
  external_part_number varchar [note: 'Customer-facing orderable part number published in datasheets and used for commercial transactions. May differ from internal part number for marketing or legacy reasons.']
  first_silicon_date date [note: 'Date when first fabricated silicon wafers were received from the fab for initial testing and validation. Marks start of silicon bring-up phase.']
  hts_code varchar [note: 'US Harmonized Tariff Schedule classification code for customs and import duty determination. Format: 8542.31.0000 for electronic integrated circuits.']
  internal_part_number varchar [note: 'Company-assigned unique part number for internal identification, tracking, and PLM integration. Primary business identifier for the IC design.']
  is_active boolean [note: 'Indicates whether this catalog entry is currently active and available for business operations. False indicates archived or soft-deleted record retained for historical reference.']
  itar_controlled boolean [note: 'Indicates whether the product is subject to ITAR export controls for defense-related articles. True if product requires US State Department export license for international shipment.']
  last_ship_date date [note: 'Final date when product shipments will be made. Marks complete discontinuation of the product. Typically 6-12 months after last-time-buy date to allow for manufacturing lead time.']
  last_time_buy_date date [note: 'Final date for customers to place orders before product is discontinued. Typically 6-12 months after EOL announcement. After this date, no new orders are accepted.']
  lead_free_compliant boolean [note: 'Indicates whether the product meets RoHS (Restriction of Hazardous Substances) lead-free requirements. True if compliant with EU RoHS Directive for lead-free solder and materials.']
  lifecycle_status varchar [note: 'Current stage in the product lifecycle from New Product Introduction (NPI) through End of Life (EOL). Governs manufacturing, sales, and support activities. Transitions tracked in status history. [ENUM-REF-CANDIDATE: NPI|Qualification|Production|Mature|EOL_Announced|EOL_Active|Obsolete — 7 candidates stripped; promote to reference product]']
  modified_timestamp timestamp [note: 'Timestamp when this IC catalog record was last updated. Tracks data currency and change history for audit and synchronization purposes.']
  npi_phase varchar [note: 'Detailed phase within NPI lifecycle for products in pre-production stages. Tracks progress from concept through design, tapeout, silicon bring-up, and qualification. Set to NA for production products. [ENUM-REF-CANDIDATE: Concept|Design|Tapeout|Silicon_Validation|Qualification|Ramp|Production|NA — 8 candidates stripped; promote to reference product]']
  operating_frequency_max_mhz decimal(12,4) [note: 'Maximum clock frequency in MHz at which the IC can reliably operate. Key performance metric for processors, SoCs, and high-speed digital circuits. Part of PPA metrics.']
  operating_voltage_max_v decimal(6,3) [note: 'Maximum supply voltage in volts for safe operation. Defines upper bound of operating voltage range. Exceeding this may cause device damage or reliability issues.']
  operating_voltage_min_v decimal(6,3) [note: 'Minimum supply voltage in volts for guaranteed operation. Defines lower bound of operating voltage range for power optimization and battery operation.']
  pin_count varchar [note: 'Total number of external pins or balls on the package. Determines PCB routing complexity, package cost, and I/O capability.']
  power_max_mw decimal(12,4) [note: 'Maximum power consumption in milliwatts under worst-case operating conditions. Used for thermal design, power supply sizing, and system integration planning.']
  power_typical_mw decimal(12,4) [note: 'Typical operating power consumption in milliwatts under nominal conditions. Critical PPA metric for mobile, IoT, and battery-powered applications. Measured at specified voltage and frequency.']
  process_technology varchar [note: 'Underlying semiconductor process technology architecture. Examples: CMOS (Complementary Metal-Oxide-Semiconductor), FinFET (Fin Field-Effect Transistor), GAA (Gate All Around), BiCMOS (Bipolar CMOS). [ENUM-REF-CANDIDATE: CMOS|FinFET|GAA|BiCMOS|SOI|GaN|SiGe — 7 candidates stripped; promote to reference product]']
  product_name varchar [note: 'Human-readable marketing name of the IC product used in customer communications, datasheets, and sales collateral.']
  product_type varchar [note: 'High-level classification of the semiconductor product type. Determines design flow, manufacturing process, and business model (silicon vs. licensable IP). [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Memory|Analog|Mixed_Signal|RF — 10 candidates stripped; promote to reference product]']
  production_release_date date [note: 'Date when product was officially released to production status and made available for volume manufacturing and customer orders. Marks end of qualification phase.']
  reach_compliant boolean [note: 'Indicates compliance with EU REACH (Registration, Evaluation, Authorization and Restriction of Chemicals) regulation. Confirms no Substances of Very High Concern (SVHC) above threshold.']
  rohs_compliant boolean [note: 'Indicates full compliance with EU RoHS Directive restricting hazardous substances (lead, mercury, cadmium, hexavalent chromium, PBB, PBDE). Required for European market access.']
  rtl_language varchar [note: 'Hardware description language used for RTL design specification. Verilog and SystemVerilog are industry standard for digital design. Set to NA for analog-only or IP-only products.']
  tapeout_date date [note: 'Date when final GDSII design database was released to the fab for mask generation and wafer fabrication. Marks completion of design phase and start of manufacturing.']
  target_market varchar [note: 'Primary market segment or application domain for which the IC is designed. Determines qualification requirements, reliability standards, and regulatory compliance needs. [ENUM-REF-CANDIDATE: Automotive|Consumer|Industrial|Medical|Aerospace|Defense|Telecom|Computing|IoT|AI_ML — 10 candidates stripped; promote to reference product]']
  temperature_grade varchar [note: 'Temperature range classification determining qualified operating environment. Commercial: 0-70C, Industrial: -40-85C, Automotive: -40-125C, Military: -55-125C. Critical for market qualification.']
  transistor_count varchar [note: 'Total number of transistors on the die. Key complexity metric for digital ICs and SoCs. Used for design effort estimation and manufacturing complexity assessment.']

  Note: 'Master record for all semiconductor products (ICs, SoCs, ASICs, FPGAs, discretes, licensable IP cores). SSOT for product identity, internal/external part numbers, product family assignment, process node, target market, and lifecycle state with full NPI→qualification→production→EOL transition history. Golden record integrated with PLM. Each entry represents a unique silicon design with one or more orderable SKU variants.'
}

Table product.sku {
  sku_id varchar [pk, note: 'Unique identifier for the stock keeping unit record. Primary key for the SKU entity representing a distinct orderable variant of a catalog product.']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: SKU definition must reference the exact package type; required for Packaging Specification report.']
  replacement_sku_id varchar [note: 'Reference to the recommended replacement SKU for customers when this SKU reaches end of life. Facilitates design migration and continuity planning.']
  to_ic_catalog_id varchar [note: 'FK to product.ic_catalog.ic_catalog_id — Every SKU is an orderable variant of a catalog product. This is the most fundamental FK in the domain — without it, SKUs are orphaned from their parent product definition.']
  code varchar [note: 'Externally-facing unique alphanumeric code identifying this orderable SKU variant. Used in customer orders, invoices, and supply chain documentation.']
  country_of_origin varchar [note: 'Three-letter ISO country code indicating the country where final manufacturing or substantial transformation occurred. Required for customs documentation.']
  created_timestamp timestamp [note: 'Timestamp when this SKU record was first created in the system. Audit trail for data lineage and compliance.']
  customer_part_number varchar [note: 'Optional customer-specific part number assigned to this SKU for custom or design-win scenarios. Facilitates customer BOM alignment.']
  eccn_code varchar [note: 'US Bureau of Industry and Security (BIS) Export Administration Regulations (EAR) classification code. Determines export licensing requirements.']
  eol_announcement_date date [note: 'Date when Product Change Notification (PCN) was issued announcing the end of life for this SKU. Triggers Last Time Buy (LTB) planning for customers.']
  halogen_free boolean [note: 'Indicates whether this SKU is manufactured without halogen-containing materials (chlorine, bromine compounds). Required for certain environmental certifications.']
  hts_code varchar [note: 'International customs classification code for tariff and duty calculation. Used for cross-border shipments and trade compliance.']
  introduction_date date [note: 'Date when this SKU was first made available for customer orders. Marks the transition from NPI to Active lifecycle status.']
  itar_controlled boolean [note: 'Indicates whether this SKU is subject to US ITAR export controls for defense articles. Requires special licensing and handling procedures.']
  last_modified_timestamp timestamp [note: 'Timestamp when this SKU record was most recently updated. Tracks data currency and change history.']
  last_ship_date date [note: 'Final date when shipments of this SKU will be fulfilled. Marks the end of product availability and transition to discontinued status.']
  last_time_buy_date date [note: 'Final date for customers to place orders for this SKU before discontinuation. Typically 6-12 months after EOL announcement.']
  lead_time_weeks varchar [note: 'Typical manufacturing and delivery lead time in weeks from order placement to shipment. Subject to capacity allocation and supply chain conditions.']
  lifecycle_status varchar [note: 'Current stage in the product lifecycle. NPI (New Product Introduction), Active (full production), Mature (stable demand), Declining (phase-out), EOL Announced (End of Life notice issued), Discontinued (no longer available).']
  list_price_usd decimal(15,4) [note: 'Published list price in US dollars for this SKU at 1000-unit quantity. Actual transaction prices subject to volume discounts and customer agreements.']
  manufacturer_part_number varchar [note: 'Official manufacturer part number assigned to this SKU. Used for cross-reference with distributor catalogs and customer Bill of Materials (BOM).']
  minimum_order_quantity varchar [note: 'Smallest quantity that can be ordered for this SKU in a single purchase order line. Driven by packaging constraints and economic order quantities.']
  moisture_sensitivity_level varchar [note: 'JEDEC moisture sensitivity classification indicating required storage and handling conditions before reflow soldering. MSL1 (unlimited floor life) to MSL6 (mandatory bake before use). [ENUM-REF-CANDIDATE: MSL1|MSL2|MSL2a|MSL3|MSL4|MSL5|MSL5a|MSL6 — 8 candidates stripped; promote to reference product]']
  orderable_flag boolean [note: 'Indicates whether this SKU is currently available for new customer orders. May be false during allocation, quality holds, or phase-out periods.']
  pcn_required_flag boolean [note: 'Indicates whether any changes to this SKU specification, manufacturing process, or supply chain require formal Product Change Notification (PCN) to customers per contractual or regulatory requirements.']
  pin_count varchar [note: 'Total number of electrical pins or balls on the package. Critical for PCB design and routing complexity assessment.']
  qualification_level varchar [note: 'Reliability and qualification standard met by this SKU. AEC-Q100 for automotive ICs, AEC-Q101 for discrete automotive, MIL-STD-883 for military/aerospace.']
  reach_compliant boolean [note: 'Indicates whether this SKU meets EU REACH regulation requirements for chemical substance registration and disclosure.']
  rohs_compliant boolean [note: 'Indicates whether this SKU meets EU RoHS directive requirements for restricted substances (lead, mercury, cadmium, hexavalent chromium, PBB, PBDE).']
  shippable_flag boolean [note: 'Indicates whether this SKU is currently authorized for shipment. May be false during quality holds, regulatory blocks, or export restrictions.']
  speed_grade varchar [note: 'Performance binning classification indicating maximum operating frequency or timing specification. Higher grades command premium pricing.']
  standard_cost_usd decimal(15,4) [note: 'Fully-loaded standard manufacturing cost in US dollars including wafer fabrication, assembly, test, and allocated overhead. Used for margin analysis and inventory valuation.']
  standard_pack_quantity varchar [note: 'Number of units in a standard shipping container (tape and reel, tray, tube). Orders are typically placed in multiples of this quantity.']
  temperature_range varchar [note: 'Qualified operating temperature range classification. Commercial (0-70C), Industrial (-40-85C), Automotive (-40-125C), Military (-55-125C), Extended (-40-105C).']
  unit_weight_grams decimal(10,3) [note: 'Weight of a single packaged unit in grams. Used for shipping cost calculation and logistics planning.']
  voltage_variant varchar [note: 'Core or I/O voltage specification variant for this SKU. Defines power supply requirements and compatibility with system voltage rails.']

  Note: 'Stock-keeping unit records representing orderable, shippable variants of catalog products. Each SKU captures the specific combination of package type, speed grade, temperature range, voltage variant, and qualification level (commercial, industrial, automotive AEC-Q100/Q101) that constitutes a distinct orderable item. Links to ic_catalog for the parent product definition and to inventory for stock tracking.'
}

Table product.family {
  family_id varchar [pk, note: 'Unique identifier for the product family. Primary key for the product family entity.']
  osat_vendor_id varchar [note: 'Foreign key linking to packaging.osat_vendor. Business justification: Product families have a designated preferred OSAT partner for strategic sourcing and capacity planning. Used in roadmap planning, OSAT capacity allocation, and supplier qualification decisions. The pl']
  parent_family_id varchar [note: 'Reference to the parent product family in the hierarchy. Supports multi-level taxonomy: portfolio → family → sub-family → product → variant. Null for top-level portfolio entries.']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: A product family is designed for a specific semiconductor process technology node (e.g., 5nm FinFET, 28nm planar). The family table currently stores process_node_nm as a denormalized integer, but proc']
  active_pcn_count varchar [note: 'Number of active PCNs currently in effect for this product family. Indicates ongoing changes to process, materials, or design that require customer notification and approval.']
  application_domain varchar [note: 'Specific application domain or use case this product family addresses (e.g., Advanced Driver Assistance Systems, Edge AI Inference, 5G Baseband Processing). Used for technical marketing and customer solution mapping.']
  business_unit varchar [note: 'Business unit or division responsible for this product family (e.g., Automotive Solutions, Mobile Computing, IoT and Embedded). Aligns with organizational structure and P&L responsibility.']
  code varchar [note: 'Unique alphanumeric code identifying the product family in external systems and customer communications. Used in PLM, ERP, and CRM systems for product taxonomy navigation.']
  created_timestamp timestamp [note: 'Timestamp when this product family record was first created in the system. Used for data lineage and audit trail.']
  description varchar [note: 'Detailed description of the product family including target applications, key features, and market positioning. Used for technical documentation and sales enablement.']
  design_center_location varchar [note: 'Primary design center location responsible for this product family (e.g., San Jose CA, Austin TX, Bangalore India). Used for resource planning and IP ownership tracking.']
  dfm_score decimal(5,2) [note: 'Design for Manufacturability score (0-100) indicating how well the product family design aligns with manufacturing best practices. Higher scores correlate with better yield and lower manufacturing risk.']
  dft_coverage_percent decimal(5,2) [note: 'Design for Testability coverage percentage indicating the proportion of circuit nodes accessible for ATPG (Automatic Test Pattern Generation). Higher coverage enables better defect detection during wafer test.']
  discontinuation_date date [note: 'Date when this product family was fully discontinued and removed from active catalog. No further production or shipments after this date.']
  ear_eccn_code varchar [note: 'Export Control Classification Number under US EAR regulations. Defines export licensing requirements for dual-use technology. Format: category (0-9), product group (A-E), reason for control (001-999).']
  eda_tool_suite varchar [note: 'Primary EDA tool suite used for design and verification of this product family (e.g., Cadence Virtuoso/Innovus, Synopsys Design Compiler/IC Compiler). Defines design methodology and tool licensing requirements.']
  eol_announcement_date date [note: 'Date when EOL was announced to customers via PCN (Product Change Notification). Triggers LTB (Last Time Buy) planning and customer migration activities.']
  fab_site_code varchar [note: 'Code identifying the primary fabrication facility for this product family. Links to fab capacity planning, process capability, and supply chain routing.']
  family_type varchar [note: 'Classification of the product family by semiconductor device type. Aligns with industry standard device categories for design, fabrication, and test planning. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|IP_Core|Discrete|Mixed_Signal — 7 candidates stripped; promote to reference product]']
  hierarchy_level varchar [note: 'Numeric level in the product family hierarchy (1=portfolio, 2=family, 3=sub-family, 4=product, 5=variant). Supports up to five levels of product taxonomy as defined in the product domain.']
  ip_core_count varchar [note: 'Number of reusable IP cores integrated into products in this family. Indicates design complexity and IP licensing requirements. Used for NRE (Non-Recurring Engineering) cost estimation.']
  itar_controlled_flag boolean [note: 'Indicates whether this product family is subject to ITAR export controls for defense-related technology. Restricts international sales and requires export licensing.']
  last_modified_timestamp timestamp [note: 'Timestamp when this product family record was last updated. Used for change tracking and data synchronization across systems.']
  lifecycle_status varchar [note: 'Current lifecycle stage of the product family: Concept (early planning), NPI (New Product Introduction), Active (volume production), Mature (stable production), Phase_Out (declining), EOL (End of Life announced), Discontinued (no longer available). Drives supply chain and customer communication strategies. [ENUM-REF-CANDIDATE: Concept|NPI|Active|Mature|Phase_Out|EOL|Discontinued — 7 candidates stripped; promote to reference product]']
  lithography_type varchar [note: 'Photolithography technology used for patterning (EUV Extreme Ultraviolet, DUV Deep Ultraviolet). Impacts design complexity, mask costs, and fab capability requirements.']
  ltb_date date [note: 'Final date for customers to place orders before product family is discontinued. Part of EOL process and customer lifecycle management.']
  modified_by_user varchar [note: 'User ID or name of the person who last modified this product family record. Used for audit trail and data governance.']
  name varchar [note: 'Business name of the product family (e.g., Cortex-M Series, Automotive MCU Family, RF Transceiver Family). Used in roadmap planning, marketing materials, and customer design-in targeting.']
  npi_start_date date [note: 'Date when this product family entered NPI phase. Marks the beginning of qualification, ramp, and early customer shipments. Used for TTM (Time to Market) tracking.']
  package_type varchar [note: 'Primary packaging technology for this product family (e.g., WLCSP Wafer-Level Chip Scale Package, BGA Ball Grid Array, QFN Quad Flat No-Lead, CoWoS Chip on Wafer on Substrate, InFO Integrated Fan-Out). Defines assembly process and thermal/electrical characteristics.']
  pdk_version varchar [note: 'Version of the Process Design Kit used for this product family. PDK contains design rules, device models, and technology files required for IC design. Critical for design-to-manufacturing alignment.']
  process_technology varchar [note: 'Transistor architecture technology used in the process node (FinFET, GAA Gate All Around, Planar, FD-SOI Fully Depleted Silicon On Insulator). Determines electrical characteristics and design rules.']
  product_line_manager varchar [note: 'Name of the product line manager responsible for roadmap, positioning, and lifecycle management of this product family. Business owner for strategic decisions.']
  qualification_standard varchar [note: 'Industry qualification standard this product family must meet (e.g., AEC-Q100 for automotive, MIL-STD-883 for military, JEDEC JESD47 for stress testing). Defines reliability testing requirements.']
  reach_compliant_flag boolean [note: 'Indicates whether this product family complies with EU REACH Regulation for chemical substance safety. Required for European market sales and supply chain transparency.']
  rohs_compliant_flag boolean [note: 'Indicates whether this product family is designed to comply with EU RoHS Directive restricting hazardous substances in electronic equipment. Critical for European market access.']
  target_market_segment varchar [note: 'Primary market segment this product family targets. Used for roadmap planning, pricing strategy, and customer design-in targeting. Aligns with business unit structure and go-to-market strategy. [ENUM-REF-CANDIDATE: Computing|Mobile|Automotive|AI_ML|IoT|Industrial|Consumer|Networking|Data_Center — 9 candidates stripped; promote to reference product]']
  target_performance_metric varchar [note: 'Key performance metric and target value for this product family (e.g., 3.5 GHz clock frequency, 100 TOPS AI performance, 10 Gbps throughput). Used for competitive analysis and roadmap planning.']
  target_power_mw decimal(12,3) [note: 'Target typical power consumption in milliwatts for this product family. Part of PPA (Power Performance Area) metrics used for competitive positioning and customer design-in evaluation.']
  target_yield_percent decimal(5,2) [note: 'Target manufacturing yield percentage (good dies per wafer) for this product family at volume production. Used for cost modeling, capacity planning, and fab performance tracking.']
  typical_die_size_mm2 decimal(10,3) [note: 'Representative die size in square millimeters for products in this family. Used for wafer yield modeling, cost estimation, and capacity planning. Actual die sizes may vary by specific product variant.']
  volume_production_date date [note: 'Date when this product family achieved volume production status (Active lifecycle). Indicates full manufacturing qualification and capacity availability.']

  Note: 'Hierarchical grouping of related IC products into product families and sub-families (e.g., Cortex-class SoCs, automotive MCU family, RF transceiver family). Manages the multi-level product taxonomy used for roadmap planning, pricing strategy, and customer design-in targeting. Supports up to five levels of hierarchy: portfolio → family → sub-family → product → variant.'
}

Table product.process_node {
  process_node_id varchar [pk, note: 'Primary key for process_node']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Each semiconductor process node is manufactured at a specific foundry (supplier) — e.g., TSMC 5nm, Samsung 3nm. Fab engineers and supply chain teams need this link for foundry capacity planning, multi']
  active_product_count varchar [note: 'Current count of active product SKUs (ICs, SoCs, ASICs, FPGAs) assigned to this process node. Used for capacity planning and node utilization analysis.']
  baseline_yield_percent decimal(5,2) [note: 'Expected baseline yield percentage (good dies per wafer) for this process node under standard manufacturing conditions. Used for cost modeling and capacity planning. Confidential manufacturing metric.']
  cost_per_wafer_usd decimal(15,2) [note: 'Standard manufacturing cost per wafer in USD for this process node. Includes FEOL (Front End of Line), MOL (Middle of Line), and BEOL (Back End of Line) processing costs. Confidential financial data used for product costing and NRE (Non-Recurring Engineering) estimation.']
  created_timestamp timestamp [note: 'Timestamp when this process node record was first created in the system. Audit trail for data lineage and compliance reporting.']
  cycle_time_days decimal(8,2) [note: 'Standard manufacturing cycle time in days from wafer start to wafer completion for this process node. Includes all FEOL, MOL, and BEOL processing steps. Critical for TTM (Time to Market) planning.']
  design_rule_complexity varchar [note: 'Qualitative assessment of design rule complexity for DFM (Design for Manufacturability) and DFT (Design for Testability). Higher complexity requires more sophisticated EDA tools and longer design cycles.']
  environmental_compliance_status varchar [note: 'Compliance status with environmental regulations including RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), and TSCA (Toxic Substances Control Act). Compliant indicates full adherence; Non-Compliant indicates violations; Under Review indicates pending assessment.']
  eol_announcement_date date [note: 'Date when EOL (End of Life) was officially announced for this process node via PCN (Product Change Notification). Triggers LTB (Last Time Buy) planning for affected products. Null if node is still active.']
  export_control_classification varchar [note: 'Export control classification under ITAR (International Traffic in Arms Regulations), EAR (Export Administration Regulations), or BIS (Bureau of Industry and Security) frameworks. Determines international transfer restrictions and CHIPS Act compliance requirements.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent update to this process node record. Tracks data currency and change history for audit and compliance purposes.']
  lifecycle_stage varchar [note: 'Current lifecycle stage of the process node. NPI (New Product Introduction) indicates initial ramp; Growth indicates volume expansion; Mature indicates stable production; Decline indicates phasing out; EOL (End of Life) indicates discontinued with LTB (Last Time Buy) notifications issued.']
  lithography_type varchar [note: 'Primary lithography technology used for patterning at this process node. EUV (Extreme Ultraviolet Lithography), DUV (Deep Ultraviolet Lithography), I-Line, G-Line, or Mixed for multi-generation processes.']
  ltb_deadline_date date [note: 'Final date for customers to place orders for products manufactured on this process node before complete discontinuation. Null if node is not in EOL status.']
  metal_layer_count varchar [note: 'Total number of metal interconnect layers available in the BEOL (Back End of Line) stack for this process node. Higher counts enable more complex routing and integration.']
  minimum_feature_size_nm decimal(10,3) [note: 'The smallest manufacturable feature dimension in nanometers for this process node. Represents the critical dimension capability and defines the node\'s resolution limit.']
  modified_by_user varchar [note: 'User identifier or system account that performed the last modification to this record. Supports audit trail and accountability requirements.']
  multi_patterning_layers varchar [note: 'Number of critical layers requiring multi-patterning techniques (double, triple, or quad patterning) to achieve target feature sizes. Zero indicates single-exposure capability. Higher counts increase mask costs and cycle time.']
  node_code varchar [note: 'Standardized alphanumeric code or identifier for the process node used across systems and documentation. Serves as the business key for external references.']
  node_generation varchar [note: 'The technology generation or family classification (e.g., sub-3nm, 5nm-class, 7nm-class, mature node). Groups nodes by manufacturing era and capability tier.']
  node_name varchar [note: 'Human-readable name of the semiconductor process technology node (e.g., 3nm GAA, 5nm FinFET, 7nm EUV, 28nm HKMG, 180nm BCD). This is the industry-standard designation for the manufacturing process generation.']
  notes varchar [note: 'Free-text field for additional technical notes, special considerations, design guidelines, or process-specific information not captured in structured fields. Used by process engineers and design teams.']
  opc_required_flag boolean [note: 'Indicates whether OPC (Optical Proximity Correction) is mandatory for mask preparation at this process node. True for advanced nodes where lithography effects require computational correction.']
  pdk_release_date date [note: 'Date when the current PDK version was officially released and made available to design teams. Tracks PDK maturity and design enablement timeline.']
  pdk_version varchar [note: 'Version identifier of the PDK (Process Design Kit) that defines design rules, device models, and technology files for EDA (Electronic Design Automation) tools. Critical for DFM (Design for Manufacturability) compliance.']
  power_performance_area_rating varchar [note: 'Qualitative assessment of the process node\'s PPA (Power Performance Area) characteristics relative to industry benchmarks. Excellent indicates best-in-class metrics; Limited indicates mature node with constrained PPA.']
  qualification_date date [note: 'Date when the process node achieved full production qualification status and was approved for volume manufacturing. Null if not yet qualified.']
  qualification_status varchar [note: 'Current qualification and readiness state of the process node for production use. Qualified indicates full production readiness; In Qualification indicates active validation; Pre-Production indicates pilot runs; Development indicates early-stage R&D; Deprecated indicates phasing out; Obsolete indicates end-of-life.']
  supported_device_types varchar [note: 'Comma-separated list of device types and IP (Intellectual Property Core) categories supported by this process node (e.g., Logic, SRAM, Analog, RF, High-Voltage, IO). Defines the breadth of design capabilities.']
  technology_readiness_level varchar [note: 'TRL score from 1 (basic research) to 9 (full production deployment) indicating the maturity of the process node technology. Used for R&D planning and risk assessment.']
  transistor_architecture varchar [note: 'The fundamental transistor structure used in this process node. GAA (Gate All Around), FinFET (Fin Field-Effect Transistor), Planar, FDSOI (Fully Depleted Silicon On Insulator), or Other specialized architectures.']
  wafer_size_mm varchar [note: 'Standard wafer diameter in millimeters supported by this process node (e.g., 300mm, 200mm, 150mm). Determines die count per wafer and manufacturing economics.']

  Note: 'Reference master for semiconductor process technology nodes (e.g., 3nm GAA, 5nm FinFET, 7nm EUV, 28nm HKMG, 180nm BCD). Captures node name, lithography generation (EUV/DUV), foundry source, PDK version, minimum feature size, metal layer count, and qualification status. Used to assign products to manufacturing process capabilities and to track node-level yield and cost baselines.'
}

Table product.product_spec {
  product_spec_id varchar [pk, note: 'Unique identifier for the product specification record. Primary key.']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Product specs (thermal resistance, pin count, operating conditions) are package-specific. Used in datasheet generation, AEC-Q qualification reports, and customer design-in support. The plain \'package_']
  primary_product_ic_catalog_id varchar [note: 'Reference to the parent product (IC, SoC, ASIC, FPGA, IP core, or discrete device) for which this specification applies.']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Product specifications (PPA metrics — Power, Performance, Area) are inherently tied to the process node on which the IC is fabricated. The product_spec table currently stores process_node_nm as a deno']
  product_reference_ic_catalog_id varchar [note: 'FK to product.ic_catalog.ic_catalog_id — Product specifications describe a specific IC product. Must reference the catalog entry.']
  approval_date date [note: 'Date when this specification was formally approved for release to manufacturing or customers.']
  approved_by varchar [note: 'Name or identifier of the engineering authority who approved this specification for release.']
  automotive_grade varchar [note: 'AEC-Q100 automotive qualification grade indicating temperature range and reliability requirements (Grade 0: -40°C to 150°C, Grade 1: -40°C to 125°C, Grade 2: -40°C to 105°C, Grade 3: -40°C to 85°C).']
  characterization_date date [note: 'Date when this specification was characterized and validated through silicon testing or simulation.']
  created_timestamp timestamp [note: 'Timestamp when this product specification record was first created in the system.']
  data_retention_years varchar [note: 'Guaranteed data retention period in years for non-volatile memory components at specified temperature.']
  die_area_achieved_mm2 decimal(12,6) [note: 'Actual measured silicon die area in square millimeters (mm²) from physical layout. Part of PPA (Power-Performance-Area) metrics.']
  die_area_target_mm2 decimal(12,6) [note: 'Target silicon die area in square millimeters (mm²). Part of PPA (Power-Performance-Area) metrics.']
  dynamic_power_achieved_mw decimal(12,4) [note: 'Actual measured or characterized dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  dynamic_power_target_mw decimal(12,4) [note: 'Target dynamic power consumption in milliwatts (mW) during active switching operation at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  endurance_cycles varchar [note: 'Number of program/erase cycles guaranteed for non-volatile memory components (applicable to flash, EEPROM).']
  esd_protection_level_kv decimal(6,3) [note: 'Electrostatic discharge protection rating in kilovolts (kV) per JEDEC standards (e.g., HBM, CDM models).']
  functional_safety_rating varchar [note: 'Functional safety certification level achieved by the product. ISO 26262 ASIL (Automotive Safety Integrity Level) A through D for automotive applications; IEC 61508 SIL (Safety Integrity Level) 1 through 4 for industrial applications. [ENUM-REF-CANDIDATE: none|iso_26262_asil_a|iso_26262_asil_b|iso_26262_asil_c|iso_26262_asil_d|iec_61508_sil_1|iec_61508_sil_2|iec_61508_sil_3|iec_61508_sil_4 — 9 candidates stripped; promote to reference product]']
  gate_count varchar [note: 'Total number of logic gates (or gate equivalents) in the design, representing design complexity.']
  interface_protocols varchar [note: 'Comma-separated list of supported communication interface protocols (e.g., PCIe, USB, DDR4, MIPI, SPI, I2C, CAN, Ethernet).']
  io_count varchar [note: 'Total number of input/output pins or pads available on the integrated circuit for signal connectivity.']
  leakage_power_achieved_mw decimal(12,4) [note: 'Actual measured or characterized static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  leakage_power_target_mw decimal(12,4) [note: 'Target static leakage power consumption in milliwatts (mW) when the circuit is idle at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  max_frequency_achieved_mhz decimal(12,3) [note: 'Actual measured or characterized maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  max_frequency_target_mhz decimal(12,3) [note: 'Target maximum operating frequency in megahertz (MHz) at nominal conditions. Part of PPA (Power-Performance-Area) metrics.']
  memory_configuration varchar [note: 'Description of on-chip memory architecture including SRAM, cache, ROM, and embedded flash sizes and organization (e.g., 256KB L2 Cache, 2MB SRAM, 512KB ROM).']
  modified_timestamp timestamp [note: 'Timestamp when this product specification record was last modified.']
  notes varchar [note: 'Additional notes, caveats, or clarifications regarding this product specification, including test conditions, measurement methodology, or known limitations.']
  operating_condition_corner varchar [note: 'Process-voltage-temperature (PVT) corner at which this specification is characterized. Typical represents nominal conditions; best/worst case represent performance extremes; slow/fast combinations represent process variation corners. [ENUM-REF-CANDIDATE: typical|best_case|worst_case|slow_slow|fast_fast|slow_fast|fast_slow — 7 candidates stripped; promote to reference product]']
  operating_temperature_max_c decimal(6,2) [note: 'Maximum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.']
  operating_temperature_min_c decimal(6,2) [note: 'Minimum junction temperature in degrees Celsius at which the product is guaranteed to function within specification.']
  operating_voltage_max_v decimal(6,3) [note: 'Maximum operating voltage in volts (V) at which the product is guaranteed to function within specification.']
  operating_voltage_min_v decimal(6,3) [note: 'Minimum operating voltage in volts (V) at which the product is guaranteed to function within specification.']
  operating_voltage_nominal_v decimal(6,3) [note: 'Nominal (typical) operating voltage in volts (V) for standard operation.']
  reach_compliant boolean [note: 'Indicates whether the product meets EU REACH regulation requirements for chemical substance registration and restriction.']
  rohs_compliant boolean [note: 'Indicates whether the product meets EU RoHS directive requirements for restriction of hazardous substances (lead, mercury, cadmium, etc.).']
  security_features varchar [note: 'Comma-separated list of implemented hardware security features (e.g., Secure Boot, TrustZone, AES-256, SHA-256, Hardware Root of Trust, Anti-Tamper).']
  spec_status varchar [note: 'Current lifecycle status of this product specification (Draft: under development, Preliminary: pre-silicon or early silicon, Final: production-qualified, Obsolete: superseded by newer version).']
  transistor_architecture varchar [note: 'Type of transistor structure used in the process technology (Planar, FinFET, GAA - Gate All Around, Nanosheet, Nanowire).']
  transistor_count varchar [note: 'Total number of transistors in the integrated circuit design.']
  version varchar [note: 'Version number of this product specification, following semantic versioning (e.g., 1.0, 2.1, 3.0.1). Incremented with each specification revision.']

  Note: 'Detailed electrical, functional, and PPA (Power-Performance-Area) specifications for each IC product at given operating condition corners. Covers operating voltage range, temperature range, I/O count, interface protocols, memory configuration, security features, functional safety ratings (ISO 26262 ASIL, IEC 61508 SIL), plus target and achieved values for dynamic power, leakage power, maximum frequency, and die area. Supports multi-corner characterization and competitive PPA benchmarking.'
}

Table product.bom {
  bom_id varchar [pk, note: 'Unique identifier for the bill of materials header record. Primary key for the BOM entity.']
  assembly_process_flow_id varchar [note: 'Foreign key linking to packaging.assembly_process_flow. Business justification: In semiconductor PLM, a product BOM is authored against a specific assembly process flow — the flow determines step sequence, materials, and yield targets. Used in NPI BOM validation, process change i']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Each BOM revision is governed by a control plan defining inspection steps and process controls for that BOM configuration — required for IATF 16949 compliance and engineering change order management i']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: A semiconductor product BOM is structurally tied to a package type — substrate, leadframe, and mold compound selections all depend on it. Used in NPI BOM creation, material planning, and package-speci']
  primary_bom_ic_catalog_id varchar [note: 'Reference to the parent IC product or assembly that this BOM defines. Links to the product master catalog.']
  substrate_bom_id varchar [note: 'Foreign key linking to packaging.substrate_bom. Business justification: A product BOM references a substrate BOM as its primary packaging material component. Standard semiconductor PLM hierarchy used in material requirements planning, cost rollup, and supply chain risk as']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: BOMs often designate a contract manufacturer or primary supplier for the overall assembly, needed for production planning.']
  to_ic_catalog_id varchar [note: 'FK to product.ic_catalog.ic_catalog_id — Each BOM defines the component structure of a specific IC product. The BOM header must reference the product it describes.']
  alternative_bom_indicator varchar [note: 'Identifier for alternative BOM configurations for the same product. Used when multiple valid component combinations exist (e.g., different suppliers, different process nodes, or design variants).']
  approval_date date [note: 'Date when this BOM was formally approved for use. Marks the transition from draft/review to approved status.']
  base_quantity decimal(18,6) [note: 'The quantity of the parent product that this BOM defines. Typically 1 for single-unit BOMs, but may be higher for batch or lot-based manufacturing. All component quantities in BOM lines are relative to this base quantity.']
  base_unit_of_measure varchar [note: 'Unit of measure for the base quantity, such as EA (each), LOT, WAFER, or other semiconductor-specific units. Must align with product master UOM.']
  bom_number varchar [note: 'Business identifier for the BOM, typically a human-readable code used across PLM and ERP systems for tracking and reference.']
  bom_status varchar [note: 'Current lifecycle status of the BOM. Draft indicates work in progress, in_review indicates pending approval, approved indicates ready for use, active indicates currently in production, frozen indicates locked for manufacturing, obsolete indicates no longer valid, superseded indicates replaced by newer revision. [ENUM-REF-CANDIDATE: draft|in_review|approved|active|frozen|obsolete|superseded — 7 candidates stripped; promote to reference product]']
  bom_type varchar [note: 'Classification of the BOM by its intended use: engineering BOM (EBOM) for design, manufacturing BOM (MBOM) for production, service BOM for maintenance, planning BOM for forecasting, as-designed for original specification, or as-built for actual production configuration.']
  conflict_minerals_compliant_flag boolean [note: 'Indicates whether the BOM and all its components are free from conflict minerals (tin, tantalum, tungsten, gold) sourced from conflict regions, per Dodd-Frank Act Section 1502 requirements.']
  cost_currency_code varchar [note: 'ISO 4217 three-letter currency code for the total material cost. Typically USD for semiconductor industry but may vary by region.']
  created_timestamp timestamp [note: 'Timestamp when this BOM record was first created in the system. Part of the audit trail for data lineage and compliance.']
  critical_material_flag boolean [note: 'Indicates whether this BOM contains components classified as critical materials (long lead time, single source, strategic importance). Used for supply chain risk management.']
  ear_classification varchar [note: 'Export Control Classification Number (ECCN) or other EAR classification for this BOM. Determines export licensing requirements and restrictions.']
  effective_end_date date [note: 'Date after which this BOM revision is no longer valid for new production orders. Null indicates the BOM is currently active with no planned end date.']
  effective_start_date date [note: 'Date from which this BOM revision becomes valid and can be used for manufacturing, procurement, and costing. Critical for managing engineering changes and product transitions.']
  engineering_change_order_number varchar [note: 'Reference to the engineering change order that created or last modified this BOM revision. Critical for change traceability and audit compliance.']
  eol_date date [note: 'Planned or actual end-of-life date for this BOM. After this date, the product is no longer manufactured or supported.']
  explosion_type varchar [note: 'Defines how the BOM should be exploded for planning and costing: single-level shows only immediate children, multi-level shows full hierarchy, summarized shows consolidated component totals.']
  external_bom_reference varchar [note: 'Original BOM identifier from the source PLM or ERP system. Maintains traceability to upstream systems and enables cross-system reconciliation.']
  itar_controlled_flag boolean [note: 'Indicates whether this BOM contains components or technology subject to ITAR export control regulations. Critical for defense and aerospace semiconductor applications.']
  last_modified_timestamp timestamp [note: 'Timestamp when this BOM record was last updated. Tracks the most recent change for change management and audit purposes.']
  lot_size decimal(18,6) [note: 'Standard production lot size for which this BOM is optimized. Used in material requirements planning (MRP) and capacity planning calculations.']
  ltb_notification_date date [note: 'Date when Last Time Buy notification was issued for this BOM, indicating the product is approaching end-of-life and customers should place final orders.']
  pcn_number varchar [note: 'Product Change Notification number issued to customers when this BOM revision represents a material change to the product. Required for customer communication and approval.']
  plant_code varchar [note: 'Manufacturing plant or fabrication facility (FAB) where this BOM is applicable. Different plants may have different BOMs for the same product due to process variations or equipment differences.']
  production_version varchar [note: 'Production version identifier linking this BOM to a specific routing or process flow. Enables coordination between BOM and manufacturing process definitions.']
  reach_compliant_flag boolean [note: 'Indicates whether the BOM and all its components meet REACH regulation requirements for chemical substance registration and safety. Rolled up from component-level compliance data.']
  revision varchar [note: 'Revision level or version of the BOM, incremented with each engineering change. Critical for change management and traceability.']
  rohs_compliant_flag boolean [note: 'Indicates whether the BOM and all its components meet RoHS directive requirements for restriction of hazardous substances. Rolled up from component-level compliance data.']
  scrap_percentage decimal(5,2) [note: 'Expected scrap or yield loss percentage at the BOM level. Used to adjust material requirements and costing. Typical semiconductor yield losses are factored here.']
  total_component_count varchar [note: 'Total number of distinct component line items in this BOM. Provides quick visibility into BOM complexity without querying detail records.']
  total_material_cost decimal(18,4) [note: 'Rolled-up total material cost for all components in this BOM, calculated from component costs and quantities. Used for product costing and margin analysis.']
  usage varchar [note: 'Intended usage context for this BOM: production for manufacturing execution, costing for financial analysis, engineering for design reference, maintenance for service operations, or sales for customer quotations.']

  Note: 'Bill of Materials header records defining the hierarchical component structure of each IC product assembly. Captures BOM revision, effectivity dates, BOM type (engineering, manufacturing, service), approval status, and overall RoHS/REACH compliance rollup. Parent entity for bom_line detail records. Integrates with PLM and ERP systems for manufacturing execution and change management.'
}

Table product.bom_line {
  bom_line_id varchar [pk, note: 'Unique identifier for the BOM line item. Primary key for the BOM line entity.']
  component_ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: In semiconductor BOMs, sub-components are frequently ICs from the same product catalog (e.g., a SoC BOM may include memory ICs, power management ICs, or interface ICs that are themselves catalog produ']
  parent_line_bom_line_id varchar [note: 'Reference to the parent BOM line in a multi-level BOM structure. Null for top-level components. Enables recursive BOM explosion and indented BOM reports.']
  primary_bom_id varchar [note: 'Reference to the parent BOM header that this line belongs to. Links the line item to the overall product BOM structure.']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Critical BOM line items (components) reference incoming quality specifications defining acceptance criteria for component inspection — used in supplier qualification programs and incoming quality cont']
  substrate_bom_id varchar [note: 'Foreign key linking to packaging.substrate_bom. Business justification: Individual BOM lines reference specific substrate BOMs as components in the BOM explosion. Used in MRP material requirements calculation, approved vendor list enforcement, and conflict minerals tracea']
  supplier_id varchar [note: 'Reference to the primary supplier or vendor for this component. Links to supplier master data for procurement and supply chain management.']
  to_bom_id varchar [note: 'FK to product.bom.bom_id — Classic header-line relationship. BOM lines are meaningless without their parent BOM header.']
  active_flag boolean [note: 'Indicates whether this BOM line is currently active and should be used in production planning and costing. Inactive lines are retained for historical reference but excluded from current operations.']
  approved_substitute_part_numbers varchar [note: 'Comma-separated list of approved alternate or substitute part numbers that can be used in place of the primary component. Supports supply chain flexibility and risk mitigation.']
  assembly_process_code varchar [note: 'Code identifying the assembly or packaging process used to integrate this component (e.g., wirebond, flip-chip, CoWoS, InFO). Links to process routing and manufacturing execution.']
  bom_level varchar [note: 'The hierarchical level of this component in the multi-level BOM structure. Level 0 is the finished product, level 1 is direct sub-assembly, level 2 is sub-component of level 1, and so on. Supports BOM explosion for cost rollup and supply chain analysis.']
  component_description varchar [note: 'Detailed textual description of the component, including technical specifications, material properties, and functional purpose within the assembly.']
  component_part_number varchar [note: 'The unique part number or SKU of the component material used in this BOM line. May reference die, package substrate, passive components, interposer, or other materials.']
  component_type varchar [note: 'Classification of the component by its functional role in the semiconductor assembly. Includes die (silicon chip), package substrate, passive components (resistors, capacitors), interposer, leadframe, wirebond, solder ball, underfill material, and mold compound. [ENUM-REF-CANDIDATE: die|package_substrate|passive|interposer|leadframe|wirebond|solder_ball|underfill|mold_compound — 9 candidates stripped; promote to reference product]']
  conflict_minerals_status varchar [note: 'Compliance status for conflict minerals (tin, tantalum, tungsten, gold) sourcing per Dodd-Frank Act Section 1502. Tracks whether component supply chain is free from conflict region sourcing.']
  cost_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the standard cost. Supports multi-currency costing and global supply chain operations.']
  created_timestamp timestamp [note: 'The date and time when this BOM line record was first created in the system. Supports audit trail and data lineage tracking.']
  critical_component_flag boolean [note: 'Indicates whether this component is critical to product functionality, quality, or supply chain continuity. Used for risk assessment and inventory planning.']
  ear_eccn_code varchar [note: 'The ECCN code assigned under US Export Administration Regulations, classifying the component for export control purposes. Required for international trade compliance.']
  effectivity_end_date date [note: 'The date on which this BOM line becomes obsolete or is replaced. Null for currently active components. Supports phase-in/phase-out scenarios and Product Change Notification (PCN) tracking.']
  effectivity_start_date date [note: 'The date from which this BOM line becomes effective. Supports date-based BOM versioning and engineering change management.']
  engineering_change_order_number varchar [note: 'The ECO number that introduced or last modified this BOM line. Provides traceability to engineering change management processes.']
  itar_controlled_flag boolean [note: 'Indicates whether the component is subject to ITAR export controls for defense-related articles and services. Critical for aerospace and defense semiconductor applications.']
  last_modified_timestamp timestamp [note: 'The date and time when this BOM line record was last updated. Supports change tracking and audit trail.']
  line_number varchar [note: 'Sequential line number within the parent BOM, used for ordering and referencing specific components in the assembly hierarchy.']
  make_or_buy_indicator varchar [note: 'Indicates whether the component is manufactured in-house (make), procured externally (buy), or transferred from another plant (transfer). Drives procurement and production planning logic.']
  manufacturer_name varchar [note: 'The name of the original equipment manufacturer (OEM) or component manufacturer. May differ from the supplier if purchased through distributors.']
  manufacturer_part_number varchar [note: 'The manufacturers original part number for the component. Used for cross-referencing and supplier communication.']
  notes varchar [note: 'Free-text notes or comments providing additional context, assembly instructions, quality requirements, or special handling instructions for this BOM line.']
  phantom_bom_flag boolean [note: 'Indicates whether this is a phantom or transient sub-assembly that is not stocked or tracked as inventory. Phantom BOMs are exploded through during MRP but not manufactured as discrete items.']
  procurement_lead_time_days varchar [note: 'The typical lead time in days required to procure this component from suppliers. Used for material requirements planning (MRP) and supply chain risk analysis.']
  quantity_per_assembly decimal(18,6) [note: 'The quantity of this component required to produce one unit of the parent assembly. Supports fractional quantities for materials measured by weight or volume.']
  reach_compliant_flag boolean [note: 'Indicates whether the component complies with EU REACH Regulation for chemical substance registration and safety. Required for European market access.']
  reference_designator varchar [note: 'The reference designator or location identifier for the component on the physical layout or assembly drawing (e.g., U1, C23, R45). Links BOM to physical design.']
  rohs_compliant_flag boolean [note: 'Indicates whether the component complies with EU RoHS Directive restricting hazardous substances (lead, mercury, cadmium, hexavalent chromium, PBB, PBDE). Critical for regulatory compliance and market access.']
  scrap_factor_percent decimal(5,2) [note: 'Expected scrap or yield loss percentage for this component during manufacturing. Used to calculate net material requirements accounting for process losses.']
  single_source_flag boolean [note: 'Indicates whether this component is available from only one supplier, representing a supply chain risk. Triggers dual-sourcing initiatives and risk mitigation strategies.']
  standard_cost decimal(18,4) [note: 'The standard unit cost of the component in the base currency. Used for BOM cost rollup, product costing, and margin analysis.']
  unit_of_measure varchar [note: 'The unit in which the component quantity is expressed. Common values include EA (each), KG (kilogram), G (gram), L (liter), ML (milliliter), M (meter), MM (millimeter), WAFER, DIE. [ENUM-REF-CANDIDATE: EA|KG|G|L|ML|M|MM|WAFER|DIE — 9 candidates stripped; promote to reference product]']

  Note: 'Line items within a product BOM, each representing a component or sub-assembly. Captures component part number, quantity per assembly, UoM, component type (die, package substrate, passive, interposer), approved substitutes, lead time, and compliance attributes (RoHS, REACH, conflict minerals). Supports multi-level BOM explosion for cost rollup and supply chain risk analysis.'
}

Table product.compliance_cert {
  compliance_cert_id varchar [pk, note: 'Unique identifier for the product compliance certification record.']
  cert_family_id varchar [note: 'Foreign key linking to product.family. Business justification: Compliance certifications in the semiconductor industry frequently apply at the product family level. Automotive qualifications (AEC-Q100/Q101/Q200), functional safety certifications (ISO 26262, IEC 6']
  cert_sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Compliance certifications in the semiconductor industry can be specific to orderable SKU variants, not just the base IC catalog product. For example, a lead-free (RoHS) certification may apply to a sp']
  cert_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Compliance certificates (RoHS, REACH, conflict minerals, AEC-Q) in semiconductors are issued by or validated against specific suppliers. Regulatory audits and customer compliance declarations require ']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: AEC-Q100/Q101 and automotive compliance certifications require reference to the specific final test run that generated qualification evidence. test_report_number is a denormalized reference to final_t']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Lot-level compliance certifications (AEC-Q100, JEDEC) reference the specific inspection lot tested — required for lot traceability in automotive qualification, customer audit responses, and certificat']
  kgd_certification_id varchar [note: 'Foreign key linking to quality.quality_kgd_certification. Business justification: KGD compliance certifications reference the KGD certification record for die-level shipment compliance and customer-facing certification documentation — essential for bare-die supply chain traceabilit']
  primary_ic_catalog_id varchar [note: 'FK to product.ic_catalog.ic_catalog_id — Compliance certifications are obtained for specific products or SKUs. Required for export control screening and customer documentation.']
  reliability_test_id varchar [note: 'Foreign key linking to quality.reliability_test. Business justification: AEC-Q100/JEDEC compliance certifications are substantiated by specific reliability test results — the cert must reference the qualifying reliability test for audit traceability, recertification tracki']
  applicable_markets varchar [note: 'Comma-separated list of geographic markets, regions, or countries where this compliance certification is recognized and valid (e.g., USA, EU, CHN, JPN, KOR). Uses ISO 3166-1 alpha-3 country codes.']
  applicable_regions varchar [note: 'Comma-separated list of regulatory regions or jurisdictions where this certification applies (e.g., North America, European Union, Asia-Pacific, EMEA).']
  auditor_name varchar [note: 'Name of the lead auditor or assessor from the certification body who conducted the compliance assessment.']
  automotive_grade_certified boolean [note: 'Boolean flag indicating whether the product has achieved automotive-grade qualification certification (e.g., AEC-Q100 for ICs, AEC-Q101 for discrete semiconductors) for use in automotive applications.']
  certification_body varchar [note: 'Name of the accredited third-party organization or regulatory authority that issued the compliance certification (e.g., TÜV, UL, Intertek, SGS, Bureau Veritas).']
  certification_number varchar [note: 'Unique certificate number or identifier issued by the certification body for this compliance certification.']
  certification_scope varchar [note: 'Detailed description of the scope of the certification, including specific product variants, process nodes, package types, or application domains covered by this certification.']
  certification_status varchar [note: 'Current lifecycle status of the compliance certification indicating whether it is active and valid, expired, pending approval, suspended, revoked, or under review.']
  certification_type varchar [note: 'Type of regulatory or standards certification obtained. RoHS (Restriction of Hazardous Substances), REACH (Registration Evaluation Authorization and Restriction of Chemicals), TSCA (Toxic Substances Control Act), AEC-Q100/Q101 (Automotive Electronics Council qualification standards), ISO 26262 (Automotive Functional Safety), IEC 61508 (Functional Safety), UL (Underwriters Laboratories), CE (Conformité Européenne), FCC (Federal Communications Commission), ITAR (International Traffic in Arms Regulations), EAR (Export Administration Regulations). [ENUM-REF-CANDIDATE: RoHS|REACH|TSCA|AEC-Q100|AEC-Q101|ISO 26262|IEC 61508|UL|CE|FCC|ITAR|EAR — 12 candidates stripped; promote to reference product]']
  compliance_notes varchar [note: 'Free-text field for additional notes, exceptions, conditions, or special handling instructions related to this compliance certification.']
  conflict_minerals_declaration varchar [note: 'Declaration of conflict minerals (tin, tantalum, tungsten, gold - 3TG) sourcing and compliance status with Dodd-Frank Act Section 1502 and OECD Due Diligence Guidance.']
  created_timestamp timestamp [note: 'Timestamp when this compliance certification record was first created in the system.']
  customer_specific_requirement varchar [note: 'Description of any customer-specific compliance requirements or certifications that this record addresses beyond standard regulatory requirements.']
  ear_controlled boolean [note: 'Boolean flag indicating whether the product is subject to EAR (Export Administration Regulations) export controls administered by the Bureau of Industry and Security.']
  effective_date date [note: 'Date from which the compliance certification becomes valid and enforceable for the product.']
  environmental_standard varchar [note: 'Environmental management system standard under which this certification was issued (e.g., ISO 14001, ISO 50001 for energy management).']
  expiry_date date [note: 'Date on which the compliance certification expires and requires renewal or re-certification. Nullable for certifications without expiration.']
  export_control_classification varchar [note: 'Export control classification code or category assigned to the product under this certification (e.g., ECCN - Export Control Classification Number under EAR, or USML category under ITAR).']
  functional_safety_level varchar [note: 'Functional safety integrity level achieved by the product under ISO 26262 (ASIL A/B/C/D for automotive) or IEC 61508 (SIL 1/2/3/4 for industrial) standards. ASIL (Automotive Safety Integrity Level), SIL (Safety Integrity Level). [ENUM-REF-CANDIDATE: ASIL_A|ASIL_B|ASIL_C|ASIL_D|SIL_1|SIL_2|SIL_3|SIL_4|not_applicable — 9 candidates stripped; promote to reference product]']
  hazardous_substance_declaration varchar [note: 'Detailed declaration of hazardous substances present in the product, including substance names, CAS (Chemical Abstracts Service) numbers, concentration levels, and compliance status with RoHS, REACH, and TSCA regulations.']
  internal_owner varchar [note: 'Name or employee identifier of the internal compliance manager or product quality engineer responsible for maintaining this certification.']
  issue_date date [note: 'Date on which the compliance certification was officially issued by the certification body.']
  itar_controlled boolean [note: 'Boolean flag indicating whether the product is subject to ITAR (International Traffic in Arms Regulations) export controls and requires special handling for international shipments.']
  last_updated_timestamp timestamp [note: 'Timestamp when this compliance certification record was last modified or updated in the system.']
  pcn_reference_number varchar [note: 'Reference number of the Product Change Notification (PCN) that triggered this certification or recertification, if applicable.']
  quality_management_standard varchar [note: 'Quality management system standard under which this certification was issued (e.g., ISO 9001, IATF 16949, AS9100, ISO 13485).']
  reach_compliant boolean [note: 'Boolean flag indicating whether the product is compliant with REACH Regulation EC 1907/2006 governing the registration, evaluation, authorization, and restriction of chemicals in the European Union.']
  recertification_frequency_months varchar [note: 'Number of months between required recertification cycles. Null if recertification is not required or is event-driven rather than time-based.']
  recertification_required boolean [note: 'Boolean flag indicating whether this certification requires periodic recertification or renewal (True) or is a one-time certification (False).']
  recertification_trigger_events varchar [note: 'Comma-separated list of business events that trigger mandatory recertification (e.g., design change, process node migration, package change, supplier change, PCN issuance, material substitution).']
  restricted_countries varchar [note: 'Comma-separated list of ISO 3166-1 alpha-3 country codes to which export or sale of this product is restricted or prohibited under applicable export control regulations.']
  rohs_compliant boolean [note: 'Boolean flag indicating whether the product is compliant with RoHS (Restriction of Hazardous Substances) Directive 2011/65/EU restricting the use of specific hazardous materials in electrical and electronic equipment.']
  supporting_documentation_url varchar [note: 'URL or file path to the repository location containing supporting documentation, test reports, certificates, and compliance declarations for this certification.']
  test_laboratory varchar [note: 'Name of the accredited testing laboratory that performed the compliance testing and analysis supporting this certification.']

  Note: 'Product compliance certification records tracking regulatory and standards certifications obtained for each product or SKU, including RoHS, REACH, TSCA, AEC-Q100/Q101, ISO 26262, IEC 61508, UL, CE, FCC, and ITAR classification. Captures certification body, certificate number, issue date, expiry date, applicable markets/regions, and re-certification trigger events. Supports export control screening and customer compliance documentation requests.'
}

Table customer.account {
  account_id varchar [pk, note: 'Unique identifier for the account record.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Required for Preferred Supplier selection per account, used in sourcing strategy and procurement reports.']
  account_status varchar [note: 'Current lifecycle status of the account.']
  account_type varchar [note: 'Classification of the account within the semiconductor ecosystem.']
  audit_status varchar [note: 'Result of the most recent compliance audit for the account.']
  closure_date date [note: 'Date when the account was closed or deactivated, if applicable.']
  communication_preference varchar [note: 'Preferred channel for account communications.']
  compliance_status varchar [note: 'Current compliance posture of the account with internal and external regulations.']
  credit_rating varchar [note: 'External credit rating of the account. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|C|D — promote to reference product]']
  currency_code varchar [note: 'Three‑letter ISO 4217 currency code used for billing. [ENUM-REF-CANDIDATE: USD|EUR|JPY|CNY|KRW|... — promote to reference product]']
  data_classification varchar [note: 'Data classification level applied to the account record.']
  description varchar [note: 'Free‑form description or notes about the account.']
  duns_number varchar [note: 'Dun & Bradstreet unique identifier for the legal entity.']
  export_control_classification varchar [note: 'Export control regime applicable to the account.']
  geographic_region varchar [note: 'Primary geographic region of the account\'s operations.']
  industry_vertical varchar [note: 'Primary industry vertical the account operates in (e.g., automotive, consumer electronics). [ENUM-REF-CANDIDATE: automotive|consumer|industrial|communications|computing|... — promote to reference product]']
  label_requirements varchar [note: 'Labeling format required on products delivered to the account.']
  last_activity_date date [note: 'Date of the most recent interaction or transaction with the account.']
  last_order_date date [note: 'Date of the most recent order placed by the account.']
  legal_name varchar [note: 'Full legal name of the corporate entity as registered.']
  name varchar [note: 'Primary display name of the account (legal or trade name).']
  notes varchar [note: 'Additional free‑form notes captured by sales or support teams.']
  packaging_requirements varchar [note: 'Special packaging or labeling requirements for shipments to the account.']
  payment_terms varchar [note: 'Standard payment terms agreed with the account.']
  preferred_language varchar [note: 'Preferred language for communications with the account.']
  primary_address_code varchar [note: 'Foreign key linking to customer.address. Business justification: Normalize primary address fields by referencing address table.']
  primary_email varchar [note: 'Main email address used for account communications.']
  primary_phone varchar [note: 'Main telephone number for the account point of contact.']
  record_audit_created timestamp [note: 'Timestamp when the account record was first created.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the account record.']
  revenue_tier varchar [note: 'Revenue bracket of the account based on annual sales.']
  risk_score decimal(5,2) [note: 'Numerical risk rating (0‑100) based on credit, compliance, and transaction history.']
  sales_region varchar [note: 'Geographic sales region assigned to the account.']
  strategic_classification varchar [note: 'Strategic importance of the account to the company.']
  tax_exempt_flag boolean [note: 'Indicates whether the account is tax‑exempt.']
  tax_identifier varchar [note: 'Government‑issued tax identifier for the account.']
  creation_date date [note: 'Date when the account was first created in the system.']

  Note: 'Master record for all customer accounts in the semiconductor ecosystem, including OEMs, fabless design houses, ODMs, distributors, and automotive Tier-1 suppliers. SSOT for customer identity, legal entity name, DUNS number, account type, industry vertical, revenue tier, strategic classification, credit rating, payment terms, export control classification (EAR/ITAR), account status, preferred communication settings, packaging/labeling requirements, and Salesforce CRM account ID. Integrates with SAP S/4HANA SD module and Salesforce CRM Account object.'
}

Table customer.contact {
  contact_id varchar [pk, note: 'Unique system-generated identifier for the contact.']
  address_id varchar [note: 'FK to customer.address']
  primary_contact_account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Connect contact to its parent customer account for hierarchy and reporting.']
  birth_date date [note: 'Birth date of the contact, used for age verification where required.']
  contact_status varchar [note: 'Current lifecycle status of the contact record.']
  data_classification varchar [note: 'Classification level of the contact data.']
  department varchar [note: 'Department within the organization where the contact works.']
  email varchar [note: 'Primary email address for the contact.']
  external_reference_code varchar [note: 'Identifier of the contact in external systems (e.g., Salesforce ID).']
  first_name varchar [note: 'Given name of the contact.']
  full_name varchar [note: 'Legal full name of the contact person.']
  gdpr_consent_status varchar [note: 'Current GDPR consent status for personal data processing.']
  is_employee boolean [note: 'True if the contact is an employee of Semiconductors.']
  is_key_contact boolean [note: 'Indicates whether the contact is a primary point of contact for the customer account.']
  language_preference varchar [note: 'Preferred language for communications.']
  last_consent_update timestamp [note: 'Timestamp of the most recent GDPR consent status change.']
  last_interaction_date date [note: 'Date of the most recent interaction with the contact.']
  last_name varchar [note: 'Family name of the contact.']
  linkedin_profile varchar [note: 'URL to the contact\'s LinkedIn professional profile.']
  marketing_opt_in boolean [note: 'Indicates if the contact has opted in to receive marketing communications.']
  nationality varchar [note: 'Contact\'s nationality.']
  notes varchar [note: 'Free-text notes about the contact.']
  phone_number varchar [note: 'Primary telephone number for the contact, in international format.']
  preferred_communication_channel varchar [note: 'Preferred method for contacting the individual.']
  profile_picture_url varchar [note: 'URL to the contact\'s profile picture.']
  record_audit_created timestamp [note: 'Timestamp when the contact record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the contact record.']
  role_type varchar [note: 'Categorization of the contact\'s functional role.']
  time_zone varchar [note: 'Time zone of the contact for scheduling communications.']
  title varchar [note: 'Professional title or position of the contact within their organization.']

  Note: 'Individual contact persons associated with customer accounts, including design engineers, procurement managers, FAE (Field Application Engineers) counterparts, and executive sponsors. Captures full name, title, department, role type (technical, commercial, executive), email, phone, preferred communication channel, LinkedIn profile, GDPR consent status, and active/inactive status. Maps to Salesforce CRM Contact object.'
}

Table customer.account_hierarchy {
  account_hierarchy_id varchar [pk, note: 'System‑generated unique identifier for each account hierarchy relationship record.']
  child_account_id varchar [note: 'Identifier of the child corporate account linked to the parent.']
  parent_account_id varchar [note: 'Identifier of the parent corporate account in the hierarchy.']
  primary_account_id varchar [note: 'FK to customer.account.account_id — The parent_account_id in account_hierarchy must reference the account product. Without this FK, hierarchy records are orphaned.']
  account_hierarchy_status varchar [note: 'Current operational status of the hierarchy link.']
  created_timestamp timestamp [note: 'Timestamp when the hierarchy record was first created in the source system.']
  description varchar [note: 'Free‑text notes providing additional context about the parent‑child relationship.']
  effective_from date [note: 'Date on which the hierarchical relationship became effective.']
  effective_until date [note: 'Date on which the hierarchical relationship ended; null if still active.']
  hierarchy_level varchar [note: 'Numeric depth of the child account within the corporate hierarchy (1 = top‑level).']
  is_primary boolean [note: 'True if the child account is the primary entity under the parent; otherwise false.']
  last_modified_by varchar [note: 'User identifier of the person who last updated the hierarchy record.']
  relationship_type varchar [note: 'Classification of the hierarchical relationship between parent and child accounts.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the hierarchy record.']
  created_by varchar [note: 'User identifier of the person who created the hierarchy record.']

  Note: 'Defines parent-child corporate hierarchy relationships between customer accounts, enabling roll-up of revenue, design-wins, and engagement metrics across global enterprise accounts. Captures parent account, child account, hierarchy level, relationship type (subsidiary, division, affiliate, distributor branch), effective date, and end date. Critical for global OEM and distributor account management.'
}

Table customer.address {
  address_id varchar [pk, note: 'System-generated unique identifier for the address record.']
  account_id varchar [note: 'FK to customer.account.account_id — Addresses are associated with customer accounts (ship-to, bill-to, HQ). This FK is required for order fulfillment, logistics, and export control screening.']
  address_status varchar [note: 'Current lifecycle status of the address record.']
  address_type varchar [note: 'Category of the address indicating its business purpose.']
  change_reason varchar [note: 'Reason code or description for the most recent address change.']
  change_timestamp timestamp [note: 'Timestamp when the most recent address change was recorded.']
  city varchar [note: 'City component of the address.']
  classification varchar [note: 'Classification indicating whether the address belongs to internal organization, external customer, or partner.']
  code varchar [note: 'Internal code used to reference the address within ERP and PLM systems.']
  contact_email varchar [note: 'Email address of the primary contact at the address.']
  contact_name varchar [note: 'Name of the primary contact person at the address.']
  contact_phone varchar [note: 'Phone number of the primary contact at the address.']
  country_code varchar [note: 'Three‑letter ISO 3166‑1 country code.']
  created_timestamp timestamp [note: 'Timestamp when the address record was first created in the system.']
  effective_from date [note: 'Date when the address becomes valid for business use.']
  effective_until date [note: 'Date when the address ceases to be valid (null if open‑ended).']
  export_control_screened boolean [note: 'True if the address has been screened against export control lists.']
  export_control_status varchar [note: 'Result of export‑control screening for the address.']
  geolocation_accuracy varchar [note: 'Indicates the precision level of the latitude/longitude values.']
  is_primary boolean [note: 'Indicates whether this address is the primary location for the associated account.']
  label varchar [note: 'Human‑readable label identifying the address (e.g., “HQ San Jose”).']
  last_verified date [note: 'Date when the address information was last validated.']
  latitude double [note: 'Latitude coordinate in decimal degrees.']
  lineage_code varchar [note: 'Identifier linking this address to its predecessor in case of address merges or splits.']
  longitude double [note: 'Longitude coordinate in decimal degrees.']
  notes varchar [note: 'Free‑form notes or remarks about the address.']
  postal_code varchar [note: 'Postal or ZIP code for the address.']
  purpose varchar [note: 'Business purpose for which the address is used.']
  region varchar [note: 'Broad geographic region (e.g., APAC, EMEA, AMER) used for reporting.']
  state_province varchar [note: 'State or province component of the address.']
  street_line1 varchar [note: 'First line of the street address.']
  street_line2 varchar [note: 'Second line of the street address (optional).']
  tax_jurisdiction_code varchar [note: 'Code representing the tax jurisdiction applicable to the address.']
  time_zone varchar [note: 'IANA time‑zone identifier for the address location.']
  updated_by varchar [note: 'Identifier of the user or process that performed the last update.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the address record.']
  verification_status varchar [note: 'Current status of address verification.']
  created_by varchar [note: 'Identifier of the user or process that created the record.']

  Note: 'Physical and mailing addresses associated with customer accounts and contacts, including headquarters, ship-to, bill-to, and design center locations. Captures address type, street lines, city, state/province, postal code, country (ISO 3166), region, time zone, and geolocation coordinates. Supports multi-site global accounts with multiple address records per account. Used for logistics, tax jurisdiction, and export control screening.'
}

Table customer.design_win {
  design_win_id varchar [pk, note: 'Surrogate primary key for the customer design win record.']
  assembly_process_flow_id varchar [note: 'Foreign key linking to packaging.assembly_process_flow. Business justification: Each design win selects a packaging process flow; linking enables process planning and yield forecasting in the Process Flow Assignment workflow.']
  channel_partner_id varchar [note: 'Reference to the distributor channel partner, if the win originated via a distributor.']
  contact_id varchar [note: 'FK to customer.contact.contact_id — Design-wins reference the FAE owner and customer engineering contact. Contact FK enables relationship tracking.']
  customer_contract_id varchar [note: 'Foreign key linking to sales.customer_contract. Business justification: In semiconductors, design wins for high-volume production are governed by long-term supply contracts. Linking design win to its governing customer contract enables supply commitment tracking, LTB (las']
  design_account_id varchar [note: 'FK to customer.account.account_id — Every design-win is attributed to a specific customer account. This FK is critical for revenue forecasting and account-level reporting.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Design win pipeline reporting requires linking the commercial win to the technical design project for milestone tracking, NRE budget reconciliation, and revenue recognition tied to design phase gates.']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: At design win stage, the customer selects a specific package type that drives OSAT selection, assembly order creation, and yield targets. Replacing the denormalized \'package_type\' string with a FK to ']
  primary_customer_account_id varchar [note: 'Reference to the customer organization that owns the design win.']
  competitive_displacement_flag boolean [note: 'Indicates whether the win displaces a competitor\'s product (true) or not (false).']
  confirmation_timestamp timestamp [note: 'Timestamp when the design win was officially confirmed (won).']
  created_timestamp timestamp
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  design_project_name varchar [note: 'Name of the internal design project associated with the win.']
  design_win_number varchar [note: 'External business identifier assigned to the design win record.']
  estimated_annual_revenue_usd decimal(18,2) [note: 'Projected annual revenue from the design win, expressed in US dollars.']
  estimated_annual_unit_volume varchar [note: 'Projected number of units the customer will purchase per year.']
  estimated_annual_volume varchar
  notes varchar [note: 'Free‑form notes captured by the FAE or sales team.']
  nre_amount_usd decimal(18,2) [note: 'Estimated NRE cost associated with the design win, expressed in US dollars.']
  nre_required_flag boolean [note: 'True if the project includes a non‑recurring engineering (NRE) component.']
  platform_generation varchar [note: 'Generation of the platform family for which the design win is targeted.']
  process_node varchar [note: 'Technology node (e.g., 7nm, 5nm) selected for the design.']
  production_ramp_date date [note: 'Target date when volume production is expected to ramp.']
  record_audit_created timestamp [note: 'Timestamp when this record was first created in the data lake.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to this record.']
  reference varchar
  registration_timestamp timestamp [note: 'Timestamp when the design win was first registered in the system.']
  source varchar [note: 'Origin of the design win (internal development, channel‑sourced, or partner‑sourced).']
  stage varchar [note: 'Current stage of the design‑win lifecycle.']
  tapeout_target_date date [note: 'Planned date for tape‑out of the design.']
  target_application varchar [note: 'Intended end‑product or market application (e.g., smartphone SoC, ADAS ECU, AI accelerator).']
  win_date date
  win_status varchar

  Note: 'Unified record tracking the full design-in lifecycle from initial registration through confirmed design-win for semiconductor products selected by customers. SSOT for the complete design-in pipeline from early registration through revenue forecasting — distinct from sales-domain opportunity records which track revenue probability and sales stage. Captures design project name, target end product/application (e.g., smartphone SoC, ADAS ECU, AI accelerator), platform generation, process node, package type, device/part number selected, design-win stage (registered, evaluating, sampling, won, lost, on-hold), registration date, design-win confirmation date, tapeout target date, production ramp date, estimated annual unit volume (AUV), estimated annual revenue, competitive displacement flag, associated distributor (if channel-sourced), FAE owner, and NRE requirements. Integrates with Salesforce CRM Opportunity. References SSOT: sales.sales_design_win'
}

Table customer.design_registration {
  design_registration_id varchar [pk, note: 'Surrogate primary key uniquely identifying each customer design registration record.']
  account_id varchar [note: 'Identifier of the customer owning the design project.']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: A customer design registration is initiated and managed by a specific design engineer or technical contact at the customer account. Linking customer_design_registration to contact.contact_id captures ']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: A customer design registration is the formal precursor to a design win in the semiconductor design-in lifecycle. Once a registration progresses to a confirmed win, the registration record should refer']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Customer design registrations initiate internal design projects in semiconductor design services. Linking registration to the resulting ic_design_project enables traceability from customer design-in r']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Design registration specifies the intended package type; linking ensures downstream packaging aligns with the registered specifications, used in the Design Registration Review process.']
  created_timestamp timestamp [note: 'Timestamp when the registration record was first created.']
  design_complexity varchar [note: 'Qualitative assessment of design difficulty.']
  design_project_description varchar [note: 'Free‑form description of the design objectives, features, and scope.']
  design_project_name varchar [note: 'Human‑readable name of the customer’s design project.']
  design_start_date date [note: 'Date when the customer officially started the design effort.']
  expected_yield_percent decimal(5,2) [note: 'Projected percentage of good dies per wafer for the design.']
  expiration_date date
  nre_budget_amount decimal(18,2) [note: 'Non‑Recurring Engineering budget allocated for the design project.']
  nre_budget_currency varchar [note: 'Currency of the NRE budget amount.']
  package_type varchar [note: 'Physical package style for the final silicon die.']
  platform_generation varchar [note: 'Generation of the semiconductor platform (e.g., next‑gen, legacy) targeted by the design.']
  process_node_nm varchar [note: 'Technology node (in nanometers) selected for the design.']
  production_target_date date [note: 'Target date for first silicon production run.']
  qualification_date date [note: 'Date when the qualification status was determined.']
  qualification_status varchar [note: 'Result of the customer design qualification review.']
  registration_date date
  registration_number varchar [note: 'Business identifier assigned to the design registration, used for tracking and external communication.']
  registration_status varchar [note: 'Current lifecycle state of the design registration.']
  tapeout_target_date date [note: 'Planned date for the final mask set release (tape‑out).']
  target_application varchar [note: 'Primary market or end‑use application for which the design is intended.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the registration record.']

  Note: 'Formal registration of a customer design project that uses a specific semiconductor product, capturing the design project name, target application, platform generation, process node, package type, design start date, tapeout target date, production target date, design registration status, and associated distributor (if applicable). Enables early pipeline visibility and NRE planning. Precedes and feeds into design_win records. References SSOT: sales.sales_design_registration'
}

Table customer.nda_agreement {
  nda_agreement_id varchar [pk, note: 'System-generated unique identifier for the NDA agreement record.']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: In semiconductors, NDAs are routinely scoped to specific product families to gate access to datasheets, PDKs, and roadmap information. Linking nda_agreement to product.family enables access-control en']
  primary_account_id varchar [note: 'FK to customer.account.account_id — NDAs are executed with customer accounts. Must reference the account for access control and roadmap sharing decisions.']
  signatory_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: NDA agreements are executed by individual signatories who are tracked as contacts in the customer domain. The nda_agreement currently stores signatory_name, signatory_email, and signatory_phone as den']
  agreement_number varchar [note: 'External reference number or code assigned to the NDA by the legal or sales organization.']
  compliance_requirements varchar [note: 'List of regulatory or contractual compliance obligations referenced in the NDA (e.g., ITAR, EAR, GDPR).']
  confidentiality_level varchar [note: 'Classification of the NDA\'s sensitivity as defined by corporate data governance.']
  created_timestamp timestamp [note: 'Timestamp when the NDA record was first created in the system.']
  document_reference_code varchar [note: 'Identifier linking to the stored NDA document in the document management system.']
  effective_date date [note: 'Date on which the NDA becomes legally binding.']
  execution_date date [note: 'Date the NDA was signed by the authorized signatory.']
  expiration_date date
  expiry_date date [note: 'Date on which the NDA expires unless renewed.']
  is_mutual boolean
  jurisdiction varchar [note: 'ISO‑3166‑1 alpha‑3 country code representing the legal jurisdiction governing the NDA.']
  legal_entity_name varchar [note: 'Official legal name of the customer organization bound by the NDA.']
  nda_agreement_status varchar [note: 'Current lifecycle state of the NDA agreement.']
  nda_number varchar
  nda_status varchar
  nda_type varchar [note: 'Indicates whether the NDA is mutual (both parties exchange confidential information) or one‑way (only the semiconductor company shares information).']
  renewal_notice_date date [note: 'Date on which a renewal notice must be sent to the customer before expiry.']
  scope_description varchar [note: 'Free‑text description of the technology, roadmap, pricing, or other information covered by the NDA.']
  signed_by_name varchar
  termination_reason varchar [note: 'Reason provided for early termination of the NDA, if applicable.']
  updated_by varchar [note: 'User identifier of the person who last modified the NDA record.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the NDA record.']
  version_number varchar [note: 'Incremental version of the NDA when amendments are made.']
  created_by varchar [note: 'User identifier of the person who created the NDA record.']

  Note: 'Non-Disclosure Agreement records between the semiconductor company and customer accounts, capturing NDA type (mutual, one-way), execution date, expiry date, covered scope (product roadmap, process technology, pricing), signatory contacts, legal entity names, NDA status (active, expired, under renewal), and document reference ID. Required before sharing roadmap, PDK, or pre-production device information with customers.'
}

Table customer.credit_profile {
  credit_profile_id varchar [pk, note: 'Unique identifier for the credit profile record.']
  primary_account_id varchar [note: 'FK to customer.account.account_id — Credit profiles are per-account. Must reference the account for order-to-cash credit checks.']
  primary_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: A credit profile is managed in coordination with a primary contact at the customer account (e.g., the finance or procurement contact). The credit_profile currently stores primary_contact_email as a de']
  compliance_flag boolean [note: 'Indicates if the credit profile is subject to any regulatory hold or review.']
  created_timestamp timestamp
  credit_analyst_notes varchar [note: 'Free‑form notes entered by the credit analyst.']
  credit_hold boolean [note: 'Indicates whether the customer\'s credit is currently on hold.']
  credit_hold_flag boolean
  credit_hold_reason varchar [note: 'Reason for placing the customer\'s credit on hold.']
  credit_limit_adjustment_amount decimal(18,2) [note: 'Amount by which the credit limit was adjusted.']
  credit_limit_adjustment_date date [note: 'Date when the credit limit adjustment took effect.']
  credit_limit_adjustment_reason varchar [note: 'Reason for the most recent credit limit change.']
  credit_limit_amount decimal(18,2) [note: 'Maximum credit amount approved for the customer.']
  credit_limit_currency varchar [note: 'Currency of the credit limit (ISO 4217 three‑letter code).']
  credit_limit_effective_from date [note: 'Date when the current credit limit became effective.']
  credit_limit_effective_until date [note: 'Date when the current credit limit expires (null if open‑ended).']
  credit_limit_usd decimal(18,2)
  credit_profile_status varchar [note: 'Current lifecycle status of the credit profile.']
  credit_profile_type varchar [note: 'Category of the credit profile based on internal risk segmentation.']
  credit_rating varchar
  credit_rating_external varchar [note: 'External credit rating from a third‑party agency.']
  credit_rating_internal varchar [note: 'Internal credit rating assigned by the company.']
  credit_review_date date [note: 'Date of the most recent credit review.']
  credit_review_notes varchar [note: 'Analyst comments from the latest credit review.']
  credit_review_outcome varchar [note: 'Result of the most recent credit review.']
  credit_score varchar [note: 'Numerical credit score from an external scoring model.']
  credit_score_date date [note: 'Date when the credit score was obtained.']
  credit_score_source varchar [note: 'Source of the credit score (e.g., Equifax, Experian).']
  credit_used_usd decimal(18,2)
  credit_utilization_pct decimal(5,2) [note: 'Percentage of the credit limit currently utilized.']
  currency_code varchar [note: 'Currency used for all monetary fields (ISO 4217).']
  external_rating_agency varchar [note: 'Name of the external agency providing the credit rating.']
  is_preferred_customer boolean [note: 'Indicates whether the customer is marked as a preferred partner.']
  last_review_date date
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the credit profile.']
  outstanding_balance decimal(18,2) [note: 'Current unpaid balance owed by the customer.']
  overdue_amount decimal(18,2) [note: 'Amount past due beyond the agreed payment terms.']
  payment_terms varchar [note: 'Standard payment terms agreed with the customer.']
  preferred_customer_reason varchar [note: 'Business justification for preferred customer status.']
  profile_name varchar [note: 'Human‑readable name for the credit profile (e.g., "Standard Credit Profile").']
  rating_date date [note: 'Date when the external credit rating was issued.']
  record_audit_created timestamp [note: 'Timestamp when the credit profile record was first created.']
  risk_category varchar [note: 'Overall risk classification derived from credit metrics.']
  status_date date [note: 'Date when the credit profile status last changed.']
  updated_by varchar [note: 'User identifier who last updated the credit profile record.']
  created_by varchar [note: 'User identifier who created the credit profile record.']

  Note: 'Customer-facing credit and financial risk profile maintained by the customer domain as SSOT for customer creditworthiness assessment. Captures credit limit, credit rating (internal and external Dun & Bradstreet), payment terms (Net 30, Net 60, prepay), credit hold status, credit review date, outstanding balance, overdue amount, credit utilization percentage, currency, and credit analyst notes. Distinct from finance-domain AR aging and collections records — this product owns the customer\'s credit posture used for real-time order-to-cash credit checks. Integrates with SAP S/4HANA FI-AR (Accounts Receivable).'
}

Table customer.price_agreement {
  price_agreement_id varchar [pk, note: 'System-generated unique identifier for the price agreement record.']
  assembly_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Semiconductor pricing contracts are package-type specific — BGA, QFN, and flip-chip carry different unit prices and NRE costs. Linking price_agreement to package_type enables package-level pricing rep']
  price_account_id varchar [note: 'FK to customer.account.account_id — Customer-specific pricing is negotiated per account. FK to account is mandatory for pricing lookups during order entry.']
  primary_price_account_id varchar [note: 'Unique identifier of the customer to which the price agreement applies.']
  agreement_number varchar [note: 'External reference number assigned to the price agreement, used in contracts and communications.']
  agreement_status varchar
  agreement_type varchar [note: 'Category of the price agreement indicating its purpose or pricing model.']
  approval_date date [note: 'Date on which the price agreement was approved.']
  approval_status varchar [note: 'Result of the internal approval workflow for the price agreement.']
  approved_by varchar [note: 'Name or employee identifier of the person who approved the agreement.']
  contract_reference varchar [note: 'Reference number of the Special Price Authorization or contract linked to this agreement.']
  created_timestamp timestamp [note: 'Timestamp when the price agreement record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the agreed price.']
  description varchar [note: 'Free‑form text describing the purpose, scope, or special conditions of the agreement.']
  discount_percent decimal(5,2) [note: 'Percentage discount applied on top of the base unit price.']
  effective_date date
  effective_from date [note: 'Date on which the price agreement becomes binding.']
  effective_until date [note: 'Date on which the price agreement expires; null for open‑ended agreements.']
  expiration_date date
  is_price_locked boolean [note: 'Indicates whether the price agreement is locked from further changes.']
  last_modified_by varchar [note: 'User identifier that performed the latest update.']
  min_quantity varchar
  minimum_order_quantity varchar [note: 'Minimum quantity that must be ordered to qualify for the agreed price.']
  notes varchar [note: 'Additional remarks or internal comments related to the agreement.']
  part_revision varchar [note: 'Specific revision or mask set of the part covered by the agreement.']
  price_agreement_status varchar [note: 'Current lifecycle state of the price agreement.']
  price_change_approval_reference varchar [note: 'Reference to the approval workflow instance for a price change.']
  price_change_effective_date date [note: 'Date on which a price amendment becomes effective.']
  price_change_reason varchar [note: 'Narrative reason for a price amendment or re‑negotiation.']
  price_source varchar [note: 'Origin of the price data (e.g., SAP SD pricing condition, manual entry, external feed).']
  price_uom varchar [note: 'Unit of measure for the price (e.g., per die, per wafer, per lot).']
  pricing_channel varchar [note: 'Sales channel through which the price is offered.']
  pricing_region varchar [note: 'Geographic region to which the pricing terms apply.']
  tax_included_flag boolean [note: 'Indicates whether taxes are already included in the unit price.']
  tier_end_quantity varchar [note: 'Inclusive upper bound of quantity for this volume tier; null if no upper limit.']
  tier_price decimal(18,4) [note: 'Agreed unit price applicable for the defined volume tier.']
  tier_start_quantity varchar [note: 'Inclusive lower bound of quantity for this volume tier.']
  unit_price decimal(18,4) [note: 'Agreed price per unit of the part, expressed in the specified currency.']
  unit_price_usd decimal(18,2)
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the price agreement record.']
  volume_tier varchar [note: 'Label for the volume‑based pricing tier.']
  created_by varchar [note: 'User identifier that created the price agreement record.']

  Note: 'Customer-specific pricing agreements and special price authorizations (SPAs) negotiated for specific part numbers. SSOT for customer-negotiated prices distinct from sales-domain standard list pricing and discount schedules. Captures agreed unit price, currency, minimum order quantity (MOQ), volume tiers, effective date, expiry date, approval chain, SPA reference number, and associated design-win or contract. These are customer-committed prices that flow into order entry — not sales pipeline pricing assumptions. Integrates with SAP S/4HANA SD pricing conditions.'
}

Table sales.opportunity {
  opportunity_id varchar [pk, note: 'System-generated unique identifier for the sales opportunity.']
  account_id varchar [note: 'Identifier of the customer account linked to the opportunity.']
  channel_partner_id varchar [note: 'Foreign key linking to sales.channel_partner. Business justification: Semiconductor design-win opportunities are frequently managed through authorized channel partners (distributors or rep firms). Linking opportunity to channel_partner identifies the primary distributio']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Opportunity Management process requires a primary contact person; linking to customer.contact enables accurate follow‑up and reporting.']
  nda_agreement_id varchar [note: 'Foreign key linking to customer.nda_agreement. Business justification: In semiconductors, sharing technical roadmap details during an opportunity requires an active NDA. Linking opportunity to its governing NDA is a legal compliance requirement, enabling NDA coverage ver']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: In semiconductor design-win sales, opportunities are tied to a specific package type the customer is designing in (e.g., flip-chip BGA for a server CPU). Sales engineers and OSAT capacity planners use']
  competitive_landscape varchar [note: 'Free‑text description of key competitors and market positioning for the opportunity.']
  contract_end_date date [note: 'Planned end or expiration date of the contract; nullable for open‑ended agreements.']
  contract_start_date date [note: 'Effective start date of the contract if the opportunity is won.']
  contract_status varchar [note: 'Current lifecycle status of the contract.']
  contract_type varchar [note: 'Nature of the contractual agreement associated with the opportunity.']
  country_code varchar [note: 'Three‑letter country code of the primary customer location.']
  created_timestamp timestamp [note: 'Timestamp when the opportunity record was first created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the monetary amounts (e.g., USD, EUR).']
  end_market varchar [note: 'Primary market segment the opportunity addresses.']
  expected_close_date date [note: 'Projected date when the opportunity is expected to be closed (won or lost).']
  expected_discount_amount decimal(18,2) [note: 'Estimated discount or rebate amount applied to the gross revenue.']
  expected_gross_amount decimal(18,2) [note: 'Projected gross revenue before discounts, taxes, or adjustments.']
  expected_net_amount decimal(18,2) [note: 'Projected net revenue after discounts and adjustments.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the opportunity record.']
  name varchar [note: 'Descriptive name of the opportunity, often reflecting the target product or project.']
  nre_amount decimal(18,2) [note: 'Potential NRE revenue associated with custom design or engineering services.']
  opportunity_number varchar [note: 'Human‑readable business identifier assigned to the opportunity (e.g., OPP‑2024‑00123).']
  price_per_unit decimal(12,4) [note: 'Unit price used for revenue calculations, expressed in the selected currency.']
  pricing_model varchar [note: 'Pricing structure applied to the opportunity.']
  probability_percent varchar [note: 'Estimated probability (0‑100) that the opportunity will be won, based on stage and historical data.']
  region varchar [note: 'Broad geographic region for the opportunity.']
  sales_channel varchar [note: 'Channel through which the sale is pursued.']
  stage varchar [note: 'Current pipeline stage of the opportunity.']
  stage_change_timestamp timestamp [note: 'Timestamp when the opportunity last moved to its current stage.']
  target_application varchar [note: 'Intended end‑use or application for the product (e.g., automotive ADAS, AI accelerator).']
  unit_of_measure varchar [note: 'Measurement unit for the quantity (e.g., units, chips).']
  win_loss_date date [note: 'Date on which the opportunity outcome (win or loss) was recorded.']
  win_loss_reason varchar [note: 'Narrative reason why the opportunity was won or lost.']

  Note: 'Master record: Core sales opportunity tracking design-win campaigns, pipeline stages (Prospecting→Design-In→Design-Win→Production Ramp→Won/Lost), probability, and expected revenue for semiconductor IC, SoC, ASIC, and FPGA engagements. Sourced from Salesforce CRM Opportunity object. Captures end market (automotive, mobile, AI, IoT, computing), product family, target application, competitive landscape, NRE potential, design-win status, campaign grouping (campaign type, target segment, effectiveness metrics), and stage transition history for pipeline velocity analysis. SSOT for all sales pipeline activity including campaign-level aggregation for design-in programs, product launches, and competitive displacement initiatives.'
}

Table sales.quote {
  quote_id varchar [pk, note: 'Unique system-generated identifier for the quote record.']
  account_id varchar [note: 'Identifier of the customer or prospect receiving the quote.']
  channel_partner_id varchar [note: 'Foreign key linking to sales.channel_partner. Business justification: Semiconductor quotes issued through distribution channels must reference the specific channel partner for whom the quote is prepared. Distributor quotes have distinct pricing (distributor price vs. di']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Quote generation must record the exact customer contact authorizing the quote; this FK supports compliance and audit trails.']
  family_id varchar [note: 'Foreign key linking to product.product_family. Business justification: Quote header must be tied to a product family for contract and pricing governance.']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Quote generation requires selecting a package type; linking ensures accurate pricing, compliance, and production planning.']
  price_list_id varchar [note: 'FK to sales.price_list.price_list_id — Quotes reference the applicable price list for base pricing. Essential for pricing compliance and margin analysis.']
  primary_quote_opportunity_id varchar [note: 'FK to sales.opportunity.opportunity_id — Quotes are generated in the context of an opportunity. This is the core pipeline-to-commercial link. Required for quote-to-win conversion tracking.']
  source_opportunity_id varchar [note: 'FK to sales.opportunity.opportunity_id — Every quote is generated in context of an opportunity — this is the core pipeline-to-commercial conversion link. Engineers need this to trace quote→opportunity for pipeline reporting.']
  conversion_date timestamp [note: 'Timestamp when the quote was converted to an order, if applicable.']
  created_timestamp timestamp [note: 'Timestamp when the quote record was first created in the system.']
  currency varchar [note: 'Three‑letter ISO 4217 currency code for the quote amounts.']
  delivery_terms varchar [note: 'Additional delivery conditions beyond Incoterms, such as FOB destination or DAP warehouse.']
  description varchar [note: 'Free‑form text describing the scope, special conditions, or notes for the quote.']
  discount_amount decimal(18,4) [note: 'Monetary discount applied to the gross amount.']
  incoterms varchar [note: 'International commercial terms defining delivery responsibilities. [ENUM-REF-CANDIDATE: EXW|FCA|FOB|CFR|CIF|DAP|DDP — promote to reference product]']
  is_converted boolean [note: 'Indicates whether the quote has been converted to a sales order.']
  lead_time_days varchar [note: 'Estimated number of calendar days from order receipt to delivery.']
  net_amount decimal(18,4) [note: 'Final amount payable after discount and tax.']
  payment_terms varchar [note: 'Standard payment condition attached to the quote.']
  quote_date timestamp [note: 'Timestamp when the quote was issued to the customer.']
  quote_number varchar [note: 'Human‑readable business identifier for the quotation, often used in communications and tracking.']
  quote_status varchar [note: 'Current lifecycle state of the quote.']
  reason_lost varchar [note: 'Textual reason provided when a quote is marked as lost.']
  sales_region varchar [note: 'Three‑letter country code representing the primary sales region for the quote.']
  tax_amount decimal(18,4) [note: 'Tax calculated on the gross amount after discount.']
  total_amount decimal(18,4) [note: 'Total quoted amount before discounts, taxes, or adjustments.']
  unit_price decimal(18,4) [note: 'Price per individual unit for the quoted product at the selected volume tier.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the quote record.']
  valid_until date [note: 'Date after which the quote is no longer valid.']
  volume_tier varchar [note: 'Quantity bracket that determines unit pricing.']
  win_loss_status varchar [note: 'Outcome of the quote after the decision period.']
  valid_from date [note: 'Date from which the quoted terms become effective.']

  Note: 'Transaction record: Commercial price quotation issued to a customer or prospect for semiconductor products including ICs, packaged devices, wafer-level products, and IP licensing. Captures quoted unit price, volume tiers, lead time, validity period, incoterms, currency, and SAP SD quotation reference. Tracks quote-to-order conversion and win/loss outcomes.'
}

Table sales.quote_line {
  quote_line_id varchar [pk, note: 'Unique identifier for the quote line record.']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: KGD quote lines reference specific die bank lots for pricing (unit cost, bin class) and availability confirmation. Semiconductor KGD sales require quoting against actual die bank inventory to confirm ']
  family_id varchar [note: 'Foreign key linking to product.product_family. Business justification: Enables quote‑level reporting and margin analysis by product family.']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Quote line pricing and availability require linking to the specific finished good inventory record for SKU, enabling real-time stock checks during quoting.']
  ip_core_id varchar [note: 'Foreign key linking to design.ip_core. Business justification: Quote lines often represent IP core licensing; linking tracks IP revenue and compliance.']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: quote_line carries a plain-text \'package_type\' column — a clear denormalization of packaging.package_type. Multi-line quotes in semiconductors specify different package types per line item. Replacing ']
  price_agreement_id varchar [note: 'Foreign key linking to customer.price_agreement. Business justification: Quote lines in semiconductors must reference the customer-specific price agreement governing the quoted price for audit traceability and pricing approval workflows. This is distinct from the general p']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: Individual quote line items in semiconductor quoting can reference specific price lists at the line level, particularly when different SKUs on the same quote are priced from different price lists (e.g']
  primary_quote_id varchar [note: 'Identifier of the parent sales quote to which this line belongs.']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Semiconductor quote lines for qualified or custom parts must cite the applicable quality spec defining acceptance criteria, test type, and limits. Sales engineers and pricing teams reference quality s']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Required for accurate pricing, inventory and compliance tracking in quote lines.']
  tertiary_quote_id varchar [note: 'FK to sales.quote.quote_id — Header-detail relationship: quote_line cannot exist without its parent quote. Critical for quote value calculation and line-level pricing analysis.']
  cost_center_code varchar [note: 'Internal cost center to which the line\'s revenue is allocated.']
  created_timestamp timestamp [note: 'Date and time when the quote line was created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the quote (e.g., USD, EUR).']
  customer_requested_delivery_date date [note: 'Date the customer expects delivery of the quoted items.']
  discount_percent decimal(5,2) [note: 'Percentage discount applied to the unit price.']
  effective_date date [note: 'Date on which the quoted terms become effective.']
  expiration_date date [note: 'Date after which the quoted terms are no longer valid.']
  internal_approval_status varchar [note: 'Status of internal sales or finance approval for the line.']
  is_custom boolean [note: 'True if the quoted SKU is a custom or engineered product.']
  is_price_locked boolean [note: 'True if the quoted price is locked and cannot be changed without re‑quote.']
  lead_time_days varchar [note: 'Estimated number of calendar days from order to shipment.']
  line_comment varchar [note: 'Free‑form comment entered by the sales rep for this line.']
  line_number varchar [note: 'Sequential number of the line within the quote for ordering.']
  net_price decimal(18,4) [note: 'Unit price after discount, before tax.']
  pricing_tier varchar [note: 'Pricing tier classification that determines discount levels.']
  quantity varchar [note: 'Number of units of the product requested in this line.']
  quote_line_status varchar [note: 'Current lifecycle status of the quote line.']
  sales_channel varchar [note: 'Channel through which the sale is pursued.']
  sales_region varchar [note: 'Geographic sales region associated with the quote.']
  special_handling_instructions varchar [note: 'Any customer‑specific handling, packaging, or shipping notes.']
  tax_amount decimal(18,4) [note: 'Monetary tax calculated for this line.']
  tax_rate decimal(5,2) [note: 'Applicable tax rate expressed as a percentage.']
  total_price decimal(18,4) [note: 'Gross amount for the line (unit_price * quantity) before tax.']
  unit_price decimal(18,4) [note: 'Base price per unit before discounts, in the quote currency.']
  uom varchar [note: 'Measurement unit for quantity, typically \'pcs\' for pieces.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the quote line.']
  warranty_years varchar [note: 'Number of years of warranty offered for the product.']

  Note: 'Detail record: Individual line item within a sales quotation specifying a single semiconductor SKU, die, or IP core with its quoted quantity, unit price, discount, package type, lead time, and applicable pricing tier. Supports multi-line quotes covering mixed product families and end-market configurations.'
}

Table sales.price_list {
  price_list_id varchar [pk, note: 'Unique identifier for the price list record.']
  family_id varchar [note: 'Foreign key linking to product.product_family. Business justification: Price lists are defined per product family to enforce consistent pricing policies.']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Price list entries are defined per package type; FK replaces denormalized package_type column for consistency and audit.']
  superseded_by_price_list_id varchar [note: 'Reference to a newer price list that supersedes this one.']
  adjustment_amount decimal(18,6) [note: 'Monetary amount of the price adjustment.']
  adjustment_reason varchar [note: 'Business reason or justification for the price adjustment.']
  adjustment_type varchar [note: 'Type of price adjustment applied to the base price.']
  approval_timestamp timestamp [note: 'Timestamp when the price list was approved.']
  audit_trail varchar [note: 'Append-only log of changes to the price list record.']
  created_timestamp timestamp [note: 'Timestamp when the price list record was created.']
  currency varchar [note: 'Three-letter ISO 4217 currency code for the price.']
  description varchar [note: 'Detailed description of the price list purpose and scope.']
  effective_from date [note: 'Date when the price becomes effective.']
  effective_until date [note: 'Date when the price expires or is superseded.']
  end_market varchar [note: 'Target market segment (e.g., automotive, mobile, data center).']
  is_default boolean [note: 'Flag indicating if this price list is the default for its scope.']
  name varchar [note: 'Descriptive name of the price list.']
  notes varchar [note: 'Free-form notes or comments about the price list.']
  price_list_status varchar [note: 'Current lifecycle status of the price list.']
  price_type varchar [note: 'Category of pricing defined by the list (e.g., standard list, distributor, OEM, spot).']
  pricing_condition_code varchar [note: 'SAP SD pricing condition record identifier.']
  region varchar [note: 'Geographic region for which the price list applies.']
  tax_code varchar [note: 'Tax code applicable to the price.']
  unit_price decimal(18,6) [note: 'Base price per unit for the defined tier and product.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the price list record.']
  validity_end date [note: 'End date of the price list\'s validity window.']
  validity_start date [note: 'Start date of the price list\'s validity window.']
  version varchar [note: 'Version identifier for the price list.']
  volume_tier_max varchar [note: 'Maximum quantity for the volume pricing tier.']
  volume_tier_min varchar [note: 'Minimum quantity for the volume pricing tier.']

  Note: 'Master record: Master pricing repository defining standard and customer-specific pricing for semiconductor products by product family, package type, volume tier, and end market. Supports list price, distributor price, OEM price, and spot price variants. Contains price adjustment records capturing negotiated deviations, special bids, volume rebate adjustments, design-win incentives, and distributor markdowns with adjustment type, approved deviation amount, approval authority, validity windows, and SAP SD pricing condition override references. Integrates with SAP SD condition records and Salesforce CRM pricing engine. Tracks effective dates, supersession history, and full adjustment audit trail. SSOT for all semiconductor product pricing and price deviations.'
}

Table sales.customer_contract {
  customer_contract_id varchar [pk, note: 'Unique system-generated identifier for the customer contract.']
  account_id varchar [note: 'Identifier of the customer party that holds the contract.']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: Foundry and IDM customer contracts frequently specify the manufacturing facility (e.g., for ITAR compliance, geographic supply chain requirements, or customer-qualified fab site). Contract managers an']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: Customer contracts in semiconductors are scoped to product families for EOL notification obligations, PCN requirements, and pricing framework agreements. product_family on customer_contract is a plain']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Contract fulfillment management: semiconductor customer contracts (LTAs, LTB clauses, supply assurance agreements) specify exact materials covered. Linking enables supply commitment validation, PCN ob']
  nda_agreement_id varchar [note: 'Foreign key linking to customer.nda_agreement. Business justification: Semiconductor customer contracts are executed under or alongside an NDA governing confidentiality of pricing, technology, and supply terms. Linking contract to its governing NDA is a standard legal op']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Semiconductor customer contracts frequently specify approved or mandated package types (e.g., ITAR-controlled packages, BGA-only clauses). Contract compliance teams and sales ops need this FK to enfor']
  price_agreement_id varchar [note: 'Foreign key linking to customer.price_agreement. Business justification: Semiconductor customer contracts reference specific negotiated price agreements that define the pricing terms of the supply relationship. This link enables contract-to-price-agreement traceability for']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: Long-term semiconductor customer contracts define pricing terms that are anchored to a specific price list (or customer-specific price list). Linking customer_contract to price_list normalizes the pri']
  primary_customer_opportunity_id varchar [note: 'FK to sales.opportunity.opportunity_id — Long-term supply contracts often originate from won opportunities. Links contract terms back to the originating sales engagement.']
  amendment_count varchar [note: 'Number of times the contract has been amended.']
  annual_value decimal(15,2) [note: 'Average yearly revenue expected from the contract.']
  arbitration_clause boolean [note: 'Indicates whether disputes are resolved via arbitration.']
  auto_renew_flag boolean [note: 'Indicates if the contract will auto‑renew at the end of its term.']
  confidentiality_clause boolean [note: 'Indicates whether a confidentiality clause is present.']
  contract_name varchar [note: 'Descriptive title of the contract for easy identification.']
  contract_number varchar [note: 'External contract number assigned by the customer or sales organization.']
  contract_type varchar [note: 'Category of the contract such as supply, service, license, or NRE.']
  contract_value_total decimal(15,2) [note: 'Aggregate monetary value of the contract over its full term.']
  created_timestamp timestamp [note: 'Timestamp when the contract record was first created.']
  credit_limit decimal(15,2) [note: 'Maximum credit exposure allowed for the customer.']
  credit_rating varchar [note: 'Internal credit rating of the customer.']
  currency varchar [note: 'Three‑letter ISO currency code used for all monetary amounts.']
  customer_contract_status varchar [note: 'Current lifecycle status of the contract.']
  description varchar [note: 'Free‑form text describing the contract purpose and special conditions.']
  discount_rate decimal(5,2) [note: 'Percentage discount applied to the base unit price.']
  effective_from date [note: 'Date when the contract becomes binding.']
  effective_until date [note: 'Date when the contract expires or is terminated; null for open‑ended contracts.']
  eol_clause boolean [note: 'Indicates whether an End‑of‑Life provision is part of the contract.']
  invoicing_frequency varchar [note: 'How often invoices are issued under the contract.']
  last_amendment_date date [note: 'Date of the most recent contract amendment.']
  ltb_provision boolean [note: 'Indicates whether a Last‑Time‑Buy clause is included.']
  max_order_quantity varchar [note: 'Maximum quantity per order allowed under the contract.']
  min_order_quantity varchar [note: 'Minimum quantity per order required by the contract.']
  payment_terms varchar [note: 'Standard payment condition agreed with the customer.']
  pcn_obligation boolean [note: 'Specifies if the supplier must notify the customer of product changes.']
  pricing_terms varchar [note: 'Narrative description of pricing structure, discounts, and rebates.']
  renewal_option varchar [note: 'Specifies whether the contract renews automatically, manually, or not at all.']
  sales_region varchar [note: 'Geographic sales region associated with the contract.']
  supply_scope varchar [note: 'Scope of supply coverage: exclusive, multi‑source, or global.']
  termination_date date [note: 'Date on which the contract is formally terminated.']
  termination_notice_period_days varchar [note: 'Number of days notice required before contract termination.']
  unit_price decimal(15,4) [note: 'Base price per unit of product or service covered by the contract.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the contract record.']
  volume_commitment varchar [note: 'Total quantity of units the customer commits to purchase over the contract term.']

  Note: 'Master record: Long-term commercial contract with a semiconductor customer covering supply commitments, pricing agreements, volume guarantees, last-time-buy (LTB) provisions, product change notification (PCN) obligations, and end-of-life (EOL) terms. Distinct from NRE agreements — governs ongoing product supply rather than development services. Linked to SAP SD outline agreements.'
}

Table sales.forecast {
  forecast_id varchar [pk, note: 'System-generated unique identifier for the forecast record.']
  account_id varchar [note: 'Identifier of the customer for whom the forecast is created.']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: Semiconductor revenue forecasting is built around design wins. Sales forecasts must reference the specific design win driving projected volume, enabling design-win pipeline forecasting and win-rate-to']
  family_id varchar [note: 'Foreign key linking to product.product_family. Business justification: Forecasts are produced per product family for capacity planning and financial reporting.']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Semiconductor demand forecasts are maintained at finished good (part number) level for replenishment planning and inventory build decisions. This FK enables forecast accuracy reporting (MAPE by part n']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Semiconductor demand planning and fab loading require part-number-level forecasts. S&OP processes, wafer start planning, and inventory positioning all depend on forecasts tied to specific IC catalog e']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Semiconductor demand planning teams build revenue/volume forecasts against specific design projects to drive wafer start planning and capacity allocation. A sales domain expert expects forecasts to be']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Demand planning: semiconductor sales forecasts must be tied to specific materials for granular MRP input. family_id alone is insufficient for component-level supply planning. This link enables materia']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: Sales forecasts in semiconductor design-win pipelines are frequently tied to specific opportunities (e.g., forecasting expected volume for a design-win campaign at a specific end customer). Linking sa']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Semiconductor demand forecasts are broken down by package type to drive OSAT capacity allocation and substrate procurement planning. Demand planners and supply chain teams require package-level foreca']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: Sales forecasts in semiconductors are always segmented by technology node to drive fab capacity planning and wafer start authorizations. Capacity planners and S&OP teams use forecast-by-node to alloca']
  approval_date date [note: 'Date the forecast was approved.']
  approved_by varchar [note: 'User identifier who approved the forecast.']
  bias decimal(5,2) [note: 'Average signed deviation of forecast from actuals.']
  category varchar [note: 'High‑level category of the forecast (demand, supply, or capacity).']
  confidence_level varchar [note: 'Confidence rating assigned to the forecast.']
  created_timestamp timestamp [note: 'Timestamp when the forecast record was first created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  effective_end date [note: 'Last day of the period the forecast covers.']
  effective_start date [note: 'First day of the period the forecast covers.']
  end_market varchar [note: 'Target market segment of the forecast.']
  fiscal_period varchar [note: 'Fiscal period identifier (e.g., FY2025Q1).']
  forecast_number varchar [note: 'Business identifier assigned to the forecast (e.g., F2025Q1-001).']
  forecast_status varchar [note: 'Current lifecycle status of the forecast.']
  forecast_type varchar [note: 'Classification of the forecast scenario (commit, upside, or best‑case).']
  geography varchar [note: 'Three‑letter ISO country code representing the forecast geography.']
  horizon_months varchar [note: 'Length of the forecast horizon expressed in months.']
  is_locked boolean [note: 'Indicates whether the forecast is locked from further edits.']
  last_review_date date [note: 'Date of the most recent review of the forecast.']
  last_reviewer varchar [note: 'User identifier who performed the last review.']
  mape decimal(5,2) [note: 'Statistical measure of forecast accuracy.']
  notes varchar [note: 'Free‑form comments or rationale for the forecast.']
  quantity varchar [note: 'Projected unit volume for the forecast period.']
  revenue decimal(18,2) [note: 'Projected revenue amount for the forecast period.']
  scenario_name varchar [note: 'Named scenario associated with the forecast.']
  submission_date date [note: 'Date the forecast was submitted for review.']
  unit_of_measure varchar [note: 'Measurement unit for forecast_quantity.']
  updated_by varchar [note: 'User identifier who last updated the forecast.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the forecast record.']
  variance_to_actual decimal(5,2) [note: 'Percentage variance between forecast and actual results.']
  version_number varchar [note: 'Sequential version identifier for the forecast record.']
  created_by varchar [note: 'User identifier who created the forecast.']

  Note: 'Transaction record: Sales demand forecast capturing expected unit volume and revenue by product family, customer, end market, geography, and fiscal period. Supports rolling 12-month and 18-month forecast horizons used in semiconductor S&OP and wafer-start authorization processes. Tracks forecast version (commit, upside, best-case), submission date, confidence level, and variance against actuals. Integrates with SAP APO/IBP demand planning. Enables forecast accuracy KPI tracking (MAPE, bias) critical for fab capacity planning decisions.'
}

Table sales.booking {
  booking_id varchar [pk, note: 'System-generated unique identifier for the booking record.']
  account_id varchar [note: 'Unique identifier of the customer who placed the booking.']
  address_id varchar [note: 'Identifier of the destination location for shipment.']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Booking (order fulfillment) must specify the package type to be produced; needed for manufacturing scheduling and regulatory reporting.']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: A confirmed semiconductor booking captures the price list that was in effect at the time of order placement, enabling price list effectiveness analysis, revenue variance attribution, and audit trail f']
  primary_booking_opportunity_id varchar [note: 'FK to sales.opportunity.opportunity_id — Bookings fulfill opportunities. This link closes the pipeline-to-revenue loop essential for forecast accuracy measurement.']
  quote_id varchar [note: 'Foreign key linking to sales.quote. Business justification: A confirmed booking (firm customer PO) in semiconductor sales is typically placed against a specific quote. The standard sales flow is opportunity → quote → booking. Adding quote_id to booking enables']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Production bookings are linked to a tapeout to schedule wafer fabrication and track yield.']
  backlog_flag boolean [note: 'True if the booking is currently in backlog (unfulfilled).']
  booked_quantity varchar [note: 'Number of units (dies) committed in the booking.']
  booked_revenue_gross decimal(18,2) [note: 'Total revenue amount before discounts and taxes, in the booking currency.']
  booked_revenue_net decimal(18,2) [note: 'Revenue after discounts and before tax.']
  booking_number varchar [note: 'External business number assigned to the booking, used in sales and finance processes.']
  booking_status varchar [note: 'Current lifecycle state of the booking.']
  booking_timestamp timestamp [note: 'Timestamp when the booking was created in the source system.']
  comments varchar [note: 'Free‑form notes entered by sales or operations.']
  compliance_status varchar [note: 'Current compliance status of the booking with internal and regulatory rules.']
  created_timestamp timestamp [note: 'Timestamp when the record was first captured in the lakehouse.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the booking amounts.']
  delivery_mode varchar [note: 'Preferred logistics mode for shipment.']
  discount_amount decimal(18,2) [note: 'Monetary discount applied to the gross revenue.']
  external_order_ref varchar [note: 'Reference to the original sales order in SAP SD.']
  forecast_flag boolean [note: 'True if the booking is included in the sales forecast.']
  is_critical boolean [note: 'True if the booking is deemed critical for product launch or revenue targets.']
  order_type varchar [note: 'Classification of the booking (e.g., standard sale, NRE, design‑win).']
  payment_terms varchar [note: 'Standard payment terms agreed with the customer.']
  pricing_model varchar [note: 'Pricing approach applied to the booking.']
  priority_level varchar [note: 'Business priority assigned to the booking.']
  product_family varchar [note: 'High‑level product family (e.g., ASIC, FPGA, SoC) for the booked part.']
  regulatory_reporting_flag boolean [note: 'True if the booking must be reported under specific regulatory frameworks (e.g., CHIPS Act).']
  requested_delivery_date date [note: 'Date the customer expects the shipment to be delivered.']
  revenue_recognition_date date [note: 'Date when the booked revenue is recognized for accounting.']
  sales_region varchar [note: 'Geographic sales region for the booking.']
  ship_to_country varchar [note: 'Three‑letter country code of the ship‑to location.']
  source varchar [note: 'Origin system that created the booking record.']
  tax_amount decimal(18,2) [note: 'Tax component applied to the net revenue.']
  total_tax_code varchar [note: 'Tax code used for calculating tax_amount.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the booking record.']
  warranty_period_months varchar [note: 'Warranty duration provided to the customer, in months.']

  Note: 'Transaction record: Confirmed sales booking representing a firm customer purchase order commitment for semiconductor devices. Captures booking date, booked revenue, booked units, device part number, customer account, ship-to location, requested delivery date, backlog status, and SAP SD sales order reference. Represents the commercial booking event — distinct from shipment or invoice. SSOT for bookings-to-billings (B2B) ratio, book-to-ship analysis, and revenue waterfall reporting critical to semiconductor quarterly earnings.'
}

Table sales.channel_partner {
  channel_partner_id varchar [pk, note: 'System-generated unique identifier for the channel partner record.']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: Authorized semiconductor channel partners (distributors like Arrow, Avnet) operate under specific pricing agreements tied to a designated price list. Linking channel_partner to price_list normalizes t']
  address_line1 varchar [note: 'First line of the partner\'s primary business address.']
  address_line2 varchar [note: 'Second line of the partner\'s primary business address (optional).']
  authorized_product_lines varchar [note: 'Comma‑separated list of product families the partner may sell.']
  channel_partner_status varchar [note: 'Current operational status of the partner relationship.']
  city varchar [note: 'City component of the partner\'s primary address.']
  contract_effective_from date [note: 'Date on which the partner contract becomes effective.']
  contract_effective_until date [note: 'Date on which the partner contract expires or is scheduled to terminate (null if open‑ended).']
  contract_number varchar [note: 'Unique identifier of the master agreement governing the partner relationship.']
  contract_status varchar [note: 'Lifecycle state of the partner contract.']
  country_code varchar [note: 'Three‑letter ISO country code for the partner\'s primary location.']
  created_timestamp timestamp [note: 'Date‑time when the channel partner record was first created in the lakehouse.']
  external_partner_code varchar [note: 'Identifier used for the partner in external systems (e.g., third‑party distributor portal).']
  hub_consignment_level varchar [note: 'Level of consignment inventory maintained at partner hubs.']
  inventory_reporting_obligation boolean [note: 'Indicates whether the partner must provide regular inventory visibility to Semiconductors.']
  last_audit_timestamp timestamp [note: 'Date‑time when the record was last reviewed for compliance or data quality.']
  legal_entity_name varchar [note: 'Full legal entity name as registered for contracts and compliance.']
  notes varchar [note: 'Free‑form text for internal comments, observations, or special handling instructions.']
  partner_name varchar [note: 'Legal or trade name of the channel partner organization.']
  partner_type varchar [note: 'Category of the partner based on its business model and relationship to Semiconductors.']
  postal_code varchar [note: 'Postal or ZIP code for the partner\'s primary address.']
  price_protection_claims_allowed boolean [note: 'Indicates if the partner can submit price‑protection claims under the agreement.']
  pricing_agreement_type varchar [note: 'Pricing model governing the partner\'s purchase terms.']
  primary_contact_email varchar [note: 'Email address used for official communications with the partner.']
  primary_contact_name varchar [note: 'Full name of the main business contact for the partner.']
  primary_contact_phone varchar [note: 'Telephone number for the primary partner contact.']
  sap_partner_function_code varchar [note: 'SAP SD code that classifies the partner\'s functional role (e.g., sold‑to, ship‑to, bill‑to).']
  sell_through_rate decimal(5,2) [note: 'Percentage of partner inventory sold to end customers over a defined period.']
  state_province varchar [note: 'State or province component of the partner\'s primary address.']
  stock_on_hand varchar [note: 'Current quantity of semiconductor units physically held by the partner.']
  territory_coverage varchar [note: 'Geographic or market territories the partner is authorized to sell within.']
  tier_classification varchar [note: 'Strategic tier assigned to the partner reflecting level of authorization and performance expectations.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the channel partner record.']
  weeks_of_supply decimal(5,2) [note: 'Estimated number of weeks the current stock will satisfy forecasted demand.']

  Note: 'Master record: Authorized semiconductor sales channel partner including distributors (Arrow, Avnet, WPG), rep firms, value-added resellers (VARs), and system integrators. Captures partner type, authorized product lines, territory coverage, tier classification (authorized, preferred, elite), contract status, inventory reporting obligations (stock on hand, weeks of supply, sell-through, hub/consignment levels), and SAP SD partner function reference. SSOT for channel partner identity and distributor inventory visibility within the sales domain. Supports ship-from-stock-and-debit (SFSD) processing and price protection claim management.'
}

Table order.order {
  order_id varchar [pk, note: 'Primary key for order']
  account_id varchar [note: 'Reference to the customer who placed the sales order. Links to the customer master data product.']
  channel_partner_id varchar [note: 'Foreign key linking to sales.channel_partner. Business justification: Orders may be placed via channel partners; the FK enables partner‑attributed revenue and commission reporting.']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Order Management requires a primary sales contact for each order; the Order Confirmation Report pulls contact details, making this link essential.']
  credit_profile_id varchar [note: 'Foreign key linking to customer.credit_profile. Business justification: Order booking and hold/release workflows in semiconductors are directly governed by the customer credit profile. A direct FK supports order credit hold management, credit limit enforcement at booking,']
  customer_contract_id varchar [note: 'Foreign key linking to sales.customer_contract. Business justification: Semiconductor orders are routinely placed under Long-Term Agreements (LTAs) or Master Supply Agreements. Linking order to its governing customer_contract enables pricing compliance validation, volume-']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: In semiconductors, production orders are traceable to the design win that initiated the product ramp. Design-win-to-revenue tracking is a critical KPI for semiconductor sales operations, enabling win ']
  nda_agreement_id varchar [note: 'Foreign key linking to customer.nda_agreement. Business justification: Semiconductor orders for advanced-node or IP-sensitive products must reference an active NDA for export control and IP protection compliance. Order acceptance workflows validate NDA status before book']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: Order creation originates from a closed‑won opportunity; linking enables opportunity‑to‑order conversion reporting.']
  originating_booking_id varchar [note: 'Foreign key linking to sales.booking. Business justification: In semiconductors, a booking event (demand signal confirming customer intent) directly creates a sales order. Linking order back to its originating booking is essential for booking-to-revenue reconcil']
  price_agreement_id varchar [note: 'Foreign key linking to customer.price_agreement. Business justification: Pricing Governance applies a specific price agreement to an order; the Pricing Audit Report and revenue recognition rely on this relationship.']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Shipping Execution process stores the exact customer address for each order; the Shipping Manifest and compliance checks depend on this link.']
  actual_delivery_date date [note: 'The actual date on which the ordered products were delivered to the customer or ship-to location. Used for on-time delivery (OTD) performance analysis and customer satisfaction reporting.']
  allocation_status varchar [note: 'Current inventory or production capacity allocation status of the order. Indicates whether sufficient die, wafer, or finished goods inventory has been reserved to fulfill the order. Critical for backlog management and supply-demand balancing.']
  backlog_flag boolean [note: 'Indicates whether this order is currently included in the active order backlog. True when the order is open and not yet fully shipped or invoiced. Used for backlog valuation, revenue forecasting, and capacity planning.']
  cancellation_reason varchar [note: 'Business reason code or description for order cancellation. Populated only when order_status is CANCELLED. Used for lost revenue analysis, demand forecasting accuracy, and customer relationship management.']
  chips_act_eligible boolean [note: 'Indicates whether this order is associated with products or programs eligible for US CHIPS and Science Act incentives or reporting requirements. Used for government reporting and subsidy tracking.']
  confirmed_delivery_date date [note: 'The delivery date confirmed by the semiconductor manufacturer based on production capacity, wafer fab scheduling, and logistics. May differ from the requested delivery date. Used for backlog management and customer commitment tracking.']
  created_timestamp timestamp [note: 'Timestamp when the sales order record was first created in the source system (SAP S/4HANA SD). Used for audit trail, data lineage, and order entry performance measurement. Corresponds to SAP VBAK.ERDAT + VBAK.ERZET.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the order transaction (e.g., USD, EUR, JPY, TWD, KRW). Defines the currency in which order values, pricing, and invoicing are denominated. Corresponds to SAP VBAK.WAERK.']
  customer_po_number varchar [note: 'The purchase order number provided by the customer at the time of order placement. Used for cross-referencing with the customer\'s procurement system and required for invoice matching. Corresponds to SAP VBAK.BSTNK.']
  distribution_channel varchar [note: 'The sales channel through which the order was placed. Determines pricing tiers, commission structures, and revenue reporting by channel. Corresponds to SAP VBAK.VTWEG.']
  end_market_segment varchar [note: 'The end-market application segment for which the ordered semiconductor products are destined. Used for market segmentation analysis, revenue reporting by vertical, and strategic planning. [ENUM-REF-CANDIDATE: COMPUTING|MOBILE|AUTOMOTIVE|AI_ML|IOT|INDUSTRIAL|NETWORKING|CONSUMER|DEFENSE|MEDICAL — promote to reference product]']
  export_license_required boolean [note: 'Indicates whether an export license is required for this order based on the destination country, end-user, and product ECCN classification. True triggers export compliance review workflow before shipment authorization.']
  gross_order_value decimal(18,2) [note: 'Total gross value of the sales order before application of discounts, taxes, or surcharges, expressed in the order currency. Represents the sum of all line item gross values. Used for revenue forecasting and backlog valuation.']
  hold_reason varchar [note: 'Reason code or description for placing the order on hold. Populated when order_status is ON_HOLD. Common reasons include credit hold, export compliance review, customer request, or supply shortage.']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms) code defining the responsibilities of buyer and seller for delivery, risk transfer, and cost allocation. Corresponds to SAP VBAK.INCO1. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]']
  incoterms_location varchar [note: 'The named place or port associated with the Incoterms code, specifying where risk and cost transfer between buyer and seller (e.g., \'Shanghai Port\', \'Customer Dock\'). Corresponds to SAP VBAK.INCO2.']
  itar_controlled boolean [note: 'Indicates whether any products in this order are subject to ITAR (International Traffic in Arms Regulations) controls. When True, additional export authorization and end-use certification requirements apply before shipment.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the sales order record in the source system. Used for change tracking, audit compliance, and incremental data pipeline processing. Corresponds to SAP VBAK.AEDAT.']
  net_order_value decimal(18,2) [note: 'Net value of the sales order after application of all discounts and pricing conditions but before tax. Represents the contractually agreed revenue amount. Corresponds to SAP VBAK.NETWR. Used for revenue recognition and financial reporting.']
  notes varchar [note: 'Free-text notes or special instructions associated with the sales order, capturing customer-specific requirements, handling instructions, or internal processing notes. Corresponds to SAP order header text.']
  nre_amount decimal(18,4) [note: 'Non-Recurring Engineering (NRE) charges associated with this order, covering one-time design, mask set, and process development costs. Applicable for ASIC, custom IC, and MPW order types. Reported separately from unit product revenue.']
  order_date date [note: 'The calendar date on which the customer placed the sales order. Represents the principal business event date for the order-to-cash lifecycle. Corresponds to SAP VBAK.AUDAT.']
  order_status varchar [note: 'Current lifecycle status of the sales order within the order-to-cash process. Drives workflow routing, backlog reporting, and revenue recognition. [ENUM-REF-CANDIDATE: DRAFT|OPEN|IN_FULFILLMENT|SHIPPED|DELIVERED|CLOSED|CANCELLED|ON_HOLD — promote to reference product]']
  order_type varchar [note: 'Classification of the sales order by product or engagement type. Determines order processing rules, pricing, and fulfillment workflow. Values include: STANDARD_IC (standard integrated circuit), ASIC (Application-Specific Integrated Circuit), FPGA (Field-Programmable Gate Array), MPW (Multi-Project Wafer), NRE (Non-Recurring Engineering), DIE_BANK (die bank pull order), WAFER_START (wafer start authorization). [ENUM-REF-CANDIDATE: STANDARD_IC|ASIC|FPGA|MPW|NRE|DIE_BANK|WAFER_START — promote to reference product]']
  payment_terms_code varchar [note: 'SAP payment terms key defining the payment due date, early payment discount conditions, and cash discount percentages applicable to this order. Corresponds to SAP VBAK.ZTERM (e.g., NT30, NT60, 2/10NET30).']
  priority varchar [note: 'Business priority level assigned to the order, influencing production scheduling, wafer start queue position, and allocation decisions. Critical orders may trigger expedite fees or override standard allocation rules.']
  reach_compliant boolean [note: 'Indicates whether the products ordered comply with the EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) Regulation. Required for EU market access and supply chain chemical safety reporting.']
  requested_delivery_date date [note: 'The date by which the customer has requested delivery of the ordered products. Used for delivery scheduling, wafer start planning, and on-time delivery (OTD) performance measurement. Corresponds to SAP VBAK.VDATU.']
  rohs_compliant boolean [note: 'Indicates whether the products ordered comply with the EU RoHS (Restriction of Hazardous Substances) Directive, restricting the use of specific hazardous materials in electronic equipment. Required for EU market access and customer compliance declarations.']
  ship_to_country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the destination country for shipment. Critical for export compliance screening (EAR/ITAR/BIS), trade sanctions checks, and logistics routing. Corresponds to SAP ship-to party country.']
  so_number varchar [note: 'Externally visible sales order number as assigned by SAP S/4HANA SD module. Used in all customer-facing communications, shipping documents, and invoices. Corresponds to the VBELN field in SAP VBAK table.']
  source varchar [note: 'The channel or system through which the customer order was received and entered. Used for order entry efficiency analysis and digital transformation tracking.']
  tax_amount decimal(18,4) [note: 'Total tax amount applicable to the sales order, including VAT, GST, or other applicable taxes, expressed in the order currency. Required for tax reporting and financial compliance.']
  wafer_start_authorization boolean [note: 'Indicates whether this order has triggered a wafer start authorization in the fabrication facility (FAB). When True, the MES (Manufacturing Execution System) has been instructed to initiate wafer lot processing for this order.']

  Note: 'Master record for all customer sales orders in the semiconductor order-to-cash lifecycle. Captures order header information including customer identity, order type (standard IC, ASIC, FPGA, MPW, NRE), order date, requested delivery date, priority, incoterms, payment terms, currency, total order value, and order status. SSOT for all customer-placed orders including wafer start authorizations, die bank orders, and production lot assignments. Sourced from SAP S/4HANA SD module.'
}

Table order.line {
  line_id varchar [pk, note: 'Unique surrogate identifier for each order line item within the Databricks Silver Layer. Serves as the primary key for the order_line data product.']
  account_id varchar [note: 'Reference to the customer placing the order. Used for line-level customer attribution in multi-ship-to or multi-sold-to scenarios. Corresponds to SAP S/4HANA SD KUNNR (Customer Number).']
  design_registration_id varchar [note: 'Foreign key linking to customer.customer_design_registration. Business justification: Design registrations in semiconductors govern protected pricing and allocation priority for a specific customer/part combination. Linking order lines to design registrations enforces channel conflict ']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Bare die / KGD order lines are fulfilled from die bank inventory. die_bank_order is a plain text field on order_line — denormalization signal. FK to die_bank enables KGD availability checks at order e']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: Customer Certificate of Conformance and quality traceability reports require linking each order line to the final_test_run that qualified the shipped units. Semiconductor quality agreements (IATF 1694']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Order lines for packaged semiconductor products reference specific finished goods inventory records for lot-controlled fulfillment. Linking order_line to finished_good enables available-to-promise at ']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Engineering sample orders, prototype wafer orders, and NRE line items in semiconductors are tied to a specific IC design project for project cost tracking, wafer_start_authorization, and revenue recog']
  order_id varchar [note: 'FK to order.sales_order.sales_order_id — Fundamental header-to-line relationship. Every order line must belong to exactly one sales order. This is the most critical FK in the domain — without it, order lines are orphaned.']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Needed for Packaging Planning; order line specifies requested package type, linking to package_type enables yield, cost, and compliance analysis per packaging family.']
  price_agreement_id varchar [note: 'Foreign key linking to customer.price_agreement. Business justification: In semiconductors, individual order lines reference specific volume-tiered price agreement tiers per SKU. Line-level price agreement FK supports contracted-vs-billed price audit, revenue recognition a']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Semiconductor order fulfillment requires each order line to be validated against applicable quality specifications (AQL, test coverage, reliability grade) before shipment confirmation. This link enabl']
  quote_line_id varchar [note: 'Foreign key linking to sales.quote_line. Business justification: Each order line is derived from a quote line; needed for line‑level margin and fulfillment analysis.']
  sku_id varchar [note: 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, or discrete device) being ordered on this line. Links to the product master for SKU-level configuration details including package type, speed grade, and temperature range.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Primary supplier for the SKU on each order line, used in procurement planning and supplier performance reporting.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: NRE and MPW shuttle order lines in semiconductors are directly tied to a specific tapeout event for mask cost billing, wafer start authorization, and first-silicon delivery tracking. A fab operations ']
  actual_ship_date date [note: 'The date on which the semiconductor units for this order line were physically shipped from the warehouse or OSAT facility. Populated upon goods issue posting in SAP S/4HANA. Used for on-time delivery (OTD) performance measurement.']
  allocation_type varchar [note: 'Classification of the supply allocation method applied to this order line. Standard = normal backlog allocation; Priority = customer-priority or design-win protected allocation; Strategic = long-term agreement allocation; Spot = spot market fulfillment; Buffer = safety stock draw.']
  cancellation_reason varchar [note: 'Reason code for cancellation of this order line when line_status is \'cancelled\'. Supports backlog analysis, demand planning accuracy, and customer relationship management. Populated only for cancelled lines. [ENUM-REF-CANDIDATE: customer_request|supply_constraint|end_of_life|duplicate|pricing_dispute|export_hold|other — 7 candidates stripped; promote to reference product]']
  confirmed_quantity decimal(18,4) [note: 'The quantity of semiconductor units confirmed by supply chain for delivery on this order line, reflecting available inventory, wafer start authorizations, and die bank allocations. May differ from ordered quantity due to allocation constraints.']
  confirmed_ship_date date [note: 'The date confirmed by supply chain and manufacturing for shipment of this order line, based on available inventory, die bank status, and OSAT packaging capacity. May differ from requested ship date due to supply constraints.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the semiconductor product was manufactured (FAB location). Required for customs declarations, trade compliance, tariff classification, and CHIPS Act domestic content reporting.']
  created_timestamp timestamp [note: 'System timestamp when this order line record was first created in the data platform. Used for audit trail, data lineage, and Silver Layer ingestion tracking. Conforms to ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the transaction currency of this order line (e.g., USD, EUR, JPY, KRW, TWD). Semiconductor industry commonly transacts in USD but supports multi-currency for global customers.']
  customer_part_number varchar [note: 'The customer\'s own internal part number or cross-reference number for the ordered semiconductor product. Critical for design-win tracking, customer portal integration, and order acknowledgment matching. Sourced from Salesforce CRM design-win records.']
  date_entered date [note: 'The business date on which this order line was entered into the SAP S/4HANA SD system. Represents the commercial event date for backlog aging calculations and order-to-cash cycle time measurement.']
  export_control_classification varchar [note: 'Export Administration Regulations (EAR) Export Control Classification Number (ECCN) for the semiconductor product on this order line (e.g., 3A001 for advanced ICs). Required for export compliance screening, license determination, and ITAR/EAR regulatory reporting.']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibilities between the semiconductor company and the customer for this order line (e.g., FOB, DDP, EXW). Corresponds to SAP S/4HANA SD INCO1. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  item_category varchar [note: 'SAP SD item category classification for this order line, indicating the business nature of the line (e.g., standard product sale, consignment fill-up, customer return, engineering sample, NRE charge, MPW service, evaluation unit). Drives pricing, delivery, and billing behavior. [ENUM-REF-CANDIDATE: standard|consignment|returns|sample|nre|mpw|evaluation — 7 candidates stripped; promote to reference product]']
  line_number varchar [note: 'Sequential position number of this line item within the parent sales order. Used for ordering, display, and reference in customer-facing documents. Corresponds to SAP S/4HANA SD POSNR (Item Number of the SD Document).']
  line_status varchar [note: 'Current workflow status of this order line item within the order-to-cash lifecycle. Drives backlog management, allocation decisions, and revenue recognition. Corresponds to SAP S/4HANA SD overall delivery status at item level.']
  lot_number varchar [note: 'The manufacturing lot number assigned to the production batch fulfilling this order line. Enables traceability from customer order back to wafer fabrication lot, die bank lot, and OSAT packaging lot. Sourced from Camstar MES lot tracking.']
  mpw_order boolean [note: 'Indicates whether this order line is associated with a Multi-Project Wafer (MPW) run, where multiple customer designs share a single wafer to reduce NRE costs. True = MPW order; False = dedicated production lot order.']
  net_value decimal(18,2) [note: 'Total net value of this order line calculated as confirmed quantity multiplied by unit price in the transaction currency. Used for backlog reporting, revenue forecasting, and SOX-compliant revenue recognition. Corresponds to SAP S/4HANA SD NETWR (Net Value of the Order Item).']
  ordered_quantity decimal(18,4) [note: 'The quantity of semiconductor units (dies, packaged ICs, wafers, or reels) requested by the customer on this order line. Expressed in the sales unit of measure (e.g., pieces, wafers, reels). Corresponds to SAP S/4HANA SD KWMENG (Cumulative Order Quantity).']
  partial_shipment_allowed boolean [note: 'Indicates whether the customer permits partial shipments against this order line. True = partial shipments accepted; False = complete order line quantity must ship together. Drives delivery scheduling and backlog management decisions.']
  product_revision varchar [note: 'The silicon revision or stepping of the ordered semiconductor product (e.g., A0, B1, C2). Critical for tracking product change notifications (PCNs), errata management, and ensuring customers receive the correct silicon revision per their qualification.']
  reach_compliant boolean [note: 'Indicates whether the semiconductor product on this order line is compliant with the EU REACH Regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals). Required for EU chemical safety compliance and customer material declarations.']
  requested_delivery_date date [note: 'The date by which the customer requires receipt of the semiconductor units at their facility. Distinct from requested ship date; accounts for transit time. Used for customer SLA compliance tracking.']
  requested_ship_date date [note: 'The date on which the customer has requested shipment of this order line. Drives production scheduling, wafer start authorization timelines, and OSAT packaging commitments. Corresponds to SAP S/4HANA SD WUNSK (Customer\'s Requested Delivery Date at Item Level).']
  rohs_compliant boolean [note: 'Indicates whether the semiconductor product on this order line is compliant with the EU Restriction of Hazardous Substances (RoHS) Directive, restricting use of lead, mercury, cadmium, and other hazardous materials. Required for EU market access.']
  sap_line_item_number varchar [note: 'The native SAP S/4HANA SD six-digit item number (POSNR) for this order line, used for traceability back to the system of record and for EDI/customer portal reconciliation.']
  ship_to_country varchar [note: 'ISO 3166-1 alpha-3 country code for the destination country of this order line shipment. Used for export control screening, customs documentation, tariff determination, and trade compliance reporting.']
  shipped_quantity decimal(18,4) [note: 'Cumulative quantity of semiconductor units actually shipped against this order line across all partial shipments. Used for backlog calculation and revenue recognition. Sourced from SAP S/4HANA SD delivery documents.']
  special_handling_code varchar [note: 'Code indicating special handling, storage, or shipping requirements for this order line (e.g., ESD-sensitive, moisture-sensitive level (MSL), controlled humidity, ITAR-controlled, hazmat). Drives warehouse and logistics instructions. [ENUM-REF-CANDIDATE: ESD|MSL1|MSL2|MSL3|ITAR|HAZMAT|CONTROLLED_TEMP|FRAGILE — promote to reference product]']
  speed_grade varchar [note: 'The speed or performance grade of the ordered semiconductor product, indicating the maximum operating frequency or timing specification (e.g., -1, -2, -3 for FPGAs; 3200MHz, 4800MHz for memory). Differentiates SKUs within the same product family.']
  temperature_grade varchar [note: 'Operating temperature range classification for the ordered semiconductor product. Commercial (0°C to 70°C), Industrial (-40°C to 85°C), Automotive (-40°C to 125°C, AEC-Q100), Military (-55°C to 125°C). Determines qualification standard and pricing tier.']
  unit_of_measure varchar [note: 'Sales unit of measure for the ordered semiconductor product. EA = Each (individual packaged IC), WFR = Wafer, REEL = Tape-and-reel packaging, TRAY = JEDEC tray, TUBE = Tube packaging. Corresponds to SAP S/4HANA SD VRKME (Sales Unit).']
  unit_price decimal(18,6) [note: 'Agreed net unit selling price for the semiconductor product on this order line, expressed in the transaction currency. Reflects negotiated pricing, volume discounts, and design-win pricing agreements. Corresponds to SAP S/4HANA SD NETPR (Net Price).']
  updated_timestamp timestamp [note: 'System timestamp of the most recent update to this order line record in the data platform. Supports change data capture (CDC), audit trail, and incremental processing in the Databricks Lakehouse Silver Layer.']
  wafer_start_authorization boolean [note: 'Indicates whether a wafer start authorization (WSA) has been issued to the fabrication facility (FAB) to initiate production of wafers for fulfilling this order line. True = WSA issued; False = pending or not required (e.g., fulfilled from die bank or finished goods inventory).']

  Note: 'Individual line items within a customer sales order, each representing a distinct semiconductor product SKU, quantity, unit price, requested ship date, confirmed ship date, and line-level status. Captures product configuration details such as package type, speed grade, temperature range, and special handling requirements. Supports partial shipments and line-level allocation tracking. Sourced from SAP S/4HANA SD order line items.'
}

Table order.delivery_schedule {
  delivery_schedule_id varchar [pk, note: 'Unique surrogate identifier for each delivery schedule line record in the SAP S/4HANA SD schedule line table (VBEP). Primary key for the delivery_schedule data product in the Silver layer.']
  account_id varchar [note: 'Reference to the sold-to customer for whom this delivery schedule is planned. Supports customer-level delivery performance analytics and blanket order management.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Delivery schedule lines in semiconductor ops are committed against specific assembly lots. Lot-level delivery commit tracking — used in customer commit reports and supply chain visibility dashboards —']
  assembly_order_id varchar [note: 'Foreign key linking to packaging.assembly_order. Business justification: In semiconductor make-to-order manufacturing, delivery schedule lines are driven by assembly orders. Production-to-delivery commit visibility — used in S&OP planning and customer promise date manageme']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Bare die delivery schedules are fulfilled from die bank inventory. die_bank_order_number is a plain text denormalized field on delivery_schedule. Normalizing to die_bank_id enables die bank availabili']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Delivery schedule confirmation (CTP/ATP) requires knowing which finished goods inventory record will fulfill each scheduled delivery line. Semiconductor customer service teams confirm delivery schedul']
  fulfilling_shipment_id varchar [note: 'Foreign key linking to order.shipment. Business justification: A delivery schedule line represents a planned delivery commitment; a shipment represents the physical execution of that commitment. Linking delivery_schedule to shipment via fulfilling_shipment_id ena']
  order_id varchar [note: 'Reference to the parent sales order header from which this delivery schedule line originates. Links the schedule line back to the order-to-cash transaction header.']
  origin_storage_location_id varchar [note: 'Reference to the originating ship-from location for this delivery schedule line. May be a wafer fabrication facility (FAB), OSAT (Outsourced Semiconductor Assembly and Test) site, or finished goods warehouse.']
  primary_delivery_order_line_id varchar [note: 'Reference to the specific sales order line item (order item) for which this delivery schedule line is created. A single order line may have multiple schedule lines representing different delivery windows.']
  ship_to_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Delivery schedules in semiconductors specify the exact customer destination address per schedule line (fab, warehouse, or consignment hub). Required for incoterms application, export control screening']
  sku_id varchar [note: 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, or packaged die) being scheduled for delivery on this schedule line.']
  to_order_line_id varchar [note: 'FK to order.order_line.order_line_id — Delivery schedules define delivery windows per order line. delivery_schedule.order_line_id → order_line.order_line_id.']
  actual_delivery_date date [note: 'The date on which the shipment was confirmed as received at the customer\'s ship-to location. Used for on-time delivery (OTD) KPI calculation and customer satisfaction reporting.']
  actual_ship_date date [note: 'The actual date on which the shipment physically departed the ship-from location. Populated upon goods issue posting in SAP. Used for on-time shipment performance measurement.']
  allocation_priority varchar [note: 'Numeric priority rank assigned to this delivery schedule line during constrained supply allocation. Lower values indicate higher priority. Used by supply chain planners to allocate limited wafer or die inventory across competing customer orders.']
  backlog_flag boolean [note: 'Indicates whether this delivery schedule line is currently in backlog status (confirmed delivery date is past due or confirmed quantity is less than ordered quantity). Used for backlog management reporting and customer escalation tracking.']
  blanket_order_flag boolean [note: 'Indicates whether this delivery schedule line is part of a blanket (framework) order with periodic call-offs. Blanket orders are common for high-volume semiconductor customers with rolling delivery schedules.']
  call_off_number varchar [note: 'The specific call-off or release number issued by the customer against a blanket order for this delivery schedule line. Identifies the periodic release instruction within the blanket order framework.']
  confirmed_delivery_date date [note: 'The delivery date confirmed by the semiconductor manufacturer to the customer after availability check (ATP) and capacity validation. May differ from the requested date due to wafer fab cycle time or OSAT capacity constraints.']
  confirmed_quantity decimal(18,4) [note: 'The quantity confirmed by the manufacturer for delivery on this schedule line after ATP (Available-to-Promise) check. May be less than ordered quantity due to allocation constraints or yield limitations.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the semiconductor product was manufactured (wafer fab or final assembly location). Required for customs declarations, tariff classification, and export control compliance.']
  created_timestamp timestamp [note: 'Timestamp when this delivery schedule line record was first created in the source SAP S/4HANA SD system. Supports audit trail, data lineage, and SLA measurement from order entry.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the transaction value fields on this delivery schedule line (e.g., USD, EUR, JPY). Supports multi-currency semiconductor sales operations.']
  delivered_quantity decimal(18,4) [note: 'The actual quantity of units shipped and delivered against this schedule line. Populated from goods issue and proof-of-delivery confirmation. Used to compute open backlog.']
  delivery_document_number varchar [note: 'SAP outbound delivery document number (SD delivery order) created against this schedule line. Links the schedule line to the physical goods issue and shipping execution documents.']
  eccn_code varchar [note: 'Export Control Classification Number assigned to the semiconductor product on this schedule line per the US Commerce Control List (CCL). Determines applicable export license requirements. Examples: 3A001 (electronic components), 3E001 (technology for IC design).']
  export_control_status varchar [note: 'Export control compliance status for this delivery schedule line. Semiconductor shipments may be subject to EAR (Export Administration Regulations), ITAR (International Traffic in Arms Regulations), or CHIPS Act restrictions. \'blocked\' prevents shipment until clearance is obtained.']
  hazmat_flag boolean [note: 'Indicates whether the shipment for this delivery schedule line contains hazardous materials (e.g., certain chemical compounds in semiconductor packaging). Triggers special handling, labeling, and documentation requirements per RoHS and REACH regulations.']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms 2020) code defining the transfer of risk and responsibility between the semiconductor manufacturer and the customer for this delivery. Governs freight cost allocation and insurance obligations. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  incoterms_location varchar [note: 'The named place or port associated with the Incoterms code for this delivery schedule line (e.g., \'FOB Shanghai\', \'DAP Austin TX\'). Required by ICC Incoterms 2020 to complete the delivery terms specification.']
  last_reschedule_reason varchar [note: 'Free-text or coded reason for the most recent rescheduling of this delivery schedule line (e.g., \'wafer yield shortfall\', \'OSAT capacity constraint\', \'customer push-out request\', \'export hold\'). Supports root cause analysis for delivery performance.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this delivery schedule line record in the source SAP S/4HANA SD system. Used for incremental data pipeline processing and change detection in the Silver layer.']
  mpw_order_flag boolean [note: 'Indicates whether this delivery schedule line is associated with a Multi-Project Wafer (MPW) order, where multiple customer designs share a single wafer run. MPW orders have distinct lead times and delivery constraints.']
  net_value decimal(18,2) [note: 'Net monetary value of the confirmed quantity on this delivery schedule line in the transaction currency. Calculated as confirmed quantity multiplied by the agreed unit price. Used for revenue recognition, backlog valuation, and SOX financial reporting.']
  ordered_quantity decimal(18,4) [note: 'The quantity of semiconductor units (dies, packaged ICs, wafers) originally ordered by the customer on this schedule line. Expressed in the sales unit of measure (e.g., pieces, wafers).']
  packaging_type varchar [note: 'The physical packaging format for the semiconductor units being delivered on this schedule line. Packaging type affects handling, storage, and customer assembly line compatibility. Common formats include tape-and-reel (for SMT), tray, tube, bulk, waffle pack, and bare wafer.']
  quantity_unit varchar [note: 'Unit of measure for all quantity fields on this schedule line. Common semiconductor units include PC (pieces/individual ICs), WF (wafers), KGD (Known Good Die), LOT (production lot), REEL (tape-and-reel packaging), TRAY (tray packaging).']
  requested_delivery_date date [note: 'The delivery date originally requested by the customer for this schedule line. Represents the customer\'s desired receipt date and is the baseline for on-time delivery (OTD) measurement.']
  rohs_compliant_flag boolean [note: 'Indicates whether the semiconductor product being delivered on this schedule line is compliant with the EU Restriction of Hazardous Substances (RoHS) Directive. Required for shipments to EU customers and increasingly mandated globally.']
  sap_schedule_line_category varchar [note: 'SAP SD schedule line category code controlling the delivery and goods movement behavior of this schedule line (e.g., CP = standard delivery with transfer of requirements, CN = no goods movement). Sourced from SAP VBEP-ETTYP.']
  schedule_line_number varchar [note: 'Sequential line number of this delivery schedule entry within the parent order line item. Used to order multiple delivery windows for the same order line (e.g., line 1 = 500 units on date A, line 2 = 500 units on date B).']
  schedule_line_revision varchar [note: 'Revision counter tracking how many times this delivery schedule line has been modified (date changes, quantity adjustments, rescheduling). Supports audit trail requirements and customer change notification (PCN) tracking.']
  schedule_line_status varchar [note: 'Current fulfillment lifecycle status of this delivery schedule line. Drives backlog management, delivery performance reporting, and customer communication. \'blocked\' indicates an export control or credit hold.']
  schedule_status varchar
  scheduled_delivery_date date
  scheduled_quantity decimal(18,4)
  scheduled_ship_date date [note: 'The planned date on which the shipment is expected to leave the ship-from location (fab, OSAT, or warehouse). Calculated by subtracting transit lead time from the confirmed delivery date.']
  wafer_start_authorization_number varchar [note: 'Wafer Start Authorization number linking this delivery schedule line to the authorized wafer fab start that will produce the units for this delivery. Critical for semiconductor order-to-cash lifecycle management and fab capacity planning.']

  Note: 'Planned and confirmed delivery schedule for customer orders, capturing multiple delivery windows per order line. Records scheduled delivery date, confirmed quantity, ship-from location (fab, OSAT, warehouse), ship-to customer location, carrier, incoterms, and schedule line status. Supports rolling delivery schedules for high-volume customers with blanket orders and periodic call-offs. Sourced from SAP S/4HANA SD schedule lines.'
}

Table order.shipment {
  shipment_id varchar [pk, note: 'Unique system-generated identifier for the shipment record. Primary key for the shipment data product in the order domain.']
  account_id varchar [note: 'Reference to the customer receiving this shipment. Used for delivery confirmation, revenue recognition, and customer service tracking.']
  line_id varchar [note: 'FK to order.order_line.order_line_id — Shipments fulfill order lines. After merging shipment_line into shipment, the shipment entity needs direct linkage to order lines for fulfillment tracking.']
  nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: Shipments with damaged_goods_flag, wrong_part_flag, or quantity_shortage_flag trigger NCRs in semiconductor operations. Direct FK from shipment to NCR enables outbound quality event traceability, cust']
  origin_storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Shipments originate from a specific warehouse or storage location. origin_facility_code is a denormalized plain text field on shipment. Linking to storage_location enables outbound logistics reporting']
  osat_vendor_id varchar [note: 'Foreign key linking to packaging.osat_vendor. Business justification: Shipments originate from OSAT facilities; linking shipment to osat_vendor enables OSAT-level on-time delivery KPIs, quality escape traceability, and logistics cost reporting. origin_facility_code is a']
  primary_shipment_order_id varchar [note: 'Reference to the parent sales order that initiated this shipment. Links the shipment back to the order-to-cash lifecycle.']
  receiving_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Semiconductor shipments require a named customer receiving contact for ASN delivery notifications, customs clearance coordination, and proof-of-delivery confirmation. This contact is distinct from the']
  shipment_order_id varchar
  to_order_id varchar [note: 'FK to order.order.order_id — Shipments fulfill customer orders. shipment.sales_order_id → order.sales_order_id. Critical for order-to-cash traceability.']
  actual_arrival_date date [note: 'Confirmed date the shipment physically arrived at the customer receiving location. Populated from carrier proof of delivery (POD) or customer EDI 856 acknowledgement.']
  asn_number varchar [note: 'Advance Shipment Notice (ASN) number transmitted to the customer via EDI 856 prior to physical delivery. Enables customer warehouse receiving preparation and automated goods receipt.']
  carrier_name varchar [note: 'Name of the freight carrier or logistics service provider responsible for transporting the shipment (e.g., FedEx, DHL, UPS, Nippon Express). Used for carrier performance analytics and claims management.']
  carrier_tracking_number varchar [note: 'Carrier-assigned tracking number for the shipment. Enables real-time shipment visibility and customer self-service tracking via carrier portals.']
  created_timestamp timestamp [note: 'Timestamp when the shipment record was first created in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for monetary values in this shipment record (e.g., USD, EUR, JPY). Supports multi-currency operations across global semiconductor supply chains.']
  customer_po_number varchar [note: 'Customer-provided purchase order number referenced on the shipment and delivery documentation. Required for customer receiving, invoice matching, and accounts payable processing.']
  damaged_goods_flag boolean [note: 'Indicates whether the customer reported damaged goods upon delivery. Triggers carrier claims process, RMA initiation, and DPPM (Defective Parts Per Million) quality reporting.']
  declared_value_usd decimal(14,2) [note: 'Declared value of the shipment contents in US dollars for customs and insurance purposes. Required for import duty calculation and export documentation under EAR/ITAR.']
  destination_country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the customer delivery destination. Required for export compliance screening under EAR and ITAR regulations.']
  estimated_arrival_date date [note: 'Carrier-provided estimated date of arrival at the customer destination. Used for delivery scheduling, customer communication, and on-time delivery (OTD) performance tracking.']
  export_control_classification varchar [note: 'Export Control Classification Number (ECCN) assigned to the semiconductor products in this shipment per the Commerce Control List (CCL). Determines applicable export license requirements.']
  freight_cost_usd decimal(14,2) [note: 'Total freight and logistics cost for this shipment in US dollars. Used for cost allocation, customer billing (if freight is charged), and supply chain cost analytics.']
  gross_weight_kg decimal(10,3) [note: 'Total gross weight of the shipment in kilograms including packaging. Required for carrier freight billing, customs declarations, and dangerous goods compliance.']
  hs_tariff_code varchar [note: 'Harmonized System (HS) tariff classification code for the semiconductor products in this shipment. Required for customs declarations, import duties, and cross-border trade compliance.']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms 2020) code defining the transfer of risk and responsibility between seller and buyer. Governs freight cost allocation and title transfer point. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]']
  inspection_certificate_number varchar [note: 'Reference number of the quality inspection certificate (Certificate of Conformance or Certificate of Analysis) accompanying the shipment. Required for automotive (IATF 16949) and aerospace customers.']
  is_multi_leg boolean [note: 'Indicates whether this shipment involves multiple transportation legs (e.g., fab to OSAT to customer, or cross-border transshipment). Enables multi-leg shipment tracking and compliance documentation.']
  lot_numbers varchar [note: 'Comma-separated list of manufacturing lot numbers (wafer lot IDs) included in this shipment. Enables full traceability from customer delivery back to wafer fabrication and process engineering records in Camstar MES.']
  notes varchar [note: 'Free-text field for operational notes, special handling instructions, or customer-specific delivery requirements associated with this shipment (e.g., ESD handling, temperature-controlled transport).']
  package_count varchar [note: 'Total number of physical packages (boxes, reels, trays, tubes) included in this shipment. Used for carrier manifest, customs declaration, and receiving verification.']
  package_type varchar [note: 'Physical packaging format used for the semiconductor products in this shipment. Determines handling requirements, ESD protection, and customer assembly line compatibility.']
  pod_confirmed_quantity decimal(18,4) [note: 'Quantity confirmed as received by the customer at the delivery location per the proof of delivery (POD). Compared against shipped_quantity to identify shortages or overages.']
  pod_receipt_date date [note: 'Date the customer confirmed receipt of the shipment as captured in the proof of delivery (POD). Triggers downstream invoice release and revenue recognition in SAP S/4HANA FI.']
  pod_signoff_reference varchar [note: 'Customer signoff reference or electronic signature identifier from the proof of delivery document. Serves as legal evidence of delivery completion for dispute resolution and revenue recognition.']
  quantity_shortage_flag boolean [note: 'Indicates whether the customer reported a quantity shortage at delivery (POD confirmed quantity less than shipped quantity). Triggers discrepancy investigation and potential credit memo.']
  reach_compliant boolean [note: 'Indicates whether the shipment contents comply with EU REACH regulation requirements for chemical substance registration and restriction. Required for EU market access.']
  receiving_location_code varchar [note: 'Code identifying the specific customer receiving dock, warehouse, or facility where the shipment was delivered. Used for multi-site customer delivery routing and POD reconciliation.']
  rma_reference_number varchar [note: 'Return Merchandise Authorization (RMA) number associated with this shipment if a return or dispute has been initiated. Links shipment to the RMA and reverse logistics process.']
  rohs_compliant boolean [note: 'Indicates whether all semiconductor products in this shipment comply with the EU Restriction of Hazardous Substances (RoHS) Directive. Required for EU market access and customer compliance declarations.']
  service_level varchar [note: 'Carrier service tier selected for this shipment (e.g., overnight, express, standard ground). Determines transit time commitment and freight cost.']
  ship_date date [note: 'Actual date the shipment physically departed the origin facility (fab, OSAT, or distribution center). Principal business event date for the shipment transaction.']
  shipment_number varchar [note: 'Externally visible, human-readable shipment identifier used in carrier communications, customer EDI 856 ASN, and logistics documentation. Sourced from SAP S/4HANA SD outbound delivery number.']
  shipment_status varchar [note: 'Current lifecycle state of the shipment. Drives downstream processes including invoice release and revenue recognition upon delivery confirmation.']
  shipped_quantity decimal(18,4) [note: 'Total quantity of semiconductor units (dies, packaged ICs, wafers) physically shipped in this shipment. Expressed in the base unit of measure (UOM) for the product.']
  tracking_number varchar
  unit_of_measure varchar [note: 'Unit of measure for the shipped quantity. EA = each (packaged IC), WFR = wafer, DIE = individual die, REEL = tape-and-reel, TRAY = JEDEC tray, TUBE = IC tube.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the shipment record. Supports change tracking, audit compliance, and incremental data pipeline processing.']
  wrong_part_flag boolean [note: 'Indicates whether the customer reported receipt of an incorrect part number or product. Triggers RMA process, root cause analysis, and corrective action in the quality management system.']

  Note: 'Physical shipment record tracking the outbound movement of semiconductor products from origin (fab, OSAT, distribution center) to customer destination. Header captures shipment number, carrier, tracking number, ship date, estimated and actual arrival dates, package count, gross weight, HS tariff codes, export license reference, and shipment status. Line-level detail captures shipped quantity per order line, lot numbers, wafer lot IDs, package types, serial numbers, unit of measure, and inspection certificate references. Delivery confirmation section captures proof of delivery (POD) including confirmed receipt date, receiving location, confirmed quantity, customer PO reference, discrepancy flags (quantity shortage, wrong part, damaged goods), and customer signoff reference. POD receipt triggers downstream invoice release and revenue recognition. Supports multi-leg shipments, cross-border trade compliance (EAR, ITAR), RMA dispute resolution, and full traceability from order line through physical delivery. Sourced from SAP S/4HANA SD outbound delivery, carrier POD data, and customer EDI 856 ASN acknowledgements.'
}

Table order.shipment_line {
  shipment_line_id varchar [pk, note: 'Unique surrogate identifier for each shipment line record in the Silver Layer lakehouse. Primary key for the shipment_line data product.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Semiconductor lot traceability regulations (ITAR, RoHS, customer quality audits) require linking each shipped line to its assembly lot. Quality escapes and field failure investigations depend on this ']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Bare die shipment lines are fulfilled from die bank inventory. die_bank_order_number is a plain text denormalized field on shipment_line. FK to die_bank enables die bank quantity depletion tracking on']
  fabrication_wafer_lot_id varchar [note: 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: Semiconductor shipment traceability requires linking each shipment line to the source wafer lot for Certificate of Conformance (CoC), customer quality records, ITAR/export control compliance, and RMA ']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: Shipment-level test traceability is a core semiconductor quality requirement. Linking shipment_line to final_test_run enables Certificate of Conformance generation, customer quality audits, and field ']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Shipment lines ship specific finished goods inventory lots. Linking shipment_line to finished_good enables certificate of conformance generation, lot traceability for customer quality records, and pos']
  fulfilling_allocation_record_id varchar [note: 'Foreign key linking to order.allocation_record. Business justification: In semiconductor order fulfillment, a shipment line is the physical execution of an allocation record — the allocation reserves specific wafer lots or die bank inventory, and the shipment line records']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Shipment lines carry lot-level traceability in semiconductor operations. The inspection_lot result is required to generate the certificate_of_conformance_number on the shipment_line. Direct FK enables']
  primary_shipment_id varchar [note: 'Reference to the parent shipment header record. Links this line to the physical shipment event (HEADER_REFERENCE per TRANSACTION_LINE role).']
  primary_shipment_order_line_id varchar [note: 'Reference to the customer order line that this shipment line fulfills. Enables traceability from physical shipment back to the originating sales order line in the order-to-cash lifecycle.']
  sku_id varchar [note: 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, etc.) being shipped on this line. RESOURCE_REFERENCE per TRANSACTION_LINE role.']
  to_order_line_id varchar [note: 'FK to order.order_line.order_line_id — Critical fulfillment traceability link. Each shipment line fulfills a specific order line. Required for order fulfillment tracking, partial shipment management, and revenue recognition.']
  to_shipment_id varchar [note: 'FK to order.shipment.shipment_id — Fundamental header-to-line relationship. Every shipment line must belong to exactly one shipment.']
  actual_ship_date date [note: 'Date on which the product was physically handed over to the carrier or freight forwarder. Used for on-time shipment performance, revenue recognition trigger, and export documentation.']
  advance_ship_notice_number varchar [note: 'EDI Advance Ship Notice (ASN/856) document number transmitted to the customer prior to shipment. Enables customer receiving automation and inventory planning.']
  backorder_flag boolean [note: 'Indicates whether this shipment line represents a partial fulfillment of a backordered quantity, where the full ordered quantity could not be shipped due to inventory allocation constraints.']
  certificate_of_conformance_number varchar [note: 'Document number of the Certificate of Conformance issued by quality assurance, attesting that the shipped product meets all specified requirements. Required for automotive (IATF 16949) and aerospace customers.']
  country_of_origin varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code indicating where the semiconductor product was manufactured or substantially transformed. Required for customs declarations, export control (EAR/ITAR), and RoHS/REACH compliance documentation.']
  created_timestamp timestamp [note: 'Timestamp when this shipment line record was first created in the system. Used for audit trail, data lineage, and Silver Layer ingestion tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the unit selling price and line value (e.g., USD, EUR, JPY). Required for multi-currency order management.']
  customer_part_number varchar [note: 'Customer-assigned part number or device designation for the shipped product. Required for customer-facing shipping documents, ASN (Advance Ship Notice), and design-in traceability.']
  date_code varchar [note: 'Manufacturing date code in YYWW format (year + work week) indicating when the product was fabricated or assembled. Required for shelf-life management, FIFO inventory rotation, and customer quality audits.']
  delivery_document_number varchar [note: 'Externally-visible SAP outbound delivery document number associated with this shipment line, used for customer communication and logistics coordination.']
  eccn_code varchar [note: 'Export Control Classification Number assigned to this product line item per the US Commerce Control List (CCL). Required for EAR compliance screening and export license determination for semiconductor products.']
  goods_issue_timestamp timestamp [note: 'Precise timestamp when goods issue was posted in SAP, marking the transfer of ownership and triggering revenue recognition and inventory reduction. BUSINESS_EVENT_TIMESTAMP for this transaction line.']
  inspection_certificate_number varchar [note: 'Reference number of the quality inspection certificate (Certificate of Conformance or Certificate of Analysis) issued for this shipment line. Links to quality records from KLA ICOS inspection systems and QM module.']
  itar_controlled boolean [note: 'Indicates whether this shipment line item is subject to ITAR controls as a defense article or defense service. When true, requires State Department export license and end-use certificate.']
  line_net_value decimal(18,4) [note: 'Total net value of this shipment line (shipped_quantity × unit_selling_price after applicable discounts). Used for revenue recognition, invoice generation, and SOX financial reporting.']
  line_number varchar [note: 'Sequential line number within the parent shipment, used to order and reference individual line items. LINE_SEQUENCE per TRANSACTION_LINE role.']
  line_status varchar [note: 'Current fulfillment lifecycle status of this shipment line. Tracks progression from open through picking, packing, shipment, and delivery confirmation or cancellation.']
  moisture_sensitivity_level varchar [note: 'JEDEC moisture sensitivity level classification for the shipped packaged IC. Determines floor life, storage, and baking requirements at the customer\'s SMT assembly facility.']
  ordered_quantity decimal(18,4) [note: 'Original quantity requested on the customer order line for this product. Enables calculation of fulfillment rate and identification of short-ships or over-ships.']
  package_type varchar [note: 'Semiconductor package type for the shipped product (e.g., BGA, QFN, WLCSP, InFO, CoWoS, TSOP, DIP, SOP). Determines handling, inspection, and customer board assembly requirements. [ENUM-REF-CANDIDATE: BGA|QFN|WLCSP|InFO|CoWoS|TSOP|DIP|SOP|LGA|CSP — promote to reference product]']
  packaging_configuration varchar [note: 'Physical packaging configuration used for the shipped semiconductor units. Determines handling requirements, moisture sensitivity level (MSL), and customer SMT assembly compatibility.']
  part_number varchar [note: 'Manufacturer part number (MPN) for the shipped semiconductor product as listed in the product catalog and on the shipping documentation. Used for customer identification and BOM matching.']
  partial_shipment_flag boolean [note: 'Indicates whether this line represents a partial shipment against the order line quantity. When true, additional shipment lines are expected to fulfill the remaining ordered quantity.']
  promised_delivery_date date [note: 'Committed delivery date for this shipment line as agreed with the customer at order entry. Used for on-time delivery (OTD) performance measurement and customer SLA tracking.']
  reach_compliant boolean [note: 'Indicates whether the shipped product complies with EU REACH regulation requirements for chemical substance registration and restriction. Required for EU market access and supply chain transparency.']
  revision_level varchar [note: 'Hardware or mask revision level of the shipped IC (e.g., A0, B1, C2). Critical for customer compatibility verification, PCN (Product Change Notification) compliance, and field failure analysis.']
  rma_reference_number varchar [note: 'RMA number associated with this shipment line if it is a replacement shipment for a previously returned or disputed lot. Enables linkage between original shipment, quality dispute, and replacement fulfillment.']
  rohs_compliant boolean [note: 'Indicates whether the shipped product complies with EU RoHS Directive restrictions on hazardous substances (lead, mercury, cadmium, etc.). Required for EU market access and customer compliance declarations.']
  serial_number_range_end varchar [note: 'Ending serial number of the serialized unit range included in this shipment line. Used with serial_number_range_start to define the complete set of serialized units shipped.']
  serial_number_range_start varchar [note: 'Starting serial number of the serialized unit range included in this shipment line. Applicable for high-value or security-sensitive ICs requiring individual unit traceability (e.g., automotive, military-grade).']
  shipped_quantity decimal(18,4) [note: 'Actual quantity of semiconductor units (dies, packaged ICs, wafers, etc.) physically shipped on this line. LINE_QUANTITY per TRANSACTION_LINE role. May differ from ordered quantity due to partial shipments or allocation constraints.']
  temperature_grade varchar [note: 'Operating temperature range grade of the shipped IC (commercial: 0–70°C, industrial: -40–85°C, automotive: -40–125°C, military: -55–125°C). Critical for customer application qualification and IATF 16949 automotive compliance.']
  unit_of_measure varchar [note: 'Unit of measure for the shipped quantity. Common semiconductor UoMs include EA (each/die), WFR (wafer), LOT (production lot), REEL (tape-and-reel packaging), TRAY (IC tray), BOX (carton). Aligned with SAP base UoM.']
  unit_selling_price decimal(18,6) [note: 'Agreed selling price per unit for this shipment line as invoiced to the customer. LINE_VALUE_OR_RESULT per TRANSACTION_LINE role. Sensitive commercial pricing data.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this shipment line record. Supports change data capture (CDC), audit compliance, and Silver Layer delta processing.']
  wafer_start_authorization_number varchar [note: 'Wafer Start Authorization number that triggered the production lot associated with this shipment line. Links shipment fulfillment back to the original fab capacity commitment in the order-to-cash lifecycle.']
  yield_grade varchar [note: 'Quality or speed grade assigned to the shipped product based on wafer test (probe) results and final test binning. Indicates performance tier (e.g., commercial, industrial, automotive, military grade) for the shipped units.']

  Note: 'Line-level detail of a shipment record, linking specific order lines and quantities to a physical shipment. Captures shipped quantity, unit of measure, lot number, wafer lot ID, package type, serial numbers (where applicable), and inspection certificate references. Enables traceability from customer order line to physical shipment and supports RMA and quality dispute resolution.'
}

Table order.backlog_position {
  backlog_position_id varchar [pk, note: 'Unique surrogate identifier for each backlog position snapshot record in the order-to-cash lifecycle. Primary key for the backlog_position data product.']
  account_id varchar [note: 'Reference to the customer account associated with this backlog position. Used for customer-level backlog aggregation, escalation prioritization, and revenue forecasting.']
  assembly_order_id varchar [note: 'Foreign key linking to packaging.assembly_order. Business justification: Semiconductor backlog management requires linking open demand positions to their fulfilling assembly orders. Backlog-to-production matching reports — used by demand planners and customer commit teams ']
  customer_contract_id varchar [note: 'Foreign key linking to sales.customer_contract. Business justification: Semiconductor backlog reporting is governed by LTA volume commitments and pricing tiers defined in customer contracts. Linking backlog_position to customer_contract enables contract-vs-backlog varianc']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Bare die / KGD backlog positions must be reconciled against die bank inventory for commit date calculation. Semiconductor companies with die bank programs track open backlog against available KGD die.']
  fabrication_wafer_lot_id varchar [note: 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: Semiconductor backlog management requires linking backlog positions to specific wafer lots to determine when backlog will convert to shipment. Sales ops use this for commit accuracy, push/pull analysi']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Backlog management requires real-time available-to-promise against finished goods inventory. Sales operations and supply chain teams run backlog-vs-inventory reconciliation reports daily to identify f']
  order_id varchar [note: 'Reference to the parent sales order header to which this backlog position belongs. Links the backlog snapshot to the originating customer order.']
  primary_order_line_id varchar [note: 'FK to order.order_line.order_line_id — Backlog positions track unshipped quantities for specific order lines. Without this FK, backlog cannot be reconciled to orders.']
  sku_id varchar [note: 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, or discrete device) associated with this backlog position. Enables product-level backlog analysis and demand planning.']
  allocated_quantity decimal(18,4) [note: 'The quantity from available inventory or in-process production lots that has been formally allocated to fulfill this backlog position. May be less than committed_quantity in constrained supply scenarios.']
  allocation_status varchar [note: 'Indicates the degree to which available inventory or production capacity has been allocated to fulfill this backlog position. Critical for backlog management and supply-demand balancing in constrained semiconductor supply environments.']
  backlog_aging_days varchar [note: 'Number of calendar days this order line has been in open backlog as of the snapshot date, calculated from order_entry_date. Used for customer escalation prioritization and aged backlog reporting.']
  backlog_quantity decimal(18,4)
  backlog_status varchar [note: 'Current workflow state of this backlog position. \'open\' = unshipped committed order; \'committed\' = confirmed with delivery date; \'at_risk\' = delivery commitment in jeopardy; \'pushed_out\' = delivery date deferred; \'cancelled\' = order line cancelled; \'fulfilled\' = shipped and closed.']
  backlog_value decimal(18,2) [note: 'The monetary value of the unshipped committed backlog quantity, calculated as committed_quantity multiplied by the net selling price. Used for revenue forecasting, quarterly guidance, and book-to-bill ratio reporting.']
  cancelled_quantity decimal(18,4) [note: 'Quantity cancelled from the original order line. Tracks cancellation impact on backlog coverage and book-to-bill ratio reporting.']
  committed_quantity decimal(18,4) [note: 'The unshipped quantity (in units) that remains committed in backlog for this order line as of the snapshot date. Core metric for backlog management and production planning.']
  created_timestamp timestamp [note: 'The timestamp when this backlog position record was first created in the data platform. Used for audit trail, data lineage, and record lifecycle management.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which the backlog value and selling price are denominated (e.g., USD, EUR, JPY, KRW, TWD). Required for multi-currency backlog reporting and FX exposure analysis.']
  current_commit_date date [note: 'The most recent confirmed delivery date committed to the customer, reflecting any push-outs or pull-ins from the original promise date. Used for revenue forecasting and quarterly close planning.']
  customer_part_number varchar [note: 'The customer\'s own part number or reference code for the ordered product. Required for customer-facing order confirmations and cross-referencing customer purchase orders with internal part numbers.']
  customer_po_number varchar [note: 'The customer\'s purchase order number referencing this backlog position. Required for customer reconciliation, invoice matching, and accounts receivable processing.']
  design_win_flag boolean [note: 'Indicates whether this backlog position is associated with a strategic design-win account tracked in Salesforce CRM. Design-win orders receive elevated fulfillment priority to protect long-term revenue relationships.']
  end_market_segment varchar [note: 'The end-market application segment for which the ordered semiconductor product is destined. Used for segment-level backlog analysis, demand forecasting, and investor guidance on market exposure. [ENUM-REF-CANDIDATE: computing|mobile|automotive|industrial|iot|communications|consumer|ai_datacenter — promote to reference product]']
  export_control_flag boolean [note: 'Indicates whether this order line is subject to export control regulations (EAR/ITAR). When true, shipment requires validated export license or license exception before fulfillment.']
  export_license_number varchar [note: 'The export license number issued by the Bureau of Industry and Security (BIS) or State Department authorizing shipment of controlled semiconductor products. Required when export_control_flag is true.']
  hold_code varchar [note: 'Code indicating the reason this backlog position is on hold and cannot be shipped. Examples include credit hold, export license pending, quality hold, or customer-requested hold. Null when no hold is active. [ENUM-REF-CANDIDATE: credit_hold|export_hold|quality_hold|customer_hold|compliance_hold|capacity_hold — promote to reference product]']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms 2020) code defining the delivery obligations, risk transfer point, and cost responsibilities between seller and buyer for this order line. Impacts revenue recognition timing. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  last_updated_timestamp timestamp [note: 'The timestamp when this backlog position record was most recently modified, reflecting the latest change to any field such as commit date revision, quantity adjustment, or status change.']
  net_selling_price decimal(18,6) [note: 'The agreed net unit selling price for this order line after all applicable discounts and price adjustments. Used to compute backlog value and support revenue recognition under ASC 606.']
  order_entry_date date [note: 'The date on which the customer order was originally entered into the order management system. Used to calculate backlog aging and time-in-backlog metrics.']
  order_type varchar [note: 'Classification of the order type driving this backlog position. Distinguishes standard production orders from Multi-Project Wafer (MPW) orders, die bank orders, wafer start authorizations, sample orders, Return Material Authorizations (RMA), and consignment orders. [ENUM-REF-CANDIDATE: standard|mpw|die_bank|wafer_start|sample|rma|consignment — promote to reference product]']
  original_order_quantity decimal(18,4) [note: 'The total quantity originally ordered by the customer on this order line. Used to calculate fulfillment percentage and track cancellation or reduction impacts on backlog.']
  original_promise_date date [note: 'The initial delivery date committed to the customer at the time of order entry. Baseline for measuring push-outs and delivery performance against original commitment.']
  part_number varchar [note: 'The manufacturer\'s part number (MPN) of the semiconductor product ordered. Used for product identification, cross-referencing with PLM and ERP systems, and customer-facing order documentation.']
  priority_rank varchar [note: 'Numeric priority ranking assigned to this backlog position for allocation and fulfillment sequencing. Lower values indicate higher priority. Used during supply-constrained periods to prioritize strategic customers and design-win accounts.']
  push_out_days varchar [note: 'Number of calendar days the current_commit_date has been deferred beyond the original_promise_date. Positive value indicates a push-out (delay); negative value indicates a pull-in (acceleration). Key metric for delivery performance and customer satisfaction.']
  push_out_reason_code varchar [note: 'Standardized reason code explaining why the delivery commitment was pushed out or pulled in. Examples include wafer yield issue, capacity constraint, material shortage, customer request, or logistics delay. [ENUM-REF-CANDIDATE: yield_issue|capacity_constraint|material_shortage|customer_request|logistics_delay|design_change|export_hold — promote to reference product]']
  requested_delivery_date date [note: 'The delivery date originally requested by the customer on the purchase order. May differ from the original promise date if the committed date was negotiated.']
  revenue_recognition_flag boolean [note: 'Indicates whether this backlog position meets the criteria for revenue recognition upon shipment under ASC 606 / IFRS 15. False indicates revenue deferral conditions apply (e.g., consignment, bill-and-hold arrangements).']
  sales_region varchar [note: 'Geographic sales region associated with this backlog position (e.g., Americas, EMEA, Japan, Greater China, Rest of APAC). Used for regional backlog reporting and revenue forecasting.']
  ship_to_country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the destination country for shipment. Used for export control screening, logistics routing, and regional revenue reporting.']
  shipped_quantity decimal(18,4) [note: 'Cumulative quantity already shipped against this order line as of the snapshot date. Together with committed_quantity, reconciles to the original order quantity.']
  snapshot_date date [note: 'The calendar date on which this point-in-time backlog position snapshot was captured. Enables time-series backlog trending, quarterly close reporting, and book-to-bill ratio calculation.']
  unit_of_measure varchar [note: 'The unit in which quantities are expressed for this backlog position. EA = each (individual units), KU = thousands of units, WAFER = full wafer, DIE = individual die, REEL = tape-and-reel packaging unit, TRAY = tray packaging unit.']

  Note: 'Point-in-time snapshot of open order backlog for a specific order line, capturing unshipped committed quantity, backlog value, original promise date, current commit date, and backlog aging in days. Used for backlog management, revenue forecasting, customer escalation prioritization, and quarterly book-to-bill ratio reporting. Tracks push-outs, pull-ins, and cancellations affecting committed backlog. Critical for semiconductor revenue recognition, quarterly close processes, and investor guidance on backlog coverage.'
}

Table order.allocation_record {
  allocation_record_id varchar [pk, note: 'Unique system-generated surrogate key identifying a single inventory, capacity, or lot allocation record within the order fulfillment process.']
  account_id varchar [note: 'Reference to the customer for whom inventory or capacity is being allocated. Used for constrained supply allocation prioritization across competing customers.']
  allocated_die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: KGD (Known Good Die) and bare die orders are allocated directly from die bank inventory. Semiconductor companies serving flip-chip or bare die customers must link allocation records to die bank to tra']
  allocated_finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Finished goods allocation to customer orders is a core semiconductor order fulfillment process. Allocation records must reference the specific finished goods inventory record being committed to a cust']
  allocated_inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Semiconductor allocation planning explicitly ties wafer lot WIP inventory to allocation records for supply commit decisions. Allocation managers need to know which specific wafer lot backs each custom']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Semiconductor allocation management assigns specific finished-goods assembly lots to customer orders. Lot-level allocation tracking — required for constrained supply scenarios, priority customers, and']
  fabrication_wafer_lot_id varchar [note: 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: Semiconductor allocation engines assign specific wafer lots to customer orders — the allocation record must reference the exact lot being allocated to support inventory reservation, supply-demand matc']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Semiconductor supply planners confirm or hold allocations based on inspection lot disposition (pass/fail/hold). allocation_record has quality_disposition field indicating denormalization from inspecti']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Allocation records must reference the material master to verify compliance attributes (RoHS, REACH, ITAR), lead times, and safety stock parameters at allocation time. This supports regulatory complian']
  nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: Semiconductor supply planners place allocations on hold when an NCR is raised against the associated lot. Direct FK from allocation_record to nonconformance_report enables automated hold management, d']
  primary_order_line_id varchar [note: 'FK to order.order_line.order_line_id — Allocations reserve inventory against specific order lines. This is the core link for constrained supply management.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Allocation records in semiconductor order management must reference the supplying purchase order to confirm supply availability, calculate commit dates, and support demand-supply matching. This is the']
  sales_order_id varchar [note: 'Reference to the parent sales order header under which this allocation record is created. Supports backlog management and order-to-cash reporting.']
  sku_id varchar [note: 'Reference to the semiconductor product (IC, SoC, ASIC, FPGA, packaged die, or wafer) being allocated to the customer order line.']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: Semiconductor supply allocation decisions are directly constrained by wafer probe yield results. Supply planners reference wafer_probe_run to determine allocatable die counts and commit delivery dates']
  actual_ship_date date [note: 'The actual date on which the allocated goods were shipped to the customer. Used for on-time delivery measurement and order fulfillment confirmation.']
  allocated_quantity decimal(18,4) [note: 'The quantity of units (dies, wafers, or packaged devices) reserved against the customer order line. Expressed in the unit of measure applicable to the lot type.']
  allocation_date date [note: 'The business date on which the allocation was created and the inventory or capacity was reserved against the order line. Principal business event date for this transaction.']
  allocation_number varchar [note: 'Externally visible, human-readable business identifier for this allocation record. Used in customer communications, ERP transactions, and supply chain coordination.']
  allocation_source varchar [note: 'Identifies the inventory or capacity pool from which this allocation is drawn: \'finished_goods\' (packaged inventory), \'die_bank\' (singulated die inventory), \'wafer_lot\' (in-process wafer inventory), \'fab_capacity\' (reserved fab production capacity), \'mpw_pool\' (Multi-Project Wafer shared pool).']
  allocation_status varchar
  allocation_type varchar [note: 'Categorizes the nature of the allocation: \'hard\' (firm reservation of physical inventory), \'soft\' (provisional hold pending confirmation), \'tentative\' (preliminary planning hold), \'capacity\' (fab capacity reservation), \'die_bank\' (allocation from die bank inventory), \'mpw\' (Multi-Project Wafer run allocation). [ENUM-REF-CANDIDATE: hard|soft|tentative|capacity|die_bank|mpw — promote to reference product]']
  assignment_status varchar [note: 'Current lifecycle state of the allocation assignment: \'tentative\' (preliminary hold), \'confirmed\' (firm allocation committed to order), \'shipped\' (goods dispatched against this allocation), \'cancelled\' (allocation voided), \'expired\' (allocation lapsed past expiry date), \'on_hold\' (allocation suspended pending resolution). [ENUM-REF-CANDIDATE: tentative|confirmed|shipped|cancelled|expired|on_hold — promote to reference product]']
  backlog_flag boolean [note: 'Indicates whether this allocation record is part of the open order backlog (i.e., not yet shipped). Used for backlog management reporting and supply-demand balancing.']
  cancellation_reason varchar [note: 'Reason code or description explaining why this allocation was cancelled. Populated when assignment_status transitions to \'cancelled\'. Supports root cause analysis and supply planning.']
  chips_act_eligible boolean [note: 'Indicates whether this allocation is associated with production eligible for US CHIPS and Science Act incentives or reporting requirements. Supports CHIPS Act compliance tracking.']
  confirmation_date date [note: 'The date on which the allocation was formally confirmed, transitioning from tentative or soft to confirmed status. Triggers downstream shipment scheduling.']
  confirmed_quantity decimal(18,4) [note: 'The quantity formally confirmed for shipment after quality disposition and availability verification. May differ from allocated_quantity due to yield loss, quality holds, or partial confirmations.']
  constrained_supply_flag boolean [note: 'Indicates whether this allocation was made under constrained supply conditions, where demand exceeded available inventory or fab capacity. Triggers priority-based allocation logic.']
  created_timestamp timestamp [note: 'System timestamp recording when this allocation record was first created in the order fulfillment system. Supports audit trail and data lineage requirements.']
  end_market_segment varchar [note: 'Target end-market segment for the allocated product: \'automotive\', \'mobile\', \'computing\', \'iot\', \'aerospace\', \'industrial\', \'consumer\'. Drives allocation priority rules and regulatory traceability requirements (e.g., IATF 16949 for automotive). [ENUM-REF-CANDIDATE: automotive|mobile|computing|iot|aerospace|industrial|consumer — promote to reference product]']
  expiry_date date [note: 'The date after which this allocation record is no longer valid and reserved inventory or capacity is released back to available supply. Critical for managing soft allocations and tentative holds.']
  export_control_classification varchar [note: 'Export Administration Regulations (EAR) Export Control Classification Number (ECCN) applicable to the allocated product lot. Required for export compliance screening and license determination.']
  fab_site_code varchar [note: 'Code identifying the fabrication facility (FAB) where the allocated wafer lot or die lot was manufactured. Supports supply chain traceability and export control compliance.']
  hold_reason varchar [note: 'Reason code or description explaining why this allocation is placed on hold. Populated when assignment_status is \'on_hold\'. May relate to quality holds, export control review, or customer credit issues.']
  inventory_batch_code varchar [note: 'SAP batch management identifier for the specific inventory batch being allocated. Enables batch-level traceability and quality disposition linkage within SAP S/4HANA MM.']
  itar_controlled boolean [note: 'Indicates whether the allocated lot is subject to International Traffic in Arms Regulations (ITAR) controls. When true, additional export licensing and handling restrictions apply.']
  last_updated_timestamp timestamp [note: 'System timestamp recording the most recent modification to this allocation record. Used for change tracking, audit compliance, and incremental data pipeline processing.']
  lot_type varchar [note: 'Classifies the type of manufacturing lot being allocated: \'wafer_lot\' (silicon wafer lot at fab), \'die_lot\' (singulated die inventory), \'packaged_goods_lot\' (finished packaged semiconductor units), \'mpw_lot\' (Multi-Project Wafer shared lot).']
  osat_site_code varchar [note: 'Code identifying the Outsourced Semiconductor Assembly and Test (OSAT) facility responsible for packaging and testing the allocated lot. Relevant for packaged goods lot allocations.']
  priority_rank varchar [note: 'Numeric priority rank assigned to this allocation record for constrained supply allocation decisions. Lower values indicate higher priority. Used during supply shortages to sequence allocation across competing customer orders.']
  quality_disposition varchar [note: 'Quality disposition status of the allocated lot or inventory batch: \'accepted\' (meets all quality specifications), \'rejected\' (fails quality criteria), \'conditionally_accepted\' (accepted with documented deviations), \'under_review\' (quality evaluation in progress), \'scrapped\' (lot destroyed). Supports IATF 16949 lot-level quality traceability.']
  quality_disposition_notes varchar [note: 'Free-text notes documenting lot-specific quality disposition findings, deviations, or conditions associated with this allocation. Supports automotive and aerospace traceability requirements.']
  quantity_unit_of_measure varchar [note: 'Unit of measure for the allocated quantity: \'EA\' (each, for packaged units), \'WFR\' (wafers), \'DIE\' (individual die), \'KPC\' (thousand pieces). Aligns with SAP base unit of measure.']
  reach_compliant boolean [note: 'Indicates whether the allocated lot complies with EU REACH regulation requirements for chemical safety. Required for EU market shipments and supply chain due diligence.']
  requested_ship_date date [note: 'Customer-requested shipment date for the allocated quantity. Used for delivery schedule management and on-time delivery performance tracking.']
  rohs_compliant boolean [note: 'Indicates whether the allocated lot meets EU RoHS Directive requirements for restriction of hazardous substances. Required for EU market shipments and customer compliance documentation.']
  scheduled_ship_date date [note: 'Internally confirmed shipment date scheduled by supply chain planning for this allocation. May differ from requested_ship_date due to capacity or inventory constraints.']
  shipped_quantity decimal(18,4) [note: 'Actual quantity shipped against this allocation record. Populated upon delivery confirmation. Used for order fulfillment reconciliation and backlog management.']
  wafer_start_authorization_number varchar [note: 'Wafer Start Authorization number associated with this allocation, linking the allocation to the authorized fab production run. Relevant for capacity allocations and wafer lot allocations in the order-to-cash lifecycle.']

  Note: 'Inventory, capacity, and lot allocation record that reserves specific wafer lots, die bank inventory, finished goods, or fab capacity against a customer order line. Captures allocated quantity, allocation type (hard/soft), allocated lot or inventory batch, lot number, lot type (wafer lot, die lot, packaged goods lot), assignment status (tentative, confirmed, shipped), assignment date, lot-specific quality disposition notes, allocation expiry date, and priority rank. SSOT for all allocation and lot-to-order assignment decisions in the order fulfillment process. Manages constrained supply allocation across competing customer orders during supply shortages. Supports automotive (IATF 16949) and aerospace lot-level traceability requirements from order through shipment.'
}

Table order.rma {
  rma_id varchar [pk, note: 'Primary key for rma']
  account_id varchar [note: 'Reference to the customer initiating the return. Links RMA to the customer master record.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: RMA disposition and DPPM analysis in semiconductor quality management require tracing returned units to their originating assembly lot. Corrective action reports and supplier scorecards depend on this']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: RMA initiation and warranty claim processing require tracking the specific customer contact (quality engineer, procurement manager) who raised the return. Enables RMA history per contact, failure anal']
  fabrication_wafer_lot_id varchar [note: 'Reference to the manufacturing lot from which the returned units originated. Critical for traceability and yield impact analysis.']
  failure_analysis_report_id varchar [note: 'Reference to the failure analysis record if FA was performed. Links RMA to detailed root cause investigation and corrective action.']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: RMA failure analysis requires determining if a field failure was a test escape by comparing field failure mode against the original final_test_run data. This is a mandatory step in semiconductor FA wo']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: RMAs for engineering samples and first-silicon require tracing failures back to the originating IC design project for design-level root cause analysis, corrective action, and DPPM reporting. rma has r']
  line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: An RMA is typically raised against a specific order line item (a particular part number, quantity, and price on the original order). Linking rma.rma_order_line_id to order_line.order_line_id enables p']
  nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: Every customer RMA in semiconductor operations triggers an NCR for defect documentation, disposition decision, and corrective action initiation. ISO 9001 / IATF 16949 mandate traceability from custome']
  original_shipment_id varchar [note: 'Foreign key linking to order.shipment. Business justification: An RMA is initiated because a customer received defective or incorrect product via a specific shipment. Linking rma.original_shipment_id to shipment.shipment_id enables direct traceability from the re']
  primary_rma_order_id varchar [note: 'FK to order.order.order_id — RMAs reference the original sales order for the returned product. rma.sales_order_id → order.sales_order_id.']
  receiving_storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Returned goods are received at a specific quarantine or receiving storage location. receiving_facility_code is a denormalized plain text field on rma. Linking to storage_location enables quarantine in']
  return_from_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: RMA logistics require the customer ship-from address for carrier pickup scheduling, export control re-screening of returned goods, and credit memo processing. In semiconductors, returned parts may be ']
  return_inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Returned material in semiconductor RMA processes undergoes incoming inspection, creating an inspection_lot for disposition (scrap, rework, return to stock). Role-prefix \'return_\' distinguishes incomin']
  returned_finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: RMA disposition processing requires linking returned parts to the finished goods inventory record for restock, scrap, or rework decisions. Quality teams need to match returned goods to the original fi']
  rma_order_id varchar [note: 'FK to order.sales_order.sales_order_id — RMAs reference the original sales order for the returned product. Required for credit processing and quality traceability.']
  sku_id varchar [note: 'Reference to the product master record for the returned semiconductor product (IC, SoC, ASIC, FPGA, or packaged die).']
  tertiary_rma_sales_order_id varchar [note: 'Reference to the original sales order from which the returned product was shipped. Links RMA to the originating order transaction.']
  unit_test_result_id varchar [note: 'Foreign key linking to test.unit_test_result. Business justification: Unit-level RMA failure analysis requires linking the returned device to its specific unit_test_result to identify test escapes and correlate parametric data with field failures. Semiconductor FA engin']
  approval_date date [note: 'Date when the RMA was approved by the quality or customer service team. Nullable if RMA is rejected or still pending.']
  closed_date date [note: 'Date when the RMA was fully closed after disposition action completed (credit issued, replacement shipped, or material scrapped).']
  corrective_action_required boolean [note: 'Indicates whether a formal corrective action (CAPA) is required based on the RMA findings. True triggers CAPA workflow per ISO 9001 and IATF 16949.']
  created_timestamp timestamp [note: 'Timestamp when this RMA record was first created in the system. Audit trail for record lifecycle tracking.']
  credit_amount decimal(18,2) [note: 'Monetary value of the credit issued to the customer in the transaction currency. Nullable if no credit is issued.']
  credit_memo_number varchar [note: 'Reference number of the credit memo issued to the customer for the returned material. Nullable if no credit is issued (e.g., customer error returns).']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the credit amount (e.g., USD, EUR, JPY, CNY).']
  defect_description varchar [note: 'Free-text description of the defect or issue reported by the customer. Captures detailed failure symptoms, visual observations, or functional anomalies.']
  disposition_instruction varchar [note: 'Action to be taken with the returned material. Determines downstream workflow (credit memo, replacement order, FA request, or scrap authorization).']
  dppm_impact_flag boolean [note: 'Indicates whether this RMA should be counted in DPPM calculations. True if the defect is attributable to manufacturing or design (excludes customer-induced damage).']
  export_control_flag boolean [note: 'Indicates whether the returned product is subject to export control regulations (ITAR, EAR). True requires special handling and documentation.']
  failure_analysis_requested boolean [note: 'Indicates whether a formal failure analysis (FA) has been requested for the returned units. True triggers FA workflow and lab assignment.']
  inspection_result varchar [note: 'Outcome of the incoming inspection. Determines whether the return claim is valid and informs disposition and credit decisions.']
  internal_notes varchar [note: 'Internal notes and comments for cross-functional coordination (quality, engineering, customer service). Not shared with customer.']
  last_modified_timestamp timestamp [note: 'Timestamp when this RMA record was last updated. Audit trail for change tracking and data lineage.']
  reach_compliant boolean [note: 'Indicates whether the returned product is REACH compliant. Affects material handling, disposal, and rework procedures.']
  received_date date [note: 'Date when the returned material was physically received at the receiving facility or OSAT partner. Nullable until material arrives.']
  request_date date [note: 'Date when the customer initiated the RMA request. Principal business event timestamp for the RMA lifecycle.']
  return_reason varchar
  return_reason_code varchar [note: 'Standardized code categorizing the reason for the return. Used for root cause analysis, DPPM tracking, and warranty claim classification.']
  return_shipping_carrier varchar [note: 'Name of the logistics carrier used to ship the returned material (e.g., FedEx, UPS, DHL, regional freight forwarder).']
  return_tracking_number varchar [note: 'Carrier tracking number for the return shipment. Used for shipment visibility and proof of receipt.']
  returned_quantity decimal(18,4) [note: 'Number of units (dies, packaged chips, or wafers) returned under this RMA. Used for DPPM calculation and inventory adjustment.']
  rma_date date
  rma_number varchar [note: 'Externally-visible unique business identifier for the RMA. Used in customer communications, shipping labels, and cross-system tracking.']
  rma_status varchar [note: 'Current lifecycle status of the RMA. Tracks progression from customer request through receipt, inspection, and final disposition. [ENUM-REF-CANDIDATE: requested|approved|rejected|in_transit|received|inspected|closed|cancelled — 8 candidates stripped; promote to reference product]']
  rohs_compliant boolean [note: 'Indicates whether the returned product is RoHS compliant. Affects disposition options (scrap vs. rework) and environmental handling requirements.']
  root_cause_category varchar [note: 'High-level categorization of the root cause identified during inspection or FA. Used for DPPM trending and corrective action prioritization.']
  unit_of_measure varchar [note: 'Unit of measure for the returned quantity. EA=each (individual die/chip), WFR=wafer, LOT=production lot, KIT=assembly kit.']
  warranty_claim_flag boolean [note: 'Indicates whether this RMA is being processed as a warranty claim. True if the return is within warranty period and defect is covered.']
  warranty_expiration_date date [note: 'Date when the warranty coverage for the returned product expires. Used to validate warranty claim eligibility.']

  Note: 'RMA (Return Material Authorization) record managing customer returns of semiconductor products for quality issues, shipping damage, or end-of-life returns. Captures RMA number, return reason code, defect description, returned product and quantity, original order reference, disposition instruction (scrap, rework, credit, replacement), credit memo reference, and failure analysis request flag. SSOT for customer return workflows and DPPM tracking inputs.'
}

Table quality.inspection_lot {
  inspection_lot_id varchar [pk, note: 'Unique identifier for the inspection lot record.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Required for the Inspection Lot Customer Assignment report, tying each lot’s inspection results to the purchasing customer for traceability, billing, and compliance.']
  calibration_record_id varchar [note: 'Foreign key linking to equipment.calibration_record. Business justification: IATF 16949 requires traceability of measurement equipment calibration status at the time of inspection. Linking inspection_lot to the active calibration_record of the inspection tool enables auditors ']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: An inspection lot is conducted according to a control plan that defines the sampling rate, measurement criteria, tolerances, and inspection tool. Adding control_plan_id to inspection_lot normalizes th']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Inspection Lot‑PO traceability required for Supplier Performance Review reports linking inspection results to the originating purchase order.']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: Incoming quality inspection of raw materials (silicon wafers, process chemicals) is a mandatory IQC process. inspection_lot.lot_type and material_type indicate raw material coverage. This link support']
  supplier_id varchar [note: 'Unique identifier of the supplier providing the material.']
  acceptance_criteria varchar [note: 'Maximum defect count allowed for acceptance.']
  created_timestamp timestamp [note: 'Timestamp when the inspection lot record was created.']
  defect_count varchar [note: 'Total number of defects detected in the lot.']
  defect_density decimal(10,4) [note: 'Defects per unit area metric for the lot.']
  disposition varchar [note: 'Final disposition assigned to the lot after inspection.']
  disposition_reason varchar [note: 'Explanation for the chosen disposition.']
  external_lot_code varchar [note: 'External reference code used by suppliers or customers.']
  iatf_16949_compliant boolean [note: 'Indicates compliance with IATF 16949 automotive quality standards.']
  inspection_lot_status varchar [note: 'Current lifecycle status of the inspection lot.']
  inspection_result varchar [note: 'Overall outcome of the inspection.']
  inspection_stage varchar [note: 'Process stage at which the inspection occurs.']
  inspection_type varchar [note: 'Category of inspection performed on the lot.']
  iso_9001_compliant boolean [note: 'Indicates compliance with ISO 9001 quality management.']
  jedec_reliability_compliant boolean [note: 'Indicates compliance with JEDEC reliability specifications.']
  kgd_certification_date date [note: 'Date when KGD certification was granted.']
  kgd_certified boolean [note: 'Flag indicating whether the lot contains KGD‑certified dies.']
  last_modified_by varchar [note: 'User name of the person who last modified the record.']
  lot_size varchar [note: 'Total number of units (wafers, dies, or packaged parts) in the lot.']
  lot_type varchar [note: 'Classification of the lot based on its position in the workflow.']
  material_type varchar [note: 'Type of material the lot consists of.']
  measurement_timestamp timestamp [note: 'Timestamp of the primary measurement taken during inspection.']
  measurement_unit varchar [note: 'Unit of the measured value.']
  measurement_value decimal(12,4) [note: 'Numeric value of the key measurement (e.g., critical dimension).']
  notes varchar [note: 'Free‑form notes or comments about the inspection lot.']
  quality_engineer varchar [note: 'Name of the quality engineer responsible for the lot.']
  rejection_criteria varchar [note: 'Defect count threshold that triggers rejection.']
  sample_size varchar [note: 'Number of units sampled from the lot.']
  sampling_plan_aql varchar [note: 'AQL value defined for the sampling plan.']
  technology_node varchar [note: 'Process technology node used for the lot.']
  unit_of_measure varchar [note: 'Unit used to quantify the lot size.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  wafer_size_mm decimal(5,2) [note: 'Diameter of wafers in the lot, expressed in millimetres.']
  yield_percent decimal(5,2) [note: 'Percentage of good units produced from the lot.']

  Note: 'Master record for a quality inspection lot representing a batch of wafers, dies, or packaged units submitted for quality inspection at any stage. Covers all inspection types: incoming material (IQC for raw wafers, chemicals, photomasks, gases, OSAT subassemblies with supplier and PO reference), in-process (FEOL, BEOL, packaging), and final outgoing. Captures lot origin, supplier ID (for IQC), inspection type, inspection stage, lot size, sampling plan parameters (AQL, sample size, acceptance/rejection numbers), inspection results, measured parameters, and disposition decision (accept, reject, hold, rework). Integrates with SAP QM and Camstar MES for lot status management and goods receipt inspection. SSOT for all quality inspection activities across the fab-to-finish flow including incoming quality control.'
}

Table quality.defect_record {
  defect_record_id varchar [pk, note: 'Unique identifier for the defect record.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Enables the Defect Ownership Tracking process, linking each defect to the responsible customer account for warranty claims and customer notifications.']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Defect records with die_x/die_y coordinates track die-level defects that directly affect die bank quality and KGD status. This link enables die bank quality holds and KGD re-certification decisions wh']
  ip_core_id varchar [note: 'Foreign key linking to design.ip_core. Business justification: Needed for Defect Attribution Report to associate each defect with the specific IP core block used in the design, enabling targeted remediation.']
  primary_wafer_map_id varchar [note: 'FK to quality.wafer_map.wafer_map_id — Defects with X/Y coordinates must link to the wafer map for spatial analysis. This is critical for systematic defect pattern detection.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Supplier Corrective Action Requests (SCARs) and supplier quality scorecards require defect records to be directly traceable to the responsible supplier. IATF 16949 supplier monitoring mandates this tr']
  wafer_id varchar [note: 'Identifier of the wafer on which the defect was observed.']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: Defects are detected during wafer probe runs. Quality engineers must correlate defect records to the specific probe run for yield loss analysis, probe card qualification, and root cause investigation.']
  bin_assignment varchar [note: 'Pass/fail bin code assigned to the die (e.g., P, F1, F2).']
  comments varchar [note: 'Additional free‑form notes from the inspector or analyst.']
  corrective_action varchar [note: 'Planned or executed action to remediate the defect.']
  defect_area_um2 double [note: 'Calculated area of the defect in square micrometers.']
  defect_classification varchar [note: 'High‑level classification of the defect (e.g., particle, patterning, etch).']
  defect_code varchar [note: 'Standardized code representing the defect type (e.g., D001, D002).']
  defect_density_per_zone double [note: 'Number of defects per unit area within the zone.']
  defect_layer varchar [note: 'Process layer where the defect was found.']
  defect_severity varchar [note: 'Severity rating indicating impact on yield.']
  defect_size_nm double [note: 'Measured size of the defect in nanometers.']
  defect_status varchar [note: 'Current workflow status of the defect record.']
  detection_method varchar [note: 'Technique used to detect the defect.']
  die_x varchar [note: 'Column index of the die containing the defect on the wafer grid.']
  die_y varchar [note: 'Row index of the die containing the defect on the wafer grid.']
  disposition varchar [note: 'Final handling decision for the defect.']
  edge_exclusion_zone_flag boolean [note: 'Indicates whether the defect lies within the defined edge exclusion area.']
  event_timestamp timestamp [note: 'Date and time when the defect was detected during inspection.']
  flat_notch_orientation varchar [note: 'Orientation of wafer flat or notch relative to the defect.']
  inspection_recipe varchar [note: 'Name of the inspection recipe or parameter set used.']
  record_audit_created timestamp [note: 'Timestamp when the defect record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the defect record.']
  repeatability_flag boolean [note: 'True if the defect pattern repeats across multiple wafers.']
  root_cause varchar [note: 'Narrative description of the identified root cause.']
  x_coordinate double [note: 'Horizontal position of the defect on the wafer map (millimeters).']
  y_coordinate double [note: 'Vertical position of the defect on the wafer map (millimeters).']

  Note: 'Transactional record capturing individual defect events, wafer-level defect maps, and spatial bin distributions detected during wafer inspection, die sort, or final test. At the defect event level: stores defect classification code, defect coordinates (X/Y on wafer map), defect size, defect layer (FEOL/MOL/BEOL), detection method (KLA ICOS optical, e-beam, SEM), severity rating, and disposition (scrap, rework, accept). At the wafer map level: captures per-wafer die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Enables yield spatial analysis, systematic defect pattern detection (repeater analysis, cluster detection), and wafer-level bin map visualization. Integrates directly with KLA ICOS inspection system output and ATE wafer probing systems. SSOT for all defect events, spatial defect analysis, and wafer-level quality maps.'
}

Table quality.wafer_map {
  wafer_map_id varchar [pk, note: 'Primary key for wafer_map']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Design-correlated defect pattern analysis: wafer maps are generated for specific design projects; design engineers analyze wafer maps to distinguish systematic (design-driven) from random defect patte']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: A wafer map is a spatial defect/bin distribution map produced for an individual wafer within an inspection lot. wafer_map currently links to fabrication_wafer_lot and wafer but has no direct FK to the']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Tapeout-level defect density tracking: wafer maps are produced from tapeout-specific mask sets. Linking wafer_map to tapeout enables tapeout-level defect density trending, mask defect attribution, and']
  wafer_id varchar [note: 'Identifier of the wafer associated with this map.']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: REQUIRED: Test execution (wafer_probe_run) creates the wafer map; traceability report links map to its probe run for root‑cause analysis.']
  bin_count_total varchar [note: 'Total number of distinct bins used in the map.']
  compliance_iatf16949 boolean [note: 'Flag indicating compliance with IATF 16949 for this wafer map.']
  compliance_iso9001 boolean [note: 'Flag indicating compliance with ISO 9001 for this wafer map.']
  created_timestamp timestamp [note: 'Record creation timestamp in the data lake.']
  defect_density_per_sqmm decimal(10,4) [note: 'Average defect density across the wafer measured in defects per square millimeter.']
  defect_type varchar [note: 'Primary defect type identified on the wafer.']
  defect_zone varchar [note: 'Region of the wafer where defects are concentrated.']
  die_grid_columns varchar [note: 'Number of die columns in the wafer grid.']
  die_grid_rows varchar [note: 'Number of die rows in the wafer grid.']
  die_yield_percentage decimal(5,2) [note: 'Yield percentage calculated from passing dies over total dies.']
  edge_exclusion_zone_mm decimal(6,2) [note: 'Width of the edge exclusion zone in millimeters where dies are not counted.']
  fail_bin_code varchar [note: 'Bin code representing failing (defective) dies.']
  failing_die_count varchar [note: 'Number of dies classified as failing.']
  flat_orientation varchar [note: 'Orientation of the wafer flat/notch relative to the map coordinate system.']
  is_kgd_certified boolean [note: 'Indicates whether the wafer passed Known Good Die certification.']
  kgd_certification_timestamp timestamp [note: 'Timestamp when KGD certification was applied.']
  map_checksum varchar [note: 'Checksum (e.g., SHA-256) of the map file for integrity verification.']
  map_file_path varchar [note: 'File system path or URI where the wafer map image/file is stored.']
  map_generation_timestamp decimal(12,4) [note: 'Date and time when the wafer map was generated.']
  map_status varchar [note: 'Current processing status of the wafer map.']
  map_version varchar [note: 'Version identifier of the map generation algorithm or software.']
  pass_bin_code varchar [note: 'Bin code representing passing (good) dies.']
  passing_die_count varchar [note: 'Number of dies classified as passing.']
  remarks varchar [note: 'Free-text comments or notes about the wafer map.']
  total_die_count varchar [note: 'Total number of dies evaluated on the wafer.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Spatial defect and bin distribution map for an individual wafer within an inspection lot. Captures wafer ID, lot ID, die grid coordinates, per-die pass/fail bin assignment, defect density per zone, edge exclusion zone, flat/notch orientation, and map generation timestamp. Sourced from KLA ICOS and ATE wafer probing systems. Enables yield spatial analysis and systematic defect pattern detection.'
}

Table quality.yield_record {
  yield_record_id varchar [pk, note: 'System-generated unique identifier for the yield record.']
  fab_tool_id varchar [note: 'Identifier of the equipment that performed the measurement.']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: REQUIRED: Yield records reference the final test run that produced pass/fail counts; needed for yield vs. test performance dashboards.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Design-for-yield feedback loop: yield engineers correlate yield loss (fallout_rate, yield_gap_percent, yield_loss_category) to specific IC design projects to trigger design ECOs. Standard semiconducto']
  inspection_lot_id varchar [note: 'FK to quality.inspection_lot.inspection_lot_id — Yield measurements are taken at quality gates associated with inspection lots. This link enables yield-to-defect correlation analysis.']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Yield Reporting aggregates yield percentages per inventory lot for financial reporting and customer yield guarantees.']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: A yield record measures yield against a defined quality gate specification. quality_spec defines the yield targets, acceptance criteria, and measurement parameters for each process step or SKU. Adding']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Yield records are produced per SKU for production performance dashboards; FK to sku replaces denormalized product_sku column.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Supports Yield Analysis Dashboard linking yield data to the corresponding tapeout, essential for performance tracking and cost forecasting.']
  tool_qualification_id varchar [note: 'Foreign key linking to equipment.tool_qualification. Business justification: Yield records from qualification wafer runs are the primary evidence for tool qualification acceptance. Process engineers reference the tool qualification to contextualize yield data, distinguish qual']
  wafer_id varchar [note: 'Unique identifier for the individual wafer.']
  wafer_map_id varchar [note: 'Foreign key linking to quality.wafer_map. Business justification: A yield record captures yield measurement outcomes at quality gates. The spatial bin distribution captured in a wafer map is the source data for yield calculations. Linking yield_record.wafer_map_id →']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: Yield records capture yield at wafer probe stage. yield_record already has final_test_run_id; adding wafer_probe_run_id completes yield traceability across both test stages. Yield engineers need to co']
  batch_number varchar [note: 'Identifier of the data acquisition batch.']
  bin_distribution_summary varchar [note: 'Compact representation (e.g., JSON) of die bin counts across test bins.']
  bin_yield_pct decimal(10,4) [note: 'Bin yield as a percentage']
  calibration_status decimal(12,4) [note: 'Indicates whether the measurement equipment was calibrated.']
  comments varchar [note: 'Free-text notes or observations related to the measurement.']
  created_timestamp timestamp [note: 'Timestamp when the yield record was first created in the system.']
  defect_count varchar [note: 'Number of defects detected for the specified defect type.']
  defect_density_per_cm2 decimal(8,4) [note: 'Number of defects per square centimeter of wafer area.']
  defect_type varchar [note: 'Classification of the dominant defect observed.']
  event_timestamp timestamp [note: 'Date and time when the yield measurement was captured.']
  fab_line varchar [note: 'Production line identifier within the fab.']
  fallout_rate decimal(18,2) [note: 'Fallout rate as a decimal ratio']
  good_die_count varchar [note: 'Number of dies that passed all quality tests.']
  inspection_result varchar [note: 'Overall pass/fail outcome of the inspection.']
  inspection_system varchar [note: 'Name of the inspection/metrology system used (e.g., KLA ICOS).']
  lot_humidity_percent decimal(4,2) [note: 'Relative humidity of the fab environment during measurement.']
  lot_origin varchar [note: 'Fab location code where the wafer lot originated.']
  lot_status varchar [note: 'Current processing status of the wafer lot.']
  lot_temperature_c decimal(5,2) [note: 'Average temperature of the wafer lot during measurement.']
  measurement_accuracy_percent decimal(5,2) [note: 'Stated accuracy of the measurement as a percentage.']
  measurement_method varchar [note: 'Physical method used to obtain the yield measurement.']
  measurement_stage varchar [note: 'Quality gate at which the yield was measured.']
  measurement_unit varchar [note: 'Unit of the primary measurement (e.g., percent, count).']
  measurement_variance_percent decimal(5,2) [note: 'Statistical variance observed across repeated measurements.']
  process_node varchar [note: 'Technology node (e.g., 7nm, 5nm) used for the wafer.']
  quality_gate varchar [note: 'Specific quality gate where the measurement was recorded.']
  shift varchar [note: 'Work shift during which the measurement was taken.']
  source_file_name varchar [note: 'Name of the source file or data feed that supplied the measurement.']
  test_time_seconds decimal(8,2) [note: 'Total time taken to perform the yield test.']
  tool_serial_number varchar [note: 'Serial number of the measurement tool.']
  total_die_count varchar [note: 'Total number of dies on the wafer lot.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the yield record.']
  yield_gap_percent decimal(5,2) [note: 'Difference between actual yield and target yield.']
  yield_loss_category decimal(12,4) [note: 'Root cause classification for yield loss.']
  yield_percent decimal(5,2)
  yield_percentage decimal(5,2) [note: 'Yield expressed as a percentage of good dies over total dies.']
  yield_rate decimal(18,2) [note: 'Yield rate as a decimal ratio']
  yield_record_status decimal(12,4) [note: 'Current validation status of the yield record.']
  yield_target_percent decimal(5,2) [note: 'Target yield percentage defined for the product/process.']
  yield_type varchar

  Note: 'Transactional record capturing yield measurement outcomes at each quality gate: wafer probe (die sort yield), final test yield, and packaged unit yield. Stores wafer lot ID, process node, product SKU, total die count, good die count, yield percentage, bin distribution summary, yield loss category (random defect, systematic, parametric, test escape), and measurement timestamp. SSOT for yield tracking across the fab-to-finish flow.'
}

Table quality.reliability_test {
  reliability_test_id varchar [pk, note: 'Unique identifier for the reliability test record.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Package-level reliability tests (HTOL, thermal cycling, HAST) are performed on assembled lots. Linking reliability_test to assembly_lot enables traceability of test results back to specific OSAT vendo']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Reliability tests (HTOL, ESD, latch-up) are performed on die sampled from die banks for JEDEC/AEC-Q qualification. This link provides traceability from reliability test results to the specific die ban']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: AEC-Q100/Q101 and JEDEC qualification require reliability testing of packaged finished goods. This link ties reliability test results directly to finished good inventory records, enabling qualificatio']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: JEDEC/AEC-Q100 qualification tracking: reliability qualification tests (HTOL, TDDB, EM) are executed against a specific IC design project. Qualification engineers must link test results to the design ']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Reliability tests on wafer-level samples require traceability to the inventory wafer lot for hold/release decisions. This link enables inventory disposition based on reliability test outcomes, support']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Reliability qualification programs for outsourced or purchased components require test results to be traceable to the supplying entity. Supplier qualification status and JEDEC reliability compliance r']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Reliability qualification is performed on silicon from a specific tapeout (mask revision, process node). JEDEC qualification reports must identify the exact tapeout under test; this link enables tapeo']
  analysis_method varchar [note: 'Technique used to analyze the failed device.']
  applicable_standard varchar [note: 'Industry standard governing the qualification (e.g., AEC‑Q100, JEDEC JESD47).']
  approval_authority varchar [note: 'Name or role of the person/committee approving the qualification.']
  compliance_iatf_16949 boolean [note: 'True if the test complies with automotive quality standard IATF 16949.']
  compliance_iso_9001 boolean [note: 'True if the test complies with ISO 9001 quality management requirements.']
  compliance_jedec boolean [note: 'True if the test follows applicable JEDEC reliability standards.']
  data_source_system varchar [note: 'Source system that supplied the reliability test data (e.g., KLA ICOS).']
  device_type varchar [note: 'Identifier for the device family or SKU under test.']
  failure_count varchar
  failure_mechanism varchar [note: 'Physical mechanism responsible for the failure.']
  failure_mode varchar [note: 'Observed mode of failure for the device.']
  failure_serial_number varchar [note: 'Serial number of the device that failed during testing.']
  failure_time_hours decimal(6,2) [note: 'Time elapsed until failure, measured in hours.']
  fit_rate decimal(10,4) [note: 'Calculated failure rate expressed in FIT (10⁹ hours).']
  fit_rate_confidence decimal(5,2) [note: 'Statistical confidence level for the reported FIT rate.']
  is_kgd_certified boolean [note: 'Indicates whether the device is Known Good Die (KGD) certified.']
  milestone_schedule varchar [note: 'Key milestones and dates for the qualification program.']
  operator_name varchar [note: 'Name of the technician who ran the test.']
  overall_status varchar [note: 'Current lifecycle status of the qualification program.']
  pass_fail_criteria varchar [note: 'Business rule defining pass or fail for the test (e.g., max failure rate).']
  program_code varchar [note: 'Business identifier for the reliability qualification program.']
  qualification_plan_version varchar [note: 'Version identifier of the qualification plan document.']
  qualification_type varchar [note: 'Type of qualification driving the reliability test.']
  record_created_timestamp timestamp [note: 'Timestamp when the reliability test record was created in the system.']
  record_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the reliability test record.']
  reliability_grade varchar [note: 'Qualitative reliability grade assigned to the device.']
  reltest_to_qualification varchar [note: 'FK to quality.qualification_program.qualification_program_id — Reliability tests are executed as part of qualification programs. This link is essential for tracking qualification completeness.']
  root_cause_classification varchar [note: 'High‑level classification of the root cause.']
  sample_size varchar [note: 'Number of devices subjected to the test.']
  test_date date
  test_duration_hours decimal(6,2) [note: 'Total duration of the stress test, in hours.']
  test_execution_timestamp timestamp [note: 'Date and time when the test was executed.']
  test_humidity_percent decimal(5,2) [note: 'Relative humidity level during the test, expressed as a percentage.']
  test_location varchar [note: 'Facility or fab where the test was performed.']
  test_result varchar [note: 'Overall pass/fail outcome of the test.']
  test_standard varchar
  test_status varchar [note: 'Current execution status of the test.']
  test_temperature_c decimal(5,2) [note: 'Temperature set point for the stress test, in degrees Celsius.']
  test_type varchar [note: 'Stress test methodology applied.']
  test_voltage_v decimal(5,2) [note: 'Voltage applied during the stress test, in volts.']
  weibull_scale_parameter decimal(10,3) [note: 'Scale parameter of the Weibull reliability model.']
  weibull_shape_parameter decimal(6,3) [note: 'Shape parameter of the Weibull reliability model.']

  Note: 'Master record for reliability qualification programs and individual test execution, encompassing program definition, test planning, stress test execution, and failure event tracking. At the program level: captures qualification type (new product, process change, OSAT qualification, PCN-driven), applicable standards (AEC-Q100, JEDEC JESD47, ISO 9001), qualification plan version, milestone schedule, overall qualification status, and approval authority. At the test level: captures test type (HTOL, HAST, TC, ESD, JEDEC stress tests), test conditions (temperature, voltage, humidity, duration), sample size, device type, pass/fail criteria, and individual failure details including failed unit serial number, failure time (hours), failure mode, failure analysis method (SEM, FIB, EMMI, curve trace), root cause classification, and failure mechanism (electromigration, TDDB, HCI, NBTI). SSOT for JEDEC JESD47 and AEC-Q100/Q101 qualification lifecycle from program initiation through test execution to final disposition, FIT rate calculations, and Weibull reliability modeling.'
}

Table quality.kgd_certification {
  kgd_certification_id varchar [pk, note: 'System-generated unique identifier for the KGD certification record.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Supports the Customer‑Specific KGD Certification Management workflow, replacing free‑text customer_name with a reference to the customer account for accurate certification tracking.']
  die_bank_id varchar [note: 'Identifier of the die lot that was certified.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: KGD qualification traceability to design: KGD certification is performed on dies from a specific IC design project. Design engineers need to track KGD qualification status per project for customer com']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: KGD certifications for purchased dies must be traceable to the supplying foundry or die vendor. Supplier qualification programs and customer-facing KGD certification documents require direct supplier ']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: KGD certification tied to tapeout revision: KGD qualification is silicon-revision-specific; a new tapeout requires re-qualification. Linking quality_kgd_certification to tapeout enables tapeout-level ']
  wafer_map_id varchar
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: KGD certification is issued based on wafer probe test results demonstrating die quality. The certification must reference the specific probe run that provided the test evidence. This is a fundamental ']
  approval_timestamp timestamp [note: 'Timestamp when the certification was formally approved.']
  burn_in_status varchar [note: 'Indicates whether burn‑in testing was performed and its outcome.']
  certification_batch varchar [note: 'Batch identifier grouping multiple certifications performed together.']
  certification_date date [note: 'Date the certification was issued.']
  certification_location varchar [note: 'Physical location where the certification was performed.']
  certification_number varchar [note: 'Human‑readable identifier assigned to the certification.']
  certification_reference varchar [note: 'External reference code used by customers or partners to track the certification.']
  certification_standard varchar [note: 'Standard or specification against which the die lot was certified.']
  certification_status varchar
  compliance_iatf16949 boolean [note: 'True if the certification complies with automotive quality standards.']
  compliance_iso9001 boolean [note: 'True if the certification complies with ISO 9001 quality standards.']
  compliance_jedec boolean [note: 'True if the certification meets JEDEC requirements.']
  created_timestamp timestamp [note: 'Timestamp when the certification record was created.']
  customer_requirements varchar [note: 'Any customer‑specific KGD criteria or notes.']
  expiration_reason decimal(12,4) [note: 'Reason why the certification expired or was terminated.']
  expiry_date date [note: 'Date the certification becomes invalid.']
  kgd_version varchar [note: 'Version of the KGD certification schema applied.']
  notes varchar [note: 'Free‑form comments or observations about the certification.']
  parametric_screen_result varchar [note: 'Result of the parametric screening step.']
  part_number varchar [note: 'Manufacturer part number of the product associated with the die lot.']
  quality_kgd_certification_status varchar [note: 'Current lifecycle state of the certification.']
  reliability_grade varchar [note: 'Overall reliability classification assigned to the die lot.']
  revision_number varchar [note: 'Revision count of the certification record.']
  test_coverage_percent decimal(5,2) [note: 'Percentage of required tests that were successfully completed.']
  test_duration_hours decimal(5,2) [note: 'Length of time the test was run.']
  test_temperature_c decimal(5,2) [note: 'Temperature at which the test was conducted.']
  test_type varchar [note: 'Category of test performed for the certification.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the certification record.']

  Note: 'Known Good Die certification record attesting that a specific die lot has passed all required electrical, parametric, and reliability screens for bare-die shipment to customers. Captures die lot ID, product part number, certification standard (JEDEC JESD49), test coverage percentage, burn-in status, parametric screen results, certification date, expiry date, certifying engineer, and customer-specific KGD requirements. Critical for advanced packaging and MCM customers.'
}

Table quality.dppm_record {
  dppm_record_id varchar [pk, note: 'System-generated unique identifier for the DPPM record.']
  account_id varchar [note: 'Unique identifier of the customer who received the shipment and reported the defect.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Field DPPM records must trace back to the originating assembly lot to identify the OSAT vendor, package type, and process conditions responsible for field failures. This traceability is required for 8']
  capa_record_id varchar [note: 'FK to quality.capa_record.capa_record_id — Customer quality issues (DPPM events, 8D reports) trigger CAPA records. This link is required for customer complaint resolution tracking per IATF 16949.']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: DPPM performance in semiconductors is tracked at the design win/program level for customer quality scorecards and SLA compliance. dppm_record has account_id and ic_catalog_id but no program-level link']
  dppm_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: DPPM reporting in semiconductors requires formal notification to a specific customer quality contact. The 8D report and corrective action responses are sent to a named contact. dppm_record already has']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: DPPM metrics are computed from final test results and customer returns. Linking dppm_record to final_test_run enables direct traceability from customer-facing quality KPIs to the test execution data, ']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: DPPM records track customer-reported defects on shipped finished goods. This link ties DPPM metrics directly to finished_good inventory records, enabling customer quality scorecards, field return anal']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: DPPM records track defective units per part number; linking to ic_catalog enables part‑level defect analytics.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Customer quality scorecard reporting: DPPM records are tracked per design project for customer-facing quality KPIs and corrective action programs. Design-level DPPM trending is a standard automotive/i']
  rma_id varchar [note: 'Foreign key linking to order.rma. Business justification: DPPM calculation in semiconductor quality is directly driven by customer returns. Linking dppm_record to the originating RMA enables accurate DPPM computation, customer quality scorecards, and supplie']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: DPPM is a primary supplier quality KPI in semiconductor manufacturing. Every DPPM record must be directly traceable to the responsible supplier for supplier scorecards, IATF 16949 supplier monitoring,']
  audit_created_timestamp timestamp [note: 'Timestamp when the DPPM record was first created in the system.']
  audit_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the DPPM record.']
  closure_status varchar [note: 'Current closure state of the quality notification.']
  compliance_iso9001 boolean [note: 'Compliance status of the record with ISO 9001 quality management requirements.']
  containment_action varchar [note: 'Immediate actions taken to contain the defect and prevent further impact.']
  corrective_action varchar [note: 'Corrective steps implemented to eliminate the root cause.']
  defect_count varchar
  defect_rate decimal(18,2) [note: 'Defect rate as a decimal ratio']
  defective_units varchar [note: 'Number of units returned by the customer that were identified as defective.']
  dppm_value decimal(10,4) [note: 'Calculated DPPM value for the shipment period (defective_units / total_units_shipped * 1,000,000).']
  eight_d_report_reference varchar [note: 'Identifier of the associated 8‑D problem‑solving report.']
  event_timestamp timestamp [note: 'Timestamp of the primary quality event (e.g., notification creation).']
  failure_description varchar [note: 'Narrative description of the observed failure mode or defect.']
  is_kgd_certified boolean [note: 'Indicates whether the returned die was a Known Good Die (KGD) certified part.']
  kgd_certification_date date [note: 'Date on which the KGD certification was granted.']
  lifecycle_status varchar [note: 'Overall lifecycle state of the DPPM record.']
  notes varchar [note: 'Free‑form field for any supplemental information or comments.']
  notification_type varchar [note: 'Classification of the quality notification associated with the record.']
  period_end_date date
  period_start_date date
  preventive_action varchar [note: 'Preventive measures introduced to avoid recurrence of similar defects.']
  record_number varchar [note: 'Business identifier assigned to the DPPM record, used for external reference and tracking.']
  reject_rate decimal(18,2) [note: 'Reject rate as a decimal ratio']
  response_due_date date [note: 'Date by which the customer or supplier must respond to the notification.']
  root_cause varchar [note: 'Root cause analysis result identifying the underlying reason for the defect.']
  shipment_end_date date [note: 'Last calendar date of the shipment period covered by this DPPM record.']
  shipment_start_date date [note: 'First calendar date of the shipment period covered by this DPPM record.']
  total_units_shipped varchar [note: 'Total number of units shipped to the customer during the shipment period.']
  units_shipped varchar

  Note: 'Customer quality performance and communication record encompassing DPPM tracking, formal quality notifications (8D, SCAR, customer complaints), field return management, and customer-facing quality communications. Captures product part number, customer account, shipment period, total units shipped, defective units returned, DPPM value, notification type, failure description, containment actions, root cause, corrective/preventive actions, 8D report reference, response due date, and closure status. SSOT for all customer-facing quality metrics, notifications, and communications per IATF 16949 customer satisfaction monitoring. Integrates with Salesforce CRM for customer communication tracking.'
}

Table quality.capa_record {
  capa_record_id varchar [pk, note: 'System-generated unique identifier for the CAPA record.']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: CAPAs are frequently initiated from final test failures. The CAPA record must reference the test run that triggered the corrective action to enable effectiveness verification — re-running the same tes']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: CAPAs triggered by finished good quality escapes (customer returns, ATE failures) must reference the affected finished good inventory. This link supports inventory quarantine and rework decisions driv']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Design-triggered CAPA closure: CAPAs caused by systematic design issues (e.g., design rule violations causing yield loss) must reference the design project to assign corrective actions to design engin']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: CAPAs triggered by wafer lot nonconformances must reference the affected inventory wafer lot to manage inventory holds and disposition. This link supports the CAPA-driven inventory hold/release workfl']
  nonconformance_report_id varchar [note: 'FK to quality.nonconformance_report.nonconformance_report_id — CAPAs are triggered by nonconformances. This is a critical traceability link for ISO 9001 clause 10.2 compliance.']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: CAPAs triggered by incoming raw material nonconformances (e.g., silicon wafer defects, chemical purity failures) must reference the specific raw material. This link supports supplier corrective action']
  required_maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: CAPA corrective actions in semiconductor fabs frequently require specific maintenance events (tool repair, chamber replacement, recalibration). Quality engineers link the CAPA to the maintenance event']
  sku_id varchar [note: 'Identifier of the product or design associated with the CAPA.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: CAPAs in semiconductors are frequently issued as Supplier Corrective Action Requests (SCARs). The CAPA must reference the responsible supplier for IATF 16949 compliance, supplier performance tracking,']
  actual_completion_date date [note: 'Date when the action was actually completed.']
  attachment_reference varchar [note: 'Reference (e.g., URL or file ID) to supporting documents or images.']
  capa_number varchar [note: 'Business identifier or code assigned to the CAPA for tracking and reference.']
  capa_record_status varchar [note: 'Current lifecycle status of the CAPA record.']
  capa_status varchar
  capa_type varchar [note: 'Indicates whether the action is corrective or preventive.']
  closure_approval_status varchar [note: 'Approval status of the CAPA closure after verification.']
  closure_date date [note: 'Date when the CAPA was formally closed.']
  compliance_reference varchar [note: 'Reference to the specific compliance clause or standard (e.g., ISO 9001, IATF 16949) governing the CAPA.']
  corrective_action varchar
  corrective_action_description varchar [note: 'Specific actions planned or taken to eliminate the identified root cause.']
  cost_actual decimal(18,2) [note: 'Actual financial cost incurred after implementation.']
  cost_estimate decimal(18,2) [note: 'Estimated financial cost to implement the corrective or preventive action.']
  created_timestamp timestamp [note: 'Timestamp when the CAPA record was initially created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for cost fields.']
  department varchar [note: 'Business department owning the CAPA (e.g., Quality, Engineering).']
  detection_date date [note: 'Date when the problem was first detected.']
  detection_phase varchar [note: 'Phase of the product lifecycle where the issue was detected.']
  detection_source varchar [note: 'Source of detection (e.g., inspection, customer, audit).']
  due_date date
  effectiveness_verification_criteria varchar [note: 'Criteria and metrics used to verify that the CAPA was effective.']
  impact varchar [note: 'Description of the business or technical impact of the non‑conformance.']
  notes varchar [note: 'Free‑form notes or comments related to the CAPA.']
  preventive_action varchar
  preventive_action_description varchar [note: 'Actions designed to prevent recurrence of similar issues in the future.']
  priority varchar [note: 'Priority ranking to schedule the CAPA work.']
  problem_description varchar
  problem_statement varchar [note: 'Clear description of the problem or non‑conformance that triggered the CAPA.']
  record_audit_created timestamp [note: 'Audit timestamp for when the record was first captured in the system.']
  record_audit_updated timestamp [note: 'Audit timestamp for the most recent modification of the record.']
  risk_level varchar [note: 'Risk assessment of the issue before mitigation.']
  root_cause_description varchar [note: 'Detailed narrative of the identified root cause.']
  root_cause_method varchar [note: 'Methodology used to determine the root cause (e.g., 5‑Why, Ishikawa, FTA, Pareto).']
  severity varchar [note: 'Severity level of the issue addressed by the CAPA.']
  target_completion_date date [note: 'Planned date by which the corrective or preventive action should be completed.']
  verification_date date [note: 'Date when the effectiveness of the CAPA was verified.']
  verification_result varchar [note: 'Outcome of the effectiveness verification.']
  created_by varchar [note: 'User identifier of the person who created the CAPA record.']

  Note: 'Corrective and Preventive Action record managing the full lifecycle of a quality improvement action triggered by a defect, customer complaint, audit finding, or reliability failure. Captures problem statement, root cause analysis method (5-Why, Ishikawa, FTA), root cause description, corrective action plan, preventive action plan, implementation owner, target and actual completion dates, effectiveness verification criteria, and closure approval. Supports ISO 9001 clause 10.2 and IATF 16949 CAPA requirements.'
}

Table quality.nonconformance_report {
  nonconformance_report_id varchar [pk, note: 'System-generated unique identifier for the non‑conformance report.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Feeds the Customer Impact Reporting procedure, associating each NCR with the affected customer account to trigger notifications and compliance reporting.']
  customer_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: NCRs with customer impact (is_customer_impact=true) require notification to a specific customer contact. Fields customer_notification_required and customer_notification_sent_timestamp exist but no FK ']
  defect_record_id varchar [note: 'Foreign key linking to quality.defect_record. Business justification: A Non-Conformance Report is typically raised in response to a specific defect event captured in a defect record. Adding defect_record_id to nonconformance_report links the NCR to the originating defec']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: IATF 16949 NCR traceability: nonconformances originating from design-related issues (DRC violations, design-rule non-compliance at incoming inspection) must reference the design project for root cause']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: NCR‑PO linkage needed for root‑cause analysis and supplier accountability in Nonconformance Reporting.']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: An NCR documents a deviation from a quality specification. nonconformance_report.specification_violated is a free-text string that should be normalized to a FK reference to quality_spec. Adding qualit']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: NCRs are raised against incoming raw materials (silicon wafers, photoresist, process gases) failing incoming inspection. This link supports incoming quality control disposition, supplier notification,']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: NCRs for incoming material nonconformances must directly reference the supplier for SCAR issuance, supplier notification workflows, and IATF 16949 supplier quality management. Direct FK enables suppli']
  wafer_id varchar [note: 'Unique identifier of the wafer where the issue was detected.']
  attached_document_ids varchar [note: 'Comma‑separated list of document identifiers attached to the report.']
  audit_trail_notes varchar [note: 'Free‑form notes capturing audit trail details.']
  compliance_standard varchar [note: 'Regulatory or industry standard applicable to the report.']
  corrective_action_due_date date [note: 'Target date for completion of corrective actions.']
  corrective_action_plan varchar [note: 'Planned corrective actions to prevent recurrence.']
  corrective_action_status varchar [note: 'Current status of the corrective action implementation.']
  created_timestamp timestamp [note: 'Timestamp when the record was first created in the system.']
  customer_notification_required boolean [note: 'Flag indicating if the customer must be notified.']
  customer_notification_sent_timestamp timestamp [note: 'Date‑time when the customer notification was sent.']
  detection_point varchar [note: 'Process step or system where the non‑conformance was first detected.']
  die_range varchar [note: 'Range of die numbers on the wafer affected (e.g., "100-200").']
  disposition varchar
  disposition_action_required varchar [note: 'Specific actions required to implement the chosen disposition.']
  disposition_decision varchar [note: 'Final decision on how the non‑conforming material will be treated.']
  hold_initiated_timestamp timestamp [note: 'Date‑time when the quality hold was placed.']
  hold_reason varchar [note: 'Reason why the lot was placed on hold.']
  hold_release_condition varchar [note: 'Condition(s) that must be satisfied to release the hold.']
  hold_released_timestamp timestamp [note: 'Date‑time when the quality hold was lifted (null if still active).']
  hold_type varchar [note: 'Category of quality hold applied to the lot.']
  impact_amount decimal(18,2) [note: 'Estimated monetary impact of the non‑conformance.']
  impact_currency_code varchar [note: 'Three‑letter ISO currency code for the financial impact.']
  is_customer_impact boolean [note: 'Indicates whether the non‑conformance impacts a customer.']
  mrb_decision varchar [note: 'Decision made by the MRB regarding the non‑conformance.']
  ncr_number varchar
  ncr_status varchar
  nonconformance_description varchar [note: 'Narrative description of the deviation from specification.']
  nonconformance_report_status varchar [note: 'Current lifecycle status of the report.']
  priority varchar [note: 'Priority assigned for handling the report.']
  report_number varchar [note: 'Business‑visible identifier (NCR number) assigned to the report.']
  report_timestamp timestamp [note: 'Date‑time when the non‑conformance was initially recorded.']
  root_cause_analysis varchar [note: 'Analysis identifying the underlying cause of the non‑conformance.']
  severity_level varchar [note: 'Severity classification of the non‑conformance.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the record.']

  Note: 'Non-Conformance Report (NCR) and quality hold management record documenting product or process deviations from specification, managing lot hold/release lifecycle, and tracking material review board dispositions. Captures NCR number, affected lot/wafer/unit range, non-conformance description, specification violated, detection point, hold type (process excursion, SPC out-of-control, customer complaint, reliability failure), hold initiation and release timestamps, hold reason, hold release conditions with approver, disposition decision (use-as-is, rework, scrap, return to supplier), material review board (MRB) decision, responsible quality engineer, required disposition actions, and financial impact assessment. SSOT for all in-process quality escapes, quality holds, MRB dispositions, and lot release management. Integrates with Camstar MES and SAP QM for lot status management.'
}

Table quality.quality_spec {
  quality_spec_id varchar [pk, note: 'Unique identifier for the quality specification record.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Design-specific quality specification governance: quality specs define acceptance criteria, measurement parameters, and tolerance limits for a specific IC design project. Design review processes requi']
  limit_id varchar [note: 'Foreign key linking to test.limit. Business justification: Quality specs define engineering acceptance criteria that test limits must implement. Quality engineers must verify that test limits conform to quality specs during product qualification and spec chan']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Quality specs define acceptance criteria for specific materials in incoming inspection. Linking quality_spec to material_master enables material-level quality specification management, supporting inco']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Required for Package Design Specification process where each quality spec must be linked to its package type to enforce dimensional and electrical limits.']
  pdk_id varchar [note: 'Foreign key linking to design.pdk. Business justification: PDK-level quality governance: quality specs for DRC/LVS acceptance criteria, process corner tolerances, and reliability limits are PDK-specific. Foundry qualification requires linking quality specs to']
  process_step_id varchar [note: 'Foreign key linking to fabrication.process_step. Business justification: Specification documents are applied to a particular process step; linking supports step‑specific spec compliance checks.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Quality specifications are defined per SKU; FK replaces the denormalized product_sku field for precise version control.']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.technology_node. Business justification: Specs often depend on the technology node; linking allows node‑specific parameter validation.']
  acceptance_criteria varchar [note: 'Free‑text description of the acceptance criteria.']
  applicability_scope varchar [note: 'Level of the product hierarchy the spec applies to.']
  approval_date date [note: 'Date when the specification was approved.']
  approval_status varchar [note: 'Current approval state of the specification.']
  approved_by varchar [note: 'Name of the person who approved the specification.']
  audit_trail varchar [note: 'Chronological log of changes made to the specification.']
  change_reason varchar [note: 'Reason for the most recent change to the specification.']
  created_timestamp timestamp [note: 'Timestamp when the specification record was created.']
  document_url varchar [note: 'Link to the detailed specification document.']
  effective_from date [note: 'Date when the specification becomes effective.']
  effective_until date [note: 'Date when the specification expires (null if open‑ended).']
  iatf_16949_compliant boolean [note: 'Indicates compliance with automotive quality standard IATF 16949.']
  inspection_method varchar [note: 'Technique used to inspect or measure the parameter.']
  iso_9001_compliant boolean [note: 'Indicates whether the specification complies with ISO 9001 quality standards.']
  jedec_reliability_compliant boolean [note: 'Indicates compliance with JEDEC reliability specifications.']
  last_validated_date date [note: 'Date of the most recent validation activity.']
  lower_limit decimal(12,4) [note: 'Minimum acceptable value for the parameter.']
  measurement_accuracy_percent decimal(5,2) [note: 'Stated accuracy of the measurement equipment as a percentage.']
  measurement_variance_percent decimal(5,2) [note: 'Observed variance of repeated measurements expressed as a percentage.']
  nominal_value decimal(12,4) [note: 'Target nominal value for the parameter.']
  notes varchar [note: 'Free‑form notes or comments about the specification.']
  parameter_name varchar [note: 'Name of the measured parameter (e.g., Vth, line width).']
  product_family varchar [note: 'Family or series to which the product belongs.']
  quality_spec_status varchar [note: 'Current lifecycle state of the specification.']
  review_cycle varchar [note: 'Frequency at which the specification is reviewed.']
  revision_number varchar [note: 'Sequential revision number of the specification.']
  spec_code varchar [note: 'Unique business code assigned to the specification.']
  spec_name varchar [note: 'Human‑readable name of the quality specification.']
  spec_status varchar
  spec_type varchar [note: 'Category of the specification such as electrical, dimensional, visual, or reliability.']
  test_type varchar [note: 'Category of test associated with the specification.']
  unit_of_measure varchar [note: 'Measurement unit for the parameter (e.g., mV, nm).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the specification record.']
  upper_limit decimal(12,4) [note: 'Maximum acceptable value for the parameter.']
  validated_flag boolean [note: 'Indicates whether the specification has been validated against actual parts.']
  version varchar [note: 'Version identifier for the specification.']

  Note: 'Master record defining the quality specification for a product SKU or process step, including all acceptance criteria, parametric limits, visual inspection standards, and test coverage requirements. Captures spec version, applicable product family, process node, specification type (electrical, dimensional, visual, reliability), parameter name, nominal value, upper and lower spec limits, measurement units, and approval status. SSOT for quality acceptance criteria referenced by inspection lots and test programs.'
}

Table quality.failure_analysis_report {
  failure_analysis_report_id varchar [pk, note: 'Unique identifier for the failure analysis report.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: Failure analysis reports on packaged devices must trace to the assembly lot to identify OSAT vendor, package type, material lot, and process conditions as root cause inputs. FA engineers require this ']
  capa_record_id varchar [note: 'FK to quality.capa_record.capa_record_id — Failure analysis conclusions drive corrective actions. This is a critical link in the closed-loop quality system.']
  defect_record_id varchar
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Failure analysis is performed on die sampled from die banks when KGD failures are detected. This link provides traceability from FA findings to the specific die bank lot, enabling die bank quarantine ']
  final_test_run_id varchar [note: 'Foreign key linking to test.final_test_run. Business justification: Failure analysis reports are initiated from final test failures. The FAR must reference the test run to access bin distribution, test conditions, and parametric data needed for root cause analysis. Th']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Failure analysis reports are routinely conducted on failed finished goods from customer returns or ATE escapes. This link ties FA findings to specific finished good inventory, enabling quarantine of a']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Failure analysis feedback to design: FA reports on silicon failures trigger design ECOs and design rule updates. Design engineers must be able to retrieve all FA reports against their project. Standar']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Failure analysis reports on wafer lot failures require direct traceability to the inventory wafer lot for disposition decisions. This link enables inventory hold/scrap decisions based on FA findings a']
  physical_layout_id varchar [note: 'Foreign key linking to design.physical_layout. Business justification: Layout-driven failure analysis: FA reports on metal shorts, via failures, or antenna violations reference the specific physical layout version (routing, metal fill) that caused the failure. Layout eng']
  primary_failure_nonconformance_report_id varchar [note: 'FK to quality.nonconformance_report.nonconformance_report_id — FA reports are triggered by non-conformances. FA description explicitly states \'Links to... nonconformance_report\'. This is a critical investigation-to-disposition link.']
  reliability_test_id varchar [note: 'FK to quality.reliability_test.reliability_test_id — Failure analysis reports investigate failures detected during reliability testing. FA report description states \'Links to reliability_failure\' which is now merged into reliability_test.']
  unit_test_result_id varchar [note: 'Foreign key linking to test.unit_test_result. Business justification: A FAR is initiated for a specific failing unit identified by its unit test result. This atomic link enables FA engineers to access the exact parametric measurements, bin assignment, and test condition']
  analysis_end_timestamp timestamp [note: 'Timestamp when the failure analysis investigation was completed.']
  analysis_method varchar
  analysis_start_timestamp timestamp [note: 'Timestamp when the failure analysis investigation began.']
  analysis_technique varchar [note: 'Primary analytical method(s) employed during the failure investigation.']
  approval_status varchar [note: 'Result of the final review of the report.']
  approval_timestamp timestamp [note: 'Date and time when the report was formally approved or rejected.']
  comments varchar [note: 'Free‑form notes or observations added by the analyst.']
  creation_timestamp timestamp [note: 'Date and time when the report record was first created.']
  defect_code varchar [note: 'Standard defect code identifying the defect class (e.g., D1234).']
  failure_analysis_report_status varchar [note: 'Current lifecycle status of the report.']
  failure_mechanism varchar [note: 'Descriptive classification of the underlying failure mechanism (e.g., electromigration, latch‑up, oxide breakdown).']
  failure_severity varchar [note: 'Severity rating assigned to the failure based on impact and recurrence risk.']
  failure_site_location varchar [note: 'Physical location on the die/wafer where the failure was observed (e.g., metal layer 3, die X12Y7).']
  far_number varchar
  last_updated_timestamp timestamp [note: 'Date and time of the most recent modification to the report record.']
  report_date date
  report_number varchar [note: 'Business identifier assigned to the report (e.g., FA‑2023‑0012).']
  report_title varchar [note: 'Human‑readable title of the failure analysis report.']
  report_type varchar [note: 'Category indicating the origin of the failure analysis request.']
  root_cause varchar [note: 'Narrative of the root cause conclusion derived from the analysis.']
  sample_description varchar [note: 'Brief description of the physical sample(s) examined (e.g., wafer lot, die coordinates, package type).']
  supporting_evidence_refs varchar [note: 'Comma‑separated list of file paths or identifiers for images, data files, and test logs that support the analysis.']

  Note: 'Formal failure analysis report documenting the investigation of a failed device, wafer, or component. Captures FA request source (reliability test, customer return, in-process failure), sample description, analysis techniques used (SEM, FIB cross-section, EMMI, TEM, EDX), failure site location, identified failure mechanism, root cause conclusion, supporting evidence references, analyst name, and report approval status. Links to reliability_failure, nonconformance_report, and capa_record.'
}

Table quality.control_plan {
  control_plan_id varchar [pk, note: 'Primary key for control_plan']
  superseded_control_plan_id varchar [note: 'Self-referencing FK on control_plan (superseded_control_plan_id)']
  approval_status varchar [note: 'Current approval state of the control plan.']
  author_name varchar [note: 'Name of the person or team that authored the control plan.']
  change_reason varchar [note: 'Reason or justification for the most recent change to the control plan.']
  compliance_standard varchar [note: 'Quality or industry standard(s) the control plan adheres to.']
  control_plan_status varchar [note: 'Current lifecycle state of the control plan.']
  created_timestamp timestamp [note: 'Date and time when the control plan record was first created.']
  description varchar [note: 'Detailed free‑text description of the control plan purpose and scope.']
  dppm_actual decimal(10,4) [note: 'Observed defect rate measured under the control plan.']
  dppm_target decimal(10,4) [note: 'Target defect rate expressed in parts per million.']
  effective_from date [note: 'Date when the control plan becomes effective.']
  effective_until date [note: 'Date when the control plan expires or is superseded (nullable for open‑ended plans).']
  inspection_tool varchar [note: 'Equipment or system used to perform the inspection (e.g., KLA ICOS).']
  is_critical boolean [note: 'Indicates whether the control plan is considered critical for product quality.']
  last_review_date date [note: 'Date when the control plan was last reviewed for relevance.']
  measurement_criteria varchar [note: 'Key measurement or characteristic monitored by the control plan.']
  notes varchar [note: 'Additional free‑form remarks or observations.']
  plan_code varchar [note: 'External code or number used to reference the control plan in manufacturing systems.']
  plan_name varchar [note: 'Human‑readable name of the control plan.']
  plan_status varchar
  plan_type varchar [note: 'Category describing the nature of the control plan.']
  process_step varchar [note: 'Manufacturing process step(s) covered by the control plan.']
  review_cycle varchar [note: 'Scheduled frequency for reviewing the control plan.']
  risk_level varchar [note: 'Risk classification associated with the control plan.']
  sampling_rate decimal(12,4) [note: 'Frequency or method of sampling for the control plan.']
  target_value decimal(10,4) [note: 'Target numeric value for the measured characteristic.']
  tolerance_lower decimal(10,4) [note: 'Maximum acceptable deviation below the target value.']
  tolerance_upper decimal(10,4) [note: 'Maximum acceptable deviation above the target value.']
  unit_of_measure varchar [note: 'Unit used for the target and tolerance values.']
  updated_by varchar [note: 'Identifier of the user or system that performed the last update.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the control plan record.']
  version_number varchar [note: 'Version identifier of the control plan (e.g., v1.0, v2.1).']
  created_by varchar [note: 'Identifier of the user or system that created the record.']

  Note: 'Master reference table for control_plan. Referenced by control_plan_id.'
}

Table test.program {
  program_id varchar [pk, note: 'System-generated unique identifier for each test program record.']
  ate_configuration_id varchar [note: 'Foreign key linking to test.ate_configuration. Business justification: Test programs are executed on specific ATE configurations; many programs can share one configuration, so add FK from test_program to ate_configuration.']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: Test program is defined for a specific finished‑good SKU to ensure test coverage aligns with product specifications.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Test programs are developed for specific IC design projects — DFT coverage reporting, NRE cost tracking, and tapeout readiness sign-off all require this link. \'target_device\' and \'target_device_family']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Test programs are node-specific: parametric limits, ATPG patterns, and coverage targets differ by process node geometry. Linking test_program to product.process_node enables node-level test program qu']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Test programs are qualified and released against specific tapeout revisions. Test program qualification per tapeout is a mandatory step in semiconductor production release — correlation studies and va']
  tool_qualification_id varchar [note: 'Foreign key linking to equipment.tool_qualification. Business justification: Test program to tool qualification traceability: tool qualification protocols specify which test program was used to qualify the tool. This link enables re-qualification triggers when a test program c']
  verification_plan_id varchar [note: 'Foreign key linking to design.verification_plan. Business justification: The verification plan\'s DFT strategy and coverage targets directly drive test program structure and ATPG tool selection. This design-to-test handoff traceability is required for ISO 26262 / AEC-Q100 c']
  actual_coverage_percent decimal(5,2) [note: 'Measured fault‑coverage achieved after program execution.']
  approval_date date [note: 'Date on which the program was approved.']
  ate_platform varchar [note: 'Automatic Test Equipment platform compatible with the program.']
  atpg_tool varchar [note: 'ATPG software used to generate the test vectors (e.g., Synopsys TestMAX, Mentor Tessent).']
  bin_mapping_reference varchar [note: 'Identifier of the bin‑mapping table associated with this program.']
  category varchar [note: 'High‑level classification of the test program purpose.']
  change_description varchar [note: 'Detailed narrative of modifications to test flows, limits, or parameters.']
  code varchar [note: 'Business‑assigned code that uniquely identifies the test program across systems.']
  correlation_study_reference varchar [note: 'Identifier of the wafer‑to‑package correlation study associated with the program.']
  coverage_target_percent decimal(5,2) [note: 'Desired fault‑coverage percentage the program aims to achieve.']
  created_timestamp timestamp [note: 'Timestamp when the program record was first created in the system.']
  deprecation_date date [note: 'Date on which the program version was marked as deprecated.']
  impact_assessment varchar [note: 'Narrative assessment of the program\'s impact on yield, cost, and schedule.']
  is_deprecated boolean [note: 'Flag indicating whether the program version is deprecated.']
  owner varchar [note: 'Name of the engineer or team responsible for the program.']
  parametric_test_data_reference varchar [note: 'Link to the parametric test data set used for limit verification.']
  release_date date [note: 'Calendar date when the program version was officially released for production use.']
  test_coverage_metric varchar [note: 'Metric used to express coverage (e.g., fault, code, timing).']
  test_environment varchar [note: 'Physical environment where the program is executed.']
  test_flow_description varchar [note: 'Detailed description of the test flow sequence executed by the program.']
  test_flow_version varchar [note: 'Version identifier of the underlying test flow definition.']
  test_limit_units varchar [note: 'Units for numeric test limits (e.g., mV, mA, ns).']
  test_limit_value decimal(10,4) [note: 'Numeric value of the primary test limit associated with the program.']
  test_program_name varchar [note: 'Human‑readable name of the test program.']
  test_program_status varchar [note: 'Overall lifecycle state of the test program.']
  test_type varchar [note: 'Category of testing performed by the program (e.g., wafer probe, die sort, final test, burn‑in, system level test).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the program record.']
  validation_status varchar [note: 'Current validation state of the program version.']
  version_description varchar [note: 'Free‑form description of changes introduced in this version.']
  version_number varchar [note: 'Semantic version identifier for the program (e.g., 1.0.3).']

  Note: 'Master record for ATPG-generated and manually authored test programs used on ATE platforms, with full version lifecycle management. Captures program name, target device family, test type (wafer probe, die sort, final test, burn-in, SLT), ATE platform compatibility, ATPG tool used, coverage targets, and program lifecycle status. Includes version-level tracking: version number, change description, changed test flows or limits, validation status, release date, approved-by engineer, associated PCN/ECO reference, and change impact assessment. SSOT for all test program definitions and their complete evolution history across test operations.'
}

Table test.ate_configuration {
  ate_configuration_id varchar [pk, note: 'Unique system-generated identifier for the ATE configuration record.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: ATE configurations are qualified for specific IC design projects — pin electronics mapping, load board revision, and parallel site count are determined by the design project\'s I/O specifications. \'sup']
  tool_qualification_id varchar [note: 'Foreign key linking to equipment.tool_qualification. Business justification: ATE configuration qualification: each ATE configuration must be formally qualified on the tool before production use. Linking ate_configuration to the tool_qualification record enables configuration c']
  bin_mapping_version varchar [note: 'Version identifier for the binning map used in this configuration.']
  calibration_due_date date [note: 'Date by which the configuration must be re‑calibrated.']
  calibration_status varchar [note: 'Current calibration state of the configuration.']
  change_reason varchar [note: 'Free‑text reason describing why the configuration was changed.']
  compliance_ear_status varchar [note: 'Indicates whether the configuration complies with Export Administration Regulations.']
  compliance_itar_status varchar [note: 'Indicates whether the configuration complies with International Traffic in Arms Regulations.']
  configuration_code varchar [note: 'Business identifier code used to reference the configuration in work orders and test plans.']
  created_timestamp timestamp [note: 'Timestamp when the configuration record was first created.']
  effective_end_date date [note: 'Date when the configuration is retired (null if open‑ended).']
  effective_start_date date [note: 'Date when the configuration becomes valid for use.']
  hardware_revision varchar [note: 'Revision identifier for the ATE hardware bundle (e.g., Rev A, Rev B).']
  instrument_resource_allocation varchar [note: 'List of instrument resources (e.g., power supplies, signal generators) allocated to this configuration.']
  last_calibration_timestamp timestamp [note: 'Timestamp of the most recent calibration activity.']
  lifecycle_status varchar [note: 'Current lifecycle state of the configuration.']
  load_board_qualification_status varchar [note: 'Current qualification status of the load board for production use.']
  load_board_revision varchar [note: 'Revision identifier of the load board / Device Interface Board used.']
  maintenance_window varchar [note: 'Scheduled maintenance window description (e.g., weekly Saturday 02:00‑04:00).']
  max_parallel_site_count varchar [note: 'Maximum number of test sites that can be exercised simultaneously.']
  name varchar [note: 'Human‑readable name identifying this ATE configuration.']
  notes varchar [note: 'Additional free‑form notes or comments about the configuration.']
  parametric_test_supported boolean [note: 'Indicates whether parametric testing is enabled for this configuration.']
  pin_electronics_card_map varchar [note: 'Mapping description of pin‑to‑electronics card assignments for the configuration.']
  platform_type varchar [note: 'Type of test platform the configuration supports (wafer probe, final test, or reliability).']
  test_coverage_percentage decimal(5,2) [note: 'Percentage of functional test coverage provided by this configuration.']
  test_yield_target_percentage decimal(5,2) [note: 'Target yield percentage that the configuration aims to achieve during test runs.']
  tester_model varchar [note: 'Model of the Automatic Test Equipment platform (e.g., Advantest V93000).']
  updated_by varchar [note: 'User identifier of the person who last modified the configuration record.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the configuration record.']
  version varchar [note: 'Semantic version identifier for the configuration (e.g., 1.2.0).']
  warranty_expiration_date date [note: 'Date when the hardware warranty for this configuration expires.']
  created_by varchar [note: 'User identifier of the person who created the configuration record.']

  Note: 'Master configuration record for Automatic Test Equipment (ATE) platform setups used across wafer probe and final test operations. Captures tester model and platform type (e.g., Advantest V93000, Teradyne UltraFlex), hardware configuration revision, pin electronics card map, load board/DIB (Device Interface Board) revision and qualification status, instrument resource allocation, calibration status and due date, supported device families, maximum parallel site count, and configuration effective dates. SSOT for ATE setup definitions that test runs reference for full equipment traceability. Links to equipment domain for physical asset and maintenance tracking.'
}

Table test.probe_card {
  probe_card_id varchar [pk, note: 'Unique identifier for the probe card.']
  fab_tool_id varchar [note: 'Identifier of the prober equipment to which the probe card is currently assigned.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Probe cards are designed and qualified for specific IC design projects — die pad layout, pitch, and needle count are determined by the design project\'s physical specifications. Probe card qualificatio']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Probe cards are procured materials with part numbers, lead times, and reorder points managed in material_master. Procurement and inventory planning for probe cards requires this link. A supply chain e']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Probe card specifications (pitch_um, needle_count) are directly determined by process node minimum feature size and wafer size. Linking probe_card to product.process_node enables node-qualified probe ']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Probe cards are sourced from specific suppliers (e.g., FormFactor, MPI). Supplier qualification, lead time negotiation, and defect escalation require this link. The existing plain-text \'supplier\' colu']
  card_name varchar [note: 'Human‑readable name of the probe card used for identification in test engineering.']
  compliance_status varchar [note: 'Regulatory compliance classification applicable to the probe card.']
  contact_resistance_ohm decimal(6,3) [note: 'Measured electrical resistance of needle contacts in ohms.']
  cost_usd decimal(12,2) [note: 'Acquisition cost of the probe card in US dollars.']
  created_timestamp timestamp [note: 'Timestamp when the probe card record was first created in the system.']
  description varchar [note: 'Free‑form text describing special features, notes, or remarks about the probe card.']
  die_site_layout varchar [note: 'Description of the die site arrangement on the wafer for this probe card.']
  last_maintenance_date date [note: 'Date when the probe card last underwent scheduled maintenance.']
  last_used_timestamp timestamp [note: 'Timestamp of the most recent test run that utilized the probe card.']
  maintenance_cycle_months varchar [note: 'Planned interval in months between preventive maintenance activities.']
  manufacturer varchar [note: 'Company that manufactured the probe card.']
  needle_count varchar [note: 'Total number of probing needles/pins on the card.']
  needle_replacements varchar [note: 'Cumulative number of needle replacement events performed on the card.']
  next_maintenance_due date [note: 'Planned date for the next preventive maintenance.']
  notes varchar [note: 'Any additional remarks or observations about the probe card.']
  pitch_um decimal(5,2) [note: 'Center‑to‑center spacing of needles in micrometers.']
  probe_card_status varchar [note: 'Current lifecycle state of the probe card within test operations.']
  probe_card_type varchar [note: 'Design classification of the probe card (e.g., cantilever, vertical, MEMS, advanced).']
  qualification_date date [note: 'Date when the probe card was qualified for production use.']
  qualification_status varchar [note: 'Current status of the probe card qualification process.']
  safety_classification varchar [note: 'Safety classification level for handling the probe card.']
  serial_number varchar [note: 'Manufacturer‑assigned serial number that uniquely identifies the physical probe card.']
  touchdown_count varchar [note: 'Number of successful needle contacts recorded per test cycle.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the probe card record.']
  usage_hours decimal(8,2) [note: 'Total operational hours the probe card has been used in testing.']
  warranty_expiration_date date [note: 'Date when the manufacturer\'s warranty for the probe card expires.']

  Note: 'Master record for probe cards used in wafer probing operations, owned by test engineering for qualification, assignment, and performance tracking. Captures probe card type (cantilever, vertical, MEMS, advanced), needle/pin count, pitch, technology node compatibility, die site layout, touchdown count, maintenance cycle, current condition status, and assigned prober tool. Tracks probe card lifecycle from incoming qualification through active use to retirement, including needle replacement history and contact resistance trending. Links to equipment domain for physical asset management while test domain owns operational qualification and assignment decisions.'
}

Table test.bin_definition {
  bin_definition_id varchar [pk, note: 'Unique surrogate key for each bin definition record.']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: Bin definitions are created at the product family level and reused across ICs within a family. device_family is a denormalized text field. A proper FK to product.family enables family-level bin standa']
  program_id varchar [note: 'Foreign key linking to test.test_program. Business justification: Bin definitions belong to a test program; many bins per program, so add FK from bin_definition to test_program.']
  bin_category varchar [note: 'Classification of the bin outcome according to JEDEC taxonomy.']
  bin_code varchar [note: 'Alphanumeric code used in test programs to reference the bin.']
  bin_definition_status varchar [note: 'Current lifecycle status of the bin definition.']
  bin_limit_pct decimal(10,4) [note: 'Bin limit as a percentage of total die']
  bin_name varchar [note: 'Human‑readable name describing the purpose of the bin.']
  bin_number varchar [note: 'Numeric identifier assigned to the test bin within a test program.']
  bin_sort_order varchar [note: 'Display order for bins in reports and UI.']
  created_timestamp timestamp [note: 'Timestamp when the bin definition record was first created.']
  description varchar [note: 'Detailed free‑text description of the bin purpose and usage.']
  disposition_rule varchar [note: 'Action to be taken for devices falling into this bin.']
  effective_from date [note: 'Date when the bin definition becomes active.']
  effective_until date [note: 'Date when the bin definition is retired (null if indefinite).']
  failure_mode varchar [note: 'Root cause or failure mechanism associated with the bin.']
  is_default boolean [note: 'Flag indicating whether this bin is the default for its category.']
  parameter_set varchar [note: 'Set of parametric test parameters associated with the bin.']
  test_level varchar [note: 'Stage of testing where the bin is applied.']
  updated_by varchar [note: 'User identifier who last modified the bin definition record.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the bin definition.']
  yield_impact_classification varchar [note: 'Indicates how the bin affects overall wafer or lot yield.']
  yield_target_pct decimal(10,4) [note: 'Target yield percentage for this bin category']
  created_by varchar [note: 'User identifier who created the bin definition record.']

  Note: 'Reference master defining all test bin codes used in wafer sort and final test. Captures bin number, bin name, bin category (pass, functional fail, parametric fail, contact fail, leakage fail), disposition rule (ship, scrap, rework, hold), yield impact classification, and associated failure mode. Provides standardized bin taxonomy across all test programs and device families per JEDEC and internal standards.'
}

Table test.wafer_probe_run {
  wafer_probe_run_id varchar [pk, note: 'Unique identifier for each wafer probing execution event.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Billing & Reporting: wafer probe runs are billed to the customer account that owns the wafer lot, required for financial and compliance reports.']
  ate_configuration_id varchar [note: 'FK to test.ate_configuration.ate_configuration_id — Each probe run executes on a specific ATE configuration. Required for traceability and equipment correlation analysis.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Wafer probe runs are performed on wafers from a given design project; yield analysis links probe data to the originating IC design project.']
  physical_layout_id varchar [note: 'Foreign key linking to design.physical_layout. Business justification: Wafer probe yield is correlated to physical layout version for DFM feedback — routing congestion, metal fill density, and DRC violations in physical_layout directly impact probe yield. This DFM-yield ']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Wafer probe runs are executed on wafers from a specific tapeout revision. Yield analysis by tapeout revision is a critical semiconductor yield engineering process — existing FK to ic_design_project do']
  ate_configuration varchar [note: 'Configuration identifier for the Automatic Test Equipment used in the run.']
  bin_map_version varchar [note: 'Version identifier of the binning map used to classify die test results.']
  completed_timestamp timestamp
  contact_yield_percent decimal(5,2) [note: 'Percentage of dies that made electrical contact during probing.']
  end_timestamp timestamp [note: 'Timestamp when the wafer probing run completed or was terminated.']
  fail_die_count varchar [note: 'Number of dies that failed one or more test criteria.']
  gross_die_count varchar [note: 'Total die count before any filtering (e.g., before known‑good die certification).']
  parametric_test_data_available boolean [note: 'Indicates whether parametric test measurements were captured for this run.']
  pass_die_count varchar [note: 'Number of dies that passed all test criteria.']
  probe_cost decimal(18,2) [note: 'Cost of the wafer probe run']
  record_audit_created timestamp [note: 'Timestamp when this run record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent modification to this run record.']
  remarks varchar [note: 'Free‑form notes or comments entered by the operator or quality engineer.']
  run_number varchar [note: 'Business identifier assigned to the probe run, typically following the pattern RUN-######.']
  run_status varchar
  start_timestamp timestamp [note: 'Timestamp when the wafer probing run started.']
  started_timestamp timestamp
  test_coverage_percent decimal(5,2) [note: 'Proportion of functional tests executed relative to the total test plan.']
  total_die_count varchar [note: 'Total number of dies present on the wafer.']
  wafer_probe_run_status varchar [note: 'Current lifecycle status of the probe run.']
  wafer_sequence_number varchar [note: 'Sequential number of the wafer within the lot.']
  yield_percent decimal(5,2)

  Note: 'Transactional record capturing each wafer probing execution event. Records wafer lot ID, wafer sequence number, probe card used, ATE configuration, test program version, prober tool, start and end timestamps, total die count, pass die count, fail die count, contact yield, gross die count, and operator ID. Core operational event for wafer-level electrical test and die sort operations.'
}

Table test.unit_test_result {
  unit_test_result_id varchar [pk, note: 'Primary key for unit_test_result']
  final_test_run_id varchar [note: 'FK to test.final_test_run.final_test_run_id — Package-level test results must link back to the final test run event. Required for lot disposition and DPPM tracking.']
  netlist_id varchar [note: 'Foreign key linking to design.netlist. Business justification: Die test results are correlated to the netlist version used for synthesis; debugging reports require the netlist_id reference.']
  primary_bin_definition_id varchar [note: 'FK to test.bin_definition.bin_definition_id — Every unit test result is assigned a bin code from the bin_definition master. This is the core yield classification link.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Required for Test Result Traceability to Procurement: links die test results to the purchase order that supplied the wafer lot, enabling warranty claims and quality audits.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Unit test results must be traceable to the tapeout that produced the silicon for tapeout yield analysis and silicon-to-design correlation. This supports tapeout quality reporting and failure analysis ']
  wafer_id varchar [note: 'Identifier of the wafer containing the unit.']
  wafer_probe_run_id varchar [note: 'FK to test.wafer_probe_run.wafer_probe_run_id — Die-level test results from wafer probing must link back to the probe run event. Required for wafer map generation and lot traceability.']
  assembly_position varchar [note: 'Position identifier for multi-die or chiplet assemblies.']
  created_timestamp timestamp [note: 'Timestamp when the test result record was created in the system.']
  device_serial_number varchar [note: 'Serial number of the packaged device, if applicable.']
  hard_bin_code varchar [note: 'Hard bin classification assigned to the unit based on test outcome.']
  kgd_status varchar [note: 'Qualification status of the unit as a Known Good Die.']
  measurement_summary varchar [note: 'Concise summary of parametric measurement values for the unit.']
  measurement_units varchar [note: 'Units of the parametric measurements reported. [ENUM-REF-CANDIDATE: C|V|Ohm|nA|pF|%|dB — 7 candidates stripped; promote to reference product]']
  parametric_flags varchar [note: 'Flags indicating which parametric tests were executed or passed.']
  pass_fail varchar [note: 'Overall pass or fail result for the unit.']
  pass_fail_flag boolean
  result_value decimal(18,6)
  retest_count varchar [note: 'Number of times the unit has been retested.']
  retest_indicator boolean [note: 'Indicates whether the unit was retested after an initial failure.']
  soft_bin_code varchar [note: 'Soft bin classification for detailed failure analysis.']
  test_condition varchar [note: 'Descriptive condition of the test environment.']
  test_result_comment varchar [note: 'Free-text comments or notes associated with the test result.']
  test_result_version varchar [note: 'Version identifier of the test result format or schema.']
  test_stage varchar [note: 'Discriminator indicating the test insertion stage where the result was captured.']
  test_temperature_c decimal(6,2) [note: 'Temperature at which the unit was tested, in degrees Celsius.']
  test_time_seconds decimal(10,3) [note: 'Total duration of the test execution for the unit, in seconds.']
  test_timestamp timestamp [note: 'Date and time when the test was performed.']
  test_voltage_v decimal(6,2) [note: 'Voltage level applied during testing, in volts.']
  test_yield_flag boolean [note: 'Indicates if the unit is counted towards lot yield calculations.']
  unit_identifier varchar [note: 'Identifier of the tested unit, expressed as wafer X/Y coordinates for wafer-level or serial number for package-level.']
  unit_serial_number varchar
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the test result record.']

  Note: 'Transactional record capturing individual unit-level test results from all test insertions including wafer probing, die sort, final test, and system-level test (SLT). Records unit identifier (X/Y die coordinates for wafer-level or device serial/unit position for package-level), test insertion stage discriminator, assigned hard-bin and soft-bin codes per bin_definition, pass/fail status, total test time, parametric measurement summary flags, retest indicator and retest count, KGD (Known Good Die) qualification status, multi-die/chiplet assembly position, and test temperature/voltage condition. Serves as the single source of truth for all unit-level test outcomes across the entire test flow, enabling wafer map generation, unit-level yield analysis, full lot traceability, and die-to-package correlation. Aligns with STDF PTR/FTR/MPR record concepts.'
}

Table test.final_test_run {
  final_test_run_id varchar [pk, note: 'Unique internal identifier for the package-level test execution event.']
  ate_configuration_id varchar [note: 'FK to test.ate_configuration.ate_configuration_id — Final test runs execute on specific ATE configurations. Required for equipment utilization and correlation analysis.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Final test runs are executed for a specific IC design project. Yield and quality reporting by design project is a standard semiconductor operations report — existing FK to tapeout does not directly su']
  osat_vendor_id varchar [note: 'Foreign key linking to packaging.osat_vendor. Business justification: Final test is performed at OSAT vendor sites. OSAT vendor yield scorecards, quality audits, and cost-per-unit-by-vendor reports require linking final_test_run to the OSAT vendor. final_test_run.test_l']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Final test results are reported per package type; linking to package_type enables yield analysis and compliance reporting per JEDEC package family.']
  primary_final_test_program_id varchar [note: 'Foreign key linking to test.test_program. Business justification: Final test runs are generated by a specific test program; add FK to capture this relationship.']
  ate_name varchar [note: 'Name or model of the ATE system executing the test.']
  bin_distribution varchar [note: 'Compact representation of test bin counts (e.g., JSON or delimited string).']
  boot_success_count varchar [note: 'Number of devices that successfully booted during SLT.']
  comments varchar [note: 'Free‑form notes captured by the operator or system.']
  completed_timestamp timestamp
  defect_code varchar [note: 'Standardized code describing the primary failure mode when the run fails.']
  end_timestamp timestamp [note: 'Timestamp when the test execution completed.']
  fail_count varchar [note: 'Number of devices that failed one or more test criteria.']
  final_test_run_status varchar [note: 'Current lifecycle status of the test run.']
  handler_name varchar [note: 'Identifier of the handler module that loads devices into the ATE.']
  insertion_type varchar
  parametric_test_fail varchar [note: 'Count of parametric test points that failed.']
  parametric_test_pass varchar [note: 'Count of parametric test points that passed.']
  pass_count varchar [note: 'Number of devices that passed all test criteria.']
  power_consumption_mw decimal(8,2) [note: 'Measured average power consumption during system‑level test, in milliwatts.']
  record_audit_created timestamp [note: 'Timestamp when this test run record was first created in the data lake.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to this test run record.']
  run_status varchar
  slt_board_code varchar [note: 'Identifier of the board used for system‑level testing, if applicable.']
  socket_code varchar [note: 'Identifier of the socket used to hold the device during testing.']
  start_timestamp timestamp [note: 'Timestamp when the test execution started.']
  started_timestamp timestamp
  test_location varchar [note: 'Code of the laboratory or floor where the test was performed.']
  test_program_version varchar [note: 'Version identifier of the ATE test program used for this run.']
  test_result varchar [note: 'Aggregated result of the test run.']
  test_run_code varchar [note: 'Business identifier assigned to the test run, used for tracking across systems.']
  test_shift varchar [note: 'Work shift during which the test run was executed.']
  test_temperature_c decimal(5,2) [note: 'Temperature at which the test was performed, expressed in degrees Celsius.']
  test_time_seconds decimal(8,2) [note: 'Total duration of the test execution for the device.']
  test_type varchar [note: 'Discriminator indicating whether the run is a final test or system‑level test (SLT).']
  total_sites varchar [note: 'Number of parallel test sites active on the ATE for this run.']
  yield_percent decimal(5,2) [note: 'Yield of the test run expressed as a percentage of passed devices.']

  Note: 'Transactional record for package-level test execution events on ATE including final test and system-level test (SLT). Captures device lot ID, package type, test type discriminator (final_test, SLT), test configuration (socket, ATE, handler, SLT board), test program version, test temperature, test time, pass/fail counts, bin distribution, power consumption (SLT), boot success (SLT), and test site count. Covers all post-packaging test operations distinct from wafer-level probing.'
}

Table test.parametric_measurement {
  parametric_measurement_id varchar [pk, note: 'Unique surrogate key for each parametric measurement record.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Quality Compliance: parametric measurements are reported back to the owning customer account for quality assurance and regulatory compliance.']
  bin_definition_id varchar [note: 'Foreign key linking to test.bin_definition. Business justification: Parametric measurements reference a bin definition; replace ad‑hoc bin fields with FK to bin_definition.']
  calibration_record_id varchar [note: 'Identifier of the calibration record applied to the equipment for this measurement.']
  fab_tool_id varchar [note: 'Identifier of the test equipment (ATE, probe card, etc.) that generated the measurement.']
  final_test_run_id varchar
  goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: Incoming quality control (IQC) in semiconductor fabs generates parametric measurements tied to a specific goods receipt lot. This link enables traceability from incoming material receipt to parametric']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: Parametric measurements need the IC catalog reference to correlate measured values with product specifications.']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Parametric measurements are associated with the inventory wafer lot for SPC and statistical analysis.']
  limit_id varchar
  parametric_baseline_unit_test_result_id varchar [note: 'Identifier linking to the overall test result set for the die.']
  primary_parametric_die_wafer_id varchar [note: 'Identifier of the individual die on which the measurement was performed.']
  primary_parametric_unit_test_result_id varchar [note: 'FK to test.unit_test_result.unit_test_result_id — Parametric measurements are captured per unit under test. Must link to the parent unit result for traceability.']
  process_step_id varchar [note: 'Identifier of the specific test step within the program.']
  program_id varchar [note: 'Identifier of the test program or ATPG pattern set used for the measurement.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Parametric measurements are taken on final silicon; regulatory and reliability reports link each measurement to the tapeout that produced the device.']
  tool_chamber_id varchar [note: 'Foreign key linking to equipment.tool_chamber. Business justification: Chamber-level parametric SPC: parametric measurements must be traceable to the specific measurement tool chamber for chamber-level drift analysis and process control. Required for identifying chamber-']
  wafer_probe_run_id varchar
  event_timestamp timestamp [note: 'Date and time when the measurement event was captured by the test system.']
  lower_spec_limit decimal(20,6) [note: 'Lower acceptable bound for the parameter as defined by the product spec.']
  measured_value decimal(20,6) [note: 'Numeric value recorded for the test parameter.']
  measurement_average_value decimal(20,6) [note: 'Average of repeated measurements for the parameter.']
  measurement_comment varchar [note: 'Free‑form comment entered by the operator or analyst.']
  measurement_condition_frequency_mhz decimal(12,3) [note: 'Frequency condition during the measurement, expressed in megahertz.']
  measurement_condition_temperature_c decimal(12,3) [note: 'Temperature condition during the measurement, expressed in degrees Celsius.']
  measurement_condition_voltage_mv decimal(12,3) [note: 'Voltage condition applied during the measurement, expressed in millivolts.']
  measurement_evaluated_against_limit varchar [note: 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against specification limits defined in test_limit. This link enables pass/fail determination and SPC analysis.']
  measurement_flagged boolean [note: 'Indicates if the measurement was flagged for outlier review.']
  measurement_for_unit_result varchar [note: 'FK to test.die_test_result.die_test_result_id — Parametric measurements are captured for specific die/device test results. This is the detail-level link from measurement to the unit being tested.']
  measurement_location varchar [note: 'Physical location on the die where the measurement was taken.']
  measurement_mode varchar [note: 'Mode of the test, indicating whether the measurement is parametric or functional.']
  measurement_quality_flag boolean [note: 'Quality assessment of the measurement data.']
  measurement_repeat_count varchar [note: 'Number of times the parameter was measured in this test cycle.']
  measurement_review_status varchar [note: 'Current review status of the measurement.']
  measurement_review_timestamp timestamp [note: 'Timestamp when the measurement review was completed.']
  measurement_sequence varchar [note: 'Ordinal position of this measurement within the test program.']
  measurement_source varchar [note: 'Source of the measurement data, e.g., probe card or automatic test equipment.']
  measurement_status varchar [note: 'Lifecycle status of the measurement record.']
  measurement_std_dev decimal(12,6) [note: 'Statistical standard deviation of repeated measurements.']
  measurement_timestamp timestamp [note: 'Exact time the physical measurement occurred (may differ from ingestion time).']
  measurement_tool_version varchar [note: 'Software/firmware version of the test tool that generated the measurement.']
  measurement_type varchar [note: 'Indicates whether the measurement is analog or digital.']
  measurement_uncertainty decimal(12,6) [note: 'Estimated uncertainty of the measured value.']
  measurement_unit varchar
  parameter_name varchar
  parametric_against_limit varchar [note: 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit specification. Required for pass/fail determination and SPC.']
  parametric_checked_against_limit varchar [note: 'FK to test.test_limit.test_limit_id — Each parametric measurement is evaluated against a test limit. This FK enables limit-vs-actual analysis and SPC trending.']
  pass_fail_status varchar [note: 'Result of the measurement against spec limits.']
  record_created_timestamp timestamp [note: 'Timestamp when the measurement record was first persisted in the lakehouse.']
  record_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the measurement record.']
  test_parameter_name varchar [note: 'Name of the specific parametric test parameter (e.g., Vth, Idsat).']
  unit_of_measure varchar [note: 'Engineering unit associated with the measured value. [ENUM-REF-CANDIDATE: V|mV|A|mA|Ohm|C|K|Hz — 8 candidates stripped; promote to reference product]']
  upper_spec_limit decimal(20,6) [note: 'Upper acceptable bound for the parameter as defined by the product spec.']

  Note: 'Transactional record storing individual parametric test measurements captured during wafer probe and final test. Records test parameter name, measured value, lower specification limit (LSL), upper specification limit (USL), pass/fail status, measurement unit, test condition (voltage, temperature, frequency), and associated die or device result. Enables SPC analysis, parametric yield optimization, and process-test correlation studies.'
}

Table test.limit {
  limit_id varchar [pk, note: 'System-generated unique identifier for the test limit record.']
  bin_definition_id varchar [note: 'Foreign key linking to test.bin_definition. Business justification: A parametric test limit is directly associated with a bin outcome — when a unit fails a limit, it is assigned to a specific bin. The limit table currently carries bin_mapping_code (STRING) as an infor']
  approval_status varchar [note: 'Current approval state of the limit record.']
  approved_by varchar [note: 'User identifier of the person who approved the limit.']
  audit_trail varchar [note: 'Chronological log of actions performed on the limit record.']
  category varchar [note: 'High‑level category of the limit.']
  change_reason varchar [note: 'Narrative explanation for why the limit was changed.']
  compliance_standard varchar [note: 'Regulatory or industry standard governing the limit.']
  created_by_department varchar [note: 'Organizational department responsible for creating the limit.']
  created_timestamp timestamp [note: 'Timestamp when the limit record was first created.']
  data_source varchar [note: 'Origin of the measurement data used for the limit.']
  effective_date date [note: 'Date on which the limit becomes active for production testing.']
  expiration_date date [note: 'Date after which the limit is no longer valid (null for open‑ended).']
  is_active boolean [note: 'Indicates whether the limit is currently active in the test flow.']
  last_modified_by varchar [note: 'User identifier of the person who last modified the record.']
  last_review_date date [note: 'Date of the most recent formal review of the limit.']
  lower_limit decimal(18,6)
  lower_spec_limit decimal(12,4) [note: 'Minimum acceptable measured value for the parameter.']
  measurement_type varchar [note: 'Category of measurement the limit belongs to.']
  notes varchar [note: 'Free‑form comments or observations about the limit.']
  parameter_name varchar [note: 'Human‑readable name of the parametric test parameter (e.g., Vdd, Idd).']
  regulatory_flag boolean [note: 'True if the limit is mandated by a regulatory requirement.']
  review_cycle varchar [note: 'Scheduled frequency for limit review.']
  risk_level varchar [note: 'Risk classification associated with the limit deviation.']
  sample_size varchar [note: 'Number of samples used to calculate the limit.']
  source varchar [note: 'Origin of the limit definition.']
  statistical_method varchar [note: 'Statistical approach used to derive the limit.']
  target_value decimal(12,4) [note: 'Nominal target value that the process aims to achieve.']
  test_condition_set varchar [note: 'Named set of test conditions (temperature, voltage, frequency) under which the limit is valid.']
  test_flow_name varchar [note: 'Name of the test flow or sequence where the limit is applied.']
  tolerance_percent decimal(5,2) [note: 'Allowed percentage deviation from the target value.']
  unit varchar
  unit_of_measure varchar [note: 'Measurement unit for the limit values. [ENUM-REF-CANDIDATE: V|mV|A|mA|Ohm|kOhm|nF|pF|C|% — 10 candidates stripped; promote to reference product]']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the limit record.']
  upper_limit decimal(18,6)
  upper_spec_limit decimal(12,4) [note: 'Maximum acceptable measured value for the parameter.']
  version varchar [note: 'Version identifier for the limit record, incremented on each change.']
  version_history varchar [note: 'JSON or delimited text capturing historical versions of the limit.']

  Note: 'Master record defining parametric test limits for each test parameter by device type, product revision, and test condition. Captures parameter name, LSL, USL, target value, measurement unit, test condition set, limit revision history, effective date, and approval status. SSOT for all test specification limits used across ATPG programs and ATE test flows. Supports limit change management and PCN-driven limit updates.'
}

Table test.case {
  case_id varchar [pk, note: 'Primary key for test_case']
  limit_id varchar [note: 'Foreign key linking to test.limit. Business justification: A test case in semiconductor testing defines the pass/fail criteria for a specific test parameter. The limit table holds the authoritative parametric limits (upper_limit, lower_limit, target_value) by']
  parent_test_case_id varchar [note: 'Self-referencing FK on test_case (parent_test_case_id)']
  rtl_specification_id varchar [note: 'Foreign key linking to design.rtl_specification. Business justification: Test cases are derived from RTL block functional specifications — each RTL design block\'s interface protocols and functional requirements drive specific test cases. ISO 26262 and AEC-Q100 require dire']
  bin_mapping_version varchar [note: 'Version identifier for the binning scheme associated with this test case.']
  coverage_percent decimal(5,2) [note: 'Proportion of functional or parametric specifications covered by this test case.']
  created_timestamp timestamp [note: 'Date and time when the test case record was first created in the system.']
  default_duration_seconds varchar [note: 'Standard execution time expected for the test case, in seconds.']
  effective_from date [note: 'Date when the test case becomes valid for use in production.']
  effective_until date [note: 'Date after which the test case is no longer valid; null if open‑ended.']
  expected_result varchar
  is_automated boolean [note: 'Indicates whether the test case is executed automatically by ATE without manual intervention.']
  owner varchar [note: 'Name of the engineering group or individual responsible for maintaining the test case.']
  priority varchar [note: 'Business priority indicating the importance of the test case for production release.']
  specification_url varchar [note: 'Link to the detailed test specification document stored in the PLM system.']
  target_yield_percent decimal(5,2) [note: 'Desired yield percentage that the test case aims to achieve.']
  test_case_category varchar [note: 'Level at which the test is applied, such as wafer‑level, die‑level, package‑level, or system‑level.']
  test_case_code varchar [note: 'Short alphanumeric code that uniquely identifies the test case within the test management system.']
  test_case_description varchar [note: 'Free‑form description of the test purpose, methodology, and any special considerations.']
  test_case_name varchar [note: 'Human‑readable name of the test case used in reports and dashboards.']
  test_case_status varchar [note: 'Current lifecycle state of the test case definition.']
  test_case_type varchar [note: 'Category of test performed, indicating the nature of the measurement or stimulus.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the test case record.']

  Note: 'Master reference table for test_case. Referenced by test_case_id.'
}

Table test.probe_card_qualification {
  probe_card_qualification_id varchar [pk, note: 'Primary key for the probe_card_qualification association']
  ate_configuration_id varchar [note: 'Foreign key linking to the ATE configuration against which the probe card is being qualified.']
  probe_card_id varchar [note: 'Foreign key linking to the probe card being qualified against the ATE configuration.']
  compatibility_notes varchar [note: 'Free-text engineering notes documenting compatibility observations, constraints, or conditions specific to this probe card and ATE configuration pairing. Sourced from detection phase relationship_data: compatibility_notes.']
  max_touchdown_count_for_config varchar [note: 'Maximum number of touchdowns permitted for this probe card when used with this specific ATE configuration. This limit varies by configuration and cannot be stored on the probe card alone. Sourced from detection phase relationship_data: max_touchdown_count_for_config.']
  probe_card_qualification_status varchar [note: 'Current lifecycle state of the qualification for this specific probe card and ATE configuration pairing. Sourced from detection phase relationship_data: qualification_status.']
  qualification_date date [note: 'Date on which this specific probe card and ATE configuration pairing was formally qualified for production use. Sourced from detection phase relationship_data: qualification_date.']

  Note: 'This association product represents the formal Qualification event between a probe_card and an ate_configuration in semiconductor test operations. It captures the engineering qualification record that certifies a specific probe card as compatible and approved for use with a specific ATE configuration. Each record links one probe_card to one ate_configuration and carries qualification lifecycle attributes — status, date, touchdown limits, and compatibility notes — that exist only in the context of this specific pairing and cannot be stored on either parent entity.. Existence Justification: In semiconductor test operations, probe cards must be formally qualified against specific ATE configurations before production use — a probe card may be qualified for multiple ATE configurations (e.g., different tester platforms or hardware revisions), and a single ATE configuration may be qualified with multiple probe cards (e.g., different probe card types for different device families). This qualification process is a formal, actively managed engineering activity with its own lifecycle, status, and traceability data that belongs to neither the probe card nor the ATE configuration alone.'
}

Table equipment.fab_tool {
  fab_tool_id varchar [pk, note: 'Primary key for fab_tool']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: A fab tool physically resides in a specific fab facility — this is fundamental for asset management, capacity planning by facility, maintenance scheduling, and facility-level OEE reporting. fab_tool h']
  oem_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: PROCUREMENT: OEM supplier needed for purchase contracts and warranty compliance; experts track OEM supplier per tool.']
  asset_status varchar [note: 'Operational status of the asset within the enterprise.']
  asset_tag varchar [note: 'Internal asset tag used for inventory and tracking within the enterprise.']
  calibration_date date [note: 'Date of the most recent calibration activity.']
  calibration_due_date date [note: 'Planned date for the next calibration.']
  capacity_wafer_per_hour decimal(10,2) [note: 'Maximum number of wafers the tool can process per hour.']
  capital_expenditure_amount decimal(15,2) [note: 'Initial capital cost recorded for the asset.']
  cleanroom_class varchar [note: 'Cleanroom classification where the tool operates.']
  created_timestamp timestamp [note: 'Timestamp when the record was first created in the data lake.']
  depreciation_end_date date [note: 'Date depreciation of the asset ends (end of useful life).']
  depreciation_start_date date [note: 'Date depreciation of the asset begins.']
  description varchar [note: 'Free‑form description of the equipment, including special features.']
  energy_consumption_kwh_per_year decimal(12,2) [note: 'Estimated electricity usage per year.']
  firmware_version varchar [note: 'Current firmware version installed on the tool.']
  installation_date date [note: 'Date the equipment was first installed in the fab.']
  last_maintenance_date date [note: 'Most recent date on which preventive maintenance was performed.']
  lifecycle_status varchar [note: 'Current lifecycle phase of the equipment.']
  maintenance_interval_days varchar [note: 'Planned interval between preventive maintenance activities.']
  model_number varchar [note: 'Model designation assigned by the OEM.']
  mtbf_hours decimal(10,2) [note: 'Average operating time between failures.']
  mttr_hours decimal(10,2) [note: 'Average time required to repair the tool after a failure.']
  name varchar [note: 'Human‑readable name of the equipment (e.g., "EUV Scanner 1").']
  oee_percent decimal(5,2) [note: 'Calculated OEE expressed as a percentage.']
  power_rating_kw decimal(8,2) [note: 'Maximum electrical power consumption of the tool.']
  process_node_compatibility varchar [note: 'Semiconductor process nodes the tool can support.']
  purchase_date date [note: 'Date the equipment was purchased or capitalized.']
  regulatory_status varchar [note: 'Current compliance status with applicable regulations.']
  serial_number varchar [note: 'Manufacturer‑assigned serial number uniquely identifying the physical unit.']
  software_version varchar [note: 'Current version of the tool\'s control software.']
  tool_subtype varchar [note: 'Technology subtype describing the process method. [ENUM-REF-CANDIDATE: euv|duv|cvd|pvd|ald|plasma|chemical — 7 candidates stripped; promote to reference product]']
  tool_type varchar [note: 'High‑level functional category of the equipment. [ENUM-REF-CANDIDATE: lithography|deposition|etch|cmp|metrology|ate|ion_implanter — 7 candidates stripped; promote to reference product]']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  warranty_expiration_date date [note: 'Date the manufacturer warranty ends.']

  Note: 'Master record for all semiconductor manufacturing equipment assets including lithography scanners (EUV/DUV), CVD/PVD/ALD deposition systems, etch chambers, CMP tools, ion implanters, ATE platforms, and metrology/inspection systems. Authoritative SSOT for tool identity, classification, OEM specifications, process node compatibility, FAB location, install date, and asset lifecycle status. Sourced from Applied Materials SmartFactory MES and SAP S/4HANA Fixed Assets.'
}

Table equipment.tool_chamber {
  tool_chamber_id varchar [pk, note: 'Unique identifier for the tool chamber.']
  governing_quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Chamber calibration setpoints (temperature, pressure, gas flow) are governed by quality specs defining process window tolerances. Process engineers reference quality specs to validate chamber qualific']
  vendor_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: PROCUREMENT: Chamber vendor is a supplier; linking enables vendor performance reporting and spare‑part sourcing.']
  audit_last_date date [note: 'Date of the most recent compliance audit for the chamber.']
  calibration_date date [note: 'Date when the chamber was last calibrated.']
  calibration_status varchar [note: 'Current calibration condition of the chamber.']
  chamber_code varchar [note: 'Unique alphanumeric code assigned to the chamber by the manufacturer or fab.']
  chamber_lifetime_hours decimal(12,2) [note: 'Cumulative operating hours the chamber has logged.']
  chamber_name varchar [note: 'Human‑readable name of the process chamber.']
  chamber_status_reason varchar [note: 'Free‑text explanation for the current status (e.g., fault code, maintenance activity).']
  chamber_type varchar [note: 'Category of the chamber based on its primary process function.']
  compliance_status varchar [note: 'Regulatory and internal compliance state of the chamber.']
  created_timestamp timestamp [note: 'Timestamp when the chamber record was first created in the system.']
  description varchar [note: 'Free‑text description of the chamber\'s purpose, capabilities, or special notes.']
  firmware_version varchar [note: 'Version of the embedded firmware controlling the chamber.']
  gas_flow_rate_sccm decimal(8,2) [note: 'Standard cubic centimeters per minute flow rate for process gases.']
  installation_date date [note: 'Date the chamber was first installed in the fab.']
  last_calibration_result varchar [note: 'Outcome of the most recent calibration (e.g., pass, fail, deviation values).']
  last_inspection_date date [note: 'Date when the chamber was last inspected for wear or damage.']
  last_maintenance_date date [note: 'Date of the most recent preventive or corrective maintenance event.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the chamber record.']
  location varchar [note: 'Specific location within the fab (e.g., line, bay, floor).']
  maintenance_cycle_days varchar [note: 'Standard interval in days between scheduled maintenance events.']
  model_number varchar [note: 'Model designation of the chamber.']
  mtbf_hours decimal(10,2) [note: 'Average operating hours between failures for the chamber.']
  mttr_hours decimal(10,2) [note: 'Average time required to repair the chamber after a failure.']
  next_maintenance_due date [note: 'Planned date for the next maintenance activity based on the maintenance cycle.']
  oee_percentage decimal(5,2) [note: 'Calculated OEE metric for the chamber (percentage).']
  pressure_setpoint_pa decimal(10,2) [note: 'Target pressure setting for the chamber during operation.']
  qualification_date date [note: 'Date when the chamber was last qualified.']
  qualification_result varchar [note: 'Detailed outcome of the qualification test (e.g., pass, fail, notes).']
  qualification_status varchar [note: 'Result of the most recent qualification run for the chamber.']
  safety_lock_status varchar [note: 'Current state of the chamber\'s safety interlock.']
  serial_number varchar [note: 'Manufacturer‑assigned serial number for the chamber.']
  software_version varchar [note: 'Version of the control software used by the chamber.']
  temperature_setpoint_c decimal(6,2) [note: 'Target temperature setting for the chamber during operation.']
  throughput_pph decimal(12,2) [note: 'Maximum parts‑per‑hour the chamber can process under nominal conditions.']
  tool_chamber_status varchar [note: 'Current operational state of the chamber.']
  warranty_expiration_date date [note: 'Date when the manufacturer\'s warranty for the chamber ends.']

  Note: 'Individual process chamber or module within a multi-chamber fab tool (e.g., a CVD cluster tool with 4 deposition chambers, or an etch system with multiple etch modules). Tracks chamber-level qualification status, process recipe assignments, chamber-specific utilization, and maintenance history independently from the parent tool. Essential for chamber-level SPC and yield correlation in multi-chamber tools.'
}

Table equipment.tool_qualification {
  tool_qualification_id varchar [pk, note: 'Unique identifier for each tool qualification record.']
  family_id varchar [note: 'Foreign key linking to product.product_family. Business justification: QUALIFICATION COMPLIANCE report requires linking each tool qualification to the specific product family it supports, enabling audit of qualification status per family.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Tool qualification reports must reference the specific design project they validate, required for the \'Design Qualification Management\' process.']
  process_flow_id varchar [note: 'Foreign key linking to fabrication.fabrication_process_flow. Business justification: Tool qualification in semiconductor fabs is flow-specific — a tool must be qualified for each process flow it will run in production. Linking tool_qualification to fabrication_process_flow enables flo']
  qualification_inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Tool qualification requires running qualification wafers that generate an inspection lot. Quality engineers link the qualification event to the specific inspection lot to trace qualification wafer res']
  approval_date date [note: 'Date the qualification was formally approved.']
  approved_by varchar [note: 'Name of the process engineer or manager who approved the qualification.']
  baseline_value decimal(12,4) [note: 'Target baseline value that the tool must meet or exceed.']
  calibration_date date [note: 'Date when the measurement tool was last calibrated.']
  calibration_status varchar [note: 'Current calibration status of the measurement tool.']
  change_control_number varchar [note: 'Reference number of the change control request linked to this qualification.']
  compliance_approval_status varchar [note: 'Regulatory compliance sign‑off status for the qualification.']
  compliance_document_reference varchar [note: 'Reference to the compliance document associated with the qualification.']
  created_timestamp timestamp [note: 'Timestamp when the qualification record was created in the system.']
  documentation_url varchar [note: 'Link to detailed qualification documentation or report.']
  equipment_serial_number varchar [note: 'Manufacturer-assigned serial number of the equipment.']
  is_critical boolean [note: 'Indicates whether the tool is on the critical production path.']
  last_maintenance_date date [note: 'Date of the most recent preventive or corrective maintenance on the equipment.']
  maintenance_status varchar [note: 'Indicates whether the equipment maintenance is current.']
  measurement_method varchar [note: 'Method used to capture the qualification metric.']
  notes varchar [note: 'Free‑form comments or observations captured during qualification.']
  oee_impact decimal(5,2) [note: 'Estimated impact of the qualification on Overall Equipment Effectiveness, expressed as a percentage.']
  qualification_end_date date [note: 'Date when the qualification activity completed.']
  qualification_location varchar [note: 'Plant or fab location where the qualification was performed.']
  qualification_protocol varchar [note: 'Name or code of the protocol used to qualify the tool.']
  qualification_reason varchar [note: 'Business driver for performing the qualification.']
  qualification_start_date date [note: 'Date when the qualification activity began.']
  qualification_status varchar [note: 'Current lifecycle status of the qualification process.']
  qualification_type varchar [note: 'Category of qualification performed on the tool.']
  qualification_validity_period_days varchar [note: 'Number of days the qualification remains valid from the start date.']
  qualification_version varchar [note: 'Version identifier for the qualification record, incremented on re‑qualifications.']
  result varchar [note: 'Overall outcome of the qualification.']
  result_metric_unit varchar [note: 'Unit of measure for the result metric.']
  result_metric_value decimal(12,4) [note: 'Measured value of the primary qualification metric (e.g., overlay error).']
  risk_assessment varchar [note: 'Risk level associated with the qualification outcome.']
  tolerance decimal(12,4) [note: 'Acceptable deviation from the baseline value.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the qualification record.']
  validity_end_date date [note: 'Date after which the qualification expires and must be renewed.']
  validity_start_date date [note: 'Date from which the qualification is considered valid for production.']

  Note: 'Qualification and certification records for fab tools and chambers against specific process nodes, recipes, and product families. Captures qualification type (initial qual, re-qual, process change qual), qualification protocol, pass/fail criteria, baseline metrology results, approving process engineer, and qualification validity period. A tool must be qualified before it can run production wafer lots. Sourced from Oracle Agile PLM and SmartFactory MES.'
}

Table equipment.pm_schedule {
  pm_schedule_id varchar [pk, note: 'Unique identifier for the preventive maintenance schedule record.']
  primary_pm_fab_tool_id varchar [note: 'Identifier of the fab tool or chamber to which the schedule applies.']
  required_spare_part_id varchar [note: 'Identifier of the spare part that must be available for the maintenance.']
  compliance_requirement varchar [note: 'Regulatory or industry standard that the maintenance activity must satisfy.']
  created_timestamp timestamp [note: 'Timestamp when the schedule record was first created in the system.']
  description varchar [note: 'Free‑text description of the maintenance activity and its purpose.']
  estimated_downtime_minutes varchar [note: 'Planned equipment downtime in minutes for the maintenance activity.']
  interval_unit varchar [note: 'Unit of measure for the interval value (day, week, month, wafer, or run).']
  interval_value varchar [note: 'Numeric value defining the interval between maintenance events (e.g., 500 wafers, 1000 runs, 30 days).']
  is_critical boolean [note: 'Indicates whether the equipment is classified as critical for production (true) or not (false).']
  last_modified_by varchar [note: 'User identifier of the person who last modified the schedule record.']
  last_performed_date date [note: 'Date on which the maintenance activity was last executed.']
  maintenance_window_end timestamp [note: 'Planned end time of the maintenance window.']
  maintenance_window_start timestamp [note: 'Planned start time of the maintenance window.']
  next_scheduled_date date [note: 'Planned calendar date for the next execution of the maintenance.']
  oee_impact_estimate decimal(5,2) [note: 'Estimated impact of the maintenance on Overall Equipment Effectiveness expressed as a percentage.']
  pm_procedure_reference varchar [note: 'Reference code or document ID for the detailed preventive maintenance procedure.']
  pm_schedule_status varchar [note: 'Current lifecycle status of the schedule.']
  pm_type varchar [note: 'Category of preventive maintenance activity (e.g., daily, weekly, monthly, wafer‑count‑based, run‑count‑based).']
  priority varchar [note: 'Business priority assigned to the maintenance activity.']
  required_technician_skill_level varchar [note: 'Skill level required of the technician performing the maintenance.']
  schedule_code varchar [note: 'Business code used to uniquely reference the schedule across systems.']
  schedule_name varchar [note: 'Human‑readable name describing the maintenance schedule.']
  scheduling_constraint varchar [note: 'Business rule or production window constraint that influences when the PM can be run.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the schedule record.']
  work_order_template_code varchar [note: 'Identifier of the work‑order template used to generate PM work orders.']

  Note: 'Preventive maintenance (PM) schedule master defining planned PM activities for each fab tool or chamber. Specifies PM type (daily, weekly, monthly, wafer-count-based, run-count-based), PM procedure reference, estimated downtime window, required spare parts, required technician skill level, and scheduling constraints relative to production WIP. Drives the PM work order generation cadence in SAP PM module.'
}

Table equipment.maintenance_event {
  maintenance_event_id varchar [pk, note: 'System-generated unique identifier for the maintenance event record.']
  pm_schedule_id varchar [note: 'FK to equipment.pm_schedule.pm_schedule_id — Scheduled PM events must link back to the PM schedule that triggered them, enabling PM compliance tracking.']
  primary_fab_tool_id varchar [note: 'FK to equipment.fab_tool.fab_tool_id — Every maintenance event must reference the tool serviced. Core operational FK for maintenance history and MTTR calculation.']
  primary_spare_part_id varchar [note: 'FK to equipment.spare_part.spare_part_id — Maintenance events consume spare parts. This link enables parts consumption tracking and inventory depletion.']
  storage_location_id varchar [note: 'Identifier of the fab floor or site where the equipment resides.']
  triggering_nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: In semiconductor fabs, tool excursions generating NCRs trigger maintenance events (tool hold and repair). Maintenance engineers need to reference the NCR that initiated the maintenance action for root']
  baseline_change_flag boolean [note: 'True if the maintenance altered the equipment baseline for qualification.']
  comments varchar [note: 'Additional free‑form notes captured by technicians or supervisors.']
  compliance_regulation varchar [note: 'Regulatory framework applicable to the maintenance activity.']
  cost_currency varchar [note: 'Three‑letter ISO currency code for monetary amounts.']
  downtime_duration_minutes varchar [note: 'Total equipment downtime measured in minutes.']
  downtime_minutes varchar
  eco_reference varchar [note: 'Identifier of the ECO that drove the modification, if applicable.']
  end_timestamp timestamp [note: 'Date‑time when the maintenance work was completed.']
  event_number varchar [note: 'Human‑readable identifier or ticket number assigned to the maintenance event.']
  event_timestamp timestamp
  event_type varchar [note: 'Classification of the maintenance activity.']
  labor_cost_total decimal(12,2) [note: 'Monetary cost of labor based on labor hours and rate.']
  labor_hours decimal(6,2) [note: 'Total technician labor time recorded for the event.']
  maintenance_category varchar [note: 'Strategic classification of the maintenance approach.']
  maintenance_event_status varchar [note: 'Current processing state of the maintenance event.']
  oee_impact_percentage decimal(5,2) [note: 'Estimated impact on Overall Equipment Effectiveness expressed as a percent.']
  parts_cost_total decimal(12,2) [note: 'Aggregate cost of all spare parts and consumables used.']
  performance_improvement_target varchar [note: 'Planned performance gain (e.g., throughput increase) resulting from the event.']
  post_config_version varchar [note: 'Snapshot or version identifier of equipment configuration after maintenance.']
  pre_config_version varchar [note: 'Snapshot or version identifier of equipment configuration before maintenance.']
  record_audit_created timestamp [note: 'Timestamp when the maintenance event record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the maintenance event record.']
  repair_action_description varchar [note: 'Narrative of the corrective actions performed during the event.']
  requalification_required boolean [note: 'Indicates whether a formal re‑qualification is needed after the event.']
  requalification_status varchar [note: 'Current status of any required re‑qualification process.']
  root_cause_category varchar [note: 'High‑level classification of the underlying cause of failure.']
  root_cause_detail varchar [note: 'Free‑text description of the specific root cause identified.']
  safety_incident_description varchar [note: 'Details of any safety incident associated with the maintenance.']
  safety_incident_flag boolean [note: 'True if the maintenance event involved a safety incident.']
  start_timestamp timestamp [note: 'Date‑time when the maintenance work actually began.']
  technician_name varchar [note: 'Full name of the technician responsible for the maintenance.']
  total_cost decimal(12,2) [note: 'Combined cost of parts, labor, and any additional charges.']
  trigger_source varchar [note: 'Origin that caused the maintenance event to be created.']
  updated_by varchar [note: 'System user identifier that last modified the record.']
  upgrade_type varchar [note: 'Indicates whether the event involved a hardware, software, or firmware upgrade.']
  created_by varchar [note: 'System user identifier that created the record.']

  Note: 'Transactional record of every maintenance activity executed on a fab tool or chamber, including preventive maintenance (PM), corrective maintenance (CM), emergency breakdown repair, engineering-driven modifications, tool upgrades/retrofits, and hardware/software modifications. Captures event type, trigger (scheduled PM, alarm, operator-reported, FDC event, ECO), start/end timestamps, actual downtime duration, root cause classification (5-why, fishbone), repair actions taken, spare parts and consumables consumed (part ID, quantity, unit cost, planned vs unplanned), technician IDs, upgrade/retrofit details (upgrade type, ECO reference, pre/post configuration, performance improvement targets, baseline change flag), and return-to-service sign-off including re-qualification requirements. SSOT for tool downtime attribution, MTTR/MTBF calculation, parts consumption tracking, upgrade history, and total cost of ownership. Sourced from SAP S/4HANA PM and SmartFactory MES.'
}

Table equipment.tool_downtime {
  tool_downtime_id varchar [pk, note: 'System-generated unique identifier for each downtime event record.']
  fabrication_wafer_lot_id varchar [note: 'Foreign key linking to fabrication.fabrication_wafer_lot. Business justification: Tool downtime directly impacts in-process WIP lots — fab operations track which lots were affected by downtime for customer communication, delivery date revision, and hot-lot prioritization. tool_down']
  impacted_inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: Tool downtime directly impacts WIP wafer lots held in inventory. This link enables yield-loss-per-downtime-event reporting, customer impact assessment, and SLA breach analysis. tool_downtime.impact_wi']
  primary_fab_tool_id varchar [note: 'Unique identifier of the fab tool or chamber that experienced the downtime.']
  primary_tool_chamber_id varchar [note: 'Foreign key linking to equipment.tool_chamber. Business justification: Downtime in multi-chamber fab tools is often chamber-specific — one chamber may be down for maintenance or process issues while other chambers in the same cluster tool continue operating. Linking tool']
  primary_tool_maintenance_event_id varchar [note: 'Reference to the maintenance work order associated with the downtime, if any.']
  scheduled_pm_schedule_id varchar [note: 'Foreign key linking to equipment.pm_schedule. Business justification: tool_downtime has a scheduled_flag boolean indicating whether the downtime was planned. When scheduled_flag is true, the downtime is associated with a preventive maintenance activity. Linking tool_dow']
  triggering_nonconformance_report_id varchar [note: 'Foreign key linking to quality.nonconformance_report. Business justification: Quality-initiated tool holds (NCR disposition placing tool on hold) generate downtime records. Fab operations teams track which NCR caused the tool hold to report quality-driven downtime separately fr']
  comments varchar [note: 'Free‑form notes or observations related to the downtime event.']
  corrective_action_taken varchar [note: 'Brief description of the corrective action performed to resolve the issue.']
  created_timestamp timestamp [note: 'Timestamp when the downtime record was first created in the system.']
  downtime_duration_minutes varchar [note: 'Total duration of the downtime event expressed in whole minutes.']
  downtime_end_timestamp timestamp [note: 'Exact date and time when the tool exited the downtime state.']
  downtime_reason varchar
  downtime_reason_code varchar [note: 'Standardized code representing the root cause of the downtime.']
  downtime_reason_description varchar [note: 'Human‑readable description of why the tool was down.']
  downtime_start_timestamp timestamp [note: 'Exact date and time when the tool entered the downtime state.']
  downtime_type varchar [note: 'Classification of the downtime according to the SEMI E10 state model.']
  duration_minutes varchar
  end_timestamp timestamp
  oee_impact_percentage decimal(5,2) [note: 'Estimated reduction in Overall Equipment Effectiveness caused by the downtime, expressed as a percentage.']
  responsible_party varchar [note: 'Team or role accountable for handling the downtime event.']
  root_cause_category varchar [note: 'High‑level category describing the underlying cause of the downtime.']
  scheduled_flag boolean [note: 'Indicates whether the downtime was planned (true) or unplanned (false).']
  severity_level varchar [note: 'Severity rating of the downtime event based on impact and urgency.']
  shift varchar [note: 'Production shift during which the downtime occurred.']
  start_timestamp timestamp
  state_after varchar [note: 'Equipment state after the downtime event concluded.']
  state_before varchar [note: 'Equipment state immediately prior to the downtime event.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the downtime record.']

  Note: 'Granular downtime records for each fab tool and chamber classified per SEMI E10 equipment state model (Productive, Standby, Engineering, Scheduled Downtime, Unscheduled Downtime, Non-Scheduled). Captures state transition timestamps, downtime reason code, responsible party (maintenance, engineering, facilities, scheduling), and impact on WIP lots. Feeds OEE (Overall Equipment Effectiveness) calculation and capacity planning models.'
}

Table equipment.calibration_record {
  calibration_record_id varchar [pk, note: 'System-generated unique identifier for each calibration record.']
  primary_calibration_fab_tool_id varchar [note: 'Unique identifier of the fab equipment that was calibrated.']
  tertiary_fab_tool_id varchar [note: 'FK to equipment.fab_tool.fab_tool_id — Calibration records must reference the tool/instrument calibrated. Required for ISO 9001 traceability.']
  triggering_pm_schedule_id varchar [note: 'Foreign key linking to equipment.pm_schedule. Business justification: Calibration activities in semiconductor fabs are frequently scheduled as part of preventive maintenance programs — PM schedules often include calibration verification steps. Linking calibration_record']
  calibration_date date
  calibration_interval_days varchar [note: 'Planned interval in days between successive calibrations for this equipment.']
  calibration_method varchar [note: 'Technique used to perform the calibration.']
  calibration_record_status varchar [note: 'Current processing status of the calibration record.']
  calibration_report_url varchar [note: 'Link to the detailed calibration report stored in the document repository.']
  calibration_result varchar
  calibration_result_code varchar [note: 'Standardized code representing the calibration outcome for downstream analytics.']
  calibration_source_system varchar [note: 'Name of the source system that generated the record (e.g., KLA ICOS, SmartFactory MES).']
  calibration_standard varchar [note: 'Reference standard used for calibration (e.g., NIST traceable, SEMI E30).']
  calibration_timestamp timestamp [note: 'Date and time when the calibration activity was performed.']
  calibration_type varchar [note: 'Method of calibration applied to the equipment.']
  comments varchar [note: 'Additional remarks or observations captured by the technician.']
  compliance_reference varchar [note: 'Reference to the compliance clause (e.g., ISO 9001, IATF 16949) satisfied by this calibration.']
  created_timestamp timestamp [note: 'Timestamp when the calibration record was first created in the system.']
  location varchar [note: 'Plant or fab line where the equipment resides (e.g., FAB1, LineA).']
  lot_number varchar [note: 'Identifier of the wafer lot associated with the calibration (if applicable).']
  measured_value decimal(12,4) [note: 'Value recorded by the instrument during calibration.']
  measurement_uncertainty decimal(12,4) [note: 'Estimated uncertainty of the measured value.']
  measurement_unit varchar [note: 'Unit of the measured and nominal values (e.g., nanometers, volts).']
  next_calibration_date date
  next_due_date date [note: 'Date by which the next calibration must be performed.']
  nominal_value decimal(12,4) [note: 'Target or nominal value that the equipment should meet.']
  pass_fail_result varchar [note: 'Pass/Fail outcome of the calibration activity.']
  technician_name varchar [note: 'Full name of the calibration technician.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the calibration record.']

  Note: 'Calibration and metrology verification records for fab tools and measurement instruments. Tracks calibration type (in-situ, offline, periodic), calibration standard used, measured vs. nominal values, calibration pass/fail result, calibration interval, next due date, calibrating technician, and traceability to NIST or SEMI standards. Mandatory for ISO 9001 and IATF 16949 compliance. Sourced from KLA ICOS and SmartFactory MES calibration modules.'
}

Table equipment.oee_record {
  oee_record_id varchar [pk, note: 'Unique surrogate key for each OEE measurement record.']
  fabrication_wafer_lot_id varchar [note: 'Identifier of the wafer lot being processed during the measurement period.']
  primary_fab_tool_id varchar [note: 'FK to equipment.fab_tool.fab_tool_id — OEE records must reference the measured tool. This is the fundamental relationship for equipment productivity reporting.']
  primary_maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: OEE records track equipment state transitions and downtime categories. When a maintenance event causes a state change (e.g., tool goes from productive to unscheduled downtime), linking the oee_record ']
  primary_tool_chamber_id varchar [note: 'Foreign key linking to equipment.tool_chamber. Business justification: OEE (Overall Equipment Effectiveness) metrics in semiconductor fabs are tracked at both the tool level and the chamber level for multi-chamber systems. A CVD cluster tool with 4 chambers may have diff']
  process_step_id varchar [note: 'Foreign key linking to fabrication.fabrication_process_step. Business justification: Step-level OEE reporting is a standard semiconductor manufacturing KPI — OEE is measured per tool per process operation to identify bottleneck steps. Linking OEE records to specific process steps enab']
  availability_percent decimal(5,2)
  availability_rate decimal(5,2) [note: 'Percentage of scheduled time the equipment was available for production.']
  available_hours decimal(6,2) [note: 'Total scheduled time the equipment was available for production.']
  comments varchar [note: 'Free‑form notes or observations related to the OEE measurement.']
  created_timestamp timestamp [note: 'Timestamp when the OEE record was first inserted into the data lake.']
  downtime_category varchar [note: 'High‑level classification of downtime type.']
  downtime_reason_code varchar [note: 'Standard code describing the root cause of downtime.']
  engineering_hours decimal(6,2) [note: 'Hours spent in engineering or setup state (non‑productive).']
  event_timestamp timestamp [note: 'Exact date‑time when the OEE measurement was recorded.']
  idle_hours decimal(6,2) [note: 'Hours the equipment was idle (no work) while available.']
  measurement_period varchar [note: 'Granularity of the OEE aggregation (e.g., shift, day, week).']
  oee_calculation_method varchar [note: 'Methodology used to compute OEE (e.g., SEMI E10 standard or custom algorithm).']
  oee_percent decimal(5,2)
  oee_percentage decimal(5,2) [note: 'Composite OEE metric calculated as availability × performance × quality.']
  performance_percent decimal(5,2)
  performance_rate decimal(5,2) [note: 'Ratio of actual production speed to ideal speed, expressed as a percentage.']
  productive_hours decimal(6,2) [note: 'Total hours the equipment spent in productive state during the measurement period.']
  quality_percent decimal(5,2)
  quality_rate decimal(5,2) [note: 'Percentage of good units produced out of total units processed.']
  record_date date
  record_status varchar [note: 'Current lifecycle status of the OEE record.']
  responsible_party varchar [note: 'Team or function accountable for the recorded downtime or state.']
  scheduled_downtime_hours decimal(6,2) [note: 'Planned downtime (e.g., maintenance, changeover) duration in hours.']
  shift_date date [note: 'Calendar date of the production shift associated with the OEE record.']
  shift_name varchar [note: 'Label of the shift (e.g., A, B, C, D) during which the OEE data was collected.']
  state_current varchar [note: 'Equipment state at the end of the measurement period.']
  state_last_change_timestamp timestamp [note: 'Timestamp of the most recent state transition within the period.']
  state_transition_count varchar [note: 'Number of equipment state changes recorded in the period.']
  unscheduled_downtime_hours decimal(6,2) [note: 'Unplanned downtime (e.g., breakdown) duration in hours.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the OEE record.']
  utilization_rate decimal(18,2) [note: 'Equipment utilization rate as a percentage']
  wafer_throughput decimal(8,2) [note: 'Number of good wafers produced per hour (WPH) during the period.']

  Note: 'Periodic equipment productivity measurement and state tracking records for each fab tool combining SEMI E10 equipment state model data and OEE (Overall Equipment Effectiveness) metrics. Captures granular state transitions (Productive, Standby, Engineering, Scheduled Downtime, Unscheduled Downtime, Non-Scheduled), state transition timestamps, downtime reason codes, responsible party attribution (maintenance, engineering, facilities, scheduling), WIP lot impact, measurement period (shift, day, week), availability rate, performance rate, quality rate, composite OEE percentage, productive hours, available hours, idle hours, engineering hours, wafer throughput (WPH), and downtime breakdown. SSOT for all equipment state tracking, downtime attribution, productivity reporting, capacity consumption analysis, bottleneck identification, and fab scheduling inputs. Sourced from SmartFactory MES run data and OEE calculation engine.'
}

Table equipment.spare_part {
  spare_part_id varchar [pk, note: 'Unique surrogate key for each spare part record.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Spare parts in semiconductor fabs are procured materials defined in the material master (SAP/ERP standard). Linking spare_part to material_master enables procurement planning, RoHS/REACH compliance ch']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Spare parts are physically stored in inventory-managed storage locations (cleanrooms, warehouses). Maintenance planners use this link to locate parts during a maintenance event. The denormalized locat']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: INVENTORY/RISK: Each spare part has a primary supplier for lead‑time, quality, and risk assessment reports.']
  calibration_interval_days varchar [note: 'Number of days between required calibrations for the part.']
  calibration_required_flag boolean [note: 'True if the part must be calibrated periodically (e.g., sensors, metrology tools).']
  compliance_certifications varchar [note: 'Comma‑separated list of regulatory or industry certifications applicable to the part (e.g., RoHS, REACH).']
  created_timestamp timestamp [note: 'Date‑time when the spare part record was first created in the system.']
  criticality_rating varchar [note: 'Business impact rating if the part is unavailable (high = production‑stop risk).']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency used for the unit cost.']
  current_stock_qty varchar [note: 'Number of units of the part currently available in the fab stockroom.']
  description varchar [note: 'Detailed textual description of the part, including function and key specifications.']
  disposal_method varchar [note: 'Preferred method for disposing of excess or expired parts.']
  equipment_compatible varchar [note: 'List of equipment models or tool families that can use this spare part.']
  hazardous_material_flag boolean [note: 'Indicates whether the part is classified as hazardous under safety regulations.']
  last_inspection_date date [note: 'Date the part was most recently inspected for quality or safety compliance.']
  last_received_date date [note: 'Date the most recent shipment of this part was received into inventory.']
  last_used_date date [note: 'Date the part was last issued for equipment maintenance or repair.']
  lead_time_days varchar [note: 'Average number of calendar days from order placement to receipt of the part.']
  lifecycle_end_date date [note: 'Date the part was officially retired or marked obsolete.']
  lifecycle_start_date date [note: 'Date the part was first introduced into the inventory catalog.']
  min_stock_level varchar [note: 'Minimum quantity that must be on hand to avoid stock‑out situations.']
  part_category varchar [note: 'High‑level equipment domain the part supports. [ENUM-REF-CANDIDATE: lithography|deposition|etch|cmp|metrology|ate|assembly|test|other — 9 candidates stripped; promote to reference product]']
  part_image_url varchar [note: 'Link to a digital image or drawing of the spare part.']
  part_name varchar [note: 'Human‑readable name of the spare part used in inventory and work orders.']
  part_number varchar [note: 'Manufacturer‑assigned part number that uniquely identifies the component across suppliers.']
  part_type varchar [note: 'Classification of the part based on its usage and criticality to fab operations.']
  part_volume_cm3 decimal(10,2) [note: 'Physical volume of a single unit of the part in cubic centimeters.']
  part_weight_kg decimal(8,3) [note: 'Physical weight of a single unit of the part in kilograms.']
  reorder_point varchar [note: 'Inventory quantity threshold that triggers a replenishment order.']
  safety_stock_qty varchar [note: 'Buffer quantity kept to protect against demand variability and supply delays.']
  spare_part_status varchar [note: 'Current lifecycle status of the part within the inventory system.']
  stock_quantity varchar
  storage_condition varchar [note: 'Environmental condition required for safe storage of the part.']
  supplier varchar [note: 'Primary external supplier or vendor from which the part is sourced.']
  unit_cost decimal(12,2) [note: 'Standard purchase cost per individual unit of the part.']
  unit_cost_usd decimal(18,2)
  updated_by varchar [note: 'Identifier of the system user who last modified the record.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the spare part record.']
  warranty_expiration_date date [note: 'Date on which the manufacturer\'s warranty for the part expires.']
  created_by varchar [note: 'Identifier of the system user who created the record.']

  Note: 'Master record for spare parts and consumables inventory specific to fab tool maintenance, including critical spare parts (e.g., focus rings, edge rings, quartz liners, lamp assemblies, pump kits), their OEM part numbers, compatible tool types, minimum stock levels, lead times, and storage location in the FAB stockroom. Supports PM planning and emergency repair readiness. Sourced from SAP S/4HANA MM module.'
}

Table inventory.inventory_wafer_lot {
  inventory_wafer_lot_id varchar [pk, note: 'Unique surrogate identifier for the wafer lot master record within the inventory domain. Primary key for the inventory_wafer_lot data product. Role: TRANSACTION_HEADER — this entity represents a discrete WIP business event (a lot moving through FAB) with a clear lifecycle, party references, timestamps, and quantitative results.']
  account_id varchar [note: 'Reference to the customer for whom this wafer lot is being fabricated. Applicable for foundry/OSAT business models where lots are customer-specific. Null for internal product lots. This is the PARTY_REFERENCE category field for this TRANSACTION_HEADER entity.']
  fab_facility_id varchar [note: 'Foreign key linking to fabrication.fab_facility. Business justification: Wafer lot traceability to originating fab facility is required for yield analysis by facility, capacity planning, and regulatory/export-control reporting. A semiconductor operations expert expects eve']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Wafer‑lot allocation to a specific IC design project is required for production planning and capacity reports.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Wafer lots are tracked against material master records for ERP valuation, MRP planning, and procurement cost roll-up in semiconductor fabs. This link enables standard cost calculation, material consum']
  physical_layout_id varchar [note: 'Foreign key linking to design.physical_layout. Business justification: WIP wafer lots in fabrication must be traceable to the specific physical layout (GDS version) being manufactured. Fab engineers and process integration teams use this link for DRC/LVS sign-off traceab']
  primary_inventory_fabrication_wafer_lot_id varchar [note: 'Externally-known, human-readable lot identifier assigned by the Manufacturing Execution System (MES) at lot creation. Used across FAB operations, quality systems, and customer traceability. Corresponds to the Camstar MES Lot ID / SAP PP Production Order number. This is the BUSINESS_IDENTIFIER category field for this TRANSACTION_HEADER entity.']
  process_flow_id varchar [note: 'Identifier of the MES process route (flow plan) assigned to this wafer lot, defining the ordered sequence of operations from wafer start through final FAB step. Determines which process steps, equipment, and recipes apply to the lot.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: inventory_wafer_lot has a denormalized storage_location_code (STRING) that references the physical storage location of the wafer lot in the FAB. Normalizing this to a FK to storage_location eliminates']
  tapeout_id varchar [note: 'Reference to the tapeout record (final design submission for manufacturing) associated with this wafer lot. Links WIP inventory to the design domain for design-to-silicon traceability and first silicon yield analysis.']
  actual_completion_date date [note: 'Actual date on which the wafer lot completed all FAB process steps. Populated upon lot completion. Used for cycle time actuals, on-time delivery KPI calculation, and process improvement analysis.']
  created_timestamp timestamp [note: 'Timestamp when this wafer lot master record was first created in the inventory data product (Silver layer). Represents the RECORD_AUDIT_CREATED category for this TRANSACTION_HEADER entity. Used for data lineage and audit trail.']
  die_per_wafer varchar [note: 'Theoretical number of die that can be patterned on a single wafer for this product at the given process node and die size. Used as the denominator for yield calculations and finished goods quantity forecasting.']
  good_wafer_count varchar [note: 'Number of wafers in the lot that have passed all in-line inspection and metrology checks to date. Represents the current count of wafers expected to yield good die. Updated after each inspection or disposition event.']
  hold_flag boolean [note: 'Indicates whether the wafer lot is currently placed on hold and cannot proceed to the next process step. A True value means the lot is blocked pending engineering review, quality disposition, or management approval. Sourced from MES hold management.']
  hold_reason_code varchar [note: 'Coded reason for the current or most recent hold placed on the wafer lot (e.g., \'PROCESS_EXCURSION\', \'EQUIPMENT_FAILURE\', \'YIELD_LOSS\', \'CUSTOMER_REQUEST\', \'ENGINEERING_REVIEW\'). Populated when hold_flag is True. Used for hold disposition tracking and FMEA analysis. [ENUM-REF-CANDIDATE: PROCESS_EXCURSION|EQUIPMENT_FAILURE|YIELD_LOSS|CUSTOMER_REQUEST|ENGINEERING_REVIEW|MATERIAL_SHORTAGE|QUALITY_DISPOSITION — promote to reference product]']
  hold_timestamp timestamp [note: 'Date and time when the most recent hold was placed on the wafer lot. Null if the lot has never been placed on hold. Used for hold duration tracking and SPC (Statistical Process Control) excursion response time measurement.']
  inventory_valuation_amount decimal(18,4) [note: 'Current standard cost valuation of the wafer lot in the inventory ledger, expressed in the functional currency. Calculated based on the number of wafers and the standard cost per wafer at the current process step. Used for WIP inventory valuation in SAP FI/CO and financial reporting under SOX.']
  lithography_type varchar [note: 'Type of photolithography exposure technology used for the critical layers of this wafer lot. EUV (Extreme Ultraviolet) is used for leading-edge nodes (sub-7nm); DUV (Deep Ultraviolet) for mature nodes. Determines equipment routing and cost structure.']
  lot_start_date date [note: 'Calendar date on which the wafer lot was officially started (wafer start authorization executed) in the FAB. Used for cycle time measurement, WIP aging analysis, and on-time delivery tracking. This is the BUSINESS_EVENT_TIMESTAMP (date precision) category field.']
  lot_status varchar [note: 'Current lifecycle state of the wafer lot within the FAB WIP flow. \'active\' indicates the lot is progressing through process steps; \'on_hold\' indicates a hold flag is set pending disposition; \'completed\' indicates all process steps are finished; \'scrapped\' indicates the lot has been disposed; \'cancelled\' indicates the lot was terminated before completion. This is the LIFECYCLE_STATUS category field.']
  lot_type varchar [note: 'Classification of the wafer lot by its manufacturing purpose. \'production\' lots are for customer shipment; \'engineering\' lots support process development; \'qualification\' lots validate new processes or products; \'monitor\' lots track process stability; \'reliability\' lots support JEDEC/IATF reliability testing. This is the CLASSIFICATION_OR_TYPE category field.']
  mes_lot_reference varchar [note: 'Native lot reference number as recorded in the Applied Materials SmartFactory or Camstar MES system. Enables direct cross-reference to the operational system of record for lot tracking, dispatch, and WIP management.']
  priority_class varchar [note: 'Dispatch priority classification assigned to the wafer lot, used by MES to sequence lot movement through FAB equipment queues. \'hot\' lots receive highest priority for customer-critical or yield-recovery situations; \'expedite\' for accelerated delivery; \'standard\' for normal flow; \'low\' for non-urgent engineering runs.']
  process_stage varchar [note: 'High-level semiconductor fabrication stage classification: FEOL (Front End of Line) covers transistor formation; MOL (Middle of Line) covers local interconnects; BEOL (Back End of Line) covers metal interconnect layers. Used for WIP stage-gate reporting and cycle time decomposition.']
  route_version varchar [note: 'Version identifier of the process route assigned to this lot. Tracks which revision of the process flow was active at lot start, supporting process change impact analysis and PCN (Product Change Notification) traceability.']
  scrap_wafer_count varchar [note: 'Cumulative number of wafers scrapped from this lot since lot creation. Includes wafers scrapped due to process excursions, equipment failures, or quality dispositions. Used for yield loss analysis and DPPM (Defective Parts Per Million) reporting.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this wafer lot record was sourced (e.g., CAMSTAR for Camstar MES, SMARTFACTORY for Applied Materials SmartFactory, SAP_PP for SAP Production Planning). Supports data lineage and multi-system reconciliation in the Databricks Silver layer.']
  target_completion_date date [note: 'Planned date by which the wafer lot is expected to complete all FAB process steps and be ready for wafer probe/test. Derived from the process flow cycle time and lot start date. Used for delivery commitment and capacity planning.']
  updated_timestamp timestamp [note: 'Timestamp when this wafer lot master record was last modified in the inventory data product. Represents the RECORD_AUDIT_UPDATED category for this TRANSACTION_HEADER entity. Used for incremental data pipeline processing and audit trail.']
  valuation_currency varchar [note: 'ISO 4217 three-letter currency code for the inventory valuation amount (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.']
  wafer_count_current varchar [note: 'Current number of wafers remaining in the lot after accounting for any scrapped or split wafers during processing. Reflects real-time WIP inventory quantity for this lot.']
  wafer_count_start varchar [note: 'Number of wafers in the lot at the time of lot creation (wafer start). Typically 25 wafers per FOUP/cassette for standard lots. Used as the baseline denominator for yield and scrap rate calculations. This is the QUANTITATIVE_RESULT / principal measured quantity for this WIP transaction.']
  wafer_diameter_mm varchar [note: 'Physical diameter of the silicon wafers in this lot, in millimeters. Standard values are 200mm (8-inch) and 300mm (12-inch). Determines equipment compatibility, cassette type, and cost per wafer.']

  Note: 'Master record for a wafer lot (batch of wafers) moving through the FAB as work-in-process inventory. Tracks lot ID, wafer count, process node, product code, lot type (production/engineering/qualification), priority class, current operation step, WIP status (active/hold/complete/scrapped), start date, target completion date, hold flags, cumulative scrap count, good wafer count, and MES lot reference. SSOT for WIP lot identity and traceability across FEOL, MOL, and BEOL process stages within the inventory domain. References SSOT: fabrication.fabrication_wafer_lot'
}

Table inventory.raw_material {
  raw_material_id varchar [pk, note: 'Unique system-generated surrogate key identifying a raw material master record in the semiconductor inventory domain. Primary key for the raw_material product.']
  approved_vendor_id varchar [note: 'Foreign key linking to supply.approved_vendor. Business justification: Semiconductor fabs must source raw materials only from AVL-qualified vendors per IATF 16949 and customer-specific quality requirements. Linking raw_material to approved_vendor enforces AVL compliance ']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Raw material records must link to ERP material master for MRP-driven replenishment planning, procurement parameter governance (lead time, lot size, reorder point), and inventory valuation in semicondu']
  po_line_id varchar [note: 'Foreign key linking to supply.po_line. Business justification: Each raw material lot is procured against a specific PO line item. Linking raw_material to po_line enables 3-way match (PO line → goods receipt → invoice), partial delivery tracking, and supplier perf']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Raw materials (silicon wafers, process chemicals) in semiconductor fabs are qualified and allocated to specific process nodes. Material qualification tracking, process node yield analysis, and EOL pro']
  storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Raw materials need a default storage location for receiving and replenishment workflows.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: PROCUREMENT: Supplier of each raw material is required for qualification, lead‑time, and compliance tracking; experts expect a direct supplier_id FK.']
  base_unit_of_measure varchar [note: 'The primary unit of measure in which the raw material is stocked and consumed (e.g., EA for each wafer, KG for chemicals, L for liquids, M2 for photomasks). Corresponds to SAP MARA.MEINS (base unit of measure). [ENUM-REF-CANDIDATE: EA|KG|L|M2|M3|PC|SHT|BOX|DRUM|CYLINDER — 10 candidates stripped; promote to reference product]']
  batch_managed boolean [note: 'Indicates whether the raw material is managed at the batch/lot level in SAP inventory management. Batch management is mandatory for silicon wafers, photomasks, and shelf-life-controlled chemicals to enable full lot traceability from receipt through consumption. Corresponds to SAP MARA.XCHPF.']
  cas_number varchar [note: 'The unique CAS Registry Number assigned by the American Chemical Society to identify chemical substances. Mandatory for process chemicals, specialty gases, CMP slurries, and ALD precursors for REACH, RoHS, and TSCA regulatory compliance reporting.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the raw material was manufactured or substantially transformed. Required for export control compliance (EAR/ITAR), customs declarations, and CHIPS Act domestic content tracking.']
  created_timestamp timestamp [note: 'Timestamp when the raw material master record was first created in the system of record (SAP S/4HANA MM). Used for audit trail, data lineage, and compliance with SOX internal controls over financial reporting.']
  discontinuation_date date [note: 'Date on which the raw material is scheduled to be discontinued or reaches end-of-life (EOL). Triggers last-time-buy (LTB) procurement actions and product change notification (PCN) processes. Null if the material is not scheduled for discontinuation.']
  export_control_classification varchar [note: 'Export Control Classification Number (ECCN) assigned under the US Export Administration Regulations (EAR) for dual-use materials. Required for export license determination for specialty chemicals, gases, and advanced materials used in semiconductor manufacturing.']
  fixed_lot_qty decimal(18,4) [note: 'Fixed order quantity used when lot_size_type is \'fixed\'. Represents the standard purchase order quantity per replenishment cycle, often aligned with supplier minimum order quantities or packaging units. Corresponds to SAP MARC.BSTFE.']
  hazard_classification varchar [note: 'GHS/UN hazard classification of the raw material for safe storage, handling, and transport. Drives storage location assignment, PPE requirements, and emergency response procedures. [ENUM-REF-CANDIDATE: non_hazardous|flammable|corrosive|toxic|oxidizer|pyrophoric|compressed_gas|carcinogen — promote to reference product]']
  inspection_required boolean [note: 'Indicates whether incoming quality inspection (IQC) is mandatory upon goods receipt for this raw material. When true, received lots are placed in quality inspection stock in SAP QM before being released to unrestricted use. Corresponds to SAP MARC.QKZUL.']
  itar_controlled boolean [note: 'Indicates whether the raw material is subject to ITAR controls under the US Munitions List. ITAR-controlled materials require State Department licensing for export and impose strict access and handling restrictions.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent modification to the raw material master record. Supports change tracking, delta extraction for the Silver layer, and audit compliance. Corresponds to SAP MARA.LAEDA (last change date).']
  lead_time_days varchar [note: 'Planned procurement lead time in calendar days from purchase order placement to goods receipt. Used by SAP MRP for replenishment scheduling and safety stock calculations. Corresponds to SAP MARC.PLIFZ (planned delivery time).']
  lot_size_type varchar [note: 'SAP MRP lot-sizing procedure that determines how replenishment quantities are calculated. \'fixed\' orders a fixed quantity, \'lot_for_lot\' orders exact requirement, \'min_max\' uses min/max boundaries, \'periodic\' groups requirements by period. Corresponds to SAP MARC.DISMM.']
  manufacturer_part_number varchar [note: 'The original manufacturer\'s part number for the raw material, which may differ from the supplier part number when the supplier is a distributor. Critical for photomasks, specialty chemicals, and ALD precursors where manufacturer identity affects process qualification.']
  material_class varchar [note: 'High-level classification of the raw material type used in semiconductor manufacturing. Drives storage, handling, and compliance rules. [ENUM-REF-CANDIDATE: silicon_wafer|photomask|process_chemical|specialty_gas|cmp_slurry|ald_precursor|packaging_material|other — promote to reference product]']
  material_group varchar [note: 'SAP material group code (MARA.MATKL) used to categorize raw materials for procurement, reporting, and spend analytics. Examples: \'WAFER-SI\', \'CHEM-ETCH\', \'GAS-SPEC\', \'MASK-EUV\'.']
  material_status varchar [note: 'Current lifecycle status of the raw material master record. Controls whether the material can be procured, consumed in production, or is subject to end-of-life (EOL) restrictions. Aligns with SAP MARA.MMSTA (plant-level material status).']
  max_stock_qty decimal(18,4) [note: 'Maximum allowable inventory quantity for the raw material, used to prevent overstocking of hazardous materials, shelf-life-limited chemicals, or high-cost items. Corresponds to SAP MARC.MABST (maximum stock level).']
  min_remaining_shelf_life_days varchar [note: 'Minimum number of days of remaining shelf life required at the time of goods receipt for the material to be accepted into inventory. Materials received with less than this remaining shelf life are rejected or placed in restricted use. Corresponds to SAP MARA.MHDLP.']
  moving_avg_price decimal(18,4) [note: 'Current moving average price per base unit of measure, recalculated with each goods receipt based on actual purchase prices. Used for inventory valuation under the moving average price control method. Corresponds to SAP MBEW.VERPR.']
  price_control_type varchar [note: 'Determines the inventory valuation method for the material: \'standard\' uses a fixed standard price, \'moving_average\' recalculates price with each goods movement. Corresponds to SAP MBEW.VPRSV (price control indicator: S or V).']
  price_currency varchar [note: 'ISO 4217 three-letter currency code for the standard price and moving average price fields (e.g., USD, EUR, JPY, TWD). Required for multi-currency financial reporting and SOX compliance.']
  purity_pct decimal(8,6) [note: 'Chemical purity of the raw material expressed as a percentage (e.g., 99.9999 for 6N-grade specialty gases, 99.99 for ultra-high-purity chemicals). Critical quality specification for process chemicals, specialty gases, and ALD precursors where trace contamination causes yield loss.']
  qualification_status varchar [note: 'Process qualification status of the raw material indicating whether it has been approved for use in production. Materials must pass incoming quality inspection and process qualification before being released for fab consumption. Managed in Oracle Agile PLM and SAP QM.']
  reach_svhc_flag boolean [note: 'Indicates whether the raw material contains or is classified as a Substance of Very High Concern (SVHC) under the EU REACH Regulation. Triggers mandatory disclosure obligations when SVHC concentration exceeds 0.1% w/w in articles.']
  reorder_point_qty decimal(18,4) [note: 'Inventory level at which a replenishment purchase requisition is automatically triggered in SAP MRP. When on-hand stock falls to or below this quantity, procurement is initiated to prevent production line stoppages. Corresponds to SAP MARC.MINBE (reorder point).']
  resistivity_ohm_cm decimal(10,4) [note: 'Electrical resistivity of the silicon wafer substrate in Ohm·cm, indicating doping concentration and conductivity type. Critical specification for FEOL process compatibility and device electrical performance. Null for non-wafer materials.']
  rohs_compliant boolean [note: 'Indicates whether the raw material complies with the EU RoHS Directive (2011/65/EU) restricting the use of hazardous substances including lead, mercury, cadmium, hexavalent chromium, PBB, and PBDE. Required for materials used in products shipped to EU markets.']
  safety_stock_qty decimal(18,4) [note: 'Minimum buffer stock quantity maintained to protect against supply disruptions, demand variability, and supplier lead time uncertainty. Represents the floor below which inventory should not fall under normal operating conditions. Corresponds to SAP MARC.EISBE (safety stock).']
  serialized boolean [note: 'Indicates whether individual units of the raw material are tracked by unique serial number. Applicable to high-value items such as photomasks and reticles where individual unit traceability is required for defect root cause analysis and reticle qualification tracking.']
  shelf_life_days varchar [note: 'Maximum number of days the raw material can be stored from the date of manufacture or receipt before it is considered expired and must be quarantined or disposed of. Critical for photoresists, ALD precursors, and specialty chemicals with time-sensitive stability. Corresponds to SAP MARA.MHDRZ (shelf life in days).']
  standard_price decimal(18,4) [note: 'Standard cost price per base unit of measure used for inventory valuation in SAP CO (Controlling) and FI (Financial Accounting). Used for WIP costing, variance analysis, and financial reporting. Corresponds to SAP MBEW.STPRS (standard price).']
  storage_condition varchar [note: 'Categorical storage environment required for the raw material. Drives warehouse location assignment and storage area classification. Examples: cleanroom for bare silicon wafers, refrigerated for certain photoresists, nitrogen_purge for moisture-sensitive ALD precursors. [ENUM-REF-CANDIDATE: ambient|refrigerated|frozen|cleanroom|nitrogen_purge|dark_storage|fireproof_cabinet — 7 candidates stripped; promote to reference product]']
  storage_humidity_max_pct decimal(5,2) [note: 'Maximum allowable relative humidity percentage for storage of the raw material. Particularly critical for silicon wafers, photomasks, and hygroscopic chemicals where moisture exposure causes defects or degradation.']
  storage_temp_max_c decimal(6,2) [note: 'Maximum allowable storage temperature in degrees Celsius for the raw material. Exceeding this threshold may degrade material quality, trigger safety hazards, or invalidate process qualification. Used for warehouse environmental compliance monitoring.']
  storage_temp_min_c decimal(6,2) [note: 'Minimum allowable storage temperature in degrees Celsius for the raw material. Used to configure environmental monitoring alerts in the warehouse management system and ensure compliance with material safety data sheet (SDS) requirements.']
  supplier_part_number varchar [note: 'The part number or catalog number assigned by the primary supplier to this raw material. Used for purchase order creation, supplier communication, and incoming inspection cross-referencing. Stored in SAP INFO record (EINE.IDNLF).']
  wafer_diameter_mm decimal(6,2) [note: 'Nominal diameter of the silicon wafer in millimeters (e.g., 200.0 for 8-inch, 300.0 for 12-inch). Applicable only to silicon wafer material class. Critical for process tool compatibility and fab line qualification. Null for non-wafer materials.']
  wafer_type varchar [note: 'Specifies the silicon wafer substrate type: bare_silicon (polished CZ), epitaxial (epi-layer deposited), soi (Silicon-on-Insulator), fz (Float Zone), or cz (Czochralski). Determines process compatibility and electrical characteristics. Null for non-wafer materials.']

  Note: 'Master record for raw materials consumed in semiconductor manufacturing including silicon wafers (bare and epitaxial), process chemicals, specialty gases, photomasks, CMP slurries, and ALD precursors. Captures material code, description, material class, unit of measure, supplier part number, shelf life, storage temperature range, hazard classification (RoHS/REACH), reorder point, and safety stock level. SSOT for raw material identity in the inventory domain.'
}

Table inventory.finished_good {
  finished_good_id varchar [pk, note: 'Unique surrogate identifier for the finished good master record in the inventory system. Primary key for the finished_good data product.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Needed for Order Fulfillment process to associate shipped finished goods with the purchasing customer account for invoicing and compliance.']
  assembly_lot_id varchar [note: 'Foreign key linking to packaging.assembly_lot. Business justification: A finished good is produced from a specific assembly lot. Direct lot-level traceability is mandatory for semiconductor quality systems (AEC-Q100, IATF 16949) — enables date code verification, yield-to']
  assembly_order_id varchar [note: 'Foreign key linking to packaging.assembly_order. Business justification: A finished good is the output of an assembly order. This FK enables production-to-inventory traceability, cost roll-up from assembly order to finished good valuation, and supports customer shipment tr']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: A finished good (packaged chip) originates from KGD dies sourced from a die bank. This FK establishes the critical traceability chain from packaged finished good back to the die bank source, enabling ']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Linking finished goods to their design project supports warranty tracking and post‑sale support processes.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Finished ICs are managed as material master records in ERP for sales order processing, inventory valuation, export control classification, and BOM explosion. This link enables standard cost calculatio']
  osat_vendor_id varchar [note: 'Reference to the Outsourced Semiconductor Assembly and Test (OSAT) partner responsible for packaging and assembly of this finished good. Used for consignment stock tracking and supplier quality management.']
  package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: finished_good.package_type is a denormalized text field duplicating the package_type entity. A proper FK enables finished goods inventory reporting by package family, moisture sensitivity level, and t']
  storage_location_id varchar [note: 'Reference to the warehouse or distribution center where this finished good inventory is physically held, including OSAT consignment locations.']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Finished‑good traceability to the originating tapeout is needed for quality audits and regulatory compliance.']
  aec_q_qualified boolean [note: 'Indicates whether the finished good has been qualified to AEC-Q100 (IC), AEC-Q101 (discrete), or AEC-Q200 (passive) automotive reliability standards. Required for automotive supply chain design-in.']
  country_of_origin varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code indicating the country where the finished good was manufactured or substantially transformed. Required for customs declarations, trade compliance, and preferential tariff determination.']
  created_timestamp timestamp [note: 'Timestamp when the finished good master record was first created in the inventory system. Audit trail field for data governance and SOX compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the standard cost and inventory valuation of this finished good (e.g., \'USD\', \'EUR\', \'TWD\').']
  date_code varchar [note: 'Manufacturing date code in YYWW format (year + work week) indicating when the device was assembled and packaged. Used for shelf life tracking, lot traceability, and field failure analysis.']
  device_marking varchar [note: 'Alphanumeric marking laser-inscribed or printed on the physical package surface. Includes part number, speed grade, temperature grade, and manufacturer code. Used for traceability and counterfeit detection.']
  device_type varchar [note: 'Classification of the semiconductor device type. Indicates whether the finished good is an Integrated Circuit (IC), System on Chip (SoC), Application-Specific Integrated Circuit (ASIC), Field-Programmable Gate Array (FPGA), discrete device, or other category. [ENUM-REF-CANDIDATE: IC|SoC|ASIC|FPGA|Discrete|MCU|DSP|PMIC|Memory|RF|Sensor|Analog — promote to reference product]']
  dppm_target decimal(10,2) [note: 'Quality target expressed as Defective Parts Per Million (DPPM) for outgoing quality of this finished good. Used in customer quality agreements and SPC monitoring. Automotive-grade typically requires <10 DPPM.']
  eccn_number varchar [note: 'Export Control Classification Number (ECCN) assigned under the US Export Administration Regulations (EAR) administered by BIS. Determines export licensing requirements and restricted country applicability. Sensitive for trade compliance purposes.']
  eol_date date [note: 'Announced End of Life (EOL) date after which the finished good will no longer be manufactured or sold. Triggers Last Time Buy (LTB) notifications to customers per JEDEC JESD48 standard.']
  hts_code varchar [note: 'Harmonized Tariff Schedule (HTS) classification code used for customs declaration, import/export duty determination, and trade statistics reporting. Follows the 10-digit US HTS format.']
  inventory_status varchar [note: 'Current inventory disposition status of the finished good lot. \'available\' indicates unrestricted stock; \'quarantine\' indicates pending quality review; \'reserved\' indicates allocated to an order; \'consignment\' indicates stock held at OSAT or customer site; \'hold\' indicates engineering or compliance hold.']
  inventory_valuation_method varchar [note: 'Accounting method used to value this finished good inventory in the general ledger. \'standard\' = standard cost; \'moving_average\' = moving average price (MAP); \'fifo\' = First In First Out; \'lifo\' = Last In First Out.']
  itar_controlled boolean [note: 'Indicates whether the finished good is subject to International Traffic in Arms Regulations (ITAR) controls administered by the US State Department DDTC. ITAR-controlled items require specific export licenses and handling procedures.']
  kgd_status boolean [note: 'Indicates whether the die used in this finished good has been verified as a Known Good Die (KGD) through wafer-level testing prior to packaging. Critical for advanced packaging (CoWoS, InFO, chiplet) and high-reliability applications.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the finished good master record. Used for change data capture (CDC), data lineage tracking, and audit compliance.']
  lifecycle_status varchar [note: 'Commercial lifecycle stage of the finished good. \'active\' = in production and available; \'nrnd\' = Not Recommended for New Designs; \'eol\' = End of Life (EOL) announced; \'ltb\' = Last Time Buy (LTB) window open; \'discontinued\' = no longer available.']
  msd_level varchar [note: 'Moisture Sensitivity Level (MSL) classification per IPC/JEDEC J-STD-020 indicating the device\'s sensitivity to ambient moisture during storage and handling. Level 1 = unlimited floor life; Level 6 = must be baked immediately before use. [ENUM-REF-CANDIDATE: 1|2|2a|3|4|5|5a|6 — 8 candidates stripped; promote to reference product]']
  package_body_size_mm varchar [note: 'Physical body dimensions of the semiconductor package expressed as length x width in millimeters (e.g., \'10x10\', \'5.5x5.5\'). Used for PCB design, handling equipment setup, and storage tray selection.']
  pcn_reference varchar [note: 'Reference number of the most recent Product Change Notification (PCN) affecting this finished good. PCNs document changes to materials, processes, or package that may impact customer qualification status.']
  pin_count varchar [note: 'Total number of electrical pins, balls, or leads on the finished good package. Critical for PCB design compatibility, socket selection, and ATE (Automatic Test Equipment) configuration.']
  qualification_status varchar [note: 'Current product qualification status indicating whether the finished good has passed all required reliability and quality qualification tests for its target market segment (consumer, industrial, automotive, military).']
  quantity_on_hand varchar [note: 'Current physical inventory quantity of this finished good in units (individual packaged devices). Reflects unrestricted stock available for order fulfillment as tracked in SAP MM inventory management.']
  reach_compliant boolean [note: 'Indicates whether the finished good complies with EU REACH Regulation (EC No 1907/2006) regarding chemical substance safety, including absence of Substances of Very High Concern (SVHC) above threshold concentrations.']
  rohs_compliant boolean [note: 'Indicates whether the finished good complies with the EU RoHS Directive (2011/65/EU) restricting use of hazardous substances including lead, mercury, cadmium, and hexavalent chromium in electronic equipment.']
  shelf_life_days varchar [note: 'Maximum allowable storage duration in days from the manufacturing date before the finished good must be baked, re-qualified, or scrapped. Particularly relevant for moisture-sensitive devices (MSD) per IPC/JEDEC J-STD-033.']
  shelf_life_expiry_date date [note: 'Calculated date on which the shelf life of this finished good lot expires, derived from the manufacturing date code plus shelf life days. Triggers re-bake or scrap workflow in SAP MM.']
  speed_grade varchar [note: 'Performance speed grade or frequency bin classification of the finished good (e.g., \'-1\', \'-2\', \'3.0GHz\', \'800MHz\'). Determined during wafer sort and final test binning. Differentiates product variants within the same die.']
  standard_cost decimal(18,6) [note: 'Standard cost per unit of the finished good in the functional currency as maintained in SAP CO (Controlling) for inventory valuation, cost of goods sold calculation, and variance analysis.']
  storage_temperature_max_c decimal(5,2) [note: 'Maximum allowable storage temperature in degrees Celsius for this finished good. Exceeding this threshold may degrade device reliability or void qualification. Used to configure warehouse environmental monitoring alerts.']
  temperature_grade varchar [note: 'Operating temperature range classification of the finished good. \'commercial\' (0°C to 70°C), \'industrial\' (-40°C to 85°C), \'automotive\' (-40°C to 125°C/150°C per AEC-Q100), \'military\' (-55°C to 125°C), \'extended\' for specialized ranges.']
  unit_of_measure varchar [note: 'Base unit of measure for inventory counting of the finished good. \'EA\' = each (individual device); \'TRAY\' = JEDEC tray; \'REEL\' = tape-and-reel; \'TUBE\' = tube/stick packaging; \'BOX\' = bulk box.']

  Note: 'Master record for packaged semiconductor finished goods held in inventory including ICs, SoCs, ASICs, FPGAs, and discrete devices in final package form. Tracks SKU, product family, package type (WLCSP, BGA, QFN, CoWoS), device marking, date code, lot traceability code, HTS classification, RoHS compliance status, ECCN number for export control, and shelf life. Links to product domain SKU catalog.'
}

Table inventory.die_bank {
  die_bank_id varchar [pk, note: 'Unique system-generated surrogate identifier for the die bank inventory record. Primary key for the die_bank data product.']
  consignment_account_id varchar [note: 'Foreign key linking to customer.account. Business justification: KGD die banks held on consignment for advanced packaging customers must be tracked against the owning customer account. is_consignment flag on die_bank confirms this business scenario. Enables custome']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Die‑bank inventory is tracked per design project for yield analysis and customer yield reporting.']
  inventory_wafer_lot_id varchar [note: 'FK to inventory.wafer_lot.wafer_lot_id — Die banks originate from wafer lots after singulation. This traceability link is required for IATF 16949 compliance and customer complaint root cause analysis.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: KGD inventory in die banks is managed as material master records for consignment tracking, inventory valuation, and customer-specific KGD programs. This link enables KGD inventory valuation, MRP visib']
  osat_vendor_id varchar [note: 'Reference to the OSAT partner at whose facility this die bank is held as consignment stock, if applicable. Null if stored at internal warehouse.']
  primary_storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Die banks are stored at specific locations (cleanroom storage, cold storage). Location tracking is critical for environmental compliance and retrieval.']
  probe_card_id varchar [note: 'Identifier of the probe card used during wafer sort for the parent wafer lot. Enables correlation of test results to probe card condition and supports yield excursion root cause analysis.']
  source_wafer_id varchar [note: 'Foreign key linking to fabrication.wafer. Business justification: KGD (Known Good Die) traceability requires linking die bank inventory to the specific source wafer for genealogy reports, reliability screening, and customer quality documentation. Role prefix \'source']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Die bank inventory must be traceable to the exact tapeout for wafer probe yield analysis, PCN (Product Change Notice) tracking, and customer design win fulfillment. Inventory planners and yield engine']
  wafer_probe_run_id varchar [note: 'Foreign key linking to test.wafer_probe_run. Business justification: KGD traceability: die_bank is populated directly from wafer probe results. Linking to the specific wafer_probe_run that qualified the die enables KGD certification, yield analysis, and customer qualit']
  carrier_type varchar [note: 'Physical carrier medium in which the singulated dies are stored (e.g., waffle pack, gel pack, tape-and-reel, JEDEC tray). Determines handling requirements, automated pick-and-place compatibility, and storage density.']
  code varchar [note: 'Human-readable, externally-known unique business identifier for the die bank lot, used in MES, ERP, and OSAT partner communications. Follows internal lot numbering conventions.']
  created_timestamp timestamp [note: 'System timestamp when this die bank record was first created in the data platform. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the unit cost and inventory valuation of this die bank (e.g., USD, EUR, JPY).']
  die_bank_status varchar [note: 'Current lifecycle status of the die bank inventory record. \'Available\' indicates dies are ready for allocation; \'Reserved\' indicates committed to an order; \'Consumed\' indicates fully used in packaging; \'Quarantined\' indicates hold pending quality investigation; \'Scrapped\' indicates disposed; \'Expired\' indicates shelf life exceeded.']
  die_revision varchar [note: 'Silicon revision or stepping identifier for the die (e.g., A0, B1, C2). Tracks design iterations post-tapeout; critical for distinguishing engineering samples from production silicon.']
  die_size_mm2 decimal(10,4) [note: 'Physical area of a single die in square millimeters. Critical for packaging selection, cost-per-die calculations, and wafer yield modeling.']
  esd_sensitivity_class varchar [note: 'JEDEC Human Body Model (HBM) or Charged Device Model (CDM) ESD sensitivity classification for the dies. Determines handling precautions, packaging requirements, and ESD-protected area (EPA) storage mandates.']
  expiry_date date [note: 'Calculated date on which the die bank shelf life expires, based on creation date plus shelf_life_days under specified storage conditions. After this date, dies require re-qualification before use.']
  export_control_classification varchar [note: 'Export Administration Regulations (EAR) Export Control Classification Number (ECCN) assigned to this die product. Determines export license requirements and restricted country applicability under BIS/EAR and ITAR.']
  inventory_valuation_method varchar [note: 'Accounting method used to value this die bank inventory in the ERP system (e.g., Standard Cost, Moving Average Price, FIFO, LIFO). Determines how cost of goods sold is calculated upon consumption.']
  is_consignment boolean [note: 'Indicates whether this die bank is held as consignment stock at an OSAT partner or customer site (True) versus owned and stored at an internal facility (False). Affects inventory ownership, liability, and financial reporting.']
  is_engineering_sample boolean [note: 'Indicates whether the dies in this bank are engineering samples (True) or production-qualified silicon (False). Engineering samples may have restricted use, limited warranty, and different pricing terms.']
  kgd_status varchar [note: 'Known Good Die (KGD) certification status indicating whether the dies in this bank have passed all required electrical and functional tests and are certified for packaging or direct shipment. Certified dies meet full production test specifications.']
  last_inspection_date date [note: 'Date of the most recent physical or visual inspection of the die bank, including carrier integrity check, quantity verification, and storage condition audit. Required for periodic quality surveillance.']
  moisture_sensitivity_level varchar [note: 'JEDEC/IPC Moisture Sensitivity Level classification for the dies, indicating how sensitive the package or die is to ambient moisture and the required floor life before reflow. Governs dry-pack and bake-out requirements.']
  quality_hold_reason varchar [note: 'Free-text or coded reason for placing this die bank on quality hold or quarantine status. Populated when die_bank_status is \'quarantined\'. Examples: parametric excursion, contamination event, ESD damage suspected.']
  quantity_available varchar [note: 'Current count of dies available for allocation or shipment in this die bank record. Decremented upon reservation or consumption. Expressed in units of individual dies.']
  quantity_initial varchar [note: 'Original count of dies placed into this die bank at the time of creation, before any consumption, scrap, or reservation. Used as the baseline for yield and consumption tracking.']
  quantity_reserved varchar [note: 'Count of dies in this die bank that are currently reserved against open orders or packaging work orders but not yet physically consumed. Supports ATP (Available-to-Promise) calculations.']
  quantity_scrapped varchar [note: 'Cumulative count of dies from this die bank that have been scrapped due to handling damage, quality failures, or shelf life expiry. Used for loss tracking and yield analysis.']
  reach_compliant boolean [note: 'Indicates whether the die and carrier materials comply with EU REACH Regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals), confirming no SVHC (Substances of Very High Concern) above threshold.']
  rohs_compliant boolean [note: 'Indicates whether the dies and their carrier materials comply with the EU RoHS Directive (Restriction of Hazardous Substances), restricting lead, mercury, cadmium, and other hazardous materials. Required for EU market access.']
  shelf_life_days varchar [note: 'Maximum number of days the dies can be stored under specified conditions before they are considered expired and require re-qualification or scrap. Drives FEFO (First Expired First Out) inventory rotation.']
  storage_humidity_max_pct decimal(5,2) [note: 'Maximum allowable relative humidity percentage for storage of this die bank. Moisture-sensitive dies require controlled humidity to prevent MSL (Moisture Sensitivity Level) violations.']
  storage_temperature_max_c decimal(6,2) [note: 'Maximum allowable storage temperature in degrees Celsius for this die bank. Exceeding this limit risks solder bump oxidation, adhesive degradation, or ESD damage.']
  storage_temperature_min_c decimal(6,2) [note: 'Minimum allowable storage temperature in degrees Celsius for this die bank. Violations may cause electrostatic or material degradation. Enforced by warehouse management system.']
  unit_cost decimal(18,6) [note: 'Standard or moving average cost per individual die in the die bank, expressed in the functional currency. Used for inventory valuation, cost of goods sold, and transfer pricing to OSAT partners.']
  updated_timestamp timestamp [note: 'System timestamp of the most recent update to this die bank record in the data platform. Used for change tracking, incremental ETL, and audit compliance.']
  creation_date date [note: 'Business date on which this die bank record was created, representing when the singulated dies were formally received into die bank inventory following wafer dicing and initial inspection.']

  Note: 'Master record for die bank inventory — singulated known-good dies (KGD) stored in waffle packs, gel packs, or tape-and-reel awaiting packaging or direct shipment. Tracks die bank ID, product code, process node, die revision, KGD certification status, bin classification, quantity available, storage location, storage temperature, wafer lot origin, tapeout version, and die bank creation date. Critical for fabless and OSAT-model inventory management.'
}

Table inventory.storage_location {
  storage_location_id varchar [pk, note: 'Unique surrogate identifier for the storage location master record within the inventory management system. Primary key for the storage_location entity.']
  osat_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: storage_location has is_osat_partner_location and osat_partner_name (denormalized). Linking storage_location to supplier enables proper supplier-managed inventory (SMI) and consignment stock managemen']
  access_restriction_level varchar [note: 'Physical access control level for this storage location. unrestricted — open access; badge-access — requires valid facility badge; authorized-personnel — restricted to named personnel list (e.g., for ITAR-controlled materials); security-vault — highest security for KGD die banks, photomask vaults, and ITAR-controlled IP. Supports ITAR/EAR export control compliance.']
  bay varchar [note: 'Bay designation within the building or cleanroom where this storage location is physically situated (e.g., \'BAY-03\', \'A-WEST\'). Used for precise physical navigation, equipment layout planning, and cleanroom zone management per SEMI E187.']
  building_code varchar [note: 'Identifier for the physical building within the facility where this storage location resides (e.g., \'FAB1\', \'CHEM-WH-B\', \'OSAT-PKG-C\'). Supports facility layout mapping, emergency response planning, and environmental zone management.']
  capacity_unit_of_measure varchar [note: 'Unit of measure used to express the maximum capacity and current utilization of this storage location. Varies by facility type: cassette (wafer storage), pod (photomask storage), tray (packaged chip storage), container (chemical storage), box (die bank storage), pallet (bulk warehouse storage).']
  cleanroom_iso_class varchar [note: 'ISO 14644-1 cleanroom classification for this storage location, defining the maximum allowable airborne particulate concentration. Critical for wafer, photomask, and KGD die storage compliance. Applicable only to cleanroom facility types; null for non-cleanroom locations. Values: ISO-1 (cleanest) through ISO-6.']
  commissioned_date date [note: 'Date on which this storage location was formally commissioned and made available for inventory use. Marks the start of the location\'s operational lifecycle. Used for asset age tracking, depreciation scheduling, and facility capacity planning.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code of the country where this storage location is physically situated (e.g., \'USA\', \'TWN\', \'KOR\', \'JPN\'). Critical for ITAR/EAR export control jurisdiction determination, REACH/RoHS regulatory applicability, and multi-national inventory reporting.']
  created_timestamp timestamp [note: 'Timestamp when this storage location master record was first created in the system (ISO 8601 format: yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for record provenance and data governance compliance per SOX and ISO 9001 quality management requirements.']
  current_utilization_units varchar [note: 'Current number of inventory units occupying this storage location at the time of last inventory update. Compared against max_capacity_units to compute utilization percentage for capacity planning and inventory placement decisions. Updated by MES and SAP MM inventory movements.']
  decommissioned_date date [note: 'Date on which this storage location was permanently decommissioned and removed from active inventory use. Populated only when location_status is \'decommissioned\'. Supports facility lifecycle management and historical inventory traceability.']
  esd_protection_class varchar [note: 'ESD protection classification of this storage location per ANSI/ESD S20.20 and JEDEC JESD625 standards. Determines suitability for storing ESD-sensitive devices (ICs, dies, packaged chips). class-0 (most sensitive, <250V HBM) through class-3 (>2000V HBM); unprotected for non-ESD-controlled areas.']
  facility_type varchar [note: 'Classification of the physical facility type housing this storage location. Drives environmental compliance rules, MSD floor life management, and hazmat handling procedures. Valid values: cleanroom (ISO-classified FAB area), warehouse (general materials storage), cold-storage (temperature-controlled for chemicals/biologics), gas-cabinet (pressurized specialty gas storage), nitrogen-cabinet (nitrogen-purged dry storage for moisture-sensitive devices), die-vault (secure KGD die bank storage).']
  fire_suppression_type varchar [note: 'Type of fire suppression system installed at this storage location. Critical for chemical warehouse and gas cabinet locations storing flammable or reactive materials. Drives emergency response planning and insurance compliance. Values: sprinkler, halon (legacy), fm200 (clean agent), co2, dry-powder, none.']
  geo_latitude decimal(9,6) [note: 'Geographic latitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used for multi-site supply chain mapping, emergency response planning, and regulatory jurisdiction determination for ITAR/EAR export control compliance.']
  geo_longitude decimal(9,6) [note: 'Geographic longitude coordinate (WGS84 decimal degrees) of the facility where this storage location resides. Used in conjunction with geo_latitude for multi-site supply chain mapping and regulatory jurisdiction determination.']
  hazmat_classification varchar [note: 'UN/DOT hazardous materials classification code applicable to materials stored at this location (e.g., \'UN1170\' for ethanol, \'UN2014\' for hydrogen peroxide, \'FLAMMABLE-LIQUID\', \'CORROSIVE\', \'COMPRESSED-GAS\', \'NON-HAZMAT\'). Governs storage segregation, emergency response, and regulatory reporting under REACH, RoHS, and TSCA. [ENUM-REF-CANDIDATE: flammable-liquid|corrosive|compressed-gas|oxidizer|toxic|non-hazmat|pyrophoric — promote to reference product]']
  inventory_valuation_method varchar [note: 'Inventory valuation method applied to stock held at this storage location for financial reporting purposes. standard-cost (used for WIP wafer lots), moving-average (raw materials), fifo (finished goods), fefo (shelf-life-managed chemicals). Aligns with SAP S/4HANA FI/CO valuation area configuration and SOX financial reporting requirements.']
  is_osat_partner_location boolean [note: 'Indicates whether this storage location is physically situated at an OSAT (Outsourced Semiconductor Assembly and Test) partner facility rather than an internal company site. True for consignment stock locations at OSAT partners. Drives consignment inventory valuation, ownership tracking, and inter-company transfer accounting.']
  itar_controlled boolean [note: 'Indicates whether this storage location is designated for ITAR-controlled materials, requiring strict access logging, personnel authorization, and regulatory reporting. True for locations storing defense-related ICs, ASIC designs, or photomasks subject to ITAR jurisdiction. Drives export control compliance workflows.']
  kgd_storage_certified boolean [note: 'Indicates whether this storage location is certified for KGD (Known Good Die) die bank storage, meeting requirements for ESD protection, nitrogen purge, temperature/humidity control, and access security. KGD storage certification is required for high-value tested dies awaiting packaging or shipment.']
  last_inspection_date date [note: 'Date of the most recent environmental and safety inspection conducted for this storage location. Used to track compliance with SEMI S2, ISO 14001, and ISO 45001 periodic inspection requirements. Drives inspection scheduling and regulatory audit readiness.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent modification to this storage location master record (ISO 8601 format: yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture (CDC), data synchronization between SAP S/4HANA and the Databricks Silver Layer, and audit trail maintenance.']
  location_code varchar [note: 'Externally-known alphanumeric code uniquely identifying the storage location, aligned with SAP S/4HANA MM storage location key (LGORT) and Camstar MES location identifiers. Used for lot traceability, WIP tracking, and inventory placement across FAB, warehouse, and OSAT partner facilities.']
  location_name varchar [note: 'Human-readable descriptive name of the storage location (e.g., \'Bay 3 Shelf 12 — EUV Photomask Vault\', \'Cleanroom A Chemical Cabinet Row 5\'). Used in operational reports, MES screens, and inventory placement instructions.']
  location_status varchar [note: 'Current operational lifecycle status of the storage location. \'active\' — available for inventory placement; \'blocked\' — temporarily unavailable due to maintenance, contamination, or audit hold; \'decommissioned\' — permanently retired from use. Controls whether new inventory can be assigned to this location.']
  max_capacity_units varchar [note: 'Maximum number of inventory units (wafer cassettes, chemical containers, photomask pods, chip trays, or die boxes) that can be physically stored at this location. Used for capacity planning, inventory placement optimization, and utilization reporting.']
  max_humidity_pct decimal(5,2) [note: 'Maximum allowable relative humidity percentage (0–100%) for this storage location. Exceedance above maximum triggers MSD floor life reset, inventory quarantine, and environmental non-conformance reporting per IPC/JEDEC J-STD-033.']
  max_temperature_c decimal(6,2) [note: 'Maximum allowable storage temperature in degrees Celsius for this location. Defines the upper bound of the acceptable temperature range. Exceedance triggers inventory quarantine and environmental non-conformance reporting per ISO 14001 and SEMI C10 chemical storage guidelines.']
  min_humidity_pct decimal(5,2) [note: 'Minimum allowable relative humidity percentage (0–100%) for this storage location. Critical for MSD floor life management, photomask storage, and chemical stability. Exceedance below minimum may cause ESD risk or material degradation.']
  min_temperature_c decimal(6,2) [note: 'Minimum allowable storage temperature in degrees Celsius for this location. Defines the lower bound of the acceptable temperature range for stored materials (chemicals, photoresists, gases, packaged devices). Used for environmental compliance monitoring and MSD (Moisture Sensitive Device) floor life management per IPC/JEDEC J-STD-033.']
  msd_floor_life_capable boolean [note: 'Indicates whether this storage location is equipped and certified to manage MSD floor life tracking per IPC/JEDEC J-STD-033. True for nitrogen-purged cabinets, dry-storage cabinets, and controlled-humidity cleanroom locations. Enables automatic floor life clock suspension for stored MSDs.']
  msd_sensitivity_level varchar [note: 'Maximum Moisture Sensitivity Level (MSL) of devices that can be safely stored at this location per IPC/JEDEC J-STD-020. MSL-1 (unlimited floor life at ≤30°C/85%RH) through MSL-5 (most sensitive, 24-hour floor life). Determines which packaged semiconductor devices are eligible for placement at this location.']
  next_inspection_due_date date [note: 'Scheduled date for the next mandatory environmental and safety inspection of this storage location. Automatically calculated based on inspection frequency requirements per SEMI S2 and ISO 14001. Triggers inspection work orders in the facility management system.']
  nitrogen_purge_capable boolean [note: 'Indicates whether this storage location is equipped with nitrogen purge capability to maintain an inert, moisture-free atmosphere. True for nitrogen-cabinet and die-vault locations used for long-term KGD die storage, photomask preservation, and moisture-sensitive chemical storage. Drives MSD floor life management decisions.']
  photomask_storage_capable boolean [note: 'Indicates whether this storage location meets the environmental and cleanliness requirements for photomask (reticle) storage, including ISO cleanroom class, nitrogen purge, and ESD protection. Photomasks are high-value assets used in EUV/DUV lithography and require specialized storage conditions.']
  plant_code varchar [note: 'SAP S/4HANA plant identifier to which this storage location belongs. Represents the manufacturing or distribution facility (FAB, OSAT partner site, or warehouse) in the enterprise organizational hierarchy. Enables multi-plant inventory management and inter-plant transfer tracking.']
  row varchar [note: 'Row designation within the bay for this storage location (e.g., \'R-12\', \'ROW-A\'). Provides granular physical addressing for inventory placement, pick-and-put-away operations, and automated storage/retrieval system (ASRS) integration.']
  shelf varchar [note: 'Shelf or bin designation within the row for this storage location (e.g., \'S-04\', \'BIN-002\'). Lowest level of the physical location hierarchy, enabling precise inventory placement and retrieval for wafer cassettes, chemical containers, photomasks, and packaged chip trays.']
  shelf_life_tracking_enabled boolean [note: 'Indicates whether shelf life expiry tracking is enabled for materials stored at this location. True for chemical storage, photoresist storage, and gas cabinet locations where materials have defined shelf lives. Enables automated expiry alerts and FEFO (First Expired First Out) inventory management.']
  weight_capacity_kg decimal(10,3) [note: 'Maximum allowable total weight in kilograms for materials stored at this location. Critical for shelf structural integrity compliance, particularly for heavy chemical drums, gas cylinders, and bulk wafer cassette storage. Enforced per facility safety standards.']
  wip_staging_area boolean [note: 'Indicates whether this storage location is designated as a WIP (Work in Process) staging area for wafer lots between process steps. True for inter-bay buffers, equipment load ports, and process queue areas within the FAB cleanroom. Enables WIP flow tracking and cycle time analysis in the MES.']

  Note: 'Master record for physical and logical storage locations within FAB cleanrooms, chemical warehouses, gas cabinets, die bank vaults, and OSAT partner facilities. Captures location code, location name, facility type (cleanroom/warehouse/cold-storage/gas-cabinet/nitrogen-cabinet/die-vault), building, bay, row, shelf, temperature range, humidity range, ESD protection class, nitrogen purge capability, hazmat classification, maximum capacity, current utilization, and location status (active/blocked/decommissioned). Enables precise inventory placement, environmental compliance tracking, and MSD floor life management.'
}

Table inventory.stock_balance {
  stock_balance_id varchar [pk, note: 'Unique surrogate identifier for each stock balance snapshot record in the inventory management system. Primary key for the stock_balance data product.']
  consignment_account_id varchar [note: 'Foreign key linking to customer.account. Business justification: Semiconductor consignment programs hold finished inventory at customer sites tracked against a specific account. This FK replaces the denormalized consignment_partner_code text field, enabling consign']
  consignment_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: stock_balance has consignment_partner_code (denormalized). In semiconductor consignment programs, stock balances for consignment stock are owned by a specific supplier. This link enables consignment s']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: stock_balance tracks on-hand inventory quantities by material. Die bank inventory (KGD dies in waffle packs) is a distinct inventory category in semiconductor manufacturing that requires quantity trac']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: stock_balance tracks on-hand inventory quantities by material. It currently links to raw_material and inventory_wafer_lot but has no FK to finished_good. Finished goods inventory (packaged chips) is a']
  goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: In SAP-style ERP (standard in semiconductor fabs), every goods receipt posts a stock balance update. Linking stock_balance to goods_receipt enables reconciliation of received quantities against on-han']
  inbound_shipment_id varchar [note: 'Foreign key linking to supply.inbound_shipment. Business justification: stock_balance tracks qty_in_transit as a stock type. Linking stock_balance to inbound_shipment enables real-time in-transit stock reconciliation, allowing supply chain planners to include pipeline inv']
  inventory_wafer_lot_id varchar [note: 'Reference to the specific production or procurement lot associated with this stock balance record. Enables full lot traceability from raw silicon wafer through WIP to finished packaged chip, as required by IATF 16949 and JEDEC traceability standards.']
  po_line_id varchar [note: 'Foreign key linking to supply.po_line. Business justification: Stock balances can be traced to specific PO lines for partial delivery tracking and line-level stock posting reconciliation. In semiconductor ERP, this link enables 3-way match at the stock balance le']
  primary_stock_material_master_id varchar [note: 'Reference to the material master record representing the specific semiconductor material, component, or product (e.g., silicon wafer, photomask, packaged IC, chemical) for which this stock balance is recorded.']
  primary_stock_raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: raw_material is a master for raw materials; linking stock_balance to raw_material via raw_material_id replaces generic material_master references and enables direct lookup of raw material attributes.']
  primary_storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Stock balance is always held AT a specific storage location. This is a fundamental dimension of inventory position — you cannot have a meaningful stock balance without knowing WHERE the stock is. Day-']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: INVENTORY RECEIPT: Stock balance must be tied to the PO that supplied the material for traceability and financial reconciliation.']
  reserved_order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Stock balance records track qty_reserved against specific demand. Linking to order_line enables reserved-stock-to-order-line reconciliation for supply planning and allocation management. Semiconductor']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Stock balance tracks available-to-promise (ATP) and inventory valuation per orderable unit. Semiconductor operations require stock balance by SKU for order fulfillment, export control compliance, and ']
  source_raw_material_id varchar [note: 'FK to inventory.raw_material.raw_material_id — Stock balance for raw materials must reference the raw_material master record. This is the core master-transaction relationship for material inventory visibility.']
  spare_part_id varchar [note: 'Foreign key linking to equipment.spare_part. Business justification: stock_balance tracks on-hand quantities of all stocked items including spare parts. Spare part inventory management (reorder triggers, safety stock monitoring, cycle counts) requires stock_balance rec']
  batch_classification varchar [note: 'Quality grade classification of the wafer or material batch. \'prime\' = meets all specifications for production; \'test\' = test wafers used for process qualification; \'engineering\' = engineering samples not for production; \'monitor\' = process monitor wafers; \'reject\' = failed quality inspection and not usable.']
  bin_classification varchar [note: 'Die or wafer bin classification code assigned during wafer sort or final test, indicating the performance grade or speed bin of the die (e.g., \'BIN1_HIGH_PERF\', \'BIN2_STD\', \'BIN3_LOW_SPEED\', \'REJECT\'). Used for die bank management, customer order fulfillment by grade, and yield analysis. [ENUM-REF-CANDIDATE: promote to reference product as bin classifications vary by product family]']
  export_control_flag boolean [note: 'Indicates whether this material is subject to export control regulations (True), including ITAR (International Traffic in Arms Regulations) or EAR (Export Administration Regulations) administered by BIS. Export-controlled inventory requires additional authorization before transfer to foreign nationals or shipment to controlled countries.']
  hazmat_flag boolean [note: 'Indicates whether this material is classified as hazardous (True) under applicable regulations (OSHA HazCom, REACH, TSCA, or DOT). Hazardous materials include certain process chemicals, gases (e.g., arsine, phosphine), and solvents used in semiconductor fabrication. Triggers special storage, handling, and disposal requirements.']
  kgd_status varchar [note: 'Indicates the Known Good Die (KGD) qualification status for die bank inventory. \'known_good\' = die has passed all electrical and functional tests; \'failed\' = die has failed one or more tests; \'untested\' = die has not yet been tested; \'conditionally_good\' = die passed with minor deviations within specification limits. Applicable only to die bank material types.']
  last_goods_issue_date date [note: 'Date of the most recent goods issue (GI) posting for this material from this storage location. Used to identify dormant inventory, assess consumption velocity, and support slow-moving inventory analysis.']
  last_goods_receipt_date date [note: 'Date of the most recent goods receipt (GR) posting for this material at this storage location. Used to calculate stock aging, assess replenishment lead times, and support FIFO/FEFO inventory consumption sequencing.']
  last_physical_count_date date [note: 'Date of the most recent physical inventory count or cycle count performed for this material at this storage location. Used to assess inventory accuracy, schedule next count, and support SOX financial reporting requirements for inventory valuation.']
  lot_number varchar [note: 'The human-readable lot or batch identifier assigned by the MES (Camstar or Applied Materials SmartFactory) for WIP wafer lots, or by the ERP for raw material and finished goods batches. Critical for traceability, yield analysis, and IATF 16949 compliance.']
  msd_level varchar [note: 'Moisture Sensitivity Level (MSL) classification per IPC/JEDEC J-STD-020 for packaged semiconductor devices and components. Determines floor life limits and baking requirements before reflow soldering. Applicable to finished goods and packaging inventory. [ENUM-REF-CANDIDATE: 1|2|2a|3|4|5|5a|6 — 8 candidates stripped; promote to reference product]']
  qty_available decimal(18,6) [note: 'Quantity of unrestricted stock that is not committed to any open reservation or production order. Represents the net available quantity for Available-to-Promise (ATP) calculations and new production planning decisions. Computed as unrestricted stock minus open reservations.']
  qty_blocked decimal(18,6) [note: 'Quantity of material placed in blocked stock due to quality rejection, ITAR/EAR export control restrictions, supplier non-conformance, or regulatory hold. Blocked stock is not available for production or shipment until formally released.']
  qty_in_transit decimal(18,6) [note: 'Quantity of material that has been shipped from a source location but has not yet been received at the destination location. Includes inter-plant transfers, OSAT shipments, and inbound supplier deliveries in transit.']
  qty_in_wip decimal(18,6) [note: 'Quantity of material currently consumed into active production orders and undergoing fabrication processing (e.g., wafer lots in FEOL/BEOL processing, die in packaging). Tracked by the MES and reflected in SAP PP WIP accounts.']
  qty_on_hand decimal(18,6) [note: 'Total physical quantity of the material present at the storage location across all stock types, expressed in the base unit of measure. Represents the gross inventory position before reservations or quality holds are considered.']
  qty_quality_inspection decimal(18,6) [note: 'Quantity of material currently held in SAP QM quality inspection stock, pending disposition decision (accept, reject, rework). Includes incoming inspection lots, in-process inspection holds, and post-process quality holds.']
  qty_reserved decimal(18,6) [note: 'Total quantity committed to active inventory reservations linked to open production orders, sales orders, or transfer orders. Corresponds to open inventory_reservation records and reduces the available quantity for new demand.']
  record_created_timestamp timestamp [note: 'Timestamp when this stock balance record was first created in the lakehouse silver layer. Supports audit trail requirements for SOX financial reporting and data governance lineage tracking.']
  record_updated_timestamp timestamp [note: 'Timestamp when this stock balance record was last updated in the lakehouse silver layer, reflecting the most recent refresh from the source system. Used for incremental load processing and data freshness monitoring.']
  reorder_point_qty decimal(18,6) [note: 'The minimum on-hand quantity threshold at which a replenishment order should be triggered for this material at this storage location. Maintained in SAP MRP parameters and used by production planning to prevent stockouts of critical raw materials, chemicals, and gases.']
  rohs_compliant_flag boolean [note: 'Indicates whether this material lot is compliant with the EU RoHS Directive (Restriction of Hazardous Substances), restricting the use of lead, mercury, cadmium, hexavalent chromium, PBB, and PBDE. Required for finished goods destined for EU markets and tracked per Oracle Agile PLM compliance records.']
  safety_stock_qty decimal(18,6) [note: 'Buffer stock quantity maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Defined in SAP MRP safety stock parameters. Critical for high-value materials like EUV photomasks and specialty process gases with long procurement lead times.']
  shelf_life_expiry_date date [note: 'Date on which the material\'s shelf life expires and it becomes unusable for production. Applicable to chemicals, photoresists, gases, and certain packaging materials. Enforced by SAP batch management shelf-life expiration date (SLED) functionality. Materials past this date must be quarantined and disposed per REACH and RoHS regulations.']
  slow_moving_flag boolean [note: 'Indicates whether this stock balance has been flagged as slow-moving (True) based on the stock_aging_days exceeding the material-specific slow-moving threshold. Used for inventory write-down risk assessment, EOL (End of Life) planning, and LTB (Last Time Buy) decision support.']
  snapshot_timestamp timestamp [note: 'The principal business event timestamp indicating when this stock balance snapshot was captured from the source system (SAP MM or MES). Represents the point-in-time inventory position and is the primary temporal key for real-time inventory visibility and ATP calculations.']
  source_system_code varchar [note: 'Identifies the operational system of record from which this stock balance record was sourced. Enables data lineage tracking and reconciliation across SAP MM, Camstar MES, Applied Materials SmartFactory MES, and Oracle Agile PLM in the lakehouse silver layer.']
  special_stock_indicator varchar [note: 'SAP special stock indicator identifying non-standard stock ownership or custody arrangements. \'E\' = sales order stock; \'K\' = consignment stock at customer; \'Q\' = project stock; \'W\' = consignment stock from vendor; \'O\' = stock at subcontractor (OSAT). Empty value indicates standard own stock.']
  stock_aging_days varchar [note: 'Number of days the current on-hand stock has been held at this storage location since the oldest receipt date. Used for slow-moving inventory identification, shelf-life monitoring, and obsolescence risk assessment. Critical for chemicals, gases, and photoresists with defined shelf lives.']
  stock_type varchar [note: 'SAP stock category indicating the usability status of the inventory. \'unrestricted\' is available for production or shipment; \'quality_inspection\' is under QM hold pending disposition; \'blocked\' is rejected or quarantined; \'consignment\' is held at OSAT partner sites; \'restricted\' is subject to export control or ITAR/EAR restrictions.']
  storage_condition_code varchar [note: 'Required storage environment classification for this material. Drives warehouse management system (WMS) slotting and compliance with SEMI, REACH, and OSHA storage requirements. \'nitrogen_purge\' for moisture-sensitive devices (MSD); \'cold_storage\' for temperature-sensitive chemicals; \'cleanroom_class1/10\' for wafers and photomasks; \'hazmat\' for regulated chemicals.']
  unit_of_measure varchar [note: 'Base unit of measure for all quantity fields on this stock balance record. \'EA\' = each (packaged chips), \'WFR\' = wafer, \'LOT\' = wafer lot, \'KG\' = kilogram (chemicals), \'L\' = liter (liquid chemicals/gases), \'M2\' = square meter (substrate), \'MASK\' = photomask, \'DIE\' = individual die. Aligned with SAP base UoM configuration. [ENUM-REF-CANDIDATE: EA|WFR|LOT|KG|L|M2|MASK|DIE — 8 candidates stripped; promote to reference product]']
  unrestricted_use_flag boolean [note: 'Indicates whether this stock balance record represents inventory that is fully available for unrestricted use in production or shipment (True), or whether it is subject to any hold, restriction, or quality disposition (False). Derived from stock_type but maintained as an explicit flag for rapid ATP query performance.']
  valuation_class varchar [note: 'SAP valuation class code that determines the general ledger (GL) accounts to which inventory postings are made for this material. Links inventory movements to the correct balance sheet accounts for financial reporting. Detailed financial valuation fields are maintained in the stock_valuation data product.']
  wafer_process_node varchar [note: 'The semiconductor process technology node at which the wafer lot or die was fabricated (e.g., \'7nm\', \'14nm\', \'28nm\', \'180nm\'). Critical for inventory segregation, process compatibility checks, and customer design-in alignment.']

  Note: 'Transactional snapshot of on-hand inventory quantities by material, storage location, lot, and stock type (unrestricted, quality inspection, blocked, consignment). Captures quantity on hand, quantity available (unreserved), quantity reserved (linked to active inventory_reservation records), quantity in transit, quantity in WIP, unit of measure, last physical count date, and stock aging days. Supports real-time inventory visibility, ATP calculations, and production planning decisions. Financial valuation fields are maintained in stock_valuation.'
}

Table inventory.goods_movement {
  goods_movement_id varchar [pk, note: 'Unique identifier for the goods movement transaction. Primary key for the goods movement record.']
  account_id varchar [note: 'Identifier of the customer for goods issue transactions related to sales orders or consignment stock transfers. Links to customer master for finished goods shipments.']
  assembly_order_id varchar [note: 'Foreign key linking to packaging.assembly_order. Business justification: Goods issues (movement type 261) are triggered by assembly orders when dies/wafers are issued to packaging. This FK enables assembly order cost accounting, material consumption reporting, and ERP good']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: goods_movement records die bank transfers to OSAT partners for packaging, inter-facility KGD transfers, and die bank adjustments. A direct FK to die_bank enables movement history tracking for KGD die ']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: goods_movement records goods issues of finished goods to customers, inter-warehouse transfers, and returns. A direct FK to finished_good enables movement history tracking for packaged chips, supportin']
  goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: In semiconductor ERP (SAP MM), a goods receipt in the supply domain triggers a goods movement (movement type 101) in inventory. This fundamental link enables audit trails, goods receipt reversal proce']
  inbound_shipment_id varchar [note: 'Foreign key linking to supply.inbound_shipment. Business justification: Inbound shipments of raw materials or finished goods trigger goods movements upon arrival at the fab. Linking goods_movement to inbound_shipment enables end-to-end shipment-to-stock traceability requi']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: goods_movement records every inventory movement event including WIP wafer lot transfers between FAB areas, scrap postings, and inter-facility transfers. A direct FK to inventory_wafer_lot enables wafe']
  line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Goods issue movements in semiconductor ERP (SAP-style) are executed against specific order lines. goods_movement already has order_id but lacks order_line_id. Line-level goods issue traceability is re']
  maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: Goods movements (spare part issues, chemical disbursements) are triggered by maintenance events. This FK enables total material cost calculation per maintenance event, supports maintenance cost accoun']
  material_certification_id varchar [note: 'Foreign key linking to supply.material_certification. Business justification: When receiving certified materials (RoHS, REACH, ITAR-controlled), the goods movement must reference the applicable material certification for compliance audit trails. This link supports regulatory co']
  order_id varchar [note: 'Foreign key linking to order.order. Business justification: REQUIRED: Financial and logistics reporting ties inventory movements to the originating sales order for cost of goods sold and compliance.']
  po_line_id varchar [note: 'Foreign key linking to supply.po_line. Business justification: Every goods movement against a purchase order references a specific PO line item (standard SAP MM process). goods_movement has purchase_order_id but no po_line FK. This link enables PO line delivery s']
  primary_goods_material_master_id varchar [note: 'Identifier of the material being moved. References the material master record for silicon wafers, chemicals, gases, photomasks, packaged chips, or die banks.']
  primary_goods_stock_balance_id varchar [note: 'FK to inventory.stock_balance.stock_balance_id — Every goods movement posting updates the stock balance. This is the fundamental inventory equation: stock_balance = sum(goods_movements). Critical for reconciliation and audit.']
  primary_goods_storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Every goods movement must reference source location for audit trail and inventory reconciliation.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: LOGISTICS: Each goods movement (receipt/shipment) is driven by a PO; linking supports audit, costing, and on‑time delivery metrics.']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: goods_movement records goods receipts from suppliers for raw materials (silicon wafers, chemicals, gases, photomasks) and goods issues to production. A direct FK to raw_material enables movement histo']
  shipment_id varchar [note: 'Foreign key linking to order.shipment. Business justification: Outbound goods movements (goods issue) are associated with specific shipments in semiconductor logistics. Linking goods_movement to shipment enables outbound delivery document reconciliation, proof-of']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Goods movements (receipts, shipments, transfers) in semiconductor operations are executed against specific SKUs for shipping documentation, export control (ECCN/ITAR), and revenue recognition. No exis']
  source_storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Every goods movement has a source location (for issues, transfers) or destination location (for receipts). Location reference is mandatory for movement posting and audit trail.']
  spare_part_id varchar [note: 'Foreign key linking to equipment.spare_part. Business justification: Goods movements record spare part issues to maintenance and receipts from suppliers. goods_movement already has raw_material_id, finished_good_id, die_bank_id FKs; spare_part_id completes the material']
  supplier_id varchar [note: 'Identifier of the supplier for goods receipt transactions. Links to vendor master for silicon wafer suppliers, chemical vendors, gas suppliers, or OSAT (Outsourced Semiconductor Assembly and Test) partners.']
  batch_number varchar [note: 'Batch or lot number for batch-managed materials such as chemicals, gases, or raw wafers. Distinct from wafer lot number; used for supplier batch traceability and shelf-life management.']
  bin_classification varchar [note: 'Quality bin or grade classification for die or wafer inventory: Bin 1 (prime), Bin 2 (downgrade), Bin 3 (scrap), or custom bin codes. Used for Known Good Die (KGD) status tracking and yield analysis.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the valuation amount. Typically company currency (USD, EUR, JPY, etc.) for inventory accounting.']
  delivery_note_number varchar [note: 'Delivery note or packing slip number from the supplier or shipping carrier. Used for goods receipt matching and three-way match (PO, goods receipt, invoice) reconciliation.']
  destination_plant_code varchar [note: 'Plant or FAB site code where the material was moved to. Used for inter-plant transfers and multi-site inventory tracking. Critical for global supply chain visibility.']
  destination_storage_location varchar [note: 'Storage location code where the material was moved to. Represents warehouse, stockroom, or FAB storage area. Empty for goods issues to external customers or scrap.']
  document_line_item varchar [note: 'Line item number within the material document. Supports multi-line goods movement documents where multiple materials or lots are moved in a single transaction.']
  document_number varchar [note: 'Unique material document number generated by the ERP system for this goods movement. Primary business identifier for the transaction, used for audit trail and reversal references.']
  lot_number varchar [note: 'Wafer lot or batch identifier for Work in Process (WIP) inventory. Critical for lot traceability and IATF 16949 compliance. Tracks wafer lots through fabrication, die banks, and packaging.']
  movement_date date [note: 'Date when the physical goods movement occurred. Business event date for inventory transaction, distinct from posting date. Critical for SOX Section 404 audit trail and inventory valuation.']
  movement_type varchar [note: 'Classification of the inventory movement transaction: goods receipt from supplier, goods issue to production, inter-location transfer, scrap disposal, return from production, or posting reversal. Aligns with SAP MM movement type codes.']
  notes varchar [note: 'Free-text notes or comments about the goods movement transaction. Used for documenting special handling instructions, quality issues, or operational exceptions.']
  posting_date date [note: 'Date when the goods movement was posted to the financial ledger. Used for period-end closing and financial reporting. May differ from movement date for backdated or delayed postings.']
  production_order_number varchar [note: 'Production order number for goods issues to manufacturing or goods receipts from production. Links inventory movements to wafer fabrication, die packaging, or assembly operations.']
  quantity decimal(18,6) [note: 'Quantity of material moved in this transaction. Positive for receipts and transfers-in, negative for issues and transfers-out. Precision supports wafer counts, die counts, and chemical volumes.']
  reason_code varchar [note: 'Code indicating the business reason for the goods movement: quality hold, scrap due to defect, return to vendor, obsolescence, cycle count adjustment, or other operational reason. Required for scrap and adjustment transactions.']
  reference_document_line_item varchar [note: 'Line item number within the reference document. Provides precise linkage to the specific line of the purchase order, production order, or delivery note.']
  reference_document_number varchar [note: 'Number of the source document that triggered this goods movement. Links to purchase order, production order, delivery note, or other originating transaction for full traceability.']
  reference_document_type varchar [note: 'Type of source document that triggered this goods movement: purchase order (PO) for receipts, production order for manufacturing issues/receipts, delivery note for shipments, transfer order for inter-location moves, sales order for customer shipments, or reservation for planned consumption.']
  reservation_number varchar [note: 'Material reservation number for planned goods issues. Links to production order or maintenance order reservations for material requirements planning (MRP) and allocation.']
  reversal_indicator boolean [note: 'Flag indicating whether this goods movement is a reversal of a previous transaction. True for cancellation or correction postings. Used for audit trail and error correction tracking.']
  reversed_document_number varchar [note: 'Material document number of the original transaction being reversed. Populated only when reversal_indicator is true. Provides linkage for audit trail and reconciliation.']
  serial_number varchar [note: 'Serial number for serialized inventory items such as high-value equipment parts or Known Good Die (KGD) units. Enables unit-level traceability for critical components.']
  shelf_life_expiration_date date [note: 'Expiration date for time-sensitive materials such as photoresists, chemicals, or adhesives. Used for shelf-life management and FIFO (First In First Out) inventory control.']
  source_plant_code varchar [note: 'Plant or FAB site code where the material originated. Used for inter-plant transfers and multi-site inventory tracking. Aligns with SEMI E120 traceability requirements.']
  source_storage_location varchar [note: 'Storage location code where the material was moved from. Represents warehouse, stockroom, or FAB storage area. Empty for goods receipts from external suppliers.']
  special_stock_indicator varchar [note: 'Indicator for special stock types: consignment stock at OSAT partners, project-specific stock, sales order allocated stock, returnable packaging, or pipeline inventory. Affects ownership and valuation rules.']
  stock_type varchar [note: 'Stock status classification: unrestricted (available for use), quality inspection (pending QA release), blocked (quality hold or obsolete), or restricted use (conditional release). Determines material availability for production and sales.']
  transaction_timestamp timestamp [note: 'Precise date and time when the goods movement transaction was recorded in the system. Used for audit trail, sequence verification, and real-time inventory updates.']
  unit_of_measure varchar [note: 'Unit of measure for the movement quantity: wafers (EA), dies (PC), liters (L), kilograms (KG), or other standard units. Aligns with ISO 80000 quantity standards.']
  valuation_amount decimal(18,2) [note: 'Total monetary value of the goods movement in company currency. Calculated as quantity multiplied by material standard cost or moving average price. Used for inventory valuation and financial reporting.']
  work_center varchar [note: 'Work center or production resource where the material was issued or received. Identifies specific FAB equipment, packaging line, or assembly station for process traceability.']

  Note: 'Transactional record for every inventory movement event: goods receipts from suppliers, goods issues to production, inter-location transfers, scrap disposals, returns, and posting reversals. Captures movement type, date, material, quantity, UoM, source/destination locations, reference document (PO/production order/delivery note), posting date, and document number. Provides the complete inventory audit trail required for SOX Section 404 controls, IATF 16949 traceability, and real-time stock balance updates.'
}

Table inventory.physical_inventory {
  physical_inventory_id varchar [pk, note: 'Unique identifier for the physical inventory count event record.']
  adjustment_goods_movement_id varchar [note: 'Foreign key linking to inventory.goods_movement. Business justification: When a physical inventory count reveals a variance that exceeds tolerance, an inventory adjustment goods movement is posted to correct the stock balance. A FK from physical_inventory to goods_movement']
  consignment_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Physical inventory counts of consignment stock require supplier reference for reconciliation reports sent to the consignment supplier. physical_inventory has consignment_partner_code (denormalized). T']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: physical_inventory records cycle counts of die bank inventory (KGD dies in waffle packs). A FK to die_bank links the count event to the specific die bank record being counted, enabling KGD quantity re']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: physical_inventory records cycle counts of finished goods (packaged chips) in finished goods warehouses. A FK to finished_good links the count event to the specific finished good SKU being counted, en']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: physical_inventory records cycle counts and wall-to-wall counts of WIP wafer lots in FAB cleanrooms. A FK to inventory_wafer_lot links the count event to the specific wafer lot being counted, enabling']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Physical inventory counts in semiconductor fabs are performed against material master records to validate book quantities. physical_inventory has material_number (denormalized). This link enables vari']
  primary_storage_location_id varchar [note: 'FK to inventory.storage_location.storage_location_id — Physical counts are always performed at a specific location. Required for SOX audit trail.']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: physical_inventory records cycle counts of raw materials (silicon wafers, chemicals, gases) in chemical warehouses and cleanrooms. A FK to raw_material links the count event to the specific raw materi']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Physical inventory cycle counts and annual audits in semiconductor operations are performed and reported by SKU for financial audit compliance (SOX) and inventory accuracy reporting. physical_inventor']
  spare_part_id varchar [note: 'Foreign key linking to equipment.spare_part. Business justification: Physical inventory counts must cover all stocked items including spare parts in maintenance storage areas. physical_inventory already links to raw_material, finished_good, die_bank, and inventory_wafe']
  stock_balance_id varchar [note: 'Foreign key linking to inventory.stock_balance. Business justification: physical_inventory reconciles counted quantities against book quantities in stock_balance. A FK from physical_inventory to stock_balance directly links the count event to the stock balance record bein']
  approval_timestamp timestamp [note: 'Timestamp when the supervisor approved the physical count results, authorizing variance posting to the system.']
  bin_classification varchar [note: 'Bin classification code for die or chip inventory, categorizing units by electrical test performance (e.g., Bin 1 for prime Known Good Die (KGD), Bin 2-9 for various performance grades or defects).']
  book_quantity decimal(18,3) [note: 'System-recorded inventory quantity (book quantity) at the time of the physical count, representing the expected quantity per ERP records.']
  consignment_flag boolean [note: 'Boolean indicator (True/False) specifying whether this inventory is consignment stock held at an OSAT (Outsourced Semiconductor Assembly and Test) partner or customer location, owned by the company but physically located off-site.']
  count_completion_timestamp timestamp [note: 'Timestamp when the physical count activity was completed and submitted for review.']
  count_date date [note: 'The date on which the physical inventory count was performed or is scheduled to be performed.']
  count_document_number varchar [note: 'Externally-known unique document number assigned to this physical inventory count event for traceability and audit purposes.']
  count_notes varchar [note: 'Free-text notes or comments recorded by the counter or supervisor regarding count conditions, discrepancies observed, damaged goods, or other relevant observations.']
  count_start_timestamp timestamp [note: 'Timestamp when the physical count activity began for this inventory event.']
  count_status varchar [note: 'Current lifecycle status of the physical inventory count event: planned (scheduled but not started), in-progress (counting underway), completed (count finished awaiting approval), posted (variance posted to system), cancelled, or on-hold.']
  count_type varchar [note: 'Classification of the physical inventory count event: cycle count (periodic rotation), annual wall-to-wall (full facility), triggered count (post-movement discrepancy or system exception), spot check, variance recount, or regulatory audit.']
  counted_quantity decimal(18,3) [note: 'Physically counted quantity recorded by the counter during the inventory count event.']
  created_timestamp timestamp [note: 'Timestamp when this physical inventory count record was first created in the system.']
  fiscal_period varchar [note: 'Fiscal period (month or quarter) within the fiscal year when the count was performed, supporting periodic financial close and inventory valuation.']
  fiscal_year varchar [note: 'Fiscal year in which the physical inventory count was performed, supporting annual financial reporting and SOX compliance.']
  freeze_flag boolean [note: 'Boolean indicator (True/False) specifying whether inventory movements were frozen (blocked) during the count period to ensure accuracy and prevent discrepancies.']
  inventory_category varchar [note: 'High-level classification of the inventory being counted: raw material (silicon wafers, chemicals, gases, photomasks), WIP (Work in Process wafer lots), finished goods (packaged chips), die bank, consignment stock, or spare parts.']
  kgd_status varchar [note: 'Status indicating whether the die or chip inventory has been verified as Known Good Die (KGD) through electrical testing, is non-KGD (failed test), untested, or in quarantine pending test results.']
  last_modified_timestamp timestamp [note: 'Timestamp when this physical inventory count record was last updated or modified in the system.']
  lot_number varchar [note: 'Lot or batch identifier for WIP wafer lots, die banks, or consignment stock being counted, enabling full traceability per IATF 16949 requirements.']
  plant_code varchar [note: 'Code identifying the manufacturing plant or facility where the physical count was performed.']
  posting_date date [note: 'The date on which the inventory variance was posted to the financial and inventory management system, adjusting book quantities and valuations.']
  recount_flag boolean [note: 'Boolean indicator (True/False) specifying whether this count is a recount of a previously counted item due to variance exceeding tolerance thresholds or supervisor request.']
  recount_reason varchar [note: 'Reason code for why a recount was triggered: variance exceeds threshold, supervisor request, system discrepancy, damaged goods, quality hold, or initial count error.']
  shelf_life_expiry_date date [note: 'Expiration date for materials with limited shelf life (chemicals, photoresists, gases, adhesives), beyond which the material may not meet specification and must be disposed or retested.']
  standard_cost_usd decimal(18,4) [note: 'Standard cost per unit of the material at the time of count, used for variance valuation and financial reporting.']
  storage_condition_code varchar [note: 'Code indicating required storage conditions for the material: ambient, controlled temperature, controlled humidity, nitrogen purge (for moisture-sensitive devices), vacuum, or cleanroom environment.']
  unit_of_measure varchar [note: 'Unit of measure for the counted quantity: EA (each for wafers or chips), KG (kilograms for chemicals), L (liters for gases or liquids), or other standard UOM codes.']
  variance_exceeds_tolerance_flag boolean [note: 'Boolean indicator (True/False) specifying whether the calculated variance exceeds the defined tolerance threshold, requiring investigation or recount per quality management procedures.']
  variance_quantity decimal(18,3) [note: 'Calculated difference between counted quantity and book quantity (counted minus book), representing inventory discrepancy. Positive values indicate surplus, negative values indicate shortage.']
  variance_tolerance_pct decimal(5,2) [note: 'Acceptable variance tolerance percentage for this count event, beyond which a recount or investigation is triggered. Typically set per material category and value class.']
  variance_value_usd decimal(18,2) [note: 'Financial value of the inventory variance in US dollars, calculated as variance quantity multiplied by standard cost or moving average price. Critical for SOX Section 404 financial controls and inventory valuation accuracy.']

  Note: 'Transactional record of physical inventory count events including cycle counts, annual wall-to-wall counts, and triggered counts (post-movement discrepancy or system exception). Captures count document number, count date, material/lot reference, storage location, system book quantity, physically counted quantity, variance quantity, variance value, count status (planned/in-progress/completed/posted), recount flag, counter ID, supervisor approval, and posting date. Supports SOX Section 404 financial controls, IATF 16949 inventory accuracy requirements, and ISO 9001 documented evidence of stock verification.'
}

Table inventory.reservation {
  reservation_id varchar [pk, note: 'System-generated unique identifier for the inventory reservation record.']
  account_id varchar [note: 'Identifier of the customer associated with the reservation, if applicable.']
  assembly_order_id varchar [note: 'Foreign key linking to packaging.assembly_order. Business justification: Inventory reservations are created against assembly orders to earmark dies and wafers before physical issuance. A typed FK replaces the free-text demand_source_reference, enabling reservation-to-assem']
  consignment_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Reservations against consignment stock owned by a specific supplier require supplier reference for consignment liability tracking and supplier notification. This link enables consignment reservation m']
  consuming_goods_movement_id varchar [note: 'Reference to the goods movement that will consume the reservation.']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: Design-win-driven inventory reservation is a core semiconductor supply planning process: when a customer wins a design, inventory is reserved against that specific design win to guarantee supply for p']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: reservation earmarks specific quantities of KGD dies from die bank for OSAT packaging runs or engineering sample builds. A FK to die_bank links the reservation to the specific die bank record being re']
  finished_good_id varchar [note: 'Foreign key linking to inventory.finished_good. Business justification: reservation earmarks specific quantities of finished goods for customer orders, safety stock replenishment, or export shipments. A FK to finished_good links the reservation to the specific finished go']
  fulfilling_goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: When a goods receipt posts, it fulfills open reservations. Linking reservation to goods_receipt (role-prefixed \'fulfilling\' to distinguish from consuming_goods_movement_id) enables automated reservati']
  inbound_shipment_id varchar [note: 'Foreign key linking to supply.inbound_shipment. Business justification: Semiconductor planners reserve in-transit shipment quantities for specific production lots or customer orders before physical arrival. Linking reservation to inbound_shipment enables in-transit reserv']
  inventory_wafer_lot_id varchar [note: 'Foreign key linking to inventory.inventory_wafer_lot. Business justification: reservation earmarks specific quantities of WIP wafer lots for production orders, customer commitments, or engineering samples. A FK to inventory_wafer_lot links the reservation to the specific wafer ']
  line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Inventory reservations in semiconductor operations are demand-driven and created against specific order lines. reservation.demand_source_reference is a plain text denormalization. FK to order_line ena']
  maintenance_event_id varchar [note: 'Foreign key linking to equipment.maintenance_event. Business justification: Materials and spare parts are reserved in inventory for upcoming maintenance events. This FK enables maintenance planners to confirm material availability before scheduling downtime. demand_source_ref']
  material_master_id varchar [note: 'Identifier of the raw material or finished‑good SKU associated with the reservation.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: In semiconductor procurement, reservations are created against specific purchase orders to earmark incoming stock for production orders or customer commitments before physical receipt. This link enabl']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: reservation earmarks specific quantities of raw materials (silicon wafers, chemicals, photomasks) for planned production runs. A FK to raw_material links the reservation to the specific raw material b']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Inventory reservations in semiconductor order management are made against specific SKUs for customer demand fulfillment and ATP calculations. Reservation must reference the orderable SKU directly to s']
  split_from_reservation_id varchar [note: 'Self-referencing FK on reservation (split_from_reservation_id)']
  stock_balance_id varchar [note: 'Foreign key linking to inventory.stock_balance. Business justification: reservation earmarks quantities from a specific stock balance record. A FK from reservation to stock_balance directly links the reservation to the stock balance being reserved against, enabling real-t']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: reservation has a storage_location_code (STRING) that denotes the storage location from which the reserved material will be issued. Normalizing this to a FK to storage_location enables proper joins fo']
  wafer_id varchar [note: 'Identifier of the wafer or material lot that is being reserved.']
  bin_classification varchar [note: 'Classification of the inventory bin (e.g., A, B, C) used for yield or quality segregation.']
  created_timestamp timestamp [note: 'Timestamp when the reservation record was first captured in the lakehouse.']
  expiration_timestamp timestamp [note: 'Date and time when the reservation automatically expires if not consumed.']
  inventory_status varchar [note: 'Current operational status of the reserved inventory (e.g., available, on_hold).']
  is_kgd boolean [note: 'Indicates whether the reservation is for KGD‑qualified inventory.']
  priority varchar [note: 'Business priority used for allocation sequencing.']
  reason varchar [note: 'Free‑text explanation for why the reservation was created.']
  requested_delivery_date date [note: 'Customer‑or‑production requested date for the reserved inventory to be delivered.']
  reservation_number varchar [note: 'Business-visible reservation code used in communications and reporting.']
  reservation_status varchar [note: 'Current lifecycle state of the reservation.']
  reservation_timestamp timestamp [note: 'Date and time when the reservation was created in the source system.']
  reservation_type varchar [note: 'Category of demand source that triggered the reservation.']
  reserved_quantity decimal(20,4) [note: 'Amount of inventory units earmarked by the reservation.']
  unit_of_measure varchar [note: 'Measurement unit for the reserved quantity (e.g., pcs, wafers, kg).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the reservation record.']

  Note: 'Transactional record for inventory allocation and reservation events that earmark specific quantities of WIP lots, die bank dies, raw materials, or finished goods for a designated demand source (customer order, production order, packaging run, engineering sample request). Captures reservation ID, material/lot reference, reserved quantity, UoM, demand source type and ID, reservation date, requested delivery date, priority, reservation status (active/consumed/cancelled/expired), consuming goods_movement reference, and reserving user. Enables ATP (available-to-promise) calculations, prevents double-allocation of scarce KGD inventory, and supports OSAT packaging run scheduling.'
}

Table packaging.assembly_order {
  assembly_order_id varchar [pk, note: 'Primary key for assembly_order']
  account_id varchar [note: 'Unique identifier of the customer who requested the assembly order.']
  booking_id varchar [note: 'Foreign key linking to sales.booking. Business justification: Assembly orders are created to fulfill customer bookings in semiconductor ops. Production planners and customer service teams trace booking commitments to OSAT assembly execution for on-time delivery ']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: Needed for Assembly Order Cost Allocation and Regulatory Traceability linking the order to the die bank supplying the dies.']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Assembly Order is created for a specific IC design project; linking enables traceability, cost allocation, and schedule alignment in the packaging execution process.']
  material_lot_id varchar [note: 'Identifier of the substrate lot used in the packaging process.']
  primary_assembly_osat_vendor_id varchar [note: 'Identifier of the outsourced assembly partner responsible for execution.']
  primary_assembly_package_type_id varchar [note: 'FK to packaging.package_type.package_type_id — Every assembly order specifies a package type. This FK is essential for filtering orders by package format, capacity planning, and routing to qualified OSAT sites.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: REQUIRED: Assembly order fulfillment depends on a purchase order; linking supports order‑PO status reconciliation and financial reporting.']
  ship_to_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Assembly orders specify where OSAT-finished goods ship — customer warehouse, distribution center, or consignment hub. Linking assembly_order to customer.address via ship_to_address_id enables logistic']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Packaging must reference the tapeout record to ensure the correct mask set and timing closure status are used for assembly.']
  actual_yield_percent decimal(5,2) [note: 'Yield percentage achieved after assembly completion.']
  assembly_order_status varchar [note: 'Current lifecycle state of the assembly order.']
  assembly_osat_vendor_fk varchar [note: 'FK to packaging.osat_vendor.osat_vendor_id — Assembly orders are issued to a specific OSAT vendor or internal site. This FK is essential for OSAT capacity planning, scorecard reporting, and order routing.']
  assembly_site varchar [note: 'Code of the facility where the assembly is performed.']
  completion_date date [note: 'Date when the assembly work was completed.']
  cost_adjustment_amount decimal(12,2) [note: 'Any cost adjustments (e.g., discounts, fees) applied to the gross amount.']
  cost_gross_amount decimal(12,2) [note: 'Estimated total cost before any adjustments.']
  cost_net_amount decimal(12,2) [note: 'Final cost after adjustments, representing the amount to be billed.']
  created_timestamp timestamp [note: 'Timestamp when the assembly order record was created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the cost amounts.']
  defect_count varchar [note: 'Number of defects recorded during assembly.']
  expected_yield_percent decimal(5,2) [note: 'Target yield percentage expected for the assembly run.']
  hold_flag boolean [note: 'Indicates whether the order is currently on hold.']
  inspection_status varchar [note: 'Result of the final inspection for the assembled package.']
  last_status_change_timestamp timestamp [note: 'Timestamp of the most recent status transition.']
  notes varchar [note: 'Free‑form comments or remarks related to the order.']
  order_number varchar [note: 'Business-visible alphanumeric identifier assigned to the assembly order.']
  order_placed_timestamp timestamp [note: 'Timestamp when the assembly order was initially placed.']
  order_source varchar [note: 'Origin of the order request.']
  priority varchar [note: 'Business priority assigned to the assembly order.']
  quantity_ordered varchar [note: 'Number of die units requested for assembly.']
  release_date date [note: 'Date when the order was released for execution.']
  special_handling_instructions varchar [note: 'Any additional instructions required for the assembly (e.g., cleanroom level, moisture sensitivity).']
  target_ship_date date [note: 'Planned date for shipment of the completed assembly.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the assembly order record.']

  Note: 'Primary transactional record for die packaging and assembly work orders issued to OSAT partners or internal assembly lines. Captures assembly order number, package type (WLCSP, InFO, CoWoS, flip-chip, wire bond, BGA, leadframe), die lot reference, substrate lot, quantity ordered, target ship date, assembly site, process flow revision, and order status lifecycle (released, in-process, completed, on-hold). SSOT for all assembly execution events in the packaging domain. Shipment logistics and delivery tracking are owned by the order domain; cost accounting is owned by the finance domain.'
}

Table packaging.package_type {
  package_type_id varchar [pk, note: 'Primary key for package_type']
  ball_count_max varchar [note: 'Maximum number of solder balls for BGA‑type packages.']
  ball_count_min varchar [note: 'Minimum number of solder balls for BGA‑type packages.']
  created_timestamp timestamp [note: 'Date‑time when the package type record was first created in the system.']
  description varchar [note: 'Free‑form description of the package’s mechanical and electrical characteristics.']
  effective_from date [note: 'Date on which the package type becomes valid for use.']
  effective_until date [note: 'Date after which the package type is no longer valid (null if indefinite).']
  is_3d_ic boolean [note: 'True if the package incorporates through‑silicon vias or other 3‑D stacking.']
  is_advanced_package boolean [note: 'True for cutting‑edge or specialty package formats.']
  is_ball_grid_array boolean [note: 'True if the package is a ball‑grid array type.']
  is_flip_chip boolean [note: 'True if the package utilizes flip‑chip interconnect technology.']
  is_heterogeneous_integration boolean [note: 'Indicates whether the package supports heterogeneous integration (e.g., chip‑on‑wafer).']
  is_itar_controlled boolean [note: 'True if the package is subject to International Traffic in Arms Regulations.']
  is_leadframe boolean [note: 'True if the package uses a traditional leadframe.']
  is_osat_supported boolean [note: 'True if the package type is commonly offered by outsourced assembly providers.']
  is_reach_compliant boolean [note: 'True if the package complies with REACH chemical safety regulations.']
  is_rohs_compliant boolean [note: 'True if the package meets RoHS restriction requirements.']
  is_wire_bond boolean [note: 'True if the package uses wire‑bond interconnects.']
  jedec_outline_code varchar [note: 'Official JEDEC outline identifier for the package (e.g., 5x5‑1mm).']
  max_current_a decimal(6,2) [note: 'Maximum continuous current rating for the package.']
  max_die_pitch_um decimal(6,2) [note: 'Maximum center‑to‑center spacing between dies for multi‑die packages.']
  max_operating_temperature_c decimal(5,2) [note: 'Highest temperature at which the package can reliably operate.']
  max_power_dissipation_w decimal(6,2) [note: 'Maximum power the package can dissipate safely.']
  max_voltage_v decimal(6,2) [note: 'Maximum voltage rating the package can withstand.']
  min_die_pitch_um decimal(6,2) [note: 'Minimum center‑to‑center spacing between dies for multi‑die packages.']
  min_operating_temperature_c decimal(5,2) [note: 'Lowest temperature at which the package can reliably operate.']
  moisture_sensitivity_level varchar [note: 'JEDEC‑defined moisture sensitivity classification.']
  package_category varchar [note: 'Primary category of the package format; limited to six most common values.']
  package_dimensions_height_um decimal(8,2) [note: 'External height (thickness) dimension of the package.']
  package_dimensions_length_um decimal(8,2) [note: 'External length dimension of the package.']
  package_dimensions_width_um decimal(8,2) [note: 'External width dimension of the package.']
  package_family varchar [note: 'Higher‑level family grouping (e.g., Wafer‑Level, Flip‑Chip, 3D‑IC).']
  package_material varchar [note: 'Primary material used for the package substrate.']
  package_name varchar [note: 'Human‑readable name of the package format (e.g., WLCSP, CoWoS).']
  package_type_status varchar [note: 'Current lifecycle status of the package type.']
  pin_count_max varchar [note: 'Maximum number of electrical pins/balls the package can support.']
  pin_count_min varchar [note: 'Minimum number of electrical pins/balls the package can support.']
  qualification_status varchar [note: 'Current qualification state of the package format.']
  reference_document varchar [note: 'Identifier or URL of the primary specification document for the package type.']
  thermal_resistance_c_per_w decimal(10,4) [note: 'Thermal resistance from die to ambient, expressed in degrees Celsius per Watt.']
  typical_thickness_um decimal(6,2) [note: 'Nominal vertical thickness of the finished package.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the package type record.']

  Note: 'Reference master for all semiconductor package formats supported by Semiconductors, including WLCSP, InFO, CoWoS, TSV-based 3D-IC, flip-chip BGA, wire-bond QFN, leadframe DIP/QFP, and advanced heterogeneous integration formats. Stores package family, body dimensions, pin/ball count range, thermal resistance specs, moisture sensitivity level (MSL), JEDEC outline code, and qualification status. SSOT for package format classification used across assembly, product catalog, and qualification domains.'
}

Table packaging.osat_vendor {
  osat_vendor_id varchar [pk, note: 'Unique surrogate key for OSAT vendor record.']
  supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: REQUIRED: OSAT vendor is a supplier; linking enables unified supplier performance, audit, and regulatory reporting.']
  aec_q100_certified boolean [note: 'Indicates if the vendor holds AEC-Q100 qualification.']
  audit_score decimal(5,2) [note: 'Score from the latest audit (0-100).']
  capacity_tier varchar [note: 'Capacity tier classification for the vendor\'s assembly lines.']
  created_timestamp timestamp [note: 'Timestamp when the vendor record was first created.']
  dppm_rate decimal(10,4) [note: 'Historical DPPM rate of the vendor\'s assembly processes.']
  duns_number varchar [note: 'Dun & Bradstreet unique identifier for the vendor.']
  export_control_classification varchar [note: 'Export control regime applicable to the vendor.']
  iatf_16949_certified boolean [note: 'Indicates if the vendor holds IATF 16949 certification.']
  iso_9001_certified boolean [note: 'Indicates if the vendor holds ISO 9001 certification.']
  last_audit_date date [note: 'Date of the most recent quality audit performed on the vendor.']
  lifecycle_status varchar [note: 'Overall lifecycle state of the vendor record.']
  nda_ip_protection boolean [note: 'Indicates whether a non-disclosure agreement and IP protection are in place.']
  notes varchar [note: 'Free-form notes regarding the vendor.']
  package_capabilities varchar [note: 'Comma-separated list of package types the vendor is qualified to assemble (e.g., WLCSP, InFO, CoWoS, TSV, flip-chip, BGA).']
  partnership_status varchar [note: 'Current qualification status of the vendor within the OSAT program.']
  preferred_package_types varchar [note: 'Comma-separated list of package types the vendor is preferred for.']
  primary_contact_email varchar [note: 'Email address of the primary contact.']
  primary_contact_name varchar [note: 'Name of the primary contact person at the vendor.']
  primary_contact_phone varchar [note: 'Phone number of the primary contact.']
  quality_certifications varchar [note: 'Semicolon-separated list of quality certifications held by the vendor (e.g., IATF 16949, ISO 9001, AEC-Q100).']
  standard_lead_time_days varchar [note: 'Typical lead time in days for standard package orders.']
  tax_identifier varchar [note: 'Government tax identifier for the vendor.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the vendor record.']
  vendor_address varchar [note: 'Physical address of the vendor\'s primary site.']
  vendor_code varchar [note: 'Unique vendor code used in ERP and PLM systems.']
  vendor_country varchar [note: 'ISO 3166-1 alpha-3 country code of the vendor\'s headquarters. [ENUM-REF-CANDIDATE: USA|CHN|KOR|JPN|TWN|DEU|... — promote to reference product]']
  vendor_name varchar [note: 'Legal name of the OSAT vendor as registered.']
  vendor_short_name varchar [note: 'Commonly used short name or abbreviation for the vendor.']
  vendor_type varchar [note: 'Classification of the vendor based on ownership and relationship.']

  Note: 'Master record for Outsourced Semiconductor Assembly and Test (OSAT) partners and internal assembly sites used by Semiconductors. Captures vendor legal name, site locations, approved package type capabilities, quality certifications (IATF 16949, ISO 9001, AEC-Q100), historical DPPM performance, capacity tiers, standard lead times, NDA/IP protection status, export control classification (EAR/ITAR), and approved/preferred/probation status. SSOT for OSAT partner identity and qualification status within the packaging domain.'
}

Table packaging.assembly_process_flow {
  assembly_process_flow_id varchar [pk, note: 'Unique system-generated identifier for each assembly process flow definition.']
  assembly_package_type_id varchar [note: 'FK to packaging.packaging_package_type.packaging_package_type_id — Process flows are defined per package type. A package type may have multiple flow revisions but each flow targets a specific package format.']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: An assembly process flow defines packaging steps; a control plan governs quality checkpoints within that flow. In IATF 16949 semiconductor manufacturing, control plans are directly associated with pro']
  primary_assembly_package_type_id varchar [note: 'FK to packaging.package_type.package_type_id — Process flows are defined per package type. Required for routing and DFM constraint validation.']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: Process Flow Definition uses a specific process node; required for Process Flow Specification report.']
  assembly_process_flow_status varchar [note: 'Current lifecycle status of the flow definition.']
  bond_type varchar [note: 'Primary interconnect technology employed in the flow.']
  compliance_standard varchar [note: 'Regulatory or industry standard that this flow must satisfy.']
  created_timestamp timestamp
  description varchar [note: 'Detailed free‑text description of the flow, its purpose, and scope.']
  dfm_constraints varchar [note: 'Free‑text list of DFM rules or constraints that must be obeyed for this flow.']
  die_attach_method varchar [note: 'Method used to attach the die to the substrate.']
  effective_from date [note: 'Date on which the flow becomes valid for use.']
  effective_until date [note: 'Date after which the flow is no longer valid (null if open‑ended).']
  equipment_class varchar [note: 'High‑level classification of equipment required for the flow (e.g., "Flip‑Chip Bonder", "Mold Press").']
  final_inspection_type varchar [note: 'Primary inspection technique performed after assembly completion.']
  flow_name varchar [note: 'Human‑readable name describing the assembly process flow (e.g., "Advanced 3D‑IC Flip‑Chip Flow").']
  flow_status varchar
  is_default_flow boolean [note: 'Flag indicating whether this flow is the default for its package type.']
  marking_method varchar [note: 'Method used to apply identification marks to the finished package.']
  molding_material varchar [note: 'Encapsulation material applied during the molding step.']
  process_time_target decimal(6,2) [note: 'Target total processing time for the flow, expressed in minutes.']
  process_yield_target decimal(5,2) [note: 'Target yield percentage for the flow (e.g., 98.75).']
  record_audit_created timestamp [note: 'Timestamp when the flow record was first created.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the flow record.']
  revision_number varchar [note: 'Sequential revision number of the flow definition.']
  safety_classification varchar [note: 'Safety level assigned to the flow (e.g., "Class A – Low Hazard").']
  singulation_method varchar [note: 'Technique used to separate individual packages from the wafer or panel.']
  step_count varchar [note: 'Total count of discrete steps defined in the flow.']
  underfill_material varchar [note: 'Material used to fill the gap between die and substrate after bonding.']
  updated_by varchar [note: 'User identifier of the person who last modified the flow record.']

  Note: 'Master definition of the step-by-step assembly process flow for each package type and product combination. Captures flow revision, process steps (die attach, wire bond/flip-chip bump, underfill, molding, singulation, marking, final inspection), equipment class per step, material specifications, and DFM constraints. Linked to package type and product SKU. Enables traceability from assembly order to process specification.'
}

Table packaging.substrate_bom {
  substrate_bom_id varchar [pk, note: 'Unique surrogate key for each substrate BOM record.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Substrate BOMs drive material master creation in supply. Linking enables procurement teams to source substrates defined in the BOM and validates compliance (RoHS, REACH) against the material master. p']
  primary_substrate_package_type_id varchar [note: 'FK to packaging.package_type.package_type_id — Substrate BOMs are specific to a package type. Required for procurement and assembly material planning.']
  substrate_package_type_id varchar [note: 'FK to packaging.packaging_package_type.packaging_package_type_id — Substrate BOMs are defined for specific package types (CoWoS interposer, flip-chip BGA substrate, etc.).']
  supplier_id varchar [note: 'Identifier of the supplier providing the substrate.']
  avl_status varchar [note: 'AVL qualification status of the substrate supplier.']
  bom_number varchar
  bump_pitch_um decimal(5,2) [note: 'Center‑to‑center distance between bumps on the substrate, expressed in micrometers.']
  classification varchar [note: 'Classification indicating performance tier or special characteristics.']
  compliance_status varchar [note: 'Overall regulatory compliance status of the substrate.']
  core_material varchar [note: 'Primary material of the substrate core (e.g., ABF, BT resin, silicon, glass).']
  created_timestamp timestamp [note: 'Timestamp when the BOM record was first created.']
  currency varchar [note: 'Currency code for the unit cost.']
  density_g_per_cm3 decimal(5,2) [note: 'Material density of the substrate.']
  dielectric_constant decimal(5,3) [note: 'Relative permittivity of the substrate material.']
  effective_from date [note: 'Date from which this BOM revision is valid for procurement.']
  effective_until date [note: 'Date until which this BOM revision remains valid (null if open‑ended).']
  is_obsolete boolean [note: 'Indicates whether the substrate is marked as obsolete.']
  last_eco_timestamp timestamp [note: 'Timestamp of the most recent engineering change order affecting this BOM.']
  layer_count varchar [note: 'Number of material layers in the substrate stack.']
  lifecycle_status varchar [note: 'Current lifecycle phase of the substrate product.']
  material_grade varchar [note: 'Grade or quality level of the substrate material.']
  max_operating_temp_c decimal(5,2) [note: 'Maximum temperature at which the substrate can reliably operate.']
  min_operating_temp_c decimal(5,2) [note: 'Minimum temperature for reliable substrate operation.']
  name varchar [note: 'Human‑readable name or description of the substrate.']
  notes varchar [note: 'Free‑form notes or comments about the substrate BOM.']
  pad_finish varchar [note: 'Surface finish applied to substrate pads (e.g., ENIG, OSP, immersion tin, gold).']
  rdl_spec varchar [note: 'Specification details of the redistribution layer (RDL) used on the substrate.']
  reach_compliant boolean [note: 'Indicates whether the substrate complies with REACH chemical safety requirements.']
  revision varchar
  revision_date date [note: 'Date when the current revision was released.']
  revision_number varchar [note: 'Revision identifier for the BOM version.']
  rohs_compliant boolean [note: 'Indicates whether the substrate complies with RoHS restrictions.']
  substrate_bom_status varchar [note: 'Current lifecycle status of the BOM record.']
  substrate_type varchar [note: 'Category of substrate used in packaging (e.g., interposer, die, panel, wafer).']
  thermal_conductivity_w_per_mk decimal(6,3) [note: 'Thermal conductivity of the substrate material.']
  thickness_um decimal(6,2) [note: 'Physical thickness of the substrate in micrometers.']
  unit_cost decimal(12,4) [note: 'Reference cost per unit of substrate (excluding taxes and freight).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the BOM record.']

  Note: 'Bill of Materials for packaging substrates and interposers used in advanced semiconductor packages. Captures substrate part number, layer count, core material (ABF, BT resin, silicon interposer, glass core), redistribution layer (RDL) specs, bump pitch, pad finish (ENIG, OSP, immersion tin), supplier, AVL status, unit cost reference, RoHS/REACH compliance flag, and revision history with ECO traceability. SSOT for substrate material specifications enabling procurement and assembly execution.'
}

Table packaging.assembly_lot {
  assembly_lot_id varchar [pk, note: 'Unique system-generated identifier for the assembly lot record.']
  assembly_order_id varchar [note: 'FK to packaging.pkg_assembly_order.pkg_assembly_order_id — Assembly lots are created against assembly orders. This is the fundamental WIP-to-order traceability link.']
  assembly_package_type_id varchar [note: 'FK to packaging.packaging_package_type.packaging_package_type_id — Each assembly lot is for a specific package type. Required for WIP reporting and routing.']
  assembly_packaging_package_type_id varchar [note: 'FK to packaging.package_type']
  die_bank_id varchar [note: 'Foreign key linking to inventory.die_bank. Business justification: An assembly lot draws dies from a specific die bank. This FK enables die consumption tracking, die bank depletion reporting, and KGD traceability — essential for inventory accuracy and customer-facing']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Lot tracking reports require the originating design project to correlate yield and defect data with design intent.']
  primary_assembly_osat_vendor_id varchar [note: 'FK to packaging.osat_vendor.osat_vendor_id — Each lot is processed at a specific OSAT site. Required for site-level yield analysis and capacity tracking.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Logistics and Inventory Valuation require storing the location of each assembled package for warehouse management.']
  supplier_id varchar [note: 'FK to supply.supplier']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Semiconductor manufacturing requires direct lot-to-tapeout traceability for failure analysis, customer returns (RMA), and yield correlation by mask revision. assembly_lot has ic_design_project_id but ']
  wafer_map_id varchar [note: 'Foreign key linking to quality.wafer_map. Business justification: Assembly operations consume the wafer map to identify KGD-certified die eligible for packaging. The wafer_map provides the die-level pass/fail bitmap that directly drives die selection for each assemb']
  actual_completion_date date [note: 'Date when the lot was actually completed; may be null if not yet finished.']
  assembly_site varchar [note: 'Name of the OSAT vendor or internal fab where the lot is assembled.']
  cost_estimate_usd decimal(12,2) [note: 'Estimated monetary cost of assembling the lot, expressed in US dollars.']
  created_timestamp timestamp [note: 'Date‑time when the assembly lot record was first created in the system.']
  cumulative_yield_percent decimal(5,2) [note: 'Overall percentage of good dies produced from the lot after each process step.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values associated with the lot.']
  current_process_step varchar [note: 'The most recent manufacturing step the lot has completed or is currently executing.']
  defect_density decimal(6,3) [note: 'Number of defects per unit area (e.g., defects per cm²) observed on the lot.']
  die_count varchar [note: 'Total number of individual dies contained in the assembly lot.']
  hold_flag boolean [note: 'Indicates whether the lot is currently on hold for any reason.']
  hold_reason varchar [note: 'Free‑text description of why the lot was placed on hold.']
  inspection_fail_count varchar [note: 'Number of inspection points that failed during the latest quality check.']
  inspection_pass_count varchar [note: 'Number of inspection points that passed during the latest quality check.']
  last_updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the assembly lot record.']
  lot_name varchar [note: 'Human‑readable name or label for the assembly lot, often used in reports and dashboards.']
  lot_number varchar [note: 'External business identifier assigned to the assembly lot, used for tracking across systems.']
  lot_status varchar [note: 'Overall lifecycle state of the lot, indicating whether it is active, completed, or terminated.']
  package_version varchar [note: 'Version or revision identifier of the package design used for this lot.']
  quality_status varchar [note: 'Result of the most recent quality inspection for the lot.']
  quantity varchar
  start_date date [note: 'Planned or actual date when assembly of the lot began.']
  target_completion_date date [note: 'Planned date by which the lot should be fully assembled.']
  wip_status varchar [note: 'Operational status of the lot within the assembly workflow.']

  Note: 'Master tracking entity for an assembly lot progressing through OSAT or internal packaging operations. Captures lot number, parent wafer lot reference, die count, package type, assembly site (OSAT vendor), current process step, WIP status (queued, in-process, hold, complete), start/target/actual completion dates, cumulative yield, and hold flags. Central WIP identity that all step records, yield results, inspections, and defects reference. SSOT for assembly lot identity and real-time WIP status within the packaging domain. Equipment asset records are owned by the equipment domain; SPC charting is owned by the quality domain.'
}

Table packaging.assembly_yield {
  assembly_yield_id varchar [pk, note: 'Primary key for assembly_yield']
  fab_tool_id varchar [note: 'Identifier of the equipment (e.g., die attach machine, wire bonder) used for this step.']
  primary_assembly_lot_id varchar [note: 'Identifier of the parent assembly run or batch to which this yield step belongs.']
  assembly_yield_status varchar [note: 'Current lifecycle status of the step record.']
  created_timestamp timestamp [note: 'Timestamp when the yield record was first created in the system.']
  cumulative_yield_percent decimal(5,2) [note: 'Running cumulative yield from the start of the assembly run to this step.']
  dppm decimal(10,2) [note: 'Defective parts per million metric for the step.']
  fallout_rate decimal(18,2) [note: 'Assembly fallout rate as a decimal ratio']
  first_pass_yield varchar [note: 'First pass yield percentage']
  good_unit_count varchar
  process_step varchar [note: 'Name of the specific packaging process step for which the yield data is recorded.']
  recorded_timestamp timestamp
  scrap_reason_code varchar [note: 'Standardized code describing why units were scrapped.']
  step_end_timestamp timestamp [note: 'Date and time when the process step completed.']
  step_sequence varchar [note: 'Ordinal position of the step within the overall assembly run.']
  step_start_timestamp timestamp [note: 'Date and time when the process step began.']
  units_in varchar [note: 'Number of dies or packages entering the process step.']
  units_out varchar [note: 'Number of good dies or packages exiting the process step.']
  units_scrapped varchar [note: 'Number of dies or packages discarded during the step.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the yield record.']
  yield_percent decimal(5,2) [note: 'Yield for the step expressed as a percentage of units_out to units_in.']
  yield_rate decimal(18,2) [note: 'Assembly yield rate as a decimal ratio']

  Note: 'Transactional record capturing assembly yield data at each major process step and at final assembly completion for each lot. Stores lot ID, process step, units in, units out, units scrapped, scrap reason codes, yield percentage, cumulative assembly yield, and DPPM. Also serves as the authoritative record for scrap quantities and loss reasons within the packaging domain. Feeds assembly yield trending, OSAT scorecard, cost of poor quality (COPQ) analysis, and product cost calculations. Distinct from wafer probe yield (owned by test domain).'
}

Table packaging.package_qualification {
  package_qualification_id varchar [pk, note: 'Primary key for package_qualification']
  design_win_id varchar [note: 'Foreign key linking to customer.customer_design_win. Business justification: Customer design wins frequently trigger new package qualifications — the customer\'s application requirements mandate a specific qualification test. Linking package_qualification to customer_design_win']
  ic_design_project_id varchar [note: 'Foreign key linking to design.ic_design_project. Business justification: Package qualification must be tied to the design project to verify that the chosen package meets the design\'s electrical and mechanical requirements.']
  osat_vendor_id varchar [note: 'FK to packaging.osat_vendor.osat_vendor_id — Qualifications are site-specific — a package type must be qualified at each OSAT site independently.']
  primary_packaging_package_type_id varchar [note: 'FK to packaging.package_type']
  program_id varchar [note: 'Foreign key linking to test.test_program. Business justification: Package qualification requires a specific test program; linking provides traceability of which test program validated the package, required for qualification audit.']
  quality_spec_id varchar [note: 'Foreign key linking to quality.quality_spec. Business justification: Package qualification is executed against a quality specification defining pass/fail criteria, test types, and compliance standards. This link enables qualification engineers to enforce spec-driven qu']
  reliability_test_id varchar [note: 'Foreign key linking to quality.reliability_test. Business justification: Package qualification (AEC-Q100, JEDEC JESD47) is directly validated by reliability test results. Qualification engineers must link the qualification record to the specific reliability test that demon']
  sku_id varchar [note: 'FK to product.sku']
  supplier_qualification_id varchar [note: 'Foreign key linking to supply.supplier_qualification. Business justification: IATF 16949 and PPAP require that OSAT vendors performing package qualification are also qualified suppliers. Linking package_qualification to supplier_qualification enables compliance reporting: confi']
  tapeout_id varchar [note: 'Foreign key linking to design.tapeout. Business justification: Qualification results are linked to the specific tapeout to ensure the mask set used matches the qualified package specifications.']
  technology_node_id varchar [note: 'Foreign key linking to fabrication.fabrication_technology_node. Business justification: Package qualification (JEDEC, AEC-Q100) is performed against a specific fabrication technology node. Qualification records must reference the node to ensure the package is certified for that process g']
  tertiary_package_type_id varchar [note: 'FK to packaging.package_type.package_type_id — Qualifications certify specific package types for production. Essential for determining which package types are production-released.']
  test_fab_tool_id varchar [note: 'Foreign key linking to equipment.fab_tool. Business justification: AEC-Q100 and JEDEC package qualification records must reference the specific fab tool used during qualification testing. test_equipment_code is a denormalized string representation of this tool. A pro']
  tool_qualification_id varchar [note: 'Foreign key linking to equipment.tool_qualification. Business justification: Package qualification validity depends on the equipment qualification status of the tools used. Semiconductor quality systems (IATF 16949, AEC-Q100) require that package qualification records referenc']
  approval_date date [note: 'Date the qualification was formally approved for production release.']
  compliance_flag boolean [note: 'Indicator of any special compliance considerations (e.g., automotive, aerospace).']
  cost_currency varchar [note: 'Currency code for the qualification cost.']
  created_timestamp timestamp [note: 'Timestamp when the qualification record was first created in the system.']
  defect_rate_ppm varchar [note: 'Defective parts per million observed in the qualification samples.']
  effective_from date [note: 'Date the qualification becomes effective for manufacturing.']
  effective_until date [note: 'Expiration date of the qualification, if applicable.']
  external_audit_date date [note: 'Scheduled date for the external audit, if required.']
  external_audit_required boolean [note: 'Indicates whether an external audit is mandated for this qualification.']
  notes varchar [note: 'Free‑form comments or observations recorded by the qualification team.']
  pass_fail_criteria varchar [note: 'Defined criteria that determine pass or fail outcomes for each test.']
  qualification_cost_usd decimal(12,2) [note: 'Total cost incurred for the qualification program, expressed in US dollars.']
  qualification_document_number varchar [note: 'Reference to the document that contains the full qualification report.']
  qualification_method varchar [note: 'Approach used for qualification testing.']
  qualification_owner varchar [note: 'Name of the person responsible for managing the qualification program.']
  qualification_result varchar [note: 'Overall outcome of the qualification after evaluating all test criteria.']
  qualification_standard varchar [note: 'Standard or specification against which the package is qualified.']
  qualification_status varchar [note: 'Current lifecycle status of the qualification program.']
  qualification_type varchar [note: 'Category of qualification: new package, package‑product combo, or OSAT site certification.']
  regulatory_compliance varchar [note: 'Regulatory framework(s) the qualification adheres to.']
  revision_number varchar [note: 'Sequential revision number of the qualification record.']
  risk_level varchar [note: 'Assessed risk category of the qualification based on test outcomes.']
  sample_quantity varchar [note: 'Number of sample units tested during qualification.']
  stress_test_matrix varchar [note: 'Set of stress tests applied during qualification (e.g., High Temperature Operating Life, Temperature Cycling).']
  test_duration_hours decimal(6,2) [note: 'Total duration of the qualification test cycle in hours.']
  test_location varchar [note: 'Physical location or facility where the qualification testing was conducted.']
  test_temperature_c decimal(5,2) [note: 'Maximum temperature (in Celsius) applied during stress testing.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the qualification record.']
  version varchar [note: 'Version label for the qualification plan (e.g., v1.0, v2.1).']
  yield_percentage decimal(5,2) [note: 'Percentage of good dies per wafer after qualification testing.']

  Note: 'Master record for package qualification programs executed to certify a new package type, package-product combination, or OSAT site for production release. Captures qualification plan ID, package type, product SKU, qualification standard (JEDEC JESD47, AEC-Q100/Q101, MIL-STD-883), stress test matrix (HTOL, TC, HAST, ESD, latch-up), pass/fail criteria, qualification status, and approval date. SSOT for package qualification certification.'
}

Table packaging.material_lot {
  material_lot_id varchar [pk, note: 'Primary key for material_lot']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Each material lot corresponds to a material master record defining procurement specs, RoHS/REACH compliance, and storage conditions. Linking enables compliance validation and procurement planning. par']
  osat_vendor_id varchar
  primary_material_substrate_bom_id varchar [note: 'FK to packaging.substrate_bom.substrate_bom_id — Material lots received are matched to substrate BOM line items for consumption tracking.']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: Material Traceability and Compliance reports need to link each packaging material lot to its raw material inventory record.']
  supplier_id varchar [note: 'Unique identifier of the external supplier providing the material lot.']
  certificate_of_conformance_ref varchar [note: 'Reference identifier to the Certificate of Conformance document associated with the lot.']
  compliance_document_ref varchar [note: 'Reference to any additional compliance documentation attached to the lot.']
  compliance_itar_status varchar [note: 'ITAR export‑control status of the material lot.']
  compliance_reach_status varchar [note: 'REACH compliance status of the material lot.']
  compliance_rohs_status varchar [note: 'RoHS compliance status of the material lot.']
  cost_per_unit decimal(12,4) [note: 'Standard cost assigned to a single unit of the material.']
  created_timestamp timestamp
  currency_code varchar [note: 'Three‑letter ISO currency code for cost_per_unit.']
  humidity_storage_percent decimal(5,2) [note: 'Recorded relative humidity percentage for the lot\'s storage environment.']
  incoming_inspection_status varchar [note: 'Result of the initial quality inspection performed on receipt of the lot.']
  inspection_failure_reason varchar [note: 'Textual reason for inspection failure, if applicable.']
  inspection_passed boolean [note: 'True if the lot passed all required inspections.']
  lot_number varchar [note: 'Human‑readable identifier assigned to the material lot by the receiving facility.']
  material_description varchar [note: 'Free‑text description of the material, including any special characteristics.']
  material_lot_status varchar [note: 'Current lifecycle status of the material lot within the packaging operation.']
  material_type varchar [note: 'Category of the packaging material (e.g., substrate, lead frame, mold compound). [ENUM-REF-CANDIDATE: substrate|lead_frame|mold_compound|bond_wire|solder_paste|underfill|marking_ink — 7 candidates stripped; promote to reference product]']
  quality_score decimal(5,2) [note: 'Numerical quality rating assigned after inspection (0‑100).']
  quantity_received decimal(12,2) [note: 'Total amount of material received in the lot, expressed in the unit defined by unit_of_measure.']
  quarantine_flag boolean [note: 'Indicates whether the lot is currently placed in quarantine pending further review.']
  received_date date
  received_timestamp timestamp [note: 'Exact date‑time when the material lot was logged into the system.']
  record_audit_created timestamp [note: 'Timestamp when the material lot record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the material lot record.']
  release_date date [note: 'Date the lot was released from quarantine and made available for production.']
  shelf_life_expiry_date date [note: 'Date after which the material lot is considered out‑of‑spec for use.']
  storage_condition varchar [note: 'Required storage environment (e.g., temperature‑controlled, humidity‑controlled).']
  supplier_lot_number varchar [note: 'Lot number provided by the external supplier for traceability.']
  temperature_storage_c decimal(5,2) [note: 'Recorded storage temperature in degrees Celsius for the lot.']
  unit_of_measure varchar [note: 'Measurement unit for quantity_received (e.g., pieces, kilograms).']

  Note: 'Master record for incoming packaging material lots received at the assembly site, including substrates, lead frames, mold compounds, bond wires, solder paste, underfill, and marking inks. Captures material part number, supplier lot number, quantity received, incoming inspection status, Certificate of Conformance (CoC) reference, shelf life expiry, storage conditions, and quarantine/release status. SSOT for packaging-specific material lot identity and incoming quality status. General inventory management is owned by the inventory domain; supplier master data is owned by the supply domain; RoHS/REACH compliance declarations are owned by the compliance domain.'
}

Table supply.supplier {
  supplier_id varchar [pk, note: 'System-generated unique identifier for the supplier record.']
  address_line1 varchar [note: 'First line of the supplier\'s primary address.']
  address_line2 varchar [note: 'Second line of the supplier\'s primary address (optional).']
  approval_date date [note: 'Date when the supplier was approved for procurement.']
  approved_by varchar [note: 'Name of the internal user who approved the supplier onboarding.']
  city varchar [note: 'City component of the supplier\'s primary address.']
  code varchar
  compliance_status varchar [note: 'Current compliance standing of the supplier with internal and external regulations.']
  country_code varchar [note: 'Three‑letter ISO country code of the supplier\'s primary location.']
  created_timestamp timestamp [note: 'Date and time when the supplier record was first created.']
  credit_limit decimal(15,2) [note: 'Maximum credit amount approved for the supplier.']
  currency_code varchar [note: 'Default transaction currency used with the supplier.']
  duns_number varchar [note: 'Dun & Bradstreet unique identifier for the supplier organization.']
  ear_controlled boolean [note: 'Indicates whether the supplier is subject to EAR export controls.']
  export_control_classification varchar [note: 'Export classification code for the supplier\'s products or services.']
  financial_rating varchar [note: 'Credit rating assigned to the supplier based on financial health.']
  global_footprint varchar [note: 'Scope of the supplier\'s operational presence.']
  industry_classification varchar [note: 'Broad industry segment to which the supplier belongs.']
  is_certified_kga boolean [note: 'Indicates whether the supplier holds a KGA (Known Good Assembly) certification.']
  itar_controlled boolean [note: 'Indicates whether the supplier is subject to ITAR export controls.']
  last_audit_date date [note: 'Date of the most recent supplier quality or compliance audit.']
  lead_time_days varchar [note: 'Typical number of days from order placement to delivery.']
  legal_name varchar [note: 'Full legal registered name of the supplier entity.']
  name varchar [note: 'Primary display name of the supplier used in business transactions.']
  notes varchar [note: 'Additional remarks or comments about the supplier.']
  payment_terms varchar [note: 'Standard payment terms negotiated with the supplier.']
  postal_code varchar [note: 'Postal/ZIP code of the supplier\'s primary address.']
  preferred_logistics_partner varchar [note: 'Logistics provider most frequently used for shipments from this supplier.']
  primary_contact_name varchar [note: 'Name of the main contact person for the supplier.']
  primary_email varchar [note: 'Email address of the primary supplier contact.']
  primary_phone varchar [note: 'Telephone number of the primary supplier contact.']
  quality_rating varchar [note: 'Overall quality performance rating based on audits and defect data.']
  registration_number varchar [note: 'Official registration number of the supplier\'s legal entity.']
  risk_score decimal(5,2) [note: 'Aggregated risk score derived from financial, geopolitical, and operational factors.']
  state_province varchar [note: 'State or province of the supplier\'s primary address.']
  supplier_group varchar [note: 'Business grouping used for strategic sourcing and spend analysis.']
  supplier_status varchar [note: 'Current lifecycle status of the supplier record.']
  supplier_type varchar [note: 'Classification of the supplier based on strategic importance and spend volume.']
  sustainability_score decimal(5,2) [note: 'Score reflecting the supplier\'s environmental and social responsibility performance.']
  tax_number varchar [note: 'Government‑issued tax registration number for the supplier.']
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the supplier record.']
  website varchar [note: 'Public website URL of the supplier.']

  Note: 'Master record for all semiconductor supply chain vendors including raw material suppliers, chemical suppliers, gas suppliers, photomask vendors, OSAT partners, and subcontractors. Captures supplier identity, classification (Tier 1/2/3), business registration, DUNS number, geographic footprint, financial health rating, strategic importance, and ITAR/EAR export control classification. SSOT for supplier identity across the supply domain. Sourced from SAP S/4HANA MM Vendor Master.'
}

Table supply.approved_vendor {
  approved_vendor_id varchar [pk, note: 'Primary key for approved_vendor']
  material_master_id varchar [note: 'FK to supply.material_master.material_master_id — AVL records approve a supplier FOR a specific material category. The material_master is the SSOT for what\'s being approved.']
  primary_approved_supplier_id varchar [note: 'Foreign key linking to supply.supplier. Business justification: Each approved vendor record belongs to a single supplier; linking provides parent‑child hierarchy and removes redundant supplier details that may exist in approved_vendor.']
  supplier_qualification_id varchar [note: 'Foreign key linking to supply.supplier_qualification. Business justification: An Approved Vendor List (AVL) entry is the outcome of a formal supplier qualification process. The approved_vendor record should reference the supplier_qualification that authorized the vendor\'s inclu']
  address_line1 varchar [note: 'First line of the vendor\'s street address.']
  address_line2 varchar [note: 'Second line of the vendor\'s street address (optional).']
  approval_date date [note: 'Date on which the vendor was granted approved status.']
  approval_status varchar [note: 'Current qualification status of the vendor within the Approved Vendor List.']
  approved_commodity_scope varchar [note: 'List or description of material categories, chemical families, or process inputs the vendor is qualified to supply.']
  approved_vendor_status varchar [note: 'Overall operational status of the vendor within the enterprise.']
  audit_score decimal(5,2) [note: 'Numerical result of the latest audit (0‑100).']
  city varchar [note: 'City component of the vendor\'s address.']
  compliance_certifications varchar [note: 'Comma‑separated list of certifications (e.g., ISO 9001, IATF 16949, RoHS) held by the vendor.']
  country_code varchar [note: 'Three‑letter ISO 3166‑1 alpha‑3 country code of the vendor\'s primary location.']
  created_timestamp timestamp
  currency varchar [note: 'Currency code used for transactions with the vendor.']
  description varchar [note: 'Free‑form text providing additional context or notes about the vendor.']
  duns_number varchar [note: 'Dun & Bradstreet unique identifier for the vendor organization.']
  expiry_date date [note: 'Date on which the vendor\'s approved status expires unless renewed.']
  financial_rating varchar [note: 'Credit rating assigned to the vendor based on financial health.']
  last_audit_date date [note: 'Date of the most recent supplier audit.']
  lead_time_days varchar [note: 'Average number of calendar days from order placement to material receipt for this vendor.']
  payment_terms varchar [note: 'Standard payment condition agreed with the vendor.']
  postal_code varchar [note: 'Postal or ZIP code of the vendor\'s address.']
  primary_contact_email varchar [note: 'Email address of the vendor\'s primary contact.']
  primary_contact_name varchar [note: 'Name of the main point of contact for the vendor.']
  primary_contact_phone varchar [note: 'Telephone number of the vendor\'s primary contact.']
  quality_tier varchar [note: 'Internal quality classification assigned to the vendor based on performance and compliance.']
  record_audit_created timestamp [note: 'Timestamp when the approved vendor record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the approved vendor record.']
  regulatory_status varchar [note: 'Current status of the vendor with respect to applicable semiconductor regulations.']
  risk_score decimal(5,2) [note: 'Numerical risk rating (0‑100) derived from supply‑risk assessments.']
  state varchar [note: 'State or province component of the vendor\'s address.']
  tax_number varchar [note: 'Vendor\'s tax registration number for invoicing and compliance.']
  updated_timestamp timestamp
  vendor_code varchar [note: 'Internal alphanumeric code used to uniquely identify the vendor within the enterprise.']
  vendor_name varchar [note: 'Full legal name of the supplier organization.']
  vendor_type varchar [note: 'Category of the vendor based on its role in the semiconductor supply chain.']

  Note: 'Approved Vendor List (AVL) records establishing which suppliers are qualified and authorized to supply specific material categories, chemical families, or process inputs to the fab. Tracks qualification status, approval date, expiry date, approved commodity scope, quality tier, and the engineering/procurement authority who granted approval. Supports DFM and process qualification gating. Sourced from Oracle Agile PLM and SAP MM.'
}

Table supply.material_master {
  material_master_id varchar [pk, note: 'System-generated unique identifier for each material master record.']
  supplier_id varchar [note: 'Reference to the approved vendor supplying this material.']
  base_uom varchar [note: 'Standard unit of measure used for inventory and procurement transactions (e.g., kg, L, pcs).']
  batch_management boolean [note: 'True if the material is managed in batches for traceability.']
  country_of_origin varchar [note: 'Three‑letter ISO country code indicating where the material originates.']
  created_timestamp timestamp [note: 'Date and time when the material master record was first created.']
  currency_code varchar [note: 'Three‑letter ISO code of the currency for the standard cost.']
  expiration_date date [note: 'Date after which the material must not be used.']
  hazardous_classification varchar [note: 'Regulatory classification indicating the material\'s hazardous status under RoHS, REACH, and TSCA.']
  lead_time_days varchar [note: 'Average number of days from purchase order issuance to receipt of the material.']
  lifecycle_status varchar [note: 'Current lifecycle state of the material record.']
  lot_size_qty decimal(12,2) [note: 'Standard production or procurement lot size for the material.']
  material_description varchar [note: 'Detailed textual description of the material, including its purpose and key characteristics.']
  material_name varchar [note: 'Human‑readable name or title of the material.']
  material_number varchar [note: 'Business-visible alphanumeric code that uniquely identifies the material across the enterprise.']
  material_type varchar [note: 'Classification of the material by its functional role in semiconductor manufacturing.']
  max_order_qty decimal(12,2) [note: 'Largest quantity that can be ordered in a single purchase order.']
  min_order_qty decimal(12,2) [note: 'Smallest quantity that can be ordered from a supplier.']
  procurement_group varchar [note: 'Organizational group responsible for procuring the material.']
  quality_inspection_required boolean [note: 'True if incoming or in‑process inspection is mandatory for the material.']
  reach_compliant boolean [note: 'True if the material meets the Registration, Evaluation, Authorisation and Restriction of Chemicals (REACH) requirements.']
  reorder_point_qty decimal(12,2) [note: 'Inventory level that triggers a replenishment order.']
  rohs_compliant boolean [note: 'True if the material complies with the Restriction of Hazardous Substances (RoHS) directive.']
  safety_stock_qty decimal(12,2) [note: 'Quantity of material kept on hand to protect against demand or supply variability.']
  serial_management boolean [note: 'True if the material is tracked by serial numbers.']
  shelf_life_days varchar [note: 'Number of days the material can be stored before it expires.']
  standard_cost decimal(15,4) [note: 'Default cost used for valuation and planning, expressed in the base currency.']
  storage_humidity_max_pct decimal(5,2) [note: 'Highest permissible relative humidity percentage for storage.']
  storage_humidity_min_pct decimal(5,2) [note: 'Lowest permissible relative humidity percentage for storage.']
  storage_temperature_max_c decimal(5,2) [note: 'Highest permissible storage temperature in degrees Celsius.']
  storage_temperature_min_c decimal(5,2) [note: 'Lowest permissible storage temperature in degrees Celsius.']
  tsca_compliant boolean [note: 'True if the material is compliant with the US Toxic Substances Control Act (TSCA).']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the material master record.']
  valuation_class varchar [note: 'Key for grouping materials with similar accounting treatment.']

  Note: 'Authoritative master record for all procured materials used in semiconductor manufacturing: silicon wafer substrates, process chemicals (slurries, etchants, photoresists), specialty gases (silane, nitrogen, argon), photomasks, packaging substrates, lead frames, bonding wire, and consumables. Captures material number, description, material type, base unit of measure, hazardous material classification (RoHS/REACH/TSCA), storage conditions, shelf life, procurement lead time, safety stock levels, reorder points, and lot sizing parameters. SSOT for material identity and procurement parameters within the supply domain.'
}

Table supply.purchase_order {
  purchase_order_id varchar [pk, note: 'System-generated unique identifier for the purchase order record.']
  primary_purchase_supplier_id varchar [note: 'Unique identifier of the supplier (vendor) to which the purchase order is issued.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Purchase orders specify destination storage location for delivery in semiconductor ERP. purchase_order has storage_location (plain attr, denormalized). This link enables receiving dock assignment, inv']
  actual_delivery_date date [note: 'Date when goods/services were actually received.']
  approval_date date [note: 'Date when the purchase order was approved.']
  approval_status varchar [note: 'Current approval state of the purchase order.']
  compliance_flags varchar [note: 'Semicolon‑separated list of compliance indicators (e.g., RoHS, REACH).']
  created_timestamp timestamp [note: 'Timestamp when this purchase order record was first captured in the data lake.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary amounts on the PO.']
  delivery_schedule varchar [note: 'Free‑text description of delivery windows or milestones.']
  discount_amount decimal(18,2) [note: 'Monetary value of the discount applied.']
  discount_percent decimal(5,2) [note: 'Percentage discount granted on the gross amount.']
  expected_delivery_date date [note: 'Planned date for goods/services to be delivered.']
  export_control_classification varchar [note: 'Export classification code (e.g., EAR99, ITAR, ECCN) for the items on the PO.']
  freight_amount decimal(18,2) [note: 'Monetary cost of freight/shipping.']
  freight_terms varchar [note: 'Responsibility for freight costs.']
  incoterms varchar [note: 'International commercial terms defining delivery responsibilities. [ENUM-REF-CANDIDATE: EXW|FCA|FOB|CFR|CIF|DAP|DDP — 7 candidates stripped; promote to reference product]']
  is_ear_controlled boolean [note: 'Indicates whether the PO is subject to U.S. Export Administration Regulations.']
  lead_time_days varchar [note: 'Planned number of days from PO issuance to expected receipt.']
  material_description varchar [note: 'Human‑readable description of the material or service.']
  material_number varchar [note: 'Identifier of the material or service being procured.']
  order_date timestamp [note: 'Timestamp when the purchase order was initially created/submitted.']
  payment_terms varchar [note: 'Agreed payment schedule and conditions for the purchase order.']
  plant varchar [note: 'SAP plant code where the goods are to be received.']
  po_number varchar [note: 'External business identifier assigned to the purchase order by the procurement system.']
  purchase_group varchar [note: 'Organizational group responsible for the procurement.']
  purchase_order_status varchar [note: 'Current lifecycle state of the purchase order.']
  purchase_order_type varchar [note: 'Classification of the PO based on its procurement strategy.']
  purchase_supplier_fk varchar [note: 'FK to supply.supplier.supplier_id — Every PO is issued TO a supplier. This is a day-1 mandatory FK.']
  purchasing_org varchar [note: 'SAP purchasing organization that owns the PO.']
  quantity varchar [note: 'Number of units ordered for the material.']
  release_date date [note: 'Date when the purchase order was released to the supplier.']
  tax_code varchar [note: 'Code representing the tax jurisdiction and rate applied.']
  total_gross_amount decimal(18,2) [note: 'Total amount before taxes, discounts, and freight.']
  total_net_amount decimal(18,2) [note: 'Final payable amount after taxes, discounts, and freight.']
  total_tax_amount decimal(18,2) [note: 'Aggregate tax amount applied to the purchase order.']
  unit_of_measure varchar [note: 'Measurement unit for the ordered quantity (e.g., EA, KG, L).']
  unit_price decimal(18,4) [note: 'Agreed price per unit of the material before taxes and discounts.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the purchase order record.']

  Note: 'Procurement purchase orders issued to qualified suppliers for raw materials, process chemicals, gases, photomasks, equipment spare parts, and subcontracted services (OSAT assembly/test). Captures PO number, supplier, line items, ordered quantities, agreed unit price, currency, delivery schedule, Incoterms, payment terms, and export control classification (EAR/ITAR). Represents the legally binding procurement commitment. Sourced from SAP S/4HANA MM (EKKO/EKPO).'
}

Table supply.po_line {
  po_line_id varchar [pk, note: 'Unique surrogate identifier for the purchase order line record.']
  primary_po_material_master_id varchar [note: 'FK to supply.material_master.material_master_id — Each PO line procures a specific material. Essential for material traceability and MRP consumption.']
  primary_purchase_order_id varchar [note: 'FK to supply.purchase_order.purchase_order_id — Header-line pattern: every PO line belongs to exactly one PO. Critical structural relationship.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: PO lines specify the destination storage location for delivery in semiconductor ERP. po_line has storage_location (plain attr, denormalized). This link enables proper goods receipt routing to the corr']
  supplier_id varchar [note: 'Unique identifier of the supplier providing the material.']
  account_assignment_code varchar [note: 'Identifier of the specific cost center, WBS element, or order linked to this line.']
  account_assignment_type varchar [note: 'Classification of the cost object (cost center, WBS element, or internal order).']
  contract_number varchar [note: 'Reference to a framework contract governing this line, if applicable.']
  created_timestamp timestamp [note: 'Date and time when the purchase order line record was created.']
  currency varchar [note: 'Three‑letter ISO currency code for the monetary values on the line.']
  currency_code varchar
  delivery_date date [note: 'Date by which the supplier should deliver the material.']
  discount_amount decimal(15,4) [note: 'Total discount value applied to the line.']
  goods_receipt_status varchar [note: 'Current status of goods receipt for this line.']
  incoterms varchar [note: 'International commercial terms defining delivery responsibilities.']
  is_final_invoice boolean [note: 'Indicates whether this line has been invoiced in its final form.']
  is_service_line boolean [note: 'True if the line represents a service rather than a material.']
  lead_time_days varchar [note: 'Planned number of days from order to delivery for this line.']
  line_number varchar [note: 'Sequential number of the line within the purchase order.']
  line_status varchar [note: 'Current processing status of the purchase order line.']
  line_total_amount decimal(15,4) [note: 'Gross amount before tax and discount (ordered_quantity * net_price).']
  material_description varchar [note: 'Human‑readable description of the material.']
  material_number varchar [note: 'Master data identifier for the material or component being procured.']
  net_amount decimal(15,4) [note: 'Net monetary value of the line after tax and discount.']
  net_price decimal(15,4) [note: 'Net price per unit of the material before taxes and discounts.']
  ordered_quantity decimal(15,3) [note: 'Quantity of the material requested on this line.']
  plant varchar [note: 'Code of the manufacturing plant or site receiving the material.']
  price_unit varchar [note: 'Number of units that the net price applies to (e.g., price per 1000 pieces).']
  purchase_group varchar [note: 'Organizational group responsible for the procurement.']
  quantity decimal(18,4)
  receipt_date date [note: 'Date on which the goods were received.']
  receipt_quantity decimal(15,3) [note: 'Quantity of material that has been received against this line.']
  supply_risk_score varchar [note: 'Risk rating (0‑100) assessing supplier and material availability risk.']
  tax_amount decimal(15,4) [note: 'Monetary tax amount calculated for the line.']
  tax_code varchar [note: 'Tax classification code used to calculate tax for the line.']
  unit_of_measure varchar [note: 'Unit in which the ordered quantity is expressed.']
  unit_price decimal(18,4)
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the line record.']
  vendor_material_number varchar [note: 'Supplier\'s own part number for the material.']

  Note: 'Individual line items within a purchase order, each representing a distinct material or service being procured. Captures line number, material number, ordered quantity, unit of measure, net price, delivery date, plant/storage location destination, account assignment (cost center or WBS element), and goods receipt status. Enables granular tracking of multi-material POs and partial deliveries. Sourced from SAP S/4HANA MM (EKPO).'
}

Table supply.goods_receipt {
  goods_receipt_id varchar [pk, note: 'System-generated unique identifier for the goods receipt record.']
  inbound_shipment_id varchar [note: 'Foreign key linking to supply.inbound_shipment. Business justification: A goods receipt is the warehouse/fab confirmation that an inbound shipment has physically arrived and been processed. The inbound_shipment tracks the logistics movement; the goods_receipt records the ']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: A goods receipt records the physical receipt of a specific material. material_master is the authoritative record for all procured materials. goods_receipt currently stores material_number and material']
  po_line_id varchar
  primary_goods_purchase_order_id varchar [note: 'System identifier of the purchase order associated with the receipt.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Goods receipts post materials to specific storage locations (receiving docks, quarantine areas, cleanrooms) in the fab. goods_receipt has storage_location (plain attr, denormalized). This link enables']
  supplier_id varchar [note: 'Unique identifier of the supplier providing the goods.']
  accepted_quantity decimal(18,4)
  batch_number varchar [note: 'Identifier for the production batch or lot of the received material.']
  compliance_flag boolean [note: 'Indicates whether the material complies with applicable regulations (e.g., RoHS).']
  compliance_status varchar [note: 'Detailed compliance status of the material.']
  created_timestamp timestamp [note: 'Timestamp when the goods receipt record was first created.']
  currency_code varchar [note: 'ISO 4217 three‑letter code of the currency used for monetary values.']
  external_reference varchar [note: 'Any external system reference linked to this receipt (e.g., logistics tracking ID).']
  goods_purchase_order_fk varchar [note: 'FK to supply.purchase_order.purchase_order_id — Goods receipts are posted against a purchase order. Core three-way match requirement.']
  goods_receipt_status varchar [note: 'Current lifecycle status of the receipt (e.g., posted, reversed, pending).']
  gross_amount decimal(15,2) [note: 'Total monetary value of the receipt before taxes and discounts.']
  inspection_lot_number varchar [note: 'Reference to the quality inspection lot created for this receipt.']
  inspection_status varchar
  lead_time_days varchar [note: 'Number of calendar days between purchase order issuance and goods receipt.']
  lot_number varchar
  movement_type varchar [note: 'SAP movement type code indicating the nature of the receipt (e.g., 101 = goods receipt).']
  net_amount decimal(15,2) [note: 'Net monetary value after tax and discounts.']
  notes varchar [note: 'Free‑text field for additional comments or observations.']
  plant_code varchar [note: 'Identifier of the manufacturing plant or fab where receipt is posted.']
  posting_date date [note: 'Date on which the receipt is posted to financial accounting.']
  quality_status varchar [note: 'Result of the incoming quality inspection for the received material.']
  quantity_received decimal(15,3) [note: 'Amount of material physically received, expressed in the unit of measure.']
  receipt_date date [note: 'Calendar date when the goods were physically received.']
  receipt_number varchar [note: 'Business identifier assigned to the receipt document (e.g., GR number).']
  receipt_timestamp timestamp [note: 'Exact date and time when the receipt was recorded in the system.']
  received_by varchar [note: 'Name or employee identifier of the person who logged the receipt.']
  received_quantity decimal(18,4)
  rejected_quantity decimal(18,4)
  risk_assessment_score decimal(5,2) [note: 'Numeric score representing supply risk for the received material (higher = higher risk).']
  supplier_batch_reference varchar [note: 'Reference supplied by the vendor for the batch (e.g., vendor lot number).']
  tax_amount decimal(15,2) [note: 'Tax component associated with the receipt.']
  unit_of_measure varchar [note: 'Unit in which the quantity is measured (e.g., each, kilogram, liter, meter).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the goods receipt record.']
  valuation_type varchar [note: 'Valuation category for the material (e.g., S = standard, U = moving average, V = special).']

  Note: 'Records the physical receipt of materials and goods at the fab or warehouse against a purchase order. Captures GR document number, posting date, received quantity, unit of measure, storage location, batch number, quality inspection lot reference, and movement type. Triggers inventory update and initiates incoming quality inspection. Sourced from SAP S/4HANA MM (MSEG/MKPF — movement type 101).'
}

Table supply.supplier_qualification {
  supplier_qualification_id varchar [pk, note: 'System-generated unique identifier for each supplier qualification record.']
  family_id varchar [note: 'Foreign key linking to product.family. Business justification: Semiconductor supplier qualifications are frequently scoped at product family level (e.g., a foundry qualified for an entire MCU family under IATF 16949). Supply quality teams track family-level quali']
  nda_agreement_id varchar [note: 'Foreign key linking to customer.nda_agreement. Business justification: Semiconductor supplier qualification requires a valid NDA before sharing process specifications or IP during audits. The \'NDA-Gated Supplier Qualification\' process mandates this link to verify NDA cov']
  primary_supplier_id varchar [note: 'Identifier of the supplier being qualified, linking to the supplier master record.']
  tertiary_supplier_id varchar [note: 'FK to supply.supplier.supplier_id — Qualification records assess a specific supplier. Cannot exist without supplier reference.']
  approval_date date [note: 'Date on which the qualification was formally approved.']
  audit_date date [note: 'Calendar date on which the audit was performed.']
  audit_score decimal(5,2)
  audit_team varchar [note: 'Comma‑separated list of auditors and subject‑matter experts who conducted the audit.']
  audit_type varchar [note: 'Classification of the audit execution: initial qualification, routine surveillance, or for‑cause audit.']
  compliance_standards varchar [note: 'Semicolon‑separated list of regulatory or industry standards the qualification satisfies.']
  corrective_action_due_date date [note: 'Date by which all corrective actions must be completed.']
  corrective_action_plan varchar [note: 'Detailed plan describing corrective actions required to resolve audit findings.']
  corrective_action_status varchar [note: 'Current status of the corrective action plan.']
  created_timestamp timestamp [note: 'Timestamp when the qualification record was first created in the system.']
  expiry_date date
  findings_severity varchar [note: 'Highest severity level of audit findings identified during the assessment.']
  findings_summary varchar [note: 'Narrative summary of audit observations, non‑conformances, and strengths.']
  notes varchar [note: 'Free‑form comments or additional information captured by the qualification team.']
  overall_rating varchar [note: 'Result of the qualification audit after considering findings and corrective actions.']
  qualification_date date
  qualification_number varchar [note: 'External reference number assigned to the qualification program for tracking and audit purposes.']
  qualification_program_type varchar [note: 'Type of qualification program: initial onboarding, scheduled periodic review, or change‑triggered re‑qualification.']
  qualification_scope varchar [note: 'Scope of the qualification assessment covering quality system audit, process capability, material certification, or a combination.']
  qualification_status varchar [note: 'Current lifecycle status of the qualification record.']
  qualification_type varchar
  qualified_by varchar
  risk_assessment_score decimal(5,2) [note: 'Quantitative risk score (0‑100) derived from supplier risk assessment models.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the qualification record.']
  validity_end_date date [note: 'Date when the supplier qualification expires unless re‑qualified.']
  validity_start_date date [note: 'Date when the supplier qualification becomes effective.']

  Note: 'Formal supplier qualification lifecycle records encompassing the full assessment, audit, and approval process for onboarding new suppliers or re-qualifying existing ones. Captures qualification program type (initial, periodic, change-triggered), assessment scope (quality system audit, process capability, material certification review), on-site and remote audit execution details (audit type — initial qualification, surveillance, for-cause; audit team composition; findings by severity — critical/major/minor; corrective action plans and closure tracking; overall audit rating), qualification criteria and pass/fail results, validity period, and approving engineer. SSOT for all supplier audit and qualification activity within the supply domain. Supports IATF 16949, ISO 9001, and SEMI standards supplier approval requirements.'
}

Table supply.material_requirement_plan {
  material_requirement_plan_id varchar [pk, note: 'Unique surrogate key for each material requirement plan record.']
  backlog_position_id varchar [note: 'Foreign key linking to order.backlog_position. Business justification: MRP planning runs in semiconductors consume backlog snapshots as demand inputs. Linking MRP records to the backlog_position that drove the requirement enables S&OP backlog-to-supply reconciliation, pu']
  demand_order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: MRP gross requirements in semiconductors are driven by customer order line demand. Linking MRP to the originating order line enables S&OP demand-supply gap analysis, backlog-to-plan reconciliation, an']
  forecast_id varchar [note: 'Foreign key linking to sales.sales_forecast. Business justification: S&OP process: MRP runs in semiconductors are driven by sales forecasts as the primary demand signal. Linking MRP to the source sales_forecast enables full demand-to-supply traceability, supports S&OP ']
  ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: MRP execution in semiconductor fabs is driven by demand for specific IC catalog products. Planners trace planned orders to the IC driving demand for capacity allocation, lead-time management, and supp']
  primary_material_master_id varchar [note: 'Surrogate key referencing the material master record.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: MRP run outputs define planned procurement quantities and timing. When procurement acts on an MRP plan, a purchase order is created to fulfill the planned requirement. This FK links the MRP planned or']
  raw_material_id varchar [note: 'Foreign key linking to inventory.raw_material. Business justification: MRP plans are generated specifically for raw materials (silicon wafers, process chemicals) to drive replenishment. Linking MRP to raw_material enables planners to see which raw material record the pla']
  supplier_id varchar [note: 'Reference to the approved supplier that will fulfill the planned order.']
  tertiary_material_master_id varchar [note: 'FK to supply.material_master.material_master_id — MRP outputs are calculated for specific materials.']
  batch_managed_flag boolean [note: 'Flag indicating if the material requires batch tracking (Y) or not (N).']
  created_timestamp timestamp
  creation_timestamp timestamp [note: 'Date‑time when the MRP system generated this record.']
  currency_code varchar [note: 'Currency in which the planned cost is expressed.']
  demand_date date [note: 'Date on which the underlying demand (e.g., production start) is scheduled.']
  demand_quantity decimal(15,3) [note: 'Quantity of the material required by production orders or forecasts.']
  exception_message varchar [note: 'Textual description of any planning exception (e.g., shortfall, excess).']
  gross_requirement_qty decimal(18,4)
  is_fixed_lot boolean [note: 'True if the lot size is fixed by engineering, otherwise False.']
  last_updated_timestamp timestamp [note: 'Date‑time of the latest modification (e.g., quantity change, status update).']
  lead_time_days varchar [note: 'Number of calendar days from order placement to receipt of material.']
  lot_sizing_procedure varchar [note: 'Algorithm used to calculate the lot size for the planned order.']
  material_requirement_plan_status varchar [note: 'Operational status indicating whether the line is still in planning, released to procurement, or flagged.']
  mrp_controller varchar [note: 'Code of the person or system that owns the MRP parameters for the material.']
  mrp_type varchar [note: 'Classification of the planning method used for this line.']
  net_requirement_qty decimal(18,4)
  plan_period varchar
  planned_cost decimal(15,2) [note: 'Estimated monetary cost of the planned quantity based on standard price.']
  planned_delivery_date date [note: 'Target date by which the material must be available for production.']
  planned_order_qty decimal(18,4)
  planned_quantity decimal(15,3) [note: 'Quantity of material that the MRP run recommends procuring.']
  planning_horizon_end date [note: 'Last day of the time window considered by the MRP run.']
  planning_horizon_start date [note: 'First day of the time window considered by the MRP run.']
  planning_run_date date [note: 'Calendar date on which the MRP calculation was performed.']
  planning_run_number varchar [note: 'Identifier of the MRP execution that generated this plan.']
  plant_code varchar [note: 'Identifier of the fabrication plant or site for which the plan is created.']
  procurement_group varchar [note: 'Organizational unit within supply chain that owns the procurement process.']
  reorder_point_quantity decimal(15,3) [note: 'Inventory level that triggers a new procurement recommendation.']
  requirement_date date
  safety_stock_quantity decimal(15,3) [note: 'Quantity kept as buffer to protect against demand or supply variability.']
  unit_of_measure varchar [note: 'Standard unit in which the planned quantity is expressed.']

  Note: 'Material Requirements Planning (MRP) run outputs defining planned procurement quantities and timing for all fab materials based on production schedules, wafer start plans, safety stock levels, and reorder points. Captures planning run date, material, plant, planned order quantity, planned delivery date, MRP type, lot sizing procedure, and exception messages (shortfall, excess, rescheduling). Sourced from SAP S/4HANA PP-MRP (MDKP/MDTB).'
}

Table supply.inbound_shipment {
  inbound_shipment_id varchar [pk, note: 'System-generated unique identifier for the inbound shipment record.']
  po_line_id varchar [note: 'Foreign key linking to supply.po_line. Business justification: An inbound shipment fulfills specific PO line items, not just the PO header. inbound_shipment already has FKs to purchase_order (header level), but line-level traceability is essential in semiconducto']
  primary_inbound_purchase_order_id varchar [note: 'FK to supply.purchase_order.purchase_order_id — Inbound shipments deliver against purchase orders. Required for logistics tracking and landed cost.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Inbound shipments are directed to specific storage locations (receiving docks, quarantine areas) in the fab. Linking inbound_shipment to storage_location enables warehouse slotting, receiving dock ass']
  supplier_id varchar [note: 'Identifier of the supplier providing the material.']
  actual_arrival_date date [note: 'Date on which the shipment was physically received.']
  bill_of_lading_number varchar [note: 'Reference number of the bill of lading document.']
  cold_chain_required boolean [note: 'Indicates whether temperature‑controlled handling is required.']
  compliance_status varchar [note: 'Overall compliance assessment for the shipment (e.g., compliant, exception, pending).']
  created_timestamp timestamp [note: 'Timestamp when the inbound shipment record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code of the freight cost.']
  customs_declaration_number varchar [note: 'Identifier of the customs entry for the shipment.']
  delivery_window_end date [note: 'End date of the agreed delivery window.']
  delivery_window_start date [note: 'Start date of the agreed delivery window.']
  destination_plant varchar [note: 'Identifier of the fab or warehouse receiving the shipment.']
  ear_controlled boolean [note: 'Indicates whether the shipment contains items subject to Export Administration Regulations.']
  estimated_arrival_date date [note: 'Planned date on which the shipment is expected to arrive.']
  export_control_classification varchar [note: 'Export control classification code (e.g., ECCN) for the shipment.']
  freight_cost decimal(12,2) [note: 'Total cost charged by the carrier for transporting the shipment.']
  hazardous_goods_classification varchar [note: 'Classification code for hazardous materials per UN/ADR.']
  inbound_po_fk varchar [note: 'FK to supply.purchase_order.purchase_order_id — Inbound shipments deliver materials against purchase orders. Required for supply continuity monitoring and landed cost calculation.']
  inbound_shipment_status varchar [note: 'Current lifecycle status of the inbound shipment.']
  incoterms varchar [note: 'International commercial term defining responsibility and cost allocation.']
  itar_controlled boolean [note: 'Indicates whether the shipment contains items subject to ITAR regulations.']
  lead_time_days varchar [note: 'Planned number of days from shipment dispatch to arrival.']
  notes varchar [note: 'Free‑form comments or special instructions related to the shipment.']
  origin_country varchar [note: 'Three‑letter ISO country code of the shipment origin.']
  packaging_type varchar [note: 'Description of the primary packaging used (e.g., pallet, container, drum).']
  risk_score decimal(5,2) [note: 'Quantitative risk rating for the shipment based on supplier and logistics factors.']
  ship_date date
  shipment_number varchar [note: 'External shipment reference number assigned by the carrier or logistics provider.']
  shipment_status varchar
  shipment_timestamp timestamp [note: 'Timestamp of the primary shipment event (e.g., departure from supplier).']
  temperature_max_c decimal(5,2) [note: 'Maximum allowable temperature for the shipment when cold chain is required.']
  temperature_min_c decimal(5,2) [note: 'Minimum allowable temperature for the shipment when cold chain is required.']
  tracking_number varchar [note: 'Unique tracking identifier provided by the carrier.']
  transport_mode varchar [note: 'Mode of transport used for the inbound shipment.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the inbound shipment record.']
  volume_m3 decimal(10,3) [note: 'Total cubic volume of the shipment.']
  weight_kg decimal(10,2) [note: 'Total weight of the shipment in kilograms.']

  Note: 'Inbound logistics records tracking the physical movement of procured materials from supplier origin to fab or warehouse destination. Captures shipment number, carrier, mode of transport (air, sea, road, courier), origin country, destination plant, estimated and actual arrival dates, freight cost, customs declaration number, Incoterms, hazardous goods classification, and cold chain requirements for temperature-sensitive chemicals. Supports landed cost calculation and supply continuity monitoring.'
}

Table supply.material_certification {
  material_certification_id varchar [pk, note: 'System-generated unique identifier for each material certification record.']
  goods_receipt_id varchar [note: 'Foreign key linking to supply.goods_receipt. Business justification: Material certifications (CoC, RoHS, REACH, PCN documents) are matched to specific incoming lots at the point of goods receipt. This FK links the certification document to the physical receipt event, e']
  primary_material_master_id varchar [note: 'FK to supply.material_master.material_master_id — Certifications (CoC/CoA) are issued for specific materials. Required for incoming quality release.']
  primary_material_supplier_id varchar [note: 'Identifier of the supplier that issued the certification.']
  tertiary_material_master_id varchar [note: 'FK to supply.material_master.material_master_id — Material certifications (CoC/CoA) are issued for specific materials. Required for incoming quality release decisions.']
  approval_date date [note: 'Date the certification was approved for production release.']
  certification_number varchar
  certification_status varchar [note: 'Current lifecycle status of the certification.']
  certification_type varchar [note: 'Category of certification document, such as Certificate of Conformance, Certificate of Analysis, RoHS compliance, REACH compliance, TSCA certification, or Product Change Notification.']
  compliance_standard varchar [note: 'Regulatory or industry standard to which the certification attests compliance.']
  created_timestamp timestamp [note: 'Timestamp when the certification record was first created in the system.']
  document_reference varchar [note: 'Path or URL to the electronic certification document.']
  document_version varchar [note: 'Version identifier of the certification document.']
  expiry_date date [note: 'Date the certification expires or becomes invalid.']
  issue_date date [note: 'Date the certification was issued by the supplier.']
  issuing_body varchar [note: 'Name of the organization or department that issued the certification.']
  lot_number varchar
  material_lot_number varchar [note: 'Lot identifier assigned to the batch of material covered by the certification.']
  material_supplier_fk varchar [note: 'FK to supply.supplier.supplier_id — Certifications are issued by a specific supplier. Required to trace compliance evidence to its source.']
  notes varchar [note: 'Free‑text field for additional remarks or observations.']
  pcn_change_description varchar [note: 'Detailed description of the change communicated in the PCN.']
  pcn_change_type varchar [note: 'Category of change described in the PCN.']
  pcn_customer_notification_required boolean [note: 'Indicates whether the PCN must be communicated to customers.']
  pcn_effective_date date [note: 'Date when the PCN change becomes effective.']
  pcn_impact_assessment varchar [note: 'Summary of the impact of the PCN on downstream processes and customers.']
  pcn_number varchar [note: 'Identifier of the PCN associated with this material certification, if applicable.']
  pcn_requalification_decision varchar [note: 'Decision on whether the material requires re‑qualification after the PCN.']
  risk_score decimal(5,2) [note: 'Numerical risk rating associated with the material based on certification and supplier data.']
  supplier_fk varchar [note: 'FK to supply.supplier.supplier_id — Certifications are issued BY a specific supplier for their material lots.']
  test_result varchar [note: 'Outcome of the compliance test associated with the certification.']
  test_units varchar [note: 'Units of measurement for the test value, such as ppm, mg/kg, or %.']
  test_value decimal(12,4) [note: 'Quantitative result of the test (e.g., concentration, impurity level).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the certification record.']

  Note: 'Supplier-originated material compliance documents including quality certifications and product change notifications. Captures Certificate of Conformance (CoC), Certificate of Analysis (CoA), RoHS compliance declarations, REACH SVHC declarations, TSCA certifications, and Product Change Notifications (PCNs). For certifications: certification type, issuing supplier, material lot number, test results, compliance standard, issue date, expiry date, and document reference. For PCNs: PCN number, supplier, affected material or component, change type (process, material, site, EOL), change description, effective date, impact assessment, required customer notification obligation, and re-qualification decision. SSOT for all supplier-originated material compliance and change documentation within the supply domain. Required for regulatory compliance, incoming quality release, process stability, and customer PCN pass-through obligations.'
}

