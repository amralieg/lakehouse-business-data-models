  component_description varchar [note: 'The component description of the bom line record in the product domain.']
  component_part_number varchar [note: 'The component part number of the bom line record in the product domain.']
  component_type varchar [note: 'The component type of the bom line record in the product domain.']
  conflict_minerals_status varchar [note: 'The conflict minerals status of the bom line record in the product domain.']
  cost_currency_code varchar [note: 'Coded value representing the cost currency code of the bom line product record.']
