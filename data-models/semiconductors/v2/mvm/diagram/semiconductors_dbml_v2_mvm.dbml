  Note: 'Semiconductor process technology node definition with lithography, architecture, and qualification parameters.'
}

Table product.product_spec {
  product_spec_id varchar [pk, note: 'Primary key']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: Product specs (thermal resistance, max power, operating temperature) are package-specific. Datasheet generation, customer qualification reports, and AEC-Q100 submissions require spec-to-package linkag']
  primary_ic_catalog_id varchar [note: 'Unique identifier for the primary ic catalog record within the product spec product entity.']
  primary_product_ic_catalog_id varchar [note: 'FK to product IC catalog']
  process_node_id varchar [note: 'Foreign key linking to product.process_node. Business justification: product_spec.process_node_nm is a denormalized integer (nanometers) that duplicates data already captured in process_node.minimum_feature_size_nm. Adding spec_process_node_id as a FK to process_node.p']
  to_ic_catalog_id varchar [note: 'FK to IC catalog']
  approval_date date [note: 'The approval date associated with the product spec product record.']
  approved_by varchar [note: 'The approved by of the product spec record in the product domain.']
  automotive_grade varchar [note: 'The automotive grade of the product spec record in the product domain.']
  characterization_date date [note: 'The characterization date associated with the product spec product record.']
  created_timestamp timestamp [note: 'The created timestamp of the product spec record in the product domain.']
  data_retention_years varchar [note: 'The data retention years of the product spec record in the product domain.']
  die_area_achieved_mm2 decimal(12,6) [note: 'Die area achieved']
  die_area_target_mm2 decimal(12,6) [note: 'Die area target']
  dynamic_power_achieved_mw decimal(12,4) [note: 'Dynamic power achieved']
  dynamic_power_target_mw decimal(12,4) [note: 'Dynamic power target']
  endurance_cycles varchar [note: 'The endurance cycles of the product spec record in the product domain.']
  esd_protection_level_kv decimal(6,3) [note: 'ESD protection level']
  functional_safety_rating varchar [note: 'The functional safety rating of the product spec record in the product domain.']
  gate_count varchar [note: 'The gate count of the product spec record in the product domain.']
  interface_protocols varchar [note: 'The interface protocols of the product spec record in the product domain.']
  io_count varchar [note: 'The io count of the product spec record in the product domain.']
  last_modified_timestamp timestamp [note: 'The last modified timestamp of the product spec record in the product domain.']
  leakage_power_achieved_mw decimal(12,4) [note: 'Leakage power achieved']
  leakage_power_target_mw decimal(12,4) [note: 'Leakage power target']
  max_frequency_achieved_mhz decimal(12,3) [note: 'Max frequency achieved']
  max_frequency_target_mhz decimal(12,3) [note: 'Max frequency target']
  memory_configuration varchar [note: 'The memory configuration of the product spec record in the product domain.']
  model_lineage_source varchar [note: 'The model lineage source of the product spec record in the product domain.']
  modified_timestamp timestamp [note: 'The modified timestamp of the product spec record in the product domain.']
  notes varchar [note: 'The notes of the product spec record in the product domain.']
  operating_condition_corner varchar [note: 'The operating condition corner of the product spec record in the product domain.']
  operating_temperature_max_c decimal(6,2) [note: 'Max operating temperature']
  operating_temperature_min_c decimal(6,2) [note: 'Min operating temperature']
  operating_voltage_max_v decimal(6,3) [note: 'Max operating voltage']
  operating_voltage_min_v decimal(6,3) [note: 'Min operating voltage']
  operating_voltage_nominal_v decimal(6,3) [note: 'Nominal operating voltage']
  product_spec_status varchar [note: 'The status of the product spec record in the product domain.']
  reach_compliant boolean [note: 'The reach compliant of the product spec record in the product domain.']
  rohs_compliant boolean [note: 'The rohs compliant of the product spec record in the product domain.']
  security_features varchar [note: 'The security features of the product spec record in the product domain.']
  spec_status varchar [note: 'The spec status of the product spec record in the product domain.']
  transistor_architecture varchar [note: 'The transistor architecture of the product spec record in the product domain.']
  transistor_count varchar [note: 'The transistor count of the product spec record in the product domain.']
  version varchar [note: 'Version or revision identifier of the product spec product record.']

  Note: 'Detailed product specification covering electrical, thermal, and mechanical parameters with target vs achieved metrics.'
}

Table product.bom {
  bom_id varchar [pk, note: 'Primary key']
  packaging_package_type_id varchar [note: 'Foreign key linking to packaging.package_type. Business justification: BOM material sets (substrate, mold compound, die attach) differ by package type. Procurement and manufacturing engineering reference BOM-to-package-type for correct material selection, ECO management,']
