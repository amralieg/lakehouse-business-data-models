  bom_status varchar [note: 'BOM status']
  bom_type varchar [note: 'The type of the bom record in the product domain.']
  conflict_minerals_compliant_flag boolean [note: 'Conflict minerals compliant']
  cost_currency_code varchar [note: 'Coded value representing the cost currency code of the bom product record.']
