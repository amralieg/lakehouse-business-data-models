  itar_controlled_flag boolean [note: 'The itar controlled flag of the bom record in the product domain.']
  last_modified_timestamp timestamp [note: 'The last modified timestamp of the bom record in the product domain.']
  lot_size decimal(18,6) [note: 'The lot size of the bom record in the product domain.']
  ltb_notification_date date [note: 'The ltb notification date associated with the bom product record.']
