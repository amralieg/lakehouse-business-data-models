  bom_line_id varchar [pk, note: 'Primary key']
  component_ic_catalog_id varchar [note: 'Foreign key linking to product.ic_catalog. Business justification: bom_line.component_part_number and manufacturer_part_number are free-text fields that may reference ICs in the catalog. When a BOM component is itself an IC product in the catalog (common in SoC and m']
