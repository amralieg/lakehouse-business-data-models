  total_component_count varchar [note: 'The total component count of the bom record in the product domain.']
  total_material_cost decimal(18,4) [note: 'The total material cost of the bom record in the product domain.']
  usage varchar [note: 'The usage of the bom record in the product domain.']

  Note: 'Bill of materials header defining the component structure for an IC product with compliance and cost tracking.'
}

