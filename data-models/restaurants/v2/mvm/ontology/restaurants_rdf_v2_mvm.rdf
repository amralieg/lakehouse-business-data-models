ind:laborPctEvening rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Evening' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the evening shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPctMidday rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Midday' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the midday shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPctMorning rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Morning' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the morning shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPctNight rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Night' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the night shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date covered by the schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date covered by the schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Human-readable schedule code assigned by the scheduling system (e.g., SCHED-2024-W15).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalScheduledHours rdf:type rdf:Property ;
    rdfs:label 'Total Scheduled Hours' ;
    rdfs:comment 'Aggregate number of labor hours planned across all dayparts and positions for the schedule period.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique surrogate key for the time entry record.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Foreign key linking to workforce.payroll_record. Business justification: Time entries are the atomic labor records that aggregate into period-level payroll records. Linking time_entry.payroll_record_id -> payroll_record.payroll_record_id enables direct reconciliation betwe' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the time entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByManager rdf:type rdf:Property ;
    rdfs:label 'Approved By Manager' ;
    rdfs:comment 'True when a manager has approved the time entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakFlag rdf:type rdf:Property ;
    rdfs:label 'Break Flag' ;
    rdfs:comment 'True if a break was taken during the shift.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Minutes' ;
    rdfs:comment 'Total minutes taken for breaks during the shift.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'Exact date-time when the employee clocked in.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'Exact date-time when the employee clocked out.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Human-readable unique code for the time entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRole rdf:type rdf:Property ;
    rdfs:label 'Job Role' ;
    rdfs:comment 'Functional role of the employee during the shift.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Hourly wage rate applicable to the employee for this entry (in local currency).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPunchFlag rdf:type rdf:Property ;
    rdfs:label 'Missed Punch Flag' ;
    rdfs:comment 'True if the employee missed a clock-in or clock-out punch.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours worked.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payCode rdf:type rdf:Property ;
    rdfs:label 'Pay Code' ;
    rdfs:comment 'Payroll code indicating the type of pay (regular, overtime, sick leave, etc.).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of non-overtime hours worked.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date-time of the shift according to the schedule.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Time Entry Status' ;
    rdfs:comment 'Current lifecycle status of the time entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryType rdf:type rdf:Property ;
    rdfs:label 'Time Entry Type' ;
    rdfs:comment 'Method by which the time entry was recorded.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total number of hours (including overtime and breaks) recorded for the entry.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'Calendar date on which the shift occurred.' ;
    rdfs:domain ind:TimeEntry ;
