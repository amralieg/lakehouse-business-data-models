    rdfs:comment 'Geographic region code where this combo meal is available (e.g., \'NORTHEAST\', \'WEST\', \'SOUTH\'). Supports regional menu variation, pricing strategy, and PMIX analysis across the restaurant network.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCalories rdf:type rdf:Property ;
