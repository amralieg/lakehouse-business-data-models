    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Traceability Batch Number' ;
    rdfs:comment 'Batch or lot number used for ingredient traceability throughout the supply chain.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdaGrade rdf:type rdf:Property ;
    rdfs:label 'Usda Grade' ;
    rdfs:comment 'USDA quality grade assigned to the ingredient.' ;
    rdfs:domain ind:Ingredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vitaminCMgPerUnit rdf:type rdf:Property ;
    rdfs:label 'Vitamin C Mg Per Unit' ;
    rdfs:comment 'Vitamin C content per unit of the ingredient, expressed in milligrams.' ;
