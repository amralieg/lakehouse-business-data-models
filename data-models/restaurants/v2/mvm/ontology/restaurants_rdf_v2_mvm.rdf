    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: In-Restaurant Interaction Log tracks the employee handling each guest interaction, required for training effectiveness and KPI reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Interaction Guest Profile Id' ;
    rdfs:comment 'Surrogate identifier of the guest who generated the interaction.' ;
