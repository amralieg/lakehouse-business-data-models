    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastePercentage rdf:type rdf:Property ;
    rdfs:label 'Waste Percentage' ;
    rdfs:comment 'Typical percentage of the ingredient that is wasted during preparation or storage.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Unique identifier for the supply_purchase_order data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PO approval authorization workflow: restaurant procurement requires tracking which employee (manager/buyer) formally approved each purchase order for spend-authority compliance, audit trails, and AP r' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: Purchase orders are frequently issued against negotiated supplier contracts to enforce contracted pricing, volume tiers, and payment terms. Linking supply_purchase_order to supplier_contract enables c' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the replenishment order was received at the restaurant unit. Used for supplier performance tracking and variance analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyerName rdf:type rdf:Property ;
