    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:daypartScheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Daypart Schedule Notes' ;
    rdfs:comment 'Optional comments or special instructions for each daypart (e.g., event staffing, overtime alerts).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteEvening rdf:type rdf:Property ;
    rdfs:label 'Fte Evening' ;
    rdfs:comment 'Planned full-time equivalent staff for the evening shift (e.g., 16:00-22:00).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteMidday rdf:type rdf:Property ;
    rdfs:label 'Fte Midday' ;
    rdfs:comment 'Planned full-time equivalent staff for the midday shift (e.g., 12:00-16:00).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteMorning rdf:type rdf:Property ;
    rdfs:label 'Fte Morning' ;
    rdfs:comment 'Planned full-time equivalent staff for the morning shift (e.g., 06:00-12:00).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteNight rdf:type rdf:Property ;
    rdfs:label 'Fte Night' ;
    rdfs:comment 'Planned full-time equivalent staff for the night shift (e.g., 22:00-02:00).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fteTotal rdf:type rdf:Property ;
    rdfs:label 'Fte Total' ;
    rdfs:comment 'Sum of planned FTEs across all dayparts for the schedule period.' ;
