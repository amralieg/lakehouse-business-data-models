ind:estimatedIncomeBand rdf:type rdf:Property ;
    rdfs:label 'Estimated Income Band' ;
    rdfs:comment 'Income bracket estimate for the household used for segmentation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date when the household was first created in the system.' ;
