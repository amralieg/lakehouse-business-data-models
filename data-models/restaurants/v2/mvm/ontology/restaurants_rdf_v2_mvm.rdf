ind:fteEquivalency rdf:type rdf:Property ;
    rdfs:label 'Fte Equivalency' ;
    rdfs:comment 'Full-time equivalent factor used for labor forecasting (e.g., 1.0 = full-time, 0.5 = half-time).' ;
