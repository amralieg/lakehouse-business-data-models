    rdfs:comment 'Target Product Mix (PMIX) percentage representing the expected share of total transactions this combo meal should represent within its category. Used for menu performance benchmarking and sales forecasting.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posItemCode rdf:type rdf:Property ;
