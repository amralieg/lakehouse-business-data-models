    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:interactionProfileId rdf:type rdf:Property ;
    rdfs:label 'Interaction Profile Id' ;
    rdfs:comment 'Surrogate identifier of the guest who generated the interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:interactionRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Interaction Restaurant Unit Id' ;
