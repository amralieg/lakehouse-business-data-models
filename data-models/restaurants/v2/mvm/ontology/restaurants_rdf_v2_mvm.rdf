    rdfs:range xsd:date .

ind:ccpKitchenStationId rdf:type rdf:Property ;
    rdfs:label 'Ccp Kitchen Station Id' ;
    rdfs:comment 'Foreign key linking to restaurant.kitchen_station. Business justification: CCPs are physically located at specific kitchen stations (cooking CCP at grill station, cold-holding CCP at walk-in). HACCP implementation requires mapping each CCP to its physical monitoring location' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KitchenStation .

ind:responsiblePositionId rdf:type rdf:Property ;
    rdfs:label 'Responsible Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: CCPs require a designated responsible position for monitoring (e.g., \'Grill Station Cook monitors internal temp CCP\'). The existing \'responsible_role\' is a denormalized text field. A proper FK to work' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:averageDeviationValue rdf:type rdf:Property ;
    rdfs:label 'Average Deviation Value' ;
    rdfs:comment 'Average magnitude of deviations observed across monitoring events.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalControlPointStatus rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Status' ;
    rdfs:comment 'Current lifecycle status of the CCP.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitMax rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Max' ;
    rdfs:comment 'Upper bound of the acceptable range for the control parameter (e.g., maximum temperature).' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLimitMin rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Min' ;
    rdfs:comment 'Lower bound of the acceptable range for the control parameter (e.g., minimum temperature).' ;
