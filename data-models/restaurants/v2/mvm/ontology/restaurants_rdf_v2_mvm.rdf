    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Specific legal framework applied to interpret the contract.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Minimum insurance coverage the supplier must maintain.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Legal Jurisdiction' ;
    rdfs:comment 'State, province, or country whose laws govern the contract.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Liability Limit' ;
    rdfs:comment 'Maximum monetary liability the supplier assumes under the contract.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate applied once the threshold amount is reached.' ;
