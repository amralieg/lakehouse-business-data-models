ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'Channel most frequently used by the household for ordering.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address used to contact the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Analytical segment used for marketing and forecasting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of individuals associated with the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpend rdf:type rdf:Property ;
    rdfs:label 'Total Spend' ;
    rdfs:comment 'Cumulative monetary spend of the household across all channels.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTransactions rdf:type rdf:Property ;
    rdfs:label 'Total Transactions' ;
    rdfs:comment 'Cumulative count of all transactions associated with the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionSurveyId rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Id' ;
    rdfs:comment 'Unique identifier for each satisfaction survey instance.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to order.channel. Business justification: NPS and CSAT reporting by channel (app, kiosk, email, third-party delivery) is a standard restaurant CX KPI. delivery_channel on satisfaction_survey is a plain text denormalization of order.channel; n' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primarySatisfactionGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Satisfaction Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who received the survey.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primarySatisfactionUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Satisfaction Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where the guest experience occurred.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:serverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Server Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Service Quality Dashboard linking survey scores to the serving employee, supporting performance coaching and bonus calculations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:surveyBrandId rdf:type rdf:Property ;
    rdfs:label 'Survey Brand Id' ;
    rdfs:comment 'Foreign key linking to restaurant.brand. Business justification: Brand-level NPS/CSAT reporting is a named business process in multi-brand restaurant enterprises. Survey responses must be aggregated by brand for brand health dashboards and executive reporting. No e' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:surveyShiftId rdf:type rdf:Property ;
    rdfs:label 'Survey Shift Id' ;
    rdfs:comment 'Foreign key linking to workforce.shift. Business justification: Shift-level CSAT/NPS quality reporting: restaurant quality managers analyze satisfaction scores by shift to identify underperforming shifts and staff. This link enables the standard shift-quality dash' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:tertiarySatisfactionUnitId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Satisfaction Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where the guest experience occurred.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Foreign key linking to guest.guest_visit. Business justification: A satisfaction survey is triggered by and belongs to a specific guest visit. This 1:N FK (many surveys per visit, though typically one) anchors the survey to the operational visit record, enabling acc' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments entered by the guest.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Indicates whether the guest completed, partially completed, declined, or never received the survey.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'CSAT rating provided by the guest, typically on a 1-5 scale.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date-time when the survey was sent to the guest.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO language code of the survey presented to the guest.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'NPS rating provided by the guest on a scale of 0-10.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date-time when the guest submitted the survey response.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:satisfactionSurveyStatus rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Status' ;
    rdfs:comment 'Current lifecycle status of the survey record.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey (Customer Satisfaction, Net Promoter Score, or post-delivery feedback).' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the survey questionnaire used.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'System-generated unique identifier for the complaint record.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Complaint Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who raised the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:complaintProfileId rdf:type rdf:Property ;
    rdfs:label 'Complaint Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who raised the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:complaintRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Complaint Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant location where the complaint originated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:complaintUnitId rdf:type rdf:Property ;
    rdfs:label 'Complaint Unit Id' ;
    rdfs:comment 'Identifier of the restaurant location where the complaint originated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:guestOrderId rdf:type rdf:Property ;
    rdfs:label 'Guest Order Id' ;
    rdfs:comment 'Identifier of the order associated with the complaint, if applicable.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:handlingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handling Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Complaint Resolution Report that assigns a responsible employee to each complaint, enabling accountability and SLA tracking.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:illnessReportId rdf:type rdf:Property ;
    rdfs:label 'Illness Report Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.illness_report. Business justification: Guest foodborne illness complaints directly trigger illness_report investigations. Regulatory traceability requires linking the guest complaint record to the formal illness_report filed with health au' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IllnessReport .

ind:ingredientId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Id' ;
    rdfs:comment 'Foreign key linking to supply.ingredient. Business justification: Needed for food safety incident tracking: associating complaints with the specific ingredient allows root-cause analysis, recall decisions, and FDA reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ingredient .

ind:ingredientLotId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Lot Id' ;
    rdfs:comment 'Foreign key linking to supply.ingredient_lot. Business justification: Food safety traceability regulations (FDA, HACCP) require linking guest complaints about illness or contamination to the specific ingredient lot served. This enables recall management, root cause anal' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IngredientLot .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Foreign key linking to workforce.shift. Business justification: Shift-level incident and complaint reporting: restaurant operations track complaints by shift to identify problem shifts, staff accountability, and recurring quality issues. This enables the standard ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the complaint (e.g., C-20231234).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
