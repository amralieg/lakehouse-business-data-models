    rdfs:range xsd:dateTime .

ind:isPerishable rdf:type rdf:Property ;
    rdfs:label 'Is Perishable' ;
    rdfs:comment 'Indicates whether the received item is perishable and requires special handling.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether the line was later returned to the supplier.' ;
