ind:scheduledEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled End' ;
    rdfs:comment 'Planned end timestamp of the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Planned shift duration in hours (excluding breaks).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start' ;
    rdfs:comment 'Planned start timestamp of the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
