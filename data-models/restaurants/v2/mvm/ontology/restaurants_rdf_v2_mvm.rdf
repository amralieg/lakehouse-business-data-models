ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date of the shift (derived from scheduled_start).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Employee Id' ;
    rdfs:comment 'Unique identifier of the manager or supervisor who approved the schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Manager Employee Id' ;
    rdfs:comment 'Unique identifier of the manager or supervisor who approved the schedule.' ;
    rdfs:domain ind:Schedule ;
