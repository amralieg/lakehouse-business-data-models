ind:preferredUnitId rdf:type rdf:Property ;
    rdfs:label 'Preferred Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: Household-level preferred store assignment drives local marketing, delivery radius matching, and household-level sales attribution. A loyalty/CRM expert expects a household\'s home unit for targeted lo' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Member Id' ;
    rdfs:comment 'Identifier of the primary guest/member designated for the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:addressVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Address Verification Date' ;
    rdfs:comment 'Date when the household address was last verified.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressVerified rdf:type rdf:Property ;
    rdfs:label 'Address Verified' ;
    rdfs:comment 'Indicates whether the household address has been validated.' ;
    rdfs:domain ind:Household ;
