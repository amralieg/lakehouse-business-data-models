    rdfs:range xsd:boolean .

ind:averageTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Count' ;
    rdfs:comment 'Average number of transactions per defined period for the household.' ;
    rdfs:domain ind:Household ;
