    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to workforce.schedule. Business justification: A shift is a component of a published schedule. The schedule product represents the weekly/period-level labor plan, while shift represents individual scheduled work blocks within that plan. Without sc' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:shiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shift Employee Id' ;
    rdfs:comment 'Identifier of the user who scheduled the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:stationKitchenStationId rdf:type rdf:Property ;
    rdfs:label 'Station Kitchen Station Id' ;
    rdfs:comment 'Foreign key linking to restaurant.kitchen_station. Business justification: Shifts are assigned to specific kitchen stations (grill, fry, expo) for labor scheduling and station-level productivity reporting. The existing plain-text `station` column is a denormalization of kitc' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KitchenStation .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'Actual clock-out timestamp recorded for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Actual worked hours for the shift (excluding breaks).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'Actual clock-in timestamp recorded for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total break time in minutes allocated for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Flag indicating soft deletion of the shift record.' ;
