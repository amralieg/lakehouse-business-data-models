ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'Base hourly compensation for hourly-paid positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isManager rdf:type rdf:Property ;
    rdfs:label 'Is Manager' ;
    rdfs:comment 'True if the position includes managerial responsibilities.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:level rdf:type rdf:Property ;
    rdfs:label 'Level' ;
    rdfs:comment 'Career level of the position within the organization hierarchy.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'Minimum legal age required to be eligible for the position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payBand rdf:type rdf:Property ;
    rdfs:label 'Pay Band' ;
    rdfs:comment 'Compensation band used for salary or hourly rate determination.' ;
