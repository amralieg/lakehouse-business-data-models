ind:memberId rdf:type rdf:Property ;
    rdfs:label 'Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: At POS/kiosk, visits are identified by loyalty card scan — member_id is the primary identifier used operationally. Direct FK enables visit-based points accrual audits and tier qualification period vis' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:amount rdf:type rdf:Property ;
