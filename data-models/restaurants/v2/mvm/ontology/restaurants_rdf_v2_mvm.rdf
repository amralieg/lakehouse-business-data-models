    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the demographic record.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Host Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Guest Flow Management records which host/hostess greeted the guest, essential for staffing analysis and guest experience metrics.' ;
    rdfs:domain ind:Visit ;
