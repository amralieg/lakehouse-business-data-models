    rdfs:range xsd:decimal .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Cumulative number of recorded deviations from the critical limits.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haccpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Version' ;
    rdfs:comment 'Version identifier of the HACCP plan to which this CCP belongs.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
