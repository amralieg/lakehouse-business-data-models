ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Overall processing status of the goods receipt.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code of the warehouse or site location where the material is stored.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Job Cost Transaction Id' ;
    rdfs:comment 'Foreign key linking to finance.job_cost_transaction. Business justification: Goods issues to site generate job cost transactions recording actual material cost against the project. Direct FK enables cost-to-issue traceability for project cost reporting, EVM, and audit — a stan' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCostTransaction .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Foreign key linking to material.requisition. Business justification: A goods_issue fulfills a material requisition — the requisition is the demand document that triggers the warehouse to issue materials. This is a fundamental procurement-to-issue traceability link. goo' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:returnIssueGoodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Return Issue Goods Issue Id' ;
    rdfs:comment 'Identifier of the goods issue record that reverses this transaction, if any.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Batch or lot identifier for traceability of the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
