# RDFS Schema for Business: Construction

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/construction#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Construction ---
ind:Construction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Construction' ;
    rdfs:comment 'construction industry enterprise data model.' .

# --- Domain Classes ---
ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Project' ;
    rdfs:comment 'Core SSOT for all construction project lifecycle data from NTP through commissioning and handover. Owns project identity, WBS (Work Breakdown Structure), milestones, baseline scope, EVM metrics (CPI, SPI), deliverables, and project performance tracking. Central to EPC (Engineering Procurement Construction) execution and PMO (Project Management Office) governance across DB, DBB, and PPP delivery models.' .

ind:Client rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Client' ;
    rdfs:comment 'Master client/owner data managing relationships with project owners, developers, and sponsors who commission construction work. Owns client profiles, account hierarchies, JV structures, stakeholder contacts, communication preferences, and relationship history. Supports CRM (Customer Relationship Management), opportunity pipeline management, and client segmentation across public-sector, private-sector, and PPP/BOT arrangements.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Authoritative contract repository governing all contractual agreements including FIDIC-based EPC, GMP (Guaranteed Maximum Price), lump-sum, and unit-rate contracts. Owns CO (Change Order) logs, LD (Liquidated Damages) provisions, DLP (Defects Liability Period) terms, EOT (Extension of Time) entitlements, payment schedules, and contract milestone administration.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Site' ;
    rdfs:comment 'Owns daily site execution data including daily logs, production tracking, work fronts, crew assignments, site logistics, mobilization/demobilization, concrete pours, earthworks volumes, and field progress measurements. Integrates with HCSS HeavyJob for cost coding and production tracking and Procore for daily logs and field management. Supports earned value computation feeding the project domain.' .

ind:Design rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Design' ;
    rdfs:comment 'Engineering and design domain owning BIM models, CAD drawings, technical specifications, design packages, RFIs, submittals, clash detection, document control registers, transmittals, correspondence, workflow approvals, and handover documentation for construction projects' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Procurement and supply chain domain managing the full source-to-contract lifecycle including RFQ/RFP issuance, vendor evaluation, PO (Purchase Order) creation, MTO (Material Take-Off) data, supplier qualification records, and procurement lead times. Coordinates material delivery schedules with project timelines and manages vendor master data via SAP MM.' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Material' ;
    rdfs:comment 'Materials management domain tracking inventory, stock levels, material receipts, consumption, transfers between sites, and material traceability (batch/lot tracking for concrete, steel, MEP components). Manages BOQ (Bill of Quantities) reconciliation, material specifications, FAT/SAT records, material conformance certificates, and warehouse operations for construction materials and consumables.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Construction equipment and fleet management domain tracking heavy machinery (cranes, excavators, concrete pumps), tools, generators, and fleet vehicles. Owns asset master data, utilization tracking, maintenance schedules, equipment hours, mobilization/demobilization records, rental vs. owned classification, and asset lifecycle management via SAP PM and HCSS HeavyJob.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'Construction workforce management domain tracking labor resources, crew assignments, time tracking, production rates, skill certifications, labor cost coding, field personnel deployment, and site access records. Manages craft labor, supervision, and project-based staffing distinct from corporate HR functions. Integrates with HCSS HeavyJob for timesheets and SAP SuccessFactors for HCM.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Project scheduling domain managing CPM (Critical Path Method) networks, activity sequencing, resource leveling, critical path analysis, progress tracking, baseline comparisons, look-ahead plans, and schedule performance metrics (SPI). Integrates with Oracle Primavera P6 for schedule exports and EVM (Earned Value Management) for project control.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Quality' ;
    rdfs:comment 'QA/QC (Quality Assurance/Quality Control) domain managing ITP (Inspection and Test Plans), NCR (Non-Conformance Reports), inspection checklists, material test certificates, weld records, FAT (Factory Acceptance Test), SAT (Site Acceptance Test), and defect tracking through DLP. Ensures construction deliverables meet specifications and ISO 9001 standards.' .

ind:Safety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Safety' ;
    rdfs:comment 'HSE (Health Safety Environment) domain managing incident reports, LTI (Lost Time Injury), TRIR (Total Recordable Incident Rate), near-miss records, SWMS (Safe Work Method Statements), PTW (Permit to Work), TBM (Toolbox Meeting) records, safety audits, corrective actions, PPE compliance, and environmental compliance records. Integrates with Intelex for incident management and OSHA/ISO 45001 regulatory reporting.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Finance' ;
    rdfs:comment 'SSOT for all project and corporate financial data including job costing, budget vs. actual, GL/AP/AR entries, progress billing, revenue recognition (percentage of completion), cost codes, cost centers, WBS-linked budgets, EVM financial outputs (CPI), cash flow forecasting, P&L (Profit and Loss), and EBITDA reporting. Integrates with SAP S/4HANA and Viewpoint Vista for construction accounting and IFRS/GAAP compliance.' .

# --- Data Product Classes (Tables) ---
ind:ConstructionProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Construction Project' ;
    rdfs:comment 'Core master entity representing a construction project from NTP (Notice to Proceed) through commissioning and handover. Owns project identity, delivery model (EPC, DB, DBB, PPP, BOT), project type (infrastructure, commercial, residential, energy, industrial), contract value, project status, geographic location, client reference, PMO classification, project type classification (typical duration/value ranges, required certifications, sector), and key lifecycle dates. SSOT for all project-level identity, metadata, and classification across the enterprise.' .

ind:WbsElement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure (WBS) node representing a decomposed scope element within a construction project. Captures WBS code, level, parent-child hierarchy, scope description, responsible discipline, budgeted cost, planned quantity, unit of measure, and WBS type (summary, work package, control account). Supports EVM (Earned Value Management) rollup and cost control at granular scope levels.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Key contractual and internal milestones within a construction project lifecycle, including NTP, design completion, procurement completion, construction start, mechanical completion, commissioning, and handover. Tracks planned date, forecast date, actual date, milestone type, contractual obligation flag, LD (Liquidated Damages) trigger flag, and milestone owner. Supports schedule performance and contract administration. [SSOT: distinct source of truth for project domain]' .

ind:ProjectBaseline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Baseline' ;
    rdfs:comment 'Approved project baseline and budget revision record maintaining the complete audit trail of authorized scope, schedule, and cost parameters throughout the project lifecycle. Each record captures a point-in-time snapshot: baseline type (original, revised, re-baseline, CO incorporation, re-forecast, management reserve release), revision number, revision date, approval date, approving authority, total baseline cost, baseline duration, baseline start and finish dates, budget amount before and after revision, cost account or WBS-level budget breakdown, and justification narrative. Supports EVM variance analysis (current performance vs approved baseline), change impact tracking, budget evolution audit trail at both project and cost-account level, and PMO governance and financial audit requirements.' .

ind:EvmPeriodRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Evm Period Record' ;
    rdfs:comment 'Unified Single Source of Truth for periodic earned value management, physical progress measurement, and forward-looking project forecasting at WBS or project level. Captures physical progress (percent complete, earned quantity, installed quantity, measurement method — weighted steps, milestone, units complete, level of effort — verifying engineer, and measurement date), EVM performance metrics (CPI, SPI, BCWS/PV, BCWP/EV, ACWP/AC, CV, SV, TCPI), and management forecasts (EAC, ETC, VAC, forecast completion date, forecast final cost, forecast method — CPI-based, management override, bottom-up re-estimate). Includes reporting period, cost/schedule variances, trend indicators, and management narrative commentary. Core to PMO governance, progress billing, P&L reporting, client monthly reporting, and project financial health monitoring. Sourced from HCSS HeavyJob production tracking, Procore field management, and SAP S/4HANA Project Systems.' .

ind:ProgressMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Progress Measurement' ;
    rdfs:comment 'Periodic physical progress measurement record at WBS element or activity level, capturing percent complete, earned quantity, installed quantity, measurement method (weighted steps, milestone, units complete), measurement date, reporting period, and verifying engineer. Feeds EVM calculations and progress billing. Sourced from HCSS HeavyJob production tracking and Procore field management.' .

ind:ChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Change Order' ;
    rdfs:comment 'Formal change order (CO) record capturing approved scope, schedule, and cost changes to the project baseline. Tracks CO number, description, change type (scope addition, scope reduction, design change, unforeseen condition), cost impact, schedule impact (EOT — Extension of Time), originator, approval status, approval date, and contract reference. SSOT for all approved project changes. Sourced from Procore Change Orders module. [SSOT: distinct source of truth for project domain]' .

ind:CostAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Cost Account' ;
    rdfs:comment 'Project cost account (control account) representing the intersection of WBS element and cost code for job costing and budget control. Captures cost account code, description, cost type (labor, material, equipment, subcontract, overhead), original budget, approved budget (including COs), committed cost, actual cost to date, forecast cost at completion, and variance. SSOT for project-level cost control. Sourced from SAP S/4HANA Project Systems and Viewpoint Vista Job Costing.' .

ind:Deliverable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Deliverable' ;
    rdfs:comment 'Project deliverable record representing a contractually or technically required output (engineering deliverable, construction deliverable, commissioning package, handover document). Captures deliverable code, title, discipline, deliverable type, responsible party, planned issue date, forecast issue date, actual issue date, revision status, and acceptance status. Supports handover and DLP (Defects Liability Period) tracking.' .

ind:RiskRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Risk Register' ;
    rdfs:comment 'Project risk register entry capturing identified risks and opportunities at project or WBS level. Tracks risk ID, description, risk category (technical, commercial, schedule, HSE, regulatory, force majeure), probability, impact (cost, schedule, quality), risk score, mitigation strategy, contingency plan, risk owner, status (open, mitigated, closed, realized), and residual risk assessment. Supports PMO governance and contingency management.' .

ind:Phase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Structured phase definition within a construction project lifecycle (feasibility, pre-construction, FEED, detailed engineering, procurement, construction, pre-commissioning, commissioning, handover, DLP). Captures phase code, name, sequence, planned and actual start/finish dates, phase status, phase weight for EVM rollup, gate review criteria, gate approval status, gate approval date, and phase deliverables checklist. Supports lifecycle governance, phase-gate approval workflows, and earned value rollup by phase across EPC, DB, DBB, and PPP delivery models.' .

ind:Forecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Forecast' ;
    rdfs:comment 'Rolling project cost and schedule forecast record capturing EAC (Estimate at Completion), ETC (Estimate to Complete), forecast completion date, forecast final cost, cost variance, schedule variance, and narrative commentary for a given reporting period. Distinct from EVM period records — this is the forward-looking management forecast used for P&L reporting and PMO governance. Sourced from SAP S/4HANA Project Systems.' .

ind:ProjectSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Site' ;
    rdfs:comment 'Master reference table for site. Referenced by site_id.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for each client/owner organization that commissions construction work. SSOT for client identity across public-sector agencies, private developers, government bodies, and corporate sponsors. Captures legal entity name, registration number, tax ID, industry sector, client tier, credit rating, preferred contract type (EPC, GMP, DBB, PPP, BOT), account status, CRM account owner, and segment assignments. Sourced from Salesforce CRM Account object. All other client domain products reference this entity.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual stakeholder contact associated with a client account, including project owners, technical representatives, procurement officers, legal counsel, and executive sponsors. Captures full name, job title, department, email, phone, preferred communication channel, decision-making authority level, and relationship health indicator. Sourced from Salesforce CRM Contact object.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with client accounts, including registered office, billing address, project site liaison office, and correspondence address. Captures address type, street, city, state/province, postal code, country, GIS coordinates, and address validation status. Supports multi-jurisdiction clients operating across regions.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Client segmentation classification defining market categories for strategic targeting, pipeline prioritization, and BD resource allocation. Captures segment name, sector (public, private, PPP/BOT), sub-sector (infrastructure, energy, commercial, residential, industrial), geographic region, revenue band, strategic tier (key account, growth, standard, dormant), and segmentation criteria version. Accounts are assigned to segments via a direct FK on the account record. Enables targeted BD strategies, CRM pipeline filtering, account planning by sector and tier, and win-rate analysis by market segment. Aligned with FIDIC, NEC4, and JCT procurement categories.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Pre-award commercial opportunity record tracking potential construction projects in the BD pipeline. Captures opportunity name, client account, project type, estimated contract value, delivery model (EPC, GMP, DBB, PPP), bid/no-bid decision, probability of win, expected NTP date, pipeline stage, BD owner, and win/loss outcome. Sourced from Salesforce CRM Opportunity object. SSOT for pipeline forecasting.' .

ind:Prequalification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Prequalification' ;
    rdfs:comment 'Records prequalification and due diligence assessments that client organizations apply to the construction firm before issuing RFPs or RFQs. Captures prequalification reference number, client account, category (civil, MEP, EPC, marine, tunneling), submission date, expiry date, status (approved, conditional, rejected, expired), conditions imposed, approving authority, and required renewal actions. Critical for bid eligibility tracking — the firm cannot bid on work from a client without active prequalification in the relevant category. [SSOT: distinct source of truth for client domain]' .

ind:RfpIssuance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Rfp Issuance' ;
    rdfs:comment 'Records RFP (Request for Proposal), RFQ (Request for Quotation), and ITT (Invitation to Tender) documents issued by clients, initiating the formal bid process. Captures RFP reference number, client account, project description, issue date, submission deadline, bond requirements (bid bond, performance bond), evaluation criteria weights, delivery model, pre-bid meeting dates, and linked opportunity. This is the client-side solicitation record; the firm\'s response is managed in the bid domain.' .

ind:MasterServicesAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Master Services Agreement' ;
    rdfs:comment 'Long-term framework agreements, master service agreements (MSA), or term contracts established with repeat clients, defining pre-agreed rates, scope categories, KPIs, and call-off procedures for multiple projects over a defined period. Captures agreement title, client account, agreement type (framework, MSA, term contract, blanket order), effective date, expiry date, total ceiling value, call-off mechanism, performance KPIs, renewal terms, and extension options. Common with public-sector clients (e.g., highways agencies, utilities) who procure repeat works under a single competitive framework. [SSOT: distinct source of truth for client domain]' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master contract record representing the authoritative SSOT for all contractual agreements in the construction domain. Captures FIDIC-based EPC, GMP (Guaranteed Maximum Price), lump-sum, unit-rate, DB (Design-Build), DBB (Design-Bid-Build), PPP (Public-Private Partnership), and BOT (Build-Operate-Transfer) contract types via a type classification attribute. Stores contract identity, scope narrative, detailed scope of works including WBS (Work Breakdown Structure) reference, deliverable descriptions, technical specifications reference, BOQ (Bill of Quantities) linkage, geographic boundaries, and exclusions. Records execution dates, NTP (Notice to Proceed) date, contract value, currency, governing law, dispute resolution mechanism, contract status lifecycle from award through close-out, and particular/special conditions that modify standard form terms. Maintains status transition history for audit and lifecycle analytics. Records all formal amendments including supplemental agreements, deed of variations, and novation agreements with amendment number, type, effective date, revised contract value, revised completion date, and execution status. Serves as the authoritative scope baseline against which change orders and EOT claims are evaluated.' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party' ;
    rdfs:comment 'Association entity capturing all parties bound to a contract agreement, including the employer/client, general contractor (GC), joint venture (JV) partners, engineer/consultant, and guarantors. Records party role, signatory authority, legal entity name, registration number, jurisdiction, and participation percentage for JV arrangements. Enables multi-party contract structures common in EPC and PPP delivery models.' .

ind:PaymentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Defines the contractual payment schedule governing when and how much the employer is obligated to pay the contractor, including full advance payment (mobilization payment) lifecycle management. Captures payment terms, payment intervals, payment due dates, payment method, currency, and supports both milestone-based and time-based payment structures as defined under FIDIC and GMP contract forms. Manages the complete advance payment lifecycle: advance payment amount, percentage of contract value, disbursement date, repayment/recovery schedule, cumulative amount recovered through payment certificate deductions, outstanding advance balance, advance payment guarantee reference, and advance payment status from initial disbursement through full recovery. Serves as the authoritative SSOT for all payment scheduling and advance payment tracking, alongside progress payment and retention release scheduling.' .

ind:PaymentCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Payment Certificate' ;
    rdfs:comment 'Transactional record of each interim payment certificate (IPC) and final payment certificate (FPC) issued under a main contract or subcontract. Captures certified amount, retention deducted, advance payment recovery, LD deductions, net amount due, certification date, certifier identity, payment due date, and actual payment date. Supports both main contract certification (FIDIC Clause 14) and subcontract payment certification via a contract-level discriminator distinguishing main contract from subcontract certificates. Records subcontract payment applications, certified amounts, and enables back-to-back payment flow management between main contract receipts and subcontractor disbursements. Supports cash flow forecasting, pay-when-paid clause administration, and unified payment reconciliation across the full contract hierarchy.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records formal amendments to the original contract agreement, including supplemental agreements, deed of variations, and novation agreements. Captures amendment number, amendment type, effective date, description of changes to original terms, revised contract value, revised completion date, and execution status. Maintains a complete amendment history for each contract to support audit and dispute resolution.' .

ind:BondGuarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Bond Guarantee' ;
    rdfs:comment 'Tracks all performance bonds, advance payment guarantees, retention bonds, bid bonds, and parent company guarantees associated with a contract. Records bond type, issuing bank or surety, bond amount, bond currency, issue date, expiry date, call conditions, and current status (active, expired, called, released). Provides the authoritative bond register for contract administration and financial risk management.' .

ind:InsuranceRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Insurance Register' ;
    rdfs:comment 'Maintains the register of all contractually required insurance policies for a contract, including contractor all-risk (CAR), third-party liability, professional indemnity, workers compensation, and marine cargo. Records policy number, insurer name, coverage type, coverage amount, policy period, deductible, and compliance status. Tracks insurance renewal obligations and notifies contract administrators of expiring coverage.' .

ind:Subcontract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Subcontract' ;
    rdfs:comment 'Master record for subcontracts let by the main contractor to specialist trade and MEP (Mechanical Electrical Plumbing) subcontractors under the main contract. Captures subcontract type (domestic, nominated, specialist), subcontract value, scope summary, back-to-back terms with main contract, NTP date, completion date, and subcontract status. Distinct from the subcontractor domain master — this entity owns the contractual instrument, not the subcontractor party profile.' .

ind:SubcontractPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Subcontract Payment' ;
    rdfs:comment 'Transactional record of payment applications and payment certificates issued under each subcontract. Captures application amount, certified amount, retention deducted, LD deductions, net payment due, payment due date, and actual payment date. Enables back-to-back payment flow management between main contract receipts and subcontractor disbursements, supporting cash flow forecasting and pay-when-paid clause administration.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Records formal disputes, claims, and adjudication proceedings arising under a contract. Captures dispute reference, dispute type (payment, scope, delay, quality), claim amount, dispute submission date, DAB (Dispute Adjudication Board) reference, arbitration reference, legal counsel assigned, current status, and resolution outcome. Supports FIDIC Clause 20 dispute resolution workflow and legal cost tracking.' .

ind:CommercialChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Commercial Change Order' ;
    rdfs:comment 'Authoritative log of all CO (Change Orders) and contract variations issued against a contract. Records variation instruction reference, scope description, reason code (employer-directed, unforeseen conditions, design change), cost impact (addition or omission), schedule impact in days, approval status, and executed value. Tracks the full variation lifecycle from instruction through valuation, negotiation, and formal execution. Links to EOT claims where schedule impact is asserted. [SSOT: distinct source of truth for contract domain]' .

ind:ScopeOfWork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Defines the detailed scope of works attached to a contract agreement, including WBS (Work Breakdown Structure) reference, deliverable descriptions, technical specifications reference, BOQ (Bill of Quantities) linkage, geographic boundaries, and exclusions. Serves as the authoritative scope baseline against which change orders and EOT (Extension of Time) claims are evaluated. [SSOT: distinct source of truth for contract domain]' .

ind:WorkFront rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Work Front' ;
    rdfs:comment 'Master record for each active work front (zone, area, or face) on a construction site where concurrent work activities are executed. Tracks work front identity, location coordinates (GPS/grid reference), zone classification, active/inactive status, assigned foreman, mobilization date, demobilization date, current phase, associated WBS element, and parent site reference. Serves as the primary spatial and organizational anchor for all site-level transactional records — every operational product in this domain holds a mandatory or optional FK to work_front. The work_front-centric topology enables spatial aggregation of production, cost, progress, and resource data by zone.' .

ind:DailyLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Daily Log' ;
    rdfs:comment 'Official daily site log (header + line-item structure) capturing all field activities for a given project site and date. The header records weather conditions (temperature, precipitation, wind), site access status, manpower headcount by trade, equipment on site, work performed narrative, superintendent sign-off, and overall site status. Embedded line-item events capture each notable occurrence including delay events, weather stoppages, utility strikes, design holds, access restrictions, and safety observations — each with event type, start/end time, duration, affected work fronts, root cause classification, responsible party, and EOT/cost impact flags. This is the SSOT for all site event data — no separate event entity exists. Sourced from Procore Daily Logs module. Serves as the legal and operational record of site activity and the primary evidence base for delay claims and EOT substantiation.' .

ind:ProductionEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Production Entry' ;
    rdfs:comment 'Granular production tracking record capturing quantities of work completed per activity, cost code, and work front for a specific date. Sourced from HCSS HeavyJob production tracking module. Stores installed quantity, unit of measure, production rate (units/hour), budgeted quantity, percent complete, crew size, equipment hours consumed, and cost code. Feeds earned value computation and progress billing in the project and finance domains.' .

ind:CrewDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Crew Deployment' ;
    rdfs:comment 'Daily assignment record linking a named crew or gang to a specific work front, activity, and cost code for a given date. Captures crew type (civil, MEP, concrete, steel erection), crew size, lead foreman, shift start/end times, overtime flag, productivity notes, and planned vs actual hours. Sourced from HCSS HeavyJob time tracking. Holds mandatory FK to work_front for spatial allocation. Distinct from workforce domain employee records — this entity tracks the operational deployment of crews to site activities, not individual labor records.' .

ind:ConcretePour rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Concrete Pour' ;
    rdfs:comment 'Detailed record of each concrete pour event on site, capturing pour date, pour location (structure element, grid reference), mix design code, specified compressive strength (MPa/PSI), volume poured (m³/yd³), batch plant source, delivery docket numbers, pour start/end time, ambient temperature, slump test results, number of test cylinders cast, and QC hold status. Integrates with quality domain ITP records and material domain batch traceability.' .

ind:FieldProgress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Field Progress' ;
    rdfs:comment 'Periodic field progress measurement record capturing percent complete and installed quantities for a WBS activity or BOQ line item as physically measured in the field. Stores measurement date, measurement method (visual estimate, quantity survey, milestone completion, 3D scan comparison), reported percent complete, previous percent complete, incremental progress delta, field engineer name, and approval status. Feeds EVM (Earned Value Management) calculations including BCWP, CPI, and SPI in the project domain. Provides the ground-truth measurement that reconciles against schedule domain planned progress.' .

ind:Mobilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Mobilization' ;
    rdfs:comment 'Master record tracking the mobilization and demobilization lifecycle of a construction site or major work package. Captures planned mobilization date, actual mobilization date, NTP (Notice to Proceed) date, site establishment milestones (fencing, laydown area, site office, utilities), demobilization plan date, actual demobilization date, and site closure sign-off. Provides the temporal and logistical anchor for all site operations.' .

ind:EquipmentDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Equipment Deployment' ;
    rdfs:comment 'Daily or period-based record of construction equipment deployed to a specific work front or activity on site. Captures equipment ID (FK to equipment domain), deployment date, release date, operating hours, idle hours, cost code, operator name, fuel consumption, and breakdown flag. Sourced from HCSS HeavyJob equipment hours module. Distinct from equipment domain master records — this entity tracks the operational utilization of equipment at the site level.' .

ind:MaterialDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Material Delivery' ;
    rdfs:comment 'Site-level record of material deliveries received at the construction site gate or designated laydown area. Captures delivery date, supplier name, PO reference (FK to procurement domain), delivery docket number, material description, quantity delivered, unit of measure, receiving location (laydown zone per site_logistics_plan), condition on receipt (accepted/rejected/partial), receiver name, temperature-sensitive storage flag, and discrepancy notes. Distinct from procurement domain PO records — this entity captures the physical receipt event at the site and triggers material domain stock updates.' .

ind:Permit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Permit' ;
    rdfs:comment 'Regulatory permit or access authorization record governing permission to execute specific work activities on a construction site. Captures permit type (hot work, excavation, confined space entry, crane operation, road closure, environmental discharge, noise variance), permit number, issuing authority, application date, approval date, expiry date, conditions/restrictions, associated work front, responsible person, permit status (applied/active/suspended/closed), and close-out sign-off. Required under OSHA 29 CFR 1926, local building codes, and environmental regulations. Provides the compliance gate that must be satisfied before work commences on regulated activities. [SSOT: distinct source of truth for site domain]' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site' ;
    rdfs:comment 'Master reference table for site. Referenced by current_location_site_id.' .

ind:Transmittal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Transmittal' ;
    rdfs:comment 'Records the formal dispatch of documents, drawings, and submittals between project parties via Aconex transmittals. Captures transmittal number, issue date, sender organization, recipient organization, purpose of issue (for approval, for information, for construction, for record), document list, and acknowledgement status. Provides a legally defensible audit trail of document distribution throughout the project lifecycle.' .

ind:Rfi rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Rfi' ;
    rdfs:comment 'Request for Information records capturing formal queries raised by contractors seeking clarification on design intent, specifications, or contract documents. Tracks RFI number, subject, discipline, originator, addressee, date raised, response due date, actual response date, response content, cost/schedule impact assessment, linked drawing or specification reference, and closure status. High-volume transactional entity critical for design coordination and contractual record-keeping. Sourced from Procore RFI module and Aconex.' .

ind:DocumentRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Document Register' ;
    rdfs:comment 'Central master register of all project documents beyond drawings — including specifications, reports, procedures, method statements, O&M manuals, certificates, and correspondence — managed in Aconex CDE (Common Data Environment). Captures document number, title, document type, discipline, revision, status, originator, issue date, confidentiality classification, retention period, and numbering convention. Provides the authoritative catalog of all project documentation per ISO 19650 information container requirements.' .

ind:Revision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Version control record for each document in the document register, capturing revision identifier, revision date, revision description, author, reviewer, approver, change summary, superseded revision reference, and file storage path. Maintains a complete and auditable version history for all project documents to support regulatory compliance, handover, and DLP (Defects Liability Period) obligations.' .

ind:WorkflowApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Workflow Approval' ;
    rdfs:comment 'Formal document review and approval workflow instances tracking multi-step approval chains in Aconex and BIM 360 CDE. Captures workflow template, document under review, step sequence, assigned reviewer (role and individual), action taken (approved, rejected, commented, delegated, no objection), action date, reviewer comments, SLA target vs actual duration, and overall workflow outcome. Provides the legally required audit trail of all document approval decisions for ISO 9001 quality management, ISO 19650 information management, and contractual compliance under FIDIC/NEC.' .

ind:BimModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Bim Model' ;
    rdfs:comment 'Master record for each Building Information Model (BIM) asset managed in Autodesk BIM 360, Bentley ProjectWise, or equivalent platform. Captures model identity, discipline (architectural, structural, MEP, civil), authoring software and version, file format (RVT, IFC, NWD), project coordinate system, geolocation reference point, LOD (Level of Development) classification per AIA E202/BIMForum LOD Specification, model status (WIP, shared, published, archived), lifecycle stage, federation role (host/linked), and file size. SSOT for all 3D model metadata across the project portfolio, enabling federated model assembly, clash detection workflows, 4D/5D BIM integration, and ISO 19650 information management compliance.' .

ind:Drawing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Drawing' ;
    rdfs:comment 'Master record for each engineering and construction drawing (CAD/BIM-derived) managed across the project. Tracks drawing number, title, discipline, sheet size, scale, revision number, current status (issued for construction, issued for review, superseded), originator, and approval state. Serves as the SSOT for the drawing register aligned with Autodesk BIM 360 document control.' .

ind:DrawingRevision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Transactional record capturing each revision event for a drawing. Stores revision code, revision date, description of changes, reason for revision (RFI-driven, design change, client instruction), issuing engineer, reviewer, approver, and distribution status. Enables full version-control audit trail for IFC/CAD drawing lifecycle.' .

ind:TechnicalSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Technical Specification' ;
    rdfs:comment 'Master record for each technical specification document governing materials, workmanship, and construction methods. Captures spec number, title, discipline, applicable standards (ACI, AISC, NFPA), revision status, approval state, and scope of work section reference. Linked to WBS elements and BOQ line items for design-build scope management.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Package' ;
    rdfs:comment 'Master record representing a formal design deliverable package issued at a project milestone (30%, 60%, 90%, IFC, As-Built). Groups related drawings, specifications, calculations, and BIM models into a contractual issuance unit. Tracks package number, milestone stage, discipline, issue date, contractual due date, recipient distribution list, submission status, client acceptance status, and approval workflow state. Also serves as the contractual deliverable register (DDR), tracking each required deliverable item with its type (drawing, specification, report, model, calculation), responsible discipline, milestone linkage, planned vs. actual submission dates, and client acceptance status. SSOT for design deliverable scheduling, contractual compliance monitoring, and milestone gate readiness assessment.' .

ind:EngineeringSubmittal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Engineering Submittal' ;
    rdfs:comment 'Transactional record for each design-phase submittal item tracking contractor-submitted shop drawings, material data sheets, product samples, and method statements through the review and approval lifecycle. Includes register-level metadata (specification section, required submission date, contractual obligation) and item-level tracking (submission date, review status, approval authority, disposition). [SSOT: distinct source of truth for design domain]' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all approved and prospective suppliers, subcontractors, and material vendors managed via SAP MM Vendor Master. Captures vendor identity, classification (material supplier, equipment rental, specialist subcontractor), registration status, tax identifiers, payment terms, currency, bank details, geographic coverage, diversity classification (MBE/WBE/DBE), bonding capacity, insurance certificates, and SAP vendor account number. SSOT for vendor identity across the procurement domain.' .

ind:VendorQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Qualification' ;
    rdfs:comment 'Supplier pre-qualification and approved vendor list (AVL) records capturing qualification status, financial health assessments, technical capability evaluations, HSE performance ratings, quality certifications (ISO 9001, ISO 14001, ISO 45001), bonding limits, insurance coverage verification, past performance scores, and qualification expiry dates. Tracks the full vendor onboarding and re-qualification lifecycle required before a vendor can receive a PO.' .

ind:MaterialCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Material Catalog' ;
    rdfs:comment 'Authoritative catalog of all procurable materials, equipment components, and consumables managed in SAP MM Material Master. Captures material number, description, material group, base unit of measure, weight, dimensions, hazardous material classification, storage conditions, lead time, minimum order quantity, standard cost, and BIM object reference. SSOT for material identity used across MTO, PO, and goods receipt processes.' .

ind:Rfq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Rfq' ;
    rdfs:comment 'Request for Quotation records issued to vendors for pricing and availability of materials, equipment, or services, including header-level metadata and granular line-item detail. Captures RFQ number, issuing project, scope description, BOQ reference, submission deadline, bid bond requirement, evaluation criteria, invited vendor list, currency, RFQ status (draft, issued, closed, awarded, cancelled), and individual line items (line number, material/service description, quantity, UoM, required delivery date, site delivery location, technical specification reference, drawing/BIM reference). Sourced from SAP MM RFQ process and Procore bid management workflows. Enables granular vendor pricing comparison at the line-item level.' .

ind:RfqLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Rfq Line' ;
    rdfs:comment 'Individual line items within an RFQ corresponding to specific materials, services, or BOQ positions. Captures line number, material or service description, quantity, unit of measure, required delivery date, site delivery location, technical specification reference, and any applicable drawing or BIM model reference. Enables granular vendor pricing comparison at the line-item level.' .

ind:VendorQuotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Quotation' ;
    rdfs:comment 'Vendor-submitted quotation responses to RFQs capturing quoted unit price, total price, delivery lead time, validity period, payment terms offered, country of origin, warranty terms, exceptions or deviations from specification, quotation submission timestamp, and compliance with technical specifications. Supports commercial bid tabulation, vendor price comparison analysis, and historical lead time benchmarking for award decisions. Links to RFQ and vendor master.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Legally binding purchase order issued to a vendor for supply of materials, equipment, or services, including full amendment and change order history as versioned records. Captures PO number, vendor, project and WBS element, delivery address, incoterms, payment terms, currency, total PO value, GMP flag, retention percentage, PO type (standard, blanket, framework, subcontract), approval status, NTP date, SAP document number, current version/revision number, and complete amendment audit trail (amendment number, amendment type — scope change, quantity change, price adjustment, delivery date change, CO, original value, amended value, value delta, reason, approval status, amendment date). Core transactional anchor of the procurement domain sourced from SAP MM. SSOT for all PO commercial state including historical changes and amendments.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items within a purchase order capturing material or service description, ordered quantity, unit of measure, unit price, line total, delivery schedule date, WBS element, cost code, account assignment category, goods receipt indicator, invoice receipt indicator, and cumulative goods receipt quantity to date. Enables granular cost tracking and delivery monitoring at the PO line level.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Material goods receipt records capturing physical delivery of materials or equipment to site or warehouse against a PO. Records GR document number, delivery date, received quantity, unit of measure, storage location, batch number, delivery note reference, condition on receipt (accepted, rejected, partial), receiving inspector, and SAP material document number. Triggers inventory update and three-way match for invoice verification.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal purchase requisition raised by project or site teams to initiate procurement of materials, equipment, or services. Captures requisition number, requesting department, project and WBS element, material or service description, required quantity, unit of measure, required delivery date, estimated cost, budget availability flag, approval workflow status (pending, approved, rejected), approver, urgency classification, and conversion status (converted to RFQ or PO). Sourced from SAP MM PR process. Entry point for all formal procurement activity.' .

ind:VendorInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Invoice' ;
    rdfs:comment 'Vendor invoices received against purchase orders capturing invoice number, vendor, PO reference, invoice date, invoice amount, tax amount, currency, payment due date, three-way match status (PO-GR-Invoice), invoice verification status (blocked, approved, posted), SAP FI document number, and dispute flag. Distinct from client billing invoices owned by the finance domain — this is the SSOT for vendor payable documents in procurement.' .

ind:Master rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Master' ;
    rdfs:comment 'Authoritative master record for all construction materials and consumables used across projects. Captures material identity, detailed technical specifications (applicable standards — ASTM, BS, ISO, ACI, AISC — grade/class, minimum performance criteria, specification code, specification revision), classification (concrete, steel, MEP components, aggregates, timber, formwork, etc.), unit of measure, approved equivalent substitutes with engineering justification, LEED compliance flags, LEED credit applicability, hazardous material indicators, shelf life, storage requirements, and supplier cross-references. Manages specification lifecycle (draft, approved, superseded) and material qualification status. Records approved substitutions with reason, client/engineer approval reference, cost impact, and affected BOQ lines. This is the SSOT for material identity, technical specifications, and approved substitutes in the construction enterprise — all transactions reference this record.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master record for physical warehouse, laydown yard, and storage locations across construction sites and central depots. Tracks warehouse type (bonded, open yard, climate-controlled, hazmat-certified), capacity (area sqm, weight tonnes), GPS coordinates, site association, custodian, operating hours, hazardous material storage certification, and granular storage locations (rack positions, bin rows, open yard zones). Supports multi-site inventory management, material transfer logistics, and FIFO/FEFO stock management for batch-tracked materials.' .

ind:StockLevel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Stock Level' ;
    rdfs:comment 'Current on-hand inventory position for each material at each warehouse/storage location. Captures unrestricted stock, quality-inspection stock, blocked stock, reserved stock, in-transit quantities, and committed (reserved-for-activity) quantities. Tracks reorder point, minimum/maximum stock levels, safety stock thresholds, and last movement date. Updated in real-time by stock movements (receipts, issues, transfers, returns). Critical for BOQ reconciliation, preventing site stoppages due to material shortages, and supporting procurement trigger automation.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of materials physically received at site or warehouse against a Purchase Order (PO). Captures GR date, PO reference, delivery note number, supplier, material, quantity received, unit of measure, batch/lot number, storage location, receiving inspector, and GR status (partial, complete, over-delivery). Triggers quality inspection workflow and updates stock levels. Aligns with SAP S/4HANA MIGO GR posting and Procore material delivery logs.' .

ind:GoodsIssue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Goods Issue' ;
    rdfs:comment 'Transactional record of materials issued from warehouse/stock to a WBS element, cost center, or work front for construction consumption. Captures issue date, WBS/cost code, material, quantity issued, unit of measure, batch/lot, issuing warehouse, requestor, and issue reason. Drives material cost allocation to project activities and updates stock levels. Supports EVM cost tracking and BOQ consumption reconciliation.' .

ind:BatchLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Batch Lot' ;
    rdfs:comment 'Batch and lot traceability master for materials requiring full chain-of-custody tracking — concrete pours (batch plant ticket), structural steel heats, rebar coils, MEP cable drums, and chemical admixtures. Captures batch number, lot number, manufacturer, production date, expiry date, certificate of conformance reference, test results summary, quarantine status, and linked goods receipt. Supports FAT/SAT traceability and NCR investigations.' .

ind:BoqLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Boq Line' ;
    rdfs:comment 'Bill of Quantities (BOQ) line item representing material and work quantities baselined for a project, used as the material domain\'s reference for take-off reconciliation, consumption tracking, and procurement planning. Captures BOQ item code, description, unit of measure, contract quantity, unit rate, total value, WBS element, trade/discipline, and revision history. While contractual BOQ ownership may reside in the contract domain, this product serves as the material domain\'s operational view for MTO reconciliation, material consumption variance analysis, and progress measurement against planned quantities.' .

ind:MtoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Mto Line' ;
    rdfs:comment 'Material Take-Off (MTO) line item derived from engineering drawings and BIM models, representing the estimated material quantities required for construction. Captures MTO item, material master reference, design quantity, wastage factor, net required quantity, unit of measure, drawing/BIM model reference, discipline (civil, structural, MEP), revision number, and MTO status (draft, approved, issued-for-procurement). Bridges design domain and procurement/inventory planning.' .

ind:Requisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Requisition' ;
    rdfs:comment 'Site or project team request for materials to be issued from warehouse stock or procured. Captures requisition number, requesting WBS/work front, required material, quantity, required-by date, priority, justification, approval status (pending, approved, rejected), approver, and fulfilment status. Triggers either a goods issue (if stock available) or a purchase requisition in procurement. Supports site operations planning and material demand management.' .

ind:MtoHeader rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Mto Header' ;
    rdfs:comment 'Master reference table for mto_header. Referenced by mto_header_id.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Core master record for every piece of construction equipment and fleet vehicle owned, long-term leased, or rented by the company. Captures asset identity, classification (crane, excavator, concrete pump, generator, fleet vehicle, small tool), make, model, serial number, year of manufacture, acquisition date, acquisition cost, ownership type (owned/rented/leased), current status (active, idle, under maintenance, disposed), SAP PM equipment number, HCSS HeavyJob asset ID, regulatory compliance class, and asset lifecycle stage. For disposed assets: captures disposal method (sale, auction, scrap, write-off, trade-in), disposal date, disposal proceeds, buyer details, reason for disposal, and authorizing approver. This is the SSOT for all equipment identity and lifecycle data across the enterprise, from commissioning through disposal.' .

ind:AssetCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Reference classification hierarchy for construction equipment and fleet assets. Defines the taxonomy of equipment types used across the enterprise: major categories (heavy earthmoving, lifting, concrete, MEP, fleet, small tools, generators), sub-categories, and equipment class codes aligned with HCSS HeavyJob cost coding and SAP PM functional location structures. Drives cost coding, depreciation rules, maintenance strategy assignment, and utilization benchmarking.' .

ind:FleetAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fleet Assignment' ;
    rdfs:comment 'Transactional record capturing the assignment of a specific piece of equipment or fleet vehicle to a project, site, or work front for a defined period. Tracks assignment start and end dates, assigned project, site location, responsible operator or driver, mobilization status, cost allocation code (WBS element), and applicable internal hire rate (ownership rate, operating rate, standby rate per hour/day/week). Supports equipment utilization tracking, inter-project cost allocation, internal charge-back to projects, and site logistics planning. Sourced from HCSS HeavyJob and SAP PS project systems.' .

ind:Hours rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Hours' ;
    rdfs:comment 'Daily or shift-level transactional record of equipment operating hours, idle hours, standby hours, and downtime events captured from HCSS HeavyJob field time tracking. Includes cost code, operator ID, project and WBS reference, fuel consumption, meter reading (odometer or hour meter), shift date, production quantity achieved. For non-productive time: captures downtime start/end timestamps, duration, downtime category (breakdown, awaiting parts, awaiting operator, weather hold, scheduled maintenance), root cause code, resolution action, and impact assessment. Foundational for equipment utilization rate calculation, cost-per-hour analysis, MTTR (Mean Time To Repair), MTBF (Mean Time Between Failures), availability rate reporting, and CPI/SPI reporting under EVM. SSOT for all equipment time and downtime recording. Primary source: HCSS HeavyJob daily time entry.' .

ind:MaintenancePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Plan' ;
    rdfs:comment 'Master record defining the preventive maintenance strategy and schedule for a class of equipment or individual asset. Captures maintenance plan type (time-based, meter-based, condition-based), service intervals (e.g., every 250 engine hours, every 6 months), maintenance task list reference, responsible maintenance team, estimated duration, parts and materials required, and compliance requirements (e.g., crane certification intervals, OSHA inspection schedules). Sourced from SAP PM Maintenance Plan.' .

ind:MaintenanceOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Order' ;
    rdfs:comment 'Transactional work order record for a specific maintenance activity executed on an asset, generated from a maintenance plan (preventive) or raised as a corrective/breakdown order from a notification. Captures order type (preventive, corrective, breakdown, statutory inspection), priority, planned and actual start/end dates, assigned technician, labor hours, parts consumed (part number, quantity, unit cost per line item), total maintenance cost (labor + parts + external services), order status (created, released, in-progress, completed, technically complete, closed), and SAP PM order number. Supports maintenance cost tracking at labor and parts level, asset downtime analysis, warranty claim evidence, and compliance audit trails. Parts consumption data here serves as the equipment domain\'s record of materials used — material domain owns stock levels and replenishment.' .

ind:InspectionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Inspection Record' ;
    rdfs:comment 'Transactional record of a statutory, regulatory, or internal safety inspection performed on a piece of equipment, and the master register of all resulting compliance certificates issued. Captures inspection type (pre-start check, periodic statutory inspection, OSHA compliance check, crane load test, lifting gear inspection, pressure vessel test, FAT/SAT), inspection date, inspector name and certification, pass/fail outcome, defects identified, corrective actions required, next inspection due date. For certificates: captures certificate type (crane load test certificate, pressure vessel certificate, lifting gear certificate, OSHA compliance certificate, insurance certificate), certificate number, issuing authority, issue date, expiry date, and document storage reference. SSOT for all equipment inspection events AND asset-level compliance certificates. Supports OSHA compliance, insurance requirements, equipment fitness-for-use certification, pre-mobilization compliance checks, and regulatory audit trails. Distinct from quality ITP inspections (owned by quality domain) and operator certifications (which track people, not assets).' .

ind:RentalAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Rental Agreement' ;
    rdfs:comment 'Master record governing the rental or hire of external equipment from a plant hire company or equipment supplier. Captures rental supplier, equipment description and type, rental start and end dates, agreed daily/weekly/monthly hire rate, minimum hire period, mobilization and demobilization charges, insurance requirements, operator-supplied flag, rental PO reference, and total committed rental cost. Distinct from procurement POs (owned by procurement domain) — this is the equipment-domain SSOT for rental fleet management and cost accrual.' .

ind:FuelTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fuel Transaction' ;
    rdfs:comment 'Transactional record of fuel issued to a piece of equipment or fleet vehicle. Captures fuel type (diesel, petrol, LPG), quantity issued (litres), unit cost, total cost, issuing fuel point or bowser, date and time of issue, hour meter or odometer reading at fueling, project and cost code allocation, and operator confirmation. Enables fuel consumption tracking, cost-per-hour analysis, carbon emissions reporting (ISO 14001), and detection of fuel wastage or theft.' .

ind:FunctionalLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'Master reference table for functional_location. Referenced by functional_location_id.' .

ind:CraftWorker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Craft Worker' ;
    rdfs:comment 'Master record for all craft labor personnel deployed on construction projects including hourly trade workers and working foremen/supervisors. Captures worker identity, trade classification (from skill_trade taxonomy), employment type (direct hire, agency, union referral), union affiliation and local, craft code, supervisory role flag, home project assignment, mobilization status, security clearance level, and field deployment history. SSOT for individual field worker identity in the workforce domain. Workers may hold multiple trade classifications and rotate between craft and supervisory roles across projects. Integrates with SAP SuccessFactors for HCM master data and HCSS HeavyJob for field time tracking.' .

ind:Crew rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Crew' ;
    rdfs:comment 'Master record for a named field crew or gang deployed on a construction project. Captures crew name, crew type (civil, MEP, structural, concrete, etc.), foreman assignment, home cost code, project assignment, crew size, and active status. A crew is the primary unit of field labor organization in construction operations. Distinct from individual worker records.' .

ind:CrewAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Crew Assignment' ;
    rdfs:comment 'Transactional record linking individual craft workers to a specific crew for a defined period on a project. Captures worker role within the crew (laborer, operator, foreman, lead), assignment start and end dates, cost code, WBS element, shift, and assignment status. Enables tracking of crew composition changes over time and supports labor cost allocation.' .

ind:Timesheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Timesheet' ;
    rdfs:comment 'Daily field timesheet record capturing hours worked by a craft worker on a specific project, cost code, and WBS element. Sourced from HCSS HeavyJob. Captures regular hours, overtime hours, double-time hours, shift type, work classification, pay type, equipment operated, and approval status. Core transactional record for labor cost coding and payroll processing in field operations.' .

ind:TimesheetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Timesheet Line' ;
    rdfs:comment 'Individual line item within a daily timesheet record, capturing granular labor allocation to a specific cost code, activity, WBS element, or equipment unit within a single shift. Supports split-coding of hours across multiple cost centers in a single day. Enables detailed job costing and EVM (Earned Value Management) labor tracking at the activity level.' .

ind:LaborCostCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Cost Code' ;
    rdfs:comment 'Unified reference master for labor cost codes and trade/skill classifications used to classify and allocate field labor expenditure and define workforce competency categories. Captures cost code identifier, description, trade code, trade name, craft discipline (ironworker, pipefitter, electrician, carpenter, etc.), union jurisdiction, prevailing wage classification, required certification types, budget category, SAP PS (Project Systems) WBS mapping, and active status. Serves as the single source of truth for both cost allocation and trade/skill classification — the authoritative taxonomy of construction trades and their cost coding. Integrates with SAP S/4HANA Project Systems and HCSS HeavyJob cost coding structures. Referenced by timesheets, labor rates, agency orders, and staffing plans for consistent trade and cost classification.' .

ind:CraftCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Craft Certification' ;
    rdfs:comment 'Master record for a specific trade certification, license, or qualification held by a craft worker. Captures certification type (OSHA 10/30, NCCER credentials, rigger, scaffolder, welder qualification, crane operator NCCCO, confined space, etc.), issuing body, issue date, expiry date, certification number, verification status, and renewal requirements. Supports site access control (workers cannot badge in without valid certs), workforce competency management, and compliance with project-specific qualification requirements. Distinct from apprenticeship_progression which tracks cumulative hours and level advancement — this product tracks discrete credentials already earned.' .

ind:SkillTrade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Skill Trade' ;
    rdfs:comment 'Reference classification of construction trade skills and craft disciplines (e.g., ironworker, pipefitter, electrician, carpenter, concrete finisher, heavy equipment operator, rigger, welder). Captures trade code, trade name, union jurisdiction, prevailing wage classification, and required certification types. Used for workforce planning, crew composition, and labor rate determination.' .

ind:StaffingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Staffing Plan' ;
    rdfs:comment 'Master record for a project-level workforce staffing plan defining the planned headcount, trade mix, and labor hours required by project phase, WBS element, and time period. Captures planned vs. actual headcount, peak labor requirements, trade breakdown, source strategy (direct hire, subcontract, agency), ramp-up/ramp-down curves, and plan version. Supports workforce forecasting, labor procurement decisions, and project mobilization planning. Integrates with SAP SuccessFactors workforce planning.' .

ind:Activity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity' ;
    rdfs:comment 'Core CPM (Critical Path Method) schedule activity representing a discrete unit of work within a project WBS. Captures activity ID, name, WBS code, activity type (task-dependent, resource-dependent, level of effort, milestone), planned/actual start and finish dates, original duration, remaining duration, percent complete, calendar assignment, constraint types (start-no-earlier-than, finish-no-later-than, mandatory), float values (total float, free float), critical path flag, activity status (not started, in progress, completed, suspended), and activity code assignments for filtering and grouping. The foundational scheduling entity from which all schedule analysis, critical path calculation, and progress measurement derives.' .

ind:ActivityRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity Relationship' ;
    rdfs:comment 'Logical dependency links between schedule activities defining the CPM network logic. Captures predecessor and successor activity references, relationship type (Finish-to-Start, Start-to-Start, Finish-to-Finish, Start-to-Finish), lag/lead duration, lag time unit, driving relationship flag, and relationship source (scheduling tool export, manual entry). Enables critical path calculation, schedule network analysis, and what-if scenario modeling for delay impact assessment.' .

ind:ScheduleBaseline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Schedule Baseline' ;
    rdfs:comment 'Approved project schedule baseline snapshot capturing the time-phased plan against which actual progress is measured. Stores baseline name, baseline type (original, current, supplemental), approval date, approved-by reference, baseline start and finish dates, total baseline duration, baseline data date, and scheduling tool baseline project reference. Supports EVM (Earned Value Management) calculations including BCWS (Budgeted Cost of Work Scheduled) and variance analysis. Multiple baselines per project are supported (original contract baseline, re-baselined approved revisions).' .

ind:BaselineActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Baseline Activity' ;
    rdfs:comment 'Baseline-frozen snapshot of each activity\'s planned dates, durations, and resource assignments at the time a schedule baseline was approved. Stores baseline early start, baseline early finish, baseline late start, baseline late finish, baseline original duration, baseline remaining duration, baseline percent complete, and baseline total float for each activity within a specific baseline. Enables schedule variance analysis (SV = BCWP - BCWS) and start/finish variance reporting against the approved plan.' .

ind:Resource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Resource' ;
    rdfs:comment 'Resource definitions assigned to schedule activities for resource-loaded scheduling and leveling. Captures resource name, resource type (labor, non-labor, material), unit of measure, max units per time period, default units per time, price per unit, resource calendar, overtime factor, and resource role. Sourced from the enterprise scheduling tool resource dictionary. Supports resource leveling, resource histograms, and cost-loaded schedule generation. Distinct from workforce employee records — this is the scheduling resource abstraction used for capacity planning and EVM cost loading.' .

ind:ActivityResourceAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity Resource Assignment' ;
    rdfs:comment 'Assignment of a schedule resource to a specific activity, capturing the planned and actual resource consumption. Stores assigned resource reference, activity reference, budgeted units, actual units to date, remaining units, budgeted cost, actual cost, remaining cost, resource distribution curve (front-loaded, back-loaded, bell, linear), overtime units, and assignment status. Enables resource-loaded schedule analysis, cost-loaded CPM, and EVM BCWP (Budgeted Cost of Work Performed) calculations.' .

ind:ProgressUpdate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Progress Update' ;
    rdfs:comment 'Periodic schedule progress update record capturing actual performance data, EVM metrics, and critical path state at a specific data date. Stores actual start/finish dates, remaining duration, percent complete (duration, units, physical), actual/remaining units, update source (field report, P6 import, HCSS HeavyJob), reporting period definition (period number, dates, frequency, status), EVM metrics (BCWP, BCWS, SPI, SV, SV%, forecast completion date), and critical path snapshot (project completion date, total float, critical activity count, path drift indicator). Represents the single transactional record of schedule state per reporting period. Enables schedule performance trending, SPI reporting, and critical path monitoring over time.' .

ind:LookaheadPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Lookahead Plan' ;
    rdfs:comment 'Short-interval look-ahead schedule (typically 3-week or 6-week rolling window) used for near-term construction planning and crew coordination. Captures look-ahead period dates, horizon (weeks), responsible superintendent/foreman, work front or zone, constraint identification, and readiness status (materials, permits, crew, equipment confirmed). Supports Last Planner System (LPS) and Percent Plan Complete (PPC) tracking. Bridges the gap between the master CPM schedule and daily site execution. The header record for lookahead_activity line items.' .

ind:DelayEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Delay Event' ;
    rdfs:comment 'Discrete delay event record capturing a specific occurrence that caused or is causing schedule delay. Stores event name, event type (weather, design change, employer instruction, utility conflict, permit delay, labor dispute, material shortage, force majeure), event start date, event end date, impacted activities, delay duration (calendar days, working days), responsibility party (employer, contractor, third party, neutral), delay category (excusable compensable, excusable non-compensable, non-excusable), linked EOT claim reference, and mitigation measures taken. Supports delay analysis (as-planned vs as-built, time impact analysis, windows analysis).' .

ind:Itp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Itp' ;
    rdfs:comment 'Inspection and Test Plan (ITP) master record defining the structured quality control framework for a construction work package or activity. Captures the inspection scope, hold/witness/review points, applicable standards (ISO 9001, IBC, ACI), responsible parties, acceptance criteria, and linkage to the WBS. Serves as the authoritative QA/QC planning document governing all inspection activities on a project.' .

ind:ItpLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Itp Line' ;
    rdfs:comment 'Individual inspection or test activity line item within an ITP. Defines a specific hold point, witness point, or review point with its activity description, inspection method, acceptance criteria, frequency, responsible discipline, and required documentation. Each line drives a discrete inspection event on site.' .

ind:Inspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection' ;
    rdfs:comment 'Transactional record of a physical quality inspection or checklist verification event conducted on site, at a factory, or workshop. Captures inspection date, location, inspector identity, ITP line reference, checklist template used, item-level verification results (pass/fail/N/A per check item with remarks), overall outcome (pass/fail/conditional), observations, non-conformances raised, digital sign-off, and attachments (photos, measurements). Covers all inspection types: hold-point inspections, witness-point inspections, pre-pour checks, structural inspections, MEP inspections, and any checklist-based quality verification. Each record serves as the auditable evidence trail for QA/QC compliance and may trigger NCR creation on failure.' .

ind:Ncr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Ncr' ;
    rdfs:comment 'Non-Conformance Report (NCR) and corrective action record capturing formal documentation of construction deliverables, materials, or workmanship that do not meet specified requirements. Tracks NCR number, description of non-conformance, affected work package, root cause analysis, disposition (accept-as-is, rework, reject, concession), corrective and preventive actions (CAPA) with responsible parties, target and actual completion dates, verification method, effectiveness review, and closure status. Supports hold/release workflow and the full CAPA cycle required under ISO 9001 clause 10.' .

ind:CorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Corrective and preventive action record linked to an NCR. Tracks the specific remediation steps assigned, responsible party, target completion date, actual completion date, verification method, and effectiveness review outcome. Supports the CAPA (Corrective Action / Preventive Action) cycle required under ISO 9001 clause 10.' .

ind:Checklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Checklist' ;
    rdfs:comment 'Quality inspection checklist template defining the structured set of verification items for a specific construction activity type (e.g., concrete pour, rebar placement, waterproofing, structural steel erection). Captures checklist name, revision, activity type, applicable standard, approval status, and ordered check items with acceptance criteria and inspection method. Used as the governing template when conducting inspections — each inspection references a checklist to ensure consistent verification coverage.' .

ind:TestCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Certificate' ;
    rdfs:comment 'Material test certificate and laboratory test result record capturing certified testing outcomes for construction materials (concrete, steel, aggregates, bitumen, soil, asphalt, geotextiles). Stores certificate number, sample ID, material type, batch/heat number, sampling date and location, test standard (ASTM, BS, EN, AASHTO), test parameters and measured values, pass/fail determination, issuing laboratory, laboratory accreditation number, and traceability to purchase order and delivery lot. Covers both third-party MTC documents received from suppliers and in-house/independent lab test results for site-sampled materials.' .

ind:PunchList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Punch List' ;
    rdfs:comment 'Punch list (snagging list) master record grouping outstanding defects, incomplete works, and commissioning items requiring resolution before a project milestone (mechanical completion, practical completion, or handover). Captures punch list number, associated milestone, project area/zone, creation date, total items count, open/closed item counts, target close-out date, responsible party, and overall status. Drives the close-out workflow that gates contractual handover.' .

ind:PunchItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Punch Item' ;
    rdfs:comment 'Individual punch list item within a punch list record. Captures item number, description, location, category (structural, MEP, architectural, civil), responsible subcontractor, priority, target completion date, actual completion date, verification inspector, and closure status. Drives the close-out workflow for practical completion.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Project Quality Plan (PQP) master document defining the overall QA/QC strategy for a specific project. Captures organizational quality responsibilities, applicable standards and codes, inspection regime definitions, document control procedures, audit schedule, NCR procedures, training requirements, and continuous improvement mechanisms. Serves as the top-level quality governance document per ISO 9001 and contract requirements. All ITPs, checklists, and audit programs trace back to this plan.' .

ind:Incident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Incident' ;
    rdfs:comment 'Core master record for ALL HSE safety events on construction sites, encompassing the full severity spectrum: Lost Time Injuries (LTI), medical treatment cases (including body part affected, treatment type, treating physician, return-to-work date, fitness-for-duty status), first aid cases, restricted work cases, near-misses, unsafe conditions, behavioral safety observations, property damage, dangerous occurrences, and environmental events. Captures incident classification/type, severity, location (project/site/area), date/time, injured party details, immediate cause, root cause category, OSHA recordability flag, TRIR contribution, days away/restricted/transferred (DART), regulatory notification status, environmental media affected, and workers compensation claim reference. Serves as the single unified safety event register supporting OSHA 300/300A log generation, TRIR/LTIFR/DART rate calculations, leading indicator trending, and ISO 45001 reporting. Sourced from Intelex incident management module.' .

ind:IncidentInvestigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Incident Investigation' ;
    rdfs:comment 'Detailed investigation record linked to a reported HSE incident. Captures investigation team members, root cause analysis methodology (5-Why, Fishbone), contributing factors, immediate causes, systemic causes, investigation findings, corrective action recommendations, and regulatory submission details. Tracks investigation status from open through closed. Sourced from Intelex.' .

ind:Swms rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Swms' ;
    rdfs:comment 'Safe Work Method Statement (SWMS) master records defining step-by-step work procedures for high-risk construction activities. Captures activity description, identified hazards, risk rating (before and after controls), control measures, PPE requirements, responsible supervisor, approval status, review date, and applicable legislation. SSOT for SWMS documentation across all projects and sites.' .

ind:PermitToWork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Permit To Work' ;
    rdfs:comment 'Permit to Work (PTW) records authorizing high-risk construction activities such as hot work, confined space entry, working at heights, electrical isolation, and excavation. Captures permit type, issuing authority, work scope, hazard identification, control measures, validity period, site location, isolations required, and sign-off chain. Sourced from Intelex Permit to Work module.' .

ind:ToolboxMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Toolbox Meeting' ;
    rdfs:comment 'Toolbox Meeting (TBM) records capturing pre-shift and pre-task safety briefings conducted on construction sites. Records meeting date, time, location, project/site, crew/trade group, topics discussed (linked to site hazards from risk_assessment), hazards highlighted, specific control measures communicated, attendee list with sign-off confirmation, facilitator name, and duration. Supports demonstration of safety communication compliance under OSHA and ISO 45001 clause 7.4 (Communication). Attendance records are embedded as line items within the meeting record. Sourced from Intelex.' .

ind:HseInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hse Inspection' ;
    rdfs:comment 'Routine, scheduled, and ad-hoc HSE site inspection records including emergency drill exercises and management safety walks. Captures field observations of safety conditions, housekeeping, PPE compliance, equipment safety, scaffolding/formwork integrity, excavation stability, crane setup, work practice compliance, and emergency preparedness. Records inspection type (routine/targeted/emergency drill/pre-task/management walk), inspector, site area, checklist template used, pass/fail items with photographic evidence references, deficiencies noted with severity classification, immediate actions taken, and drill-specific metrics (response time, evacuation completeness, muster accuracy). Distinct from formal audits — inspections are operational field checks and exercises performed by site safety officers and supervisors. Deficiencies link to corrective_action for remediation tracking. Sourced from Intelex Inspections module.' .

ind:HsePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hse Plan' ;
    rdfs:comment 'Project-level HSE (Health Safety Environment) Plan master record defining the safety management framework for a specific construction project. Captures plan version, approval status, applicable regulations, site-specific hazards, emergency response procedures, HSE objectives and targets, organizational responsibilities, and review schedule. SSOT for project HSE governance documentation.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Unified hazard and risk register serving as the single source of truth for all identified hazards and their risk evaluations across construction project sites. Captures hazard identification (type: fall, struck-by, caught-between, electrocution, excavation collapse, chemical exposure, environmental), activity/task scope, site location/zone, initial risk rating (likelihood x consequence matrix), control hierarchy applied (eliminate/substitute/engineer/admin/PPE), residual risk rating, control measures in place, responsible party, status (open/controlled/eliminated/closed), source (inspection/incident/design review/JHA), review date, and approver. Serves triple purpose: (1) formal risk assessment for specific activities supporting SWMS development and PTW issuance, (2) live site hazard inventory (hazard register) supporting daily pre-start briefings and toolbox meeting topic selection, and (3) Job Hazard Analysis (JHA) documentation for task-level risk evaluation. Maintains hazard register entries as living records updated through inspections, incidents, and periodic reviews. SSOT for all identified hazards, risk evaluations, and control effectiveness across the project portfolio.' .

ind:HazardRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hazard Register' ;
    rdfs:comment 'Site-level hazard register maintaining a live inventory of identified hazards across construction project sites. Captures hazard type (fall, struck-by, caught-between, electrocution, excavation collapse, chemical exposure), location/zone, initial risk rating (likelihood x consequence), control measures in place, hierarchy of controls applied, responsible party, status (open/controlled/eliminated/closed), last review date, and source (risk assessment/inspection/incident). Serves as the operational SSOT for site hazard visibility, supports daily pre-start briefings, and feeds toolbox meeting topic selection.' .

ind:EnvironmentalMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Environmental Monitoring' ;
    rdfs:comment 'Environmental monitoring measurement records capturing periodic readings for air quality, noise levels, vibration, water quality, and soil contamination at construction sites. Captures monitoring parameter, measurement value, unit, threshold limit, exceedance flag, monitoring location, instrument used, and responsible party. Supports ISO 14001 environmental management and regulatory permit compliance.' .

ind:CostCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Code' ;
    rdfs:comment 'Reference master for the construction cost coding taxonomy used to classify all project expenditures into standardized categories. Defines the hierarchical cost breakdown structure (CBS) — typically 2-4 levels deep — covering labor, materials, equipment, subcontract, and overhead categories. Each cost code carries a unique identifier, description, parent code, level indicator, unit of measure for quantity tracking, standard rate (where applicable), and active/inactive status. Used across SAP S/4HANA Project Systems and Viewpoint Vista as the authoritative classification spine for budget allocation, actual cost posting, EVM reporting, and job cost analysis.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational unit master representing financial responsibility centers within the construction enterprise — project cost centers, regional offices, corporate overhead centers, and shared-service centers. Maps to SAP S/4HANA cost center accounting (CO-CCA) and serves as the primary dimension for internal P&L reporting, overhead allocation, and EBITDA decomposition. Each cost center has a responsible manager, validity period, and hierarchy assignment.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General Ledger chart of accounts master defining every account used in the construction enterprise\'s financial statements — revenue accounts, cost-of-construction accounts, overhead, assets, liabilities, and equity. Sourced from SAP S/4HANA FI-GL and aligned to IFRS/GAAP chart of accounts. Provides the authoritative account classification for all journal entries, AP/AR postings, and financial consolidation.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core double-entry accounting document and its constituent debit/credit line items, capturing all financial postings in the construction enterprise\'s general ledger. Each document contains a header (document number, posting date, document type, reference, reversal indicator) and one or more lines specifying GL account, cost center, WBS element, cost code, debit/credit amount, currency, tax code, and assignment fields. Covers standard accruals, cost allocations, revenue recognition entries (percentage-of-completion per IFRS 15), intercompany eliminations, period-end adjustments, reclassifications, and FX revaluation entries. Sourced from SAP S/4HANA FI-GL and Viewpoint Vista. Provides full project-level financial traceability from trial balance to source transaction for audit and IFRS/GAAP compliance. Owns both header-level and line-level data as a single SSOT.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line item within a journal entry, capturing the GL account, cost center, WBS element, amount, currency, and posting date for each leg of a double-entry transaction. Enables granular drill-down from trial balance to source transaction for audit and IFRS/GAAP compliance. Sourced from SAP S/4HANA FI-GL line item tables.' .

ind:ProjectBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Project Budget' ;
    rdfs:comment 'Authoritative WBS-linked budget record for each construction project, capturing the approved contract budget, internal target cost, contingency reserves, and management reserve. Tracks original budget, approved change order (CO) adjustments, and current approved budget (CAB) at each WBS level. Integrates with Oracle Primavera P6 baseline data and SAP S/4HANA PS module. Serves as the baseline for EVM (Earned Value Management) calculations including BCWS (Budgeted Cost of Work Scheduled).' .

ind:JobCostTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Job Cost Transaction' ;
    rdfs:comment 'Granular cost transaction record capturing every actual cost posted against a construction project\'s WBS element and cost code — labor timesheets, material receipts, equipment usage charges, subcontractor invoices, and overhead allocations. The primary source for job costing and cost-to-complete analysis. Sourced from Viewpoint Vista job costing module and SAP S/4HANA CO-PA. Feeds EVM actual cost (ACWP) calculations and CPI (Cost Performance Index) reporting.' .

ind:ProgressBilling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Progress Billing' ;
    rdfs:comment 'Construction progress billing, payment certification, and client AR invoice lifecycle record covering the full claim-to-collection cycle. Captures the payment application (AIA G702/G703 or FIDIC payment certificate) including scheduled value by WBS/BOQ line, percentage complete, amount earned to date, current period claim, retention withheld, and net amount due. Also owns the formal AR tax invoice raised after payment certificate approval — invoice number, client reference, contract reference, invoice date, due date, gross amount, VAT/GST, retention deducted, net receivable, payment status, aging bucket, and collection history. Sourced from Procore, SAP S/4HANA FI-AR, and Viewpoint Vista. The authoritative SSOT for all client-facing billing, accounts receivable invoices, and receivables management in construction.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Vendor and subcontractor invoice record in the Accounts Payable (AP) ledger, capturing the full supplier billing lifecycle from receipt through approval to payment. Records invoice number, vendor/subcontractor reference, PO/subcontract reference, invoice date, due date, gross amount, tax/VAT amount, retention withheld, net payable, payment terms, approval workflow status, three-way match status (PO-GR-Invoice), and dispute/hold flags. Sourced from SAP S/4HANA FI-AP and Viewpoint Vista AP module. Covers supplier invoices for materials, equipment hire, professional services, and subcontractor progress claims. The authoritative SSOT for all accounts payable obligations in the construction enterprise.' .

ind:PaymentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Record' ;
    rdfs:comment 'Financial payment transaction record capturing both outgoing payments to vendors/subcontractors (AP disbursements) and incoming receipts from clients (AR collections). Captures payment date, payment method (wire transfer, cheque, ACH, LC drawdown), bank account, amount paid/received, currency, exchange rate, invoice references cleared, bank clearing status, and remittance advice details. Supports multi-currency payment runs, partial payments, and bank reconciliation. Sourced from SAP S/4HANA FI payment runs and Viewpoint Vista.' .

ind:CashFlowForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cash Flow Forecast' ;
    rdfs:comment 'Forward-looking cash flow projection record for construction projects and the corporate entity, capturing forecast inflows (client milestone payments, retention releases, advance drawdowns) and outflows (subcontractor payments, material procurement, payroll, equipment hire, bond premiums) by period (weekly/monthly). Includes S-curve cash flow profile, cumulative cash position, peak funding requirement, working capital gap analysis, and variance to prior forecast. Supports both project-level forecasting for contract cash management and corporate-level treasury forecasting for bonding capacity and credit facility utilization.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Master reference table for company_code. Referenced by company_code_id.' .

ind:ChartOfAccounts rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Master reference table for chart_of_accounts. Referenced by chart_of_accounts_id.' .

ind:PlanCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Plan Commitment' ;
    rdfs:comment 'This association product represents the formal commitment between a lookahead_plan and an activity within the Last Planner System (LPS). It captures the per-window readiness state, constraint tracking, and planned execution dates for a specific activity as it appears in a specific lookahead plan period. Each record links one lookahead_plan to one activity and carries attributes that exist only in the context of that plan-window/activity pairing — readiness flags, window-specific dates, and constraint details that change from one rolling window to the next.. Existence Justification: In Last Planner System (LPS) construction scheduling, a lookahead plan explicitly manages a curated set of activities for a rolling planning window (typically 3–6 weeks). A single lookahead plan covers multiple activities, AND a single activity can appear in multiple successive lookahead plans (e.g., a multi-week activity spans plan week 1, week 2, and week 3 rolling windows). The relationship itself — called a \'lookahead commitment\' or \'plan commitment\' — carries its own data: window-specific readiness flags, constraint tracking, and planned dates within that specific window that differ from the master schedule dates.' .

ind:OpportunityContactEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Opportunity Contact Engagement' ;
    rdfs:comment 'This association product represents the Role-based engagement between a client contact and a client opportunity in the BD pipeline. It captures which stakeholder contacts are formally engaged on a given opportunity, in what capacity, and with what level of evaluative influence. Each record links one contact to one client_opportunity with attributes — role, engagement date, primary evaluator flag, and evaluation score contribution — that exist only in the context of this specific contact-opportunity relationship. Sourced from Salesforce CRM OpportunityContactRole object.. Existence Justification: In construction BD operations, client contacts are actively engaged across multiple opportunities — a procurement officer may evaluate bids on three concurrent projects, while a single opportunity involves a panel of client contacts (owner, technical lead, legal counsel, executive sponsor). This is not an analytical correlation; BD teams actively manage who is engaged on which opportunity, in what role, and at what stage. The relationship is a recognized CRM concept called \'Opportunity Contact Role\' (Salesforce standard object) and carries its own operational data.' .

ind:PurchasingInfoRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchasing Info Record' ;
    rdfs:comment 'This association product represents the Contract between vendor and material_catalog in the procurement domain. It captures the approved sourcing relationship between a specific vendor and a specific catalog material, including negotiated price, lead time, and ordering constraints. Each record corresponds to an SAP MM Purchasing Info Record (PIR) — the operational entity that procurement teams create, maintain, and use to drive purchase orders, MTO processes, and goods receipt. A record exists only when a vendor is formally approved to supply a specific material.. Existence Justification: In construction procurement, a vendor supplies many catalog materials (e.g., a concrete supplier also supplies rebar, formwork, and admixtures), and a single material (e.g., structural steel) is sourced from multiple approved vendors at different prices and lead times. This is the SAP MM Purchasing Info Record (PIR) — a well-established operational business entity that procurement teams actively create, maintain, and query. The relationship carries its own data (unit price, lead time, MOQ) that belongs to neither the vendor nor the material alone.' .

ind:ScopeVariationItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Scope Variation Item' ;
    rdfs:comment 'This association product represents the Contract linkage between a scope_of_work package and a commercial_change_order in FIDIC-based construction contract administration. It captures the specific impact of a variation instruction on an individual scope package, enabling final account reconciliation, BOQ adjustments, and EOT substantiation at the scope-package level. Each record links one scope_of_work to one commercial_change_order with attributes that exist only in the context of this scope-variation pairing.. Existence Justification: In FIDIC-based EPC and lump-sum construction contracts, a single scope package (scope_of_work) can be affected by multiple change orders over the contract lifecycle (e.g., a civil works scope may receive a design change CO, an unforeseen conditions CO, and an employer-directed CO). Conversely, a single change order can span multiple scope packages simultaneously (e.g., a site-wide acceleration instruction affecting civil, mechanical, and electrical scopes). The business actively manages this relationship as a \'scope variation item\' or \'variation scope mapping\' — a recognized artifact in final account reconciliation, BOQ adjustments, and EOT substantiation.' .

# --- Attribute Properties ---
ind:constructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Construction Project Id' ;
    rdfs:comment 'Unique surrogate identifier for a construction project record in the enterprise data platform. Primary key for the construction_project master entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the client organisation that commissioned this project. Links to the client master entity for contract owner identification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Legal entity assignment: construction projects are executed under a specific legal entity (company code) for financial reporting, tax compliance, and intercompany accounting. This is fundamental for c' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:mainContractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Main Contractor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Main EPC contractor assignment for each project; required for contract management, reporting, and regulatory compliance.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:masterServicesAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Services Agreement Id' ;
    rdfs:comment 'Foreign key linking to client.master_services_agreement. Business justification: Projects executed under framework/MSA contracts must reference the governing MSA for call-off value tracking, retention terms, payment terms, and ceiling-value compliance reporting. Construction enter' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterServicesAgreement .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to client.client_opportunity. Business justification: Bid-to-project traceability: every awarded construction project originates from a won opportunity. This link enables pipeline-to-revenue conversion reporting, win-rate analysis, and bid cost recovery ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the project achieved practical completion and was formally handed over to the client. Triggers the start of the DLP (Defects Liability Period) and final account settlement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Date on which physical construction activities actually commenced on site. Recorded in Oracle Primavera P6 and Procore daily logs. May differ from NTP date due to mobilisation periods.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Budget' ;
    rdfs:comment 'Total approved project budget including all cost codes, contingency, and approved change orders (CO). Used as the control budget for EVM (Earned Value Management) and cost performance index (CPI) calculations in SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Number' ;
    rdfs:comment 'Reference number of the original bid or tender submission (RFP/RFQ) from which this project was awarded. Links project execution back to the pre-award opportunity in Salesforce CRM for win/loss analytics.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the project site is located. Used for logistics planning, local regulatory compliance, and geographic analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the contract value and all financial reporting on this project (e.g., USD, EUR, GBP, AED).' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Formal contract reference number as issued by the client or legal department. Used for contract administration, correspondence tracking in Aconex, and legal reference in all formal project documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Original awarded contract value in the project currency as defined in the contract agreement. Baseline financial figure for budget control, EVM (Earned Value Management) calculations, and P&L (Profit and Loss) reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country in which the project is physically located (e.g., USA, GBR, ARE, AUS). Used for regulatory compliance, HSE jurisdiction, and geographic reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpi rdf:type rdf:Property ;
    rdfs:label 'Cpi' ;
    rdfs:comment 'EVM (Earned Value Management) Cost Performance Index (CPI) calculated as Earned Value divided by Actual Cost. A CPI below 1.0 indicates cost overrun. Updated monthly from SAP S/4HANA Project Systems and Oracle Primavera P6 progress data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the construction project record was first created in the enterprise data platform. Used for data lineage, audit trail, and record management compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryModel rdf:type rdf:Property ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Contractual and organisational delivery model under which the project is executed. EPC (Engineering Procurement Construction), DB (Design-Build), DBB (Design-Bid-Build), PPP (Public-Private Partnership), BOT (Build-Operate-Transfer), GMP (Guaranteed Maximum Price), JV (Joint Venture). Determines risk allocation, procurement strategy, and governance structure. [ENUM-REF-CANDIDATE: EPC|DB|DBB|PPP|BOT|GMP|JV — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpEndDate rdf:type rdf:Property ;
    rdfs:label 'Dlp End Date' ;
    rdfs:comment 'Date on which the Defects Liability Period (DLP) expires, after which the contractor\'s obligation to rectify defects at no cost to the client ceases. Calculated from actual completion date plus the contractual DLP duration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Date' ;
    rdfs:comment 'Current forecast date for project completion based on latest schedule update and progress data from Oracle Primavera P6. Reflects approved EOT (Extension of Time) claims and current schedule performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Level' ;
    rdfs:comment 'Overall HSE (Health Safety and Environment) risk classification for the project based on project type, location, scope complexity, and hazard profile. Determines the level of HSE oversight, inspection frequency, and SWMS (Safe Work Method Statement) requirements as managed in Intelex.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJointVenture rdf:type rdf:Property ;
    rdfs:label 'Is Joint Venture' ;
    rdfs:comment 'Indicates whether this project is being executed under a Joint Venture (JV) arrangement with one or more partner organisations. Affects financial consolidation, risk sharing, and governance reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnerSharePct rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Share Pct' ;
    rdfs:comment 'The company\'s ownership or participation percentage in the Joint Venture (JV) arrangement for this project. Used for financial consolidation, P&L (Profit and Loss) attribution, and EBITDA reporting. Null when is_joint_venture is False.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Target' ;
    rdfs:comment 'Target LEED (Leadership in Energy and Environmental Design) certification level for the project as specified in the contract or client sustainability requirements. Drives design decisions, material procurement, and commissioning activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesRate rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Rate' ;
    rdfs:comment 'Contractual daily rate of Liquidated Damages (LD) payable to the client for each day of delay beyond the planned completion date. Critical for financial risk exposure calculation and schedule management prioritisation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ntpDate rdf:type rdf:Property ;
    rdfs:label 'Ntp Date' ;
    rdfs:comment 'Official date on which the Notice to Proceed (NTP) was issued by the client, authorising the contractor to commence construction activities. Marks the formal start of the project execution phase and is the baseline for schedule calculations in Oracle Primavera P6.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalProgressPct rdf:type rdf:Property ;
    rdfs:label 'Physical Progress Pct' ;
    rdfs:comment 'Overall physical percentage completion of the project as reported in the latest progress update from Oracle Primavera P6 and HCSS HeavyJob. Used for earned value calculations, client progress billing, and PMO dashboard reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Baseline planned completion date for the project as defined in the contract and approved schedule. Used for schedule variance analysis, LD (Liquidated Damages) exposure calculation, and EOT (Extension of Time) claim management.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Baseline planned start date for project execution as established in the approved project schedule in Oracle Primavera P6. Used for SPI (Schedule Performance Index) variance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmoClassification rdf:type rdf:Property ;
    rdfs:label 'Pmo Classification' ;
    rdfs:comment 'PMO (Project Management Office) tier classification that determines the level of governance, reporting frequency, and executive oversight applied to the project. Tier 1 projects receive the highest level of PMO scrutiny.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaveraProjectReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Project Reference' ;
    rdfs:comment 'Native project identifier in Oracle Primavera P6 scheduling system. Used for cross-system data integration between the enterprise data platform and the scheduling system of record for activity, resource, and baseline data.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreProjectReference rdf:type rdf:Property ;
    rdfs:label 'Procore Project Reference' ;
    rdfs:comment 'Native project identifier in Procore construction management platform. Used for cross-system integration to retrieve daily logs, RFIs (Requests for Information), submittals, change orders, and drawing management data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier used across Oracle Primavera P6, SAP S/4HANA Project Systems, and Procore. Serves as the cross-system business key for project identification in all operational and financial systems.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Full descriptive name of the construction project as agreed with the client and used in all formal correspondence, contracts, and reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the construction project from prospect through to completion or cancellation. Drives PMO governance workflows and financial reporting eligibility.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the construction project by sector or asset class. Determines applicable standards, certification requirements, and typical duration/value benchmarks used in PMO reporting. [ENUM-REF-CANDIDATE: infrastructure|commercial|residential|energy|industrial|transport|water|healthcare|education|mixed_use — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Internal geographic region or business unit region where the project is located (e.g., North America, Middle East, Asia Pacific, Europe). Used for PMO regional portfolio reporting and resource allocation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPct rdf:type rdf:Property ;
    rdfs:label 'Retention Pct' ;
    rdfs:comment 'Contractual retention percentage withheld by the client from each progress payment certificate. Typically released in two tranches: at practical completion and at DLP (Defects Liability Period) expiry. Used in cash flow forecasting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapProjectDefinition rdf:type rdf:Property ;
    rdfs:label 'Sap Project Definition' ;
    rdfs:comment 'SAP S/4HANA Project Systems project definition code (PS-DEF) that serves as the root WBS element for all cost postings, purchase orders, and financial transactions related to this project in the ERP system.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLatitude rdf:type rdf:Property ;
    rdfs:label 'Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the primary project site in decimal degrees (WGS84). Used for GIS (Geographic Information System) mapping, logistics routing, and environmental impact assessments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteLongitude rdf:type rdf:Property ;
    rdfs:label 'Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the primary project site in decimal degrees (WGS84). Used for GIS (Geographic Information System) mapping, logistics routing, and environmental impact assessments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spi rdf:type rdf:Property ;
    rdfs:label 'Spi' ;
    rdfs:comment 'EVM (Earned Value Management) Schedule Performance Index (SPI) calculated as Earned Value divided by Planned Value. An SPI below 1.0 indicates schedule delay. Updated monthly from Oracle Primavera P6 progress reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the construction project record in the enterprise data platform. Used for change tracking, data freshness monitoring, and incremental data pipeline processing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Top-level WBS (Work Breakdown Structure) code assigned to this project in Oracle Primavera P6 and SAP S/4HANA Project Systems. Serves as the hierarchical cost and schedule control framework root for all project activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Unique surrogate identifier for the WBS element record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:financeCostCodeId rdf:type rdf:Property ;
    rdfs:label 'Finance Cost Code Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_code. Business justification: Required for cost-coding WBS elements in EVM and budget reports; experts assign a cost code to each WBS element for financial tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCode .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to material.material_master. Business justification: Needed for WBS Cost Estimation to identify the primary material type for each work package.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent WBS node, enabling hierarchical decomposition of project scope. Null for root-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual costs incurred to date for this WBS element, sourced from SAP S/4HANA job costing and Viewpoint Vista. Used as the ACWP input in EVM calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Date on which work on this WBS element was physically completed, as recorded in Oracle Primavera P6. Null if work is still in progress. Used for schedule performance reporting and DLP (Defects Liability Period) trigger.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of work completed and installed to date for this WBS element, as recorded in HCSS HeavyJob field production tracking. Compared against planned_quantity for production performance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetChanges rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Changes' ;
    rdfs:comment 'Cumulative value of approved Change Orders (CO) that have modified the original budget for this WBS element. Reconciles original_budget_cost to budgeted_cost.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boqItemReference rdf:type rdf:Property ;
    rdfs:label 'Boq Item Reference' ;
    rdfs:comment 'Reference number or code linking this WBS element to the corresponding Bill of Quantities (BOQ) line item in the contract. Enables traceability between scope decomposition and contract pricing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'Total approved budget allocated to this WBS element, representing the Budget at Completion (BAC) for EVM purposes. Expressed in the project currency. Forms the baseline for CPI and SPI calculations.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of costs associated with this WBS element: direct (billable to project scope), indirect (overhead allocation), overhead, contingency (risk reserve), or provisional (BOQ provisional sum). Affects cost reporting and contract billing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Account Code' ;
    rdfs:comment 'Cost account or cost code assigned to this WBS element for job costing and financial reporting in SAP S/4HANA and Viewpoint Vista. Maps WBS scope to the chart of accounts for P&L reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csiDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Csi Division Code' ;
    rdfs:comment 'CSI MasterFormat division code classifying the type of construction work for this WBS element (e.g., 03 = Concrete, 05 = Metals, 26 = Electrical). Enables industry-standard scope classification and benchmarking.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary values on this WBS element (e.g., USD, EUR, GBP, AED). Supports multi-currency EPC projects and financial consolidation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnedValue rdf:type rdf:Property ;
    rdfs:label 'Earned Value' ;
    rdfs:comment 'Budgeted cost of work actually performed to date for this WBS element (BCWP). Calculated as percent_complete multiplied by budgeted_cost. Core EVM metric used to derive CPI and SPI at the WBS level.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmEnabled rdf:type rdf:Property ;
    rdfs:label 'Evm Enabled' ;
    rdfs:comment 'Flag indicating whether this WBS element is included in the project\'s EVM (Earned Value Management) performance measurement baseline. Summary and planning package nodes may be excluded from direct EVM measurement.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastFinishDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Finish Date' ;
    rdfs:comment 'Current forecast completion date for this WBS element based on progress to date and remaining work, as updated in Oracle Primavera P6. Used for schedule recovery planning and LD exposure monitoring.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLumpSum rdf:type rdf:Property ;
    rdfs:label 'Is Lump Sum' ;
    rdfs:comment 'Flag indicating whether this WBS element is priced as a lump sum (fixed price) rather than a re-measurable unit-rate item. Affects billing, change order valuation, and BOQ reconciliation.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Flag indicating whether this WBS element represents a contractual or project milestone (e.g., NTP, substantial completion, handover). Milestone WBS elements trigger payment certificates and schedule reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this WBS element record, either in the source system or during lakehouse processing. Supports incremental data loading and change detection.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalBudgetCost rdf:type rdf:Property ;
    rdfs:label 'Original Budget Cost' ;
    rdfs:comment 'The initial approved budget for this WBS element at project baseline, before any approved change orders or budget transfers. Enables variance analysis between original and current budget.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Current physical percent complete of the WBS element, representing the proportion of scope delivered to date. Used as the primary EVM progress measurement input. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteMethod rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Method' ;
    rdfs:comment 'Method used to calculate percent complete for EVM purposes: physical (field measurement), units_complete (quantity-based), duration (time-proportional), weighted_milestone, level_of_effort, or fixed_formula (e.g., 0/100, 50/50). Configured in Oracle Primavera P6.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Baseline planned finish date for this WBS element as established in the approved project schedule. Used for schedule variance analysis, milestone tracking, and Liquidated Damages (LD) exposure assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Total planned quantity of work for this WBS element as defined in the Bill of Quantities (BOQ) or Material Take-Off (MTO). Used for production tracking and unit-rate cost control in HCSS HeavyJob.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedValue rdf:type rdf:Property ;
    rdfs:label 'Planned Value' ;
    rdfs:comment 'Budgeted cost of work scheduled to be completed by the data date for this WBS element (BCWS). Derived from the time-phased budget baseline in Primavera P6. Used to compute Schedule Variance (SV) in EVM.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleDiscipline rdf:type rdf:Property ;
    rdfs:label 'Responsible Discipline' ;
    rdfs:comment 'Engineering or construction discipline accountable for executing this WBS element (e.g., Civil, Structural, MEP, Electrical, Mechanical, Instrumentation). Used for resource planning and discipline-level cost reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed narrative description of the work scope, deliverables, and boundaries associated with this WBS element. Aligns with the project\'s Statement of Work (SOW) and Bill of Quantities (BOQ) scope definitions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sequence defining the display order of this WBS element among its siblings within the same parent node. Used for consistent rendering in schedules, reports, and BOQ documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemWbsReference rdf:type rdf:Property ;
    rdfs:label 'Source System Wbs Reference' ;
    rdfs:comment 'Native identifier of this WBS element in the originating operational system (e.g., Primavera P6 WBS Object ID, SAP PS WBS Element internal number). Supports data lineage and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for planned and actual quantities on this WBS element (e.g., m3, m2, LF, EA, TON, LS, HR). Aligns with BOQ and MTO unit conventions. [ENUM-REF-CANDIDATE: m3|m2|LF|EA|TON|LS|HR|KG|ML|CY — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Integer depth of the WBS node within the project hierarchy (Level 1 = project root, Level 2 = major deliverable, Level 3+ = sub-deliverable or work package). Used for hierarchical filtering, rollup aggregation, and reporting drill-down.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsName rdf:type rdf:Property ;
    rdfs:label 'Wbs Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element describing the scope deliverable or work package (e.g., \'Substructure Works\', \'Electrical Installation – Level 3\'). Used in reports, dashboards, and EVM analysis.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element indicating whether work is active, not yet started, on hold, completed, or cancelled. Drives EVM eligibility and cost control reporting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsType rdf:type rdf:Property ;
    rdfs:label 'Wbs Type' ;
    rdfs:comment 'Classification of the WBS node by its role in the hierarchy: \'summary\' (rollup node), \'work_package\' (lowest deliverable-level node), \'control_account\' (EVM measurement point), or \'planning_package\' (future scope not yet detailed). Drives EVM rollup logic and cost control granularity.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each project milestone record in the Construction lakehouse Silver layer. Primary key for the project_milestone data product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Foreign key linking to safety.permit_to_work. Business justification: Certain contractual milestones require a valid permit to work before work can commence (hot work, confined space entry, energisation milestones). project_milestone has hse_clearance_required flag but ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitToWork .

ind:phaseId rdf:type rdf:Property ;
    rdfs:label 'Phase Id' ;
    rdfs:comment 'Foreign key linking to project.phase. Business justification: Milestones are organized within project phases — NTP milestone belongs to pre-construction phase, substantial completion belongs to construction phase. Linking project_milestone to phase enables phase' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Phase .

ind:predecessorMilestoneProjectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Project Milestone Id' ;
    rdfs:comment 'Reference to the immediately preceding milestone in the project schedule logic chain. Supports Critical Path Method (CPM) analysis and schedule dependency tracking within the milestone network.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:projectBaselineId rdf:type rdf:Property ;
    rdfs:label 'Project Baseline Id' ;
    rdfs:comment 'Foreign key linking to project.project_baseline. Business justification: Milestone baseline dates are established as part of the approved project baseline. The baseline_date field on project_milestone is derived from the baseline schedule. Linking project_milestone to proj' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBaseline .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Formal criteria that must be satisfied for the milestone to be considered achieved and accepted by the client or engineer. May reference ITP (Inspection and Test Plan) requirements, regulatory sign-offs, or contractual deliverable submissions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone was formally achieved and accepted. Populated only upon milestone completion and sign-off. Used for schedule variance calculation, contract administration, and LD (Liquidated Damages) trigger assessment.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved contract baseline date for the milestone, which may differ from the original planned date if a formal baseline revision or approved EOT (Extension of Time) has been incorporated. Used as the contractual reference for LD (Liquidated Damages) exposure calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Functional category grouping the milestone within the EPC (Engineering, Procurement, and Construction) project lifecycle phase. Supports schedule performance analysis by phase and PMO reporting. [ENUM-REF-CANDIDATE: design|procurement|construction|commissioning|handover|safety|financial|administrative — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the milestone within the project schedule, as assigned in Oracle Primavera P6 (e.g., MS-NTP001, MS-MC001). Used for cross-system referencing and contract administration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of work completed toward achieving this milestone, expressed as a value between 0.00 and 100.00. Updated during progress reporting cycles. Used for EVM (Earned Value Management) percent-complete calculations and schedule performance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eotDaysApproved rdf:type rdf:Property ;
    rdfs:label 'Eot Days Approved' ;
    rdfs:comment 'Total number of calendar days of approved Extension of Time (EOT) granted for this milestone under the contract. Reflects cumulative approved EOT claims that have adjusted the baseline date. Zero if no EOT has been granted.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotReference rdf:type rdf:Property ;
    rdfs:label 'Eot Reference' ;
    rdfs:comment 'Reference number of the approved EOT (Extension of Time) claim or contract amendment that adjusted the baseline date for this milestone. Used for contract administration audit trail and dispute resolution.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current best estimate of the date on which the milestone will be achieved, updated during schedule reviews and progress reporting cycles. Reflects schedule recovery plans, approved EOT (Extension of Time) claims, and current site conditions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Required' ;
    rdfs:comment 'Indicates whether HSE (Health, Safety and Environment) regulatory clearance or permit is a prerequisite for achieving this milestone (e.g., commissioning milestones requiring OSHA or EPA sign-off). True = HSE clearance must be obtained before milestone can be marked complete.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractual rdf:type rdf:Property ;
    rdfs:label 'Is Contractual' ;
    rdfs:comment 'Indicates whether this milestone is a contractually obligated key date as defined in the project contract (FIDIC, GMP, or bespoke agreement). True = contractual obligation with potential LD (Liquidated Damages) or payment consequences; False = internal PMO or programme milestone.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this milestone lies on the Critical Path Method (CPM) critical path of the project schedule. True = any delay to this milestone directly delays the project completion date; False = milestone has float and is not on the critical path.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Ld Trigger' ;
    rdfs:comment 'Indicates whether missing this milestone triggers Liquidated Damages (LD) as specified in the contract. True = LD clause applies upon delay; False = no LD exposure for this milestone. Critical for contract risk management and financial exposure reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Payment Trigger' ;
    rdfs:comment 'Indicates whether achievement of this milestone triggers a contractual payment event or progress payment certificate under the contract payment schedule. True = milestone completion initiates a payment claim or invoice; False = no direct payment linkage.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ld Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the Liquidated Damages (LD) daily rate (e.g., USD, EUR, GBP, AED). Ensures correct financial exposure reporting in multi-currency international EPC projects.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldRatePerDay rdf:type rdf:Property ;
    rdfs:label 'Ld Rate Per Day' ;
    rdfs:comment 'The contractually agreed daily monetary rate of Liquidated Damages (LD) applicable if this milestone is not achieved by the baseline date. Expressed in the project contract currency. Populated only when is_ld_trigger = True. Sensitive commercial data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedRelated rdf:type rdf:Property ;
    rdfs:label 'Leed Related' ;
    rdfs:comment 'Indicates whether this milestone is associated with LEED (Leadership in Energy and Environmental Design) certification requirements or green building compliance deliverables. True = milestone contributes to LEED certification pathway.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the milestone tracking its progress toward completion. \'not_started\' = work not yet begun; \'in_progress\' = activities underway; \'completed\' = milestone achieved; \'overdue\' = past planned date without completion; \'waived\' = formally waived by contract amendment; \'deferred\' = postponed with approved EOT (Extension of Time).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone by its origin and obligation level. \'contractual\' = bound by contract terms (FIDIC/GMP); \'internal\' = PMO governance milestone; \'regulatory\' = required by OSHA/EPA/IBC; \'client\' = client-driven key date; \'financial\' = triggers payment or LD exposure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name of the milestone describing the key project event or deliverable (e.g., \'Notice to Proceed (NTP)\', \'Mechanical Completion\', \'Substantial Completion\', \'Final Handover\'). Used in schedule reports and contract documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAdvanceDays rdf:type rdf:Property ;
    rdfs:label 'Notification Advance Days' ;
    rdfs:comment 'Number of calendar days in advance of the milestone date that formal notification must be issued to the client or engineer, as required by the contract. Applicable when notification_required = True. Supports contract compliance monitoring.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether formal written notification to the client or engineer is contractually required prior to or upon achievement of this milestone. True = notification obligation exists per contract; False = no formal notification required.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Contractual payment amount due upon achievement of this milestone, expressed in the project contract currency. Applicable only when is_payment_trigger = True. Used for cash flow forecasting and contract financial management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Original baseline date on which the milestone was scheduled to be achieved, as established at project kick-off or NTP (Notice to Proceed). Serves as the schedule baseline reference for variance analysis and SPI (Schedule Performance Index) calculation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procoreMilestoneReference rdf:type rdf:Property ;
    rdfs:label 'Procore Milestone Reference' ;
    rdfs:comment 'The corresponding milestone or schedule item identifier in Procore Construction Management platform. Supports cross-system reconciliation between the scheduling system of record (Primavera P6) and the construction management platform (Procore).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Description' ;
    rdfs:comment 'Detailed narrative description of the milestone, including the scope of work, acceptance criteria, and deliverables required to formally achieve the milestone. Sourced from the contract schedule or project execution plan.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for project team notes, status commentary, risk flags, or contextual information related to the milestone. Used during progress review meetings and PMO reporting to capture qualitative schedule narrative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The contracting party primarily responsible for achieving this milestone. Distinguishes between the General Contractor (GC), client, subcontractor, engineer/designer, Joint Venture (JV) partner, or regulatory authority. Critical for contract administration and risk allocation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of calendar days by which the milestone is ahead of (negative) or behind (positive) the baseline date. Calculated as forecast_date minus baseline_date for open milestones, or actual_date minus baseline_date for completed milestones. Key input for SPI (Schedule Performance Index) reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Sign Off Document Ref' ;
    rdfs:comment 'Reference number of the formal sign-off document, completion certificate, or taking-over certificate issued upon milestone achievement (e.g., Aconex document number, Procore submittal reference). Provides audit trail for contract administration and handover documentation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total schedule float in calendar days available for this milestone before it impacts the project completion date, as calculated by the CPM (Critical Path Method) schedule engine in Oracle Primavera P6. Zero or negative float indicates critical or super-critical status.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Calendar date on which the baseline was formally approved by the designated approving authority. Marks the effective start of the approved baseline for EVM measurement and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Governance tier at which this baseline was approved, reflecting the authorization hierarchy. Higher-value or re-baseline revisions typically require elevated approval levels per PMO governance policy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineNumber rdf:type rdf:Property ;
    rdfs:label 'Baseline Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the baseline record, used in PMO reporting, EVM analysis, and audit documentation. Format: BL-{ProjectCode}-{SequenceNumber}.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Status' ;
    rdfs:comment 'Current lifecycle state of the baseline record within the PMO approval workflow. Draft baselines are under preparation; pending_approval awaits sign-off; approved is the active authorized baseline; superseded indicates a newer revision has replaced it; cancelled denotes a withdrawn baseline.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Classification of the baseline record indicating the nature of the snapshot: original (initial approved baseline), revised (minor scope/cost adjustment), re_baseline (full project re-baselining), co_incorporation (Change Order incorporated), re_forecast (updated forecast adopted as new baseline), management_reserve_release (management reserve funds released into budget).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAfterRevision rdf:type rdf:Property ;
    rdfs:label 'Budget After Revision' ;
    rdfs:comment 'Total approved budget amount immediately following this baseline revision. Together with budget_before_revision, provides the complete budget delta audit trail for PMO governance and financial audit requirements.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Budget At Completion' ;
    rdfs:comment 'Total approved budget for the project or WBS element as captured in this baseline snapshot, representing the Budget at Completion (BAC) in the EVM framework. This is the total planned cost against which CPI (Cost Performance Index) and cost variance are measured.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetBeforeRevision rdf:type rdf:Property ;
    rdfs:label 'Budget Before Revision' ;
    rdfs:comment 'Total approved budget amount immediately prior to this baseline revision. Enables audit trail tracking of budget evolution and quantification of the budget delta introduced by each revision.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coValueIncorporated rdf:type rdf:Property ;
    rdfs:label 'Co Value Incorporated' ;
    rdfs:comment 'Total monetary value of Change Orders (COs) incorporated into this baseline revision. Quantifies the cumulative scope change impact on the approved budget for audit trail and contract administration purposes.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Approved contingency reserve budget included within this baseline, allocated to cover identified project risks and uncertainties. Distinct from management reserve which is held outside the project baseline.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Approved total duration of the project or WBS element in calendar days as captured in this baseline snapshot. Derived from baseline start and finish dates; stored explicitly for EVM schedule variance analysis and reporting.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this baseline was superseded by a subsequent revision or closed. Null if this is the currently active approved baseline. Supports audit trail and historical EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this approved baseline becomes the active reference for EVM variance analysis and project performance measurement. Typically aligns with approval_date or the NTP (Notice to Proceed) date for original baselines.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eotDaysGranted rdf:type rdf:Property ;
    rdfs:label 'Eot Days Granted' ;
    rdfs:comment 'Number of calendar days of Extension of Time (EOT) granted and incorporated into this baseline revision. Tracks the cumulative schedule relief authorized through contract administration, impacting the baseline finish date.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishDate rdf:type rdf:Property ;
    rdfs:label 'Finish Date' ;
    rdfs:comment 'Approved planned finish date for the project or WBS element as captured in this baseline snapshot. Used as the schedule reference for SPI (Schedule Performance Index) calculation and milestone tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClientApproved rdf:type rdf:Property ;
    rdfs:label 'Is Client Approved' ;
    rdfs:comment 'Boolean flag indicating whether the client or owner has formally approved this baseline revision. Relevant for contract-driven baselines under FIDIC, GMP (Guaranteed Maximum Price), or EPC delivery models where client sign-off is contractually required.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Current Baseline' ;
    rdfs:comment 'Boolean flag indicating whether this record represents the currently active approved baseline for the project or WBS element. Only one baseline per project/WBS should have this flag set to True at any point in time.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Management Reserve Amount' ;
    rdfs:comment 'Management reserve budget held outside the project baseline for unknown unknowns, as authorized by senior management. Tracked separately from contingency reserve per EVM methodology. Populated when baseline_type is management_reserve_release.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional PMO or project controls notes, assumptions, constraints, or caveats associated with this baseline record. Supplements the formal revision justification narrative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaveraBaselineReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Baseline Reference' ;
    rdfs:comment 'Source system identifier for this baseline record as assigned by Oracle Primavera P6. Enables traceability and reconciliation between the lakehouse Silver Layer and the operational scheduling system.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Calendar date on which the baseline revision was formally prepared and submitted for approval. Represents the point-in-time snapshot date for scope, schedule, and cost parameters.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionJustification rdf:type rdf:Property ;
    rdfs:label 'Revision Justification' ;
    rdfs:comment 'Narrative explanation of the business reason for this baseline revision, including the drivers of scope, schedule, or cost changes. Required for PMO governance approval and financial audit documentation.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential integer indicating the revision iteration of the baseline for a given project or WBS element. Revision 0 denotes the original approved baseline; subsequent revisions increment by 1.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProjectVersion rdf:type rdf:Property ;
    rdfs:label 'Sap Project Version' ;
    rdfs:comment 'SAP S/4HANA Project Systems version identifier corresponding to this baseline snapshot. Used for reconciliation between the ERP project budget version and the Primavera schedule baseline.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDataDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Data Date' ;
    rdfs:comment 'The data date (status date) of the Oracle Primavera P6 schedule from which this baseline snapshot was extracted. Defines the point-in-time reference for all schedule parameters captured in this record.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Approved planned start date for the project or WBS element as captured in this baseline snapshot. Used as the schedule reference for SPI (Schedule Performance Index) calculation and CPM (Critical Path Method) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Variance At Completion' ;
    rdfs:comment 'Variance at Completion (VAC) — the difference between the Budget at Completion (BAC) and the Estimate at Completion (EAC) at the time this baseline was established. Provides a forward-looking cost performance indicator for PMO reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmPeriodRecordId rdf:type rdf:Property ;
    rdfs:label 'Evm Period Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each EVM period record. Primary key for the evm_period_record data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvmPeriodRecord .

ind:costAccountId rdf:type rdf:Property ;
    rdfs:label 'Cost Account Id' ;
    rdfs:comment 'Foreign key linking to project.cost_account. Business justification: EVM is computed at the control account (cost account) level per ANSI/EIA-748 EVMS standards. Linking evm_period_record to cost_account enables control-account-level EVM reporting, which is the standar' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAccount .

ind:projectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.project_budget. Business justification: EVM-to-budget reconciliation: monthly EVM reporting requires BCWS/BCWP/ACWP to be reconciled against the approved project budget. Finance controllers and PMO require this link for cost performance ind' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:acwp rdf:type rdf:Property ;
    rdfs:label 'Acwp' ;
    rdfs:comment 'The cumulative actual cost incurred for work performed as of the data date. Also known as Actual Cost (AC). Sourced from SAP S/4HANA Project Systems actual postings and Viewpoint Vista job costing.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The name or user identifier of the PMO or project controls manager who approved this EVM period record for official reporting. Required for audit trail and progress billing certification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time at which this EVM period record was formally approved by the PMO approver. Establishes the official record for audit and compliance purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baselineCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Completion Date' ;
    rdfs:comment 'The approved baseline scheduled completion date for this WBS element or project as established at NTP (Notice to Proceed) or last approved baseline revision. Used to calculate schedule variance in time terms.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bcwp rdf:type rdf:Property ;
    rdfs:label 'Bcwp' ;
    rdfs:comment 'The cumulative budgeted cost of work actually performed (earned) as of the data date. Also known as Earned Value (EV). Computed from physical_percent_complete multiplied by budget_at_completion.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bcws rdf:type rdf:Property ;
    rdfs:label 'Bcws' ;
    rdfs:comment 'The cumulative budgeted cost of work that was planned to be completed as of the data date, per the approved baseline schedule. Also known as Planned Value (PV). Core EVM metric sourced from Oracle Primavera P6 baseline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'The difference between earned value and actual cost (BCWP minus ACWP). A positive value indicates under-budget performance; negative indicates cost overrun. Core EVM performance indicator for P&L reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiTrend rdf:type rdf:Property ;
    rdfs:label 'Cpi Trend' ;
    rdfs:comment 'Directional trend of the CPI compared to the previous reporting period. Indicates whether cost performance is improving, stable, or deteriorating. Used in PMO dashboard reporting and management escalation.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDate rdf:type rdf:Property ;
    rdfs:label 'Data Date' ;
    rdfs:comment 'The official status date as of which all progress, cost, and schedule data in this record are measured. Aligns with the Oracle Primavera P6 data date concept used for schedule updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eac rdf:type rdf:Property ;
    rdfs:label 'Eac' ;
    rdfs:comment 'The current forecast of total cost to complete the entire scope of work. Represents the best estimate of final project cost including all actuals to date plus estimated cost to complete. Core to P&L reporting and project financial health monitoring.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Earned Quantity' ;
    rdfs:comment 'The quantity of work physically completed and verified as of the data date, expressed in the unit of measure applicable to the WBS element (e.g., m3 of concrete poured, linear metres of pipe installed). Used in units-complete measurement method.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etc rdf:type rdf:Property ;
    rdfs:label 'Etc' ;
    rdfs:comment 'The current forecast of remaining cost required to complete all outstanding scope of work from the data date to project completion. Calculated as EAC minus ACWP.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'The methodology used to derive the Estimate at Completion (EAC) for this period record. Governs how the EAC and ETC values were calculated. [ENUM-REF-CANDIDATE: cpi_based|management_override|bottom_up_reestimate|cpi_spi_composite|eac_equals_bac — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedQuantity rdf:type rdf:Property ;
    rdfs:label 'Installed Quantity' ;
    rdfs:comment 'The total quantity of material or work physically installed in the permanent works as of the data date. May differ from earned quantity when rework or rejection adjustments apply.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementNarrative rdf:type rdf:Property ;
    rdfs:label 'Management Narrative' ;
    rdfs:comment 'Free-text management commentary explaining significant cost or schedule variances, corrective actions, risks, and forecast assumptions for this reporting period. Required for client monthly reporting and PMO governance packs.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date on which the physical progress measurement was conducted and verified in the field. May differ from the period end date when field surveys are conducted prior to period close.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementLevel rdf:type rdf:Property ;
    rdfs:label 'Measurement Level' ;
    rdfs:comment 'Indicates the hierarchical level at which EVM metrics are measured and reported in this record (e.g., project summary, WBS level, or control account). [ENUM-REF-CANDIDATE: project|wbs_level_1|wbs_level_2|wbs_level_3|activity|control_account — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodAcwp rdf:type rdf:Property ;
    rdfs:label 'Period Acwp' ;
    rdfs:comment 'The actual cost incurred for the current reporting period only. Enables period-on-period cost trend analysis and monthly P&L reporting. Sourced from SAP S/4HANA actual cost postings.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodBcwp rdf:type rdf:Property ;
    rdfs:label 'Period Bcwp' ;
    rdfs:comment 'The earned value (BCWP) for the current reporting period only. Enables period-on-period trend analysis and supports monthly progress payment certificate calculations.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodBcws rdf:type rdf:Property ;
    rdfs:label 'Period Bcws' ;
    rdfs:comment 'The planned value (BCWS) for the current reporting period only, as distinct from the cumulative BCWS. Enables period-on-period trend analysis and monthly progress billing reconciliation.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar end date of the reporting period covered by this EVM record. Defines the data cut-off for progress measurement and cost capture.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar start date of the reporting period covered by this EVM record. Used to bound the measurement window for progress and cost data.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Physical Percent Complete' ;
    rdfs:comment 'The verified physical progress percentage for this WBS element or project as of the data date. Measured by the verifying engineer and used to compute earned value (BCWP/EV). Range: 0.00 to 100.00.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Method' ;
    rdfs:comment 'The approved method used to calculate physical percent complete for this WBS element or activity. Governs how earned value (BCWP/EV) is computed. [ENUM-REF-CANDIDATE: weighted_steps|milestone|units_complete|level_of_effort|percent_complete|50_50_rule — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure applicable to earned_quantity and installed_quantity for this WBS element (e.g., m3, LM, EA, TON, m2). Sourced from the BOQ (Bill of Quantities).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this EVM period record within the PMO approval workflow. Controls which records are used for official reporting and progress billing.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVariance rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance' ;
    rdfs:comment 'The difference between earned value and planned value (BCWP minus BCWS). A positive value indicates ahead-of-schedule performance; negative indicates schedule slippage. Expressed in cost terms per ANSI/EIA-748.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spiTrend rdf:type rdf:Property ;
    rdfs:label 'Spi Trend' ;
    rdfs:comment 'Directional trend of the SPI compared to the previous reporting period. Indicates whether schedule performance is improving, stable, or deteriorating. Used in PMO dashboard reporting and client monthly reporting.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time at which this EVM period record was submitted for PMO review and approval. Supports workflow SLA tracking and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tcpi rdf:type rdf:Property ;
    rdfs:label 'Tcpi' ;
    rdfs:comment 'The cost performance efficiency required on remaining work to meet the budget at completion (BAC) or estimate at completion (EAC). Calculated as (BAC minus BCWP) divided by (BAC minus ACWP). Indicates future cost efficiency needed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vac rdf:type rdf:Property ;
    rdfs:label 'Vac' ;
    rdfs:comment 'The projected cost variance at project completion, calculated as BAC minus EAC. A positive value indicates projected under-budget completion; negative indicates projected cost overrun. Critical for P&L forecasting and EBITDA reporting.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifyingEngineer rdf:type rdf:Property ;
    rdfs:label 'Verifying Engineer' ;
    rdfs:comment 'The name or identifier of the engineer or quantity surveyor who independently verified and certified the physical percent complete measurement for this period record. Required for progress payment certification.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each periodic physical progress measurement record. Primary key for the progress_measurement data product in the project domain Silver layer.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Reference to the specific schedule activity within the WBS element being measured. Corresponds to the Primavera P6 activity object used in CPM (Critical Path Method) scheduling.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:billingPeriodReference rdf:type rdf:Property ;
    rdfs:label 'Billing Period Reference' ;
    rdfs:comment 'Reference identifier of the progress billing certificate or payment application period to which this measurement contributes (e.g., IPC-007, PA-2024-03). Links measurement data to the contract administration billing cycle.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedQuantity rdf:type rdf:Property ;
    rdfs:label 'Budgeted Quantity' ;
    rdfs:comment 'Total planned quantity of work for this WBS element or activity as defined in the approved BOQ (Bill of Quantities) or project baseline. Denominator for units-complete percent complete calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discipline rdf:type rdf:Property ;
    rdfs:label 'Discipline' ;
    rdfs:comment 'Engineering or construction discipline to which this WBS element or activity belongs (e.g., Civil, Structural, MEP (Mechanical Electrical Plumbing), Piping, Electrical, Instrumentation). Used for discipline-level progress roll-up reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Billing Eligible' ;
    rdfs:comment 'Indicates whether this approved progress measurement qualifies for inclusion in a progress billing certificate or payment application (True/False). Controlled by measurement_status and contract billing terms.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The technique used to quantify physical progress for this WBS element or activity. Weighted steps assigns weight to discrete sub-tasks; milestone marks binary completion; units complete counts installed quantities. [ENUM-REF-CANDIDATE: weighted_steps|milestone|units_complete|percent_complete|level_of_effort|physical_observation — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Number' ;
    rdfs:comment 'Externally-known business identifier for this measurement record, typically formatted as a sequential reference number (e.g., PM-2024-00123). Used in progress billing certificates and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Originating operational system from which this progress measurement was sourced. Supports data lineage traceability across HCSS HeavyJob production tracking, Procore field management, and Oracle Primavera P6.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current workflow lifecycle state of the progress measurement record, from initial field capture through engineer verification to client approval. Controls eligibility for progress billing.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies whether this measurement record captures physical progress only, financial progress (cost-based), or a combined physical and financial assessment. Determines which EVM fields are populated.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference' ;
    rdfs:comment 'Reference number of any associated NCR (Non-Conformance Report) that may affect the validity or acceptance of this progress measurement. A populated value indicates rework or quality hold may impact claimed progress.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodInstalledQuantity rdf:type rdf:Property ;
    rdfs:label 'Period Installed Quantity' ;
    rdfs:comment 'Physical quantity of work installed or completed during the current reporting period only (incremental, not cumulative). Feeds period progress billing and production rate analysis in HCSS HeavyJob.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Planned Percent Complete' ;
    rdfs:comment 'Baseline-scheduled percent complete for this WBS element or activity as of the measurement date, derived from the approved project baseline in Primavera P6. Used to compute SPI (Schedule Performance Index) variance.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Previous Percent Complete' ;
    rdfs:comment 'Physical percent complete recorded in the immediately preceding reporting period. Enables period-over-period progress increment calculation and trend analysis without requiring a self-join.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Code' ;
    rdfs:comment 'Reference to the defined reporting period (weekly, monthly, or milestone-based) within which this progress measurement falls. Used for period-over-period EVM (Earned Value Management) analysis.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period to which this progress measurement belongs. Defines the data cut-off for period progress billing and EVM (Earned Value Management) calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period to which this progress measurement belongs. Used to align measurements with EVM (Earned Value Management) data cut-off cycles.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Native record identifier from the originating operational system (HCSS HeavyJob cost code entry ID, Procore production entry ID, or Primavera P6 activity ID string). Enables traceability back to the system of record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the verifying engineer formally approved and signed off this progress measurement record. Distinct from measurement_date (when field observation occurred) and created_timestamp (when record was entered).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Full name of the engineer or site supervisor who physically verified and signed off this progress measurement. Retained for audit trail and contractual accountability under FIDIC and ISO 9001 requirements.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workArea rdf:type rdf:Property ;
    rdfs:label 'Work Area' ;
    rdfs:comment 'Physical site area, zone, or work front where the measured work is being performed (e.g., Zone A, Block 3, Pier 7). Aligns with site work front definitions used in HCSS HeavyJob and Procore daily logs.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderId rdf:type rdf:Property ;
    rdfs:label 'Change Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the change order record in the lakehouse Silver layer. Primary key for the project_change_order data product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeOrder .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Change order journal posting: approved change orders trigger budget amendment journal entries in the GL. Finance auditors and project controllers require traceability from change order approval to the' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:aconexMailRef rdf:type rdf:Property ;
    rdfs:label 'Aconex Mail Ref' ;
    rdfs:comment 'Aconex correspondence or transmittal reference number for the formal change order submission and approval correspondence. Provides document management traceability.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current workflow lifecycle state of the change order. Tracks progression from initial draft through client or owner approval. Only approved COs update the project baseline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineItemRef rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Ref' ;
    rdfs:comment 'Reference to the project budget line item or BOQ (Bill of Quantities) item that this change order modifies. Enables budget impact tracking at line-item level.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the nature of the change. Drives cost and schedule impact analysis and reporting. [ENUM-REF-CANDIDATE: scope_addition|scope_reduction|design_change|unforeseen_condition|client_directive|regulatory_change — promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coNumber rdf:type rdf:Property ;
    rdfs:label 'Co Number' ;
    rdfs:comment 'Externally-visible sequential identifier for the change order as issued on the project (e.g., CO-00042). Used in all formal correspondence, contract administration, and client reporting.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyDrawnAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Drawn Amount' ;
    rdfs:comment 'Amount drawn from the project contingency reserve to fund this change order, if applicable. Tracks contingency consumption at the CO level for project financial management.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Reference' ;
    rdfs:comment 'Specific contract clause or FIDIC sub-clause under which the change order is raised (e.g., \'FIDIC Clause 13.1 — Right to Vary\'). Establishes contractual entitlement.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Net monetary value of the change order representing the increase (positive) or decrease (negative) to the contract sum. Expressed in the contract currency. Core component of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost impact amount (e.g., USD, EUR, GBP). Required for multi-currency project environments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directCostAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Amount' ;
    rdfs:comment 'Direct labour, material, and equipment cost component of the change order before overhead and profit mark-up. Used for cost breakdown analysis and BOQ reconciliation.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Drawing revision number or BIM (Building Information Modeling) model version that forms the basis of the change order scope. Ensures design traceability.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which the approved change order takes contractual effect, potentially backdated to the date the change work commenced on site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eotGrantedDays rdf:type rdf:Property ;
    rdfs:label 'Eot Granted Days' ;
    rdfs:comment 'Number of calendar days of Extension of Time formally approved and granted by the engineer or owner in response to this change order. May differ from the claimed schedule impact.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether the change order is subject to a formal dispute or claim between the contractor and the client/owner. True if disputed; False if agreed.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Ld Applicable' ;
    rdfs:comment 'Indicates whether Liquidated Damages (LD) provisions are applicable to this change order in the event of delay. Relevant for schedule-impacting COs.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originator rdf:type rdf:Property ;
    rdfs:label 'Originator' ;
    rdfs:comment 'Party who initiated or originated the change order request. Determines contractual entitlement and responsibility for cost and schedule impacts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadAndProfitAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead And Profit Amount' ;
    rdfs:comment 'Overhead and profit mark-up applied to the direct cost to arrive at the total cost impact. Expressed in the contract currency.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority assigned to the change order indicating urgency of processing and approval. Critical COs may be on the critical path and require expedited approval.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreCoReference rdf:type rdf:Property ;
    rdfs:label 'Procore Co Reference' ;
    rdfs:comment 'Native change order identifier from the Procore Construction Management system. Used for data lineage, source system traceability, and reconciliation between the lakehouse and Procore.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectChangeOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Project Change Order Description' ;
    rdfs:comment 'Detailed narrative describing the scope of work added, reduced, or modified by this change order. Captures the full business justification and technical scope.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardised reason code categorising the root cause of the change (e.g., design error, owner-directed, differing site conditions, regulatory). Supports trend analysis and lessons learned. [ENUM-REF-CANDIDATE: design_error|owner_directed|differing_site_conditions|regulatory|scope_gap|value_engineering|force_majeure — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Co Document Number' ;
    rdfs:comment 'SAP S/4HANA project system document number generated when the approved change order is posted to the financial ledger. Enables reconciliation between project management and ERP.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Number of calendar days of Extension of Time (EOT) claimed or granted as a result of this change order. Positive value indicates delay; negative indicates acceleration. Zero if no schedule impact.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWorkSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Summary' ;
    rdfs:comment 'Concise summary of the physical scope of work added, removed, or modified by this change order. Complements the detailed description for executive reporting and CO registers.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Calendar date on which the change order was formally submitted to the client or owner for review and approval. Triggers contractual response timelines per FIDIC.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title of the change order summarising the nature of the change (e.g., \'Additional Piling Works — Zone B\'). Used in registers and dashboards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: GL reconciliation: cost accounts post actuals to specific GL accounts. cost_account.gl_account_code is a denormalized plain-text reference. A proper FK enables automated GL-to-cost-account reconciliat' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Human-readable description of the cost account scope, such as \'Structural Concrete — Foundation Works\' or \'MEP Subcontract — Electrical Rough-In\'. Used in cost reports, BOQ reconciliation, and EVM reporting.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the cost account. Active accounts accept cost postings; on_hold accounts are temporarily frozen pending review; closed accounts are complete and locked; cancelled accounts are voided; pending_approval accounts await PMO authorization before activation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual cost incurred and posted to this cost account to date, including paid invoices, posted labor timesheets, and equipment charges. Equivalent to Actual Cost of Work Performed (ACWP) in EVM. Sourced from SAP S/4HANA FI/CO and Viewpoint Vista job cost ledger.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Current approved budget for this cost account inclusive of all approved Change Orders (COs). Equivalent to Budget at Completion (BAC) in EVM terminology. Updated each time a CO is approved and posted to the cost account. The primary budget control figure used by project cost controllers.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineFinishDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Finish Date' ;
    rdfs:comment 'Planned completion date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for schedule performance tracking and Earned Value Management (EVM) analysis.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Start Date' ;
    rdfs:comment 'Planned start date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for Planned Value (PV) calculation and schedule variance analysis in EVM reporting.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetUnitRate rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Rate' ;
    rdfs:comment 'Budgeted cost per unit of measure for this cost account (Approved Budget divided by Budgeted Quantity). Used for unit rate benchmarking, bid analysis, and productivity monitoring. Expressed in the cost account currency per unit of measure.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Change Order Amount' ;
    rdfs:comment 'Cumulative value of all approved Change Orders (COs) posted to this cost account. Represents the delta between the original budget and the current approved budget. Tracked separately to support contract administration and CO impact analysis.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total value of contractual commitments against this cost account, including issued Purchase Orders (POs) and subcontract awards not yet invoiced. Represents financial obligations that will become actual costs. Critical for cash flow forecasting and cost-to-complete analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP Cost Center code associated with this cost account, representing the organizational unit responsible for the costs. Used for overhead allocation, departmental P&L reporting, and internal charge-back processes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToCompleteAmount rdf:type rdf:Property ;
    rdfs:label 'Cost To Complete Amount' ;
    rdfs:comment 'Estimated remaining cost required to complete the scope of work for this cost account. Calculated as Forecast Cost at Completion minus Actual Cost to Date. Used by cost controllers to project future cash requirements and update project financial forecasts.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Primary classification of the cost account by resource type: labor (direct workforce), material (permanent and consumable materials), equipment (plant and machinery), subcontract (third-party subcontractor scope), or overhead (indirect project costs). Drives cost segregation in EVM and P&L reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Variance between the approved budget and the forecast cost at completion for this cost account (Approved Budget minus Forecast Cost at Completion). A negative value indicates a cost overrun; positive indicates an underspend. Key metric for project cost control reporting and PMO governance.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Value Amount' ;
    rdfs:comment 'Budgeted cost of work performed (BCWP) for this cost account, representing the value of completed work expressed in budget terms. Core EVM metric used to calculate Cost Performance Index (CPI) and Schedule Performance Index (SPI) at the cost account level.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCostAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Forecast Cost At Completion' ;
    rdfs:comment 'Project cost controller\'s current best estimate of the total cost to complete this cost account, including actual costs to date plus estimated cost to complete (ETC). Equivalent to Estimate at Completion (EAC) in EVM. Updated periodically during project cost reviews.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Start Date' ;
    rdfs:comment 'Current forecast start date for the scope of work associated with this cost account, updated during project schedule reviews. Compared against the baseline start date to identify schedule slippage and its cost impact.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSubcontractScope rdf:type rdf:Property ;
    rdfs:label 'Is Subcontract Scope' ;
    rdfs:comment 'Indicates whether the scope of work for this cost account is executed by a subcontractor (True) or by the General Contractor\'s (GC) own forces (False). Drives subcontract management workflows, retention tracking, and payment certification processes.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The baseline budget amount for this cost account as established at project sanction or Notice to Proceed (NTP). Represents the original authorized cost plan before any Change Orders (COs). Immutable once the baseline is locked. Used as the denominator for variance analysis and EVM performance measurement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Value Amount' ;
    rdfs:comment 'Budgeted cost of work scheduled (BCWS) for this cost account as of the reporting data date. Represents the cumulative planned spend per the project baseline schedule. Used with Earned Value to compute Schedule Variance (SV) and SPI.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityActual rdf:type rdf:Property ;
    rdfs:label 'Quantity Actual' ;
    rdfs:comment 'Actual quantity of work completed and posted against this cost account to date. Compared against budgeted quantity to assess production efficiency and unit cost performance. Sourced from HCSS HeavyJob production entries and field daily logs.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBudgeted rdf:type rdf:Property ;
    rdfs:label 'Quantity Budgeted' ;
    rdfs:comment 'Original budgeted quantity of work for this cost account as derived from the Bill of Quantities (BOQ) or Material Take-Off (MTO). Expressed in the unit of measure applicable to the cost type (e.g., m3 for concrete, tonnes for steel, hours for labor). Enables unit rate analysis and productivity benchmarking.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The data date or cut-off date as of which the cost account financial figures (actual cost, earned value, planned value, forecast) are reported. Aligns with the project monthly cost report cycle and EVM data date in Oracle Primavera P6.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Percentage' ;
    rdfs:comment 'Contractual retention percentage applied to payments against this cost account, expressed as a percentage (e.g., 5.00 for 5%). Retention is withheld from subcontractor and supplier payments until practical completion or Defects Liability Period (DLP) expiry.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique surrogate identifier for the project deliverable record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the contract under which this deliverable is required. Supports contractual obligation tracking and FIDIC compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:itpId rdf:type rdf:Property ;
    rdfs:label 'Itp Id' ;
    rdfs:comment 'Foreign key linking to quality.itp. Business justification: Construction deliverables are governed by ITPs — each deliverable (concrete pour, structural erection, system test) must pass ITP hold/witness points before acceptance. deliverable.itp_reference is a ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Itp .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to design.package. Business justification: Contractual deliverables are grouped into submission packages for client review in construction. Design managers track which package contains each deliverable for completeness checking and client acce' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:responsibleContactId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Deliverable responsibility is assigned to a client contact to manage approvals and handover per Deliverable Acceptance process.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the deliverable was formally accepted by the client or approving authority. Used for handover milestone tracking and DLP commencement.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Client or reviewer acceptance status of the deliverable following formal review. Indicates whether the deliverable has been accepted, accepted with comments, or rejected and requires resubmission.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Issue Date' ;
    rdfs:comment 'Date on which the deliverable was actually issued or transmitted. Populated upon completion and used to calculate schedule variance and support DLP (Defects Liability Period) tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bimModelReference rdf:type rdf:Property ;
    rdfs:label 'Bim Model Reference' ;
    rdfs:comment 'Reference identifier linking this deliverable to the corresponding BIM model or element in Autodesk BIM 360. Supports clash detection, design coordination, and digital handover.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field capturing reviewer comments, rejection reasons, or clarification notes associated with the deliverable review cycle. Supports QA/QC tracking and resubmission guidance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the deliverable within the review and approval workflow. Tracks progression from initiation through approval or rejection in the document control system. [ENUM-REF-CANDIDATE: not_started|in_progress|under_review|approved|rejected|superseded|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Classification of the deliverable by its output category. Distinguishes engineering drawings, specifications, reports, calculations, procedures, commissioning packages, handover documents, and Inspection and Test Plans (ITPs). [ENUM-REF-CANDIDATE: engineering_drawing|specification|report|calculation|procedure|commissioning_package|handover_document|inspection_test_plan|method_statement|data_sheet — promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Formal document control number assigned by the document management system (e.g., Aconex or Procore). Used as the primary reference in transmittals, correspondence, and the document register.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotApplicable rdf:type rdf:Property ;
    rdfs:label 'Eot Applicable' ;
    rdfs:comment 'Indicates whether an Extension of Time (EOT) claim has been applied to the planned issue date of this deliverable. Supports contract administration and schedule delay analysis.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Issue Date' ;
    rdfs:comment 'Current forecast date for issuing the deliverable, updated during project progress reviews. Reflects schedule changes and is compared against the planned issue date to identify delays.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDlpApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Dlp Applicable' ;
    rdfs:comment 'Indicates whether this deliverable is subject to the Defects Liability Period (DLP) obligations under the contract. Enables DLP tracking and defect notification management.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHandoverRequired rdf:type rdf:Property ;
    rdfs:label 'Is Handover Required' ;
    rdfs:comment 'Indicates whether this deliverable must be included in the project handover package to the client. Supports commissioning and handover completeness tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nativeFileFormat rdf:type rdf:Property ;
    rdfs:label 'Native File Format' ;
    rdfs:comment 'File format of the deliverable document (e.g., PDF, DWG, DXF, REVIT, IFC, XLSX). Supports document management, BIM coordination, and digital handover requirements. [ENUM-REF-CANDIDATE: PDF|DWG|DXF|REVIT|IFC|XLSX|DOCX|XML|CSV — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Issue Date' ;
    rdfs:comment 'Baseline planned date on which the deliverable is scheduled to be issued to the client or for construction use. Established at project baseline and used for schedule performance tracking (SPI).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the deliverable indicating its criticality to the project schedule and construction activities. Critical deliverables are on the Critical Path Method (CPM) schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Contractually or procedurally defined date by which the reviewer must return comments or approval. Supports contract administration and review cycle management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewReturnDate rdf:type rdf:Property ;
    rdfs:label 'Review Return Date' ;
    rdfs:comment 'Actual date on which the reviewer returned comments or approval decision. Compared against review due date to track reviewer compliance and contract obligations.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionStatusCode rdf:type rdf:Property ;
    rdfs:label 'Revision Status Code' ;
    rdfs:comment 'Industry-standard document issue purpose code indicating the intent of the current revision: IFR (Issued for Review), IFC (Issued for Construction), IFI (Issued for Information), IFB (Issued for Bid), AFC (Approved for Construction), AFD (Approved for Design), ASB (As-Built). Critical for construction document control. [ENUM-REF-CANDIDATE: IFR|IFC|IFI|IFB|AFC|AFD|ASB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'URL or path to the deliverable file stored in the document management system (e.g., Aconex, Autodesk BIM 360, or SharePoint). Provides direct access to the source document.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Sequential count of the number of times this deliverable has been submitted for review. Tracks resubmission cycles and supports quality performance analysis.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightFactor rdf:type rdf:Property ;
    rdfs:label 'Weight Factor' ;
    rdfs:comment 'Relative weighting of this deliverable within the project progress measurement system. Used to calculate weighted progress and Earned Value (EV) contributions at the project or WBS level.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk register entry in the project risk register. Primary key for the risk_register data product.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Project risks with HSE implications must be traceable to specific hazards in the site hazard register for integrated risk management and regulatory compliance. risk_register has hse_risk_flag but no F' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:rfiId rdf:type rdf:Property ;
    rdfs:label 'Rfi Id' ;
    rdfs:comment 'Foreign key linking to design.rfi. Business justification: RFIs revealing design conflicts or ambiguities are primary risk triggers in construction. Risk managers formally log RFIs as risk evidence in the risk register. RFI-to-risk traceability is required fo' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfi .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: Project risks flagged as HSE risks (hse_risk_flag=true) must be formally linked to a safety risk_assessment for integrated risk reporting and regulatory compliance. Risk managers need this link to tra' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:affectedDiscipline rdf:type rdf:Property ;
    rdfs:label 'Affected Discipline' ;
    rdfs:comment 'Construction or engineering discipline most affected by this risk (e.g., Civil, Structural, MEP, Geotechnical, Electrical, Procurement). Supports discipline-level risk reporting and resource allocation for mitigation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Calendar date on which the risk entry was formally closed, either because the risk window has passed, the risk was fully mitigated, or the risk was realized and the contingency plan executed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Cost Amount' ;
    rdfs:comment 'Monetary contingency reserve allocated to this risk entry, expressed in the project currency. Feeds into the project contingency budget managed through SAP S/4HANA Project Systems and PMO cost control.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Description of the fallback actions to be executed if the risk event is realized despite mitigation efforts. Defines trigger conditions, response steps, and responsible parties for contingency activation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactRating rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential cost impact if the risk event is realized, using the standard five-point PMO scale. Used in risk matrix scoring and contingency reserve determination.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this risk has been escalated to senior management or the PMO for executive attention due to its high risk score, proximity, or strategic significance to the project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Flag' ;
    rdfs:comment 'Indicates whether this risk has a Health, Safety, and Environment (HSE) dimension requiring notification to the HSE team and potential entry into the Intelex HSE management system for regulatory compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Calendar date on which the risk or opportunity was first identified and entered into the project risk register. BUSINESS_EVENT_TIMESTAMP (date precision) for this entity. Used for risk ageing analysis and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether this risk is covered by an existing insurance policy (e.g., Contractors All Risk, Professional Indemnity, Public Liability). Supports risk transfer tracking and insurance portfolio management.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Calendar date on which this risk entry was most recently reviewed and updated by the risk owner or PMO. Used to identify overdue reviews and stale risk entries.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationResponseType rdf:type rdf:Property ;
    rdfs:label 'Mitigation Response Type' ;
    rdfs:comment 'Standard risk response strategy type applied to this risk: avoid (eliminate the risk), transfer (shift to another party via contract/insurance), mitigate (reduce probability/impact), accept (acknowledge and monitor), exploit (maximise opportunity), or enhance (increase opportunity probability/impact).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed description of the planned or implemented actions to reduce the probability or impact of the risk event. Includes engineering controls, contractual protections, procurement strategies, and HSE measures.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Qualitative probability rating of the risk event occurring, using the standard five-point PMO scale. Complements the quantitative probability score for risk matrix visualisation and executive reporting.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.3500 = 35%). Used in risk scoring calculations and Monte Carlo simulation inputs for contingency management.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityImpactRating rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential quality impact if the risk event is realized. Supports QA/QC risk assessment and Non-Conformance Report (NCR) prevention planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Flag' ;
    rdfs:comment 'Indicates whether this risk involves a regulatory or permitting dimension (e.g., EPA environmental permits, OSHA compliance, IBC building code, LEED certification requirements). Triggers regulatory compliance review.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualProbabilityScore rdf:type rdf:Property ;
    rdfs:label 'Residual Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring after mitigation actions have been applied, expressed as a decimal between 0.0000 and 1.0000. Measures the effectiveness of the risk response strategy.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Composite risk score remaining after mitigation actions have been applied. Compared against the pre-mitigation risk score to demonstrate risk reduction effectiveness and support PMO governance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this risk entry by the risk owner and PMO. Ensures risks are regularly reassessed and not left stale in the register.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the risk into a standard PMO risk category: technical (design, engineering, construction method), commercial (cost, contract, financial), schedule (programme, critical path), hse (Health Safety and Environment), regulatory (permits, compliance), or force_majeure (natural events, geopolitical). Drives risk reporting by category.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Externally-known alphanumeric risk identifier used across project documentation, PMO registers, and Procore/Primavera P6 risk modules. Follows the project risk numbering convention (e.g., RSK-PRJ001-0042). BUSINESS_IDENTIFIER for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative describing the risk or opportunity event, its cause, and potential consequence. Captures the full context required for risk assessment and mitigation planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProximity rdf:type rdf:Property ;
    rdfs:label 'Risk Proximity' ;
    rdfs:comment 'Indicates the time horizon within which the risk event is expected to occur: immediate (within 30 days), near_term (30–90 days), medium_term (90–180 days), or long_term (beyond 180 days). Supports prioritisation of risk response actions.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk score calculated as the product of probability and impact ratings, typically on a 1–25 scale (5x5 risk matrix). Used to prioritise risks in the PMO risk register and determine escalation thresholds.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the risk register entry: open (active, being monitored), mitigated (response actions applied), closed (no longer applicable), realized (risk event has occurred), or transferred (risk transferred to another party via contract/insurance). LIFECYCLE_STATUS for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, human-readable title summarising the risk or opportunity. Used as the primary display label in PMO dashboards, risk reports, and executive summaries. IDENTITY_LABEL for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTrigger rdf:type rdf:Property ;
    rdfs:label 'Risk Trigger' ;
    rdfs:comment 'Description of the early warning indicators or conditions that signal the risk event is about to occur or has been triggered. Used to activate contingency plans and alert the risk owner.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Indicates whether the register entry represents a threat (negative impact) or an opportunity (positive impact) to the project. Supports balanced risk and opportunity management per PMO governance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactRating rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential schedule impact if the risk event is realized, using the standard five-point PMO scale. Informs Extension of Time (EOT) exposure analysis and Critical Path Method (CPM) schedule risk assessment.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native identifier of this risk record in the originating operational system (e.g., Procore risk ID, Primavera P6 risk code). Enables traceability from the silver layer back to the source system for reconciliation and audit.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Phase-level financial reporting: construction project phases are mapped to cost centers for phase P&L reporting and overhead allocation. Finance controllers require phase-to-cost-center mapping for ph' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:baselineDurationDays rdf:type rdf:Property ;
    rdfs:label 'Baseline Duration Days' ;
    rdfs:comment 'Approved baseline duration of the phase in calendar days, derived from the original project schedule. Used as the denominator for schedule performance measurement and variance reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contingencyBudget rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget' ;
    rdfs:comment 'Contingency reserve allocated to this phase to cover identified and unidentified risks. Managed separately from the base budget in SAP S/4HANA Project Systems and released upon formal risk event occurrence.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesChecklist rdf:type rdf:Property ;
    rdfs:label 'Deliverables Checklist' ;
    rdfs:comment 'Structured list or description of mandatory deliverables required for phase completion (e.g., IFC drawings, BOQ, ITP, commissioning dossier). Stored as a delimited string or JSON-serialized list. Supports phase-gate governance and QA/QC compliance.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Deliverables Completion Pct' ;
    rdfs:comment 'Percentage of mandatory phase deliverables that have been completed and accepted as of the latest update (0.00–100.00). Supports phase gate readiness assessment and PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed narrative description of the scope of work, objectives, and key activities encompassed within this project phase. Used in project documentation, client reporting, and PMO governance records.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evmWeightPct rdf:type rdf:Property ;
    rdfs:label 'Evm Weight Pct' ;
    rdfs:comment 'Weighting factor assigned to this phase for EVM (Earned Value Management) rollup to the project level, expressed as a percentage of total project value (0.00–100.00). All phase weights must sum to 100 per project. Drives CPI and SPI calculations.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatDays rdf:type rdf:Property ;
    rdfs:label 'Float Days' ;
    rdfs:comment 'Total float (slack) available for this phase in calendar days, as calculated by CPM (Critical Path Method) analysis in Oracle Primavera P6. Negative float indicates a schedule overrun. Used for schedule risk assessment and EOT (Extension of Time) claims.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Date' ;
    rdfs:comment 'The date on which the phase gate was formally approved by the authorized approver, permitting progression to the next project phase. Recorded in the PMO governance register and Aconex document management system.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Status' ;
    rdfs:comment 'Current approval status of the phase gate review. Controls authorization to proceed to the next phase. Managed through PMO governance workflows and documented in Aconex or Procore approval workflows.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateApproverName rdf:type rdf:Property ;
    rdfs:label 'Gate Approver Name' ;
    rdfs:comment 'Name or role title of the individual or authority who approved the phase gate (e.g., Project Director, Client Representative, PMO Head). Provides audit trail for governance accountability.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Gate Review Criteria' ;
    rdfs:comment 'Textual description of the mandatory completion criteria and deliverables that must be satisfied before the phase gate can be approved and the next phase authorized. Aligned with PMO governance and FIDIC contract requirements.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsePlanApproved rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Approved' ;
    rdfs:comment 'Indicates whether the HSE (Health Safety and Environment) plan for this phase has been formally approved prior to commencement. A prerequisite for phase authorization under OSHA and ISO 45001 compliance requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Ld Exposure Amount' ;
    rdfs:comment 'Calculated financial exposure to Liquidated Damages (LD) for this phase based on contractual LD rate and current schedule delay. Used for financial risk reporting and contract administration. Expressed in the phase currency.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedApplicable rdf:type rdf:Property ;
    rdfs:label 'Leed Applicable' ;
    rdfs:comment 'Indicates whether LEED (Leadership in Energy and Environmental Design) sustainability requirements apply to this phase. When true, phase deliverables and activities must comply with USGBC LEED certification criteria.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractual or PMO-defined milestones associated with this phase. Provides a summary indicator of phase complexity and governance checkpoint density for PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current lifecycle state of the construction project phase. Drives PMO governance workflows, EVM reporting eligibility, and phase-gate approval triggers. Sourced from Oracle Primavera P6 activity status.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseType rdf:type rdf:Property ;
    rdfs:label 'Phase Type' ;
    rdfs:comment 'Standardized classification of the phase within the EPC/DB/DBB/PPP project lifecycle. Drives phase-gate governance rules, EVM rollup logic, and reporting hierarchies. [ENUM-REF-CANDIDATE: feasibility|pre_construction|feed|detailed_engineering|procurement|construction|pre_commissioning|commissioning|handover|dlp — promote to reference product]' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPlanApproved rdf:type rdf:Property ;
    rdfs:label 'Quality Plan Approved' ;
    rdfs:comment 'Indicates whether the Quality Management Plan (including ITP - Inspection and Test Plan) for this phase has been formally approved. Required under ISO 9001 and contract QA/QC requirements before phase work commences.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Assessed risk rating for this phase based on schedule, cost, and technical risk factors. Drives PMO escalation thresholds, contingency reserve allocation, and executive reporting. Aligned with the project risk register.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'The SAP S/4HANA Project Systems WBS element code corresponding to this phase. Enables cost and budget data reconciliation between the lakehouse and SAP PS for financial reporting and EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Integer ordering of the phase within the project lifecycle. Determines the execution sequence for scheduling, phase-gate progression, and earned value rollup. Lower numbers execute first.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique surrogate identifier for the rolling project cost and schedule forecast record in the Databricks Silver Layer. Primary key for the forecast data product.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCostToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date' ;
    rdfs:comment 'Total actual cost incurred on the project or WBS element from inception through the reporting period data date. Represents the Actual Cost of Work Performed (ACWP) in EVM terminology. Sourced from SAP S/4HANA cost postings.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bacCost rdf:type rdf:Property ;
    rdfs:label 'Bac Cost' ;
    rdfs:comment 'The approved Budget at Completion (BAC) for the project or WBS element as of the reporting period, representing the total authorized budget. Used as the denominator for cost variance and variance at completion calculations.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The current forward-looking forecast date for project or WBS element completion as of the reporting period. Distinct from the baseline completion date. Used for schedule variance calculation, EOT claims, and client reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyRemaining rdf:type rdf:Property ;
    rdfs:label 'Contingency Remaining' ;
    rdfs:comment 'The remaining contingency budget available for the project or WBS element as of the reporting period, after accounting for approved contingency drawdowns. Tracked separately from the base EAC to support risk-adjusted forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costTrendIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Trend Indicator' ;
    rdfs:comment 'Management assessment of the directional trend in cost performance compared to the prior reporting period. Improving indicates the EAC has decreased; stable indicates no material change; deteriorating indicates the EAC has increased. Used for executive dashboard traffic-light reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePct rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Pct' ;
    rdfs:comment 'Cost variance expressed as a percentage of the Budget at Completion (BAC), calculated as (BAC - EAC) / BAC × 100. Enables normalized comparison of cost performance across projects of different sizes.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eacCost rdf:type rdf:Property ;
    rdfs:label 'Eac Cost' ;
    rdfs:comment 'The current forward-looking Estimate at Completion (EAC) representing the total forecasted final cost of the project or WBS element as of the reporting period. Core EVM metric used for P&L reporting and PMO governance. Sourced from SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eacMovement rdf:type rdf:Property ;
    rdfs:label 'Eac Movement' ;
    rdfs:comment 'The change in Estimate at Completion (EAC) between the current and prior reporting period (current EAC minus prior period EAC). Positive values indicate cost growth; negative values indicate cost reduction. Key metric for P&L bridge and PMO governance reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etcCost rdf:type rdf:Property ;
    rdfs:label 'Etc Cost' ;
    rdfs:comment 'The Estimate to Complete (ETC) representing the forecasted remaining cost required to finish the project or WBS element from the reporting period data date. Calculated as EAC minus actual cost to date. Key input for cash flow forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert project currency amounts to the reporting/functional currency as of the reporting period date. Required for multi-currency EPC projects and consolidated P&L reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalCost rdf:type rdf:Property ;
    rdfs:label 'Final Cost' ;
    rdfs:comment 'The management-adjusted forecast of the total final cost at project completion, which may differ from the EAC where management applies judgment overlays, risk provisions, or contingency drawdowns not yet reflected in the bottom-up EAC. Used for P&L reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Externally-known business identifier for this forecast record, typically formatted as a project code plus reporting period reference (e.g., PRJ-2024-FCT-007). Used in PMO governance reports and P&L submissions.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle state of the forecast record within the PMO approval workflow. Draft indicates work-in-progress; submitted indicates pending PMO review; approved indicates accepted for P&L reporting; superseded indicates replaced by a newer forecast revision; cancelled indicates withdrawn.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by its reporting cadence or trigger. Monthly and quarterly forecasts are produced on a rolling basis; annual forecasts align with budget cycles; ad-hoc forecasts are produced for specific management or client events.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClientReported rdf:type rdf:Property ;
    rdfs:label 'Is Client Reported' ;
    rdfs:comment 'Indicates whether this forecast record has been formally reported to the client as part of contractual project reporting obligations. True indicates the forecast has been shared with the client; False indicates it is an internal management forecast only.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementReserveRemaining rdf:type rdf:Property ;
    rdfs:label 'Management Reserve Remaining' ;
    rdfs:comment 'The remaining management reserve held at the project level as of the reporting period. Management reserve is distinct from contingency and is controlled by senior management for unknown-unknown risks. Tracked for PMO governance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeCommentary rdf:type rdf:Property ;
    rdfs:label 'Narrative Commentary' ;
    rdfs:comment 'Free-text management commentary explaining the key drivers of cost and schedule variances, significant changes from the prior period forecast, risk events, and corrective actions. Required for PMO governance reporting and client-facing project status reports.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodEac rdf:type rdf:Property ;
    rdfs:label 'Prior Period Eac' ;
    rdfs:comment 'The approved Estimate at Completion (EAC) from the immediately preceding reporting period. Stored on the forecast record to enable period-over-period movement analysis without requiring a self-join, supporting PMO trend reporting and P&L bridge analysis.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the functional or reporting currency to which project amounts are converted for consolidated P&L and PMO portfolio reporting. Distinct from the project transaction currency.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Provision Amount' ;
    rdfs:comment 'The quantified risk provision included in the forecast final cost to cover identified project risks that have not yet materialized. Distinct from contingency; represents probabilistic risk exposure recognized in the P&L forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleTrendIndicator rdf:type rdf:Property ;
    rdfs:label 'Schedule Trend Indicator' ;
    rdfs:comment 'Management assessment of the directional trend in schedule performance compared to the prior reporting period. Improving indicates the forecast completion date has advanced; stable indicates no material change; deteriorating indicates further delay. Used for executive dashboard reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSiteId rdf:type rdf:Property ;
    rdfs:label 'Project Site Id' ;
    rdfs:comment 'Primary key for site' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to material.warehouse. Business justification: Project sites have dedicated on-site warehouses or laydown areas. Site managers need to know which warehouse serves a project site for material delivery scheduling, storage planning, and site logistic' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Cumulative actual expenditure incurred at the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information (suite, building, etc.).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqM rdf:type rdf:Property ;
    rdfs:label 'Area Sq M' ;
    rdfs:comment 'Total land area of the site in square meters.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Approved budget for the site in the project currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the site resides.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Site elevation above sea level in meters.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'Environmental compliance zone applicable to the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundCondition rdf:type rdf:Property ;
    rdfs:label 'Ground Condition' ;
    rdfs:comment 'Observed condition of the ground (e.g., rocky, soft, contaminated).' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date when the site insurance coverage expires.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number of the insurance covering the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent health, safety, or regulatory inspection.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude of the site in decimal degrees.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude of the site in decimal degrees.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the site manager for official communications.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full legal name of the person responsible for site operations.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerPhone rdf:type rdf:Property ;
    rdfs:label 'Manager Phone' ;
    rdfs:comment 'Primary telephone number for the site manager.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFloors rdf:type rdf:Property ;
    rdfs:label 'Number Of Floors' ;
    rdfs:comment 'Count of building floors present on the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permits rdf:type rdf:Property ;
    rdfs:label 'Permits' ;
    rdfs:comment 'Comma-separated list of permits and licenses held for the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal/ZIP code for the site address.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerCapacityMw rdf:type rdf:Property ;
    rdfs:label 'Power Capacity Mw' ;
    rdfs:comment 'Maximum electrical power capacity available on site in megawatts.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the site based on risk and access controls.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteDescription rdf:type rdf:Property ;
    rdfs:label 'Site Description' ;
    rdfs:comment 'Free-form textual description of the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle state of the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Category of the site based on its primary function.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilType rdf:type rdf:Property ;
    rdfs:label 'Soil Type' ;
    rdfs:comment 'Classification of soil present at the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province of the site location.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityConnectionStatus rdf:type rdf:Property ;
    rdfs:label 'Utility Connection Status' ;
    rdfs:comment 'Current status of utility (electric, water, gas) connections.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSupplyType rdf:type rdf:Property ;
    rdfs:label 'Water Supply Type' ;
    rdfs:comment 'Primary source of water for the site.' ;
    rdfs:domain ind:ProjectSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent account record for clients that are subsidiaries or divisions within a larger corporate hierarchy. Enables account hierarchy traversal for consolidated reporting and group-level relationship management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryUltimateParentAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Account Id' ;
    rdfs:comment 'Reference to the top-level account in the corporate hierarchy (ultimate holding entity). Used for group-level exposure analysis, consolidated pipeline reporting, and enterprise relationship management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to client.segment. Business justification: An account belongs to a single segment classification; using a foreign key to segment normalizes the model and removes the redundant string column.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the client account by ownership and sector type. Drives contract template selection, compliance requirements, and reporting segmentation. [ENUM-REF-CANDIDATE: public_sector|private_sector|government_body|corporate_sponsor|jv_entity|ppp_authority — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Reported or estimated annual revenue of the client organisation in the account\'s billing currency. Used for client segmentation, credit assessment, and strategic account prioritisation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Address to which invoices and financial correspondence are directed for this client account. May differ from the registered address. Used in SAP S/4HANA accounts receivable and Viewpoint Vista job costing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Requirement Level' ;
    rdfs:comment 'Level of Building Information Modeling (BIM) mandated by the client for construction projects. Drives design collaboration tooling requirements (e.g., Autodesk BIM 360), data exchange standards, and project delivery methodology.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTier rdf:type rdf:Property ;
    rdfs:label 'Client Tier' ;
    rdfs:comment 'Strategic segmentation tier assigned to the client based on revenue potential, relationship depth, and strategic importance. Tier 1 represents the highest-value clients. Drives account management resource allocation and executive engagement levels.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding receivable balance approved for this client account. Used by the finance team to manage exposure and payment risk on construction contracts. Expressed in the account\'s billing currency.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the client organisation by a recognised credit rating agency (e.g., S&P, Moody\'s, Fitch) or internal credit assessment score. Used for financial risk evaluation, payment terms negotiation, and bonding/surety decisions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Source system identifier for the account as recorded in Salesforce CRM. Used for cross-system reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether outbound marketing and unsolicited commercial communications to this client account are restricted. Set to True when the client has opted out of communications or is subject to legal/regulatory restrictions. Supports GDPR compliance.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System identifier for the client organisation. Used for credit assessment, supplier/client qualification, and global entity resolution.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees in the client organisation. Used as a proxy for organisational scale, procurement capacity, and client segmentation in CRM analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotPolicy rdf:type rdf:Property ;
    rdfs:label 'Eot Policy' ;
    rdfs:comment 'Client\'s standard policy for granting Extension of Time (EOT) on construction contracts. Indicates whether the client follows standard FIDIC provisions, applies strict timelines, or allows flexible negotiation. Used in bid risk evaluation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Compliance Required' ;
    rdfs:comment 'Indicates whether this client mandates specific Health, Safety and Environment (HSE) compliance standards (e.g., ISO 45001, OSHA requirements, client-specific HSE plans) as a condition of contract. Drives HSE planning and prequalification requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Primary industry sector of the client organisation (e.g., Infrastructure, Energy, Real Estate, Transportation, Healthcare, Government). Used for market segmentation and opportunity pipeline analytics in Salesforce CRM.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJvEntity rdf:type rdf:Property ;
    rdfs:label 'Is Jv Entity' ;
    rdfs:comment 'Indicates whether this client account represents a Joint Venture (JV) entity formed specifically for a construction project or programme. JV entities require special contract administration, profit-sharing arrangements, and consolidated reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the account record in the source Salesforce CRM system. Used for change data capture, incremental ETL processing, and audit trail maintenance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastProjectAwardDate rdf:type rdf:Property ;
    rdfs:label 'Last Project Award Date' ;
    rdfs:comment 'Date of the most recent contract or project award from this client. Used to identify dormant accounts, measure relationship recency, and prioritise re-engagement activities in the CRM pipeline.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldClauseStandard rdf:type rdf:Property ;
    rdfs:label 'Ld Clause Standard' ;
    rdfs:comment 'Indicates whether this client typically enforces Liquidated Damages (LD) clauses in construction contracts, and whether the LD terms are standard or negotiable. Informs bid risk assessment and contract strategy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Required' ;
    rdfs:comment 'Indicates whether this client requires LEED (Leadership in Energy and Environmental Design) certification for construction projects. Drives design, procurement, and construction methodology decisions to meet green building standards.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the client/owner organisation as it appears on contracts, invoices, and regulatory filings. This is the authoritative identity label for the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ntpAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Ntp Authority Level' ;
    rdfs:comment 'Describes the client\'s internal authority level or approval threshold required to issue a Notice to Proceed (NTP) on construction contracts. Used in contract administration to understand client governance and approval workflows.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms agreed with the client for construction contracts (e.g., Net 30, Net 60, milestone-based, progress payment). Drives accounts receivable management and cash flow forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContractType rdf:type rdf:Property ;
    rdfs:label 'Preferred Contract Type' ;
    rdfs:comment 'Client\'s preferred contract delivery model for construction engagements. Options include Engineering Procurement and Construction (EPC), Guaranteed Maximum Price (GMP), Design-Bid-Build (DBB), Design-Build (DB), Public-Private Partnership (PPP), and Build-Operate-Transfer (BOT). Informs bid strategy and contract template selection. [ENUM-REF-CANDIDATE: EPC|GMP|DBB|DB|PPP|BOT|FIDIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'Date on which the client\'s prequalification approval expires and requires renewal. Used to trigger re-assessment workflows and ensure compliance before new contract awards.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Current prequalification status of the client as a commissioning entity. Indicates whether the client has been assessed and approved for contract award eligibility, is pending review, or has an expired/rejected qualification.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the client organisation. Used for RFI responses, RFP submissions, contract correspondence, and CRM communication tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary point of contact at the client organisation for commercial and contractual matters. Typically the client\'s project director, procurement manager, or authorised representative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct telephone number for the primary contact at the client organisation. Used for urgent project communications, bid clarifications, and relationship management activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the client organisation as recorded with the relevant business registry. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official company or entity registration number issued by the relevant national or state business registry authority. Used for legal entity verification and compliance due diligence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the business relationship with this client was formally established (e.g., first contract award, first NTP issued, or CRM account creation date). Used for relationship tenure analysis and loyalty segmentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN, VAT number, GST number) for the client entity. Required for invoicing, contract administration, and financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or brand name used by the client organisation in day-to-day business, which may differ from the registered legal name. Used in CRM displays and correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website address of the client organisation. Used for due diligence, background research, and CRM account enrichment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the individual stakeholder contact record in the Databricks Silver Layer. Primary key for the contact data product.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:mailingAddressId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Id' ;
    rdfs:comment 'Foreign key linking to client.address. Business justification: contact carries five inline mailing address fields (mailing_street, mailing_city, mailing_state, mailing_postal_code, mailing_country) that duplicate the address table\'s purpose. The address table is ' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s direct manager or superior within the client organisation. Enables hierarchical stakeholder mapping and organisational chart modelling for large client accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountManager rdf:type rdf:Property ;
    rdfs:label 'Account Manager' ;
    rdfs:comment 'Full name of the internal account manager or business development representative responsible for managing the relationship with this contact. Used for ownership assignment and pipeline accountability in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdate rdf:type rdf:Property ;
    rdfs:label 'Birthdate' ;
    rdfs:comment 'Date of birth of the contact. Stored for relationship personalisation purposes (e.g., milestone acknowledgements) and identity verification in regulated markets. Handled under strict GDPR data minimisation principles.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record within the CRM system. \'active\' indicates an engaged stakeholder; \'inactive\' indicates no recent engagement; \'archived\' indicates the contact has left the organisation; \'do_not_contact\' indicates a communication opt-out or legal restriction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s functional role in the client relationship (e.g., owner representative, technical representative, procurement officer, legal counsel, executive sponsor, financial approver). Drives stakeholder engagement strategy and communication routing. [ENUM-REF-CANDIDATE: owner|technical|procurement|legal|executive|financial|hse|commercial — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact as recorded in Salesforce CRM Contact object. Used for cross-system reconciliation and data lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Consent Date' ;
    rdfs:comment 'Date on which the contact\'s data processing consent was last recorded or updated. Required for GDPR compliance audit trails to demonstrate lawful basis for processing personal data.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Data Consent Status' ;
    rdfs:comment 'Current status of the contact\'s consent for personal data processing under applicable privacy regulations (GDPR, CCPA). Tracks whether consent has been granted, withdrawn, is pending confirmation, or is not required (e.g., legitimate interest basis).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Indicates the contact\'s level of decision-making authority within the client organisation for construction project approvals, contract awards, and change order authorisations. Supports bid strategy and stakeholder influence mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organisational department or business unit within the client organisation to which the contact belongs (e.g., Engineering, Procurement, Legal, Finance). Supports targeted stakeholder engagement and communication routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact used for official project correspondence, RFI responses, bid submissions, and CRM communication tracking. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of email marketing communications specifically. Distinct from do_not_contact which covers all channels. Enforces GDPR consent management and CAN-SPAM compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual stakeholder contact as recorded in Salesforce CRM. Used for personalised correspondence and formal communication in client relationship management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete display name of the contact (e.g., salutation + first + last name) as stored in Salesforce CRM. Used in formal correspondence, bid submissions, and contract administration documents.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influenceScore rdf:type rdf:Property ;
    rdfs:label 'Influence Score' ;
    rdfs:comment 'Numeric score (typically 1–10) representing the contact\'s level of influence over project award decisions, contract negotiations, and change order approvals. Used in bid strategy and stakeholder mapping for major infrastructure pursuits.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has final decision-making authority for contract awards, change orders (CO), or project approvals. Critical for bid management and opportunity pipeline qualification in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor' ;
    rdfs:comment 'Indicates whether this contact holds the role of executive sponsor for the client relationship. Executive sponsors are senior client representatives who champion the construction partnership at the strategic level.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary point of contact for the client account. Only one contact per account should be flagged as primary. Used to route official correspondence and contract notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organisation (e.g., Project Director, Procurement Manager, Chief Engineer). Used to identify the contact\'s functional role in client engagement and bid management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, site visit) with this contact in Salesforce CRM. Used to measure engagement recency and identify at-risk relationships in client retention analytics.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Date' ;
    rdfs:comment 'Date of the most recent in-person or virtual meeting held with this contact. Used by account managers to track face-to-face engagement frequency and support relationship health assessments.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual stakeholder contact. Combined with first_name to form the full display name used in client-facing communications and CRM reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact. Used by business development and account management teams for relationship intelligence, stakeholder research, and pre-bid engagement in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact. Used for urgent site communications, HSE notifications, and out-of-hours contact during critical project milestones.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact, including country and area code. Used for direct communication during project execution, bid clarifications, and contract administration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for project correspondence, meeting invitations, and bid-related notifications. Sourced from Salesforce CRM and used to personalise outreach in opportunity pipeline management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code representing the contact\'s preferred language for written and verbal communication (e.g., \'en\', \'fr\', \'ar\', \'zh\'). Supports multilingual project environments common in global EPC and infrastructure projects.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealth rdf:type rdf:Property ;
    rdfs:label 'Relationship Health' ;
    rdfs:comment 'Qualitative assessment of the current health of the business relationship with this contact, as evaluated by the account manager or business development team. Used in CRM pipeline forecasting and client retention strategies.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix for the contact (e.g., Mr., Ms., Dr.) used in official correspondence, contract documents, and client communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Origin channel through which this contact was acquired or first identified (e.g., CRM import, referral, industry conference, Request for Proposal (RFP) response, website enquiry, partner introduction). Supports lead source analytics in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each client address record in the Construction data platform. Serves as the primary key for the client_address entity.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active indicates the address is in current use; inactive means it is no longer used; pending_validation awaits address verification; superseded means it has been replaced by a newer address; undeliverable indicates mail or correspondence has been returned.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the functional purpose of the address. Registered office is the legal domicile; billing is used for invoice delivery; correspondence is the preferred mailing address; project_site_liaison is the on-site contact office for a specific project; head_office and branch_office denote organisational hierarchy locations. [ENUM-REF-CANDIDATE: registered_office|billing|correspondence|project_site_liaison|head_office|branch_office — promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionTo rdf:type rdf:Property ;
    rdfs:label 'Attention To' ;
    rdfs:comment 'Name of the specific individual or department to whom correspondence should be directed at this address (e.g., \'Attn: Contracts Manager\' or \'Attn: Finance Department\'). Used in formal contract correspondence and RFI (Request for Information) transmittals.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or complex at this address (e.g., \'Empire State Building\', \'One Canada Square\', \'Dubai World Trade Centre\'). Used for precise address identification in dense urban environments and for formal correspondence headers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the country_code. Stored for display and reporting purposes to avoid repeated lookups against the ISO country reference table. Denormalized natural-key value derivable from country_code; resolved warning.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryNaturalKeySource rdf:type rdf:Property ;
    rdfs:label 'Country Natural Key Source' ;
    rdfs:comment 'SSOT pointer for the denormalized country_code/country_name natural key, governing the denormalized natural key warning.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this address became or becomes effective for the client. Supports temporal address management, enabling historical address tracking for contract administration and legal notice purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this address ceases to be effective for the client. Null indicates the address is currently active with no planned end date. Used for temporal address history management and superseded address tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'General email address associated with this address location (e.g., a departmental or office inbox). Used for electronic correspondence, transmittal delivery via Aconex, and formal notice under contract. Distinct from individual contact email addresses.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number associated with this address location. Retained for clients and jurisdictions where fax remains a legally recognised method of formal notice delivery under FIDIC contract conditions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or level number within a building at this address (e.g., \'Level 12\', \'Ground Floor\', \'Basement 2\'). Used for precise delivery instructions and visitor access coordination for client site visits.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Indicates the structural format of the address to support correct rendering and printing. Western follows street-city-state-postal conventions; eastern follows country-specific formats (e.g., Japan, China); po_box is a post office box address; free_form is an unstructured address entry.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingAddress rdf:type rdf:Property ;
    rdfs:label 'Is Billing Address' ;
    rdfs:comment 'Indicates whether this address is designated as the billing address for invoice delivery and accounts receivable correspondence. Used by SAP S/4HANA AR (Accounts Receivable) module for invoice routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the primary address for the client account. Only one address per client should be flagged as primary at any given time. Used to determine the default address for correspondence and contract documentation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegisteredOffice rdf:type rdf:Property ;
    rdfs:label 'Is Registered Office' ;
    rdfs:comment 'Indicates whether this address is the legally registered office address of the client entity. Required for contract execution, legal notices under FIDIC conditions, and regulatory compliance filings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Legal and regulatory jurisdiction code applicable to this address, combining ISO 3166-1 country code and subdivision code (e.g., US-CA for California, AU-NSW for New South Wales). Used for tax jurisdiction mapping, OSHA/EPA regulatory compliance, and contract law determination.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and suite or unit number. Represents the first line of the postal address as used in official correspondence and contract documentation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, industrial estate, or campus identifier. Optional field used when the primary line is insufficient.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line used for additional locality or district information, particularly relevant for international clients in regions where addresses require more than two street lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number associated with this address location. Used for direct contact with the client office at this address for project coordination, site liaison, and contract administration purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxNumber rdf:type rdf:Property ;
    rdfs:label 'Po Box Number' ;
    rdfs:comment 'Post Office (PO) Box number for clients who receive correspondence via a PO Box rather than a street address. Common for government agencies, public-sector clients, and clients in regions where PO Box delivery is standard.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCorrespondenceLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Correspondence Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code indicating the preferred language for correspondence sent to this address (e.g., \'en\' for English, \'fr\' for French, \'ar\' for Arabic). Supports multilingual client communication in international construction markets.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native identifier of this address record in the originating operational system (e.g., Salesforce CRM Address ID, SAP S/4HANA partner address number). Used for data lineage, reconciliation, and cross-system deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, territory, or region within the country. Used for regulatory jurisdiction mapping, tax compliance, and regional reporting across multi-jurisdiction construction clients.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Suite Unit Number' ;
    rdfs:comment 'Suite, unit, or office number within a building at this address. Provides the final level of address precision for multi-tenant buildings where multiple client offices may occupy the same floor.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Specific tax jurisdiction code for the address as used in SAP S/4HANA tax determination. May differ from the general jurisdiction code in federal/state/local tax overlay scenarios. Used for sales tax, VAT, and withholding tax calculations on client invoices.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Asia/Dubai, Australia/Sydney). Used for scheduling client communications, meeting coordination, and project milestone notifications across global construction operations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against a postal authority or address verification service. Used to schedule re-validation cycles and assess data quality freshness.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the service or system used to validate the address (e.g., USPS, Google Maps API, Loqate, SmartyStreets). Provides traceability for data quality audits and vendor management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the address validation process against a postal authority or third-party address verification service. Validated means the address has been confirmed as deliverable; not_validated means validation has not been attempted; failed means the address could not be verified; partial means only some components were verified.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent segment in a segment hierarchy (e.g., a regional sub-segment referencing a global segment). Enables hierarchical segment structures for multi-level BD reporting and account planning roll-ups.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountCountTarget rdf:type rdf:Property ;
    rdfs:label 'Account Count Target' ;
    rdfs:comment 'Planned number of client accounts to be assigned to this segment as part of the annual BD account planning cycle. Used to measure segment coverage and BD capacity planning in Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bdOwner rdf:type rdf:Property ;
    rdfs:label 'Bd Owner' ;
    rdfs:comment 'Name or identifier of the Business Development (BD) lead or team responsible for managing accounts and opportunities within this segment. Used for accountability tracking in Salesforce CRM and BD performance reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimRequirement rdf:type rdf:Property ;
    rdfs:label 'Bim Requirement' ;
    rdfs:comment 'Level of Building Information Modeling (BIM) requirement typically mandated by clients in this segment. \'mandatory\' = BIM required on all projects; \'preferred\' = BIM expected but not contractually required; \'optional\' = BIM accepted if offered; \'not_required\' = no BIM expectation. Drives Autodesk BIM 360 capability positioning in bids.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Criteria Description' ;
    rdfs:comment 'Narrative description of the specific qualification criteria used to assign accounts to this segment, including revenue thresholds, project type filters, geographic scope, and strategic fit indicators. Supports BD team alignment and CRM configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Criteria Version' ;
    rdfs:comment 'Version identifier of the segmentation criteria framework used to define and classify this segment (e.g., \'v1.0\', \'v2.3\'). Enables tracking of changes to segmentation methodology over time and supports historical win-rate analysis by criteria version.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment as recorded in Salesforce CRM. Enables cross-system reconciliation between the Databricks Silver Layer and the CRM source of record for pipeline filtering and account assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this segment definition became active and applicable for BD targeting and CRM account assignment. Supports historical segmentation analysis and criteria version tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date on which this segment definition expires or is superseded by a new version. Null indicates the segment is currently open-ended and active. Supports segmentation versioning and historical win-rate analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:esgFocus rdf:type rdf:Property ;
    rdfs:label 'Esg Focus' ;
    rdfs:comment 'Indicates whether clients in this segment place significant emphasis on Environmental, Social, and Governance (ESG) criteria in their procurement and project evaluation processes. Informs BD messaging, capability statements, and sustainability reporting alignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic market region associated with this segment (e.g., \'Asia Pacific\', \'North America\', \'Middle East & Africa\'). Used for regional BD pipeline filtering and account planning. Complements country-level targeting.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseStandard rdf:type rdf:Property ;
    rdfs:label 'Hse Standard' ;
    rdfs:comment 'Primary Health, Safety, and Environment (HSE) standard required by clients in this segment. Drives HSE prequalification requirements and Intelex configuration for incident reporting and audit compliance. Values: iso_45001, osha, client_specific, none.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalSegment rdf:type rdf:Property ;
    rdfs:label 'Is Global Segment' ;
    rdfs:comment 'Indicates whether this segment is defined at a global level (applicable across all geographic regions) or is region-specific. Global segments are used for enterprise-wide BD strategy reporting; regional segments support local account planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnershipTypical rdf:type rdf:Property ;
    rdfs:label 'Jv Partnership Typical' ;
    rdfs:comment 'Indicates whether projects in this segment are typically pursued through Joint Venture (JV) arrangements rather than as a sole contractor. Informs BD partner strategy, JV structure planning, and bid resource allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this segment definition. Derived from last_reviewed_date and review_frequency but stored explicitly to support CRM workflow triggers and governance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Prequalification Required' ;
    rdfs:comment 'Indicates whether clients in this segment require formal contractor prequalification before issuing a Request for Proposal (RFP) or Request for Quotation (RFQ). Drives BD qualification workflow and Salesforce CRM opportunity stage configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the primary target country for this segment (e.g., \'USA\', \'GBR\', \'AUS\'). Used for regulatory alignment and geographic BD targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'Dominant procurement and contract delivery model used by clients in this segment. Values: EPC (Engineering, Procurement and Construction), DB (Design-Build), DBB (Design-Bid-Build), GMP (Guaranteed Maximum Price), PPP/BOT (Public-Private Partnership/Build-Operate-Transfer), NEC4, JCT, FIDIC. Drives contract strategy and BD approach. [ENUM-REF-CANDIDATE: epc|db|dbb|gmp|ppp_bot|nec4|jct|fidic — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Primary quality management standard required by clients in this segment for project delivery and QA/QC compliance. Drives Inspection and Test Plan (ITP) and Non-Conformance Report (NCR) requirements. Values: iso_9001, client_specific, none.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory or standards framework governing procurement and project delivery for clients in this segment (e.g., \'FIDIC Red Book\', \'NEC4 ECC\', \'JCT Design and Build\', \'FAR/DFARS\' for US federal). Informs contract administration approach and compliance requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max Usd' ;
    rdfs:comment 'Maximum annual revenue threshold (in USD) defining the upper bound of the target client revenue band for this segment. A null value indicates an open-ended upper bound (e.g., mega-clients). Used alongside revenue_band_min_usd for client qualification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min Usd' ;
    rdfs:comment 'Minimum annual revenue threshold (in USD) defining the lower bound of the target client revenue band for this segment. Used for client qualification and BD targeting criteria. Expressed in USD for cross-regional comparability.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Frequency at which this segment definition and its assigned accounts are reviewed and updated by the BD and PMO teams. Drives CRM workflow scheduling and segmentation governance cadence.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'High-level ownership and funding sector of the client segment. \'public\' covers government and state-owned entities; \'private\' covers privately-funded developers and corporations; \'ppp_bot\' covers Public-Private Partnership (PPP) and Build-Operate-Transfer (BOT) arrangements. Aligned with FIDIC and NEC4 procurement categories.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. \'active\' = currently used for BD targeting and CRM filtering; \'inactive\' = no longer targeted; \'under_review\' = pending re-classification; \'archived\' = retired segment retained for historical reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Tier' ;
    rdfs:comment 'BD prioritization tier assigned to this segment indicating the level of strategic investment and relationship management effort. \'key_account\' = highest-priority clients with dedicated BD resources; \'growth\' = high-potential targets; \'standard\' = routine pipeline; \'dormant\' = inactive or deprioritized. Drives CRM pipeline weighting and BD resource allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSector rdf:type rdf:Property ;
    rdfs:label 'Sub Sector' ;
    rdfs:comment 'Detailed market sub-sector classification within the parent sector. Drives BD resource allocation and win-rate analysis by market vertical. Values: infrastructure (highways, airports, bridges), energy (power plants, renewables), commercial (offices, retail), residential (housing developments), industrial (factories, warehouses).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPipelineValueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Pipeline Value Usd' ;
    rdfs:comment 'Annual BD pipeline value target (in USD) for this segment, set during strategic planning cycles. Used to measure pipeline coverage ratio and BD resource adequacy. Supports Salesforce CRM pipeline forecasting and PMO reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWinRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Win Rate Pct' ;
    rdfs:comment 'Strategically defined target bid win rate (as a percentage, 0.00–100.00) for this segment, set during annual BD planning. Used as a benchmark for measuring BD performance and CRM pipeline health against actual win rates by segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalContractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Contract Duration Months' ;
    rdfs:comment 'Average or typical project/contract duration in months for engagements within this segment. Used in resource planning, scheduling baseline development in Oracle Primavera P6, and BD pipeline timing analysis.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalProjectValueMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Project Value Max Usd' ;
    rdfs:comment 'Maximum typical contract or project value (in USD) expected from clients in this segment. A null value indicates no upper cap (e.g., mega-infrastructure programs). Used in BD resource sizing and pipeline forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalProjectValueMinUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Project Value Min Usd' ;
    rdfs:comment 'Minimum typical contract or project value (in USD) expected from clients in this segment. Used in bid/no-bid decision frameworks and BD pipeline prioritization. Reflects the lower bound of the Bill of Quantities (BOQ) range for this market.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualAwardDate rdf:type rdf:Property ;
    rdfs:label 'Actual Award Date' ;
    rdfs:comment 'Date on which the contract was formally awarded. Populated upon win outcome. Used for win/loss analysis and BD cycle time measurement.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Bid Cost Estimate' ;
    rdfs:comment 'Internal estimate of the cost to prepare and submit the bid (tendering cost), including estimating, engineering, and proposal resources. Used for bid cost tracking and ROI analysis on BD spend.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNoBidDecision rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision' ;
    rdfs:comment 'Formal decision outcome from the bid/no-bid review process indicating whether the company will pursue this opportunity. Pending_review indicates the decision gate has not yet been completed.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidNoBidDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision Date' ;
    rdfs:comment 'Date on which the formal bid/no-bid decision was made and recorded. Used for governance audit trails and BD cycle time analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Date' ;
    rdfs:comment 'Actual or planned date on which the bid/tender/proposal was or is to be submitted to the client. Critical scheduling milestone for BD and estimating teams.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bimRequired rdf:type rdf:Property ;
    rdfs:label 'Bim Required' ;
    rdfs:comment 'Indicates whether the client mandates Building Information Modeling (BIM) as a project delivery requirement. True = BIM is contractually required. Drives technology and resource planning for the bid.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boqAvailable rdf:type rdf:Property ;
    rdfs:label 'Boq Available' ;
    rdfs:comment 'Indicates whether a Bill of Quantities (BOQ) has been issued by the client as part of the tender package. True = BOQ provided; False = lump-sum or design-build without BOQ. Affects estimating approach and bid strategy.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientOpportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Client Opportunity Description' ;
    rdfs:comment 'Free-text narrative describing the scope, nature, and key characteristics of the construction opportunity. Provides context for BD team members reviewing the pipeline and supports AI/ML-based opportunity classification.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Names of known competing firms bidding on the same opportunity. Free-text or comma-separated list. Confidential competitive intelligence used for bid strategy and market positioning analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRequirements rdf:type rdf:Property ;
    rdfs:label 'Esg Requirements' ;
    rdfs:comment 'Description of any Environmental, Social, and Governance (ESG) requirements specified by the client for this opportunity (e.g., carbon targets, local content requirements, diversity commitments). Free-text field for BD qualification notes.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Estimated total contract value of the opportunity in the reporting currency. Used for pipeline forecasting, revenue planning, and bid/no-bid decision thresholds. Raw commercial estimate; not a committed figure.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Expected Award Date' ;
    rdfs:comment 'Anticipated date on which the contract is expected to be formally awarded to the company. Used for pipeline close-date forecasting and resource mobilization planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedNtpDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ntp Date' ;
    rdfs:comment 'Anticipated date on which the client will issue the Notice to Proceed (NTP), authorizing the start of construction work. Used for resource planning and revenue recognition scheduling.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isJvBid rdf:type rdf:Property ;
    rdfs:label 'Is Jv Bid' ;
    rdfs:comment 'Indicates whether this opportunity is being pursued as a Joint Venture (JV) arrangement. True = JV bid; False = sole-entity bid. Drives JV governance and risk review processes.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnerNames rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Names' ;
    rdfs:comment 'Names of Joint Venture (JV) partners with whom the company intends to bid on this opportunity. Relevant for JV-structured bids common in large infrastructure and EPC projects. Confidential commercial information.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Reason code or description explaining why the opportunity was lost or withdrawn (e.g., price, technical score, client relationship, competitor strength, scope mismatch). Populated when win_loss_outcome is \'lost\' or \'withdrawn\'. Used for BD lessons-learned and competitive intelligence. [ENUM-REF-CANDIDATE: price|technical_score|client_relationship|competitor_strength|scope_mismatch|capacity|no_bid_decision|other — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned business development action required to advance this opportunity (e.g., \'Submit EOI by 15-Mar\', \'Attend client briefing\', \'Complete bid/no-bid review\'). Operational field used by BD team for pipeline management.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next business development action must be completed. Used for BD pipeline hygiene, follow-up scheduling, and opportunity stagnation alerts.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier for the opportunity as assigned in Salesforce CRM. Used for cross-system reference and client-facing communications.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Status' ;
    rdfs:comment 'Lifecycle status of the opportunity record indicating whether it is actively pursued, won, lost, on hold, or cancelled. Distinct from pipeline_stage which tracks the BD workflow step.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the opportunity in the business development pipeline. Drives pipeline forecasting and BD reporting. [ENUM-REF-CANDIDATE: prospect|qualification|bid_preparation|submitted|negotiation|awarded|lost|no_bid — promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfWinPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Win Pct' ;
    rdfs:comment 'Estimated probability (0–100%) that the company will be awarded this contract. Used to calculate weighted pipeline value for revenue forecasting. Assigned by the BD owner and reviewed at stage gates.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Project Duration Months' ;
    rdfs:comment 'Estimated duration of the construction project in months from NTP to practical completion. Used for resource planning, revenue phasing, and schedule risk assessment.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Project Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the construction project will be executed (e.g., USA, ARE, GBR). Used for geographic pipeline analysis and regulatory compliance scoping.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationRegion rdf:type rdf:Property ;
    rdfs:label 'Project Location Region' ;
    rdfs:comment 'State, province, or region where the construction project will be executed. Used for regional pipeline reporting, resource planning, and jurisdictional compliance (e.g., OSHA state plans, local building codes).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpIssueDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Issue Date' ;
    rdfs:comment 'Date on which the client issued the Request for Proposal (RFP) or Invitation to Tender (ITT). Marks the formal start of the bid preparation phase.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Client-issued Request for Quotation (RFQ) or Request for Proposal (RFP) reference number. Used for cross-referencing with client procurement documents and Aconex correspondence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCrmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Source Crm Opportunity Code' ;
    rdfs:comment 'Original opportunity identifier from the Salesforce CRM system of record. Used for data lineage, cross-system reconciliation, and traceability back to the operational source.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Internal strategic priority classification assigned to this opportunity by BD leadership. Tier 1 = highest strategic importance (must-win); Tier 2 = important but not critical; Tier 3 = opportunistic. Drives resource allocation for bid preparation.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Estimated contract value multiplied by the probability of win percentage, representing the risk-adjusted contribution of this opportunity to the revenue forecast. Key metric for executive pipeline reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossOutcome rdf:type rdf:Property ;
    rdfs:label 'Win Loss Outcome' ;
    rdfs:comment 'Final outcome of the opportunity after the bid process concludes. Won = contract awarded to company; Lost = awarded to competitor; Withdrawn = company withdrew bid; No_award = client cancelled procurement. Drives win rate analytics and BD performance reporting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationId rdf:type rdf:Property ;
    rdfs:label 'Prequalification Id' ;
    rdfs:comment 'Unique surrogate identifier for each client prequalification record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prequalification .

ind:clientAccountId rdf:type rdf:Property ;
    rdfs:label 'Client Account Id' ;
    rdfs:comment 'Reference to the client/owner organization that issued this prequalification assessment. Links to the master client account record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or designation of the client-side authority (individual, committee, or department) that reviewed and approved or rejected the prequalification submission.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Condition Resolution Date' ;
    rdfs:comment 'The date by which all imposed conditions must be resolved or evidenced to the client to convert a conditional approval to full approval.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or requirements imposed by the client as part of a conditional prequalification approval. Null if unconditionally approved.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Contract Delivery Method' ;
    rdfs:comment 'The project delivery method for which this prequalification applies: Engineering Procurement and Construction (EPC), Design-Build (DB), Design-Bid-Build (DBB), Guaranteed Maximum Price (GMP), Build-Operate-Transfer (BOT), or Public-Private Partnership (PPP).' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference number or identifier for the prequalification submission document package as stored in the document management system (e.g., Aconex transmittal number or document register ID).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification Required' ;
    rdfs:comment 'Indicates whether the client requires ISO 14001 or equivalent environmental management certification as part of the prequalification criteria.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the prequalification ceases to be valid. After this date, the firm is no longer eligible to bid unless renewed. Critical for bid eligibility tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Required' ;
    rdfs:comment 'Indicates whether the client requires submission of audited financial statements as part of the prequalification documentation package.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic region, country, or territory for which this prequalification is valid. Prequalification may be limited to specific jurisdictions or project locations.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Certification Required' ;
    rdfs:comment 'Indicates whether the client requires valid HSE certifications (e.g., ISO 45001, OSHA compliance) as a mandatory condition of prequalification in this category.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Required' ;
    rdfs:comment 'Indicates whether the client requires proof of adequate insurance coverage (professional indemnity, public liability, workers compensation) as a prequalification condition.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxProjectValue rdf:type rdf:Property ;
    rdfs:label 'Max Project Value' ;
    rdfs:comment 'The maximum single-project contract value (in the specified currency) for which the firm is prequalified by this client. Bids exceeding this threshold require separate approval or re-prequalification.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPassingScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score' ;
    rdfs:comment 'The minimum score threshold set by the client that the construction firm must achieve to receive an approved prequalification status in this category.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prequalificationNumber rdf:type rdf:Property ;
    rdfs:label 'Prequalification Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the client organization to this prequalification submission. Used in all correspondence and bid eligibility checks.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Indicates whether the client mandates a valid ISO 9001 or equivalent quality management system certification as a prequalification requirement.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceProjectsRequired rdf:type rdf:Property ;
    rdfs:label 'Reference Projects Required' ;
    rdfs:comment 'Minimum number of comparable completed projects the client requires the firm to demonstrate as part of the prequalification submission.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the client for rejecting the prequalification submission. Populated only when prequalification_status is \'rejected\'. Used for gap analysis and resubmission planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Actions Required' ;
    rdfs:comment 'Free-text description of specific actions, documentation updates, or re-submissions required by the client to successfully renew this prequalification.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the firm must initiate the renewal process to maintain uninterrupted prequalification status. Typically set before the expiry date to allow processing time.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Period Months' ;
    rdfs:comment 'The duration in months of each prequalification validity period before renewal is required. Typically 12, 24, or 36 months depending on client policy.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this prequalification requires periodic renewal to remain valid, as opposed to a one-time permanent approval.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfpEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rfp Eligibility Flag' ;
    rdfs:comment 'Indicates whether the firm is currently eligible to receive and respond to RFPs from this client in the specified work category, based on active prequalification status.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rfq Eligibility Flag' ;
    rdfs:comment 'Indicates whether the firm is currently eligible to receive and respond to RFQs from this client in the specified work category, based on active prequalification status.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score assigned by the client during the prequalification evaluation, typically on a 0–100 scale. Used to rank and compare contractors. Confidential as it reflects competitive assessment.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the construction firm formally submitted its prequalification documentation package to the client organization.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTrir rdf:type rdf:Property ;
    rdfs:label 'Submitted Trir' ;
    rdfs:comment 'The firm\'s actual TRIR value submitted as part of the prequalification documentation, typically based on the most recent 12-month or 3-year rolling average.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trirThreshold rdf:type rdf:Property ;
    rdfs:label 'Trir Threshold' ;
    rdfs:comment 'The maximum Total Recordable Incident Rate (TRIR) the client permits for prequalification. If the firm\'s TRIR exceeds this value, prequalification may be denied or revoked.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCategory rdf:type rdf:Property ;
    rdfs:label 'Work Category' ;
    rdfs:comment 'The construction discipline or scope category for which prequalification has been assessed (e.g., civil, MEP, EPC, marine, tunneling, structural, roads, bridges). Determines which types of RFPs/RFQs the firm is eligible to bid on. [ENUM-REF-CANDIDATE: civil|mep|epc|marine|tunneling|structural|roads|bridges|power|rail — promote to reference product]' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Years Experience Required' ;
    rdfs:comment 'Minimum number of years of relevant construction experience in the specified work category that the client requires for prequalification.' ;
    rdfs:domain ind:Prequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfpIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Rfp Issuance Id' ;
    rdfs:comment 'Unique surrogate identifier for each RFP/RFQ/ITT issuance record in the system. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpIssuance .

ind:addendumCount rdf:type rdf:Property ;
    rdfs:label 'Addendum Count' ;
    rdfs:comment 'The total number of addenda (amendments) issued by the client against this RFP since original issuance. Each addendum modifies the original RFP terms, scope, or schedule. Used to track document version history.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anticipatedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Award Date' ;
    rdfs:comment 'The client\'s indicative target date for issuing the Notice to Proceed (NTP) or contract award, as stated in the RFP. Used for resource planning, bid team scheduling, and pipeline forecasting in Salesforce CRM.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Completion Date' ;
    rdfs:comment 'The client\'s required or indicative project completion date as stated in the RFP. Defines the overall programme duration and is a key input to CPM (Critical Path Method) scheduling and resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Start Date' ;
    rdfs:comment 'The client\'s indicative target date for project commencement (Notice to Proceed / NTP) as stated in the RFP. Used for resource mobilisation planning and schedule baseline development in Oracle Primavera P6.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Percentage' ;
    rdfs:comment 'The bid bond (tender guarantee) value expressed as a percentage of the estimated contract value, as required by the client in the RFP. Typically ranges from 1% to 5% of contract value. Null if bid bond is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondRequired rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required' ;
    rdfs:comment 'Indicates whether the client requires a bid bond (tender guarantee) to be submitted with the proposal (True) or not (False). Bid bonds protect the client against bidder withdrawal after award.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidValidityDays rdf:type rdf:Property ;
    rdfs:label 'Bid Validity Days' ;
    rdfs:comment 'The number of calendar days from the submission deadline during which the bidder\'s proposal must remain valid and binding, as specified in the RFP. Typically 60 to 180 days. Impacts financial exposure and resource commitment.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Level' ;
    rdfs:comment 'The BIM maturity level required by the client in the RFP: level_1 (CAD-based), level_2 (collaborative BIM with federated models), or level_3 (fully integrated open BIM). Null if BIM is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSector rdf:type rdf:Property ;
    rdfs:label 'Client Sector' ;
    rdfs:comment 'Classification of the client/owner by sector: public (government/public authority), private (private developer/corporation), ppp (Public-Private Partnership arrangement), or jv (Joint Venture client entity). Drives compliance, reporting, and bid strategy.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Commercial Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the commercial/price component of the bid evaluation, as specified in the RFP (e.g., 40.00 for 40%). Combined with technical_score_weight to total 100%. Null for quality-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'The pricing and risk-sharing mechanism for the contract as specified in the RFP: lump_sum (fixed price), unit_rate (BOQ-based), cost_plus (reimbursable), target_cost (incentivised), or framework (call-off arrangement). Directly influences bid strategy and cost estimation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Days' ;
    rdfs:comment 'The duration of the Defects Liability Period (DLP) in calendar days as specified in the RFP, commencing from the date of practical completion. Typically 365 or 730 days. Impacts warranty provisioning and post-completion resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'The overall evaluation methodology specified in the RFP for assessing and ranking bids: price_only (lowest price wins), price_quality (weighted price and technical), quality_only (technical merit), best_value (whole-life cost), or pass_fail (compliance-based). Drives bid strategy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the RFP/RFQ/ITT was formally issued and released to prospective bidders by the client. Represents the principal business event date for this solicitation record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The system timestamp when this RFP issuance record was first created in the data platform. Represents the audit creation time, distinct from the business issue_date. Used for data lineage and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latestAddendumDate rdf:type rdf:Property ;
    rdfs:label 'Latest Addendum Date' ;
    rdfs:comment 'The date of the most recent addendum issued by the client against this RFP. Null if no addenda have been issued. Used to ensure bidders are working from the latest version of the solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Level' ;
    rdfs:comment 'The minimum LEED certification level required by the client as stated in the RFP: certified, silver, gold, or platinum. Null if LEED certification is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesApplicable rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Applicable' ;
    rdfs:comment 'Indicates whether the RFP specifies that Liquidated Damages (LD) will apply for delays or non-performance (True) or not (False). LD clauses are a key risk factor in bid pricing and schedule planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localContentRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Local Content Requirement Pct' ;
    rdfs:comment 'Minimum percentage of local workforce, materials, or subcontractors required by the client as specified in the RFP. Common in public-sector and government-funded projects. Impacts procurement and subcontractor strategy.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Percentage' ;
    rdfs:comment 'The performance bond value expressed as a percentage of the contract value, as specified in the RFP. Typically ranges from 5% to 10% of contract value. Null if performance bond is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether the client requires a performance bond to be provided upon contract award (True) or not (False). Performance bonds guarantee the contractor will fulfil contractual obligations.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preBidMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Date' ;
    rdfs:comment 'Scheduled date and time of the mandatory or optional pre-bid conference/site visit where the client clarifies scope and answers bidder questions. Attendance may be a prerequisite for bid eligibility.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preBidMeetingMandatory rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Mandatory' ;
    rdfs:comment 'Indicates whether attendance at the pre-bid meeting is mandatory for bid eligibility (True) or optional (False). Mandatory attendance is a common client requirement for complex infrastructure projects.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the project scope, works, and deliverables as outlined in the RFP. Includes key scope elements such as civil works, MEP systems, infrastructure type, and geographic extent.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSector rdf:type rdf:Property ;
    rdfs:label 'Project Sector' ;
    rdfs:comment 'The industry sector classification of the project as described in the RFP. Used for market segmentation, capability matching, and portfolio analytics. [ENUM-REF-CANDIDATE: infrastructure|energy|commercial|residential|industrial|transport|water|healthcare|education|defence — promote to reference product]' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectTitle rdf:type rdf:Property ;
    rdfs:label 'Project Title' ;
    rdfs:comment 'The official name or title of the project as stated in the RFP document. Provides the primary human-readable description of the work being solicited (e.g., \'Highway 45 Expansion Phase 2\', \'Airport Terminal C Construction\').' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Rfp Document Reference' ;
    rdfs:comment 'The document control reference number or URL/path to the official RFP package in the document management system (Aconex or Autodesk BIM 360). Enables direct retrieval of the source solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Externally-known reference number assigned by the client to uniquely identify this solicitation document (RFP, RFQ, or ITT). Used in all correspondence and bid submissions. Sourced from Salesforce CRM Bid Management or Aconex Document Management.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the RFP issuance: draft (being prepared), issued (released to market), amended (addendum issued), closed (submission deadline passed), cancelled (withdrawn by client), or awarded (contract awarded). Drives workflow and reporting.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationType rdf:type rdf:Property ;
    rdfs:label 'Solicitation Type' ;
    rdfs:comment 'Classification of the solicitation document type: RFP (Request for Proposal), RFQ (Request for Quotation), ITT (Invitation to Tender), EOI (Expression of Interest), or RFI (Request for Information). Determines the formality and evaluation process applied.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The exact date and time by which all bid/proposal submissions must be received by the client. Late submissions are typically disqualified. Critical for bid planning and scheduling in Oracle Primavera P6.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Technical Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the technical/quality component of the bid evaluation, as specified in the RFP (e.g., 60.00 for 60%). Combined with commercial_score_weight to total 100%. Null for price-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAgreementClientFrameworkAgreementMasterServicesAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Client Framework Agreement Master Services Agreement Id' ;
    rdfs:comment 'Self-referencing identifier linking a call-off contract or lot-level agreement to its parent framework agreement. Supports hierarchical agreement structures where individual call-offs are children of a master framework.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterServicesAgreement .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to site.site. Business justification: MSAs in construction are frequently scoped to specific project sites or geographic locations. Linking MSA to site enables site-level contract coverage reporting, ensuring the correct framework agreeme' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the framework agreement, used in correspondence, call-off orders, and contract administration. Typically issued by the client or procurement authority (e.g., FA-2024-HWY-001).' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the long-term agreement structure. \'framework\' = competitive framework with multiple call-offs; \'master_service_agreement\' (MSA) = pre-agreed terms for repeat services; \'term_contract\' = fixed-duration works contract; \'blanket_order\' = open purchase order for repeat supply; \'call_off_contract\' = individual release under a parent framework.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingValue rdf:type rdf:Property ;
    rdfs:label 'Ceiling Value' ;
    rdfs:comment 'Maximum total monetary value of all call-off orders that may be placed under this framework agreement over its full term. Acts as the Guaranteed Maximum Price (GMP) envelope for the framework. Expressed in the agreement currency.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientFrameworkAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Client Framework Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the framework agreement. \'draft\' = being negotiated; \'active\' = in force and accepting call-offs; \'suspended\' = temporarily halted; \'expired\' = past expiry date with no renewal; \'terminated\' = ended early; \'under_renewal\' = renewal process initiated.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedValue rdf:type rdf:Property ;
    rdfs:label 'Committed Value' ;
    rdfs:comment 'Total value of all call-off orders formally issued against this framework agreement to date. Used to track utilisation against the ceiling value and support financial forecasting.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractual mechanism for resolving disputes arising under the framework. \'dab\' = Dispute Adjudication Board (FIDIC); \'arbitration\' = binding arbitration; \'adjudication\' = statutory adjudication; \'litigation\' = court proceedings; \'mediation\' = non-binding mediation.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total planned duration of the framework agreement in calendar months from effective date to expiry date. Used for scheduling, resource planning, and renewal forecasting.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Months' ;
    rdfs:comment 'Duration in calendar months of each individual extension option. Combined with extension_options to determine the maximum possible agreement term.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionOptions rdf:type rdf:Property ;
    rdfs:label 'Extension Options' ;
    rdfs:comment 'Number of contractual extension options available to the client to extend the framework agreement beyond the original expiry date (e.g., 2 options of 12 months each).' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkLot rdf:type rdf:Property ;
    rdfs:label 'Framework Lot' ;
    rdfs:comment 'Lot or package designation within a multi-lot framework agreement (e.g., \'Lot 1 – Civils\', \'Lot 2 – MEP\', \'Lot 3 – Highways\'). Applicable where the client has structured the framework into distinct work categories.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the framework agreement is interpreted and enforced (e.g., \'English Law\', \'New York State Law\', \'UAE Federal Law\'). Critical for dispute resolution and contract administration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseRequirements rdf:type rdf:Property ;
    rdfs:label 'Hse Requirements' ;
    rdfs:comment 'Summary of Health, Safety and Environment (HSE) obligations and standards mandated under the framework agreement, such as OSHA compliance, ISO 45001 certification, SWMS submission, and minimum PPE standards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveMechanism rdf:type rdf:Property ;
    rdfs:label 'Incentive Mechanism' ;
    rdfs:comment 'Description of any pain/gain share, bonus, or incentive fee mechanism embedded in the framework agreement to reward performance above KPI thresholds or penalise underperformance.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether specific insurance requirements (e.g., professional indemnity, public liability, contractor\'s all-risk) are mandated under the framework agreement terms.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Description' ;
    rdfs:comment 'Narrative description of the performance KPIs defined in the framework agreement against which the contractor\'s performance will be measured across call-off orders (e.g., on-time delivery rate, defect rate, TRIR, CPI thresholds).' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Max Calloff Value' ;
    rdfs:comment 'Maximum monetary value of a single call-off order permitted under this framework agreement without triggering a mini-competition or additional approval. Supports procurement governance.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Min Calloff Value' ;
    rdfs:comment 'Minimum monetary value of an individual call-off order that may be placed under this framework agreement. Ensures commercial viability of individual work packages.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementRoute rdf:type rdf:Property ;
    rdfs:label 'Procurement Route' ;
    rdfs:comment 'Mechanism by which individual call-off orders are awarded under the framework. \'direct_award\' = awarded without further competition; \'mini_competition\' = secondary competition among framework members; \'competitive_tender\' = full re-tender; \'negotiated\' = negotiated with incumbent.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiry by which either party must serve notice of intent to renew or extend the framework agreement. Triggers CRM pipeline renewal workflow.' ;
    rdfs:domain ind:MasterServicesAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which the framework agreement was formally executed (signed by all parties). May precede the effective date if there is a mobilisation period.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the framework agreement was terminated early, if applicable. Null if the agreement expired naturally or is still active.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for early termination of the framework agreement. \'client_default\' = client failed to meet obligations; \'contractor_default\' = contractor breach; \'mutual_agreement\' = both parties agreed; \'force_majeure\' = unforeseeable event; \'regulatory\' = regulatory or legal requirement; \'convenience\' = termination for convenience by client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleBaselineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Id' ;
    rdfs:comment 'Foreign key linking to schedule.schedule_baseline. Business justification: The contract agreement\'s milestone_schedule and notice_to_proceed_date must be reconciled against the schedule baseline in effect at contract award. This link enables contract-baseline alignment repor' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleBaseline .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Identifier of the primary contractor responsible for delivering the work.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the agreement.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Effective Date' ;
    rdfs:comment 'Date the amendment becomes effective.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential identifier for a contract amendment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Type of amendment (e.g., supplemental, variation, novation).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date the contract was formally awarded to the contractor.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boqReference rdf:type rdf:Property ;
    rdfs:label 'Boq Reference' ;
    rdfs:comment 'Reference to the Bill of Quantities associated with the contract.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory and statutory compliance obligations attached to the agreement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsLiabilityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Months' ;
    rdfs:comment 'Duration after completion during which the contractor is liable for defects.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeResolution rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution' ;
    rdfs:comment 'Method for resolving disputes (e.g., arbitration, litigation, mediation).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessmentRef rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Ref' ;
    rdfs:comment 'Reference to the approved environmental impact assessment linked to the contract.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionOfTimeDays rdf:type rdf:Property ;
    rdfs:label 'Extension Of Time Days' ;
    rdfs:comment 'Number of days granted as an extension of time (EOT) under the contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Three-letter ISO country code where the contract work is performed.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSafetyPlanRef rdf:type rdf:Property ;
    rdfs:label 'Health Safety Plan Ref' ;
    rdfs:comment 'Reference to the HSE plan governing safety on the contract site.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Required insurance coverage and limits for the contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Amount' ;
    rdfs:comment 'Monetary amount payable for each day of delay beyond the agreed completion date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneSchedule rdf:type rdf:Property ;
    rdfs:label 'Milestone Schedule' ;
    rdfs:comment 'Key project milestones linked to contract payments.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeToProceedDate rdf:type rdf:Property ;
    rdfs:label 'Notice To Proceed Date' ;
    rdfs:comment 'Date the client issued the Notice to Proceed (NTP) to start work.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Description of payment milestones, dates, and conditions.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Security amount posted by the contractor to guarantee performance.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Revised Completion Date' ;
    rdfs:comment 'New contract completion date after amendment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedContractValue rdf:type rdf:Property ;
    rdfs:label 'Revised Contract Value' ;
    rdfs:comment 'Contract value after applying the amendment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special or bespoke conditions that modify standard contract terms.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsReference rdf:type rdf:Property ;
    rdfs:label 'Wbs Reference' ;
    rdfs:comment 'Identifier linking the contract to the associated Work Breakdown Structure.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'System-generated unique identifier for each party associated with a contract.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Account number used for contract-related payments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Financial institution where the party\'s account is held.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Main email used for contractual communications.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the insurance policy covering the party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJvPartner rdf:type rdf:Property ;
    rdfs:label 'Is Jv Partner' ;
    rdfs:comment 'True when the party participates as a JV partner in the contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryParty rdf:type rdf:Property ;
    rdfs:label 'Is Primary Party' ;
    rdfs:comment 'True when the party is the main responsible entity for the contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter country code where the party is legally registered.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official registered name of the corporate entity.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'Monetary cap on the party\'s contractual liability.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationPercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Percentage' ;
    rdfs:comment 'Percentage of ownership or profit share for joint-venture partners.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Operational status of the party within the contract management system.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Category that defines the business role of the party in construction contracts.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system of record that originated the party data.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInContract rdf:type rdf:Property ;
    rdfs:label 'Role In Contract' ;
    rdfs:comment 'The functional role the party plays for the specific contract (e.g., owner, contractor).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority' ;
    rdfs:comment 'True when the party is authorized to execute the contract on behalf of its organization.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax ID for the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Id' ;
    rdfs:comment 'System-generated unique identifier for the payment schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentSchedule .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Date the payment was actually made.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advanceBalanceRemaining rdf:type rdf:Property ;
    rdfs:label 'Advance Balance Remaining' ;
    rdfs:comment 'Outstanding advance amount yet to be recovered.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Amount of the advance payment disbursed.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Flag' ;
    rdfs:comment 'Indicates whether this schedule includes an advance payment component.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advanceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recovery Amount' ;
    rdfs:comment 'Cumulative amount recovered from subsequent payments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Business Event Timestamp' ;
    rdfs:comment 'Timestamp representing the business event that generated the schedule, e.g., milestone approval.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Any discount applied to the gross amount before tax.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which the payment is contractually due.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total amount before taxes, discounts, or retentions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeReference rdf:type rdf:Property ;
    rdfs:label 'Guarantee Reference' ;
    rdfs:comment 'Reference to the advance payment guarantee document.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequence number of this payment within the overall schedule.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFinalPayment rdf:type rdf:Property ;
    rdfs:label 'Is Final Payment' ;
    rdfs:comment 'True if this schedule represents the final payment of the contract.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Overall lifecycle state of the payment schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Amount payable after tax, discount, and retention adjustments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmountAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Net Amount After Discount' ;
    rdfs:comment 'Net payable amount after discount and before tax.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Date' ;
    rdfs:comment 'Date the payment certificate was issued.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Number' ;
    rdfs:comment 'Reference number of the payment certificate issued for this schedule.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Means by which the payment will be transferred.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodReference rdf:type rdf:Property ;
