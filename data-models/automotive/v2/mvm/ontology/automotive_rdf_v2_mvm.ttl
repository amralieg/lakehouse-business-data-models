ind:inTransitInventoryId rdf:type rdf:Property ;
    rdfs:label 'In Transit Inventory Id' ;
    rdfs:comment 'Foreign key linking to logistics.in_transit_inventory. Business justification: When inbound parts are receipted in automotive, the corresponding in-transit inventory record must be closed/resolved. Direct FK from GR to in_transit_inventory supports the inbound logistics closure ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InTransitInventory .

ind:movementTypeId rdf:type rdf:Property ;
    rdfs:label 'Movement Type Id' ;
    rdfs:comment 'Foreign key linking to inventory.movement_type. Business justification: Goods receipts must reference a movement type that governs accounting determination, quality inspection triggers, and stock category (unrestricted, quality hold, blocked). Automotive receiving operati' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MovementType .

