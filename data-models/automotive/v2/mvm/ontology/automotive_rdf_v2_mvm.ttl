ind:compoundMovementId rdf:type rdf:Property ;
    rdfs:label 'Compound Movement Id' ;
    rdfs:comment 'Foreign key linking to logistics.compound_movement. Business justification: Lifecycle events of type \'compound_arrival\', \'compound_departure\', or \'yard_move\' directly correspond to a compound_movement record. Yard management and PDI workflow systems require this link to corre' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompoundMovement .

ind:dealershipId rdf:type rdf:Property ;
    rdfs:label 'Dealership Id' ;
    rdfs:comment 'Foreign key linking to dealer.dealership. Business justification: Customer-order-driven production orders are placed by specific dealers. OEM scheduling priority, dealer-specific build confirmations, and order-to-delivery tracking all require dealer identity directl' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Field service lifecycle events (warranty repair, recall remedy, roadside assistance) are triggered by or linked to specific defect records. Quality and warranty teams need to trace lifecycle events ba' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Customer journey analytics and service history reporting require knowing which customer party was involved in a lifecycle event (service visit, self-service portal action, recall acknowledgment). life' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:recallCampaignId rdf:type rdf:Property ;
    rdfs:label 'Recall Campaign Id' ;
    rdfs:comment 'Foreign key linking to compliance.recall_campaign. Business justification: Recall remedy completion is recorded as a vehicle lifecycle event. Service operations log when a specific VIN completed a recall remedy appointment. This link enables recall completion rate tracking p' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCampaign .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: Vehicle lifecycle events of type \'vehicle_shipped\' or \'in_transit\' must reference the specific shipment record for OEM logistics traceability reporting and customer delivery status tracking. A domain ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:vehicleHandoverId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Handover Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_handover. Business justification: Lifecycle events of type \'delivery\' or \'customer_handover\' directly correspond to a vehicle_handover record. This link enables end-to-end delivery traceability, OTD (on-time delivery) reporting, and c' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleHandover .

ind:vehicleOrderId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Order Id' ;
    rdfs:comment 'Foreign key linking to sales.vehicle_order. Business justification: Lifecycle events such as \'vehicle sold\' and \'vehicle delivered\' are directly triggered by vehicle_order completion. Linking lifecycle_event to vehicle_order enables end-to-end vehicle lifecycle tracea' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOrder .

