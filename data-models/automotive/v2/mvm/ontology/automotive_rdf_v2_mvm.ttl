    rdfs:comment 'Rack identifier where the bin is located.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'Current operational status of the location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Allowed temperature range for the location (e.g., "0-5").' ;
    rdfs:domain ind:StorageLocation ;
