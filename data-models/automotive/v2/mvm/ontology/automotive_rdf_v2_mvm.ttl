ind:rateSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rate Source System' ;
    rdfs:comment 'Source system where the rate originated.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Incremental version number for the rate record to track revisions.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportRateStatus rdf:type rdf:Property ;
    rdfs:label 'Transport Rate Status' ;
    rdfs:comment 'Current lifecycle status of the rate contract.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Classification of vehicle type applicable to the rate.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Cubic Meters' ;
    rdfs:comment 'Maximum volume that can be transported under this rate.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Tons' ;
    rdfs:comment 'Maximum weight that can be transported under this rate.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationVehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Destination Vehicle Compound Id' ;
