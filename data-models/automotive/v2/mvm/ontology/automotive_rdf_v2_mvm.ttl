ind:pdiVehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Pdi Vehicle Compound Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_compound. Business justification: PDI inspection lots are performed at specific vehicle compounds. Compound quality audits, PDI capability assessments, and compound performance KPIs require knowing which compound executed each inspect' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleCompound .

ind:stockBalanceId rdf:type rdf:Property ;
    rdfs:label 'Stock Balance Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_balance. Business justification: Automotive quality inspection directly manages stock in \'quality inspection\' status. stock_balance has quality_inspection_stock_qty and quality_status fields. Linking inspection_lot to the specific st' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockBalance .

ind:vehicleTransportOrderId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Transport Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_transport_order. Business justification: PDI (Pre-Delivery Inspection) lots in automotive are directly triggered by vehicle transport orders upon compound arrival. The transport order is the operational trigger document for PDI inspection lo' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleTransportOrder .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed.' ;
