ind:schedulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Id' ;
    rdfs:comment 'Foreign key linking to supply.scheduling_agreement. Business justification: In automotive JIT/JIS supply chains, purchase orders are frequently issued as call-off releases against a long-term scheduling agreement. Linking supply_purchase_order to scheduling_agreement establis' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulingAgreement .

