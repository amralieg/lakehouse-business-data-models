    rdfs:range xsd:date .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the record.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:odometerEndKm rdf:type rdf:Property ;
    rdfs:label 'Odometer End Km' ;
    rdfs:comment 'Vehicle odometer reading at the end of the shipment.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerStartKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Start Km' ;
    rdfs:comment 'Vehicle odometer reading at the start of the shipment.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentLegCount rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Count' ;
    rdfs:comment 'Count of individual transport legs in the shipment itinerary.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitStatus rdf:type rdf:Property ;
    rdfs:label 'Transit Status' ;
    rdfs:comment 'Current operational status of the shipment.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportCostAmount rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Amount' ;
    rdfs:comment 'Monetary cost incurred for transporting the vehicle.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the transport cost.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'System-generated unique identifier for the freight invoice record.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPartyId rdf:type rdf:Property ;
    rdfs:label 'Billing Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Freight invoices are billed to the end-customer; associating each invoice with the customer party supports financial reconciliation and compliance reporting.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:partsOrderId rdf:type rdf:Property ;
    rdfs:label 'Parts Order Id' ;
    rdfs:comment 'Foreign key linking to aftersales.aftersales_parts_order. Business justification: Parts freight cost reconciliation: freight invoices for parts deliveries to service centers must reference the originating parts order for AP cost allocation, payment reconciliation, and audit complia' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsOrder .

ind:transportRateId rdf:type rdf:Property ;
    rdfs:label 'Transport Rate Id' ;
    rdfs:comment 'Foreign key linking to logistics.transport_rate. Business justification: A freight invoice should reference the contracted transport rate against which it is being reconciled. freight_invoice.agreed_rate and variance_amount imply comparison to a contracted rate, but there ' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportRate .

ind:agreedRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Rate' ;
    rdfs:comment 'Contracted rate per unit (e.g., per kilometer or per container) agreed with the carrier.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Currency conversion rate applied if invoice currency differs from reporting currency.' ;
