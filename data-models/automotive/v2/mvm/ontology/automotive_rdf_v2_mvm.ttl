    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpapSubmission .

ind:receivingPlantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.plant. Business justification: PPAP approvals are plant-specific in automotive: a part approved for Plant A is NOT automatically approved for Plant B (AIAG PPAP 4th edition). The receiving plant must be recorded on each PPAP submis' ;
    rdfs:domain ind:PpapSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:regulatoryBodyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_body. Business justification: PPAP level 3/4/5 submissions in automotive are mandated by specific regulatory bodies (NHTSA, EU type-approval authorities). Linking PPAP submissions to the governing regulatory body enables complianc' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBody .

