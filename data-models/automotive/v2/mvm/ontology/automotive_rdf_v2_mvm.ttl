ind:effectivenessVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified Flag' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEffective rdf:type rdf:Property ;
