    rdfs:comment 'Identifier of the dealer receiving the vehicle.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Date the vehicle actually arrived at the destination (if arrived).' ;
