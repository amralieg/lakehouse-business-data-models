ind:hazardousMaterialAllowed rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Allowed' ;
    rdfs:comment 'True if hazardous parts may be stored in this location.' ;
    rdfs:domain ind:Inventory ;
