ind:zone rdf:type rdf:Property ;
    rdfs:label 'Zone' ;
    rdfs:comment 'Logical zone within the warehouse (e.g., receiving, bulk, cold).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentPartyId rdf:type rdf:Property ;
    rdfs:label 'Consignment Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Consignment stock management requires identifying which customer or supplier party owns consignment_stock_qty held at a location. Automotive consignment reconciliation reports and financial liability ' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:blockedStockQty rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Qty' ;
    rdfs:comment 'Quantity that is blocked due to quality or administrative reasons.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consignmentStockQty rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Qty' ;
    rdfs:comment 'Quantity owned by a supplier but stored at the plant.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inTransitStockQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Stock Qty' ;
    rdfs:comment 'Quantity that is currently being transferred between locations.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Date and time of the most recent goods movement affecting this stock record.' ;
    rdfs:domain ind:StockBalance ;
