    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'Human-readable description of the manufacturing operation performed at this step (e.g., \'Robotic MIG weld door hinge bracket\'). Specific to this routing-work center combination.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Standard Time Seconds' ;
    rdfs:comment 'Standard cycle time in seconds for this specific operation at this specific work center within this routing. Belongs to the operation step, not to the routing header or work center master.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Work Instruction Reference' ;
    rdfs:comment 'Reference to the digital work instruction document governing this specific operation step. Links to the MES work instruction system for operator guidance at this work center for this routing.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPartsRequirementId rdf:type rdf:Property ;
    rdfs:label 'Campaign Parts Requirement Id' ;
    rdfs:comment 'Primary key for the campaign_parts_requirement association' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partRoleInRemedy rdf:type rdf:Property ;
    rdfs:label 'Part Role In Remedy' ;
    rdfs:comment 'Classifies the functional role of this part within the campaign remedy procedure. A campaign may require a primary replacement part, consumables (e.g., fluids, gaskets), and hardware (e.g., bolts, clips) — each with a distinct role. Belongs to the relationship, not to the part or campaign alone.' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partUnitCostAtCampaign rdf:type rdf:Property ;
    rdfs:label 'Part Unit Cost At Campaign' ;
    rdfs:comment 'The OEM transfer or standard cost of this part at the time the campaign was issued. Captured at the campaign level because part prices change over time and the campaign cost estimate must be locked to the issuance date. Distinct from the current dealer_net_price or list_price on service_part.' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequired rdf:type rdf:Property ;
    rdfs:label 'Parts Required' ;
    rdfs:comment 'Comma-separated list of part numbers needed to perform the remedy. [Moved from service_campaign: This comma-separated string of part numbers is a denormalized anti-pattern that attempts to capture what the campaign_parts_requirement association table properly models. Once the association table is created with one row per campaign-part pairing, this field becomes redundant and should be removed from service_campaign. The structured association records replace this field entirely.]' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'The number of calendar days required to procure sufficient stock of this part to support the campaign\'s affected VIN population. This is campaign-specific because lead times vary based on campaign volume, supplier capacity, and urgency — it is not a static attribute of the part itself.' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequiredPerVehicle rdf:type rdf:Property ;
    rdfs:label 'Quantity Required Per Vehicle' ;
    rdfs:comment 'The number of units of this part required to complete the remedy on a single affected vehicle. Belongs to the campaign-part relationship, not to either entity alone — the same part may be required in different quantities across different campaigns.' ;
    rdfs:domain ind:CampaignPartsRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlPlanCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Characteristic Id' ;
    rdfs:comment 'Primary key for the control_plan_characteristic association' ;
    rdfs:domain ind:ControlPlanCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement System' ;
    rdfs:comment 'The measurement system or gauge type used to evaluate this characteristic within this control plan (e.g., CMM, go/no-go gauge, vision system). Varies by process stage.' ;
    rdfs:domain ind:ControlPlanCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStepSequence rdf:type rdf:Property ;
    rdfs:label 'Process Step Sequence' ;
    rdfs:comment 'Ordinal position of this characteristic within the control plan, representing the process step sequence number as defined in the APQP control plan document.' ;
    rdfs:domain ind:ControlPlanCharacteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .
