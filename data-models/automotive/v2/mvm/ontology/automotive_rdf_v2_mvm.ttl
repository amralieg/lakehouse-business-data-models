ind:mrpRequirementId rdf:type rdf:Property ;
    rdfs:label 'Mrp Requirement Id' ;
    rdfs:comment 'Foreign key linking to inventory.mrp_requirement. Business justification: In automotive JIT/JIS operations, MRP requirements are the demand signals that generate delivery schedule releases. Supply planners reconcile open MRP requirements against scheduled deliveries to iden' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrpRequirement .

