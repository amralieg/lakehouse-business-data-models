ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Foreign key linking to vehicle.model. Business justification: Build sequences are model-specific for mixed-model line management and JIS call-off. vehicle_model_code is a denormalized plain string. FK to vehicle.model enables model-level sequence analysis, mixed' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:bomHeaderId rdf:type rdf:Property ;
    rdfs:label 'Bom Header Id' ;
    rdfs:comment 'Foreign key linking to product.bom_header. Business justification: Vehicle models have a base-level engineering BOM header representing the model\'s standard component structure, used in product lifecycle management and engineering release processes. This model-level ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomHeader .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Foreign key linking to engineering.bom. Business justification: A model-level BOM defines the base vehicle structure before options and configurations. Engineering change impact analysis, standard cost rollup by model, and field service parts lookup require a dire' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:platformId rdf:type rdf:Property ;
    rdfs:label 'Platform Id' ;
    rdfs:comment 'Foreign key linking to vehicle.platform. Business justification: powertrain_variant currently stores `vehicle_platform` as a STRING column, which is a denormalized reference to the platform entity. In automotive engineering, powertrain variants are designed and val' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Platform .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to product.product_segment. Business justification: Vehicle models are classified into product segments for CAFE fleet compliance reporting, portfolio strategy, and competitive benchmarking. Automotive product planners require this link to aggregate mo' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:vehicleProgramId rdf:type rdf:Property ;
