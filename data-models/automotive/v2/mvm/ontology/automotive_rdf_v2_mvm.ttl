    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Base monetary amount agreed for the lane before surcharges.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier code for the transport rate contract.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
