    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment processing status of the invoice.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsLaneId rdf:type rdf:Property ;
    rdfs:label 'Logistics Lane Id' ;
    rdfs:comment 'Foreign key linking to logistics.lane. Business justification: Rates are also specific to a logistics lane; adding logistics_lane_id links rates to lanes and resolves lane\'s silo.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Additional fixed charges (e.g., lift-gate, detention) associated with the lane.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the rate complies with applicable transport regulations (e.g., IATF, EPA).' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Code of the destination dealer or distribution center.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percent' ;
    rdfs:comment 'Percentage surcharge applied to the base rate to cover fuel price volatility.' ;
