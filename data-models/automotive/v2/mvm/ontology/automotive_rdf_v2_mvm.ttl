    rdfs:range xsd:boolean .

ind:inventoryAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Inventory Accuracy Percent' ;
    rdfs:comment 'Measured accuracy of inventory records for this location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
