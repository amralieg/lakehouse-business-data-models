ind:testObserver rdf:type rdf:Property ;
    rdfs:label 'Test Observer' ;
    rdfs:comment 'Name of the independent observer or auditor present during testing.' ;
    rdfs:domain ind:NcapTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProgram rdf:type rdf:Property ;
    rdfs:label 'Test Program' ;
    rdfs:comment 'The NCAP program under which the vehicle was tested.' ;
    rdfs:domain ind:NcapTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'External reference number assigned by the testing authority for the test report.' ;
    rdfs:domain ind:NcapTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultStatus rdf:type rdf:Property ;
    rdfs:label 'Test Result Status' ;
    rdfs:comment 'Lifecycle status of the test result record.' ;
    rdfs:domain ind:NcapTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testVersion rdf:type rdf:Property ;
    rdfs:label 'Test Version' ;
    rdfs:comment 'Version identifier of the test protocol used.' ;
    rdfs:domain ind:NcapTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleVin rdf:type rdf:Property ;
    rdfs:label 'Vehicle Vin' ;
    rdfs:comment 'Globally unique vehicle identifier used to link the test result to a specific vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCharacteristicId rdf:type rdf:Property ;
    rdfs:label 'Parent Characteristic Id' ;
    rdfs:comment 'Self-referencing FK on characteristic (parent_characteristic_id)' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Characteristic .

ind:characteristicStatus rdf:type rdf:Property ;
    rdfs:label 'Characteristic Status' ;
    rdfs:comment 'Current lifecycle status of the characteristic.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Data type of the characteristic\'s measured value.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User identifier who last modified the characteristic record.' ;
    rdfs:domain ind:Characteristic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRootCauseAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Parent Root Cause Analysis Id' ;
    rdfs:comment 'Self-referencing FK on root_cause_analysis (related_root_cause_analysis_id)' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RootCauseAnalysis .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Date on which the corrective action was actually completed.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionOwner rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Owner' ;
    rdfs:comment 'Person or team accountable for executing the corrective action plan.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Planned corrective actions to eliminate or mitigate the root cause.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionPhase rdf:type rdf:Property ;
    rdfs:label 'Detection Phase' ;
    rdfs:comment 'Process phase in which the root cause was first detected.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactDescription rdf:type rdf:Property ;
    rdfs:label 'Impact Description' ;
    rdfs:comment 'Narrative of the business or safety impact caused by the root cause.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrencePhase rdf:type rdf:Property ;
    rdfs:label 'Occurrence Phase' ;
    rdfs:comment 'Process phase where the root cause actually occurred.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name of the person or team responsible for investigating and resolving the root cause.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Status' ;
    rdfs:comment 'Current lifecycle status of the root cause analysis.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisType rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Type' ;
    rdfs:comment 'Indicates whether the cause is systemic, occasional, or a one-off event.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Numeric rating (1-5) of the impact severity of the root cause on product quality.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Planned date by which the corrective action should be completed.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the verification activity.' ;
    rdfs:domain ind:RootCauseAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterId rdf:type rdf:Property ;
    rdfs:label 'Service Center Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_center. Business justification: Parts shipment delivery routing to service center: parts shipments are delivered to specific service centers (distinct from dealerships — one dealership may have multiple service centers). Required fo' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCenter .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_transfer_order. Business justification: Inter-plant parts replenishment: stock transfer orders trigger physical shipments for parts movements between plants. Linking shipment to STO enables supply chain planners to reconcile planned transfe' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransferOrder .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Real timestamp when the shipment was received at the destination.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Real timestamp when the shipment left the origin plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'Standard container identification number when applicable.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Document Number' ;
    rdfs:comment 'Reference number for customs clearance documents.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'Primary dangerous goods hazard class if applicable' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Un Number' ;
    rdfs:comment 'UN number for dangerous goods in this shipment' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Explanation for any delay beyond the planned arrival.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Geographic location (city) of the destination dealer or yard.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportImportFlag rdf:type rdf:Property ;
    rdfs:label 'Export Import Flag' ;
    rdfs:comment 'Indicates whether the shipment is an export, import, or domestic movement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Gross transportation cost before discounts or adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International commercial term governing responsibilities and costs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMileDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delivery Flag' ;
    rdfs:comment 'Whether this shipment includes a last-mile delivery leg' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the shipment load.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'Final freight cost after discounts and adjustments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Units' ;
    rdfs:comment 'Count of individual vehicles or kits included in the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location (city) of the origin plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPlantCode rdf:type rdf:Property ;
    rdfs:label 'Origin Plant Code' ;
    rdfs:comment 'Identifier of the manufacturing plant where the shipment originates.' ;
