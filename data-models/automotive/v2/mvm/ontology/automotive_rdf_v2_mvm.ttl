    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:originSupplierPlantId rdf:type rdf:Property ;
    rdfs:label 'Origin Supplier Plant Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier_plant. Business justification: Logistics lanes in automotive originate from supplier plants. Lane already has origin_plant_id (OEM plant) — role-prefix \'origin_supplier_plant_id\' distinguishes supplier plant origin. Enables freight' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPlant .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'Transit time in days' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Appointment Id' ;
    rdfs:comment 'Foreign key linking to sales.delivery_appointment. Business justification: Vehicle handover is the physical execution of a scheduled delivery appointment. Linking enables reconciliation of scheduled vs. actual delivery, PDI completion confirmation, and customer satisfaction ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryAppointment .

ind:receivingDealershipId rdf:type rdf:Property ;
    rdfs:label 'Receiving Dealership Id' ;
    rdfs:comment 'Foreign key linking to dealer.dealership. Business justification: OEM-to-dealer vehicle delivery process: when a vehicle is physically handed over to a dealership, the receiving entity is a dealership. receiving_party_id is generic (dealer.party); a direct dealers' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:receivingPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Id' ;
    rdfs:comment 'Unique identifier of the receiving party (dealer or customer).' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acceptanceSignatureStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Signature Status' ;
    rdfs:comment 'Status of the acceptance signature: signed, unsigned, or pending.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCondition rdf:type rdf:Property ;
