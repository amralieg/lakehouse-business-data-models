    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierScac rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac' ;
    rdfs:comment 'Standard carrier code used for tracking and billing.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocation rdf:type rdf:Property ;
    rdfs:label 'Current Location' ;
    rdfs:comment 'Last known location of the vehicle while in transit.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysInTransit rdf:type rdf:Property ;
    rdfs:label 'Days In Transit' ;
    rdfs:comment 'Number of calendar days the vehicle has been in transit.' ;
    rdfs:domain ind:InTransitInventory ;
    rdf:type owl:DatatypeProperty ;
