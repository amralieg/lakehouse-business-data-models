ind:aftersalesRepairOrderId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Repair Order Id' ;
    rdfs:comment 'Foreign key linking to aftersales.aftersales_repair_order. Business justification: Parts issued to a repair order generate goods issue movements in inventory. This FK enables direct traceability of parts consumption per repair order, supporting warranty cost accounting, parts usage ' ;
    rdfs:domain ind:Automotive ;
