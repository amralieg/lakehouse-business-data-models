ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Corrective actions (8D reports) are formally issued to carriers for transport damage in automotive. quality_corrective_action has supply_supplier_id for supplier CAPAs but no carrier_id for carrier CA' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

