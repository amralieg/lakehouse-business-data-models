  designed_jph decimal(10,2) [note: 'Designed jobs per hour']
  energy_consumption_kwh_per_unit decimal(12,4) [note: 'Energy consumption per unit']
  energy_source_type varchar [note: 'Energy source type']
  eop_date date [note: 'End of production date']
  floor_space_sqm decimal(12,2) [note: 'Floor space in sqm']
  jis_enabled boolean [note: 'JIS enabled flag']
  last_maintenance_date date [note: 'Last maintenance date']
  line_code varchar [note: 'Line code']
  line_length_meters decimal(10,2) [note: 'Line length in meters']
  line_name varchar [note: 'Line name']
  line_status varchar [note: 'Line status']
  line_type varchar [note: 'Line type']
  max_vehicle_weight_kg decimal(10,2) [note: 'Max vehicle weight']
  mes_line_code varchar [note: 'MES line code']
  mixed_model_capable boolean [note: 'Mixed model capable flag']
  model_year_capability varchar [note: 'Model year capability']
  next_maintenance_date date [note: 'Next maintenance date']
  number_of_stations varchar [note: 'Number of stations']
  powertrain_type_capability varchar [note: 'Powertrain type capability']
  quality_gate_count varchar [note: 'Quality gate count']
  robot_count varchar [note: 'Robot count']
  safety_certification_expiry_date date [note: 'Safety cert expiry date']
  safety_certification_status varchar [note: 'Safety certification status']
  sop_date date [note: 'Start of production date']
  takt_time_seconds decimal(10,3) [note: 'Takt time in seconds']
  updated_timestamp timestamp [note: 'Updated timestamp']
  weld_gun_count varchar [note: 'Weld gun count']
  work_instruction_digital_flag boolean [note: 'Whether digital work instructions are deployed on this line.']

  Note: 'Assembly/production line master data including capacity, automation level, and MES integration'
}

Table manufacturing.work_center {
  work_center_id varchar [pk, note: 'Primary key']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Work centers are physically located within a manufacturing plant. work_center currently stores plant_code as a STRING denormalized reference. Adding plant_id FK to manufacturing.plant normalizes this ']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Each work center has a designated point-of-use (POU) storage location for JIT/JIS parts staging — a standard SAP/MES configuration in automotive assembly. This link enables AGV routing, material stagi']
  agv_integration_enabled boolean [note: 'AGV integration enabled']
  andon_enabled boolean [note: 'Whether andon system is enabled at this work center.']
  automation_level varchar [note: 'Automation level']
  available_capacity_hours_per_day decimal(6,2) [note: 'Available capacity hours per day']
  capacity_category varchar [note: 'Capacity category']
  category varchar [note: 'Category']
  co2_emissions_per_cycle_kg decimal(8,4) [note: 'CO2 emissions per cycle']
  code varchar [note: 'Work center code']
  commissioning_date date [note: 'Commissioning date']
  created_timestamp timestamp [note: 'Created timestamp']
  currency_code varchar [note: 'Currency code']
  cycle_time_seconds decimal(10,3) [note: 'Cycle time seconds']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  decommissioning_date date [note: 'Decommissioning date']
  description varchar [note: 'Description']
  energy_consumption_kw decimal(10,2) [note: 'Energy consumption kW']
  floor_area_sqm decimal(8,2) [note: 'Floor area sqm']
  is_bottleneck boolean [note: 'Is bottleneck flag']
  is_jis_enabled boolean [note: 'JIS enabled flag']
  is_quality_gate boolean [note: 'Is quality gate flag']
  labor_rate_per_hour decimal(10,4) [note: 'Labor rate per hour']
  last_calibration_date date [note: 'Last calibration date']
  last_updated_timestamp timestamp [note: 'Last updated timestamp']
  location_description varchar [note: 'Location description']
  machine_rate_per_hour decimal(10,4) [note: 'Machine rate per hour']
  maintenance_strategy_code varchar [note: 'Maintenance strategy code']
  mean_time_between_failures_hours decimal(10,2) [note: 'MTBF hours']
  mean_time_to_repair_hours decimal(8,2) [note: 'MTTR hours']
  mes_station_count varchar [note: 'Number of MES-tracked stations within this work center.']
  mes_work_center_code varchar [note: 'MES work center code']
  name varchar [note: 'Work center name']
  next_calibration_due_date date [note: 'Next calibration due date']
  number_of_shifts varchar [note: 'Number of shifts']
  number_of_workers varchar [note: 'Number of workers']
  overhead_rate_percent decimal(10,4) [note: 'Overhead rate percent']
  plc_node_code varchar [note: 'PLC node code']
  poka_yoke_count varchar [note: 'Number of error-proofing devices at this work center.']
  process_category varchar [note: 'Process category']
  production_line_code varchar [note: 'Production line code']
  sap_work_center_code varchar [note: 'SAP work center code']
  scada_node_code varchar [note: 'SCADA node code']
  setup_time_minutes decimal(8,2) [note: 'Setup time minutes']
  shift_model_code varchar [note: 'Shift model code']
  standard_value_key varchar [note: 'Standard value key']
  takt_time_seconds decimal(10,3) [note: 'Takt time seconds']
  teardown_time_minutes decimal(8,2) [note: 'Teardown time minutes']
  work_center_status varchar [note: 'Status']
  work_center_type varchar [note: 'Type']

  Note: 'Work center master data representing individual manufacturing stations with capacity, cost rates, and equipment details'
}

Table manufacturing.production_order {
  production_order_id varchar [pk, note: 'Primary key']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: Production orders must reference the specific engineering BOM version used for costing and change control. Direct FK enables ECO impact on open orders and standard cost roll-up. bom_version is a denor']
  configuration_id varchar [note: 'FK to vehicle configuration']
  customer_party_id varchar [note: 'FK to customer party']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Customer-order-driven production orders are placed by specific dealers. OEM scheduling priority, dealer-specific build confirmations, and order-to-delivery tracking all require dealer identity directl']
  fleet_account_id varchar [note: 'Foreign key linking to customer.customer_fleet_account. Business justification: Fleet production orders must reference the fleet account for volume tracking, contract billing, and discount tier application. Automotive OEM fleet operations require linking each production order to ']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: Before releasing a production order, manufacturing must verify the target vehicle configuration holds valid homologation approval for its destination market. Production planners and market-launch team']
  plant_id varchar [note: 'FK to plant']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Production orders are issued for a specific powertrain variant to drive BOM selection, routing assignment, and standard cost rollup. powertrain_type is a denormalized string; FK to powertrain_variant ']
  production_bom_id varchar [note: 'FK to production BOM']
  production_line_id varchar [note: 'FK to production line']
  production_schedule_id varchar [note: 'Foreign key linking to manufacturing.production_schedule. Business justification: Production orders are created to fulfill a production schedule. The production_schedule defines planned quantities, dates, and capacity for a line/plant; production_orders are the execution artifacts ']
  routing_id varchar [note: 'FK to routing']
  sku_master_id varchar [note: 'FK to SKU master']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: Order-to-production traceability: when a customer vehicle_order is confirmed, a production_order is created to fulfill it. This link drives ATP/CTP delivery promising, order status reporting to dealer']
  vehicle_program_id varchar [note: 'FK to vehicle program']
  actual_cost decimal(18,2) [note: 'Actual cost']
  actual_finish_timestamp timestamp [note: 'Actual finish timestamp']
  actual_labor_hours decimal(10,2) [note: 'Actual labor hours']
  actual_machine_hours decimal(10,2) [note: 'Actual machine hours']
  actual_start_timestamp timestamp [note: 'Actual start timestamp']
  carbon_footprint_kg_co2 decimal(12,4) [note: 'Carbon footprint kg CO2']
  confirmed_quantity decimal(15,3) [note: 'Confirmed quantity']
  created_timestamp timestamp [note: 'Created timestamp']
  currency_code varchar [note: 'Currency code']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  hazardous_material_flag boolean [note: 'Hazardous material flag']
  last_updated_timestamp timestamp [note: 'Last updated timestamp']
  mes_order_reference varchar [note: 'MES order reference']
  mes_sync_status varchar [note: 'Synchronization status between ERP and MES for this order.']
  model_year varchar [note: 'Model year']
  order_date date [note: 'Order date']
  order_description varchar [note: 'Order description']
  order_number varchar [note: 'Order number']
  order_status varchar [note: 'Order status']
  order_type varchar [note: 'Order type']
  planned_finish_date date [note: 'Planned finish date']
  planned_labor_hours decimal(10,2) [note: 'Planned labor hours']
  planned_machine_hours decimal(10,2) [note: 'Planned machine hours']
  planned_start_date date [note: 'Planned start date']
  ppap_required boolean [note: 'PPAP required flag']
  priority varchar [note: 'Priority']
  production_stage varchar [note: 'Production stage']
  release_timestamp timestamp [note: 'Release timestamp']
  rework_quantity decimal(15,3) [note: 'Rework quantity']
  scrap_quantity decimal(15,3) [note: 'Scrap quantity']
  sop_indicator boolean [note: 'SOP indicator']
  standard_cost decimal(18,2) [note: 'Standard cost']
  target_quantity decimal(15,3) [note: 'Target quantity']
  technical_completion_timestamp timestamp [note: 'Technical completion timestamp']
  total_cycle_time_planned_seconds decimal(12,3) [note: 'Total planned cycle time for all operations in this order.']
  unit_of_measure varchar [note: 'Unit of measure']
  vin_range_end varchar [note: 'VIN range end']
  vin_range_start varchar [note: 'VIN range start']
  wip_posting_flag boolean [note: 'WIP posting flag']

  Note: 'Production/manufacturing order for vehicle or component production with scheduling, costing, and status tracking'
}

Table manufacturing.build_sequence {
  build_sequence_id varchar [pk, note: 'Primary key']
  configuration_id varchar [note: 'FK to configuration']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Build sequences in automotive manufacturing are dealer-order-driven. JIS call-off timing, sequence priority flags, and destination routing all require the destination dealership identity. \'dealer_code']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Build sequences are model-specific for mixed-model line management and JIS call-off. vehicle_model_code is a denormalized plain string. FK to vehicle.model enables model-level sequence analysis, mixed']
  plant_id varchar [note: 'FK to plant']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: JIS (Just-In-Sequence) call-off requires the exact powertrain variant to trigger supplier deliveries and line-side sequencing. powertrain_type is a denormalized string; FK to powertrain_variant enable']
  production_line_id varchar [note: 'FK to production line']
  production_order_id varchar [note: 'FK to production order']
  actual_end_timestamp timestamp [note: 'Actual end timestamp']
  actual_start_timestamp timestamp [note: 'Actual start timestamp']
  body_style_code varchar [note: 'Body style code']
  build_type varchar [note: 'Build type']
  created_timestamp timestamp [note: 'Created timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  destination_market_code varchar [note: 'Destination market code']
  exterior_color_code varchar [note: 'Exterior color code']
  freeze_timestamp timestamp [note: 'Freeze timestamp']
  interior_color_code varchar [note: 'Interior color code']
  is_frozen boolean [note: 'Is frozen flag']
  is_priority_build boolean [note: 'Priority build flag']
  jis_call_off_timestamp timestamp [note: 'JIS call off timestamp']
  low_emission_priority_flag boolean [note: 'Low emission priority flag']
  mes_sequence_reference varchar [note: 'MES sequence reference']
  model_year varchar [note: 'Model year']
  operator_assignment_confirmed boolean [note: 'Whether all station operator assignments are confirmed for this sequence.']
  option_package_code varchar [note: 'Option package code']
  planned_build_date date [note: 'Planned build date']
  planned_end_timestamp timestamp [note: 'Planned end timestamp']
  planned_start_timestamp timestamp [note: 'Planned start timestamp']
  quality_hold_flag boolean [note: 'Quality hold flag']
  sequence_number varchar [note: 'Sequence number']
  sequence_revision_number varchar [note: 'Revision number']
  sequence_set_number varchar [note: 'Sequence set number']
  sequence_status varchar [note: 'Sequence status']
  sequence_type varchar [note: 'Sequence type']
  takt_time_seconds varchar [note: 'Takt time seconds']
  transmission_type varchar [note: 'Transmission type']
  trim_level_code varchar [note: 'Trim level code']
  updated_timestamp timestamp [note: 'Updated timestamp']
  vin varchar [note: 'VIN']
  work_instruction_version varchar [note: 'Active work instruction version set for this sequence position.']

  Note: 'Vehicle build sequence defining the order of vehicles on the production line with configuration and scheduling details'
}

Table manufacturing.vehicle_build {
  vehicle_build_id varchar [pk, note: 'Primary key']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Each vehicle build is executed against a specific BOM header/version. This link is critical for recall investigations (identify all vehicles built with a specific BOM revision), warranty traceability,']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: As-built BOM traceability per VIN is a regulatory and warranty requirement in automotive. Linking vehicle_build to the exact engineering BOM version used enables recall investigations, warranty claims']
  build_sequence_id varchar [note: 'Foreign key linking to manufacturing.build_sequence. Business justification: A vehicle_build record represents the actual manufacturing execution of a vehicle that was planned in a build_sequence slot. The build_sequence defines the planned order and configuration; vehicle_bui']
  build_spec_id varchar [note: 'Foreign key linking to vehicle.build_spec. Business justification: End-of-line conformance checking compares actual build outcome (vehicle_build) against the planned build specification (build_spec). This link is required for regulatory build conformance reporting, N']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: vehicle_build must reference the specific configuration being built for end-of-line configuration conformance verification and recall traceability by configuration. vehicle_model_code is a denormalize']
  finished_vehicle_stock_id varchar [note: 'Foreign key linking to inventory.finished_vehicle_stock. Business justification: When final assembly completes, a finished_vehicle_stock record is created from the vehicle_build. Recall investigations, IATF 16949 traceability audits, and warranty registration all require linking t']
  homologation_record_id varchar [note: 'FK to homologation record']
  plant_id varchar [note: 'FK to plant']
  production_order_id varchar [note: 'FK to production order']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns must identify and track specific vehicle builds (by VIN) within scope. Linking vehicle_build to recall_campaign enables recall scope determination, remedy completion tracking per buil']
  vehicle_compound_id varchar [note: 'Foreign key linking to logistics.vehicle_compound. Business justification: Post-build compound staging: every finished vehicle is staged at a vehicle compound before outbound transport. Build-to-compound assignment drives PDI scheduling, yard management, and outbound logisti']
  vin_registry_id varchar [note: 'FK to VIN registry']
  andon_call_count varchar [note: 'Total andon calls during this vehicle build.']
  battery_serial_number varchar [note: 'Battery serial number']
  body_shop_end_timestamp timestamp [note: 'Body shop end']
  body_shop_start_timestamp timestamp [note: 'Body shop start']
  body_style varchar [note: 'Body style']
  build_carbon_footprint_kg decimal(10,4) [note: 'Build carbon footprint kg']
  build_end_timestamp timestamp [note: 'Build end timestamp']
  build_start_timestamp timestamp [note: 'Build start timestamp']
  build_status varchar [note: 'Build status']
  build_type varchar [note: 'Build type']
  created_timestamp timestamp [note: 'Created timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  end_of_line_test_result varchar [note: 'End of line test result']
  engine_serial_number varchar [note: 'Engine serial number']
  final_assembly_end_timestamp timestamp [note: 'Final assembly end']
  final_assembly_start_timestamp timestamp [note: 'Final assembly start']
  hold_flag boolean [note: 'Hold flag']
  hold_reason_code varchar [note: 'Hold reason code']
  mes_build_ref varchar [note: 'MES system reference for this vehicle build.']
  model_year varchar [note: 'Model year']
  paint_color_code varchar [note: 'Paint color code']
  paint_end_timestamp timestamp [note: 'Paint end']
  paint_start_timestamp timestamp [note: 'Paint start']
  powertrain_type varchar [note: 'Powertrain type']
  quality_gate_status varchar [note: 'Quality gate status']
  rework_count varchar [note: 'Rework count']
  rework_flag boolean [note: 'Rework flag']
  scheduled_build_date date [note: 'Scheduled build date']
  total_cycle_time_seconds decimal(12,3) [note: 'Total accumulated cycle time for this vehicle build.']
  transmission_serial_number varchar [note: 'Transmission serial number']
  updated_timestamp timestamp [note: 'Updated timestamp']
  vin varchar [note: 'VIN']

  Note: 'Individual vehicle build record tracking the manufacturing lifecycle from body shop through final assembly'
}

Table manufacturing.production_schedule {
  production_schedule_id varchar [pk, note: 'Primary key']
  fleet_contract_id varchar [note: 'Foreign key linking to sales.fleet_contract. Business justification: Fleet contracts commit to specific delivery volumes by period. Production schedules must be aligned to fleet contract commitments for volume fulfillment tracking and capacity allocation. This link ena']
  milestone_id varchar [note: 'Foreign key linking to engineering.milestone. Business justification: Production schedules in automotive are gated by engineering program milestones — production cannot be scheduled before SOP milestone approval. This FK enables milestone-gated scheduling and program ma']
  plant_id varchar [note: 'FK to plant']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Production schedules are platform-specific — a platform determines which models can be built on which lines and constrains mixed-model scheduling. Platform-level scheduling enables capacity planning a']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Production scheduling requires the exact powertrain variant to allocate correct tooling, energy budgets, and takt time. powertrain_type is a denormalized string; a proper FK enables MES-driven variant']
  production_line_id varchar [note: 'FK to production line']
  vehicle_model_id varchar [note: 'FK to vehicle model']
  vehicle_program_id varchar [note: 'FK to vehicle program']
  actual_quantity varchar [note: 'Actual quantity']
  capacity_utilization_pct decimal(5,2) [note: 'Capacity utilization pct']
  confirmed_quantity varchar [note: 'Confirmed quantity']
  created_timestamp timestamp [note: 'Created timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  energy_budget_kwh decimal(12,2) [note: 'Energy budget kWh']
  freeze_horizon_date date [note: 'Freeze horizon date']
  is_frozen boolean [note: 'Is frozen']
  last_updated_timestamp timestamp [note: 'Last updated timestamp']
  mes_schedule_ref varchar [note: 'MES system reference for this schedule.']
  model_year varchar [note: 'Model year']
  operator_availability_count varchar [note: 'Number of operators available for this schedule period.']
  planned_quantity varchar [note: 'Planned quantity']
  schedule_date date [note: 'Schedule date']
  schedule_end_date date [note: 'Schedule end date']
  schedule_number varchar [note: 'Schedule number']
  schedule_status varchar [note: 'Schedule status']
  schedule_type varchar [note: 'Schedule type']
  schedule_version varchar [note: 'Schedule version']
  shift_pattern varchar [note: 'Shift pattern']
  takt_time_seconds varchar [note: 'Takt time seconds']

  Note: 'Production scheduling data including planned volumes, capacity utilization, and freeze horizons'
}

Table manufacturing.production_bom {
  production_bom_id varchar [pk, note: 'Primary key']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: The production BOM is derived from the product/engineering BOM header during manufacturing release. Tracing production_bom back to bom_header is essential for BOM change impact analysis, ECO (Engineer']
  bom_id varchar [note: 'FK to engineering BOM']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Each production BOM version is created or revised in response to an Engineering Change Order (ECO). Linking production_bom to the triggering change enables ECO implementation traceability in manufactu']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Production BOMs are configuration-specific — market variant, trim level, and option packages determine which components are included. Linking production_bom to configuration enables configurable manuf']
  model_id varchar [note: 'FK to vehicle model']
  output_sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: The production BOM header references the output finished-good SKU it produces — fundamental for MRP explosion, material cost rollups, and BOM-to-inventory availability checks. Role-prefix \'output_\' us']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Production BOM is built around a specific engineering part/material. Linking to part_master enables ECO impact analysis — when an engineering change affects a part, all production BOMs referencing it ']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Production BOMs (MBOM) are plant-specific configurations derived from the engineering BOM. production_bom currently stores plant_code as a STRING denormalized reference. Adding plant_id FK to manufact']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Production BOMs are powertrain-variant-specific — EV and ICE BOMs differ significantly in components, assembly operations, and material costs. Linking production_bom to powertrain_variant enables vari']
  base_quantity decimal(18,6) [note: 'Base quantity']
  base_unit_of_measure varchar [note: 'Base unit of measure']
  bom_description varchar [note: 'BOM description']
  bom_status varchar [note: 'BOM status']
  bom_type varchar [note: 'BOM type']
  bom_version varchar [note: 'BOM version']
  component_count varchar [note: 'Component count']
  created_timestamp timestamp [note: 'Created timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  effectivity_end_date date [note: 'Effectivity end date']
  effectivity_start_date date [note: 'Effectivity start date']
  is_configurable boolean [note: 'Is configurable']
  last_modified_timestamp timestamp [note: 'Last modified timestamp']
  model_year varchar [note: 'Model year']
  recyclability_pct decimal(5,2) [note: 'Recyclability percentage']

  Note: 'Production bill of materials (MBOM) derived from engineering BOM with plant-specific configurations'
}

Table manufacturing.material_consumption {
  material_consumption_id varchar [pk, note: 'Primary key']
  plant_id varchar [note: 'FK to plant']
  production_order_id varchar [note: 'FK to production order']
  sku_master_id varchar [note: 'FK to SKU master']
  storage_location_id varchar [note: 'FK to storage location']
  work_center_id varchar [note: 'FK to work center']
  batch_number varchar [note: 'Batch number']
  consumption_status varchar [note: 'Consumption status']
  consumption_timestamp timestamp [note: 'Consumption timestamp']
  created_timestamp timestamp [note: 'Created timestamp']
  currency_code varchar [note: 'Currency code']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  goods_movement_type varchar [note: 'Goods movement type']
  last_updated_timestamp timestamp [note: 'Last updated timestamp']
  material_cost_amount decimal(18,2) [note: 'Material cost amount']
  planned_quantity decimal(18,6) [note: 'Planned quantity']
  posting_date date [note: 'Posting date']
  quantity_consumed decimal(18,6) [note: 'Quantity consumed']
  quantity_variance decimal(18,6) [note: 'Quantity variance']
  recycled_content_pct decimal(5,2) [note: 'Recycled content pct']
  reversal_indicator boolean [note: 'Reversal indicator']
  scrap_indicator boolean [note: 'Scrap indicator']
  unit_of_measure varchar [note: 'Unit of measure']

  Note: 'Material consumption postings against production orders tracking actual vs planned usage'
}

Table manufacturing.rework_order {
  rework_order_id varchar [pk, note: 'Primary key']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Rework orders are raised for defects on specific parts. Linking to part_master enables engineering to track manufacturing defect rates by part — directly feeds FMEA RPN updates, design improvement dec']
  plant_id varchar [note: 'FK to plant']
  production_order_id varchar [note: 'FK to production order']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns directly trigger rework orders for affected vehicles. Linking rework_order to recall_campaign enables recall-driven rework cost attribution, completion rate reporting to regulatory bo']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: A rework_order is raised for a specific defective vehicle build unit. vehicle_build has rework_flag and rework_count attributes confirming that rework is tracked at the vehicle build level. Linking re']
  work_center_id varchar [note: 'FK to work center']
  actual_end_timestamp timestamp [note: 'Actual end timestamp']
  actual_rework_hours decimal(8,2) [note: 'Actual rework hours']
  actual_start_timestamp timestamp [note: 'Actual start timestamp']
  created_timestamp timestamp [note: 'Created timestamp']
  currency_code varchar [note: 'Currency code']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  defect_code varchar [note: 'Defect code']
  defect_description varchar [note: 'Defect description']
  is_safety_related boolean [note: 'Is safety related']
  planned_end_timestamp timestamp [note: 'Planned end timestamp']
  planned_rework_hours decimal(8,2) [note: 'Planned rework hours']
  planned_start_timestamp timestamp [note: 'Planned start timestamp']
  priority_level varchar [note: 'Priority level']
  re_inspection_required boolean [note: 'Re-inspection required']
  re_inspection_result varchar [note: 'Re-inspection result']
  rework_attempt_count varchar [note: 'Rework attempt count']
  rework_cost decimal(18,2) [note: 'Rework cost']
  rework_order_number varchar [note: 'Rework order number']
  rework_status varchar [note: 'Rework status']
  rework_type varchar [note: 'Rework type']
  updated_timestamp timestamp [note: 'Updated timestamp']
  waste_generated_kg decimal(10,4) [note: 'Waste generated kg']

  Note: 'Rework orders for defective units requiring correction before proceeding in production'
}

Table manufacturing.production_confirmation {
  production_confirmation_id varchar [pk, note: 'Primary key']
  goods_movement_id varchar [note: 'Foreign key linking to inventory.goods_movement. Business justification: Production confirmations trigger automatic goods movements (goods receipt for finished output, goods issue for components) in SAP. Linking confirmation to goods_movement enables confirmation-to-invent']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: In automotive SAP/MES integration, production confirmations trigger or reference inspection lots for quality verification at operation completion. This link enables confirmation-to-inspection traceabi']
  production_order_id varchar [note: 'FK to production order']
  work_center_id varchar [note: 'FK to work center']
  confirmation_number varchar [note: 'Confirmation number']
  confirmation_timestamp timestamp [note: 'Confirmation timestamp']
  confirmation_type varchar [note: 'Confirmation type']
  created_timestamp timestamp [note: 'Created timestamp']
  cycle_time_actual_seconds decimal(10,3) [note: 'Actual cycle time recorded at confirmation from MES']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  energy_actual_kwh decimal(10,4) [note: 'Energy actual kWh']
  energy_consumed_kwh decimal(10,4) [note: 'Energy consumed during this confirmed operation for ESG tracking']
  is_final_confirmation boolean [note: 'Is final confirmation']
  labor_hours decimal(8,2) [note: 'Labor hours']
  machine_hours decimal(8,2) [note: 'Machine hours']
  mes_confirmation_ref varchar [note: 'MES system reference for this confirmation.']
  oee_contribution_flag boolean [note: 'Whether this confirmation contributes to OEE calculation']
  operation_number varchar [note: 'Operation number']
  posting_date date [note: 'Posting date']
  rework_quantity decimal(15,3) [note: 'Rework quantity']
  scrap_quantity decimal(15,3) [note: 'Scrap quantity']
  station_code varchar [note: 'Station code where confirmation was recorded.']
  unit_of_measure varchar [note: 'Unit of measure']
  updated_timestamp timestamp [note: 'Updated timestamp']
  yield_quantity decimal(15,3) [note: 'Yield quantity']

  Note: 'Production order confirmations recording completed operations, quantities, and labor/machine hours'
}

Table manufacturing.capacity_plan {
  capacity_plan_id varchar [pk, note: 'Primary key']
  milestone_id varchar [note: 'Foreign key linking to engineering.milestone. Business justification: Automotive capacity plans are structured around program milestones (SOP, Job1, ramp-up gates). Linking capacity_plan to milestone enables milestone-driven capacity planning — a standard automotive pro']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Capacity plans are built around specific vehicle model volumes in S&OP (Sales & Operations Planning). Model-level demand drives required capacity hours, operator counts, and energy budgets. This link ']
  plant_id varchar [note: 'FK to plant']
  production_line_id varchar [note: 'FK to production line']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Capacity planning in automotive is always executed per vehicle program — capacity is allocated to support a specific program\'s launch volume and ramp-up. Without this FK, capacity plans cannot be aggr']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: Capacity planning in automotive manufacturing operates at the work center level, not just at the production line level. Work centers are the granular capacity units (individual stations with defined a']
  available_capacity_hours decimal(10,2) [note: 'Available capacity hours']
  created_timestamp timestamp [note: 'Created timestamp']
  cycle_time_constraint_seconds decimal(10,3) [note: 'Bottleneck cycle time constraining capacity.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  energy_budget_kwh decimal(12,2) [note: 'Planned energy budget for the capacity plan period']
  oee_target_pct decimal(5,2) [note: 'Target OEE percentage for capacity planning']
  operator_requirement_count varchar [note: 'Number of operators required for this capacity plan.']
  plan_name varchar [note: 'Plan name']
  plan_period_end date [note: 'Plan period end']
  plan_period_start date [note: 'Plan period start']
  plan_status varchar [note: 'Plan status']
  plan_type varchar [note: 'Plan type']
  planned_units varchar [note: 'Planned units']
  required_capacity_hours decimal(10,2) [note: 'Required capacity hours']
  shift_pattern varchar [note: 'Shift pattern']
  sustainability_constraint_flag boolean [note: 'Sustainability constraint flag']
  updated_timestamp timestamp [note: 'Updated timestamp']
  utilization_pct decimal(5,2) [note: 'Utilization pct']

  Note: 'Production capacity planning records for lines and plants with demand vs available capacity'
}

Table manufacturing.routing {
  routing_id varchar [pk, note: 'Primary key']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: In automotive SAP PP, a routing is directly associated with a BOM header — the routing defines the manufacturing operations to produce what the BOM specifies. This link enables standard cost calculati']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Engineering changes (ECOs) that affect part geometry or process parameters require routing updates. Linking routing to the implementing change enables manufacturing process change control traceability']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: In automotive APQP/PPAP, each routing (process flow) must reference its corresponding control plan — this is a mandatory PPAP Package element. Linking routing to control_plan enables PPAP documentatio']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Routing operations must conform to engineering design specifications (torque specs, weld parameters, surface finish). Linking routing to design_specification enables process validation traceability — ']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Routings define the model-specific sequence of manufacturing operations (body shop, paint, final assembly). Different models require different operation sequences and cycle times. Linking routing to m']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Routings define manufacturing operations for a specific part or assembly. Linking routing to part_master enables process planning traceability — when an ECO changes a part, manufacturing identifies wh']
  plant_id varchar [note: 'FK to plant']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Routings are platform-specific — the sequence of manufacturing operations (body shop geometry, weld schedules, paint process) is determined by the vehicle platform architecture. Platform-level routing']
  vehicle_program_id varchar [note: 'FK to vehicle program']
  created_timestamp timestamp [note: 'Created timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  description varchar [note: 'Routing description']
  effective_from date [note: 'Effective from']
  effective_until date [note: 'Effective until']
  energy_per_operation_kwh decimal(10,4) [note: 'Energy per operation kWh']
  mes_routing_code varchar [note: 'MES system routing identifier for integration']
  mes_routing_ref varchar [note: 'Reference to the routing definition in MES.']
  operation_count varchar [note: 'Operation count']
  routing_number varchar [note: 'Routing number']
  routing_status varchar [note: 'Routing status']
  routing_type varchar [note: 'Routing type']
  total_cycle_time_seconds decimal(12,2) [note: 'Total cycle time seconds']
  total_standard_cycle_time_seconds decimal(12,3) [note: 'Sum of standard cycle times across all operations in routing.']
  updated_timestamp timestamp [note: 'Updated timestamp']
  version varchar [note: 'Routing version']
  work_instruction_count varchar [note: 'Number of work instructions linked to this routing']
  work_instruction_linked_flag boolean [note: 'Whether all operations have linked digital work instructions.']

  Note: 'Manufacturing routing definitions specifying the sequence of operations for producing a product'
}

Table manufacturing.routing_operation {
  routing_operation_id varchar [pk, note: 'Primary key for the routing_operation association']
  routing_id varchar [note: 'Foreign key linking to the routing header that this operation step belongs to']
  work_center_id varchar [note: 'Foreign key linking to the work center that executes this operation step']
  operation_description varchar [note: 'Human-readable description of the manufacturing operation performed at this step (e.g., \'Robotic MIG weld door hinge bracket\'). Specific to this routing-work center combination.']
  operation_number varchar [note: 'Sequence number of this operation within the routing (e.g., 0010, 0020, 0030 in SAP PP convention). Determines the execution order of work centers within the routing.']
  setup_time_minutes decimal [note: 'Time in minutes required to set up the work center before executing this operation for this routing. Varies by routing-work center combination.']
  standard_time_seconds decimal [note: 'Standard cycle time in seconds for this specific operation at this specific work center within this routing. Belongs to the operation step, not to the routing header or work center master.']
  teardown_time_minutes decimal [note: 'Time in minutes required to tear down or reset the work center after completing this operation for this routing.']
  work_instruction_reference varchar [note: 'Reference to the digital work instruction document governing this specific operation step. Links to the MES work instruction system for operator guidance at this work center for this routing.']

  Note: 'This association product represents the Operation Step between routing and work_center. It captures each discrete manufacturing operation within a routing sequence, specifying which work center executes it, in what order, and with what time standards. Each record links one routing to one work center for a specific operation step, carrying attributes (operation number, standard times, work instructions) that exist only in the context of this routing-to-work-center assignment. Corresponds to SAP PP PLPO table and IATF 16949 process flow traceability requirements.. Existence Justification: In automotive manufacturing, a routing defines the sequence of operations to produce a part, and each operation step is executed at a specific work center. A single routing visits multiple work centers (e.g., stamping → welding → painting → assembly), and a single work center executes operations for many different routings across different vehicle programs. This is the canonical \'routing operation\' concept in SAP PP (PLPO table) and every automotive MES — it is an actively managed operational record, not an analytical correlation.'
}

Table supply.supplier {
  supplier_id varchar [pk, note: 'Primary key']
  jurisdiction_id varchar [note: 'FK to jurisdiction']
  city varchar [note: 'City']
  code varchar [note: 'Supplier code']
  country_code varchar [note: 'Country code']
  created_timestamp timestamp [note: 'Created timestamp']
  duns_number varchar [note: 'DUNS number']
  is_active boolean [note: 'Active flag']
  name varchar [note: 'Supplier name']
  onboarding_date date [note: 'Onboarding date']
  quality_rating varchar [note: 'Quality rating']
  supplier_type varchar [note: 'Supplier type']
  tier_level varchar [note: 'Tier level']

  Note: 'Master record for all tier-1 and tier-2 suppliers in the automotive supply chain. Captures supplier identity, classification (direct/indirect, tier level), IATF 16949 certification status, DUNS number, geographic footprint, commodity codes, preferred currency, payment terms, and supplier lifecycle status (active, probation, disqualified). SSOT for supplier identity within the supply domain; integrates with SAP MM vendor master and PTC Windchill supplier collaboration.'
}

Table supply.supplier_plant {
  supplier_plant_id varchar [pk, note: 'Primary key']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: A supplier plant operates under a specific jurisdiction\'s regulatory framework, determining which homologation, emissions, and safety standards apply to parts produced there. Sourcing and compliance t']
  supplier_id varchar [note: 'FK to supplier']
  capacity_units_per_day varchar [note: 'Daily capacity']
  city varchar [note: 'City']
  country_code varchar [note: 'Country code']
  created_timestamp timestamp [note: 'Created timestamp']
  iatf_certified boolean [note: 'IATF 16949 certified']
  is_active boolean [note: 'Active flag']
  plant_code varchar [note: 'Plant code']
  plant_name varchar [note: 'Plant name']

  Note: 'Represents the specific manufacturing or distribution plant/site of a supplier that ships parts to an OEM assembly plant. Captures plant address, plant code, production capabilities, capacity constraints, dock-to-dock lead time, customs zone, and plant-level quality certifications. Enables JIT/JIS scheduling at the plant-to-plant level and supports CKD/SKD kit origin tracking.'
}

Table supply.inbound_part {
  inbound_part_id varchar [pk, note: 'System-generated unique identifier for the inbound part record.']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Inbound parts are procured to a specific design specification revision level. When engineering releases a new spec revision, supply must identify affected inbound parts for re-sourcing or PPAP re-subm']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: Inbound parts in automotive are sourced via defined logistics lanes (supplier plant → OEM plant). Lane assignment drives freight rate selection, customs routing, and lead time calculation. Supply chai']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Inbound receipt process matches each received part to the engineering part master for quality verification and BOM reconciliation.']
  product_bom_line_id varchar [note: 'Foreign key linking to product.product_bom_line. Business justification: Inbound parts are the supply-side realization of BOM line components. Linking to product_bom_line enables direct traceability from supply receipt to BOM position — critical for PPAP compliance, engine']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Regulatory Requirement Mapping report links each inbound part to the regulatory requirement it must satisfy for emissions and safety compliance.']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: Receiving process matches inbound parts to SKU master to create accurate stock records; essential for inventory posting.']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Connect inbound part to internal supplier master for analytics']
  supplier_plant_id varchar [note: 'Foreign key linking to supply.supply_supplier_plant. Business justification: A purchased part is manufactured and shipped from a specific supplier plant, not just a supplier entity. inbound_part currently links to supply_supplier (entity level) but lacks plant-level granularit']
  average_cost decimal(12,4) [note: 'Weighted average purchase cost per unit of the part.']
  commodity_group varchar [note: 'High‑level classification of the part for procurement and reporting.']
  country_of_origin varchar [note: 'Three‑letter ISO code of the country where the part was manufactured.']
  created_timestamp timestamp [note: 'Date and time when the inbound part record was first created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the part\'s cost.']
  customs_tariff_code varchar [note: 'HS‑8 tariff classification code used for import duties.']
  effective_from date [note: 'Date from which the part information is considered valid.']
  effective_until date [note: 'Date after which the part information is no longer valid (nullable).']
  engineering_change_level varchar [note: 'Level of engineering change applied to the part (e.g., A‑E).']
  hazardous_material_flag boolean [note: 'Indicates whether the part is classified as hazardous under regulatory rules.']
  height_mm decimal(10,2) [note: 'Physical height of the part in millimetres.']
  last_received_date date [note: 'Date when the part was most recently received at the plant.']
  last_received_quantity varchar [note: 'Quantity of the part received on the most recent receipt.']
  lead_time_days varchar [note: 'Planned number of days from order placement to receipt.']
  length_mm decimal(10,2) [note: 'Physical length of the part in millimetres.']
  lifecycle_status varchar [note: 'Current operational status of the part within the supply chain.']
  lot_size varchar [note: 'Standard production batch size for the part.']
  material_type varchar [note: 'Category indicating whether the part is raw material, sub‑assembly, CKD kit, finished good, or service item.']
  minimum_order_quantity varchar [note: 'Smallest quantity that can be ordered from the supplier.']
  oem_part_number varchar [note: 'Original Equipment Manufacturer part number used internally for cross‑reference.']
  part_name varchar [note: 'Human‑readable name or description of the purchased part.']
  ppap_status varchar [note: 'Current status of the Production Part Approval Process for the part.']
  price_uom varchar [note: 'Unit of measure used for the price (e.g., each, kilogram).']
  reorder_point_quantity varchar [note: 'Inventory level that triggers a new purchase order.']
  safety_stock_quantity varchar [note: 'Buffer inventory quantity maintained to protect against supply variability.']
  supplier_part_number varchar [note: 'Identifier assigned by the external supplier to the part.']
  unit_of_measure varchar [note: 'Standard unit used for ordering and inventory management.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the record.']
  weight_kg decimal(12,3) [note: 'Net weight of the part in kilograms.']
  width_mm decimal(10,2) [note: 'Physical width of the part in millimetres.']

  Note: 'Master record for every purchased part number sourced from external suppliers. Captures OEM part number, supplier part number cross-reference, commodity group, material type (raw, sub-assembly, CKD kit), unit of measure, PPAP approval status, engineering change level, hazardous material flag, country of origin, and customs tariff code. Bridges SAP MM material master and PTC Windchill parts classification for supply-domain-owned purchased parts.'
}

Table supply.sourcing_nomination {
  sourcing_nomination_id varchar [pk, note: 'System-generated unique identifier for each sourcing nomination record.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: Supplier nomination for new programs: sourcing nominations are made within APQP program context before RFQ issuance. Commodity managers nominate suppliers against specific APQP plans to ensure quality']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Sourcing nominations are created for specific vehicle programs defined by a BOM. Linking to bom_header enables program-level sourcing strategy tied to exact BOM revision, model year, and variant — ess']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Sourcing nominations are triggered by engineering changes (new parts, design changes requiring new supplier qualification). Linking nominations to the originating ECO enables engineering change cost i']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: A sourcing nomination formally designates a supplier for a specific purchased part. inbound_part is the supply-domain master record for purchased parts. Adding inbound_part_id normalizes the part refe']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Sourcing nominations in automotive are issued per vehicle platform/program. Linking to platform enables platform-level commodity sourcing reports, supplier nomination tracking by platform, and program']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Link sourcing nomination to internal supplier master']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Sourcing nominations are created per vehicle program to establish commodity supply strategy. Program-level sourcing decisions (SOR, nominated volumes, JIT/JIS flags) are driven by vehicle program requ']
  comments varchar [note: 'Additional notes or remarks entered by the buyer or sourcing team.']
  commodity varchar [note: 'High‑level classification of the part or commodity being nominated (e.g., ENGINE, HVAC, ELECTRICAL).']
  commodity_index_linked_flag boolean [note: 'Whether the sourcing nomination pricing is linked to a commodity index.']
  created_timestamp timestamp [note: 'Timestamp when the nomination record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the target piece price.']
  effective_end_date date [note: 'Optional date when the nomination expires or is superseded.']
  effective_start_date date [note: 'Date from which the nomination becomes effective for planning purposes.']
  is_jis boolean [note: 'Indicates whether the nominated part is required under a JIS delivery strategy.']
  is_jit boolean [note: 'Indicates whether the nominated part is required under a JIT delivery strategy.']
  kit_type varchar [note: 'Specifies whether the part is supplied as a Completely Knocked Down (CKD) or Semi‑Knocked Down (SKD) kit, or not a kit.']
  model_year varchar [note: 'Model year for which the part nomination applies.']
  nominated_volume decimal(12,2) [note: 'Total quantity of the part the supplier is expected to deliver for the program.']
  nomination_date timestamp [note: 'Timestamp when the OEM formally recorded the nomination.']
  nomination_number varchar [note: 'Human‑readable business code assigned to the nomination for tracking and reference.']
  nomination_status varchar [note: 'Current lifecycle status of the nomination.']
  priority varchar [note: 'Business priority assigned to the nomination for execution planning.']
  region varchar [note: 'Region code indicating the primary supply geography for the nominated part.']
  risk_rating varchar [note: 'Qualitative assessment of supply risk for the nominated part.']
  sor_reference varchar [note: 'Reference code linking to the SOR document that defines functional and performance requirements.']
  target_piece_price decimal(12,4) [note: 'Target unit price (per piece) the OEM aims to achieve with the nominated supplier.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the nomination record.']

  Note: 'Records the formal OEM decision to nominate a specific supplier for a given part or commodity within a model year program. Captures nomination date, program/platform code, nominated supplier, awarded annual volume, target piece price, SOR (Statement of Requirements) reference, nomination status (nominated, confirmed, withdrawn), and the responsible commodity buyer. Precedes the RFQ and PPAP process. SSOT for sourcing award decisions; distinct from procurement domain\'s strategic sourcing strategy — this is the operational award record.'
}

Table supply.rfq {
  rfq_id varchar [pk, note: 'System‑generated unique identifier for the RFQ record.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: Program sourcing: RFQs for new vehicle programs are issued under APQP plans that define quality requirements suppliers must meet. Sourcing teams reference the APQP plan to set compliance_requirements ']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: RFQs are issued for parts within a specific vehicle program BOM. Linking rfq to bom_header enables BOM-level cost rollup and sourcing cost analysis per program. program_model_year is a denormalized re']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Engineering change orders (ECOs) frequently trigger new or revised RFQs when part specifications change. ECO-to-RFQ traceability is a standard automotive sourcing process requirement for cost impact a']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: RFQs must reference the specific design specification revision suppliers are quoting against. Issuing an RFQ without a spec revision reference is an automotive sourcing process gap — suppliers cannot ']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: An RFQ is issued for a specific purchased part. inbound_part is the supply-domain master for purchased parts, capturing OEM part number, supplier part number, lead time, MOQ, and other supply-specific']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: RFQ generation is driven by engineering part definitions; linking to part_master enables accurate pricing and specification alignment.']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: RFQs in automotive are issued for parts destined for a specific vehicle platform. This FK enables platform-level sourcing spend analysis, RFQ tracking by platform, and supplier selection reports per p']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: RFQs for powertrain-specific parts (battery cells, engine components, e-motors) are issued per powertrain variant. This FK enables powertrain-level sourcing cost analysis, supplier selection for speci']
  sourcing_nomination_id varchar [note: 'Foreign key linking to supply.sourcing_nomination. Business justification: In automotive procurement, an RFQ event is typically triggered by and traceable to a sourcing nomination decision. Linking rfq to sourcing_nomination establishes the procurement lifecycle chain: nomin']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Associate RFQ with internal supplier master']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: RFQs are issued for specific vehicle programs; suppliers need full program context (platform, targets, segment) to quote accurately. Program-level RFQ reporting and spend analysis require this link. p']
  approval_status varchar [note: 'Current status of internal approval workflow.']
  attachment_flag boolean [note: 'Indicates whether supporting documents are attached to the RFQ.']
  commodity_code varchar [note: 'Standard industry code classifying the type of material or service requested.']
  commodity_index_reference varchar [note: 'Reference to commodity price index for material cost escalation.']
  compliance_requirements varchar [note: 'Regulatory or quality standards the supplier must meet (e.g., IATF 16949, ISO 14001).']
  created_timestamp timestamp [note: 'Timestamp when the RFQ record was first created in the system.']
  delivery_schedule_type varchar [note: 'Preferred delivery methodology (Just‑In‑Time, Just‑In‑Sequence, or standard).']
  discount_amount decimal(18,2) [note: 'Any discount the supplier proposes relative to the target price.']
  eprocurement_portal_code varchar [note: 'FK to the e-procurement portal through which this RFQ was issued.']
  issue_timestamp timestamp [note: 'Date‑time when the RFQ was issued to suppliers.']
  last_status_change_timestamp timestamp [note: 'Timestamp of the most recent change to the RFQ status.']
  net_price_amount decimal(18,2) [note: 'Net price after discounts, taxes, and fees.']
  notes varchar [note: 'Free‑form notes entered by the buyer.']
  priority varchar [note: 'Business priority assigned to the RFQ.']
  quantity_estimate varchar [note: 'Projected annual volume the buyer expects to purchase.']
  regulatory_approval_required boolean [note: 'True if the part requires regulatory sign‑off before purchase.']
  required_delivery_date date [note: 'Date by which the part must be delivered to the plant.']
  response_due_date date [note: 'Last date on which suppliers may submit their quotations.']
  rfq_number varchar [note: 'Business‑visible RFQ number assigned by the sourcing system.']
  rfq_status varchar [note: 'Current lifecycle state of the RFQ.']
  rfq_type varchar [note: 'Classification of the RFQ request.']
  target_price_amount decimal(18,2) [note: 'Maximum price the buyer is willing to pay for the quoted item (gross).']
  target_price_currency varchar [note: 'Three‑letter ISO 4217 currency code for the target price.']
  tooling_description varchar [note: 'Details of the tooling requirements, if any.']
  tooling_required boolean [note: 'Indicates whether new tooling is needed for the part.']
  unit_of_measure varchar [note: 'Unit in which the quantity is expressed.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the RFQ record.']
  created_by varchar [note: 'User identifier of the employee who created the RFQ.']

  Note: 'Transactional record of a Request for Quotation event issued to one or more suppliers for a specific part, assembly, or service. Captures RFQ number, issue date, response due date, commodity, target price, annual volume estimate, program/model year, tooling requirements, and RFQ status (open, closed, awarded, cancelled). Integrates with SAP MM RFQ (ME41) and PTC Windchill supplier collaboration portal.'
}

Table supply.rfq_response {
  rfq_response_id varchar [pk, note: 'System-generated unique identifier for the RFQ response record.']
  rfq_id varchar [note: 'Identifier of the original Request for Quotation to which this response belongs.']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Associate RFQ response with internal supplier master']
  amortization_term_months varchar [note: 'Number of months over which the tooling cost is amortized.']
  capacity_commitment decimal(18,4) [note: 'Maximum production capacity the supplier commits to deliver per period.']
  capacity_unit varchar [note: 'Unit for the capacity commitment (e.g., units_per_month).']
  commodity_surcharge_amount decimal(18,2) [note: 'Commodity surcharge amount included in the quoted price.']
  compliance_certifications varchar [note: 'List of regulatory or industry certifications attached to the quotation.']
  created_timestamp timestamp [note: 'Timestamp when the RFQ response record was first created in the system.']
  delivery_address varchar [note: 'Physical address where the supplier will deliver the goods.']
  discount_percentage decimal(5,2) [note: 'Percentage discount offered on the quoted unit price.']
  exceptions_to_sor varchar [note: 'Supplier‑provided deviations or exceptions to the original SOR.']
  freight_included boolean [note: 'True if freight costs are included in the total price.']
  is_preferred_supplier boolean [note: 'Indicates whether the supplier is marked as a preferred source for this part.']
  lead_time_days varchar [note: 'Number of calendar days the supplier needs to deliver the quoted items after order confirmation.']
  payment_terms varchar [note: 'Standard payment condition offered by the supplier.']
  portal_submission_flag boolean [note: 'Whether this response was submitted via e-procurement portal.']
  quoted_currency varchar [note: 'ISO 4217 currency code of the quoted price.']
  quoted_quantity decimal(18,4) [note: 'Quantity of items the supplier is quoting for.']
  quoted_unit_price decimal(18,4) [note: 'Price per unit quoted by the supplier.']
  regulatory_approval_status varchar [note: 'Status of any required regulatory approvals for the quoted part.']
  remarks varchar [note: 'Additional free‑form comments from the supplier.']
  response_number varchar [note: 'External reference number assigned to the supplier\'s quotation response.']
  response_source varchar [note: 'Channel through which the supplier submitted the quotation.']
  rfq_response_status varchar [note: 'Current lifecycle status of the RFQ response.']
  shipping_method varchar [note: 'Mode of transportation for delivering the goods.']
  submission_timestamp timestamp [note: 'Date and time when the supplier submitted the quotation.']
  tax_amount decimal(18,4) [note: 'Estimated tax component included in the quotation.']
  tooling_cost decimal(18,4) [note: 'One‑time cost for tooling or molds required to produce the part.']
  total_price decimal(18,4) [note: 'Total amount for the quoted quantity (unit price multiplied by quantity).']
  unit_of_measure varchar [note: 'Measurement unit for the quoted quantity.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the RFQ response record.']
  validity_end_date date [note: 'Last date on which the quoted terms are valid.']
  validity_start_date date [note: 'First date on which the quoted terms are valid.']
  warranty_period_months varchar [note: 'Length of warranty coverage offered by the supplier.']
  warranty_type varchar [note: 'Type of warranty provided.']

  Note: 'Captures a supplier\'s formal quotation response to an RFQ. Records quoted unit price, tooling cost, amortization terms, lead time, capacity commitment, exceptions to SOR, validity period, and response status (submitted, under review, accepted, rejected). Supports competitive bid analysis and supplier selection decisions. One RFQ may have multiple responses from competing suppliers.'
}

Table supply.purchase_order {
  purchase_order_id varchar [pk, note: 'Primary key']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Dealers order parts and accessories from the OEM supply chain via purchase orders (dealer parts procurement process). Linking supply_purchase_order to dealership enables dealer parts spend reporting, ']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Purchase orders are raised by and for a specific manufacturing plant in multi-plant OEM operations. Plant-level procurement reporting, budget control, and goods receipt routing all require knowing whi']
  price_agreement_id varchar [note: 'Foreign key linking to supply.price_agreement. Business justification: A purchase order\'s pricing is governed by a formally agreed price agreement. Linking supply_purchase_order to price_agreement enables header-level price compliance validation and commercial traceabili']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: MRP/ERP procurement-to-production linkage: purchase orders are raised to fulfill specific production order material requirements. Multi-plant automotive OEMs (SAP PP-MM integration) require this link ']
  scheduling_agreement_id varchar [note: 'Foreign key linking to supply.scheduling_agreement. Business justification: In automotive JIT/JIS supply chains, purchase orders are frequently issued as call-off releases against a long-term scheduling agreement. Linking supply_purchase_order to scheduling_agreement establis']
  supplier_id varchar [note: 'FK to supplier']
  created_timestamp timestamp [note: 'Created timestamp']
  currency_code varchar [note: 'Currency code']
  delivery_date date [note: 'Expected delivery date']
  incoterms varchar [note: 'Incoterms']
  order_date date [note: 'Order date']
  payment_terms varchar [note: 'Payment terms']
  po_number varchar [note: 'PO number']
  po_status varchar [note: 'PO status']
  po_type varchar [note: 'PO type']
  total_amount decimal(18,2) [note: 'Total PO amount']

  Note: 'Legally binding procurement document issued to a supplier authorizing delivery of parts or materials at agreed price and schedule. Captures PO number, PO type (standard, blanket, scheduling agreement), supplier, plant, delivery terms (Incoterms), payment terms, total value, currency, and PO status (open, partially delivered, closed, cancelled). SSOT for purchase commitments; sourced from SAP MM (ME21N/ME22N).'
}

Table supply.po_line {
  po_line_id varchar [pk, note: 'Primary key']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: A PO line authorizes delivery of a specific purchased part. inbound_part is the supply-domain master for purchased parts. supply_po_line currently carries denormalized part_number and part_description']
  price_agreement_id varchar [note: 'Foreign key linking to supply.price_agreement. Business justification: A PO line\'s unit price is governed by a formally agreed price agreement between the OEM and supplier. Linking supply_po_line to price_agreement enables price compliance validation — comparing the PO l']
  purchase_order_id varchar [note: 'FK to PO']
  scheduling_agreement_id varchar [note: 'Foreign key linking to supply.scheduling_agreement. Business justification: In JIT/JIS automotive supply chains, purchase order lines are frequently issued as releases against a long-term scheduling agreement. Linking supply_po_line to scheduling_agreement establishes the con']
  sku_master_id varchar [note: 'FK to SKU master']
  supplier_id varchar [note: 'FK to supplier']
  delivery_date date [note: 'Delivery date']
  goods_receipt_quantity decimal(12,4) [note: 'GR quantity']
  line_number varchar [note: 'Line number']
  line_status varchar [note: 'Line status']
  net_amount decimal(18,2) [note: 'Net amount']
  quantity decimal(12,4) [note: 'Order quantity']
  unit_of_measure varchar [note: 'Unit of measure']
  unit_price decimal(18,4) [note: 'Unit price']

  Note: 'Individual line item within a purchase order representing a specific part number, quantity, unit price, delivery date, and plant destination. Captures line number, material number, ordered quantity, confirmed quantity, net price, delivery date, goods receipt quantity, and invoice quantity. Enables line-level tracking of delivery performance and invoice matching (3-way match) in SAP MM.'
}

Table supply.scheduling_agreement {
  scheduling_agreement_id varchar [pk, note: 'System generated unique identifier for the scheduling agreement record.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: New model launch: scheduling agreements for new-program parts are established under APQP plans that define quality targets (target_ppm, target_otd_percent already on scheduling_agreement). Procurement']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Scheduling agreements govern long-term supply of parts for specific vehicle programs. Linking to bom_header enables program-level supply coverage analysis, ensures agreements align with the correct BO']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: Scheduling agreements in automotive define long-term supply contracts including delivery rhythm and logistics parameters. Lane assignment to a scheduling agreement enables freight cost estimation, lea']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Scheduling agreements are created per engineering part to lock volume, price, and delivery cadence with the supplier.']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Scheduling agreements in automotive OEM procurement are plant-specific (SAP ME31L). A part approved and priced for one plant is a separate agreement for another. Plant-level SA management is required ']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Scheduling agreements are negotiated per vehicle platform/program in automotive. This FK supports platform-level supply continuity planning, contract management by program, and production volume commi']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Scheduling agreements for safety-critical or regulated parts carry compliance_approval_status and compliance_document_ref fields, indicating a real dependency on a specific regulatory requirement. Pro']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Link scheduling agreement to internal supplier master']
  supplier_plant_id varchar [note: 'Foreign key linking to supply.supply_supplier_plant. Business justification: A scheduling agreement for JIT/JIS delivery is with a specific supplier plant, not just the supplier entity. The plant\'s capacity (capacity_units_per_day) and IATF certification status (iatf_certified']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Scheduling agreements define delivery volumes and rhythm for a vehicle program\'s production lifecycle. Program-level supply planning, capacity allocation, and end-of-life management all require linkin']
  actual_otd_percent decimal(5,2) [note: 'Measured on‑time delivery performance for the agreement period.']
  actual_ppm decimal(5,2) [note: 'Measured defect rate for parts delivered under the agreement.']
  agreement_number varchar [note: 'External business identifier assigned to the scheduling agreement (e.g., contract number).']
  agreement_type varchar [note: 'Classification of the scheduling agreement (e.g., framework, spot, consignment).']
  approval_date date [note: 'Date on which the agreement received formal approval.']
  commodity_escalation_clause_flag boolean [note: 'Whether the scheduling agreement includes a commodity price escalation clause.']
  compliance_approval_status varchar [note: 'Regulatory or quality compliance status of the agreement.']
  compliance_document_ref varchar [note: 'Reference number of the attached compliance documentation.']
  contract_scope varchar [note: 'High‑level description of the parts, services, or components covered.']
  contract_version varchar [note: 'Version identifier for the agreement when amendments are made.']
  created_timestamp timestamp [note: 'Timestamp when the scheduling agreement record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency used for pricing.']
  delivery_rhythm varchar [note: 'Scheduled frequency of deliveries defined in the agreement.']
  description varchar [note: 'Free‑text description of the purpose, scope and key terms of the agreement.']
  early_termination_allowed boolean [note: 'Flag indicating whether the agreement can be terminated before the end date.']
  end_date date [note: 'Date on which the agreement expires or is terminated (nullable for open‑ended contracts).']
  kanban_flag boolean [note: 'Indicates whether the agreement uses a Kanban pull system for JIT deliveries.']
  part_description varchar [note: 'Human‑readable description of the part covered by the agreement.']
  payment_terms varchar [note: 'Standard payment condition agreed with the supplier.']
  penalty_clause varchar [note: 'Text describing penalties for missed deliveries or quality breaches.']
  portal_managed_flag boolean [note: 'Whether this scheduling agreement is managed via e-procurement portal.']
  price_per_unit decimal(18,4) [note: 'Agreed price for one unit of the supplied part.']
  release_horizon_weeks varchar [note: 'Number of weeks in advance that delivery forecasts must be submitted.']
  renewal_notice_period_days varchar [note: 'Notice period required to exercise renewal option.']
  renewal_option boolean [note: 'Indicates if the agreement includes an automatic renewal provision.']
  scheduling_agreement_status varchar [note: 'Current lifecycle status of the scheduling agreement.']
  start_date date [note: 'Date on which the agreement becomes binding.']
  target_otd_percent decimal(5,2) [note: 'Target percentage for on‑time deliveries defined in the agreement.']
  target_ppm decimal(5,2) [note: 'Maximum allowable defect rate for supplied parts.']
  termination_notice_period_days varchar [note: 'Number of days notice required to terminate the agreement early.']
  total_annual_volume decimal(18,2) [note: 'Planned total quantity of parts to be supplied over the contract year.']
  unit_of_measure varchar [note: 'Measurement unit for the volume (e.g., pieces, kilograms).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the scheduling agreement record.']

  Note: 'Long-term supply agreement with a supplier defining the framework for JIT/JIS delivery of parts over a model year or contract period. Captures agreement number, validity start/end dates, target annual volume, release horizon (firm/forecast weeks), delivery rhythm (daily, weekly), Kanban flag, and agreement status. The scheduling agreement is the backbone of JIT supply in SAP MM (ME31L/ME32L).'
}

Table supply.delivery_schedule {
  delivery_schedule_id varchar [pk, note: 'Primary key']
  mrp_requirement_id varchar [note: 'Foreign key linking to inventory.mrp_requirement. Business justification: In automotive JIT/JIS operations, MRP requirements are the demand signals that generate delivery schedule releases. Supply planners reconcile open MRP requirements against scheduled deliveries to iden']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Every delivery schedule targets a specific receiving manufacturing plant. Multi-plant OEM logistics require plant-level delivery tracking for dock scheduling, inbound logistics planning, and plant-lev']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: JIS (Just-In-Sequence) delivery schedules are tied to specific production lines, not just plants. Automotive JIS call-offs specify the exact line and sequence position; this link is essential for line']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: JIT/JIS delivery schedules are triggered by specific production orders. Automotive OEMs require this link to confirm parts arrive in time for the production order\'s planned start, enabling MRP excepti']
  production_schedule_id varchar [note: 'Foreign key linking to manufacturing.production_schedule. Business justification: Production schedules are the upstream trigger for supplier delivery scheduling in JIT automotive supply chains. This link enables supply planners to align delivery windows with frozen production sched']
  purchase_order_id varchar [note: 'FK to PO']
  scheduling_agreement_id varchar [note: 'Foreign key linking to supply.scheduling_agreement. Business justification: supply_delivery_schedule is explicitly described as a JIT/JIS delivery schedule line issued against a scheduling agreement. The scheduling_agreement is the parent framework document; delivery schedule']
  shipment_id varchar [note: 'Foreign key linking to logistics.shipment. Business justification: JIT/JIS delivery schedule lines in automotive are fulfilled by specific inbound shipments. Linking enables OTD tracking, schedule adherence reporting, and supplier delivery performance measurement — a']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Automotive JIT delivery schedules specify the exact unloading point and destination storage location (line-side, sequencing area, supermarket). Logistics coordinators use this to pre-assign dock doors']
  supplier_id varchar [note: 'FK to supplier']
  actual_delivery_date date [note: 'Actual delivery date']
  actual_quantity decimal(12,4) [note: 'Actual quantity delivered']
  created_timestamp timestamp [note: 'Created timestamp']
  delivery_status varchar [note: 'Delivery status']
  schedule_type varchar [note: 'Schedule type']
  scheduled_date date [note: 'Scheduled delivery date']
  scheduled_quantity decimal(12,4) [note: 'Scheduled quantity']

  Note: 'JIT/JIS delivery schedule line issued against a scheduling agreement, specifying exact quantities and delivery dates/times for a part to a plant dock. Captures schedule line date, time, required quantity, cumulative quantity, schedule type (firm, forecast, JIS sequence), dock door, and transmission status (sent, acknowledged, revised). Drives supplier production and logistics planning. Sourced from SAP MM schedule lines (EKET).'
}

Table supply.ppap_submission {
  ppap_submission_id varchar [pk, note: 'Primary key']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: AIAG PPAP process: every PPAP submission is executed under a specific APQP plan phase (Phase 4/5). Quality engineers use this link to verify PPAP submissions satisfy APQP gate requirements. Automotive']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: PPAP submissions are required for parts entering production on a specific vehicle program BOM. Linking to bom_header enables program-level PPAP status tracking, regulatory compliance reporting, and la']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: Control plan is one of the 18 mandatory PPAP elements per AIAG standard. PPAP Level 3+ submissions must reference the approved control plan. Supplier quality engineers track which control plan version']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: AIAG PPAP requirements mandate that submissions reference the approved design record/specification revision. Linking PPAP submissions to design_specification enables engineering to verify suppliers ar']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: AIAG PPAP Level 3+ submissions require the supplier to reference the DFMEA/PFMEA record as a mandatory element. Linking supply_ppap_submission to fmea_record enables engineering to verify PPAP package']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: A PPAP submission is the formal approval of a supplier\'s manufacturing process for a specific purchased part. inbound_part is the supply-domain master for purchased parts, and its ppap_status field di']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: PPAP submissions are tied to a specific vehicle platform/program in automotive. This FK enables platform launch readiness dashboards, regulatory PPAP compliance tracking per program, and supplier qual']
  receiving_plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: PPAP approvals are plant-specific in automotive: a part approved for Plant A is NOT automatically approved for Plant B (AIAG PPAP 4th edition). The receiving plant must be recorded on each PPAP submis']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: PPAP level 3/4/5 submissions in automotive are mandated by specific regulatory bodies (NHTSA, EU type-approval authorities). Linking PPAP submissions to the governing regulatory body enables complianc']
  supplier_id varchar [note: 'FK to supplier']
  supplier_plant_id varchar [note: 'Foreign key linking to supply.supply_supplier_plant. Business justification: PPAP (Production Part Approval Process) approves a supplier\'s manufacturing process at a specific plant. The approval is plant-specific — a supplier may have multiple plants, each requiring separate P']
  approval_date date [note: 'Approval date']
  created_timestamp timestamp [note: 'Created timestamp']
  disposition varchar [note: 'Disposition']
  reason_for_submission varchar [note: 'Reason for submission']
  reviewer_name varchar [note: 'Reviewer name']
  submission_date date [note: 'Submission date']
  submission_level varchar [note: 'PPAP submission level']
  submission_status varchar [note: 'Submission status']

  Note: 'Production Part Approval Process submission record tracking the formal approval of a supplier\'s manufacturing process for a specific part. Captures PPAP level (1–5), submission date, part number, supplier, engineering change level, submission reason (new part, engineering change, tooling move), PPAP elements checklist status, PSW (Part Submission Warrant) status, and approval/rejection date. Integrates with PTC Windchill and SAP QM. SSOT for PPAP compliance.'
}

Table supply.goods_receipt {
  goods_receipt_id varchar [pk, note: 'Primary key']
  goods_movement_id varchar [note: 'Foreign key linking to inventory.goods_movement. Business justification: Every supplier goods receipt generates an inventory goods movement posting (e.g., movement type 101 in SAP). Supply chain controllers reconcile goods receipts against inventory postings for GR/IR clea']
  in_transit_inventory_id varchar [note: 'Foreign key linking to logistics.in_transit_inventory. Business justification: When inbound parts are receipted in automotive, the corresponding in-transit inventory record must be closed/resolved. Direct FK from GR to in_transit_inventory supports the inbound logistics closure ']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Inbound quality process: goods receipt triggers creation of an inspection lot for incoming part inspection. This direct link enables receiving teams to navigate from goods receipt to inspection status']
  movement_type_id varchar [note: 'Foreign key linking to inventory.movement_type. Business justification: Goods receipts must reference a movement type that governs accounting determination, quality inspection triggers, and stock category (unrestricted, quality hold, blocked). Automotive receiving operati']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Goods receipts occur at a specific manufacturing plant (receiving plant). Required for plant-level inventory posting, storage location assignment, and multi-plant inbound logistics reporting. Fundamen']
  po_line_id varchar [note: 'Foreign key linking to supply.supply_po_line. Business justification: A goods receipt confirms physical delivery of parts against a specific PO line item. supply_goods_receipt currently links to supply_purchase_order (header level) but lacks line-level granularity. Addi']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Goods receipts fulfill material requirements for production orders (SAP movement type 101 against production order). This link is required for production order cost settlement, material availability c']
  purchase_order_id varchar [note: 'FK to PO']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Goods receipts are posted to a specific storage location (receiving dock, quality hold area). The existing plain-text \'storage_location\' column is a denormalization of inventory.storage_location. Ware']
  supplier_id varchar [note: 'FK to supplier']
  supplier_plant_id varchar [note: 'Foreign key linking to supply.supply_supplier_plant. Business justification: Goods are physically received FROM a specific supplier plant. supply_goods_receipt currently links to supply_supplier (entity level) but lacks plant-level granularity. Adding supply_supplier_plant_id ']
  accepted_quantity decimal(12,4) [note: 'Accepted quantity']
  created_timestamp timestamp [note: 'Created timestamp']
  inspection_status varchar [note: 'Inspection status']
  receipt_date date [note: 'Receipt date']
  receipt_number varchar [note: 'Receipt number']
  received_quantity decimal(12,4) [note: 'Received quantity']
  rejected_quantity decimal(12,4) [note: 'Rejected quantity']

  Note: 'Records the physical receipt and system confirmation of parts delivered by a supplier to an OEM plant. Captures GR document number, posting date, received quantity, accepted quantity, rejected quantity, storage location, batch number, GR type (standard, return, subsequent delivery), and posting status. Triggers inventory update and initiates 3-way invoice matching in SAP MM (MIGO). SSOT for inbound goods confirmation.'
}

Table supply.supplier_scorecard {
  supplier_scorecard_id varchar [pk, note: 'System-generated unique identifier for each supplier scorecard record.']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Supplier performance is evaluated per receiving plant in multi-plant OEM operations — a supplier may have excellent OTD at one plant and poor performance at another. Plant-level scorecards are standar']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Connect supplier scorecard to internal supplier master']
  commodity_price_competitiveness_score decimal(5,2) [note: 'Score measuring supplier commodity price competitiveness vs market indices.']
  compliance_score decimal(5,2) [note: 'Score measuring adherence to regulatory and internal compliance requirements.']
  corrective_action_description varchar [note: 'Free‑text description of actions the supplier must take to address deficiencies.']
  corrective_action_flag boolean [note: 'True when the supplier must undertake corrective actions.']
  created_timestamp timestamp [note: 'Date and time when the scorecard record was first created in the system.']
  delivery_quantity_accuracy_pct decimal(5,2) [note: 'Ratio of delivered quantity to ordered quantity, expressed as a percent.']
  evaluation_date timestamp [note: 'Exact timestamp when the scorecard was completed.']
  evaluation_period_end date [note: 'Last calendar day of the period covered by the scorecard.']
  evaluation_period_start date [note: 'First calendar day of the period covered by the scorecard.']
  evaluator_name varchar [note: 'Full name of the internal evaluator responsible for the scorecard.']
  notes varchar [note: 'Additional comments or observations captured during the evaluation.']
  otd_percentage decimal(5,2) [note: 'Percentage of deliveries that arrived on or before the agreed delivery date.']
  overall_score decimal(5,2) [note: 'Aggregated weighted score combining all KPI values for the evaluation period.']
  performance_tier varchar [note: 'Categorical tier assigned based on the overall score.']
  ppap_on_time_completion_rate decimal(5,2) [note: 'Percentage of PPAP submissions completed within the agreed timeframe.']
  ppm_defect_rate decimal(5,2) [note: 'Defect rate expressed in parts per million for supplied parts during the period.']
  quality_ppm decimal(10,2)
  responsiveness_score decimal(5,2) [note: 'Score reflecting the supplier\'s responsiveness to inquiries and change requests.']
  review_status varchar [note: 'Indicates whether the scorecard is still being drafted, has been finalized, or has been reviewed by management.']
  risk_score decimal(5,2) [note: 'Composite risk rating derived from financial, operational, and compliance factors.']
  scorecard_number varchar [note: 'Human‑readable identifier assigned to the scorecard, used for reporting and audit trails.']
  scorecard_period varchar
  scoring_methodology_version varchar [note: 'Identifier of the scoring model version used for this evaluation.']
  supplier_scorecard_status varchar [note: 'Current state of the scorecard in its lifecycle.']
  sustainability_score decimal(5,2) [note: 'Score reflecting the supplier\'s environmental and sustainability initiatives.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the scorecard.']

  Note: 'Periodic (monthly/quarterly) performance evaluation record for a supplier across key KPIs including PPM (Parts Per Million defect rate), OTD (On-Time Delivery percentage), delivery quantity accuracy, PPAP on-time completion rate, responsiveness score, and overall supplier rating. Captures evaluation period, scoring methodology version, individual KPI values, weighted total score, performance tier (preferred, approved, conditional, disqualified), and corrective action flag.'
}

Table supply.price_agreement {
  price_agreement_id varchar [pk, note: 'System-generated unique identifier for the price agreement record.']
  bom_header_id varchar [note: 'Foreign key linking to product.sku. Business justification: Price agreements are negotiated per SKU, supporting cost management and contract compliance.']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: A price agreement defines the formally agreed piece price for a specific purchased part. inbound_part is the supply-domain master for purchased parts. price_agreement currently carries a denormalized ']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Price agreements in automotive are negotiated at the engineering part level (drawing number, revision). Direct link to part_master enables cost target vs. actual price reconciliation — a standard comm']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Supplier price agreements in automotive are negotiated at platform/program level. This FK supports platform-level cost management, should-cost analysis by program, and annual price reduction tracking ']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Price agreements carry compliance_approval_status and compliance_document_ref, indicating regulated-part pricing requires approval against a specific regulatory requirement. Linking directly enables c']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: Price agreements are negotiated per part/SKU; linking provides pricing data for inventory valuation and costing.']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Associate price agreement with internal supplier master']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Price agreements are scoped to vehicle programs for annual price reduction commitments and program cost-down tracking. A commodity manager reporting program-level material cost performance requires th']
  actual_otd_percent decimal(5,2) [note: 'Measured on‑time delivery performance of the supplier for the current period.']
  actual_ppm decimal(5,2) [note: 'Measured defect rate of supplied parts for the current period.']
  agreement_number varchar [note: 'External business identifier assigned to the price agreement by the OEM.']
  agreement_type varchar [note: 'Classification of the agreement indicating its primary purpose (e.g., price, cost, service, tooling).']
  annual_price_reduction_commitment decimal(5,2) [note: 'Percentage reduction in price committed by the supplier each year.']
  commodity_index_linked_flag boolean [note: 'Whether the price agreement is linked to a commodity price index.']
  commodity_index_name varchar [note: 'Name of the commodity index used for price escalation (e.g., LME Aluminum).']
  compliance_approval_status varchar [note: 'Status of internal compliance review for the agreement.']
  compliance_document_ref varchar [note: 'Reference identifier for the compliance documentation attached to the agreement.']
  contract_scope varchar [note: 'Narrative defining the parts, volumes, and geographic regions covered by the agreement.']
  created_timestamp timestamp [note: 'Date and time when the price agreement record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency used for the unit price.']
  description varchar [note: 'Free‑form text describing the purpose, scope, and any special conditions of the agreement.']
  early_termination_allowed boolean [note: 'Indicates whether the agreement may be terminated before the end date without penalty.']
  effective_end_date date [note: 'Date on which the price agreement expires or is terminated; null if open‑ended.']
  effective_start_date date [note: 'Date on which the price agreement becomes binding.']
  escalation_formula varchar [note: 'Formula for commodity-based price escalation/de-escalation.']
  payment_terms varchar [note: 'Standard payment condition agreed for invoices under this price agreement.']
  penalty_clause varchar [note: 'Text describing penalties for non‑compliance such as late delivery or quality breaches.']
  price_adjustment_trigger varchar [note: 'Condition that can trigger a price change during the agreement (material index, foreign exchange, or none).']
  price_agreement_status varchar [note: 'Current lifecycle status of the price agreement.']
  renewal_notice_period_days varchar [note: 'Number of days notice required to exercise a renewal option.']
  renewal_option varchar [note: 'Specifies if the agreement auto‑renews, requires manual renewal, or does not renew.']
  target_otd_percent decimal(5,2) [note: 'Contractual target for supplier on‑time delivery performance.']
  target_ppm decimal(5,2) [note: 'Maximum acceptable defect rate for supplied parts under the agreement.']
  termination_notice_period_days varchar [note: 'Number of days notice required to terminate the agreement early.']
  tooling_amortization_terms varchar [note: 'Terms describing how tooling costs are amortized over the agreement period.']
  total_annual_volume decimal(18,2) [note: 'Maximum total quantity of the part that may be purchased under the agreement each year.']
  unit_of_measure varchar [note: 'Measurement unit used for the agreed price and volume (e.g., piece, kilogram).']
  unit_price decimal(18,6) [note: 'Negotiated price per unit of the part for the agreement period.']
  updated_timestamp timestamp [note: 'Date and time of the most recent modification to the price agreement record.']
  version_number varchar [note: 'Sequential version number of the agreement reflecting amendments.']

  Note: 'Formally agreed piece price and commercial terms between the OEM and a supplier for a specific part over a defined period. Captures agreement number, part number, supplier, effective date, expiry date, agreed unit price, currency, annual price reduction commitment (APR), tooling amortization terms, price adjustment triggers (material index, FX), and agreement status (active, expired, under negotiation). Distinct from the purchase order — this is the commercial price framework.'
}

Table quality.apqp_plan {
  apqp_plan_id varchar [pk, note: 'System-generated unique identifier for the APQP plan record.']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: APQP gate reviews in IATF 16949 require traceability to the specific BOM revision in scope. Quality engineers need to know which BOM configuration (variant, model year, emissions standard) the APQP pl']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: APQP planning requires referencing the homologation approval to align release dates with regulatory clearance.']
  milestone_id varchar [note: 'Foreign key linking to engineering.milestone. Business justification: APQP gate completion is tracked against engineering program milestones in launch readiness reviews. Quality teams must confirm engineering milestone dates align with APQP phase gates — a standard APQP']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: APQP planning is defined per vehicle model; linking APQP plan to model enables model‑specific quality goals and gate tracking.']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: APQP plans in automotive are plant-specific launch quality plans — each plant runs its own APQP for a new model launch. This link enables plant-level APQP status reporting, launch readiness tracking p']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Platform-level APQP plans govern quality gates for all models on a shared architecture. Quality engineers run platform APQP gate reviews independently of individual models. A domain expert expects apq']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: New powertrain introductions require dedicated APQP plans (PPAP submission, SOP gate). Powertrain APQP plans are managed separately from body/model plans. Quality engineers need to retrieve all APQP p']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: APQP plans explicitly require identification of applicable regulatory requirements as a Phase 1 input. Direct linkage enables regulatory requirement coverage tracking across APQP gates, supports homol']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: APQP planning is executed per vehicle program; linking aligns plans with program metadata and eliminates program_name duplication.']
  actual_ppm decimal(10,2) [note: 'Measured parts-per-million defect rate observed after validation.']
  actual_release_date date [note: 'Actual date when the product was released to production.']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  apqp_phase varchar [note: 'Current phase of the APQP process for the plan.']
  classification_type varchar [note: 'Category of the APQP plan based on product scope.']
  compliance_status varchar [note: 'Current IATF 16949 compliance status of the APQP plan.']
  created_timestamp timestamp [note: 'Date and time when the APQP plan record was created in the system.']
  documentation_link varchar [note: 'URL or path to the primary APQP documentation repository.']
  effective_from date [note: 'Date when the APQP plan becomes effective.']
  effective_until date [note: 'Date when the APQP plan expires or is superseded (nullable).']
  eop_date date [note: 'Date when series production ended for the vehicle/program.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  gate_completion_date date [note: 'Actual date when the milestone gate was completed.']
  gate_due_date date [note: 'Planned due date for the milestone gate.']
  gate_status varchar [note: 'Current status of the milestone gate.']
  lifecycle_status varchar [note: 'Current lifecycle state of the APQP plan.']
  milestone_gate varchar [note: 'Specific APQP milestone gate associated with the plan.']
  mitigation_plan varchar [note: 'Description of actions taken to mitigate identified risks.']
  model_year varchar [note: 'Model year (calendar year) of the vehicle model associated with the APQP plan.']
  notes varchar [note: 'Free-text field for additional comments or observations.']
  owner_name varchar [note: 'Name of the internal owner or manager of the APQP plan.']
  part_number varchar [note: 'Identifier of the part or component covered by the APQP plan (e.g., OEM part number).']
  plan_number varchar [note: 'External business identifier assigned to the APQP plan, often used in documentation and reporting.']
  quality_goal_ppm decimal(10,2) [note: 'Target parts-per-million defect rate defined for the APQP plan.']
  responsible_team varchar [note: 'Team or department accountable for executing the APQP plan.']
  risk_assessment_date date [note: 'Date when the risk assessment for the APQP plan was performed.']
  risk_level varchar [note: 'Overall risk classification for the APQP plan.']
  sop_date date [note: 'Date when series production started for the vehicle/program.']
  target_ppm decimal(10,2) [note: 'Planned PPM level to achieve during the APQP process.']
  target_release_date date [note: 'Planned date for the product release associated with the APQP plan.']
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the APQP plan record.']
  version_number varchar [note: 'Version identifier for the APQP plan record.']

  Note: 'Advanced Product Quality Planning master record governing the structured quality planning process for new vehicle programs and components. Tracks APQP phases (concept, design, process, validation, launch), milestone gates, responsible teams, and completion status per program/part. Aligns with IATF 16949 requirements and links to engineering change and SOP timelines.'
}

Table quality.control_plan {
  control_plan_id varchar [pk, note: 'Unique system-generated identifier for the quality control plan.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: In APQP methodology, the Control Plan is a key deliverable output of the APQP process. A control_plan belongs to a specific apqp_plan governing the product quality planning lifecycle. This FK normaliz']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: IATF 16949 and PPAP require control plans to be tied to a specific product BOM revision. When a BOM changes (ECN), the control plan must be reviewed and updated. This FK enables change impact analysis']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Control plans are derived from design specifications; FK enables automatic extraction of spec requirements for quality control.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Control plans in automotive are authored per vehicle model as part of APQP/PPAP. Quality engineers retrieve all control plans for a model during model-year changeover audits and customer-specific qual']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Control plans are authored per part to define inspection and control methods — a core PPAP element. Linking to part_master replaces the denormalized part_number column and enables part-level control p']
  primary_control_inspection_plan_id varchar [note: 'Link to the detailed inspection plan referenced by this control plan.']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: Control plans are line‑specific for process control; required for the Production Control Review report.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: IATF 16949 and APQP mandate that control plans reference applicable regulatory requirements. Control plans define process controls that must satisfy specific regulations (e.g., emissions process contr']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: IATF 16949 control plans are defined at the work center/process step level, specifying what to measure and how at each station. Linking control_plan to work_center enables station-specific SPC setup a']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  approval_date date [note: 'Date when the control plan received final approval.']
  approval_status varchar [note: 'Current approval state of the control plan.']
  approved_by varchar [note: 'Employee identifier who approved the control plan.']
  change_control_number varchar [note: 'Reference number for the change control record associated with this plan.']
  control_method varchar [note: 'Statistical or inspection method used to control the characteristic.']
  control_plan_status varchar [note: 'Current lifecycle status of the control plan per IATF 16949.']
  created_timestamp timestamp [note: 'Timestamp when the control plan record was first created in the system.']
  description varchar [note: 'Free‑text description of the purpose, scope, and key characteristics of the control plan.']
  effective_end_date date [note: 'Date when the control plan is retired or superseded (null if open‑ended).']
  effective_start_date date [note: 'Date when the control plan becomes effective for production.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  is_mandatory boolean [note: 'Indicates whether the control plan is mandatory for the operation.']
  lower_spec_limit decimal(12,4) [note: 'Minimum acceptable value for the characteristic.']
  measurement_unit varchar [note: 'Unit of measure for the control characteristic (e.g., mm, psi). [ENUM-REF-CANDIDATE: mm|cm|inch|mm2|g|kg|psi|kpa|percent — 9 candidates stripped; promote to reference product]']
  notes varchar [note: 'Free‑form field for any supplemental information or comments.']
  plan_name varchar [note: 'Human‑readable name of the control plan.']
  plan_number varchar [note: 'Business identifier or code assigned to the control plan (e.g., CP‑2024‑001).']
  plan_type varchar [note: 'Category of manufacturing operation the plan applies to.']
  reaction_plan varchar [note: 'Defined corrective actions if a measurement falls outside specification limits.']
  responsible_function varchar [note: 'Organizational function accountable for the control plan.']
  revision_date date [note: 'Date when the current revision was released.']
  revision_number varchar [note: 'Sequential revision number of the control plan.']
  sample_frequency varchar [note: 'Frequency at which sampling is performed.']
  sample_size varchar [note: 'Number of units inspected per sampling event as defined by the plan.']
  target_value decimal(12,4) [note: 'Desired nominal value for the controlled characteristic.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the control plan record.']
  upper_spec_limit decimal(12,4) [note: 'Maximum acceptable value for the characteristic.']
  created_by varchar [note: 'Name or identifier of the employee who authored the control plan.']

  Note: 'Quality control plan defining the process controls, inspection methods, measurement systems, reaction plans, and control characteristics for each manufacturing operation or assembly step. Links to PFMEA and inspection plans. Specifies sample sizes, frequencies, control methods (SPC, attribute, visual), and responsible functions per IATF 16949 requirements.'
}

Table quality.inspection_plan {
  inspection_plan_id varchar [pk, note: 'Unique identifier for the inspection plan.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: Inspection plans are developed as part of the APQP structured quality planning process. Linking inspection_plan to its governing apqp_plan enables full APQP deliverable traceability. The inspection_pl']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Inspection plans in automotive are written for specific product configurations (BOM revision, variant, model year). The inspection_plan currently stores part_number, vehicle_model, and model_year as d']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Inspection plans are authored per vehicle model in automotive quality systems. The plain-text vehicle_model column is a denormalization of vehicle.model. A proper FK enables model-specific inspection ']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Inspection plans are created per part to specify measurement methods and acceptance criteria. Linking to part_master replaces the denormalized part_number and enables part-level inspection plan tracea']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: Inspection plans are defined per production line to meet line‑specific quality standards; used in the Line Inspection Planning process.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Inspection plans are designed to verify conformance to specific regulatory requirements (emissions measurement procedures, safety inspection criteria per FMVSS/UNECE). Compliance auditors verify inspe']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: IATF 16949 requires inspection plans to be defined per part/material. inspection_plan.part_number is a plain string denormalization of the SKU master. Linking to sku_master enables retrieval of all in']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: Inspection plans specify inspection activities at specific work centers/stations in automotive manufacturing. This link supports assignment of inspection plans to stations for in-process quality contr']
  acceptance_criteria varchar [note: 'Textual definition of pass/fail conditions.']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  applicable_process varchar [note: 'Manufacturing process to which the inspection plan applies.']
  approval_date date [note: 'Date when the inspection plan was approved.']
  approved_by varchar [note: 'User identifier of the approver.']
  created_timestamp timestamp [note: 'Timestamp when the inspection plan record was first created.']
  criticality_level varchar [note: 'Risk level associated with the inspection characteristic.']
  department_responsible varchar [note: 'Organizational department owning the inspection plan.']
  description varchar [note: 'Detailed description of the purpose and scope of the inspection plan.']
  effective_end_date date [note: 'Date when the inspection plan expires or is superseded (nullable).']
  effective_start_date date [note: 'Date when the inspection plan becomes effective.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  frequency varchar [note: 'How often the inspection is performed.']
  gauge_type varchar [note: 'Specific gauge or instrument type used.']
  inspection_category varchar [note: 'Broad category of the inspection activity.']
  inspection_plan_status varchar [note: 'Current lifecycle status of the inspection plan.']
  is_automated boolean [note: 'Indicates whether the inspection is performed by automated equipment.']
  last_review_date date [note: 'Date of the most recent plan review.']
  measurement_method varchar [note: 'Technique used to perform the measurement.']
  measurement_unit varchar [note: 'Unit of measure for tolerances and results.']
  notes varchar [note: 'Free‑form comments or special instructions.']
  plan_name varchar [note: 'Human‑readable name of the inspection plan.']
  plan_number varchar [note: 'Business identifier assigned to the inspection plan.']
  plan_type varchar [note: 'Classification of the plan (e.g., incoming material, in‑process, final vehicle).']
  plant_location varchar [note: 'Code of the manufacturing plant where the plan is executed.']
  requires_approval boolean [note: 'True if the inspection results must be formally approved.']
  review_cycle_days varchar [note: 'Number of days between mandatory reviews.']
  revision_number varchar [note: 'Sequential revision number for change tracking.']
  sample_size varchar [note: 'Number of units to be inspected per batch.']
  tolerance_lower decimal(10,4) [note: 'Minimum acceptable measurement value.']
  tolerance_upper decimal(10,4) [note: 'Maximum acceptable measurement value.']
  updated_by varchar [note: 'Identifier of the user who last modified the inspection plan.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the inspection plan.']
  version varchar [note: 'Version label of the inspection plan (e.g., v1.0, v2.1).']
  created_by varchar [note: 'Identifier of the user who created the inspection plan.']

  Note: 'Detailed inspection plan specifying the characteristics to be measured, measurement methods, gauges/instruments, tolerances, sample sizes, and acceptance criteria for incoming material, in-process, and final vehicle inspections. Supports incoming material inspection (IQC), in-process quality gates, and PDI (Pre-Delivery Inspection). Linked to SAP QM inspection lots.'
}

Table quality.inspection_lot {
  inspection_lot_id varchar [pk, note: 'System-generated unique identifier for the inspection lot record.']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: An inspection lot is executed in accordance with a specific control plan that defines the inspection methods, sample sizes, and acceptance criteria. This FK links the transactional inspection event to']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: Required for the \'Inbound Part Inspection Lot\' report that ties each inspection lot to the specific inbound part received.']
  inspection_plan_id varchar [note: 'Reference to the inspection plan governing this lot.']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Inspection lots are created for specific parts during incoming inspection and in-process quality checks. Linking to part_master enables part-level quality history, defect rate trending, and supplier q']
  pdi_vehicle_compound_id varchar [note: 'Foreign key linking to logistics.vehicle_compound. Business justification: PDI inspection lots are performed at specific vehicle compounds. Compound quality audits, PDI capability assessments, and compound performance KPIs require knowing which compound executed each inspect']
  ppap_submission_id varchar [note: 'Foreign key linking to supply.supply_ppap_submission. Business justification: PPAP sample inspection: incoming inspection lots are created specifically to inspect PPAP sample parts submitted by suppliers. Linking the inspection lot to the PPAP submission enables PPAP dispositio']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: In-process and final inspection lots in automotive manufacturing are created against specific production orders (SAP QM standard). This link enables production-order-level quality traceability, PPAP d']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: REQUIRED: Inspection lots are executed per part; adding sku_master_id supports the Lot Traceability Report linking lots to the specific SKU.']
  stock_balance_id varchar [note: 'Foreign key linking to inventory.stock_balance. Business justification: Automotive quality inspection directly manages stock in \'quality inspection\' status. stock_balance has quality_inspection_stock_qty and quality_status fields. Linking inspection_lot to the specific st']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Needed for the \'Supplier Inspection Summary\' dashboard aggregating inspection lots per supplier.']
  vehicle_transport_order_id varchar [note: 'Foreign key linking to logistics.vehicle_transport_order. Business justification: PDI (Pre-Delivery Inspection) lots in automotive are directly triggered by vehicle transport orders upon compound arrival. The transport order is the operational trigger document for PDI inspection lo']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: Inspection lots are performed at specific work centers/stations. The existing plain-text \'work_center\' column is a denormalization. A proper FK enables work-center-level defect rate KPIs and station q']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  batch_number varchar [note: 'Batch identifier associated with the material or component.']
  corrective_action_due_date date [note: 'Target date by which the corrective action must be completed.']
  corrective_action_required boolean [note: 'Indicates whether a corrective action must be initiated for the identified defect.']
  created_timestamp timestamp [note: 'Timestamp when the inspection lot record was first created in the system.']
  decision varchar [note: 'Final usage decision for the lot after inspection.']
  defect_code varchar [note: 'Standardized code for any defect identified during inspection.']
  defect_description varchar [note: 'Narrative description of the defect.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  inspection_lot_status varchar [note: 'Current lifecycle status of the inspection lot.']
  inspection_method varchar [note: 'Technique used to perform the inspection.']
  inspection_reason_code varchar [note: 'Code indicating why the inspection was triggered (e.g., SOP, PPAP, random sampling).']
  inspection_timestamp timestamp [note: 'Timestamp when the inspection activity was performed.']
  lot_closure_date date [note: 'Date when the inspection lot was closed after final decision.']
  lot_number varchar [note: 'Business identifier assigned to the inspection lot, often matching the SAP lot number.']
  lot_origin varchar [note: 'Origin of the lot (e.g., goods receipt, production order).']
  lot_type varchar [note: 'Classification of the lot being inspected (e.g., incoming material, work‑in‑process assembly, finished vehicle, prototype).']
  measurement_result_status varchar [note: 'Result of the measurement against specification limits.']
  measurement_unit varchar [note: 'Unit of measure associated with the measured value (e.g., mm, V).']
  measurement_value decimal(12,4) [note: 'Quantitative measurement recorded during inspection (e.g., dimension, voltage).']
  quantity_accepted varchar [note: 'Number of units/items that passed inspection criteria.']
  quantity_inspected varchar [note: 'Total number of units/items examined in this inspection lot.']
  quantity_rejected varchar [note: 'Number of units/items that failed inspection criteria.']
  remarks varchar [note: 'Free‑form comments or notes captured by the inspector.']
  serial_number varchar [note: 'Serial number of the inspected unit, if applicable.']
  source_document_number varchar [note: 'Reference number of the originating document such as goods receipt, production order, or delivery.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the inspection lot record.']

  Note: 'Transactional record of a quality inspection event triggered for a batch of incoming materials, WIP assemblies, or finished vehicles. Captures lot origin (goods receipt, production order, delivery), inspection type, quantity inspected, inspection start/end timestamps, assigned inspector, and overall usage decision (accept, reject, conditional release). Sourced from SAP QM inspection lot management.'
}

Table quality.inspection_result {
  inspection_result_id varchar [pk, note: 'Unique identifier for the inspection result record.']
  characteristic_id varchar [note: 'Identifier of the inspected characteristic or measurement point.']
  inspection_lot_id varchar [note: 'Identifier of the inspection lot (header) to which this result belongs.']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  comments varchar [note: 'Free-text notes or observations recorded by the inspector.']
  cp_value decimal(5,3) [note: 'Cp value calculated for the characteristic.']
  cpk_value decimal(5,3) [note: 'Cpk value calculated for the characteristic.']
  created_timestamp timestamp [note: 'Timestamp when the inspection result record was created.']
  deviation_amount decimal(18,6) [note: 'Numeric difference between measured value and nearest specification limit.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  inspection_timestamp timestamp [note: 'Date and time when the measurement was taken.']
  is_critical boolean [note: 'Indicates if the characteristic is critical to vehicle safety or compliance.']
  line_sequence varchar [note: 'Sequential order of the characteristic within the inspection lot.']
  lower_spec_limit decimal(18,6) [note: 'Minimum acceptable value for the characteristic.']
  measurement_accuracy decimal(10,4) [note: 'Accuracy specification of the measurement instrument.']
  measurement_condition varchar [note: 'Environmental condition during measurement.']
  measurement_humidity_percent decimal(5,2) [note: 'Relative humidity percentage at time of measurement.']
  measurement_location varchar [note: 'Physical location on the vehicle or part where measurement was taken.']
  measurement_method varchar [note: 'Method used to capture the measurement.']
  measurement_resolution decimal(10,4) [note: 'Resolution of the measurement instrument.']
  measurement_source varchar [note: 'Origin of the measurement data (e.g., internal sensor, external lab).']
  measurement_temperature_c decimal(6,2) [note: 'Ambient temperature in Celsius at time of measurement.']
  measurement_tool varchar [note: 'Tool or equipment used for the measurement.']
  measurement_uncertainty decimal(10,4) [note: 'Estimated uncertainty of the measurement.']
  measurement_unit varchar [note: 'Unit of measure for the measured value (e.g., millimeter, kilogram).']
  measurement_value decimal(18,6) [note: 'Numeric value recorded for the characteristic.']
  record_status varchar [note: 'Current lifecycle status of the record (e.g., active, archived).']
  result_status varchar [note: 'Pass/fail outcome of the measurement.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  upper_spec_limit decimal(18,6) [note: 'Maximum acceptable value for the characteristic.']

  Note: 'Individual characteristic measurement result recorded during an inspection lot. Captures the measured value or attribute outcome, tolerance limits, pass/fail status, measurement instrument used, and inspector ID for each characteristic within an inspection plan. Supports SPC data collection and statistical analysis of process capability (Cp, Cpk).'
}

Table quality.defect_record {
  defect_record_id varchar [pk, note: 'System-generated unique identifier for the defect record.']
  apqp_plan_id varchar [note: 'Reference to the quality plan or inspection plan associated with the defect.']
  case_id varchar [note: 'Foreign key linking to customer.case. Business justification: Field quality reporting process: automotive OEMs link defect records to customer cases (warranty complaints) for 8D reporting and warranty cost tracking. A quality engineer would immediately expect to']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Defects resolved through engineering change orders (ECOs) must be linked to the implementing change — standard 8D Step 5 (permanent corrective action). Quality managers track which ECO closed a defect']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: A defect record should reference the control plan under which the defect was detected. This enables analysis of which control plans are failing to prevent defects, supporting IATF 16949 control plan e']
  dealer_repair_order_id varchar [note: 'Foreign key linking to dealer.dealer_repair_order. Business justification: Warranty defect analysis and repeat repair tracking (8D investigations) require linking defect records to the dealer repair order that surfaced the defect. Core automotive warranty quality process — O']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Defect records are frequently generated from dealer warranty claims; linking enables root‑cause analysis and dealer‑specific defect trends.']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: Detected defects are traced to FMEA failure modes for 8D root cause analysis and RPN recalculation — a mandatory AIAG FMEA/APQP requirement. Quality engineers must link defect occurrences to the origi']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: A defect record is frequently raised as a result of a failed inspection lot. Linking defect_record to the originating inspection_lot provides full traceability from defect discovery back to the inspec']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Model-level defect tracking supports recall analysis, warranty cost reporting by model, and field service bulletins. Defects may be identified at model level before individual VINs are implicated. Qua']
  ncap_test_result_id varchar [note: 'Foreign key linking to quality.ncap_test_result. Business justification: A defect record can be raised as a result of a failed NCAP or regulatory safety test. Linking defect_record to the originating ncap_test_result enables traceability from safety test failures to the de']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Defect records must reference the canonical part master for root‑cause analysis; removes redundant part_number/name.']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Powertrain-specific defect campaigns (e.g., engine oil consumption, transmission shudder) require defect records scoped to a powertrain variant. Field service engineering teams issue technical service']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Defect records are tied to the specific production order where the defect was detected, essential for the Defect Tracking Dashboard.']
  root_cause_analysis_id boolean [note: 'Foreign key linking to quality.root_cause_analysis. Business justification: A defect record should directly reference its root cause analysis record. Currently defect_record has a free-text root_cause STRING column which is a denormalized representation of what should be a st']
  shipment_leg_id varchar [note: 'Foreign key linking to logistics.shipment_leg. Business justification: Carrier liability claims for transport damage require attributing defects to the specific shipment leg (e.g., sea vs. final truck delivery). Automotive damage claim processes and carrier scorecards de']
  sku_master_id varchar [note: 'Identifier of the part or component associated with the defect.']
  spc_chart_id varchar [note: 'Foreign key linking to quality.spc_chart. Business justification: A defect record can be triggered by an SPC out-of-control signal. Linking defect_record to the spc_chart that detected the process deviation enables SPC-driven defect traceability and supports OCAP (O']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Defect records in automotive manufacturing must trace to the specific vehicle build where the defect was found. This enables build-level quality history, end-of-line defect traceability, and VIN-speci']
  vehicle_compound_id varchar [note: 'Foreign key linking to logistics.vehicle_compound. Business justification: Defects originating during compound storage (weather damage, handling damage, vandalism) must be attributed to the specific compound for insurance claims, compound operator accountability, and compoun']
  vehicle_handover_id varchar [note: 'Foreign key linking to logistics.vehicle_handover. Business justification: Defects discovered at vehicle handover (PDI punch list, delivery damage) are a core automotive quality process. Linking defect records to the handover event enables PDI defect rate KPIs, handover qual']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Defect records are tied to a specific VIN; FK to vin_registry allows traceability from defect to exact vehicle for warranty and recall actions.']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: Defects are detected and attributed to specific work centers/stations. This enables station-level defect rate analysis, Pareto charts by work center, and targeted process improvement — a standard auto']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  containment_action varchar [note: 'Immediate action taken to contain the defect and prevent further impact.']
  corrective_action varchar [note: 'Planned or executed action to eliminate the root cause of the defect.']
  corrective_action_due_date date [note: 'Target date by which the corrective action must be completed.']
  created_timestamp timestamp [note: 'Timestamp when the defect record was initially created in the system.']
  defect_category varchar [note: 'Stage of the product lifecycle where the defect was detected.']
  defect_code varchar [note: 'Business identifier code assigned to the defect for tracking and reporting.']
  defect_description varchar [note: 'Detailed textual description of the non‑conformance or quality issue.']
  defect_record_status varchar [note: 'Current lifecycle status of the defect record.']
  defect_type varchar [note: 'Classification of the defect by its origin or nature.']
  detected_timestamp timestamp [note: 'Date and time when the defect was first observed.']
  detection_method varchar [note: 'Method or channel through which the defect was discovered.']
  disposition varchar [note: 'Final disposition of the defective item after evaluation.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  investigation_end_timestamp timestamp [note: 'Timestamp when the investigation was concluded.']
  investigation_start_timestamp timestamp [note: 'Timestamp when the root‑cause investigation began.']
  is_repeat_defect boolean [note: 'Flag indicating whether this defect has been observed previously.']
  location_zone varchar [note: 'Vehicle zone or assembly area where the defect was identified (e.g., body, powertrain).']
  ppm_rate decimal(10,4) [note: 'Defect rate expressed in parts per million for quality metrics.']
  quantity_affected varchar [note: 'Number of units or parts impacted by the defect.']
  severity varchar [note: 'Severity level indicating impact on safety, performance, or compliance.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the defect record.']
  vin varchar [note: 'VIN of the vehicle in which the defect was found.']

  Note: 'Operational record of a quality defect or non-conformance identified at any stage — incoming material, in-process assembly, final inspection, or field. Captures defect code, defect description, location on vehicle (zone/component), severity classification, detection method, quantity affected, containment action taken, and disposition (rework, scrap, use-as-is). Sourced from Apriso/Dassault MES quality control module.'
}

Table quality.spc_chart {
  spc_chart_id varchar [pk, note: 'System‑generated unique identifier for the SPC chart configuration record.']
  characteristic_id varchar [note: 'Foreign key linking to quality.characteristic. Business justification: An SPC chart monitors a specific Critical-to-Quality (CTQ) characteristic. Currently spc_chart has a ctq_characteristic STRING column which is a denormalized text reference to what should be a structu']
  control_plan_id varchar [note: 'Foreign key linking to quality.control_plan. Business justification: An SPC chart is defined and governed within the context of a control plan. The control plan specifies which characteristics require SPC monitoring, the control limits, and the sampling frequency. Link']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: SPC charts monitor process variation for specific parts. Linking spc_chart to part_master enables part-level SPC history retrieval for PPAP submissions, supplier quality scorecards, and process capabi']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: SPC charts monitor key characteristics of each work center; required for the Work Center SPC Dashboard.']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  approval_timestamp timestamp [note: 'Date‑time when the SPC chart configuration was formally approved.']
  center_line decimal(12,4) [note: 'Target center line (mean) for the SPC chart.']
  chart_name varchar [note: 'Human‑readable name identifying the SPC chart for a specific CTQ characteristic.']
  chart_type varchar [note: 'Type of SPC chart used to monitor the characteristic (e.g., X‑bar/R, p‑chart).']
  confidence_level decimal(5,2) [note: 'Statistical confidence level applied when setting control limits, expressed as a percentage.']
  control_limit_lcl decimal(12,4) [note: 'Statistical lower control limit for the chart, calculated from process data.']
  control_limit_ucl decimal(12,4) [note: 'Statistical upper control limit for the chart, calculated from process data.']
  created_timestamp timestamp [note: 'Date‑time when the SPC chart record was first created in the system.']
  data_source_system varchar [note: 'System of record that supplies the raw measurement data for the SPC chart.']
  description varchar [note: 'Free‑form description providing additional context for the chart.']
  effective_from date [note: 'Date from which the SPC chart configuration becomes valid.']
  effective_until date [note: 'Date after which the SPC chart configuration is no longer valid (null if open‑ended).']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  measurement_unit varchar [note: 'Unit of measure for the monitored characteristic (e.g., mm, psi). [ENUM-REF-CANDIDATE: mm|cm|mmHg|psi|rpm|kg|%|mm/s — 8 candidates stripped; promote to reference product]']
  notes varchar [note: 'Optional free‑text field for any extra information or remarks.']
  ocap varchar [note: 'Defined actions to be taken when the chart signals an out‑of‑control condition.']
  process_step varchar [note: 'Descriptive name of the manufacturing process step where the SPC chart is applied.']
  process_step_code varchar [note: 'Internal code identifying the process step (e.g., ASSEMBLY_01).']
  sample_count varchar [note: 'Total number of samples used to compute the chart\'s control limits.']
  sampling_frequency varchar [note: 'Frequency at which samples are taken for the SPC chart.']
  spc_chart_status varchar [note: 'Current lifecycle status of the SPC chart configuration.']
  statistical_method varchar [note: 'Statistical technique used to calculate control limits (e.g., Shewhart, EWMA).']
  subgroup_size varchar [note: 'Number of units in each sampling subgroup used for chart calculations.']
  target_value decimal(12,4) [note: 'Desired target value for the characteristic (center line target).']
  tolerance_lower decimal(12,4) [note: 'Lower acceptable tolerance bound for the characteristic.']
  tolerance_upper decimal(12,4) [note: 'Upper acceptable tolerance bound for the characteristic.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the SPC chart record.']
  version_number varchar [note: 'Version identifier for the chart configuration, incremented on changes.']

  Note: 'Statistical Process Control chart master record defining the SPC monitoring configuration for a critical-to-quality (CTQ) characteristic at a specific process step. Specifies chart type (X-bar/R, X-bar/S, p-chart, c-chart), control limits (UCL, LCL), center line, subgroup size, sampling frequency, and out-of-control action plan (OCAP). Supports IATF 16949 SPC requirements.'
}

Table quality.corrective_action {
  corrective_action_id varchar [pk, note: 'Primary key']
  apqp_plan_id varchar
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: Corrective actions (8D reports) are formally issued to carriers for transport damage in automotive. quality_corrective_action has supply_supplier_id for supplier CAPAs but no carrier_id for carrier CA']
  case_id varchar [note: 'Foreign key linking to customer.case. Business justification: Customer complaint resolution process: corrective actions raised in response to customer cases must be traceable to the originating case for warranty cost reporting, customer satisfaction tracking, an']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Permanent corrective actions in 8D are implemented via engineering change orders. Linking quality_corrective_action to the engineering change that executes the fix is required for closed-loop quality ']
  control_plan_id varchar
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: OEM dealer quality audits and PDI non-conformance management require corrective actions issued directly to specific dealerships. Dealer-specific corrective action reporting and franchise compliance tr']
  defect_record_id varchar [note: 'FK to defect record']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: A corrective action is frequently triggered by a failed inspection lot. Linking quality_corrective_action to the originating inspection_lot provides the operational context for the corrective action —']
  ncap_test_result_id varchar [note: 'Foreign key linking to quality.ncap_test_result. Business justification: A corrective action can be initiated in response to a failed NCAP or regulatory safety test result. Linking quality_corrective_action to ncap_test_result enables traceability from safety test failures']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns mandate specific corrective actions as the remedy. Compliance teams track which corrective actions fulfill recall remedy obligations to report completion rates to regulatory bodies (N']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Corrective actions in automotive are frequently triggered by regulatory non-conformance findings (e.g., emissions exceedance, safety standard violation). Linking corrective actions to the specific reg']
  root_cause_analysis_id boolean
  spc_chart_id varchar [note: 'Foreign key linking to quality.spc_chart. Business justification: A corrective action can be triggered by an SPC out-of-control condition. Linking quality_corrective_action to the spc_chart that triggered the OCAP enables SPC-driven corrective action traceability. T']
  supplier_id varchar
  supplier_scorecard_id varchar [note: 'Foreign key linking to supply.supplier_scorecard. Business justification: Supplier development process: poor scorecard performance (low PPM, OTD, quality scores) formally triggers corrective action requests. Linking the corrective action to the scorecard that triggered it e']
  action_description varchar
  action_number varchar [note: 'Corrective action number']
  action_status varchar [note: 'Action status']
  action_type varchar [note: 'Action type (8D, CAPA, etc.)']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  closed_date date
  closure_date date [note: 'Closure date']
  completion_date date
  containment_action varchar [note: 'Containment action taken']
  corrective_action varchar
  corrective_action_number varchar
  cost_of_action decimal(18,2)
  created_timestamp timestamp [note: 'Record creation timestamp']
  description varchar [note: 'Corrective action description']
  due_date date [note: 'Due date']
  effectiveness_check_date date
  effectiveness_status varchar
  effectiveness_verification varchar
  effectiveness_verified boolean [note: 'Effectiveness verified flag']
  effectiveness_verified_flag boolean
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  is_effective boolean
  is_eight_d_flag boolean
  is_recurring boolean
  notes varchar
  opened_date date
  preventive_action varchar
  preventive_action_description varchar [note: 'Preventive action description']
  priority varchar
  problem_description varchar
  quality_corrective_action_status varchar
  raised_date date
  root_cause varchar
  root_cause_description varchar [note: 'Root cause description']
  severity varchar
  title varchar
  updated_timestamp timestamp [note: 'Last update timestamp']
  verification_date date
  verification_method varchar
  verification_status varchar

  Note: 'Corrective and Preventive Action (CAPA) record managing the structured problem-solving process for quality escapes and non-conformances. Supports 8D (Eight Disciplines) and 5-Why methodologies. Captures problem statement, containment actions (D3), root cause analysis (D4/5-Why), permanent corrective actions (D5), verification of effectiveness (D6), and preventive action deployment (D7). Tracks open/closed status and due dates.'
}

Table quality.ncap_test_result {
  ncap_test_result_id varchar [pk, note: 'System-generated unique identifier for the NCAP test result record.']
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: NCAP test results are directly tied to the APQP plan governing the vehicle program\'s quality planning. NCAP testing is a key validation gate in the APQP process, and linking ncap_test_result to the go']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: NCAP and homologation testing (Euro NCAP, NHTSA) is conducted on a specific vehicle BOM configuration. Regulators require traceability between test results and the exact product configuration tested. ']
  change_id varchar [note: 'Identifier of the engineering change (ECN) associated with the vehicle configuration.']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: NCAP homologation tests are conducted on a specific vehicle configuration (exact powertrain, trim, market spec). Regulatory submissions require traceability from test result to the exact configuration']
  fmvss_certification_id varchar [note: 'Foreign key linking to compliance.fmvss_certification. Business justification: FMVSS certifications (US market) require crash and safety test evidence. NCAP test results are the specific test records that substantiate FMVSS certification filings. Compliance engineers reference e']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: NCAP test results are primary evidence in the homologation dossier for type-approval. Compliance and quality teams jointly manage the homologation submission using NCAP data. A quality engineer and ho']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: NCAP ratings are published and tracked per vehicle model for marketing, homologation, and regulatory compliance reporting. Quality and product teams query NCAP results by model to support safety certi']
  primary_ncap_vehicle_vin_registry_id varchar [note: 'Internal surrogate key for the vehicle under test.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: NCAP tests are conducted to satisfy specific regulatory requirements (UNECE R94, FMVSS 208, etc.). Linking each test result to the regulatory requirement it validates is standard homologation traceabi']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  compliance_status varchar [note: 'Overall compliance determination against applicable safety regulations.']
  created_timestamp timestamp [note: 'Timestamp when the test result record was first created in the data lake.']
  data_source_system varchar [note: 'Source system that supplied the test result data.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  homologation_status varchar [note: 'Regulatory approval status of the vehicle based on the test outcome.']
  rating_scale varchar [note: 'Scale definition used for the star rating (e.g., 5‑star).']
  raw_score_front decimal(5,2) [note: 'Raw numeric score for the frontal offset impact test.']
  raw_score_pole decimal(5,2) [note: 'Raw numeric score for the pole impact test.']
  raw_score_side decimal(5,2) [note: 'Raw numeric score for the side impact test.']
  star_rating varchar [note: 'Overall star rating assigned by the NCAP program (0‑5).']
  test_comments varchar [note: 'Free‑text notes captured by the test team.']
  test_condition varchar [note: 'Environmental and operational conditions during the test (e.g., temperature, humidity).']
  test_configuration varchar [note: 'Detailed configuration of the vehicle for the test (e.g., seat position, restraint settings).']
  test_date date [note: 'Calendar date on which the crash test was performed.']
  test_facility varchar [note: 'Name of the laboratory or proving ground where the test took place.']
  test_observer varchar [note: 'Name of the independent observer or auditor present during testing.']
  test_program varchar [note: 'The NCAP program under which the vehicle was tested.']
  test_report_number varchar [note: 'External reference number assigned by the testing authority for the test report.']
  test_result_status varchar [note: 'Lifecycle status of the test result record.']
  test_type varchar [note: 'Category of crash test performed.']
  test_version varchar [note: 'Version identifier of the test protocol used.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the test result record.']
  vehicle_vin varchar [note: 'Globally unique vehicle identifier used to link the test result to a specific vehicle.']

  Note: 'New Car Assessment Programme (NCAP) and regulatory crash/safety test result record for a vehicle model variant. Captures test program (Euro NCAP, NHTSA, ANCAP), test date, test facility, vehicle configuration tested, test type (frontal offset, side impact, pole test, pedestrian, AEB), raw scores, star ratings, and homologation status. Supports regulatory compliance and product safety reporting.'
}

Table quality.characteristic {
  characteristic_id varchar [pk, note: 'Primary key for characteristic']
  parent_characteristic_id varchar [note: 'Self-referencing FK on characteristic (parent_characteristic_id)']
  product_bom_line_id varchar [note: 'Foreign key linking to product.product_bom_line. Business justification: APQP/PPAP requires critical and significant characteristics to be assigned to specific BOM component positions. Linking characteristic to product_bom_line enables the quality team to identify which BO']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  category varchar [note: 'Broad classification of the characteristic within quality domains.']
  characteristic_status varchar [note: 'Current lifecycle status of the characteristic.']
  created_by_user varchar [note: 'User identifier who initially created the characteristic record.']
  created_timestamp timestamp [note: 'Timestamp when the characteristic record was first created.']
  criticality_level varchar [note: 'Business impact rating of the characteristic on product quality.']
  data_type varchar [note: 'Data type of the characteristic\'s measured value.']
  description varchar [note: 'Detailed description of what the characteristic measures or represents.']
  effective_from date [note: 'Date when the characteristic becomes valid for use.']
  effective_until date [note: 'Date when the characteristic is retired or superseded (nullable).']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  frequency varchar [note: 'How often the characteristic is measured or evaluated.']
  measurement_method varchar [note: 'Technique used to capture the characteristic value.']
  measurement_unit varchar [note: 'Unit of measure associated with the characteristic (e.g., mm, kg, sec).']
  name varchar [note: 'Human‑readable name of the quality characteristic.']
  notes varchar [note: 'Free‑form comments or observations about the characteristic.']
  target_value decimal(12,4) [note: 'Target or nominal value that the characteristic should achieve.']
  tolerance_lower decimal(12,4) [note: 'Maximum acceptable deviation below the target value.']
  tolerance_upper decimal(12,4) [note: 'Maximum acceptable deviation above the target value.']
  updated_by_user varchar [note: 'User identifier who last modified the characteristic record.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the characteristic record.']

  Note: 'Master reference table for characteristic. Referenced by characteristic_id.'
}

Table quality.root_cause_analysis {
  root_cause_analysis_id boolean [pk, note: 'Primary key for root_cause_analysis']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: Root cause analyses reference FMEA failure modes as input and feed back updated RPN scores — explicitly required by AIAG FMEA 4th edition and IATF 16949. Quality engineers must link RCA findings to th']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: A root cause analysis is frequently initiated based on findings from an inspection lot (e.g., incoming material rejection, in-process quality gate failure). Linking root_cause_analysis directly to the']
  parent_root_cause_analysis_id boolean [note: 'Self-referencing FK on root_cause_analysis (related_root_cause_analysis_id)']
  actual_resolution_date date [note: 'Date on which the corrective action was actually completed.']
  ai_inspection_flag boolean [note: 'Whether AI/ML computer vision was used in this quality process']
  category varchar [note: 'High‑level classification of the root cause source.']
  code varchar [note: 'Business identifier or code used to reference the root cause in reports and work orders.']
  corrective_action_owner varchar [note: 'Person or team accountable for executing the corrective action plan.']
  corrective_action_plan varchar [note: 'Planned corrective actions to eliminate or mitigate the root cause.']
  created_timestamp timestamp [note: 'Timestamp when the root cause analysis record was first created.']
  description varchar [note: 'Detailed narrative describing the root cause, its symptoms, and context.']
  detection_phase varchar [note: 'Process phase in which the root cause was first detected.']
  effective_from date [note: 'Date from which the root cause analysis definition becomes active.']
  effective_until date [note: 'Date after which the root cause analysis definition is retired (nullable).']
  failure_mode varchar [note: 'Specific failure mode linked to the root cause (e.g., "Crack in chassis").']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  impact_description varchar [note: 'Narrative of the business or safety impact caused by the root cause.']
  name varchar [note: 'Human‑readable name of the root cause (e.g., "Incorrect Torque Specification").']
  occurrence_phase varchar [note: 'Process phase where the root cause actually occurred.']
  owner varchar [note: 'Name of the person or team responsible for investigating and resolving the root cause.']
  priority varchar [note: 'Business priority assigned to address the root cause.']
  risk_rating varchar [note: 'Overall risk rating associated with the root cause.']
  root_cause_analysis_status varchar [note: 'Current lifecycle status of the root cause analysis.']
  root_cause_analysis_type varchar [note: 'Indicates whether the cause is systemic, occasional, or a one‑off event.']
  severity_level varchar [note: 'Numeric rating (1‑5) of the impact severity of the root cause on product quality.']
  target_resolution_date date [note: 'Planned date by which the corrective action should be completed.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the root cause analysis record.']
  verification_method varchar [note: 'Method used to verify that the corrective action resolved the root cause.']
  verification_result varchar [note: 'Outcome of the verification activity.']

  Note: 'Master reference table for root_cause_analysis. Referenced by root_cause_analysis_id.'
}

Table quality.control_plan_characteristic {
  control_plan_characteristic_id varchar [pk, note: 'Primary key for the control_plan_characteristic association']
  characteristic_id varchar [note: 'Foreign key linking to the quality characteristic being controlled by this line item.']
  control_plan_id varchar [note: 'Foreign key linking to the parent quality control plan that contains this line item.']
  control_method varchar [note: 'Statistical or inspection method used to control this characteristic within this specific control plan (e.g., SPC, attribute gauge, visual, CMM). Varies per plan-characteristic combination.']
  lower_spec_limit decimal [note: 'Minimum acceptable value for this characteristic as enforced by this control plan. May be tightened relative to the engineering drawing limit at intermediate process stages.']
  measurement_system varchar [note: 'The measurement system or gauge type used to evaluate this characteristic within this control plan (e.g., CMM, go/no-go gauge, vision system). Varies by process stage.']
  measurement_unit varchar [note: 'Unit of measure for this characteristic measurement within this control plan context (e.g., mm, psi, Nm). Moved from control_plan header as it is characteristic-specific.']
  process_step_sequence varchar [note: 'Ordinal position of this characteristic within the control plan, representing the process step sequence number as defined in the APQP control plan document.']
  reaction_plan varchar [note: 'Defined corrective actions to be taken if this characteristic falls outside specification limits within this control plan context. Stage-specific reaction plans differ across manufacturing stages.']
  sample_frequency varchar [note: 'Frequency at which this characteristic is sampled within this control plan (e.g., every 2 hours, every 50 parts). Stage-specific and may differ across plans for the same characteristic.']
  sample_size varchar [note: 'Number of units inspected per sampling event for this characteristic as defined within this control plan. May differ from the plan-level default.']
  target_value decimal [note: 'Desired nominal value for this characteristic as specified within this control plan. Moved from control_plan header as it is characteristic-specific within each plan.']
  upper_spec_limit decimal [note: 'Maximum acceptable value for this characteristic as enforced by this control plan. May be tightened relative to the engineering drawing limit at intermediate process stages.']

  Note: 'This association product represents the Control Plan Line Item — the operational record defined by AIAG APQP that links a specific quality control plan to a specific characteristic at a given process step. Each record captures how that characteristic is controlled within the context of that plan, including the control method, sampling regime, specification limits, and reaction plan applicable to that plan-characteristic combination. This is a core IATF 16949 deliverable actively created, reviewed, and updated by quality engineers during APQP and production launches.. Existence Justification: In automotive APQP/IATF 16949 practice, a control plan is explicitly a characteristic-level document where each line item represents a specific characteristic monitored at a specific process step. One control plan covers many characteristics (e.g., a door assembly control plan monitors torque, gap, flush, paint thickness), and one characteristic (e.g., a critical weld diameter) is actively controlled by multiple control plans across different manufacturing stages (e.g., sub-assembly CP, final assembly CP, outgoing inspection CP). The business actively creates, updates, and deletes these plan-characteristic line items as part of APQP deliverables, and each combination carries its own control method, sample size, reaction plan, and spec limits that differ per plan-characteristic pairing.'
}

Table logistics.shipment {
  shipment_id varchar [pk, note: 'System-generated unique identifier for each outbound vehicle shipment.']
  carrier_id varchar [note: 'System identifier for the carrier entity.']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Required for Shipment Delivery Performance Report linking each shipment to its destination dealership; enables OTD and cost tracking per dealer.']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: Vehicles cannot legally be shipped to a market without valid type approval/homologation for that market. Logistics teams must verify homologation status before releasing a shipment; linking shipment t']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Shipments crossing international borders are governed by the destination/origin jurisdiction\'s customs, dangerous goods, and import/export regulations. Customs clearance and regulatory compliance repo']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: A shipment moves along a specific logistics lane (origin-destination pair). shipment has origin_location and destination_location (free-text strings) but no FK to lane. Adding lane_id normalizes the r']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Order fulfillment shipping links each shipment to its originating production order for traceability and cost accounting.']
  purchase_order_id varchar [note: 'Foreign key linking to supply.supply_purchase_order. Business justification: Inbound shipments in automotive are triggered by supply purchase orders. Linking shipment to supply PO enables 3-way matching (PO-GR-freight invoice), inbound freight cost allocation to PO, and inboun']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Automotive OEMs issue shipment holds when an active recall campaign covers the VINs/models being transported. Logistics operations must link shipments to recall campaigns to execute hold, reroute, or ']
  service_center_id varchar [note: 'Foreign key linking to aftersales.service_center. Business justification: Parts shipment delivery routing to service center: parts shipments are delivered to specific service centers (distinct from dealerships — one dealership may have multiple service centers). Required fo']
  stock_transfer_order_id varchar [note: 'Foreign key linking to inventory.stock_transfer_order. Business justification: Inter-plant parts replenishment: stock transfer orders trigger physical shipments for parts movements between plants. Linking shipment to STO enables supply chain planners to reconcile planned transfe']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Required for Shipment Planning Report to allocate vehicles by program; logistics teams need program context for routing and dealer allocation.']
  vin_registry_id varchar [note: 'Identifier of the truck, rail car, or vessel used for the shipment.']
  actual_arrival_timestamp timestamp [note: 'Real timestamp when the shipment was received at the destination.']
  actual_departure_timestamp timestamp [note: 'Real timestamp when the shipment left the origin plant.']
  compliance_status varchar [note: 'Current compliance verification result for the shipment.']
  container_number varchar [note: 'Standard container identification number when applicable.']
  created_timestamp timestamp [note: 'Timestamp when the shipment record was first created in the lakehouse.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary amounts.']
  customs_document_number varchar [note: 'Reference number for customs clearance documents.']
  dangerous_goods_class varchar [note: 'Primary dangerous goods hazard class if applicable']
  dangerous_goods_un_number varchar [note: 'UN number for dangerous goods in this shipment']
  delay_reason varchar [note: 'Explanation for any delay beyond the planned arrival.']
  destination_location varchar [note: 'Geographic location (city) of the destination dealer or yard.']
  discount_amount decimal(12,2) [note: 'Any discount applied to the freight cost.']
  export_import_flag boolean [note: 'Indicates whether the shipment is an export, import, or domestic movement.']
  freight_cost decimal(12,2) [note: 'Gross transportation cost before discounts or adjustments.']
  hazardous_material_flag boolean [note: 'True if the shipment contains hazardous goods.']
  incoterms_code varchar [note: 'International commercial term governing responsibilities and costs.']
  last_mile_delivery_flag boolean [note: 'Whether this shipment includes a last-mile delivery leg']
  load_type varchar [note: 'Classification of the shipment load.']
  net_cost decimal(12,2) [note: 'Final freight cost after discounts and adjustments.']
  number_of_units varchar [note: 'Count of individual vehicles or kits included in the shipment.']
  origin_location varchar [note: 'Geographic location (city) of the origin plant.']
  origin_plant_code varchar [note: 'Identifier of the manufacturing plant where the shipment originates.']
  otd_flag boolean [note: 'True if the shipment arrived on or before the planned arrival date.']
  planned_arrival_date date [note: 'Estimated date the shipment should arrive at the destination.']
  planned_departure_date date [note: 'Scheduled date for shipment departure from the origin plant.']
  returnable_packaging_count varchar [note: 'Number of returnable packaging units in this shipment']
  shipment_number varchar [note: 'Business-visible shipment number assigned by SAP SD for tracking and reference.']
  shipment_status varchar [note: 'Current lifecycle status of the shipment.']
  temperature_control_flag boolean [note: 'True if the shipment requires temperature‑controlled transport.']
  tracking_url varchar [note: 'Web link to real‑time shipment tracking information.']
  transport_mode varchar [note: 'Mode of transportation used for the shipment.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the shipment record.']
  vin_list varchar [note: 'List of VINs for all vehicles in the shipment, separated by commas.']
  volume_cbm decimal(12,2) [note: 'Total cargo volume of the shipment in cubic meters.']
  weight_kg decimal(12,2) [note: 'Gross weight of the shipment in kilograms.']

  Note: 'Core master record for each outbound vehicle shipment from plant to dealer or distribution point. Captures shipment origin (plant/compound), destination (dealer/port/yard), transport mode (rail, truck, vessel, CKD/SKD), shipment status, planned and actual departure/arrival dates, OTD tracking, and associated VINs. Primary operational entity for finished vehicle logistics. Sourced from SAP SD outbound delivery and MES traceability.'
}

Table logistics.shipment_leg {
  shipment_leg_id varchar [pk, note: 'Unique surrogate key for each shipment leg record.']
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: Multi‑modal shipment leg tracking requires a FK to the carrier entity for each leg.']
  goods_movement_id varchar [note: 'Foreign key linking to inventory.goods_movement. Business justification: Enables Shipment Leg Cost Allocation: reconciles each logistics leg with the corresponding inventory goods movement for cost analysis.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Each shipment leg may traverse a different jurisdiction with distinct customs rules (evidenced by per-leg customs_status and customs_document_number). Regulatory reporting and customs clearance requir']
  stock_transfer_order_id varchar [note: 'Foreign key linking to inventory.stock_transfer_order. Business justification: Parts logistics execution: individual shipment legs fulfill specific stock transfer orders for inter-plant parts movements. This link supports leg-level STO fulfillment tracking, cost allocation per t']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Allows detailed Shipment Leg analysis tying each leg to the VIN master record for emissions, fuel consumption, and compliance reporting.']
  actual_arrival_timestamp timestamp [note: 'Real‑time arrival date‑time recorded by carrier or IoT device.']
  actual_departure_timestamp timestamp [note: 'Real‑time departure date‑time recorded by carrier or IoT device.']
  container_code varchar [note: 'Identifier of the shipping container or trailer used for the leg.']
  cost_amount decimal(12,2) [note: 'Monetary cost incurred for this leg (freight, duty, handling, etc.).']
  cost_currency varchar [note: 'Three‑letter ISO 4217 currency code for the leg cost.']
  cost_type varchar [note: 'Category of cost represented by cost_amount.']
  created_timestamp timestamp [note: 'Timestamp when the shipment leg record was created in the system.']
  customs_document_number varchar [note: 'Reference number of the customs clearance document for cross‑border legs.']
  customs_status varchar [note: 'Current status of customs clearance for the leg.']
  dangerous_goods_declaration_number varchar [note: 'Dangerous goods declaration document number for this leg']
  delay_reason varchar [note: 'Free‑text description of why a leg is delayed, if applicable.']
  distance_km decimal(10,2) [note: 'Physical distance covered in this leg, measured in kilometers.']
  emissions_kg_co2 decimal(10,2) [note: 'Estimated carbon dioxide emissions for the leg.']
  fuel_consumption_liters decimal(10,2) [note: 'Total fuel used by the vehicle during the leg.']
  handling_instructions varchar [note: 'Special handling notes for the cargo on this leg.']
  hazardous_material_flag boolean [note: 'True if the leg carries hazardous materials.']
  hazardous_material_type varchar [note: 'Classification of hazardous material (e.g., flammable, corrosive).']
  leg_sequence varchar [note: 'Ordinal position of the leg within the multi‑modal shipment.']
  leg_status varchar [note: 'Current operational status of the leg.']
  load_type varchar [note: 'Classification of cargo load for the leg.']
  odometer_end varchar [note: 'Vehicle odometer reading at the end of the leg (kilometers).']
  odometer_start varchar [note: 'Vehicle odometer reading at the start of the leg (kilometers).']
  planned_arrival_timestamp timestamp [note: 'Scheduled arrival date‑time for the leg.']
  planned_departure_timestamp timestamp [note: 'Scheduled departure date‑time for the leg.']
  quantity varchar [note: 'Number of individual vehicles or units moved in this leg.']
  returnable_packaging_manifest varchar [note: 'Reference to returnable packaging manifest for this leg']
  seal_number varchar [note: 'Security seal identifier applied to containers or trailers.']
  temperature_control_required boolean [note: 'Indicates whether the cargo requires temperature‑controlled transport.']
  temperature_max_c decimal(5,2) [note: 'Maximum temperature setting for the leg when temperature control is required.']
  temperature_min_c decimal(5,2) [note: 'Minimum temperature setting for the leg when temperature control is required.']
  tracking_number varchar [note: 'Carrier‑provided tracking identifier for the leg.']
  transport_mode varchar [note: 'Mode of transport used for this leg (e.g., truck, rail, ship, air, pipeline).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the shipment leg record.']
  volume_cubic_meters decimal(10,3) [note: 'Total cargo volume for the leg, measured in cubic meters.']
  weight_tons decimal(10,3) [note: 'Total weight of cargo transported on this leg, expressed in metric tons.']

  Note: 'Individual transport leg within a multi-modal shipment, representing a discrete movement segment (e.g., plant to rail yard, rail yard to port, port to dealer compound). Tracks leg sequence, transport mode, carrier assignment, origin/destination facility, planned and actual departure/arrival timestamps, distance, leg-level status, and mode-specific details (rail car number/type for rail legs, vessel name/IMO/voyage for ocean legs). After merges, this product also carries rail car assignment details and vessel voyage references for their respective transport modes. Enables end-to-end multi-modal visibility for each VIN or batch.'
}

Table logistics.vehicle_transport_order {
  vehicle_transport_order_id varchar [pk, note: 'Primary key for vehicle_transport_order']
  carrier_id varchar [note: 'Identifier of the logistics carrier responsible for the shipment.']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Needed for Transport Order Execution Dashboard to associate each order with the receiving dealership; supports dealer‑level on‑time delivery metrics.']
  fleet_account_id varchar [note: 'Foreign key linking to customer.customer_fleet_account. Business justification: Fleet customers place bulk vehicle transport orders under negotiated fleet accounts with specific SLAs, billing terms, and discount tiers. Linking transport orders to the fleet account enables fleet b']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Vehicle transport orders for cross-border moves require jurisdiction-specific customs declarations, cabotage compliance, and dangerous goods regulations. compliance_regulation_code is a denormalized j']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: A vehicle transport order is issued for movement on a specific logistics lane (origin-destination pair). vehicle_transport_order has origin_compound (STRING) and distance_km but no FK to lane. Adding ']
  plant_id varchar [note: 'Identifier of the manufacturing plant where the vehicles are shipped from.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Production completion triggers transport order: when a production_order is completed, a vehicle_transport_order is created for outbound delivery. Direct FK enables production-to-logistics handoff repo']
  production_schedule_id varchar [note: 'Foreign key linking to manufacturing.production_schedule. Business justification: Production schedule drives outbound transport capacity planning: transport orders are created in alignment with confirmed production schedules to ensure carrier and lane availability. Direct FK enable']
  shipment_id varchar [note: 'Foreign key linking to logistics.shipment. Business justification: A transport order represents the execution of a shipment; linking it to the parent shipment enables traceability of cost and status.']
  vehicle_allocation_id varchar [note: 'Foreign key linking to dealer.vehicle_allocation. Business justification: Transport execution against dealer allocation: a VTO is created to physically move allocated vehicles to a dealer. Linking VTO to vehicle_allocation supports on-time delivery measurement against alloc']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Needed for Transport Order Management to group orders by vehicle program, enabling capacity planning and compliance with program launch schedules.']
  actual_arrival_timestamp timestamp [note: 'Timestamp when the shipment was actually received at the destination.']
  carrier_contact varchar [note: 'Primary phone number for the carrier\'s dispatch desk.']
  confirmed_pickup_date date [note: 'Date the carrier confirmed for vehicle pickup.']
  container_type varchar [note: 'Type of container or trailer used for the shipment (e.g., flatbed, container, roll‑on/roll‑off).']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency used for the transport cost.']
  customs_declaration_number varchar [note: 'Identifier of the customs declaration for cross‑border shipments.']
  delivery_date date [note: 'Planned date for delivery to the destination dealer.']
  distance_km decimal(8,2) [note: 'Total distance in kilometers for the shipment route.']
  emission_co2_kg decimal(10,2) [note: 'Estimated CO₂ emissions for the shipment based on distance and vehicle type.']
  estimated_arrival_timestamp timestamp [note: 'System‑estimated timestamp when the shipment is expected to arrive at the destination.']
  export_import_flag boolean [note: 'Indicates whether the shipment is an export or import movement.']
  fuel_type varchar [note: 'Dominant fuel type of the vehicles being shipped.']
  is_expedited boolean [note: 'True if the shipment is marked for expedited handling.']
  is_hazardous boolean [note: 'True if the shipment contains hazardous materials requiring special compliance.']
  notes varchar [note: 'Free‑form notes entered by logistics planners.']
  on_time_delivery_flag boolean [note: 'Indicates whether the shipment was delivered within the agreed on‑time window.']
  order_created_timestamp timestamp [note: 'Timestamp when the transport order was initially created in the system.']
  order_number varchar [note: 'External business identifier assigned to the transport order by the logistics system.']
  order_status varchar [note: 'Current lifecycle state of the transport order.']
  origin_compound varchar [note: 'Name of the storage yard or compound where vehicles are staged before pickup.']
  priority varchar [note: 'Business priority assigned to the transport order.']
  record_audit_created timestamp [note: 'Timestamp when this record was first captured for audit purposes.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to this record.']
  requested_pickup_date date [note: 'Date the shipper requested the carrier to pick up the vehicles.']
  shipping_instructions varchar [note: 'Special handling or routing instructions for the carrier.']
  tracking_number varchar [note: 'Tracking number provided by the carrier for real‑time shipment visibility.']
  transport_cost_gross decimal(12,2) [note: 'Total gross cost charged by the carrier before taxes and discounts.']
  transport_cost_net decimal(12,2) [note: 'Net amount payable to the carrier after taxes and discounts.']
  transport_cost_tax decimal(12,2) [note: 'Tax component of the transport cost.']
  transport_mode varchar [note: 'Mode of transportation used for the shipment.']
  vehicle_count varchar [note: 'Number of vehicles included in this transport order.']
  vin_list varchar [note: 'Comma‑separated list of VINs for the vehicles being shipped.']
  weight_tons decimal(8,2) [note: 'Total weight of all vehicles in the shipment.']

  Note: 'Transport order issued to a carrier for the movement of finished vehicles. Captures order number, issuing plant, carrier reference, transport mode, vehicle count, VIN list, origin compound, destination, requested pickup date, confirmed pickup date, and order status. Represents the contractual instruction to move vehicles and is the primary document linking shipments to carrier execution. Sourced from SAP TM or SAP SD.'
}

Table logistics.carrier {
  carrier_id varchar [pk, note: 'System-generated unique identifier for the carrier record.']
  jurisdiction_id varchar
  address_line1 varchar [note: 'First line of the carrier\'s primary business address.']
  address_line2 varchar [note: 'Second line of the carrier\'s primary business address (optional).']
  average_cost_per_mile decimal(18,2) [note: 'Average transportation cost incurred per mile for this carrier.']
  average_on_time_delivery_pct decimal(5,2) [note: 'Average percentage of shipments delivered on or before the promised delivery date.']
  carrier_status varchar [note: 'Current operational status of the carrier within the logistics network.']
  carrier_type varchar [note: 'Business classification of the carrier entity.']
  city varchar [note: 'City of the carrier\'s primary business address.']
  contact_email varchar [note: 'Email address for the carrier\'s primary contact.']
  contact_name varchar [note: 'Name of the primary contact person for the carrier.']
  contact_phone varchar [note: 'Telephone number for the carrier\'s primary contact.']
  contract_end_date date [note: 'Expiration date of the carrier\'s master service agreement (null if open‑ended).']
  contract_reference varchar [note: 'External reference identifier for the carrier\'s master service agreement.']
  contract_start_date date [note: 'Effective start date of the carrier\'s master service agreement.']
  country varchar [note: 'Three‑letter ISO country code of the carrier\'s primary business address.']
  created_timestamp timestamp [note: 'Date and time when the carrier record was first created in the system.']
  effective_from date [note: 'Date from which the carrier record is considered active for reporting.']
  effective_until date [note: 'Date after which the carrier record is no longer active (null if indefinite).']
  environmental_certification varchar [note: 'Environmental compliance certifications held by the carrier.']
  equipment_type varchar [note: 'Main type of equipment the carrier uses for shipments.']
  field_service_info varchar [note: 'Generic field service info placeholder']
  fleet_size varchar [note: 'Number of transport units (e.g., trucks, railcars) owned or operated by the carrier.']
  iatf_compliance_status varchar [note: 'Current IATF 16949 quality‑management compliance status of the carrier.']
  insurance_policy_number varchar [note: 'Policy number of the carrier\'s liability insurance.']
  insurance_provider varchar [note: 'Name of the insurance company covering the carrier\'s operations.']
  last_audit_date date [note: 'Date of the most recent compliance or safety audit performed on the carrier.']
  name varchar [note: 'Legal name of the transport carrier as registered with authorities.']
  notes varchar [note: 'Free‑form field for any supplemental information about the carrier.']
  operating_regions varchar [note: 'Geographic regions (e.g., continents, countries) where the carrier provides service.']
  performance_rating decimal(3,2) [note: 'Overall performance score (0‑5) derived from on‑time delivery, safety, and cost metrics.']
  postal_code varchar [note: 'Postal/ZIP code of the carrier\'s primary business address.']
  safety_rating varchar [note: 'Safety performance rating based on regulatory audits and incident history.']
  scac_code varchar [note: 'Four‑letter code uniquely identifying the carrier in North American logistics.']
  state varchar [note: 'State or province of the carrier\'s primary business address.']
  tax_identifier varchar [note: 'Government‑issued tax identifier for the carrier.']
  tier varchar [note: 'Strategic tier assigned to the carrier based on volume, reliability, and strategic importance.']
  transport_modes varchar [note: 'Transport modes the carrier is authorized to operate.']
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the carrier record.']
  website varchar [note: 'Public website URL of the carrier.']

  Note: 'Master record for transport carriers (road haulers, rail operators, ocean shipping lines, port logistics providers) engaged for finished vehicle and CKD/SKD kit logistics. Captures carrier legal name, SCAC code, DOT number, transport modes supported, operating regions, contract reference, insurance certificate details, IATF 16949 compliance status, carrier tier classification, and performance rating. SSOT for carrier identity within the logistics domain. Referenced by transport orders, shipment legs, freight invoices, damage claims, and rate contracts.'
}

Table logistics.vehicle_compound {
  vehicle_compound_id varchar [pk, note: 'Unique identifier for the vehicle compound (yard, port, or regional staging area).']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Vehicle compounds must hold environmental permits, dangerous goods storage licenses, and safety certifications issued by the local jurisdiction. Compliance audits and permit renewal tracking require l']
  plant_id varchar
  warehouse_id varchar [note: 'Foreign key linking to inventory.warehouse. Business justification: Vehicle compounds function as specialized warehouses in automotive WMS. Linking compound to warehouse enables unified inventory visibility across compound and warehouse storage, supports capacity repo']
  address_line1 varchar [note: 'Primary street address of the compound.']
  address_line2 varchar [note: 'Secondary address information (e.g., suite, building).']
  average_dwell_time_hours decimal(10,2) [note: 'Average vehicle dwell time in hours']
  capacity_units varchar [note: 'Maximum number of vehicles the compound can store.']
  city varchar [note: 'City where the compound is located.']
  compliance_certifications varchar [note: 'Comma‑separated list of certifications (e.g., ISO‑9001, IATF‑16949) held by the compound.']
  compound_code varchar [note: 'Unique business code used to reference the compound in operational systems.']
  compound_type varchar [note: 'Classification of the compound (e.g., plant yard, port yard, regional distribution center, dealer preparation site).']
  country_code varchar [note: 'Three‑letter ISO country code where the compound resides.']
  covered_slot_count varchar [note: 'Number of covered/indoor slots']
  created_timestamp timestamp [note: 'Timestamp when the compound record was first created in the system.']
  current_occupancy varchar [note: 'Current number of vehicles stored in the compound.']
  dangerous_goods_storage_flag boolean [note: 'Whether compound has dangerous goods storage capability']
  effective_from date [note: 'Date when the compound became operational.']
  effective_until date [note: 'Date when the compound is scheduled to cease operations (null if open‑ended).']
  ev_charging_slot_count varchar [note: 'Number of slots with EV charging capability']
  is_pdi_capable boolean [note: 'Indicates whether the compound can perform Pre‑Delivery Inspection (PDI) on vehicles.']
  last_inspection_date date [note: 'Date of the most recent safety or compliance inspection.']
  latitude decimal(9,6) [note: 'Geographic latitude of the compound (decimal degrees).']
  longitude decimal(9,6) [note: 'Geographic longitude of the compound (decimal degrees).']
  manager_email varchar [note: 'Contact email address for the compound operator/manager.']
  manager_phone varchar [note: 'Contact phone number for the compound operator/manager.']
  name varchar [note: 'Human‑readable name of the storage compound.']
  notes varchar [note: 'Free‑form notes or remarks about the compound.']
  occupied_slot_count varchar [note: 'Current number of occupied slots']
  operator_name varchar [note: 'Name of the person or organization responsible for day‑to‑day operations of the compound.']
  otd_target_percentage decimal(5,2) [note: 'Target percentage for on‑time delivery performance for shipments originating from this compound.']
  postal_code varchar [note: 'Postal/ZIP code of the compound.']
  region_code varchar [note: 'Internal code representing the broader geographic region (e.g., NA, EU, APAC).']
  returnable_packaging_staging_area_flag boolean [note: 'Whether compound has a returnable packaging staging area']
  security_level varchar [note: 'Security classification of the compound (low, medium, high).']
  state_province varchar [note: 'State or province of the compound location.']
  storage_area_sqft decimal(12,2) [note: 'Total floor area of the compound in square feet.']
  temperature_controlled boolean [note: 'Indicates whether the compound maintains temperature‑controlled storage.']
  total_slot_count varchar [note: 'Total number of parking slots in the compound']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the compound record.']
  vehicle_compound_status varchar [note: 'Current operational status of the compound.']
  waste_handling_capability boolean [note: 'Indicates whether the compound is equipped to handle hazardous waste.']
  yard_management_system varchar [note: 'Name of the yard management system in use']

  Note: 'Master record for vehicle storage compounds, yards, and staging areas used in the outbound logistics network (plant yards, rail yards, port compounds, regional distribution centers). Captures compound name, location, type (plant/port/regional/dealer prep), storage capacity (units), current occupancy, operator, PDI capability flag, and compound status. Enables compound capacity planning and in-transit inventory tracking.'
}

Table logistics.compound_movement {
  compound_movement_id varchar [pk, note: 'Surrogate primary key for the compound movement record.']
  carrier_id varchar [note: 'Unique identifier for the carrier.']
  finished_vehicle_stock_id varchar [note: 'Foreign key linking to inventory.finished_vehicle_stock. Business justification: Compound movements directly affect finished vehicle stock records (slot assignment, hold status, PDI completion). Direct FK replaces the plain-text \'vin\' denormalization and enables compound yard mana']
  goods_movement_id varchar [note: 'Foreign key linking to inventory.goods_movement. Business justification: Every compound movement (vehicle slot transfer, PDI staging) triggers a goods movement record for inventory position updates. This link is the standard automotive logistics-inventory integration point']
  vehicle_compound_id varchar [note: 'Foreign key linking to logistics.vehicle_compound. Business justification: Compound movements occur within a vehicle compound; adding vehicle_compound_id links movements to their compound.']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: Compound movements track a specific VIN\'s physical progression (PDI bay, staging, dispatch) within a storage compound. Linking to vehicle_order enables order-to-delivery pipeline visibility, OTD repor']
  vehicle_transport_order_id varchar [note: 'Foreign key linking to logistics.vehicle_transport_order. Business justification: compound_movement.transport_order_number is a denormalized string reference to vehicle_transport_order.order_number. Adding vehicle_transport_order_id FK normalizes this relationship and enables prope']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Compound movement tracks physical yard movements of specific VINs. The plain `vin` text column is a denormalization of vehicle.vin_registry. Yard management, PDI scheduling, and compound occupancy rep']
  actual_arrival_timestamp timestamp [note: 'Recorded arrival time at the destination zone.']
  compound_movement_status varchar [note: 'Current lifecycle status of the movement.']
  created_timestamp timestamp [note: 'Timestamp when the record was first created in the system.']
  delay_minutes varchar [note: 'Minutes of delay between ETA and actual arrival.']
  destination_zone varchar [note: 'Yard or bay where the vehicle is moved to.']
  estimated_arrival_timestamp timestamp [note: 'Expected arrival time at the destination zone.']
  field_service_info varchar [note: 'Generic field service info placeholder']
  from_slot_code varchar [note: 'Slot code the vehicle is moving from']
  is_ota_capable boolean [note: 'Indicates if the vehicle supports over‑the‑air updates.']
  load_quantity varchar [note: 'Number of units moved in this transaction (typically 1).']
  movement_reason varchar [note: 'Reason for the compound movement (optimization, dispatch, PDI, damage_repair)']
  movement_reference varchar [note: 'External reference number used by logistics to identify the movement transaction.']
  movement_timestamp timestamp [note: 'Date and time when the movement event occurred.']
  movement_type varchar [note: 'Indicates whether the vehicle is entering, leaving, or being transferred within the compound.']
  notes varchar [note: 'Free‑text field for additional remarks about the movement.']
  odometer_reading_km varchar [note: 'Vehicle odometer reading at movement time.']
  origin_zone varchar [note: 'Yard or bay where the vehicle originated.']
  priority_level varchar [note: 'Priority assigned to the movement for scheduling purposes.']
  temperature_c decimal(5,2) [note: 'Temperature in the yard at the time of movement.']
  to_slot_code varchar [note: 'Slot code the vehicle is moving to']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  weight_kg decimal(10,2) [note: 'Weight of the vehicle at the time of movement.']

  Note: 'Transactional record of a vehicle\'s physical movement into, within, or out of a compound or yard. Captures VIN, movement type (inbound/outbound/internal transfer), origin bay/zone, destination bay/zone, movement timestamp, operator ID, and associated transport order. Provides granular yard management traceability and supports compound throughput analysis.'
}

Table logistics.in_transit_inventory {
  in_transit_inventory_id varchar [pk, note: 'Surrogate primary key for the in-transit inventory record.']
  carrier_id varchar [note: 'FK to logistics.carrier']
  customer_party_id varchar [note: 'Foreign key linking to customer.party. Business justification: When vehicles are shipped directly to end‑customers, tracking the recipient party is required for delivery confirmation, warranty activation, and service scheduling.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: In-transit inventory subject to customs clearance (evidenced by customs_status, customs_document_number) must be tracked against the governing jurisdiction\'s import rules and dangerous goods regulatio']
  primary_in_dealer_dealership_id varchar [note: 'Identifier of the dealer receiving the vehicle.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: In‑transit inventory reports tie each in‑transit record to its originating production order for cost allocation and visibility.']
  shipment_id varchar [note: 'Unique business identifier for the vehicle shipment.']
  stock_transfer_order_id varchar [note: 'Foreign key linking to inventory.stock_transfer_order. Business justification: In-transit inventory is the physical execution state of a stock transfer order. Linking these enables MRP planners to reconcile open STOs against actual in-transit positions, preventing duplicate repl']
  vehicle_allocation_id varchar [note: 'Foreign key linking to dealer.vehicle_allocation. Business justification: Allocation-to-delivery pipeline tracking: in-transit inventory records vehicles moving toward a dealer destination. Linking to vehicle_allocation enables ETA visibility against allocation commitments,']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: In‑transit inventory status is reported per sales order to provide customers with accurate ETA and inventory visibility.']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Automotive program managers track in-transit parts inventory by vehicle program for launch readiness reporting and supply risk management. Parts are procured and shipped against specific programs; pro']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Needed for Real‑Time In‑Transit Inventory report to associate each inventory record with the master VIN record for compliance and warranty tracking.']
  warehouse_id varchar [note: 'Foreign key linking to inventory.warehouse. Business justification: In-transit inventory tracks goods moving between warehouses. Replacing plain-text origin/destination facility codes with a proper FK to warehouse enables accurate inventory reconciliation reports, war']
  actual_arrival_date date [note: 'Date the vehicle actually arrived at the destination (if arrived).']
  carrier_scac varchar [note: 'Standard carrier code used for tracking and billing.']
  created_timestamp timestamp [note: 'Timestamp when the in‑transit record was first created.']
  current_location varchar [note: 'Last known location of the vehicle while in transit.']
  customs_document_number varchar [note: 'Reference number for customs clearance documentation.']
  customs_status varchar [note: 'Current status of customs processing.']
  days_in_transit varchar [note: 'Number of calendar days the vehicle has been in transit.']
  delay_reason varchar [note: 'Free‑text explanation for any delay affecting the shipment.']
  emissions_kg_co2 decimal(10,2) [note: 'Estimated CO₂ emissions generated during transit.']
  estimated_arrival_date date [note: 'Planned date the vehicle is expected to arrive at the destination.']
  fuel_consumption_liters decimal(10,2) [note: 'Total fuel used during the transit leg.']
  hazardous_material_flag boolean [note: 'True if the shipment contains hazardous material.']
  hazardous_material_type varchar [note: 'Classification of hazardous material, if applicable.']
  last_update_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  load_type varchar [note: 'Classification of how the vehicle is loaded.']
  notes varchar [note: 'Optional free‑form notes related to the in‑transit record.']
  odometer_end_km varchar [note: 'Vehicle odometer reading at the end of the shipment.']
  odometer_start_km varchar [note: 'Vehicle odometer reading at the start of the shipment.']
  seal_number varchar [note: 'Security seal identifier applied to the container or trailer.']
  shipment_leg_count varchar [note: 'Count of individual transport legs in the shipment itinerary.']
  temperature_control_flag boolean [note: 'Indicates whether the shipment requires temperature control.']
  temperature_max_c decimal(5,2) [note: 'Maximum temperature setting for temperature‑controlled shipments.']
  temperature_min_c decimal(5,2) [note: 'Minimum temperature setting for temperature‑controlled shipments.']
  tracking_number varchar [note: 'Carrier‑provided tracking identifier for the shipment.']
  transit_status varchar [note: 'Current operational status of the shipment.']
  transport_cost_amount decimal(12,2) [note: 'Monetary cost incurred for transporting the vehicle.']
  transport_cost_currency varchar [note: 'Three‑letter ISO currency code for the transport cost.']
  transport_mode varchar [note: 'Mode of transportation used for the shipment.']
  volume_cubic_meters decimal(8,3) [note: 'Physical volume occupied by the vehicle or load.']
  weight_tons decimal(8,3) [note: 'Weight of the vehicle or load in metric tons.']

  Note: 'Real-time and point-in-time snapshot of finished vehicles currently in transit between plant and dealer, including vehicles on rail, truck, vessel, or staged at intermediate compounds. Captures VIN, current location (last known compound or leg), transport mode, origin, destination, estimated arrival date, days in transit, and transit status. Critical for dealer allocation visibility and OTD monitoring.'
}

Table logistics.freight_invoice {
  freight_invoice_id varchar [pk, note: 'System-generated unique identifier for the freight invoice record.']
  billing_party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Freight invoices are billed to the end‑customer; associating each invoice with the customer party supports financial reconciliation and compliance reporting.']
  carrier_id varchar [note: 'Unique identifier of the carrier that provided the transport service.']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: freight_invoice.lane_code is a denormalized string reference to lane.lane_code. Freight invoices are for transport on a specific logistics lane (origin-destination pair). Adding lane_id FK normalizes ']
  parts_order_id varchar [note: 'Foreign key linking to aftersales.aftersales_parts_order. Business justification: Parts freight cost reconciliation: freight invoices for parts deliveries to service centers must reference the originating parts order for AP cost allocation, payment reconciliation, and audit complia']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns generate specific freight costs (return logistics, remedy parts delivery, vehicle rerouting) that must be attributed to the recall campaign for warranty cost accounting and OEM reimbu']
  shipment_id varchar [note: 'Foreign key linking to logistics.shipment. Business justification: Freight invoicing ties each invoice to the specific shipment for cost allocation and audit.']
  shipment_leg_id varchar [note: 'Foreign key linking to logistics.shipment_leg. Business justification: In multi-modal logistics, freight invoices are often issued per shipment leg (e.g., separate invoices for road, rail, and ocean legs). freight_invoice already links to shipment (header level) but lack']
  transport_rate_id varchar [note: 'Foreign key linking to logistics.transport_rate. Business justification: A freight invoice should reference the contracted transport rate against which it is being reconciled. freight_invoice.agreed_rate and variance_amount imply comparison to a contracted rate, but there ']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: Freight invoicing is linked to the sales order for full cost‑to‑serve accounting and profitability analysis.']
  vehicle_transport_order_id varchar [note: 'Foreign key linking to logistics.vehicle_transport_order. Business justification: freight_invoice.transport_order_number is a denormalized string reference to vehicle_transport_order.order_number. A freight invoice is issued for services rendered on a specific transport order. Addi']
  agreed_rate decimal(18,2) [note: 'Contracted rate per unit (e.g., per kilometer or per container) agreed with the carrier.']
  approval_status varchar [note: 'Workflow status of the invoice approval process.']
  approved_by varchar [note: 'Identifier of the employee who approved the invoice.']
  approved_timestamp timestamp [note: 'Timestamp when the invoice was approved.']
  attachment_flag boolean [note: 'True if supporting documents (e.g., PDF invoice) are attached to the record.']
  cost_center_code decimal(18,2) [note: 'Internal cost‑center identifier to which the freight cost is charged.']
  cost_type decimal(18,2) [note: 'Classification of the cost element represented by the invoice.']
  created_timestamp timestamp [note: 'Timestamp when the freight invoice record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code of the invoice amount.']
  discount_amount decimal(18,2) [note: 'Any discount applied to the gross invoiced amount.']
  exchange_rate decimal(18,2) [note: 'Currency conversion rate applied if invoice currency differs from reporting currency.']
  exchange_rate_date decimal(18,2) [note: 'Date for which the exchange rate was valid.']
  field_service_info varchar [note: 'Generic field service info placeholder']
  freight_invoice_status varchar [note: 'Current lifecycle state of the freight invoice.']
  incoterms_code varchar [note: 'International commercial term governing responsibility and cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAT|DAP|DDP — 7 candidates stripped; promote to reference product]']
  invoice_date date [note: 'Date and time when the carrier issued the freight invoice.']
  invoice_number varchar [note: 'External invoice number assigned by the carrier or logistics provider.']
  invoiced_amount decimal(18,2) [note: 'Total amount billed by the carrier before discounts, taxes, or adjustments.']
  net_amount decimal(18,2) [note: 'Final amount payable after discounts and taxes.']
  number_of_units varchar [note: 'Count of individual units (vehicles, kits, parts) covered by the invoice.']
  otd_flag boolean [note: 'Indicates whether the shipment met the agreed on‑time delivery commitment.']
  payment_date date [note: 'Date on which the invoice was actually paid.']
  payment_due_date date [note: 'Date by which the invoice must be paid according to contract terms.']
  payment_status varchar [note: 'Current payment processing status of the invoice.']
  remarks varchar [note: 'Free‑form text for additional comments or notes about the invoice.']
  tax_amount decimal(18,2) [note: 'Tax component included in the invoice, if applicable.']
  transport_mode varchar [note: 'Mode of transportation used for the shipment (e.g., road, rail, sea, air, intermodal).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the freight invoice record.']
  variance_amount decimal(18,2) [note: 'Difference between the invoiced amount and the agreed rate‑based amount.']
  volume_cbm decimal(10,3) [note: 'Total cubic meter volume of the shipment.']
  weight_kg decimal(10,2) [note: 'Total weight of the shipment associated with the invoice, expressed in kilograms.']

  Note: 'Carrier freight invoice received for transport services rendered on finished vehicle or CKD/SKD shipments. Captures invoice number, carrier, invoice date, transport order references, lane, transport mode, invoiced amount, currency, agreed rate, variance amount, approval status, and payment reference. Supports freight cost management, carrier invoice verification against contracted rates, and logistics cost accounting.'
}

Table logistics.transport_rate {
  transport_rate_id varchar [pk, note: 'System-generated unique identifier for the transport rate record.']
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: Transport rates are defined per carrier; adding carrier_id creates the necessary relationship.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Transport rates are jurisdiction-specific due to varying tax regimes (VAT/GST), toll structures, and cabotage regulations. Logistics pricing and invoice validation require knowing which jurisdiction\'s']
  logistics_lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: Rates are also specific to a logistics lane; adding logistics_lane_id links rates to lanes and resolves lane\'s silo.']
  accessorial_charges decimal(12,4) [note: 'Additional fixed charges (e.g., lift‑gate, detention) associated with the lane.']
  compliance_flag boolean [note: 'Indicates whether the rate complies with applicable transport regulations (e.g., IATF, EPA).']
  container_type varchar [note: 'Type of container used for the shipment, if applicable.']
  created_timestamp timestamp [note: 'Timestamp when the rate record was first created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the rate amount.']
  destination_location_code varchar [note: 'Code of the destination dealer or distribution center.']
  effective_from date [note: 'Date when the transport rate becomes valid.']
  effective_until date [note: 'Date when the transport rate expires (null if open‑ended).']
  fuel_surcharge_percent decimal(5,2) [note: 'Percentage surcharge applied to the base rate to cover fuel price volatility.']
  notes varchar [note: 'Free‑form comments or special conditions related to the rate.']
  origin_location_code varchar [note: 'Code of the origin plant or warehouse where the shipment starts.']
  rate_amount decimal(12,4) [note: 'Base monetary amount agreed for the lane before surcharges.']
  rate_code varchar [note: 'Business identifier code for the transport rate contract.']
  rate_source_system varchar [note: 'Source system where the rate originated.']
  rate_version varchar [note: 'Incremental version number for the rate record to track revisions.']
  transport_mode varchar [note: 'Mode of transportation for the lane (e.g., road, rail, sea, air).']
  transport_rate_status varchar [note: 'Current lifecycle status of the rate contract.']
  unit_of_measure varchar [note: 'Measurement unit that the rate amount applies to.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the rate record.']
  vehicle_type varchar [note: 'Classification of vehicle type applicable to the rate.']
  volume_capacity_cubic_meters decimal(10,2) [note: 'Maximum volume that can be transported under this rate.']
  weight_capacity_tons decimal(8,2) [note: 'Maximum weight that can be transported under this rate.']

  Note: 'Contracted transport rate master for carrier lanes, defining the agreed cost per unit (vehicle or container) by origin-destination pair, transport mode, vehicle type/size class, and effective date range. Captures base rate, fuel surcharge structure, accessorial charges, currency, and rate validity period. Used for freight cost estimation, invoice verification, and logistics cost planning.'
}

Table logistics.lane {
  lane_id varchar [pk, note: 'Primary key']
  destination_vehicle_compound_id varchar [note: 'FK to destination compound']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Transport lanes crossing jurisdictions are subject to cabotage rules, emissions zone restrictions, and customs pre-clearance requirements. Lane planning and rate setting require knowing the governing ']
  origin_plant_id varchar [note: 'FK to origin plant']
  origin_supplier_plant_id varchar [note: 'Foreign key linking to supply.supply_supplier_plant. Business justification: Logistics lanes in automotive originate from supplier plants. Lane already has origin_plant_id (OEM plant) — role-prefix \'origin_supplier_plant_id\' distinguishes supplier plant origin. Enables freight']
  code varchar [note: 'Lane code']
  created_timestamp timestamp [note: 'Record creation timestamp']
  destination_country_code varchar
  destination_location varchar [note: 'Destination location']
  destination_location_code varchar
  distance_km decimal(10,2) [note: 'Distance in km']
  export_import_flag boolean
  is_active boolean [note: 'Active flag']
  lane_status varchar
  lane_type varchar
  name varchar [note: 'Lane name']
  origin_country_code varchar
  origin_location varchar [note: 'Origin location']
  origin_location_code varchar
  standard_transit_days varchar
  transit_time_days varchar [note: 'Transit time in days']
  transport_mode varchar [note: 'Transport mode']
  updated_timestamp timestamp [note: 'Last update timestamp']

  Note: 'Master record defining a logistics lane as an origin-destination pair for finished vehicle or CKD/SKD transport. Captures origin facility (plant/compound/port), destination facility (dealer/compound/port), transport mode, distance, standard transit time, lane status, and assigned primary/backup carriers. Serves as the reference for route planning, rate assignment, and OTD benchmarking.'
}

Table logistics.vehicle_handover {
  vehicle_handover_id varchar [pk, note: 'System-generated unique identifier for each vehicle handover record.']
  bom_header_id varchar [note: 'Foreign key linking to product.sku. Business justification: Handover record needs SKU to capture exact vehicle configuration handed to dealer.']
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: vehicle_handover.carrier_name is a denormalized string reference to carrier.carrier_name. The carrier who performed the final delivery is a key attribute of the handover record for carrier performance']
  delivery_appointment_id varchar [note: 'Foreign key linking to sales.delivery_appointment. Business justification: Vehicle handover is the physical execution of a scheduled delivery appointment. Linking enables reconciliation of scheduled vs. actual delivery, PDI completion confirmation, and customer satisfaction ']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Dealer handover requires linking to the production order to support warranty registration and regulatory compliance.']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Pre-delivery inspection (PDI) at vehicle handover requires verifying no open recall campaigns exist for the VIN. Dealers and logistics teams must block handover if an active recall applies; this FK en']
  receiving_dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: OEM-to-dealer vehicle delivery process: when a vehicle is physically handed over to a dealership, the receiving entity is a dealership. receiving_party_id is generic (dealer.party); a direct dealers']
  receiving_party_id varchar [note: 'Unique identifier of the receiving party (dealer or customer).']
  shipment_id varchar [note: 'Foreign key linking to logistics.shipment. Business justification: Linking handover to shipment provides traceability from transport to dealer receipt.']
  vehicle_allocation_id varchar [note: 'Foreign key linking to dealer.vehicle_allocation. Business justification: Allocation fulfillment confirmation: vehicle handover closes out a dealer vehicle allocation. Linking handover to allocation enables allocation fulfillment status updates, dealer invoice reconciliatio']
  vehicle_compound_id varchar [note: 'Foreign key linking to logistics.vehicle_compound. Business justification: vehicle_handover.handover_location is a free-text string. In automotive outbound logistics, vehicle handovers typically occur at a vehicle compound or dealer yard. Adding vehicle_compound_id FK links ']
  vehicle_transport_order_id varchar [note: 'Foreign key linking to logistics.vehicle_transport_order. Business justification: A vehicle handover is the final delivery event that closes out a vehicle transport order. Linking vehicle_handover to vehicle_transport_order enables end-to-end transport order lifecycle tracking (ord']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Enables Vehicle Handover audit linking handover record to VIN master for warranty start and liability tracking.']
  acceptance_signature_status varchar [note: 'Status of the acceptance signature: signed, unsigned, or pending.']
  container_code varchar [note: 'Identifier of the shipping container (if applicable) used for the vehicle.']
  created_timestamp timestamp [note: 'Timestamp when the handover record was initially created in the system.']
  customs_document_number varchar [note: 'Reference number of the customs clearance document.']
  delay_reason varchar [note: 'Reason for any delay affecting the handover schedule.']
  emissions_kg_co2 decimal(8,2) [note: 'Carbon dioxide emissions generated during transport, measured in kilograms.']
  export_import_flag boolean [note: 'True if the handover involves cross‑border export or import.']
  fuel_consumption_liters decimal(8,2) [note: 'Fuel consumed by the transport vehicle during the handover journey.']
  handover_condition varchar [note: 'Condition of the vehicle at handover: new, used, reconditioned, or damaged.']
  handover_fee_amount decimal(12,2) [note: 'Gross fee charged for the handover service.']
  handover_fee_currency varchar [note: 'Three‑letter ISO 4217 currency code for the handover fee.']
  handover_fee_net_amount decimal(12,2) [note: 'Net amount after tax for the handover fee.']
  handover_fee_tax_amount decimal(12,2) [note: 'Tax component of the handover fee.']
  handover_location varchar [note: 'Physical location (plant, compound, yard, or dealer site) where the handover took place.']
  handover_number varchar [note: 'Business-assigned handover reference number used for tracking and communication.']
  handover_status varchar [note: 'Current processing status of the handover record.']
  handover_timestamp timestamp [note: 'Exact date and time when the handover event occurred.']
  handover_type varchar [note: 'Classification of the handover scenario: dealer stock, retail customer, export, or import.']
  hazardous_material_flag boolean [note: 'True if the vehicle or its cargo includes hazardous materials.']
  hazardous_material_type varchar [note: 'Classification of hazardous material, if applicable.']
  home_delivery_flag boolean [note: 'Whether this handover was a home delivery.']
  incoterms_code varchar [note: 'International commercial term code governing the shipment (e.g., FOB, CIF).']
  notes varchar [note: 'Free‑form notes captured during the handover process.']
  odometer_reading_km decimal(10,2) [note: 'Vehicle odometer reading at the moment of handover, expressed in kilometers.']
  otd_flag boolean [note: 'Indicates whether the handover met the agreed on‑time delivery target.']
  pdi_reference varchar [note: 'Reference identifier linking to the Pre‑Delivery Inspection record.']
  receiving_party_type varchar [note: 'Indicates whether the receiving party is a dealer or an end‑customer.']
  temperature_control_flag boolean [note: 'Indicates whether temperature control was required for the shipment.']
  temperature_max_c decimal(5,2) [note: 'Maximum temperature maintained during transport, expressed in degrees Celsius.']
  temperature_min_c decimal(5,2) [note: 'Minimum temperature maintained during transport, expressed in degrees Celsius.']
  transport_mode varchar [note: 'Mode of transport used for moving the vehicle to the handover point.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the handover record.']
  warranty_end_date date [note: 'Date when the vehicle warranty expires.']
  warranty_start_date date [note: 'Date when the vehicle warranty becomes effective after handover.']

  Note: 'Record of formal vehicle handover from logistics/compound to dealer or end customer. Captures VIN, handover date, handover location, receiving party (dealer/customer), handover type (dealer stock/retail customer), odometer reading at handover, handover condition, PDI reference, and acceptance signature status. Marks the transfer of custody and triggers downstream billing and warranty start events.'
}

Table inventory.sku_master {
  sku_master_id varchar [pk, note: 'Primary key']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Every inventory SKU in automotive corresponds to an engineering part master. BOM explosion, cost targeting, change management, and make/buy decisions all require tracing SKUs to their engineering part']
  abc_classification varchar [note: 'ABC classification']
  base_unit_of_measure varchar [note: 'Base unit of measure']
  created_timestamp timestamp [note: 'Record creation timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  gross_weight decimal(10,3) [note: 'Gross weight']
  is_batch_managed boolean [note: 'Whether batch managed']
  is_serialized boolean [note: 'Whether item is serialized']
  material_group varchar [note: 'Material group']
  material_type varchar [note: 'Material type']
  net_weight decimal(10,3) [note: 'Net weight']
  shelf_life_days varchar [note: 'Shelf life in days']
  sku_description varchar [note: 'SKU description']
  sku_number varchar [note: 'SKU number']
  sku_status varchar [note: 'SKU status']
  updated_timestamp timestamp [note: 'Last update timestamp']
  weight_unit varchar [note: 'Weight unit']

  Note: 'SSOT for all Stock Keeping Unit (SKU) definitions across the enterprise. Owns the material master record for raw materials, production components, WIP sub-assemblies, finished vehicles, and service parts. Aligned with SAP MM material master (MARA/MARC). Captures SKU identity, classification, unit of measure, weight/dimensions, hazardous material flags, shelf-life, and MRP planning parameters. Referenced by all inventory movement and stock transactions.'
}

Table inventory.storage_location {
  storage_location_id varchar [pk, note: 'Unique surrogate key for the storage location.']
  plant_id varchar [note: 'Identifier of the plant to which the location belongs.']
  warehouse_id varchar [note: 'Identifier of the warehouse or distribution center containing the location.']
  address_line1 varchar [note: 'Primary street address of the location.']
  address_line2 varchar [note: 'Secondary address information (suite, building).']
  agv_routing_priority varchar [note: 'Priority used by automated guided vehicles when selecting this location.']
  aisle varchar [note: 'Aisle designation within the zone.']
  bin varchar [note: 'Specific bin or shelf code for inventory placement.']
  capacity_quantity decimal(12,2) [note: 'Maximum amount of material the location can hold.']
  capacity_uom varchar [note: 'Unit of measure for capacity (e.g., kg, m3, units).']
  city varchar [note: 'City where the location is situated.']
  country_code varchar [note: 'Three‑letter ISO country code of the location.']
  created_timestamp timestamp [note: 'Timestamp when the record was first created in the system.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  description varchar [note: 'Free‑form description or notes about the location.']
  effective_from date [note: 'Date when the location became active for inventory.']
  effective_until date [note: 'Date when the location is scheduled to be retired (null if indefinite).']
  external_system_source varchar [note: 'Source system that provides the master data for this location.']
  fire_safety_rating varchar [note: 'Fire‑safety classification of the location.']
  hazardous_material_allowed boolean [note: 'True if hazardous parts may be stored in this location.']
  inventory_accuracy_percent decimal(5,2) [note: 'Measured accuracy of inventory records for this location.']
  is_default_location boolean [note: 'Indicates if this is the default location for new stock of its type.']
  last_inventory_count_date date [note: 'Date of the most recent physical inventory count.']
  latitude decimal(9,6) [note: 'Geographic latitude of the location.']
  location_code varchar [note: 'External code used in ERP/WMS to identify the location.']
  location_name varchar [note: 'Human‑readable name of the storage location.']
  location_type varchar [note: 'Category describing the physical storage configuration.']
  longitude decimal(9,6) [note: 'Geographic longitude of the location.']
  postal_code varchar [note: 'Postal or ZIP code for the location.']
  rack varchar [note: 'Rack identifier where the bin is located.']
  state varchar [note: 'State or province of the location.']
  storage_location_status varchar [note: 'Current operational status of the location.']
  temperature_controlled boolean [note: 'Indicates whether the location is climate‑controlled.']
  temperature_range_celsius varchar [note: 'Allowed temperature range for the location (e.g., "0-5").']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  used_capacity_percentage decimal(5,2) [note: 'Current utilization of the location expressed as a percentage of total capacity.']
  zone varchar [note: 'Logical zone within the warehouse (e.g., receiving, bulk, cold).']

  Note: 'Master record for all physical and logical storage locations within plants, warehouses, distribution centers, and dealer parts depots. Captures location hierarchy (plant → warehouse → storage type → storage bin), location type (bulk, rack, floor, cold-chain), capacity constraints, and WM (Warehouse Management) configuration. Aligned with SAP WM storage location and bin master. Enables precise bin-level inventory tracking and AGV routing.'
}

Table inventory.stock_balance {
  stock_balance_id varchar [pk, note: 'System-generated unique identifier for each stock balance record.']
  consignment_party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Consignment stock management requires identifying which customer or supplier party owns consignment_stock_qty held at a location. Automotive consignment reconciliation reports and financial liability ']
  movement_type_id varchar [note: 'Foreign key linking to inventory.movement_type. Business justification: stock_balance has goods_movement_type (STRING) — a denormalized reference to the last movement type that affected this balance record. The movement_type reference table is the authoritative classifica']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: stock_balance records inventory per SKU; linking to sku_master provides authoritative SKU attributes and removes redundant material_number.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: stock_balance also references a storage location; adding storage_location_id FK normalizes location data.']
  batch_number varchar [note: 'Identifier of the production batch when batch management is active.']
  blocked_stock_qty varchar [note: 'Quantity that is blocked due to quality or administrative reasons.']
  consignment_stock_qty varchar [note: 'Quantity owned by a supplier but stored at the plant.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the valuation price.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  expiration_date date [note: 'Date after which the material is considered expired or unusable.']
  in_transit_stock_qty varchar [note: 'Quantity that is currently being transferred between locations.']
  is_serialized boolean [note: 'Indicates whether the material is managed at the serial number level.']
  last_movement_timestamp timestamp [note: 'Date and time of the most recent goods movement affecting this stock record.']
  lifecycle_status varchar [note: 'Current status of the stock quantity (e.g., unrestricted, blocked).']
  lot_number varchar [note: 'Lot identifier for traceability of the material.']
  manufacturing_date date [note: 'Date the material was produced or assembled.']
  physical_location_hierarchy varchar [note: 'Concatenated path representing plant, warehouse, aisle, and bin (e.g., PL01/WH02/AIS03/BIN04).']
  plant_code varchar [note: 'Identifier of the manufacturing plant or site where the stock is held.']
  purchase_order_number varchar [note: 'Most recent purchase order that affected the stock balance.']
  quality_inspection_stock_qty varchar [note: 'Quantity currently under quality inspection.']
  quality_status varchar [note: 'Result of the latest quality inspection for the stock batch.']
  quantity_on_hand varchar [note: 'Total physical quantity of the material available at the location.']
  record_audit_created timestamp [note: 'Timestamp when the stock balance record was first created in the data lake.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the stock balance record.']
  safety_stock_qty varchar [note: 'Reserved quantity to protect against demand variability.']
  serial_number varchar [note: 'Serial number of the individual unit when serialization is enabled.']
  stock_category varchar [note: 'Broad classification of the stock for reporting (e.g., raw material, finished good).']
  unit_of_measure varchar [note: 'Unit in which the stock quantity is measured (e.g., EA, KG, L).']
  unrestricted_stock_qty varchar [note: 'Quantity that is free for use or sale.']
  valuation_area_code varchar [note: 'Accounting valuation area for inventory valuation purposes.']
  valuation_price decimal(15,2) [note: 'Monetary value per unit for the material based on the valuation type.']
  valuation_type varchar [note: 'Method used for inventory valuation.']

  Note: 'Current on-hand stock balance snapshot for each SKU at each storage location, plant, and valuation area. Captures unrestricted stock, quality inspection stock, blocked stock, consignment stock, in-transit stock, and safety stock levels. Aligned with SAP MM stock overview (MMBE / MARD). Supports MRP execution, inventory turnover analysis, and obsolescence monitoring. Updated by every goods movement transaction.'
}

Table inventory.goods_movement {
  goods_movement_id varchar [pk, note: 'Unique identifier for each goods movement transaction.']
  aftersales_repair_order_id varchar [note: 'Foreign key linking to aftersales.aftersales_repair_order. Business justification: Parts issued to a repair order generate goods issue movements in inventory. This FK enables direct traceability of parts consumption per repair order, supporting warranty cost accounting, parts usage ']
  movement_type_id varchar [note: 'Foreign key linking to inventory.inventory_movement_type. Business justification: Add FK to standardize movement type lookup, remove redundant free‑text column, and give inventory_movement_type an inbound reference.']
  part_master_id varchar [note: 'Identifier of the material or component being moved.']
  primary_goods_customer_party_id varchar [note: 'Identifier of the customer for goods issue movements.']
  production_order_id varchar [note: 'Identifier of the production order linked to the movement.']
  reversal_of_movement_goods_movement_id varchar [note: 'Identifier of the original goods movement that this record reverses.']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: Every goods movement event involves a specific material/SKU. While goods_movement.part_master_id references inventory.part_master (cross-domain for engineering BOM context), the inventory domain\'s s']
  source_storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Normalize source storage location reference; replace string with FK to storage_location']
  stock_transfer_order_id varchar [note: 'Foreign key linking to inventory.stock_transfer_order. Business justification: Goods movements are frequently triggered by stock transfer orders in SAP WM. The reference_document_number (STRING) on goods_movement is a generic field covering multiple document types. Adding stock_']
  warehouse_id varchar [note: 'Foreign key linking to inventory.warehouse. Business justification: goods_movement has warehouse_number (STRING) — a denormalized reference to the warehouse where the movement occurred. The warehouse master table is the authoritative source for warehouse definitions. ']
  amount_local decimal(15,2) [note: 'Value of the movement in the plant\'s local currency.']
  amount_usd decimal(15,2) [note: 'Value of the movement converted to US dollars for consolidated reporting.']
  base_uom varchar [note: 'Unit of measure associated with the quantity field.']
  created_timestamp timestamp [note: 'Timestamp when the goods movement record was initially created.']
  currency varchar [note: 'Three‑letter ISO currency code for monetary values.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  delivery_note_number varchar [note: 'Delivery document number for goods issue movements.']
  destination_plant varchar [note: 'Plant receiving the material.']
  destination_storage_location varchar [note: 'Storage location in the destination plant where the material is placed.']
  goods_movement_status varchar [note: 'Current status of the goods movement record.']
  is_automated boolean [note: 'True if the movement was performed automatically by a system (e.g., AGV).']
  is_lot_tracked boolean [note: 'True if the material is tracked by lot.']
  is_serial_tracked boolean [note: 'True if the material is tracked by serial number.']
  line_sequence varchar [note: 'Ordering number of this line within the goods movement document.']
  location_zone varchar [note: 'Specific zone or area within the warehouse for the storage location.']
  lot_number varchar [note: 'Lot number used for traceability of batch‑controlled items.']
  movement_reason varchar [note: 'Business reason prompting the inventory movement.']
  posting_date date [note: 'Calendar date on which the goods movement was posted.']
  posting_timestamp timestamp [note: 'Exact date and time when the movement was posted.']
  quality_inspection_status varchar [note: 'Outcome of any quality inspection linked to the movement.']
  quantity decimal(15,3) [note: 'Quantity of material moved, expressed in the base unit of measure.']
  reference_document_type varchar [note: 'Type of the reference document (Purchase Order, Production Order, Work Order, Delivery, Service Order).']
  reversal_indicator boolean [note: 'True if this record represents a reversal of a previous movement.']
  source_plant varchar [note: 'Plant where the material originated.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the record.']
  valuation_type varchar [note: 'Inventory valuation method used for this movement.']

  Note: 'Transactional record of every inventory movement event including goods receipts (GR), goods issues (GI), stock transfers, returns, and scrapping. Aligned with SAP MM material document (MSEG/MKPF). Captures movement type, quantity, source and destination storage locations, reference document (purchase order, production order, delivery), posting date, and batch/serial number. Provides full audit trail for lot traceability and IATF 16949 compliance.'
}

Table inventory.stock_transfer_order {
  stock_transfer_order_id varchar [pk, note: 'Unique identifier for the stock transfer order.']
  destination_plant_id varchar [note: 'Identifier of the plant receiving the stock.']
  movement_type_id varchar [note: 'Foreign key linking to inventory.movement_type. Business justification: Every stock transfer order is governed by a SAP movement type (e.g., 311 for storage-location-to-storage-location transfer, 313 for plant-to-plant). The movement_type reference table defines the rules']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: A stock transfer order governs the physical movement of a specific material/SKU between locations. material_number and material_description are denormalized SKU attributes that duplicate data owned by']
  source_plant_id varchar [note: 'Identifier of the plant where stock is sourced.']
  source_storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: A stock transfer order moves stock FROM a source storage location. This FK establishes the origin of the transfer within the warehouse management system. No existing in-domain FK covers this relations']
  agv_code varchar [note: 'Identifier of the AGV assigned to execute the transfer.']
  batch_number varchar [note: 'Batch identifier for the material batch being moved.']
  confirmation_status varchar [note: 'Result of the confirmation step before execution.']
  cost_amount decimal(15,2) [note: 'Internal cost associated with moving the stock.']
  cost_center_code varchar [note: 'Internal cost‑center responsible for the transfer expense.']
  cost_currency varchar [note: 'Three‑letter ISO currency code for the cost amount.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  execution_end_timestamp timestamp [note: 'Timestamp when the stock transfer was completed.']
  execution_start_timestamp timestamp [note: 'Timestamp when physical movement of stock began.']
  handling_instructions varchar [note: 'Free‑text instructions for special handling during transfer.']
  hazardous_material_flag boolean [note: 'True if the material is classified as hazardous.']
  is_jis boolean [note: 'Indicates if the transfer follows Just‑In‑Sequence sequencing.']
  is_jit boolean [note: 'Indicates if the transfer supports Just‑In‑Time replenishment.']
  lot_number varchar [note: 'Lot or batch identifier for traceability.']
  movement_reason_code varchar [note: 'Reason code explaining why the stock is being transferred.']
  priority varchar [note: 'Business priority assigned to the transfer order.']
  project_number varchar [note: 'Project identifier if the transfer is linked to a specific project.']
  quantity decimal(15,3) [note: 'Amount of material to be moved.']
  record_audit_created timestamp [note: 'Timestamp when the record was first captured.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the record.']
  serial_number_flag boolean [note: 'Indicates whether the material is tracked by serial number.']
  special_handling_flag boolean [note: 'True if any non‑standard handling procedures apply.']
  stock_transfer_order_status varchar [note: 'Current processing status of the transfer order.']
  temperature_control_required boolean [note: 'Indicates whether temperature‑controlled handling is required.']
  transfer_created_timestamp timestamp [note: 'Timestamp when the transfer order was created in the system.']
  transfer_order_number varchar [note: 'External reference number assigned to the transfer order.']
  transfer_type varchar [note: 'Category of stock movement represented by the order.']
  unit_of_measure varchar [note: 'Measurement unit for the transfer quantity.']

  Note: 'Warehouse Management transfer order governing the physical movement of stock between storage bins, storage types, or plants. Aligned with SAP WM transfer order (LT0A). Captures source and destination bin, transfer quantity, movement reason, AGV assignment, picker assignment, confirmation status, and execution timestamps. Supports JIT/JIS sequencing for line-side replenishment and inter-plant stock balancing.'
}

Table inventory.mrp_requirement {
  mrp_requirement_id varchar [pk, note: 'System-generated unique identifier for the MRP requirement record.']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: MRP requirements are generated by exploding BOM headers against demand. Planners must trace each MRP requirement back to the driving BOM header for exception resolution, engineering change impact anal']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: MRP requirements are generated by exploding a specific BOM version. Linking mrp_requirement to the source bom enables planners to audit which BOM revision drove a requirement, critical for engineering']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: MRP requirements are generated for specific purchased parts. The inbound_part record defines supply parameters (lead time, lot size, safety stock, supplier) used by MRP to calculate requirement dates ']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Automotive MRP is fundamentally driven by vehicle model production schedules. Planners run MRP by model to determine parts requirements and replenishment. Without this FK, mrp_requirement cannot be tr']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: MRP requirements are generated per engineering part. Planners must trace each requirement to the part master to validate lead times, make/buy decisions, and revision levels. Automotive MRP planning an']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Powertrain-specific components (engines, transmissions, battery packs) have MRP requirements driven by powertrain variant production schedules. Powertrain assembly plants run MRP by variant. This FK e']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: MRP planned orders are converted into production orders — linking mrp_requirement to production_order enables demand-to-supply conversion traceability, a core MRP/ERP process. Production planners and ']
  production_schedule_id varchar [note: 'Foreign key linking to manufacturing.production_schedule. Business justification: MRP requirements are fulfilled by production schedules — the MRP run generates demand signals that production scheduling converts into planned output. Demand-to-schedule traceability is a core S&OP an']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns generate urgent MRP demand for replacement parts. Linking mrp_requirement to recall_campaign allows planners to prioritize recall-driven requirements, track recall parts procurement s']
  service_campaign_id varchar [note: 'Foreign key linking to aftersales.service_campaign. Business justification: Active service campaigns generate deterministic parts demand that feeds MRP planning. Linking mrp_requirement to service_campaign allows planners to trace campaign-driven replenishment requirements, p']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: MRP requirements are always generated for a specific material/SKU. The material_number (STRING) on mrp_requirement is a denormalized reference to the SKU master. Adding sku_master_id FK normalizes thi']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Link MRP requirement to storage_location for proper location tracking']
  batch_flag boolean [note: 'Indicates whether the material is managed in batches.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  demand_source varchar [note: 'Origin of the demand that generated the requirement.']
  exception_message varchar [note: 'System-generated message describing any planning exception for the requirement.']
  lead_time_days varchar [note: 'Planned procurement or production lead time expressed in days.']
  lot_size decimal(15,3) [note: 'Minimum production or procurement lot size applicable to the material.']
  mrp_requirement_status varchar [note: 'Current processing state of the requirement.']
  planning_horizon_days varchar [note: 'Number of days covered by the planning run that produced this requirement.']
  planning_scenario varchar [note: 'Planning run scenario used to generate the requirement (e.g., MPS, MRP, DRP).']
  plant_code varchar [note: 'Identifier of the manufacturing plant where the requirement applies.']
  priority_code varchar [note: 'Business priority assigned to the requirement for planning urgency.']
  quantity_required decimal(15,3) [note: 'Total quantity of the material required for the planning horizon.']
  record_audit_created timestamp [note: 'Timestamp when the requirement record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the requirement record.']
  reorder_point decimal(15,3) [note: 'Inventory level that triggers a new procurement proposal.']
  requirement_date date [note: 'Date by which the material is needed to meet production schedules.']
  requirement_number varchar [note: 'Business identifier assigned to the requirement by the MRP run.']
  requirement_type varchar [note: 'Indicates whether the requirement is independent (external demand) or dependent (internal component need).']
  safety_stock decimal(15,3) [note: 'Buffer stock maintained to protect against demand variability and supply delays.']
  source_of_supply varchar [note: 'Indicates whether the material will be sourced internally or from external suppliers.']
  unit_of_measure varchar [note: 'Measurement unit for the required quantity.']

  Note: 'MRP (Material Requirements Planning) planned requirement record generated by SAP MRP run (MD04/MD05). Captures dependent and independent demand requirements for each SKU, planned order proposals, reorder points, lot sizes, lead times, and exception messages. Drives procurement requisitions and production orders. Supports safety stock calculation, demand smoothing, and supply gap analysis across the manufacturing network.'
}

Table inventory.cycle_count {
  cycle_count_id varchar [pk, note: 'System-generated unique identifier for the physical inventory cycle count event.']
  plant_id varchar [note: 'Manufacturing plant where the inventory is stored.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: IATF 16949 and NHTSA regulations mandate specific cycle count frequencies and methods. The existing compliance_iatf16949_flag and compliance_nhtsa_flag are denormalized signals; a FK to regulatory_req']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: A cycle count event is performed for a specific SKU at a specific storage location. While cycle_count.sku_id references inventory.sku (cross-domain), the inventory domain\'s sku_master is the SSOT for in']
  storage_location_id varchar [note: 'Reference to the physical storage location (warehouse, plant, or depot) where the count took place.']
  abc_classification varchar [note: 'ABC inventory classification driving count frequency.']
  approval_timestamp timestamp [note: 'Date and time when the count was approved.']
  approved_by varchar [note: 'Employee who approved the count after review.']
  book_quantity decimal(15,3) [note: 'Quantity recorded in the system (book) prior to the count.']
  compliance_iatf16949_flag boolean [note: 'True if the count complies with IATF 16949 inventory control requirements.']
  compliance_nhtsa_flag boolean [note: 'True if the count satisfies NHTSA traceability obligations.']
  cost_center_code varchar [note: 'Internal cost center associated with the inventory location.']
  count_date date [note: 'Date on which the physical count was performed.']
  count_document_number varchar [note: 'External document number assigned by SAP MM for the inventory count (e.g., MI01/MI07).']
  count_frequency_days varchar [note: 'Number of days between scheduled counts for this SKU/location.']
  count_status varchar [note: 'Current lifecycle status of the count event.']
  count_type varchar [note: 'Specifies whether the count is a full inventory, partial, or scheduled cycle count.']
  counted_quantity decimal(15,3) [note: 'Quantity physically counted during the inventory event.']
  created_timestamp timestamp [note: 'System timestamp when the count record was first created.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  fiscal_year varchar [note: 'Fiscal year in which the count took place.']
  inventory_category varchar [note: 'High‑level classification of the inventory item.']
  is_locked boolean [note: 'Indicates whether the count record is locked from further edits.']
  is_obsolete boolean [note: 'Indicates whether the SKU is marked as obsolete.']
  last_count_date date [note: 'Date of the most recent prior count for this SKU/location.']
  lot_number varchar [note: 'Batch or lot identifier for traceability of the counted material.']
  method varchar [note: 'Technique used to perform the count.']
  model_year varchar [note: 'Model year of the vehicle or component associated with the SKU.']
  next_scheduled_count_date date [note: 'Planned date for the next cycle count based on ABC classification.']
  physical_inventory_doc_type varchar [note: 'SAP document type for the inventory count.']
  posted_by varchar [note: 'Employee who posted the count results.']
  posted_timestamp timestamp [note: 'Date and time when the count was posted to inventory.']
  recount_flag boolean [note: 'Indicates whether a recount was required after the initial count.']
  recount_number varchar [note: 'Sequential number of the recount attempt, if applicable.']
  remarks varchar [note: 'Free‑text field for additional comments or observations.']
  reorder_point_quantity decimal(15,3) [note: 'Quantity at which a replenishment order should be triggered.']
  safety_stock_quantity decimal(15,3) [note: 'Predefined safety stock level for the SKU at the location.']
  serial_number_flag boolean [note: 'Indicates whether the counted items are serialized (true) or not (false).']
  storage_bin varchar [note: 'Alphanumeric code of the specific bin or shelf within the location.']
  unit_of_measure varchar [note: 'Measurement unit for quantity fields (e.g., EA for each, KG for kilograms).']
  updated_timestamp timestamp [note: 'System timestamp of the most recent modification to the count record.']
  variance_percentage decimal(5,2) [note: 'Percentage variance calculated as (variance_quantity / book_quantity) * 100.']
  variance_quantity decimal(15,3) [note: 'Difference between counted and book quantities (counted - book).']
  variance_reason varchar [note: 'Narrative explanation for any observed variance.']

  Note: 'Physical inventory cycle count event record for a specific SKU at a specific storage location. Aligned with SAP MM physical inventory document (MI01/MI07). Captures count date, counted quantity, book quantity, variance quantity, variance percentage, count status (planned, counted, posted, approved), counter identity, and recount flag. Supports inventory accuracy KPIs, ABC classification-driven count frequency, and IATF 16949 inventory control requirements.'
}

Table inventory.finished_vehicle_stock {
  finished_vehicle_stock_id varchar [pk, note: 'System-generated unique identifier for each finished vehicle stock record.']
  allocated_party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Vehicle allocation reporting and customer-specific hold management require knowing which customer (retail or fleet) a finished vehicle is allocated to. OEM allocation dashboards and priority delivery ']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Each finished vehicle in stock was built to a specific BOM header revision. Linking enables recall traceability (which BOM version is affected), warranty claim validation, and regulatory compliance re']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Dealer allocation, order matching, and production mix reporting require knowing the exact build configuration of each stocked vehicle. finished_vehicle_stock carries denormalized body_style, color, po']
  emissions_certification_id varchar [note: 'Foreign key linking to compliance.compliance_emissions_certification. Business justification: Finished vehicles must carry valid emissions certification before delivery or registration. The existing emission_standard column is a denormalized string; a FK to compliance_emissions_certification n']
  fleet_contract_id varchar [note: 'Foreign key linking to sales.fleet_contract. Business justification: Fleet allocation reporting: finished vehicles committed under fleet contracts must be tracked against the contract for volume fulfillment and delivery scheduling. Automotive fleet operations require k']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: Vehicle approval: link each finished VIN to its homologation record required for market entry.']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: EV/ICE/hybrid production mix management and dealer allocation require powertrain-variant-level stock reporting. finished_vehicle_stock.powertrain_type is a denormalized plain attribute; a powertrain_v']
  primary_finished_allocation_dealer_dealership_id varchar [note: 'Identifier of the dealer to which the vehicle is allocated.']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: Finished vehicle stock traceability to production line is required for recall investigations, IATF 16949 quality audits, and line-level defect rate reporting. finished_vehicle_stock.production_line is']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Finished vehicles in yard/dealer stock are placed on hold when a recall is issued. The existing recall_flag and hold_code columns confirm recall awareness; a FK to recall_campaign identifies the speci']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: Finished vehicles are physically stored at specific storage locations (PDI bays, finished goods yards, dealer staging areas). current_location_code (STRING) and location_type (STRING) are denormalized']
  trim_level_id varchar [note: 'Foreign key linking to vehicle.vehicle_trim_level. Business justification: Dealer allocation and production mix management require trim-level stock reporting (e.g., Base vs. Premium inventory levels). finished_vehicle_stock carries a denormalized trim_level plain attribute. ']
  vehicle_allocation_id varchar [note: 'Foreign key linking to dealer.vehicle_allocation. Business justification: OEM vehicle pipeline management: a finished vehicle stock unit is governed by exactly one dealer vehicle_allocation record that controls acceptance deadlines, PDI requirements, dealer invoice price, a']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Supports dealership allocation and program performance reports linking finished vehicles back to their engineering program.']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Needed for Finished Vehicle Stock report linking each inventory vehicle to its VIN registry for warranty, recall, and regulatory compliance.']
  aging_days varchar [note: 'Number of days the vehicle has been in its current status.']
  allocation_date date [note: 'Date the vehicle was assigned to a dealer.']
  batch_number varchar [note: 'Internal production batch number associated with the vehicle.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  delivery_date date [note: 'Actual date the vehicle left the plant or compound for the dealer/customer.']
  expected_delivery_date date [note: 'Planned delivery date based on logistics schedule.']
  hold_code varchar [note: 'Code indicating why a vehicle is on hold (e.g., quality, finance).']
  hold_reason varchar [note: 'Free‑text explanation for the hold code.']
  lot_number varchar [note: 'Batch identifier used for traceability of the vehicle batch.']
  model_code varchar [note: 'Manufacturer\'s code representing the vehicle model (e.g., CX5, F150).']
  msrp decimal(12,2) [note: 'Standard retail price set by the manufacturer for the vehicle configuration.']
  plant_code varchar [note: 'Identifier of the plant where the vehicle was assembled.']
  production_date date [note: 'Calendar date when the vehicle completed assembly (EOL).']
  recall_flag boolean [note: 'Indicates whether the vehicle is subject to a safety recall (true) or not (false).']
  record_audit_created timestamp [note: 'Timestamp when the stock record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the stock record.']
  stock_status varchar [note: 'Current lifecycle status of the vehicle within inventory.']
  vin varchar [note: 'Globally unique 17‑character identifier assigned to each vehicle.']
  warranty_end_date date [note: 'Date when the vehicle warranty period expires.']
  warranty_start_date date [note: 'Date when the vehicle warranty period begins.']

  Note: 'Finished vehicle inventory record tracking completed vehicles from end-of-line (EOL) through PDI (Pre-Delivery Inspection), compound storage, and dealer allocation. Captures VIN, model/trim/color configuration, plant of manufacture, current compound or yard location, stock status (in-production, PDI-pending, PDI-complete, allocated, in-transit, delivered), hold codes, and aging days. Bridges manufacturing and logistics domains for vehicle order fulfillment.'
}

Table inventory.service_parts_stock {
  service_parts_stock_id varchar [pk, note: 'Unique identifier for the service parts stock record.']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Dealer parts inventory management: OEMs track service parts stock held at dealer service departments for parts fill rate reporting, replenishment programs, and warranty parts availability audits. A de']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Aftersales parts management requires knowing which vehicle model a service part applies to — for warranty provisioning, dealer parts ordering, and parts catalog management. Without this FK, service_pa']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Service parts inventory must be traceable to engineering part masters for supersession management, warranty compliance, and revision control. Automotive aftermarket operations require this link to val']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall remedy execution requires provisioning replacement parts at dealer/PDC level. Service parts stock must be linked to the driving recall campaign to support recall parts availability reporting, r']
  service_center_id varchar [note: 'Foreign key linking to aftersales.service_center. Business justification: Service parts stock is physically held at or allocated to a specific service center. This FK enables real-time parts availability checks during appointment booking, service center stock reporting, and']
  service_part_id varchar [note: 'Foreign key linking to aftersales.service_part. Business justification: service_parts_stock tracks physical inventory quantities; service_part is the aftersales catalog master with dealer net price, warranty eligibility, and lifecycle status. Linking them enables stock va']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: Service parts stock tracks spare parts and accessories inventory. Each service parts stock record is for a specific part/SKU. The sku_master is the SSOT for all SKU definitions including service parts']
  storage_location_id varchar [note: 'Unique identifier of the warehouse or dealer location where the stock is held.']
  warehouse_id varchar [note: 'FK to inventory.warehouse']
  aisle varchar [note: 'Aisle identifier within the warehouse layout.']
  batch_number varchar [note: 'Identifier for the manufacturing batch of the part.']
  bin_number varchar [note: 'Alphanumeric identifier of the storage bin or pallet location.']
  cost_per_unit decimal(12,2) [note: 'Standard cost of a single unit of the part in the local currency.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency for cost values.']
  cycle_count_status varchar [note: 'Current status of the scheduled cycle count for the location.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  expiration_date date [note: 'Date after which the part should not be used (e.g., perishable components).']
  inventory_status varchar [note: 'Overall lifecycle status of the stock record.']
  last_cost_update_timestamp timestamp [note: 'Timestamp of the most recent cost update for the part.']
  last_count_date date [note: 'Date of the most recent physical inventory count.']
  last_issue_date date [note: 'Date when the most recent stock issue (dispatch) was recorded.']
  last_receipt_date date [note: 'Date when the most recent stock receipt was recorded.']
  lead_time_days varchar [note: 'Average number of days from order placement to receipt for this part.']
  lot_number varchar [note: 'Batch or lot identifier for traceability of the part.']
  max_stock_level varchar [note: 'Upper bound for stock to avoid over‑stocking.']
  min_stock_level varchar [note: 'Safety stock threshold below which replenishment is triggered.']
  obsolescence_date date [note: 'Effective date when the part becomes obsolete.']
  obsolescence_reason varchar [note: 'Reason for obsolescence (e.g., discontinued, replaced by new model).']
  obsolescence_status varchar [note: 'Indicates whether the part is active, pending obsolescence, or obsolete.']
  quantity_available varchar [note: 'Units available for allocation to orders (excluding reserved stock).']
  quantity_committed varchar [note: 'Units already committed to pending service orders.']
  quantity_on_hand varchar [note: 'Total number of units physically present in the location.']
  record_audit_created timestamp [note: 'Timestamp when the stock record was initially created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the stock record.']
  reorder_point varchar [note: 'Inventory level that triggers a replenishment order.']
  safety_stock varchar [note: 'Buffer quantity kept to protect against demand variability.']
  serial_number_flag boolean [note: 'Indicates whether the part is tracked by individual serial numbers.']
  shelf varchar [note: 'Shelf identifier within the aisle for the part.']
  supersession_part_number varchar [note: 'Part number that supersedes this part in the product lifecycle.']
  valuation_method varchar [note: 'Inventory valuation method applied to the part stock.']
  warranty_expiration_date date [note: 'Date when the part\'s warranty coverage ends.']
  warranty_status varchar [note: 'Current warranty coverage status of the part.']

  Note: 'After-sales service parts inventory record tracking spare parts and accessories across the central parts distribution center (PDC), regional warehouses, and dealer parts rooms. Captures part number, supersession chain, current stock level by location, min/max replenishment levels, fill rate, backorder quantity, and obsolescence classification. Supports dealer parts ordering, warranty repair fulfillment, and TSB (Technical Service Bulletin) parts pre-positioning.'
}

Table inventory.movement_type {
  movement_type_id varchar [pk, note: 'Surrogate primary key for each inventory movement type record. [canonical_skip_reason: REFERENCE_LOOKUP - classification table for movement types]']
  account_determination_relevant boolean [note: 'Flag indicating whether the movement type triggers automatic account determination for financial posting.']
  allowed_destination_location_type varchar [note: 'Type of location permitted as the destination for this movement.']
  allowed_source_location_type varchar [note: 'Type of location permitted as the source for this movement (e.g., plant, warehouse, vendor).']
  batch_management_required boolean [note: 'Indicates if batch management must be maintained for movements of this type.']
  code varchar [note: 'Alphanumeric code that uniquely identifies the movement type (e.g., 101 for goods receipt, 261 for goods issue).']
  cost_center_required boolean [note: 'Indicates if a cost center must be supplied when posting this movement.']
  created_timestamp timestamp [note: 'Timestamp when the movement type record was initially created in the source system.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  default_quantity_sign varchar [note: 'Default sign (+1 or -1) applied to quantity for this movement type.']
  description varchar [note: 'Human‑readable description of the movement type and its business purpose.']
  direction varchar [note: 'Indicates whether the movement adds stock (inbound), removes stock (outbound), or moves stock between locations (transfer).']
  effective_from date [note: 'Date from which the movement type becomes valid for use.']
  effective_until date [note: 'Date after which the movement type is no longer valid (null if open‑ended).']
  hazardous_material_allowed boolean [note: 'Indicates whether hazardous materials may be moved using this movement type.']
  inventory_accounting_relevant boolean [note: 'Flag indicating whether the movement type affects inventory valuation and accounting.']
  inventory_impact varchar [note: 'Indicates whether the movement increases, decreases, or does not change stock levels.']
  is_active boolean [note: 'Indicates whether the movement type is currently active and usable in transactions.']
  is_automated boolean [note: 'Indicates whether postings of this movement type can be generated automatically by system processes.']
  is_deprecated boolean [note: 'True if the movement type is deprecated and should not be used for new transactions.']
  is_jis boolean [note: 'True if the movement type supports Just‑In‑Sequence production scheduling.']
  is_jit boolean [note: 'True if the movement type is used in Just‑In‑Time procurement processes.']
  is_lot_tracked boolean [note: 'True if lot (batch) tracking is mandatory for this movement type.']
  is_serial_tracked boolean [note: 'True if serial number tracking is mandatory for this movement type.']
  movement_category varchar [note: 'High‑level category grouping of movement types.']
  movement_reason_code varchar [note: 'Optional code that provides additional reason for the movement (e.g., scrap, rework).']
  notes varchar [note: 'Free‑form comments or additional information about the movement type.']
  price_control varchar [note: 'Method used for inventory valuation for this movement type.']
  profit_center_required boolean [note: 'Indicates if a profit center must be supplied for this movement type.']
  quality_inspection_required boolean [note: 'Flag indicating whether a quality inspection record is mandatory for this movement.']
  requires_approval boolean [note: 'Indicates whether movements of this type must be approved before posting.']
  reversal_allowed boolean [note: 'Flag indicating whether this movement type can be reversed by another movement.']
  reversal_movement_type_code varchar [note: 'Code of the movement type that reverses this movement (e.g., 102 reverses 101).']
  serial_number_required boolean [note: 'Indicates if serial numbers must be captured for this movement type.']
  special_stock_indicator varchar [note: 'Identifies special stock categories (e.g., blocked stock, quality inspection stock) associated with the movement.']
  system_defined boolean [note: 'True if the movement type is delivered by SAP and cannot be deleted.']
  tax_relevant boolean [note: 'Flag indicating whether tax calculation is applicable for this movement.']
  transaction_event varchar [note: 'Business event that typically generates this movement type (e.g., purchase order receipt, production order issue).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the movement type record.']
  valuation_class varchar [note: 'Key used in valuation to determine price control and account assignment.']

  Note: 'Reference classification table defining all valid inventory movement types used in goods movement transactions. Captures movement type code, description, movement direction (inbound/outbound/transfer), account determination relevance, reversal movement type, and applicable business scenarios (e.g., 101=GR for PO, 261=GI for production order, 311=transfer posting). Aligned with SAP MM movement type configuration. Provides standardized classification for all goods movement transactions.'
}

Table inventory.warehouse {
  warehouse_id varchar [pk, note: 'Primary key for warehouse']
  parent_warehouse_id varchar [note: 'Self-referencing FK on warehouse (parent_warehouse_id)']
  address_line1 varchar [note: 'First line of the warehouse street address.']
  address_line2 varchar [note: 'Second line of the warehouse street address (optional).']
  capacity_cubic_m decimal(12,2) [note: 'Total usable volume capacity in cubic meters.']
  capacity_sqft decimal(12,2) [note: 'Total usable floor space in square feet.']
  city varchar [note: 'City where the warehouse is located.']
  close_date date [note: 'Date when the warehouse ceased operations (null if still active).']
  code varchar [note: 'External code used to reference the warehouse in ERP and logistics systems.']
  country varchar [note: 'Three‑letter ISO country code where the warehouse resides.']
  created_timestamp timestamp [note: 'Timestamp when the warehouse record was first created in the system.']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  description varchar [note: 'Free‑form description providing additional details about the warehouse.']
  effective_from date [note: 'Date from which the warehouse information is considered effective.']
  effective_until date [note: 'Date until which the warehouse information remains effective (null for open‑ended).']
  latitude decimal(9,6) [note: 'Geographic latitude of the warehouse (decimal degrees).']
  longitude decimal(9,6) [note: 'Geographic longitude of the warehouse (decimal degrees).']
  manager_email varchar [note: 'Contact email address for the warehouse manager.']
  manager_name varchar [note: 'Full name of the person responsible for warehouse operations.']
  manager_phone varchar [note: 'Contact phone number for the warehouse manager.']
  name varchar [note: 'Human‑readable name of the warehouse.']
  open_date date [note: 'Date when the warehouse began operations.']
  operating_hours varchar [note: 'Standard daily operating hours (e.g., 08:00-17:00).']
  postal_code varchar [note: 'Postal/ZIP code for the warehouse address.']
  region varchar [note: 'Higher‑level geographic region grouping (e.g., North America, EMEA).']
  security_level varchar [note: 'Security classification of the warehouse based on access controls and monitoring.']
  state varchar [note: 'State or province of the warehouse location.']
  temperature_controlled boolean [note: 'Indicates whether the warehouse provides temperature‑controlled storage.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the warehouse record.']
  warehouse_status varchar [note: 'Current lifecycle status of the warehouse.']
  warehouse_type varchar [note: 'Category of warehouse based on its primary function.']
  zone varchar [note: 'Internal zone or area identifier within the warehouse complex.']

  Note: 'Master reference table for warehouse. Referenced by warehouse_id.'
}

Table customer.party {
  party_id varchar [pk, note: 'Unique system-generated identifier for the party record.']
  address_line1 varchar [note: 'First line of the party\'s primary mailing address.']
  address_line2 varchar [note: 'Second line of the party\'s primary mailing address (optional).']
  address_type varchar [note: 'Classification of the primary address (e.g., billing, shipping).']
  city varchar [note: 'City component of the primary mailing address.']
  communication_preference varchar [note: 'Preferred channel for outbound communications.']
  country_code varchar [note: 'Three‑letter ISO country code for the primary mailing address.']
  credit_rating varchar [note: 'External credit rating assigned to the party for risk assessment.']
  customer_lifetime_value decimal(18,2) [note: 'Estimated total net revenue expected from the party over the relationship.']
  customer_segment varchar [note: 'Business segment classification for analytics and targeting.']
  data_residency_region varchar [note: 'Geographic region where the party\'s personal data is stored to satisfy data‑sovereignty requirements.']
  date_of_birth date [note: 'Birth date of an individual party, used for age verification and KYC.']
  email_address varchar [note: 'Primary email address for electronic communication.']
  external_reference_code varchar [note: 'Additional external reference used for cross‑system reconciliation.']
  gdpr_consent_email boolean [note: 'Indicates whether the party has consented to receive email communications under GDPR.']
  gdpr_consent_sms boolean [note: 'Indicates whether the party has consented to receive SMS communications under GDPR.']
  incorporation_date date [note: 'Date the organization was legally formed.']
  industry_classification varchar [note: 'Standard industry code (NAICS or SIC) describing the party\'s primary business.']
  is_tax_exempt boolean [note: 'Indicates whether the party is exempt from sales tax.']
  kyc_status varchar [note: 'Current status of KYC verification for the party.']
  last_verified_date date [note: 'Date when the party\'s information was last validated against source data.']
  legal_name varchar [note: 'Full legal name of the individual or organization as recorded for contracts and compliance.']
  lifecycle_status varchar [note: 'Current lifecycle stage of the party within the business relationship.']
  loyalty_tier varchar [note: 'Current tier level within the loyalty program.']
  marketing_opt_in boolean [note: 'Indicates whether the party has consented to receive marketing communications.']
  net_promoter_score varchar [note: 'Latest NPS rating captured for the party.']
  notes varchar [note: 'Free‑form notes entered by business users about the party.']
  onboarding_channel varchar [note: 'Channel through which the party was onboarded.']
  onboarding_date date [note: 'Date the party was first created in the system.']
  party_type varchar [note: 'Indicates whether the party is an individual customer or an organization (e.g., fleet operator, dealer).']
  phone_number varchar [note: 'Primary telephone number for voice or SMS contact.']
  postal_code varchar [note: 'Postal or ZIP code of the primary mailing address.']
  preferred_currency varchar [note: 'ISO 4217 currency code the party prefers for billing and pricing.']
  preferred_language varchar [note: 'ISO 639‑1 language code for the party\'s preferred communication language.']
  primary_contact_method varchar [note: 'Method most frequently used to reach the party.']
  record_audit_created timestamp [note: 'Timestamp when the party record was first created in the lakehouse.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the party record.']
  registration_number varchar [note: 'Official registration number for an organization (e.g., corporate registration, dealer license).']
  source_system_code varchar [note: 'Unique identifier of the party in the source system.']
  state_province varchar [note: 'State or province component of the primary mailing address.']
  tax_exempt_reason varchar [note: 'Reason or code for tax exemption, if applicable.']
  tax_identification_number varchar [note: 'Government‑issued tax identifier (e.g., EIN, VAT) for the party.']
  trade_name varchar [note: 'Doing‑business‑as name or brand name used by the organization.']

  Note: 'SSOT master entity for all customer identities served by Automotive — retail buyers (B2C), fleet operators, corporate accounts, government entities, and dealer principals. Stores the unified identity record including party type (individual/organization), legal name, tax identification, registration number, preferred language, preferred currency, date of birth (for individuals), incorporation date (for organizations), industry classification (NAICS/SIC), credit rating, KYC status, GDPR consent flags, data residency region, source system (Salesforce Automotive Cloud party ID), onboarding channel, onboarding date, lifecycle status (prospect/active/inactive/churned), and last verified date. This is the anchor entity for all customer-domain relationships.'
}

Table customer.individual {
  individual_id varchar [pk, note: 'Unique system-generated identifier for the individual.']
  individual_dealership_id varchar [note: 'Identifier of the dealer the individual prefers for service or purchase.']
  individual_preferred_dealer_dealership_id varchar [note: 'Identifier of the dealer the individual prefers for service or purchase.']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: individual is explicitly described as \'B2C retail customer profile extending the party master for natural persons.\' The party table is the SSOT master entity for all customer identities. individual MU']
  annual_income_band varchar [note: 'Income range band used for segmentation and marketing.']
  cltv_estimate decimal(15,2) [note: 'Estimated total future revenue attributable to the individual.']
  consent_timestamp timestamp [note: 'Timestamp when the individual gave marketing consent.']
  country_of_residence varchar [note: 'Country where the individual currently resides.']
  customer_type varchar [note: 'Classification of the individual as B2C, B2B, government, or fleet.']
  driver_license_expiry date [note: 'Expiration date of the driver license.']
  driver_license_number varchar [note: 'Government‑issued driver license identifier.']
  driver_license_state varchar [note: 'State or province that issued the driver license.']
  education_level varchar [note: 'Highest completed education level of the individual.']
  employment_status varchar [note: 'Current employment situation of the individual.']
  first_name varchar [note: 'Given name of the individual.']
  gender varchar [note: 'Self‑identified gender of the individual.']
  individual_status varchar [note: 'Current lifecycle status of the individual record.']
  last_name varchar [note: 'Family name or surname of the individual.']
  last_purchase_date date [note: 'Date of the most recent vehicle or service purchase.']
  loyalty_tier varchar [note: 'Current loyalty program tier of the individual.']
  marital_status varchar [note: 'Current marital status of the individual.']
  marketing_opt_in_email boolean [note: 'True if the individual has consented to receive marketing emails.']
  marketing_opt_in_phone boolean [note: 'True if the individual has consented to receive marketing phone calls.']
  marketing_opt_in_sms boolean [note: 'True if the individual has consented to receive marketing SMS messages.']
  middle_name varchar [note: 'Middle name or initial of the individual, if any.']
  nationality varchar [note: 'Country of citizenship of the individual.']
  nps_score varchar [note: 'Latest NPS rating provided by the individual (‑100 to 100).']
  occupation varchar [note: 'Primary occupation or job title of the individual.']
  preferred_contact_method varchar [note: 'Individual\'s preferred channel for communications.']
  primary_spoken_language varchar [note: 'ISO 639‑1 code of the individual\'s primary language.']
  record_audit_created timestamp [note: 'Timestamp when the individual record was first created.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the individual record.']
  suffix varchar [note: 'Suffix such as Jr., Sr., III, if applicable.']
  vehicle_ownership_count varchar [note: 'Number of vehicles currently owned by the individual.']

  Note: 'B2C retail customer profile extending the party master for natural persons. Captures personal identity attributes: first name, middle name, last name, suffix, gender, marital status, employment status, occupation, annual income band, education level, driver license number, driver license state/country, driver license expiry, primary spoken language, nationality, country of residence, household_id (FK to household), loyalty tier, NPS score (latest), CLTV estimate, preferred contact method, marketing opt-in flags, and Salesforce Contact ID. Supports personalized marketing, loyalty management, and customer journey analytics for retail vehicle buyers.'
}

Table customer.organization_account {
  organization_account_id varchar [pk, note: 'Unique surrogate key for the organization account record.']
  parent_organization_account_id varchar [note: 'Identifier of the parent organization in corporate hierarchy, if applicable.']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: organization_account is described as \'B2B customer profile for corporate accounts, fleet operators, government entities, and leasing companies\' — it explicitly extends the party master. Like individua']
  primary_dealer_dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: B2B/corporate organization accounts are assigned to a primary dealership for account management, commercial fleet sales, and OEM incentive program eligibility. Dealer commercial sales reporting and ac']
  account_tier varchar [note: 'Tier classification of the account based on strategic importance.']
  accounts_payable_contact_email varchar [note: 'Email address of the accounts payable contact.']
  accounts_payable_contact_name varchar [note: 'Name of the accounts payable contact.']
  accounts_payable_contact_phone varchar [note: 'Phone number of the accounts payable contact.']
  annual_revenue decimal(18,2) [note: 'Annual revenue of the organization in US dollars.']
  classification varchar [note: 'Broad classification of the organization account.']
  contract_vehicle_type varchar [note: 'Contract vehicle type used for government procurement.']
  created_timestamp timestamp [note: 'Timestamp when the organization account record was created.']
  credit_limit decimal(18,2) [note: 'Maximum credit amount extended to the organization.']
  dba_name varchar [note: 'Trade name under which the organization operates.']
  duns_number varchar [note: 'Unique DUNS identifier for the organization.']
  effective_from date [note: 'Date when the account became effective.']
  effective_until date [note: 'Date when the account expires or is terminated, if applicable.']
  fleet_size varchar [note: 'Number of vehicles owned or managed by the organization.']
  government_entity_type varchar [note: 'Type of government entity, if applicable.']
  industry_codes varchar [note: 'Additional industry-specific codes (e.g., CAGE, NCAGE).']
  legal_entity_name varchar [note: 'Full legal name of the organization.']
  naics_code varchar [note: 'North American Industry Classification System code for the organization.']
  number_of_employees varchar [note: 'Total number of employees in the organization.']
  organization_account_status varchar [note: 'Current lifecycle status of the organization account.']
  payment_terms varchar [note: 'Standard payment terms agreed with the organization.']
  preferred_oem_programs varchar [note: 'Comma-separated list of preferred OEM programs for the organization.']
  primary_contact_email varchar [note: 'Primary email address for general communications with the organization.']
  primary_contact_phone varchar [note: 'Primary phone number for the organization.']
  procurement_contact_email varchar [note: 'Email address of the procurement contact.']
  procurement_contact_name varchar [note: 'Name of the primary procurement contact for the organization.']
  procurement_contact_phone varchar [note: 'Phone number of the procurement contact.']
  sap_customer_number varchar [note: 'Customer number in SAP S/4HANA Finance module.']
  sic_code varchar [note: 'Standard Industrial Classification code for the organization.']
  tax_identifier varchar [note: 'Tax identification number for the organization.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the organization account record.']

  Note: 'B2B customer profile for corporate accounts, fleet operators, government entities, and leasing companies. Extends the party master with organization-specific attributes: legal entity name, DBA name, parent company party_id (for corporate hierarchy), DUNS number, SIC/NAICS code, annual revenue, number of employees, fleet size, procurement contact name, accounts payable contact, credit limit, payment terms, preferred OEM programs, government entity type (federal/state/municipal), contract vehicle type (GSA/state contract), Salesforce Account ID, SAP customer number, and account tier (strategic/key/standard). Enables B2B fleet sales, government procurement, and corporate account management.'
}

Table customer.contact_point {
  contact_point_id varchar [pk, note: 'System-generated unique identifier for each contact point record.']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Contact points belong to a party (customer or organization). Adding contact_point.party_id creates the required inbound link and eliminates isolation.']
  address_line1 varchar [note: 'First line of the mailing address.']
  address_line2 varchar [note: 'Second line of the mailing address (optional).']
  channel varchar [note: 'Preferred channel associated with the contact point for outbound messaging.']
  city varchar [note: 'City component of the mailing address.']
  classification varchar [note: 'Business classification indicating the nature of the party owning the contact point.']
  communication_preference varchar [note: 'Type of communications the party consents to receive via this contact point.']
  contact_point_status varchar [note: 'Current lifecycle status of the contact point.']
  contact_point_type varchar [note: 'Category of the contact point indicating the medium (e.g., email, phone, mailing address, social media handle).']
  country_code varchar [note: 'Three‑letter ISO country code for the mailing address.']
  created_timestamp timestamp [note: 'Timestamp when the contact point record was first created in the lakehouse.']
  effective_date date [note: 'Date from which the contact point becomes valid for use.']
  email_address varchar [note: 'Email address used for electronic communication.']
  expiry_date date [note: 'Date after which the contact point is no longer valid.']
  is_primary boolean [note: 'Indicates whether this contact point is the primary method for reaching the party.']
  is_verified boolean [note: 'True when the contact point has been successfully verified.']
  language_preference varchar [note: 'Preferred language for communications sent to this contact point.']
  last_used_timestamp timestamp [note: 'Most recent timestamp when this contact point was used for communication.']
  opt_in_status boolean [note: 'True when the party has consented to receive communications via this contact point.']
  opt_out_date timestamp [note: 'Date and time when the party withdrew consent for this contact point.']
  phone_number varchar [note: 'Telephone number including country code, used for voice or SMS contact.']
  postal_code varchar [note: 'Postal or ZIP code of the mailing address.']
  preferred_contact_hours varchar [note: 'Typical daily time window (e.g., 09:00-17:00) when the party prefers to be contacted.']
  preferred_time_zone varchar [note: 'IANA time‑zone identifier representing the party\'s preferred time zone for contact.']
  social_handle varchar [note: 'Identifier for the party on a social media platform (e.g., @user).']
  social_platform varchar [note: 'Social media platform associated with the social handle.']
  state_province varchar [note: 'State or province component of the mailing address.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the contact point record.']
  value decimal(18,2) [note: 'The raw value of the contact point (e.g., email address, phone number, full mailing address, social handle).']
  verification_date timestamp [note: 'Date and time when the contact point was verified.']
  verification_method varchar [note: 'Method used to verify the contact point (e.g., email link, SMS code).']

  Note: 'Stores all contact information for a party (individual or organization) including email addresses, phone numbers, mailing addresses, and social media handles. Each record captures: contact point type (email/phone/address/social), contact point value, is_primary flag, is_verified flag, verification date, verification method, opt-in status, opt-out date, channel (voice/SMS/email/mail/push), preferred time zone, preferred contact hours, source system, and effective/expiry dates. Supports omnichannel communication, regulatory compliance (TCPA, CAN-SPAM, GDPR), and Salesforce Automotive Cloud contact synchronization.'
}

Table customer.vehicle_ownership {
  vehicle_ownership_id varchar [pk, note: 'Surrogate primary key uniquely identifying each vehicle ownership record.']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Recall management, warranty claims, and service campaigns require knowing the exact BOM configuration (model year, variant, powertrain) a customer owns. OEM service operations and regulatory recall co']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Required for warranty/service eligibility reports linking each ownership record to the dealer that sold the vehicle; dealer_code is denormalized and replaced.']
  party_id varchar [note: 'Unique identifier of the customer (party) that owns or leases the vehicle.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Recall and warranty traceability requires linking customer ownership directly to the production order (batch, plant, BOM version, build date range). Automotive regulators (NHTSA) and OEM recall teams ']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall Notification and Completion Tracking: OEMs must identify which customers own vehicles affected by a recall campaign (NHTSA mandate). This FK enables direct lookup of active recalls against a cu']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Required for warranty, recall and production tracking reports that map each owned vehicle to its engineering program.']
  vehicle_warranty_id varchar [note: 'Foreign key linking to aftersales.vehicle_warranty. Business justification: Ownership records must reference the active vehicle warranty for CPO certification, trade-in valuation, service scheduling eligibility checks, and warranty transfer processing. Ownership-centric warra']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Required for ownership verification and warranty claim processing; links each ownership record to the VIN registry entry to retrieve vehicle specs.']
  acquisition_channel varchar [note: 'Source through which the vehicle was obtained.']
  acquisition_date date [note: 'Date the customer acquired the vehicle (purchase, lease start, etc.).']
  acquisition_dealer_code varchar [note: 'Identifier of the dealer that facilitated the acquisition.']
  created_timestamp timestamp [note: 'Timestamp when the ownership record was first created.']
  current_odometer varchar [note: 'Most recent mileage reported for the vehicle.']
  disposition_date date [note: 'Date the vehicle was disposed of (sold, traded, etc.).']
  disposition_odometer varchar [note: 'Mileage recorded at the time of disposition.']
  disposition_type varchar [note: 'How the ownership relationship ended.']
  insurance_carrier varchar [note: 'Company providing the vehicle\'s insurance coverage.']
  insurance_expiry date [note: 'Date the insurance coverage ends.']
  insurance_policy_number varchar [note: 'Identifier of the insurance policy covering the vehicle.']
  is_primary_vehicle boolean [note: 'True if this vehicle is the primary vehicle for the customer household.']
  lien_holder_name varchar [note: 'Name of the financial institution or entity holding a lien on the vehicle.']
  odometer_at_acquisition varchar [note: 'Vehicle mileage recorded at the time of acquisition.']
  ownership_number varchar [note: 'Business identifier for the ownership agreement between the customer and the manufacturer/dealer.']
  ownership_type varchar [note: 'Classification of how the vehicle is held by the customer.']
  purchase_price decimal(12,2) [note: 'Amount paid by the customer for the vehicle at acquisition.']
  registration_country varchar [note: 'Three‑letter country code of the registration jurisdiction.']
  registration_expiry date [note: 'Date the vehicle registration expires.']
  registration_number varchar [note: 'Official license plate number assigned to the vehicle.']
  registration_state varchar [note: 'State or province where the vehicle is registered.']
  title_number varchar [note: 'Legal document number proving ownership.']
  title_state varchar [note: 'State that issued the title.']
  trade_in_vin varchar [note: 'VIN of a vehicle traded in as part of the acquisition, if applicable.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the ownership record.']
  vehicle_ownership_status varchar [note: 'Current lifecycle state of the ownership record.']

  Note: 'Tracks the ownership history of vehicles by customers — the authoritative record linking a customer (party) to a VIN. Captures: VIN, party_id (owner), ownership type (retail purchase/lease/fleet/government), acquisition date, acquisition channel (dealer/direct/auction/fleet), acquisition dealer code, purchase price, trade-in VIN, registration state/country, registration number, registration expiry, title number, title state, lien holder name, insurance carrier, insurance policy number, insurance expiry, odometer at acquisition, current odometer (last reported), is_primary_vehicle flag, disposition type (sold/traded/totaled/repossessed), disposition date, and disposition odometer. SSOT for customer-vehicle relationship; cross-references vehicle domain VIN master.'
}

Table customer.preference {
  preference_id varchar [pk, note: 'Unique system-generated identifier for each preference entry.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: CRM and loyalty programs track customer vehicle model preferences for targeted marketing, next-purchase recommendations, and conquest campaigns. A domain expert would expect preference records to refe']
  party_id varchar [note: 'Identifier of the customer (person or organization) to whom the preference applies.']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Customer preference records capturing vehicle segment interest (e.g., EV preference, truck preference) drive OEM product recommendation engines and next-best-offer campaigns. Linking preference to pro']
  category varchar [note: 'High‑level grouping of the preference (e.g., communication, vehicle feature, service scheduling, digital experience, privacy).']
  channel varchar [note: 'Preferred channel for delivering communications when the preference_category is \'communication\'.']
  confidence_score decimal(5,4) [note: 'Confidence level (0.0000‑1.0000) that the stored preference accurately reflects the customer\'s intent.']
  created_timestamp timestamp [note: 'Timestamp when the preference record was first created in the system.']
  data_origin_system varchar [note: 'Identifies the source system that supplied the preference record.']
  effective_date date [note: 'Date on which the preference becomes active.']
  expiry_date date [note: 'Date after which the preference is no longer valid; null if indefinite.']
  is_opt_out boolean [note: 'True if the customer has explicitly opted out of the indicated preference; otherwise false.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the preference record.']
  notes varchar [note: 'Optional free‑form comments or remarks about the preference.']
  preference_status varchar [note: 'Current lifecycle state of the preference (e.g., active, inactive, expired, pending review).']
  source varchar [note: 'Origin of the preference record: self‑declared by the customer, inferred by analytics, or imported from an external system.']
  value decimal(18,2) [note: 'The value assigned to the preference key; stored as text and interpreted according to value_data_type.']
  value_data_type varchar [note: 'Indicates the native data type of preference_value (e.g., string, boolean, integer, list).']

  Note: 'Stores customer-declared and inferred preferences for communications, vehicle features, service scheduling, and digital experiences. Each record captures: party_id, preference category (communication/vehicle/service/digital/privacy), preference key (e.g., preferred_fuel_type, preferred_body_style, preferred_service_day, email_frequency), preference value, value data type (string/boolean/integer/list), source (self-declared/inferred/imported), confidence score, effective date, expiry date, and last updated timestamp. Supports personalized marketing, product recommendation engines, and connected vehicle feature configuration.'
}

Table customer.consent_record {
  consent_record_id varchar [pk, note: 'Unique identifier for the customer_consent_record data product (auto-inserted pre-linking).']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Jurisdiction-Specific Consent Management: GDPR, CCPA, and other privacy laws are jurisdiction-specific. This FK replaces the denormalized `jurisdiction` text column, enabling consent validity checks, ']
  party_id varchar [note: 'Customer party who gave consent']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Consent Compliance Audit: Consent records must reference the specific regulatory requirement (GDPR Article 7, CCPA §1798.100) that mandates them. This FK replaces the denormalized `regulation_referenc']
  channel varchar [note: 'Channel through which consent was obtained']
  consent_channel varchar
  consent_date date
  consent_expiry_date date
  consent_given_flag boolean
  consent_granted_at timestamp
  consent_granted_flag boolean
  consent_granted_timestamp timestamp [note: 'When consent was granted.']
  consent_purpose varchar
  consent_revoked_timestamp timestamp
  consent_source_system varchar
  consent_status varchar [note: 'Current consent status (granted, withdrawn, expired)']
  consent_text_version varchar
  consent_timestamp timestamp
  consent_type varchar [note: 'Type of consent (marketing, data sharing, telematics, profiling)']
  consent_withdrawn_at timestamp
  consent_withdrawn_timestamp timestamp [note: 'When consent was withdrawn, if applicable.']
  created_timestamp timestamp
  double_opt_in_flag boolean
  expiry_date date [note: 'Date consent expires']
  granted_date date [note: 'Date consent was granted']
  legal_basis varchar [note: 'Legal basis for processing (GDPR Art 6)']
  opt_in_flag boolean
  purpose_description varchar
  updated_timestamp timestamp
  version_number varchar
  withdrawal_date date [note: 'Date consent was withdrawn if applicable']

  Note: 'SSOT for all customer consent and privacy preference records required under GDPR, CCPA, TCPA, and CAN-SPAM regulations. Captures: party_id, consent type (marketing_email/marketing_sms/telematics_data/data_sharing/profiling/cookies), consent status (granted/withdrawn/pending), consent version (policy version at time of consent), consent date, withdrawal date, consent channel (web/app/dealer/call_center/paper), IP address at consent, geolocation at consent, consent text snapshot, legal basis (consent/legitimate_interest/contract/legal_obligation), data processing purpose, third_party_sharing_flag, retention period (days), and regulatory jurisdiction (GDPR/CCPA/PIPEDA/LGPD). Critical for regulatory compliance and privacy-by-design.'
}

Table customer.fleet_account {
  fleet_account_id varchar [pk, note: 'Unique identifier for the customer_fleet_account data product (auto-inserted pre-linking).']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Fleet accounts are managed through a primary dealership for fleet sales, service contracts, and OEM incentive program administration. Fleet account management reporting and dealer fleet revenue attrib']
  organization_account_id varchar [note: 'Foreign key linking to customer.organization_account. Business justification: customer_fleet_account is a specialized entity for fleet customers — commercial, government, and rental fleet operators. These are inherently B2B entities that correspond to an organization_account. L']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Customer fleet accounts represent fleet customers; linking to the master party provides identity context and connects the product to the graph.']
  account_end_date date
  account_name varchar [note: 'Name of the fleet account']
  account_number varchar [note: 'Fleet account number']
  account_start_date date
  account_status varchar [note: 'Account status (active, suspended, closed)']
  annual_spend decimal(18,2) [note: 'Annual fleet spend amount']
  annual_spend_amount decimal(18,2)
  billing_currency varchar
  billing_terms varchar
  contract_end_date date [note: 'Fleet contract end date']
  contract_reference varchar
  contract_start_date date [note: 'Fleet contract start date']
  created_timestamp timestamp
  credit_limit decimal(18,2) [note: 'Credit limit assigned to the fleet account.']
  credit_limit_amount decimal(18,2)
  discount_tier varchar
  fleet_account_number varchar
  fleet_account_status varchar [note: 'Status of the fleet account (active, suspended, closed).']
  fleet_account_type varchar
  fleet_size varchar [note: 'Number of vehicles in the fleet']
  fleet_type varchar [note: 'Type of fleet (commercial, government, rental).']
  industry_sector varchar
  name varchar
  primary_contact_email varchar
  primary_contact_phone varchar
  updated_timestamp timestamp

  Note: 'Specialized master entity for fleet customer accounts — commercial, government, and rental fleet operators — extending organization_account with fleet-specific attributes. Captures: organization_account_id, fleet type (commercial/government/rental/utility/emergency), fleet size (total vehicles), active_fleet_size, annual_replacement_volume, preferred_vehicle_segments (sedan/SUV/truck/van/EV/commercial), preferred_powertrain (ICE/HEV/PHEV/EV), fleet management system name, telematics provider, upfitter name, dedicated fleet sales rep, fleet pricing tier, volume discount percentage, fleet program code, government contract number, GSA schedule number, state contract number, annual spend, and fleet account status. Supports fleet sales operations, volume pricing, and government procurement compliance.'
}

Table customer.case {
  case_id varchar [pk, note: 'Unique system-generated identifier for the customer service case.']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Customer case management and dealer accountability reporting require knowing which dealership a case is associated with (purchase complaints, warranty disputes, service failures). OEM dealer performan']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: Warranty/quality traceability: when a customer raises a defect case, the OEM must trace the failure back to the specific inbound part and supplier for 8D corrective action, warranty cost recovery, and']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Warranty and quality case management requires identifying the specific defective part involved. Automotive OEMs link customer cases to part_master for recall tracking, warranty cost allocation by part']
  party_id varchar [note: 'Identifier of the customer (individual, fleet, corporate) who raised the case.']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall-Driven Case Management: Customer service cases are frequently opened in response to recall campaigns. This FK links cases to the triggering recall for SLA tracking, remedy status reporting, and']
  retail_sale_id varchar [note: 'Foreign key linking to dealer.retail_sale. Business justification: Post-sale customer cases (lemon law claims, purchase disputes, misrepresentation complaints) must be traceable to the originating retail sale for OEM dispute resolution, dealer chargeback processing, ']
  supplier_id varchar [note: 'Foreign key linking to supply.supply_supplier. Business justification: Supplier warranty chargeback and corrective action: customer quality cases attributable to a supplier defect require direct supplier attribution for warranty cost recovery, supplier scorecard impact, ']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Warranty and quality case investigation requires direct access to the vehicle\'s build record (rework_count, end_of_line_test_result, andon_call_count). Automotive warranty teams routinely pull build d']
  vehicle_ownership_id varchar [note: 'Foreign key linking to customer.vehicle_ownership. Business justification: A customer service case (warranty claim, recall notification, complaint) is frequently filed in the context of a specific vehicle ownership record — capturing not just which vehicle (vin_registry_id a']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Needed for service case management to pull vehicle specifications, warranty status, and recall info from VIN registry.']
  case_number varchar [note: 'Business-visible case number assigned at creation.']
  case_status varchar [note: 'Current lifecycle state of the case.']
  case_type varchar [note: 'High-level classification of the case purpose.']
  category varchar [note: 'Primary business category for the case (e.g., Service, Sales, Technical).']
  closed_timestamp timestamp [note: 'Date and time when the case was finally closed.']
  customer_satisfaction_score varchar [note: 'Post‑resolution satisfaction rating provided by the customer (e.g., 1‑10).']
  description varchar [note: 'Full free‑text description of the issue, request or complaint.']
  dynamics_case_reference varchar [note: 'Native Microsoft Dynamics 365 identifier for the case.']
  escalation_level varchar [note: 'Level of escalation applied to the case, if any.']
  escalation_reason varchar [note: 'Reason why the case was escalated.']
  opened_timestamp timestamp [note: 'Date and time when the case was initially created.']
  priority varchar [note: 'Business priority level indicating urgency (P1 highest).']
  record_audit_created timestamp [note: 'System timestamp when the case record was first persisted.']
  record_audit_updated timestamp [note: 'System timestamp of the most recent update to the case record.']
  resolution_code varchar [note: 'Standard code representing how the case was resolved.']
  resolution_description varchar [note: 'Free‑text description of the resolution actions taken.']
  resolved_timestamp timestamp [note: 'Date and time when the case was marked as resolved.']
  salesforce_case_reference varchar [note: 'Native Salesforce identifier for the case record.']
  sla_due_timestamp timestamp [note: 'Target date/time by which the case should be resolved per Service Level Agreement.']
  source_channel varchar [note: 'Channel through which the case was originally submitted.']
  sub_category varchar [note: 'More detailed sub‑category within the main category.']
  subject varchar [note: 'Brief title or subject line summarising the case.']
  total_handle_time_minutes varchar [note: 'Cumulative time spent handling the case, measured in minutes.']

  Note: 'Customer service case record tracking complaints, inquiries, warranty claims, recall notifications, and roadside assistance requests raised by customers through any channel. Captures: party_id, VIN (if vehicle-related), case number, case type (complaint/inquiry/warranty_claim/recall/roadside/goodwill/lemon_law/regulatory), case category, case sub-category, subject, description, priority (P1-P4), status (new/in_progress/pending_customer/resolved/closed/escalated), opened date, SLA due date, resolved date, closed date, resolution code, resolution description, dealer code (if dealer-handled), assigned agent ID, escalation level, escalation reason, total handle time (minutes), customer satisfaction score (post-resolution), Salesforce Case ID, and Microsoft Dynamics 365 Case ID. SSOT for customer service operations.'
}

Table sales.opportunity {
  opportunity_id varchar [pk, note: 'Unique identifier for the sales opportunity record. Primary key.']
  campaign_id varchar [note: 'Reference to the marketing campaign that generated this opportunity, if applicable.']
  dealership_id varchar [note: 'Reference to the dealership managing this opportunity.']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: Pre-sale compliance validation: sales teams must confirm the target vehicle model is homologated for the customer\'s market before progressing a deal. Linking opportunity to homologation_record enables']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Opportunity tracking by model enables sales forecasting, market analysis, and model performance dashboards.']
  msrp_price_book_id varchar [note: 'Foreign key linking to product.msrp_price_book. Business justification: Opportunity valuation and pipeline reporting require knowing which MSRP price book was active when the opportunity was created. Sales managers use this for pricing audit trails, deal desk approvals, a']
  opportunity_customer_party_id varchar [note: 'Reference to the prospect or customer associated with this opportunity.']
  opportunity_party_id varchar [note: 'Reference to the prospect or customer associated with this opportunity.']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Opportunity-level powertrain selection drives EV tax credit eligibility determination, incentive program matching, and electrification sales mix reporting. \'powertrain_type\' is a denormalized string; ']
  trim_level_id varchar [note: 'Foreign key linking to vehicle.vehicle_trim_level. Business justification: Sales opportunities are configured to a specific trim level for accurate pricing, incentive eligibility, and sales mix reporting. Trim-level opportunity tracking is standard in automotive CRM for gros']
  actual_close_date date [note: 'Actual date when the opportunity was closed (won or lost).']
  competitor_brand varchar [note: 'Competitor brand or OEM that the customer is also considering, if known.']
  created_timestamp timestamp [note: 'Timestamp when the opportunity record was first created in the system.']
  delivery_location varchar [note: 'Preferred delivery location or dealership for vehicle handover.']
  digital_channel_source varchar [note: 'Digital channel source (configurator, website, app, marketplace)']
  discount_amount decimal(18,2) [note: 'Total discount amount applied to the opportunity, including dealer discounts and manufacturer incentives.']
  estimated_value decimal(18,2) [note: 'Estimated total deal value including vehicle price, options, accessories, and services.']
  expected_close_date date [note: 'Anticipated date when the opportunity is expected to close (either won or lost).']
  exterior_color varchar [note: 'Preferred exterior color for the vehicle.']
  financing_type varchar [note: 'Type of financing or payment method the customer intends to use.']
  fiscal_year varchar [note: 'Fiscal year in which the opportunity is expected to close, used for sales forecasting and quota tracking.']
  fleet_size varchar [note: 'Number of vehicles in the fleet opportunity, applicable for fleet and commercial sales.']
  fni_interest_flag boolean
  incentive_amount decimal(18,2) [note: 'Total manufacturer incentive amount applicable to this opportunity.']
  interior_color varchar [note: 'Preferred interior color or trim for the vehicle.']
  is_active boolean [note: 'Indicates whether the opportunity is currently active (open) or closed.']
  is_certified_pre_owned_interest boolean
  is_online_lead boolean
  is_won boolean [note: 'Indicates whether the opportunity was closed as won (successful sale).']
  last_activity_date date [note: 'Date of the most recent sales activity or interaction related to this opportunity.']
  last_modified_timestamp timestamp [note: 'Timestamp when the opportunity record was last modified.']
  lead_source varchar [note: 'Original channel or source through which the opportunity was generated. [ENUM-REF-CANDIDATE: web|phone|email|walk_in|referral|event|advertising|social_media|partner — 9 candidates stripped; promote to reference product]']
  loss_reason varchar [note: 'Primary reason why the opportunity was lost, if applicable. [ENUM-REF-CANDIDATE: price|product_fit|competitor|timing|financing|no_response|other — 7 candidates stripped; promote to reference product]']
  model_year varchar [note: 'Model year of the vehicle of interest in this opportunity.']
  msrp decimal(18,2) [note: 'Manufacturer Suggested Retail Price for the vehicle configuration of interest.']
  name varchar [note: 'Descriptive name of the opportunity, typically including prospect name and vehicle of interest.']
  next_follow_up_date date [note: 'Scheduled date for the next follow-up activity with the prospect.']
  notes varchar [note: 'Free-text notes and comments about the opportunity, customer preferences, and sales interactions.']
  opportunity_number varchar [note: 'Business-facing unique identifier for the opportunity, typically auto-generated and used in communications with dealers and sales teams.']
  opportunity_type varchar [note: 'Classification of the opportunity based on customer segment and purchase type.']
  priority varchar [note: 'Priority level assigned to this opportunity based on strategic importance, deal size, or customer value.']
  probability decimal(5,2) [note: 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0-100).']
  quote_date date [note: 'Date when the quote was generated, if applicable.']
  quote_generated boolean [note: 'Indicates whether a formal quote has been generated for this opportunity.']
  region varchar [note: 'Geographic sales region where this opportunity is being managed.']
  sales_stage varchar [note: 'Current stage of the opportunity in the sales pipeline, reflecting progression from initial contact through close. [ENUM-REF-CANDIDATE: lead|qualification|needs_analysis|test_drive|quote|negotiation|closed_won|closed_lost — 8 candidates stripped; promote to reference product]']
  subscription_interest_flag boolean [note: 'Whether prospect is interested in subscription/VaaS']
  territory varchar [note: 'Sales territory within the region where this opportunity is being managed.']
  test_drive_completed boolean [note: 'Indicates whether the prospect has completed a test drive for the vehicle of interest.']
  test_drive_date date [note: 'Date when the test drive was completed, if applicable.']
  trade_in_value decimal(18,2) [note: 'Appraised value of the customer\'s trade-in vehicle, if applicable.']
  vehicle_configuration varchar [note: 'Detailed configuration of the vehicle including trim level, options, and packages.']
  win_reason varchar [note: 'Primary reason why the opportunity was won, if applicable. [ENUM-REF-CANDIDATE: price|product_features|brand_loyalty|service|financing|relationship|other — 7 candidates stripped; promote to reference product]']

  Note: 'Core sales opportunity record tracking a potential vehicle sale from initial identification through close. Captures prospect vehicle interest, estimated deal value, probability of close, sales stage, assigned sales representative, source channel, and expected close date. Aligns with Salesforce Automotive Cloud Opportunity object and SAP SD pre-sales pipeline. Covers retail, fleet, and commercial vehicle opportunities.'
}

Table sales.lead {
  lead_id varchar [pk, note: 'Unique identifier for the sales lead record. Primary key.']
  campaign_id varchar [note: 'Identifier of the marketing campaign that generated this lead, if applicable.']
  contact_point_id varchar [note: 'Foreign key linking to customer.contact_point. Business justification: CRM lead management requires linking leads to canonical contact_point records for deduplication, consent enforcement, and omnichannel follow-up. Lead currently stores denormalized contact fields; a co']
  converted_opportunity_id varchar [note: 'Identifier of the opportunity record created upon lead conversion. Null if not yet converted.']
  lead_assigned_dealer_dealership_id varchar [note: 'Identifier of the dealership assigned to this lead for follow-up and conversion.']
  lead_dealership_id varchar [note: 'Identifier of the dealership assigned to this lead for follow-up and conversion.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Lead management and demand forecasting require linking a lead to the specific vehicle model of interest. Model-level lead pipeline reports, marketing attribution, and inventory planning all depend on ']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Associates leads with existing parties for referral tracking and lead conversion analysis in the Lead Management process.']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Marketing and sales analytics require classifying leads by product segment to measure segment-level lead conversion rates, cost-per-lead by segment, and campaign ROI. Lead routing rules also depend on']
  company_name varchar [note: 'Name of the organization or company associated with the lead, applicable for fleet sales or commercial vehicle inquiries.']
  converted_date date [note: 'The date when the lead was converted into an opportunity. Null if not yet converted. Format: yyyy-MM-dd.']
  cpo_interest_flag boolean
  created_timestamp timestamp [note: 'The date and time when the lead record was first created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the estimated budget amount.']
  digital_lead_flag boolean [note: 'Whether lead originated from digital channel']
  estimated_budget_amount decimal(15,2) [note: 'Estimated budget or price range the lead has indicated for the vehicle purchase.']
  financing_interest boolean [note: 'Boolean flag indicating whether the lead is interested in financing or leasing options.']
  first_name varchar [note: 'The first name (given name) of the individual lead contact.']
  is_online_lead boolean
  last_contact_date date [note: 'The date when the lead was last contacted by a sales representative. Format: yyyy-MM-dd.']
  last_name varchar [note: 'The last name (family name) of the individual lead contact.']
  lead_number varchar [note: 'Human-readable business identifier for the lead, typically auto-generated by the CRM system. Format: LEAD-NNNNNNNN.']
  lead_status varchar [note: 'Current lifecycle status of the lead in the sales pipeline (new, contacted, qualified, unqualified, converted to opportunity, lost).']
  lead_type varchar [note: 'Classification of the lead based on buyer category: individual consumer, fleet buyer, commercial enterprise, or government entity.']
  lost_reason varchar [note: 'Reason why the lead was marked as lost (e.g., purchased from competitor, no longer interested, unresponsive).']
  model_year_interest varchar [note: 'The model year (MY) of the vehicle the lead is interested in purchasing.']
  modified_timestamp timestamp [note: 'The date and time when the lead record was last modified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  next_follow_up_date date [note: 'Scheduled date for the next follow-up activity with the lead. Format: yyyy-MM-dd.']
  notes varchar [note: 'Free-text notes and comments captured by sales representatives regarding the leads preferences, objections, and conversation history.']
  opt_in_email boolean [note: 'Boolean flag indicating whether the lead has opted in to receive email marketing communications.']
  opt_in_phone boolean [note: 'Boolean flag indicating whether the lead has opted in to receive phone call communications.']
  opt_in_sms boolean [note: 'Boolean flag indicating whether the lead has opted in to receive SMS marketing communications.']
  purchase_timeframe varchar [note: 'Expected timeframe within which the lead intends to make a purchase decision (immediate, within 30 days, within 90 days, within 6 months, or future/undecided).']
  qualification_score varchar [note: 'Numeric score (0-100) representing the leads likelihood to convert, based on engagement, budget, authority, need, and timeline (BANT criteria).']
  rating varchar [note: 'Qualitative rating of the lead based on engagement and conversion potential: hot (high priority), warm (moderate interest), cold (low engagement).']
  referral_source varchar [note: 'Name or identifier of the person or entity that referred this lead, if applicable.']
  region varchar [note: 'Geographic region or sales territory where the lead is located (e.g., North America, Europe, Asia-Pacific).']
  source varchar [note: 'The origin channel through which the lead was captured (web inquiry, dealer walk-in, automotive event, customer referral, digital marketing campaign, phone inquiry).']
  subscription_interest_flag boolean
  test_drive_requested boolean [note: 'Boolean flag indicating whether the lead has requested a test drive.']
  trade_in_interest boolean [note: 'Boolean flag indicating whether the lead has expressed interest in trading in an existing vehicle as part of the purchase.']
  unqualified_reason varchar [note: 'Reason why the lead was marked as unqualified (e.g., no budget, no authority, no need, incorrect contact information).']
  vehicle_interest_category varchar [note: 'The powertrain category of vehicle the lead is interested in: ICE (Internal Combustion Engine), EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), or PHEV (Plug-in Hybrid Electric Vehicle).']
  web_form_code varchar [note: 'Identifier of the web form or landing page through which the lead was captured, used for digital campaign attribution.']

  Note: 'Inbound or outbound sales lead representing an individual or organization expressing interest in purchasing a vehicle. Tracks lead source (web, dealer walk-in, event, referral, digital campaign), lead status, assigned owner, vehicle interest category (ICE, EV, HEV, PHEV), and qualification score. Feeds into opportunity pipeline upon qualification. Sourced from Salesforce Automotive Cloud Lead object.'
}

Table sales.quote {
  quote_id varchar [pk, note: 'Primary key for quote']
  catalog_version_id varchar [note: 'Foreign key linking to product.catalog_version. Business justification: Automotive quoting systems must reference a specific catalog version to validate that quoted options, packages, and configurations are available and correctly priced. Configuration validity checks, op']
  configuration_id varchar [note: 'Foreign key linking to vehicle.vehicle_configuration. Business justification: Quote must be tied to a specific vehicle configuration to calculate options, OTA updates, and compliance; supports configuration‑based pricing.']
  fleet_contract_id varchar [note: 'Foreign key linking to sales.fleet_contract. Business justification: Fleet quotes are issued under a fleet contract framework, applying contract-specific pricing, discount tiers, and eligible nameplates. Linking quote.fleet_contract_id → fleet_contract.fleet_contract_i']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Required for Quote generation to reference the exact vehicle model, ensuring pricing consistency and enabling model‑level reporting.']
  msrp_price_book_id varchar [note: 'Foreign key linking to product.msrp_price_book. Business justification: Quote generation must reference the active MSRP price book to ensure correct base pricing, incentive eligibility, and pricing audit compliance. Finance and pricing teams require this link to audit whi']
  msrp_pricing_id varchar [note: 'Foreign key linking to vehicle.msrp_pricing. Business justification: The quote process must reference the authoritative MSRP pricing record for price audit trails, regulatory price disclosure compliance, and dealer margin calculation. Linking quote to msrp_pricing ensu']
  opportunity_id varchar [note: 'Reference to the sales opportunity or lead that generated this quote. Tracks quote back to pipeline stage in Salesforce Automotive Cloud.']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Quote-level powertrain FK is required for accurate F&I product matching, EV tax credit eligibility calculation, and emissions compliance documentation. \'powertrain_type\' on quote is a denormalized str']
  quote_customer_party_id varchar [note: 'Reference to the customer or prospect receiving this quote. Links to customer master data in SAP or Salesforce Automotive Cloud.']
  quote_dealer_dealership_id varchar [note: 'Reference to the dealership or direct sales channel issuing the quote. Links to dealer master data in CDK Global DMS or SAP.']
  quote_dealership_id varchar [note: 'Reference to the dealership or direct sales channel issuing the quote. Links to dealer master data in CDK Global DMS or SAP.']
  quote_party_id varchar [note: 'Reference to the customer or prospect receiving this quote. Links to customer master data in SAP or Salesforce Automotive Cloud.']
  quote_vehicle_vin_registry_id varchar [note: 'Reference to the specific vehicle configuration being quoted. Links to vehicle master data including model, trim, powertrain, and options.']
  quote_vin_registry_id varchar [note: 'Reference to the specific vehicle configuration being quoted. Links to vehicle master data including model, trim, powertrain, and options.']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Quote generation in automotive requires referencing the vehicle program to validate available powertrains, model years, and pricing constraints. Sales pricing teams use program specs to set floor pric']
  accessories_total decimal(15,2) [note: 'Total value of dealer-installed accessories (e.g., floor mats, cargo organizers, protection packages). Separate from factory options.']
  apr_rate decimal(5,3) [note: 'Annual percentage rate for financing if offered. Expressed as decimal (e.g., 0.0399 for 3.99% APR). Subject to credit approval.']
  buy_rate_apr decimal(5,3)
  conversion_date date [note: 'Date when quote was converted to order. Used for sales cycle time analytics and conversion rate reporting.']
  converted_to_order boolean [note: 'Indicates whether this quote was successfully converted to a customer order. True when customer accepts quote and order is created in SAP SD.']
  created_timestamp timestamp [note: 'Timestamp when this quote record was first created in the system. Audit trail for record creation.']
  credit_tier varchar
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this quote (e.g., USD, CAD, EUR, MXN).']
  delivery_method varchar [note: 'Method by which customer will take delivery of vehicle. Dealer pickup is standard; home delivery, port pickup (for imports), and factory pickup (for premium brands) are alternatives.']
  destination_charge decimal(15,2) [note: 'Freight and delivery charge from manufacturing plant to dealer. Typically a fixed amount per vehicle set by OEM.']
  doc_fee decimal(15,2) [note: 'Dealer documentation and administrative fee for processing the sale. Regulated by state law in many jurisdictions.']
  down_payment decimal(15,2) [note: 'Customer down payment amount if financing is offered. Reduces amount financed and monthly payment.']
  drivetrain varchar [note: 'Drivetrain configuration: FWD (Front-Wheel Drive), RWD (Rear-Wheel Drive), AWD (All-Wheel Drive), 4WD (Four-Wheel Drive).']
  engine_code varchar [note: 'Internal code identifying the specific engine or electric motor configuration. Used for parts ordering and service documentation.']
  estimated_delivery_date date [note: 'Estimated date when vehicle will be available for customer delivery. For in-stock vehicles, typically within days; for build-to-order, may be weeks or months.']
  expiry_date date [note: 'Date when the quote expires and pricing/terms are no longer valid. Typically 30-90 days from quote_date depending on market and vehicle type.']
  extended_warranty_flag boolean
  exterior_color_code varchar [note: 'Code representing the exterior paint color selected by customer. Links to color master data and may affect pricing for premium colors.']
  fi_monthly_payment_estimate decimal(18,2) [note: 'Estimated monthly F&I payment included in quote']
  financing_offered boolean [note: 'Indicates whether financing terms are included in this quote. True if quote includes loan or lease options, false for cash-only quotes.']
  financing_term_months varchar [note: 'Length of financing term in months if financing_offered is true. Common terms: 36, 48, 60, 72, 84 months.']
  fni_product_type varchar [note: 'F&I product offered (loan/lease/balloon)']
  gap_insurance_flag boolean
  incentive_total decimal(15,2) [note: 'Total value of manufacturer incentives, rebates, and discounts applied to this quote (e.g., loyalty bonus, conquest incentive, EV tax credit eligibility). Reduces net selling price.']
  interior_color_code varchar [note: 'Code representing the interior upholstery and trim color selected by customer.']
  is_certified_pre_owned boolean
  lease_annual_mileage varchar [note: 'Annual mileage allowance for lease if offered. Common values: 10000, 12000, 15000 miles per year. Excess mileage incurs per-mile charges.']
  lease_monthly_payment decimal(15,2) [note: 'Estimated monthly lease payment if lease is offered. Based on capitalized cost, residual value, money factor, and term.']
  lease_offered boolean [note: 'Indicates whether lease terms are included in this quote as an alternative to purchase financing.']
  lease_term_months varchar [note: 'Length of lease term in months if lease_offered is true. Common terms: 24, 36, 39, 48 months.']
  lender_name varchar
  model_year varchar [note: 'Model year of the vehicle being quoted. Critical for pricing, incentive eligibility, and inventory management.']
  modified_by varchar [note: 'User ID or name of the person who last modified this quote record. Audit trail for change tracking.']
  modified_timestamp timestamp [note: 'Timestamp when this quote record was last modified. Audit trail for record updates and revisions.']
  money_factor decimal(8,6)
  monthly_payment decimal(15,2) [note: 'Estimated monthly payment amount if financing is offered. Calculated from amount financed, APR, and term. Subject to credit approval.']
  msrp_base decimal(15,2) [note: 'Base MSRP for the vehicle model and trim before options, accessories, and destination charges. Published pricing from OEM.']
  net_selling_price decimal(15,2) [note: 'Final vehicle price after all incentives and trade-in allowance. Calculated as subtotal_amount - incentive_total - trade_in_allowance + trade_in_payoff. Base for tax calculation.']
  notes varchar [note: 'Free-text notes and comments about the quote. May include special customer requests, configuration details, or sales rep observations.']
  options_total decimal(15,2) [note: 'Total value of factory-installed options and packages selected by customer (e.g., ADAS, premium audio, sunroof). Sum of individual option prices.']
  quote_date date [note: 'Date when the quote was issued to the customer or prospect. Represents the principal business event timestamp for this transaction.']
  quote_number varchar [note: 'Externally visible business identifier for the quote, typically generated by SAP SD (VA21) or Salesforce Automotive Cloud. Used for customer communication and dealer reference.']
  quote_status varchar [note: 'Current lifecycle status of the quote. Tracks progression from draft through approval to conversion or expiry. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|expired|converted|cancelled — 7 candidates stripped; promote to reference product]']
  quote_type varchar [note: 'Classification of quote by sales channel and vehicle delivery format. Retail for individual consumers, fleet for corporate bulk orders, CKD (Completely Knocked Down) and SKD (Semi Knocked Down) for export assembly, commercial for business vehicles, demo for demonstration units. [ENUM-REF-CANDIDATE: retail|fleet|ckd|skd|commercial|demo|export — 7 candidates stripped; promote to reference product]']
  registration_fee decimal(15,2) [note: 'Government registration and title fees for the vehicle. Varies by state/province and vehicle type.']
  rejection_reason varchar [note: 'Free-text reason why quote was rejected or not converted. Captured for loss analysis and sales process improvement.']
  residual_value_amount decimal(15,2)
  residual_value_percentage decimal(5,2)
  sales_channel varchar [note: 'Channel through which quote was generated. Dealer for franchise network, direct for OEM-owned stores, online for digital sales, fleet for corporate accounts, broker for third-party intermediaries.']
  sales_region varchar [note: 'Geographic sales region code where quote was issued. Used for regional pricing, incentive eligibility, and sales performance tracking.']
  sell_rate_apr decimal(5,3)
  subscription_option_flag boolean [note: 'Whether subscription/VaaS option presented in quote']
  subtotal_amount decimal(15,2) [note: 'Subtotal before incentives, trade-in, taxes, and fees. Calculated as msrp_base + options_total + accessories_total + destination_charge.']
  tax_amount decimal(15,2) [note: 'Total sales tax calculated on net_selling_price based on customer delivery location jurisdiction. May include state, county, and local taxes.']
  total_amount decimal(18,2)
  total_amount_due decimal(15,2) [note: 'Final total amount customer must pay. Calculated as net_selling_price + tax_amount + registration_fee + doc_fee. Used for financing calculation or cash payment.']
  trade_in_allowance decimal(15,2) [note: 'Value credited to customer for trade-in vehicle. Based on used vehicle appraisal. Reduces amount due from customer.']
  trade_in_payoff decimal(15,2) [note: 'Outstanding loan balance on trade-in vehicle that must be paid off. If greater than trade_in_allowance, creates negative equity rolled into new financing.']
  trade_in_vin varchar [note: 'VIN of the customer\'s trade-in vehicle if applicable. Used for appraisal lookup and title transfer processing.']
  transmission_type varchar [note: 'Type of transmission: manual, automatic, CVT (Continuously Variable Transmission), DCT (Dual Clutch Transmission), or single-speed (for EVs).']
  trim_level varchar [note: 'Trim or grade level of the vehicle (e.g., Base, Sport, Luxury, Premium). Determines standard equipment and base pricing.']
  valid_until_date date
  version varchar [note: 'Version number of the quote. Increments when quote is revised with updated pricing, configuration, or terms. Supports quote revision history and audit trail.']
  vin varchar [note: '17-character Vehicle Identification Number if quote is for a specific in-stock or allocated vehicle. Null for build-to-order quotes where VIN is not yet assigned.']
  created_by varchar [note: 'User ID or name of the person who created this quote record. Audit trail for accountability.']

  Note: 'Formal vehicle sales quotation issued to a prospect or customer, detailing configured vehicle, MSRP, applied incentives, trade-in allowance, financing terms, accessories, and net selling price. Tracks quote version, expiry date, quote status, and issuing dealer or direct sales channel. Supports retail, fleet, and CKD/SKD export quotes. Linked to SAP SD quotation (VA21) and Salesforce Automotive Cloud Quote.'
}

Table sales.quote_line {
  quote_line_id varchar [pk, note: 'Unique identifier for the quote line item. Primary key.']
  option_package_id varchar [note: 'Foreign key linking to vehicle.vehicle_option_package. Business justification: Quote line for an option package should reference the canonical package entity for accurate pricing, warranty, and regulatory compliance.']
  primary_quote_vehicle_vin_registry_id varchar [note: 'Reference to the specific vehicle configuration being quoted. Applicable when line_type is vehicle. Links to the vehicle master for model, trim, and base specifications.']
  quote_id varchar [note: 'Foreign key reference to the parent quote header. Establishes the header-detail relationship for this line item.']
  availability_status varchar [note: 'Current availability status of the line item. Indicates whether the product is in dealer inventory, allocated from manufacturer, requires build-to-order, is backordered, or has been discontinued.']
  commission_eligible boolean [note: 'Indicates whether this line item is eligible for sales representative commission. Certain line types (fees, trade-ins) may be excluded from commission calculations.']
  commission_rate decimal(5,4) [note: 'Commission rate applied to this line item for sales representative compensation. Expressed as a decimal percentage. May vary by product type and sales program.']
  cost_amount decimal(15,2) [note: 'Dealer cost or transfer price for this line item. Used for margin analysis and profitability reporting. Confidential business data not disclosed to customers.']
  created_timestamp timestamp [note: 'Date and time when this quote line was first created. Recorded in ISO 8601 format with timezone. Used for audit trail and lifecycle tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this line. Typically inherits from quote header but may differ for international fleet quotes.']
  delivery_date date [note: 'Estimated or committed delivery date for this line item. Critical for customer expectations, logistics planning, and order fulfillment tracking.']
  discount_amount decimal(15,2) [note: 'Total discount applied to this line item. Includes dealer discounts, promotional discounts, and volume discounts. Expressed as a positive value that reduces the line total.']
  discount_percentage decimal(5,2) [note: 'Discount expressed as a percentage of the unit price. Used for percentage-based discount calculations and reporting. Stored alongside discount_amount for transparency.']
  extended_price decimal(15,2) [note: 'Line item subtotal before tax. Calculated as (unit_price * quantity) - discount_amount - incentive_amount. Represents the pre-tax line total.']
  exterior_color_code varchar [note: 'Manufacturer color code for the vehicle exterior paint. Used for vehicle configuration, pricing (premium colors), and inventory matching.']
  fi_product_type varchar [note: 'Type of F&I product if line is F&I (extended_warranty, gap, paint_protection)']
  fni_product_flag boolean
  incentive_amount decimal(15,2) [note: 'Total manufacturer or dealer incentive applied to this line item. Includes cash rebates, loyalty bonuses, conquest incentives, and special financing subsidies. Reduces the customer-facing price.']
  incentive_description varchar [note: 'Human-readable description of the incentive applied. Provides customer-facing explanation of the incentive program, eligibility criteria, and value proposition.']
  interior_color_code varchar [note: 'Manufacturer color code for the vehicle interior trim and upholstery. Used for vehicle configuration, pricing, and customer preference tracking.']
  is_cpo_item boolean
  line_number varchar [note: 'Sequential line item number within the quote. Determines the ordering and display sequence of line items.']
  line_status varchar [note: 'Current lifecycle status of the quote line. Tracks the line through draft, approval, conversion to order, or cancellation workflows.']
  line_total decimal(15,2) [note: 'Total amount for this line item including tax. Calculated as extended_price + tax_amount. Represents the final customer-facing line total.']
  line_type varchar [note: 'Classification of the quote line item. Distinguishes between vehicle configurations, accessories, service packages, warranties, insurance products, fees, discounts, and trade-in credits. [ENUM-REF-CANDIDATE: vehicle|accessory|service_package|warranty|insurance|fee|discount|trade_in — 8 candidates stripped; promote to reference product]']
  list_price decimal(15,2) [note: 'Manufacturer Suggested Retail Price (MSRP) or standard list price for the line item before any discounts or incentives. Expressed in the quote currency.']
  margin_amount decimal(15,2) [note: 'Gross margin for this line item. Calculated as extended_price - cost_amount. Used for profitability analysis and sales performance evaluation.']
  model_code varchar [note: 'Manufacturer model code representing the configured vehicle variant. Includes base model, trim level, and factory option packages. Used for pricing and inventory lookup.']
  model_year varchar [note: 'Model year of the vehicle being quoted. Critical for pricing, incentive eligibility, and inventory allocation. Aligns with manufacturer production cycles.']
  modified_by varchar [note: 'User identifier of the person who last modified this quote line. Supports change tracking and audit requirements.']
  modified_timestamp timestamp [note: 'Date and time of the most recent modification to this quote line. Recorded in ISO 8601 format with timezone. Used for change tracking and audit trail.']
  notes varchar [note: 'Free-text notes and comments specific to this line item. Used for special instructions, configuration details, customer requests, or internal coordination.']
  product_code varchar [note: 'Stock Keeping Unit (SKU) or product code for accessories, service packages, warranties, or other non-vehicle line items. Links to product master for pricing and availability.']
  product_description varchar [note: 'Detailed description of the line item product or service. Includes accessory names, service package details, warranty coverage terms, or fee descriptions for customer clarity.']
  quantity varchar [note: 'Number of units for this line item. Typically 1 for vehicles, but may be greater than 1 for accessories, fleet orders, or service packages.']
  rejection_reason varchar [note: 'Explanation for why this line item was rejected or removed from the quote. Captures business reasons such as unavailability, pricing issues, or customer preference changes.']
  tax_amount decimal(15,2) [note: 'Total sales tax calculated for this line item. Calculated as extended_price * tax_rate. Contributes to the overall quote tax total.']
  tax_code decimal(18,2) [note: 'Tax jurisdiction code determining the applicable sales tax rate for this line item. Links to tax master for rate lookup and tax calculation rules.']
  tax_rate decimal(5,4) [note: 'Sales tax rate applied to this line item, expressed as a decimal (e.g., 0.0825 for 8.25%). Used for tax calculation and compliance reporting.']
  unit_of_measure varchar [note: 'Unit of measure for the line item quantity. Common values include each (vehicles, accessories), set, pair, kit, hour (labor), month/year (subscriptions, warranties). [ENUM-REF-CANDIDATE: each|set|pair|kit|hour|month|year — 7 candidates stripped; promote to reference product]']
  unit_price decimal(15,2) [note: 'Actual selling price per unit after dealer adjustments but before line-level discounts and incentives. May differ from list price due to market conditions or dealer pricing strategy.']
  vin varchar [note: '17-character Vehicle Identification Number uniquely identifying a specific vehicle unit. Populated when quoting a specific in-stock or allocated vehicle. Null for build-to-order quotes.']
  created_by varchar [note: 'User identifier of the sales representative or system user who created this quote line. Used for audit trail and accountability.']

  Note: 'Individual line item within a vehicle sales quote, representing a specific vehicle configuration, accessory, service package, or fee. Captures line type, configured model code, option packages, unit price, discount amount, incentive applied, and line-level tax. Enables multi-vehicle fleet quotes and accessory bundling. Child entity of quote.'
}

Table sales.vehicle_order {
  vehicle_order_id varchar [pk, note: 'Primary key for vehicle_order']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Vehicle orders drive production; the BOM header defines the exact configuration to be manufactured. Order management and plant scheduling systems require this link to validate the ordered configuratio']
  catalog_version_id varchar [note: 'Foreign key linking to product.catalog_version. Business justification: Direct fleet and dealer stock orders placed without a quote must still reference a catalog version to validate the ordered configuration. Order management and compliance reporting require this link to']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Vehicle orders must reference a specific configuration for production scheduling, build-to-order fulfillment, and manufacturing plant assignment. \'vehicle_configuration_code\' is a denormalized string;']
  contact_point_id varchar [note: 'Reference to the specific address where the vehicle will be delivered. Links to customer or dealer address master data.']
  dealership_id varchar [note: 'Reference to the dealership through which the order was placed. Links to the dealer network master data.']
  fleet_contract_id varchar [note: 'Foreign key linking to sales.fleet_contract. Business justification: Vehicle orders placed under a fleet contract must reference that contract at the order header level for pricing, discount tier application, and volume tracking. order_line already has fleet_contract_i']
  homologation_record_id varchar [note: 'Foreign key linking to compliance.homologation_record. Business justification: Regulatory reporting requires each vehicle order to reference the homologation approval authorizing the model for the market.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Model-level order tracking is fundamental for sales volume reporting by nameplate, production planning, and dealer allocation management. \'vehicle_model_code\' is a denormalized string; this FK enables']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: A vehicle_order is the downstream fulfillment of a sales opportunity. Linking vehicle_order.opportunity_id → opportunity.opportunity_id enables end-to-end sales pipeline traceability from opportunity ']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Order-level powertrain FK is required for production scheduling, emissions compliance mix reporting, and incentive reconciliation at order fulfillment. \'powertrain_type\' on vehicle_order is a denormal']
  primary_vehicle_customer_party_id varchar [note: 'Reference to the customer who placed the vehicle order. Links to the customer master data.']
  primary_vehicle_vin_registry_id varchar [note: 'Reference to the specific vehicle unit ordered. For stock orders, links to existing inventory. For build-to-order, links to the vehicle configuration that will be manufactured.']
  production_plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Every vehicle order is assigned to a specific manufacturing plant for production. This link enables plant-level order allocation reporting, delivery lead time calculation by plant, and logistics routi']
  quote_id varchar [note: 'Foreign key linking to sales.quote. Business justification: A vehicle_order is the commercial commitment that results from a converted quote. Linking vehicle_order.quote_id → quote.quote_id formalizes the quote-to-order conversion chain, enabling traceability ']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Order fulfillment tracks against Vehicle Program to manage production volume and delivery timelines.']
  actual_delivery_date date [note: 'Actual date when the vehicle was delivered to the customer or dealer. Used for On-Time Delivery (OTD) performance measurement.']
  build_week varchar [note: 'Scheduled production week for the vehicle in ISO week format (YYYYWWW). Represents the planned Start of Production (SOP) week.']
  cancellation_reason varchar [note: 'Free-text explanation for order cancellation. Populated only when order_status is cancelled. Used for loss analysis and process improvement.']
  committed_delivery_date date [note: 'OEM-committed delivery date communicated to the customer. Represents the contractual delivery obligation.']
  confirmed_date date [note: 'Date when the order was confirmed by the OEM and accepted into the production schedule. Represents the commitment to fulfill the order.']
  created_timestamp timestamp [note: 'Timestamp when this order record was first created in the data platform. Used for audit trail and data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this order.']
  delivery_location varchar [note: 'Type of location where the vehicle will be delivered. Dealer for dealership pickup, customer_address for home delivery, port for export shipments, distribution_center for fleet staging.']
  discount_amount decimal(15,2) [note: 'Total discount amount applied to the MSRP. Includes dealer discounts, promotional offers, and negotiated price reductions.']
  exterior_color_code varchar [note: 'Code representing the selected exterior paint color for the ordered vehicle.']
  financing_reference_number varchar [note: 'External reference number for the financing or lease agreement associated with this vehicle order. Links to the financial institution contract.']
  financing_type varchar [note: 'Source of financing for the vehicle purchase. Captive for OEM-owned finance arm, third_party for external lenders, none for cash purchases.']
  fiscal_year varchar [note: 'Fiscal year in which the order was placed. Used for financial reporting and sales performance tracking.']
  incentive_amount decimal(15,2) [note: 'Total manufacturer incentive amount applied to the order. Includes cash rebates, loyalty bonuses, conquest incentives, and special financing subsidies.']
  interior_color_code varchar [note: 'Code representing the selected interior trim and upholstery color for the ordered vehicle.']
  is_certified_pre_owned boolean
  is_online_order boolean
  is_subscription boolean
  model_year varchar [note: 'Model year designation of the ordered vehicle. Represents the production year classification used for regulatory compliance and marketing.']
  msrp decimal(15,2) [note: 'Manufacturer Suggested Retail Price for the configured vehicle before any discounts, incentives, or dealer adjustments.']
  online_order_flag boolean [note: 'Whether order originated from online/digital channel']
  order_date date [note: 'Date when the customer placed the vehicle order. Represents the business event timestamp for order capture.']
  order_number varchar [note: 'Externally-visible unique order number assigned to the vehicle purchase order. Used for customer communication and dealer reference.']
  order_status varchar [note: 'Current lifecycle status of the vehicle order. Tracks progression from initial placement through manufacturing, shipment, and final delivery to customer. [ENUM-REF-CANDIDATE: draft|placed|confirmed|scheduled|in_production|built|shipped|delivered|cancelled — 9 candidates stripped; promote to reference product]']
  order_timestamp timestamp [note: 'Precise timestamp when the vehicle order was captured in the system. Used for order sequencing and audit trail.']
  order_type varchar [note: 'Classification of the vehicle order by customer segment and sales channel. Retail for individual consumers, fleet for commercial bulk purchases, government for public sector contracts, export for international sales, demo for dealer demonstration vehicles, internal for company use.']
  payment_method varchar [note: 'Method of payment for the vehicle order. Cash for full upfront payment, finance for loan-based purchase, lease for lease agreement, fleet_contract for commercial fleet arrangements.']
  priority_code varchar [note: 'Priority classification for production scheduling. VIP for high-value customers, expedited for rush orders, fleet_priority for large commercial contracts, standard for normal processing.']
  region_code varchar [note: 'Geographic sales region code where the order was placed. Used for regional sales performance analysis and territory management.']
  requested_delivery_date date [note: 'Customer-requested date for vehicle delivery. Used for production planning and logistics scheduling.']
  sales_channel varchar [note: 'Channel through which the order was captured. Dealer for traditional dealership sales, direct for OEM-direct sales, online for e-commerce platform, fleet_sales for commercial fleet division, broker for third-party intermediaries.']
  sales_channel_type varchar
  selling_price decimal(15,2) [note: 'Final agreed selling price for the vehicle after all discounts, incentives, rebates, and negotiations. Represents the actual transaction price.']
  special_instructions varchar [note: 'Free-text field for special handling instructions, customer requests, or delivery notes that require attention during order fulfillment.']
  tax_amount decimal(15,2) [note: 'Total sales tax, value-added tax, or other applicable taxes calculated for the vehicle order based on delivery jurisdiction.']
  total_amount decimal(15,2) [note: 'Total amount payable by the customer including selling price, taxes, fees, and any additional charges minus trade-in value.']
  trade_in_value decimal(15,2) [note: 'Appraised value of the customer trade-in vehicle applied toward the purchase. Null if no trade-in is involved.']
  updated_timestamp timestamp [note: 'Timestamp when this order record was last modified in the data platform. Used for change tracking and audit trail.']
  vin varchar [note: '17-character Vehicle Identification Number assigned to the ordered vehicle. May be null at order placement for build-to-order vehicles and populated when the vehicle enters production.']

  Note: 'Confirmed customer vehicle purchase order capturing the commercial commitment to buy a specific configured vehicle. Records order type (retail, fleet, government, export), ordered VIN or build-to-order configuration, agreed selling price, payment method, financing reference, delivery commitment date, and order status lifecycle (placed, confirmed, in-production, shipped, delivered). Interfaces with SAP SD sales order (VA01) and triggers manufacturing scheduling.'
}

Table sales.order_line {
  order_line_id varchar [pk, note: 'Unique identifier for the order line item. Primary key for the order_line product.']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Build-to-order manufacturing execution requires each order line to reference the governing BOM header to drive production scheduling, component procurement, and standard cost rollup. A production plan']
  configuration_id varchar [note: 'Reference to the detailed vehicle configuration record capturing all selected options, packages, and specifications for this order line.']
  dealership_id varchar [note: 'Reference to the dealership responsible for this order line. Links to dealer network and channel management.']
  fleet_contract_id varchar [note: 'Reference to the fleet sales contract or commercial vehicle agreement governing this line item. Null for retail orders.']
  option_package_id varchar [note: 'Foreign key linking to vehicle.vehicle_option_package. Business justification: Order line must reference option package entity to drive production planning, parts allocation, and warranty tracking.']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Production scheduling uses Order Line to retrieve Part Master details for manufacturing execution.']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: Each order line is fulfilled by a specific manufacturing plant. This FK normalizes the existing plant_code denormalized column, enabling plant-level order line fulfillment reporting, capacity allocati']
  primary_order_trade_in_vehicle_vin_registry_id varchar [note: 'Reference to the trade-in vehicle appraisal record if this order line includes a trade-in transaction. Null if no trade-in.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Each sales order line maps to a production order for fulfillment. This link enables sales teams to track production status per order line — critical for delivery promise management, dealer order statu']
  service_parts_stock_id varchar [note: 'Foreign key linking to inventory.service_parts_stock. Business justification: Parts order fulfillment: sales order lines for service parts must reference the specific stock record being committed/reserved. Automotive parts sales operations require order-line-to-stock linkage fo']
  tertiary_order_vin_registry_id varchar [note: 'Reference to the specific vehicle master record when line_type is vehicle. Links to vehicle configuration and specifications.']
  trade_in_id varchar [note: 'Reference to the trade-in vehicle appraisal record if this order line includes a trade-in transaction. Null if no trade-in.']
  vehicle_order_id varchar [note: 'Foreign key reference to the parent sales order header. Links this line item to its containing order transaction.']
  actual_delivery_date date [note: 'Actual date when the line item was delivered and accepted by the dealer or customer. Triggers revenue recognition.']
  actual_production_date date [note: 'Actual date when vehicle production was completed. Populated from MES upon job completion.']
  allocation_date date [note: 'Date when a specific vehicle unit or inventory item was allocated to fulfill this order line. Null until allocation occurs.']
  cancellation_reason varchar [note: 'Reason code or description explaining why this order line was cancelled. Null for non-cancelled lines.']
  created_timestamp timestamp [note: 'Timestamp when this order line record was first created in the system. Represents the moment of order line capture.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this line item.']
  digital_channel_flag boolean
  discount_amount decimal(15,2) [note: 'Total discount applied to this line item including dealer discounts, promotional discounts, and volume discounts.']
  estimated_delivery_date date [note: 'Estimated date when the line item will be delivered to the dealer or end customer. Updated based on production and logistics schedules.']
  exterior_color_code varchar [note: 'Manufacturer color code for the vehicle exterior paint finish. Links to paint specification and supply chain planning.']
  fi_product_flag boolean [note: 'Whether order line is an F&I product (warranty, GAP, etc.)']
  financing_type varchar [note: 'Method of financing selected for this line item. Indicates whether the customer is paying cash, securing a loan, entering a lease, or using fleet financing.']
  fleet_indicator boolean [note: 'Boolean flag indicating whether this line item is part of a fleet or commercial vehicle order. True for fleet sales, False for retail sales.']
  incentive_amount decimal(15,2) [note: 'Manufacturer or dealer incentive amount applied to this line item. Includes rebates, loyalty bonuses, and promotional incentives.']
  interior_color_code varchar [note: 'Manufacturer color code for the vehicle interior trim and upholstery. Links to interior material specifications.']
  line_number varchar [note: 'Sequential line item number within the parent order. Determines display and processing sequence.']
  line_status varchar [note: 'Current fulfillment status of this order line. Tracks progression from order capture through delivery or cancellation. [ENUM-REF-CANDIDATE: open|allocated|in_production|shipped|delivered|cancelled|on_hold — 7 candidates stripped; promote to reference product]']
  line_total decimal(15,2) [note: 'Total amount for this line item including net price, taxes, and fees. Calculated as (net_price * quantity) plus tax_amount.']
  line_type varchar [note: 'Classification of the order line item indicating whether it represents a vehicle unit, accessory, warranty product, service contract, parts, freight charge, or documentation fee. [ENUM-REF-CANDIDATE: vehicle|accessory|extended_warranty|service_contract|parts|freight|documentation_fee — 7 candidates stripped; promote to reference product]']
  list_price decimal(15,2) [note: 'Manufacturer Suggested Retail Price (MSRP) or catalog list price per unit before any discounts or incentives.']
  model_code varchar [note: 'Manufacturer model code identifying the vehicle platform, body style, and base configuration. Used for production planning and parts allocation.']
  model_year varchar [note: 'Model year designation for the vehicle. Represents the production year classification, not the calendar year of manufacture.']
  modified_timestamp timestamp [note: 'Timestamp when this order line record was last modified. Updated whenever any attribute changes.']
  net_price decimal(15,2) [note: 'Net unit price after applying all discounts and incentives but before taxes and fees. Calculated as list_price minus discount_amount minus incentive_amount.']
  powertrain_type varchar [note: 'Type of powertrain system. ICE=Internal Combustion Engine, HEV=Hybrid Electric Vehicle, PHEV=Plug-in Hybrid Electric Vehicle, BEV=Battery Electric Vehicle, FCEV=Fuel Cell Electric Vehicle.']
  product_description varchar [note: 'Human-readable description of the line item product or service. Provides business context for reporting and customer documentation.']
  quantity decimal(10,2) [note: 'Ordered quantity for this line item. Typically 1 for vehicle units, may be greater than 1 for accessories, parts, or fleet orders.']
  scheduled_production_date date [note: 'Planned Start of Production (SOP) date for this vehicle unit. Applicable only for build-to-order vehicles.']
  ship_date date [note: 'Date when the line item was shipped from the manufacturing plant or distribution center to the dealer or customer.']
  special_instructions varchar [note: 'Free-text field capturing any special handling instructions, customer requests, or delivery notes specific to this order line.']
  tax_amount decimal(15,2) [note: 'Total tax amount for this line item including sales tax, value-added tax, and any applicable excise taxes.']
  unit_of_measure varchar [note: 'Unit of measure for the quantity field. EA=Each, SET=Set, KIT=Kit, HR=Hour (for service contracts), UNIT=Unit.']
  vin varchar [note: '17-character Vehicle Identification Number assigned to this line item when available. May be null at order capture and populated during production allocation. Uniquely identifies the physical vehicle unit.']

  Note: 'Individual line item within a vehicle order representing a specific vehicle unit, accessory, extended warranty, or service contract. Captures VIN assignment (when available), model code, trim level, exterior/interior color, option packages, unit net price, quantity, and line fulfillment status. Supports multi-unit fleet orders with individual VIN-level tracking per line.'
}

Table sales.fleet_contract {
  fleet_contract_id varchar [pk, note: 'Unique identifier for the fleet contract. Primary key for the fleet contract entity.']
  campaign_id varchar [note: 'Foreign key linking to sales.campaign. Business justification: Fleet contracts are frequently driven by structured sales campaigns (e.g., fleet incentive programs, government fleet campaigns). Linking fleet_contract.campaign_id → campaign.campaign_id enables attr']
  fleet_account_id varchar [note: 'Reference to the fleet customer account that holds this contract. Links to the master fleet account entity.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Fleet contracts specify eligible vehicle models for volume pricing and allocation. Model-level fleet contract reporting, GSA schedule compliance, and fleet sales mix analytics all require this FK. \'el']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: Fleet contracts are commercial agreements that originate from a fleet sales opportunity. Linking fleet_contract.opportunity_id → opportunity.opportunity_id enables tracking of which opportunity led to']
  primary_fleet_customer_party_id varchar [note: 'Reference to the primary customer entity associated with this fleet contract. May represent corporate buyer, government agency, or rental company.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Fleet contracts, especially government/GSA contracts (fleet_contract.government_contract_flag, gsa_schedule_number), must comply with specific regulatory requirements such as fleet emissions standards']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Fleet contracts are negotiated at the product segment level (e.g., commercial vans, fleet sedans, EV fleet). Fleet sales reporting, volume discount eligibility, and contract renewal analysis all requi']
  annual_mileage_allowance varchar [note: 'Maximum annual mileage allowed per vehicle under lease terms without excess mileage charges. Typical values range from 10,000 to 25,000 miles per year. Null for purchase contracts.']
  approval_date date [note: 'Date when the fleet contract received final internal approval from sales management or finance. Precedes contract signing.']
  approved_by_user_code varchar [note: 'Reference to the user who granted final approval for this fleet contract. Typically a sales director or VP of fleet sales.']
  auto_renewal_flag boolean [note: 'Indicates whether the contract automatically renews for an additional term unless either party provides notice of non-renewal.']
  base_discount_percentage decimal(5,2) [note: 'Base percentage discount off Manufacturer Suggested Retail Price (MSRP) granted to the fleet customer. Additional volume-based discounts may apply.']
  committed_volume varchar [note: 'Total number of vehicles the fleet customer has committed to purchase or lease under this contract. Used for volume-based pricing tier qualification.']
  contract_name varchar [note: 'Descriptive name or title of the fleet contract, typically including customer name and program identifier for easy reference.']
  contract_number varchar [note: 'Externally-known unique business identifier for the fleet contract, used in communications with fleet customers and internal systems. Format: FC-YYYYNNNN.']
  contract_signed_date date [note: 'Date when the fleet contract was formally signed by both parties. Marks the legal binding of the agreement.']
  contract_status varchar [note: 'Current lifecycle status of the fleet contract. Governs whether new orders can be placed and whether pricing and incentives are active. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|completed — 7 candidates stripped; promote to reference product]']
  contract_term_months varchar [note: 'Duration of the fleet contract expressed in months. Typical terms range from 12 to 60 months for corporate fleets.']
  contract_type varchar [note: 'Classification of the fleet contract based on customer segment and business model. Determines pricing rules, incentive eligibility, and delivery processes.']
  contract_value_amount decimal(18,2) [note: 'Total estimated monetary value of the fleet contract based on committed volume and agreed pricing. Expressed in contract currency.']
  created_timestamp timestamp [note: 'Timestamp when this fleet contract record was first created in the system. Used for audit trail and data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this contract (e.g., USD, EUR, CAD).']
  delivered_volume varchar [note: 'Cumulative count of vehicles delivered to the fleet customer under this contract to date. Updated upon each delivery completion.']
  delivery_schedule_type varchar [note: 'Classification of how vehicles will be delivered over the contract term. Staggered and quarterly schedules are common for large fleet orders.']
  digital_channel_flag boolean
  effective_end_date date [note: 'Date when the fleet contract expires or terminates. After this date, no new orders can be placed under the contract terms. Nullable for open-ended agreements.']
  effective_start_date date [note: 'Date when the fleet contract becomes active and eligible for vehicle orders. Aligns with fiscal year or model year start in many cases.']
  eligible_model_years varchar [note: 'Comma-separated list of model years eligible for purchase under this contract. Typically current and next model year.']
  eligible_powertrain_types varchar [note: 'Comma-separated list of powertrain types eligible under this contract. May include ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), EV (Electric Vehicle), or combinations.']
  financing_type varchar [note: 'Primary financing method for vehicles under this contract. Captive finance refers to manufacturer-owned financing arm.']
  government_contract_flag boolean [note: 'Indicates whether this is a government procurement contract subject to special regulations, reporting requirements, and compliance standards.']
  gsa_schedule_number varchar [note: 'GSA schedule contract number for U.S. federal government fleet purchases. Null for non-government contracts.']
  last_modified_timestamp timestamp [note: 'Timestamp when this fleet contract record was last updated. Tracks the most recent change to any field in the record.']
  lease_term_months varchar [note: 'Duration of lease agreement in months if financing_type is lease. Typical fleet lease terms are 24, 36, or 48 months. Null for cash purchases.']
  maintenance_included_flag boolean [note: 'Indicates whether scheduled maintenance services are included in the fleet contract pricing. Common for lease agreements and full-service fleet contracts.']
  minimum_order_quantity varchar [note: 'Minimum number of vehicles that must be ordered in a single transaction to qualify for fleet contract pricing.']
  multi_location_delivery_flag boolean [note: 'Indicates whether vehicles under this contract will be delivered to multiple locations. True for national fleet accounts with regional distribution.']
  national_fleet_account_flag boolean [note: 'Indicates whether this is a national fleet account with centralized purchasing and multi-region delivery. National accounts receive special pricing and dedicated account management.']
  payment_terms varchar [note: 'Standard payment terms governing when payment is due after vehicle delivery. Net 30/60/90 are common for corporate fleets; government contracts may have custom terms.']
  primary_delivery_location varchar [note: 'Primary geographic location or facility where fleet vehicles will be delivered. May be a corporate headquarters, fleet depot, or distribution center.']
  remaining_volume varchar [note: 'Number of vehicles remaining to be delivered under the committed volume. Calculated as committed_volume minus delivered_volume.']
  renewal_eligible_flag boolean [note: 'Indicates whether this fleet contract is eligible for renewal upon expiration. Based on customer performance, payment history, and strategic account status.']
  sales_region varchar [note: 'Geographic sales region where this fleet contract is managed. Used for regional sales performance tracking and territory management.']
  special_terms_notes varchar [note: 'Free-text field capturing any special terms, conditions, or negotiated provisions unique to this fleet contract that are not captured in standard fields.']
  subscription_model_flag boolean [note: 'Whether fleet contract uses subscription/VaaS model']
  termination_date date [note: 'Date when the fleet contract was terminated prior to its natural expiration. Null for contracts that completed normally or are still active.']
  termination_reason varchar [note: 'Business reason for early termination of the fleet contract. Examples include customer request, breach of terms, business closure, or strategic change.']
  volume_tier_discount_percentage decimal(5,2) [note: 'Additional discount percentage applied when cumulative volume reaches specified tier thresholds. Stacks on top of base discount.']
  warranty_extension_months varchar [note: 'Number of months beyond standard manufacturer warranty that are included in the fleet contract. Zero indicates standard warranty only.']

  Note: 'Commercial agreement governing the sale or lease of multiple vehicles to a fleet customer (corporate, government, rental, utility). Captures fleet account reference, contracted volume commitments, agreed pricing tiers, eligible nameplates and model years, contract term, delivery schedule, fleet incentive program linkage, and contract status. Supports national fleet accounts and government procurement contracts. Distinct from retail sales orders due to volume pricing, multi-delivery scheduling, and contract lifecycle management.'
}

Table sales.trade_in {
  trade_in_id varchar [pk, note: 'Unique identifier for the trade-in transaction record.']
  dealership_id varchar [note: 'Reference to the dealership that appraised and accepted the trade-in vehicle.']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: Trade-in interest is captured at the opportunity stage (opportunity has trade_in_value and trade_in_interest indicators). Linking trade_in.opportunity_id → opportunity.opportunity_id enables tracking ']
  primary_trade_customer_party_id varchar [note: 'Reference to the customer who traded in the vehicle.']
  quote_id varchar [note: 'Foreign key linking to sales.quote. Business justification: Trade-in appraisals are initiated during the quoting process — the quote captures trade_in_allowance, trade_in_payoff, and trade_in_vin. Linking trade_in.quote_id → quote.quote_id formalizes the assoc']
  vehicle_order_id varchar [note: 'Reference to the associated new vehicle purchase order for which this trade-in was accepted.']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Trade-in appraisal requires linking the traded vehicle to its VIN registry record for CPO eligibility verification, recall status check, ownership history validation, and accurate residual value calcu']
  accepted_date date [note: 'Date when the customer and dealership agreed to the trade-in terms and the trade-in was officially accepted.']
  accident_history_flag boolean [note: 'Indicates whether the trade-in vehicle has a reported accident history (True/False).']
  allowance decimal(15,2) [note: 'Agreed-upon credit amount applied toward the new vehicle purchase, which may differ from appraised value due to negotiation.']
  appraisal_date date [note: 'Date when the trade-in vehicle was appraised and evaluated by the dealership.']
  appraised_value decimal(15,2) [note: 'Fair market value of the trade-in vehicle as determined by the dealership appraiser, before negotiation.']
  body_style varchar [note: 'Body style classification of the trade-in vehicle. [ENUM-REF-CANDIDATE: sedan|coupe|suv|truck|van|wagon|convertible|hatchback — 8 candidates stripped; promote to reference product]']
  condition_grade varchar [note: 'Overall condition assessment of the trade-in vehicle based on physical inspection (excellent, good, fair, poor).']
  cpo_eligible_flag boolean [note: 'Whether trade-in vehicle is eligible for CPO certification']
  created_timestamp timestamp [note: 'Timestamp when this trade-in record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this trade-in transaction.']
  digital_channel_flag boolean
  disposition_amount decimal(15,2) [note: 'Actual sale or disposal amount realized when the trade-in vehicle was disposed of, used to calculate trade-in profitability.']
  disposition_date date [note: 'Date when the trade-in vehicle was sold, transferred, or otherwise disposed of by the dealership.']
  disposition_type varchar [note: 'Planned or actual disposition channel for the trade-in vehicle after acceptance (wholesale auction, certified pre-owned program, retail resale, internal fleet, scrap).']
  exterior_color varchar [note: 'Exterior paint color of the trade-in vehicle.']
  exterior_condition varchar [note: 'Assessment of the exterior body condition of the trade-in vehicle (paint, body panels, glass).']
  inspection_completed boolean [note: 'Indicates whether a full mechanical and safety inspection was completed on the trade-in vehicle (True/False).']
  inspection_date date [note: 'Date when the detailed inspection of the trade-in vehicle was completed.']
  interior_color varchar [note: 'Interior upholstery color of the trade-in vehicle.']
  interior_condition varchar [note: 'Assessment of the interior condition of the trade-in vehicle (seats, dashboard, carpets, controls).']
  lien_holder varchar [note: 'Name of the financial institution or entity holding a lien on the trade-in vehicle, if applicable.']
  make varchar [note: 'Manufacturer or brand of the trade-in vehicle (e.g., Ford, Toyota, Honda).']
  mechanical_condition varchar [note: 'Assessment of the mechanical and operational condition of the trade-in vehicle (engine, transmission, drivetrain).']
  model varchar [note: 'Model name of the trade-in vehicle (e.g., F-150, Camry, Accord).']
  model_year varchar [note: 'Model year of the trade-in vehicle as designated by the manufacturer.']
  modified_timestamp timestamp [note: 'Timestamp when this trade-in record was last modified or updated.']
  notes varchar [note: 'Free-form notes and comments regarding the trade-in vehicle, appraisal, condition, or negotiation details.']
  odometer_reading varchar [note: 'Mileage reading on the trade-in vehicle at the time of appraisal, in miles or kilometers as per regional standard.']
  odometer_unit varchar [note: 'Unit of measure for the odometer reading (miles or kilometers).']
  outstanding_loan_balance decimal(15,2) [note: 'Remaining loan balance owed on the trade-in vehicle at the time of trade, if applicable.']
  powertrain_type varchar [note: 'Type of powertrain in the trade-in vehicle: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle).']
  reconditioning_cost decimal(15,2) [note: 'Total cost incurred to recondition the trade-in vehicle for resale (repairs, detailing, inspection).']
  service_records_available boolean [note: 'Indicates whether complete service and maintenance records are available for the trade-in vehicle (True/False).']
  tire_condition varchar [note: 'Assessment of the tire condition and tread depth on the trade-in vehicle.']
  title_status varchar [note: 'Legal title status of the trade-in vehicle (clean, salvage, rebuilt, lemon, flood).']
  trade_in_number varchar [note: 'Business-facing unique transaction number assigned to the trade-in for tracking and reference purposes.']
  transmission_type varchar [note: 'Type of transmission in the trade-in vehicle (manual, automatic, CVT, dual-clutch).']
  trim_level varchar [note: 'Trim or package level of the trade-in vehicle (e.g., LX, EX, Limited, Sport).']

  Note: 'Record of a customer vehicle trade-in evaluated and accepted as part of a new vehicle purchase transaction. Captures trade-in vehicle details (VIN, make, model, year, mileage, condition grade), appraised value, agreed trade-in allowance, appraisal date, appraising dealer, and disposition (wholesale auction, certified pre-owned, retail resale). Links to the associated vehicle order.'
}

Table sales.delivery_appointment {
  delivery_appointment_id varchar [pk, note: 'Unique identifier for the delivery appointment record. Primary key for the delivery appointment entity.']
  dealership_id varchar [note: 'Reference to the dealership or delivery center where the vehicle handover will occur.']
  pdi_technician_id varchar [note: 'Reference to the technician who performed the Pre-Delivery Inspection.']
  primary_delivery_customer_party_id varchar [note: 'Reference to the customer who will take delivery of the vehicle.']
  primary_delivery_vehicle_vin_registry_id varchar [note: 'Reference to the specific vehicle unit being delivered, linked by VIN (Vehicle Identification Number).']
  rescheduled_from_appointment_delivery_appointment_id varchar [note: 'Reference to the previous delivery appointment if this appointment is a rescheduled version.']
  trade_in_id varchar [note: 'Foreign key linking to sales.trade_in. Business justification: The delivery_appointment entity has a trade_in_status field, indicating that trade-in handover is managed as part of the delivery process. Linking delivery_appointment.trade_in_id → trade_in.trade_in_']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Delivery appointments can only be confirmed once vehicle_build is complete (end-of-line test passed). This link enables PDI scheduling based on build completion status, delivery readiness confirmation']
  vehicle_order_id varchar [note: 'Reference to the confirmed vehicle order for which this delivery appointment is scheduled.']
  actual_delivery_timestamp timestamp [note: 'Date and time when the vehicle was actually handed over to the customer and delivery was completed.']
  appointment_duration_minutes varchar [note: 'Expected duration of the delivery appointment in minutes, including vehicle walkthrough, paperwork, and handover.']
  appointment_number varchar [note: 'Business-facing unique appointment reference number used for customer communication and tracking. Format: DA-YYYYMMDD-sequence.']
  appointment_status varchar [note: 'Current lifecycle status of the delivery appointment. [ENUM-REF-CANDIDATE: scheduled|confirmed|in_progress|completed|cancelled|no_show|rescheduled — 7 candidates stripped; promote to reference product]']
  cancellation_reason varchar [note: 'Reason provided for cancellation if the delivery appointment was cancelled.']
  connected_services_activated boolean [note: 'Indicates whether connected vehicle services and mobile app access were activated during delivery.']
  created_by_user_code varchar [note: 'Reference to the user who created the delivery appointment record.']
  created_timestamp timestamp [note: 'Date and time when the delivery appointment record was first created in the system.']
  customer_arrival_timestamp timestamp [note: 'Date and time when the customer arrived at the delivery location for their appointment.']
  customer_confirmation_status varchar [note: 'Status indicating whether the customer has confirmed their attendance at the scheduled delivery appointment.']
  customer_confirmed_timestamp timestamp [note: 'Date and time when the customer confirmed the delivery appointment.']
  delivery_address_line1 varchar [note: 'Primary street address line for the delivery location if delivery is not at a standard dealership facility.']
  delivery_address_line2 varchar [note: 'Secondary address line (suite, apartment, building) for the delivery location.']
  delivery_city varchar [note: 'City name for the delivery location.']
  delivery_country_code varchar [note: 'Three-letter ISO country code for the delivery location.']
  delivery_location_type varchar [note: 'Classification of the delivery location where the vehicle will be handed over to the customer.']
  delivery_postal_code varchar [note: 'Postal or ZIP code for the delivery location.']
  delivery_satisfaction_score varchar [note: 'Customer satisfaction rating for the delivery experience, typically on a scale of 1-10, collected immediately after delivery.']
  delivery_state_province varchar [note: 'State or province code for the delivery location.']
  delivery_type varchar [note: 'Classification of the delivery service level provided to the customer.']
  digital_channel_flag boolean
  digital_owner_manual_sent boolean [note: 'Indicates whether the digital owner manual and vehicle information was sent to the customer.']
  documentation_status varchar [note: 'Status of delivery documentation preparation including title, registration, warranty cards, and owner manuals.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  financing_status varchar [note: 'Status of financing approval and funding for the vehicle purchase if applicable.']
  handover_duration_minutes varchar [note: 'Actual duration of the vehicle handover process from customer arrival to departure.']
  home_delivery_flag boolean [note: 'Whether delivery is to customer home (direct-to-consumer)']
  last_reminder_sent_timestamp timestamp [note: 'Date and time when the most recent appointment reminder was sent to the customer.']
  modified_by_user_code varchar [note: 'Reference to the user who last modified the delivery appointment record.']
  modified_timestamp timestamp [note: 'Date and time when the delivery appointment record was last modified.']
  pdi_completed_timestamp timestamp [note: 'Date and time when the Pre-Delivery Inspection was completed and the vehicle was cleared for delivery.']
  pdi_status varchar [note: 'Status of the Pre-Delivery Inspection process ensuring the vehicle meets quality standards before customer handover.']
  reminder_sent_count varchar [note: 'Number of appointment reminder notifications sent to the customer via email, SMS, or phone.']
  scheduled_delivery_date date [note: 'The date on which the vehicle delivery appointment is scheduled to occur.']
  scheduled_delivery_time timestamp [note: 'The precise date and time when the customer is expected to arrive for vehicle handover.']
  special_instructions varchar [note: 'Any special instructions or requirements for the delivery appointment such as accessibility needs, language preferences, or specific requests.']
  trade_in_status varchar [note: 'Status of trade-in vehicle processing if the customer is trading in a vehicle as part of the transaction.']
  vehicle_orientation_completed boolean [note: 'Indicates whether the delivery specialist completed the vehicle features and controls orientation with the customer.']
  vehicle_preparation_status varchar [note: 'Status of vehicle preparation activities including cleaning, fueling, accessory installation, and final detailing before delivery.']
  vin varchar [note: '17-character Vehicle Identification Number uniquely identifying the vehicle being delivered. ISO 3779 standard format.']

  Note: 'Scheduled vehicle delivery appointment for a confirmed vehicle order, coordinating the handover of a new vehicle to the customer at a dealer or direct delivery point. Captures scheduled delivery date and time, delivery location, assigned delivery specialist, PDI (Pre-Delivery Inspection) completion status, customer confirmation status, and actual delivery completion timestamp. Triggers post-delivery customer satisfaction follow-up.'
}

Table sales.campaign {
  campaign_id varchar [pk, note: 'Unique surrogate key for the sales campaign record.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Campaigns are market-specific and require jurisdiction-level compliance approval (advertising standards differ by country/region). Normalizing campaign.region_code to jurisdiction_id enables complianc']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Marketing campaigns target specific vehicle models; model-level campaign effectiveness reporting, incentive attribution, and sales lift analysis require this FK. \'target_nameplate\' is a denormalized m']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Marketing campaigns must comply with advertising regulations governing emissions claims, pricing disclosures, and incentive offers (e.g., FTC, ASA, EU consumer protection rules). Linking campaign to r']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Campaign planning and effectiveness reporting require linking campaigns to the product segment they target. Marketing teams measure campaign ROI, lead volume, and sales lift by product segment. The ta']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Marketing campaigns are launched for specific vehicle programs (e.g., EV platform launch). Linking campaign to vehicle_program enables program launch ROI reporting, aligns campaign KPIs (kpi_sales_vol']
  actual_spent_amount decimal(15,2) [note: 'Total amount actually spent on the campaign to date.']
  actual_spent_currency varchar [note: 'ISO 4217 currency code for the actual spent amount.']
  budget_amount decimal(15,2) [note: 'Planned monetary budget allocated to the campaign.']
  budget_currency varchar [note: 'ISO 4217 currency code for the budget amount.']
  campaign_status varchar [note: 'Current lifecycle state of the campaign.']
  campaign_type varchar [note: 'Category of the campaign indicating its strategic purpose.']
  code varchar
  created_timestamp timestamp [note: 'Timestamp when the campaign record was first created.']
  dealer_participation_flag boolean [note: 'Indicates whether dealers are required to participate in the campaign.']
  description varchar [note: 'Free‑form text describing the campaign goals, scope, and key messages.']
  digital_campaign_flag boolean [note: 'Whether campaign targets digital/online channels']
  digital_channel_flag boolean
  end_date date [note: 'Date when the campaign is scheduled to end.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  kpi_market_share_actual decimal(5,2) [note: 'Observed market‑share percentage change achieved by the campaign.']
  kpi_market_share_target decimal(5,2) [note: 'Target market‑share percentage increase for the nameplate during the campaign period.']
  kpi_sales_volume_actual varchar [note: 'Actual number of vehicles sold attributable to the campaign.']
  kpi_sales_volume_target varchar [note: 'Planned number of vehicles to be sold as a result of the campaign.']
  marketing_channels varchar [note: 'Primary channels used to deliver the campaign messaging.']
  name varchar [note: 'Human‑readable name of the campaign used in reporting and UI.']
  notes varchar [note: 'Free‑form field for any supplemental information or remarks.']
  objective varchar [note: 'High‑level business objective the campaign aims to achieve (e.g., increase sales volume, improve market share).']
  priority varchar [note: 'Business priority assigned to the campaign.']
  start_date date [note: 'Date when the campaign becomes active.']
  target_customer_segment varchar [note: 'Customer segment the campaign is designed for.']
  target_model_year varchar [note: 'Model year of the vehicle nameplate targeted by the campaign.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the campaign record.']

  Note: 'Master record for a structured sales and marketing campaign targeting specific customer segments, nameplates, or market regions to drive vehicle sales. Captures campaign name, campaign type (model launch, clearance, seasonal, conquest, loyalty), target nameplate and model year, target customer segment, campaign period, budget allocation, participating dealers or regions, and campaign objectives. Distinct from incentive programs — campaigns coordinate multi-channel outreach while incentive programs define financial offers.'
}

Table dealer.dealership {
  dealership_id varchar [pk, note: 'Unique surrogate identifier for each dealer location in the OEM franchise network. Primary key for the dealership master record and the enterprise Single Source of Truth (SSOT) for dealer identity.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Dealerships operate under jurisdiction-specific franchise laws, dealer licensing requirements, and consumer protection regulations. Linking dealership to jurisdiction enables franchise law compliance ']
  activation_date date [note: 'Date on which the dealership was formally activated in the OEM dealer network and became eligible to receive vehicle allocations and participate in OEM programs.']
  adas_certified boolean [note: 'Indicates whether the dealership is certified to perform Advanced Driver Assistance Systems (ADAS) calibration and repair. Required for servicing vehicles equipped with cameras, radar, and LiDAR-based safety systems.']
  address_line1 varchar [note: 'Primary street address of the dealership physical location. Used for logistics, customer navigation, regulatory filings, and Pre-Delivery Inspection (PDI) vehicle delivery coordination.']
  address_line2 varchar [note: 'Secondary address line for the dealership (suite, unit, building number). Supplements address_line1 for precise location identification.']
  cdk_dealer_code varchar [note: 'Unique dealer identifier assigned within the CDK Global Dealer Management System (DMS). This is the integration key used for all data exchanges between the OEM lakehouse and the CDK DMS platform including inventory, F&I, and service scheduling feeds.']
  channel_classification varchar [note: 'Categorizes the dealer\'s primary sales channel model. Retail covers traditional showroom sales; fleet covers B2B volume sales; agency model covers OEM-set pricing arrangements; export covers cross-border sales points.']
  city varchar [note: 'City in which the dealership is physically located. Used for geographic market analysis, territory assignment, and customer proximity reporting.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code for the country in which the dealership is physically located (e.g., USA, CAN, MEX, GBR, DEU). Drives regulatory compliance, currency, and tax treatment.']
  deactivation_date date [note: 'Date on which the dealership was deactivated or terminated from the OEM dealer network. Nullable for currently active dealers. Used for franchise termination tracking and regulatory reporting.']
  dealer_code varchar [note: 'Externally-known alphanumeric code assigned by the OEM to uniquely identify the dealer location across all enterprise systems including SAP SD, CDK Global DMS, and Salesforce Automotive Cloud. Used on all inter-system communications, vehicle allocations, and incentive programs.']
  dealer_status varchar [note: 'Current lifecycle status of the dealership within the OEM franchise network. Controls eligibility for vehicle allocation, incentive programs, and DMS integration. [ENUM-REF-CANDIDATE: active|inactive|suspended|pending_approval|terminated|under_review — promote to reference product]']
  dealer_tier varchar [note: 'OEM-assigned performance tier classification for the dealership based on annual sales volume, customer satisfaction scores, and compliance metrics. Determines eligibility for premium vehicle allocations, co-op marketing funds, and incentive program tiers.']
  dms_go_live_date date [note: 'Date on which the CDK Global DMS integration for this dealership went live and began transmitting data to the OEM enterprise systems. Used for integration tenure tracking and data completeness assessments.']
  dms_integration_status varchar [note: 'Current status of the CDK Global DMS data integration feed for this dealership. Indicates whether real-time inventory, sales, and service data is flowing correctly into the OEM lakehouse.']
  ev_certified boolean [note: 'Indicates whether the dealership has completed OEM Electric Vehicle (EV) certification requirements including technician training, charging infrastructure installation, and EV-specific tooling. Required for allocation of BEV and PHEV models.']
  ev_charger_count varchar [note: 'Number of EV charging stations installed at the dealership for customer and demo vehicle use. Relevant for EV certification compliance and customer experience reporting.']
  franchise_agreement_number varchar [note: 'Reference number of the active franchise agreement between the OEM and the dealer entity. Used to link the dealership master record to the franchise agreement contract for legal and compliance purposes.']
  franchise_expiry_date date [note: 'Date on which the current franchise agreement is scheduled to expire or must be renewed. Nullable for perpetual agreements. Triggers renewal workflow when within the notice period.']
  franchise_start_date date [note: 'Date on which the current franchise agreement between the OEM and the dealer became effective. Used for tenure calculations, renewal scheduling, and performance baseline setting.']
  franchise_type varchar [note: 'Classification of the dealer\'s franchise arrangement with the OEM. Distinguishes OEM-owned (captive) outlets from independent franchise dealers, authorized repairers, fleet-only points, used vehicle specialists, and satellite locations. [ENUM-REF-CANDIDATE: oem_owned|independent_franchise|authorized_repairer|fleet_only|used_vehicle_only|satellite — promote to reference product]']
  home_delivery_enabled_flag boolean [note: 'Whether this dealership supports home delivery to customers.']
  last_mile_delivery_radius_km decimal(8,2) [note: 'Maximum delivery radius in km for home delivery from this dealership.']
  latitude decimal(9,6) [note: 'Geographic latitude coordinate (WGS 84 decimal degrees) of the dealership location. Enables spatial analytics, territory mapping, and customer proximity calculations for dealer locator services.']
  legal_name varchar [note: 'Full registered legal name of the dealer entity as recorded with the relevant state or national business registry. Used for franchise agreements, regulatory filings, and financial settlements.']
  longitude decimal(9,6) [note: 'Geographic longitude coordinate (WGS 84 decimal degrees) of the dealership location. Enables spatial analytics, territory mapping, and customer proximity calculations for dealer locator services.']
  lot_capacity varchar [note: 'Maximum number of vehicles that can be stored on the dealer lot (outdoor inventory storage). Used for vehicle allocation limits, inventory aging analysis, and logistics planning.']
  market_region_code varchar [note: 'OEM-defined market region code to which this dealership belongs (e.g., NORTHEAST, MIDWEST, SOUTHWEST, WEST, SOUTHEAST). Used for territory management, regional incentive programs, and sales performance reporting.']
  new_vehicle_sales_capacity varchar [note: 'OEM-assessed annual new vehicle sales capacity (unit count) for this dealership based on facility size, staffing, and market area. Used as the denominator for allocation planning and sales target setting.']
  oem_brand_codes varchar [note: 'Pipe-delimited list of OEM brand codes (e.g., BRAND_A|BRAND_B) that this dealership is franchised to sell and service. A single dealer point may hold multi-brand authorizations (e.g., passenger car and commercial vehicle brands).']
  ownership_group_name varchar [note: 'Name of the dealer group or automotive retail group that owns this dealership location (e.g., AutoNation, Penske, Lithia). Enables group-level performance aggregation, consolidated incentive calculations, and multi-point dealer management.']
  parts_warehouse_area_sqm decimal(10,2) [note: 'Total floor area in square metres of the dealership\'s parts storage facility. Used for parts inventory capacity planning, MRP replenishment calculations, and Just-in-Time (JIT) parts delivery scheduling.']
  pdi_certified boolean [note: 'Indicates whether the dealership is certified to perform Pre-Delivery Inspection (PDI) on new vehicles prior to customer handover. PDI certification is required for new vehicle delivery authorization.']
  postal_code varchar [note: 'Postal or ZIP code of the dealership\'s physical location. Used for geographic market segmentation, territory boundary analysis, and customer catchment area reporting.']
  primary_email varchar [note: 'Primary business email address for the dealership used for OEM communications, vehicle allocation notifications, incentive program updates, and Technical Service Bulletin (TSB) distribution.']
  primary_phone varchar [note: 'Main switchboard or primary contact telephone number for the dealership. Used for OEM-to-dealer communications, customer service escalations, and directory listings.']
  principal_contact_email varchar [note: 'Email address of the primary OEM relationship contact at the dealership. Used for franchise communications, incentive program notifications, and regulatory bulletin distribution.']
  principal_contact_name varchar [note: 'Full name of the primary OEM relationship contact at the dealership (typically the Dealer Principal or General Manager). Used for OEM communications, franchise agreement correspondence, and escalation routing.']
  record_created_timestamp timestamp [note: 'Timestamp when the dealership master record was first created in the enterprise data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for data lineage, audit trail, and record age analysis.']
  record_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the dealership master record in the enterprise data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change detection, data freshness monitoring, and audit compliance.']
  sales_district_code varchar [note: 'OEM-defined sales district code representing the sub-regional territory assignment for this dealership. Used for district sales manager (DSM) alignment, vehicle allocation quotas, and performance benchmarking.']
  sap_customer_number varchar [note: 'SAP S/4HANA customer master number (SD module) assigned to this dealership for vehicle order processing, invoicing, and financial settlement. Links dealership to SAP SD sales orders and FI accounts receivable.']
  service_bay_count varchar [note: 'Total number of service bays available at the dealership for vehicle maintenance and repair operations. Used for after-sales capacity planning, warranty repair throughput analysis, and service scheduling optimization.']
  showroom_display_capacity varchar [note: 'Maximum number of vehicles that can be displayed simultaneously in the dealership showroom. Used for vehicle allocation planning, demo fleet sizing, and facility investment decisions.']
  state_province_code varchar [note: 'ISO 3166-2 state or province code for the dealership\'s physical location (e.g., CA, TX, NY, ON). Used for CAFE compliance reporting, CARB emissions zone classification, and state-level dealer franchise law compliance.']
  trading_name varchar [note: 'The public-facing \'doing business as\' (DBA) name of the dealership as displayed to customers, on signage, and in marketing materials. May differ from the legal entity name.']
  used_vehicle_sales_capacity varchar [note: 'OEM-assessed annual used vehicle sales capacity (unit count) for this dealership. Used for certified pre-owned (CPO) program eligibility and used vehicle allocation planning.']
  warranty_authorized boolean [note: 'Indicates whether the dealership is authorized to perform OEM warranty repairs and submit warranty claims. Drives warranty claim processing eligibility in SAP and CDK DMS.']
  website_url varchar [note: 'Public-facing website URL for the dealership. Used for digital marketing integration, online inventory syndication, and customer-facing dealer locator services.']
  yard_slot_capacity varchar [note: 'Number of vehicle storage slots available at the dealership yard.']

  Note: 'Master record for each dealer location in the OEM franchise network. Captures dealer legal entity, DMS (Dealer Management System) integration identifiers (CDK Global), franchise type (OEM-owned vs independent), physical address, contact details, operational status, market region, and channel classification. This is the SSOT for dealer identity across the enterprise.'
}

Table dealer.franchise_agreement {
  franchise_agreement_id varchar [pk, note: 'Unique identifier for the franchise agreement record. Primary key.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: franchise_agreement.governing_law_jurisdiction is a denormalized reference to jurisdiction. Franchise agreements are governed by specific jurisdictions\' dealer franchise laws. Normalizing to jurisdict']
  primary_franchise_dealer_dealership_id varchar [note: 'Reference to the dealer entity that is party to this franchise agreement.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Franchise agreements are governed by jurisdiction-specific dealer franchise protection laws and regulatory requirements. OEM legal/compliance teams must ensure franchise agreement terms comply with ap']
  warranty_policy_id varchar [note: 'Foreign key linking to aftersales.warranty_policy. Business justification: OEM franchise agreements govern which warranty policies a dealer is authorized to administer. warranty_administration_authorized_flag and recall_service_authorized_flag on franchise_agreement require ']
  agreement_currency_code varchar [note: 'Three-letter ISO 4217 currency code for all financial terms in the franchise agreement (quotas, fees, investment requirements). Example: USD, EUR, JPY.']
  agreement_document_url varchar [note: 'Secure URL or file path to the digitally stored franchise agreement contract document (PDF or scanned image).']
  agreement_name varchar [note: 'Human-readable name or title of the franchise agreement, typically including dealer name and location.']
  agreement_number varchar [note: 'Externally-known unique business identifier for the franchise agreement. Format: FA-NNNNNNNN.']
  agreement_status varchar [note: 'Current lifecycle status of the franchise agreement: draft (being negotiated), pending approval (awaiting OEM sign-off), active (in force), suspended (temporarily inactive), terminated (ended before expiration), or expired (reached end date).']
  agreement_type varchar [note: 'Classification of the franchise agreement based on its purpose: new franchise grant, renewal of existing agreement, amendment to terms, territory expansion, or termination agreement.']
  allocation_priority_tier varchar [note: 'Priority tier for vehicle inventory allocation. Higher tiers receive preferential allocation of high-demand models and limited-production vehicles. Tier 1 = highest priority.']
  authorized_nameplates varchar [note: 'Comma-separated list of vehicle nameplates (brands, model lines) that the dealer is authorized to sell under this franchise agreement. Examples: Sedan, SUV, Truck, EV (Electric Vehicle), HEV (Hybrid Electric Vehicle).']
  authorized_vehicle_lines varchar [note: 'Specific vehicle lines or series the dealer is authorized to sell, such as luxury, commercial, electric, or performance segments.']
  auto_renewal_flag boolean [note: 'Indicates whether the franchise agreement automatically renews at expiration unless either party provides notice. True = auto-renews, False = requires explicit renewal.']
  certified_pre_owned_authorized_flag boolean [note: 'Indicates whether the dealer is authorized to sell OEM-certified pre-owned vehicles under the manufacturer\'s CPO program. True = authorized, False = not authorized.']
  commercial_fleet_authorized_flag boolean [note: 'Indicates whether the dealer is authorized to sell vehicles to commercial fleet customers and participate in fleet sales programs. True = authorized, False = not authorized.']
  created_timestamp timestamp [note: 'Timestamp when this franchise agreement record was first created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  customer_satisfaction_target_score decimal(5,2) [note: 'Minimum Net Promoter Score (NPS) or customer satisfaction score the dealer must achieve to maintain franchise agreement in good standing. Typically measured on a scale of 0-100.']
  dealer_signatory_name varchar [note: 'Full name of the dealer authorized representative (typically dealer principal or owner) who signed the franchise agreement.']
  digital_retailing_required_flag boolean [note: 'Indicates whether the dealer must offer digital retailing capabilities (online sales, virtual showroom, e-commerce) as required by the franchise agreement. True = required, False = optional.']
  dms_integration_required_flag boolean [note: 'Indicates whether the dealer must integrate their DMS (Dealer Management System) with OEM systems for real-time inventory, sales, and service data sharing. True = required, False = optional.']
  effective_date date [note: 'Date when the franchise agreement becomes legally binding and operational. Marks the start of the dealer\'s franchise rights and obligations.']
  ev_charging_infrastructure_required_flag boolean [note: 'Indicates whether the dealer must install and maintain EV (Electric Vehicle) charging infrastructure at their facility as a condition of selling electric or hybrid vehicles. True = required, False = optional.']
  exclusive_territory_flag boolean [note: 'Indicates whether the dealer has exclusive rights to sell in the assigned territory. True = exclusive (no other dealers in territory), False = non-exclusive (shared territory).']
  expiration_date date [note: 'Date when the franchise agreement is scheduled to end. Nullable for open-ended or perpetual agreements subject to performance review.']
  facility_investment_requirement_amount decimal(15,2) [note: 'Minimum capital expenditure (CapEx) the dealer must invest in facility improvements, showroom standards, service equipment, and infrastructure to meet OEM brand standards.']
  franchise_tier varchar [note: 'Tier or level of the franchise agreement indicating dealer status, privileges, and performance expectations. Higher tiers typically receive preferential allocation and incentives.']
  home_delivery_obligation_flag boolean [note: 'Whether the franchise agreement requires home delivery capability.']
  incentive_program_eligibility_flag boolean [note: 'Indicates whether the dealer is eligible to participate in OEM dealer incentive programs, volume bonuses, and performance rewards. True = eligible, False = not eligible.']
  last_modified_timestamp timestamp [note: 'Timestamp when this franchise agreement record was last updated in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  minimum_sales_quota_annual varchar [note: 'Minimum number of vehicle units the dealer must sell annually to maintain franchise agreement in good standing. Performance obligation defined in agreement.']
  minimum_service_capacity varchar [note: 'Minimum number of vehicles the dealer must be capable of servicing per month to meet franchise agreement service obligations.']
  notice_period_days varchar [note: 'Number of days advance notice required by either party to terminate or not renew the franchise agreement. Typical values are 30, 60, 90, or 180 days.']
  oem_signatory_name varchar [note: 'Full name of the OEM authorized representative who signed the franchise agreement on behalf of the manufacturer.']
  ownership_model varchar [note: 'Classification of dealer ownership structure: OEM (Original Equipment Manufacturer) owned, independent franchise, joint venture, or corporate store.']
  parts_inventory_requirement_amount decimal(15,2) [note: 'Minimum dollar value of OEM (Original Equipment Manufacturer) parts inventory the dealer must maintain at all times to meet franchise agreement obligations.']
  performance_review_frequency varchar [note: 'Frequency at which the OEM conducts formal performance reviews of the dealer against franchise agreement obligations and performance metrics.']
  recall_service_authorized_flag boolean [note: 'Indicates whether the dealer is authorized to perform recall repairs and service campaigns issued by the OEM or NHTSA (National Highway Traffic Safety Administration). True = authorized, False = not authorized.']
  renewal_date date [note: 'Date when the franchise agreement was last renewed or is scheduled for renewal review. Used for tracking renewal cycles.']
  renewal_term_months varchar [note: 'Duration in months for each renewal period of the franchise agreement. Typical values are 12, 24, 36, or 60 months.']
  signed_date date [note: 'Date when the franchise agreement was formally signed by both the dealer and OEM authorized representatives, making it legally binding.']
  termination_date date [note: 'Actual date when the franchise agreement was terminated, if applicable. Populated only for agreements that ended before their scheduled expiration.']
  termination_reason varchar [note: 'Detailed explanation of why the franchise agreement was terminated early, including performance issues, dealer request, market consolidation, or regulatory compliance.']
  territory_description varchar [note: 'Textual description of the geographic territory assigned to the dealer under this franchise agreement, including cities, counties, postal codes, or radius from dealer location.']
  territory_radius_km decimal(10,2) [note: 'Radius in kilometers from the dealer\'s primary location defining the franchise territory boundary, if territory is defined by radius rather than geographic boundaries.']
  training_certification_required_flag boolean [note: 'Indicates whether dealer staff must complete OEM-mandated training and certification programs as a condition of the franchise agreement. True = required, False = optional.']
  warranty_administration_authorized_flag boolean [note: 'Indicates whether the dealer is authorized to process and submit warranty claims on behalf of customers under OEM warranty programs. True = authorized, False = not authorized.']

  Note: 'Formal franchise contract between the OEM and an independent or OEM-owned dealer. Tracks agreement effective dates, expiration, renewal terms, franchise tier, authorized vehicle lines (nameplates), territory rights, performance obligations, and agreement status. Supports both new franchise grants and renewals.'
}

Table dealer.territory {
  territory_id varchar [pk, note: 'Unique identifier for the dealer territory assignment. Primary key.']
  franchise_agreement_id varchar [note: 'Reference to the franchise agreement that governs this territory assignment. Links territory rights to contractual terms.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Territory planning aligns with the legal jurisdiction for emissions and safety regulations; linking enables jurisdiction‑specific reporting.']
  primary_dealer_dealership_id varchar [note: 'Reference to the dealership that owns or is assigned this territory.']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: OEM territory planning assigns each dealer territory to a product segment (e.g., EV, truck, luxury) for allocation quotas and market coverage analysis. market_segment_classification is a denormalized ']
  allocation_quota_percentage decimal(5,2) [note: 'Percentage of regional or national vehicle allocation assigned to this territory. Sum of all territory percentages within a region should equal 100.']
  approval_date date [note: 'Date when the territory assignment or modification was formally approved by OEM (Original Equipment Manufacturer) management.']
  approved_by varchar [note: 'Name or identifier of the OEM (Original Equipment Manufacturer) executive or manager who approved this territory assignment or modification.']
  city_list varchar [note: 'Comma-separated list of cities or municipalities included in the territory coverage area.']
  code varchar [note: 'Unique alphanumeric code identifying the territory within the dealer network. Used for vehicle allocation and market planning.']
  competitive_intensity_rating varchar [note: 'Assessment of competitive pressure within the territory based on number of competing brands, dealer density, and market saturation.']
  country_code varchar [note: 'Three-letter ISO country code for the territory location (e.g., USA, CAN, MEX).']
  county_region varchar [note: 'County, district, or regional subdivision name within the state/province that defines part of the territory boundary.']
  created_timestamp timestamp [note: 'Timestamp when this territory assignment record was first created in the system. Audit trail for data lineage.']
  dms_integration_status varchar [note: 'Status of territory data synchronization with the dealer\'s DMS (Dealer Management System), specifically CDK Global DMS. Indicates whether territory boundaries are reflected in dealer systems.']
  dms_last_sync_timestamp timestamp [note: 'Timestamp of the last successful synchronization of territory data with the dealer\'s DMS (Dealer Management System). Used to monitor data freshness and integration health.']
  effective_end_date date [note: 'Date when the territory assignment expires or is terminated. Null indicates an open-ended assignment.']
  effective_start_date date [note: 'Date when the territory assignment becomes active and the dealer assumes responsibility for the defined area.']
  geographic_boundary_description varchar [note: 'Textual description of territory boundaries using landmarks, highways, or natural features (e.g., \'North of I-40, East of Highway 101\').']
  home_delivery_coverage_flag boolean [note: 'Whether home delivery is available in this territory.']
  household_count_estimate varchar [note: 'Estimated number of households within the territory. Used for market penetration analysis and vehicle allocation planning.']
  incentive_program_eligibility_flag boolean [note: 'Indicates whether dealers in this territory are eligible for special OEM (Original Equipment Manufacturer) incentive programs or bonuses. True = eligible; False = not eligible.']
  last_modified_timestamp timestamp [note: 'Timestamp when this territory assignment record was last updated. Tracks the most recent change to any field in the record.']
  last_review_date date [note: 'Date when the territory assignment was last reviewed or audited by OEM (Original Equipment Manufacturer) management. Used to track compliance with periodic review requirements.']
  manager_email varchar [note: 'Email address of the OEM (Original Equipment Manufacturer) territory manager. Used for dealer communications and escalations.']
  manager_name varchar [note: 'Name of the OEM (Original Equipment Manufacturer) regional or territory manager responsible for overseeing this territory and dealer relationship.']
  manager_phone varchar [note: 'Contact phone number for the OEM (Original Equipment Manufacturer) territory manager.']
  modification_reason varchar [note: 'Business justification for the most recent change to the territory assignment (e.g., market expansion, dealer consolidation, performance adjustment).']
  name varchar [note: 'Business-friendly name or description of the territory (e.g., \'Metro East Region\', \'Downtown District\').']
  next_review_date date [note: 'Scheduled date for the next territory assignment review. Ensures regular evaluation of territory boundaries and dealer performance.']
  overlap_allowed_flag boolean [note: 'Indicates whether this territory can overlap with other dealer territories. True allows shared coverage; False enforces exclusive boundaries.']
  overlap_rule_description varchar [note: 'Business rules governing how overlapping territories are managed, including priority rules, customer assignment logic, and conflict resolution procedures.']
  performance_benchmark_group varchar [note: 'Peer group or cohort used for dealer performance benchmarking. Territories with similar characteristics are grouped for fair comparison.']
  population_estimate varchar [note: 'Estimated total population within the territory boundaries. Used for market sizing and dealer performance benchmarking.']
  postal_code_list varchar [note: 'Comma-separated or range-based list of postal/zip codes included in the territory (e.g., \'90001-90099,91000\'). Used for precise geographic allocation.']
  primary_area_of_responsibility varchar [note: 'Geographic description of the core territory where the dealer has primary sales and service responsibility. May include city names, county boundaries, or regional descriptors.']
  sales_potential_index decimal(5,2) [note: 'Numeric index representing the relative sales potential of the territory compared to a baseline (e.g., 100 = average, 150 = 50% above average). Used for vehicle allocation and quota setting.']
  special_program_notes varchar [note: 'Free-text notes describing any special programs, pilot initiatives, or unique conditions applicable to this territory (e.g., EV (Electric Vehicle) launch market, rural incentive zone).']
  state_province_code varchar [note: 'Two or three-letter code for the state, province, or administrative region (e.g., CA, TX, ON).']
  territory_status varchar [note: 'Current lifecycle status of the territory assignment. Active territories are operational; pending awaits approval; suspended is temporarily halted; terminated is closed.']
  territory_type varchar [note: 'Classification of territory assignment model: exclusive (single dealer), shared (multiple dealers), open (no restrictions), primary (main responsibility), secondary (backup coverage), overlay (special program).']
  vehicle_allocation_priority varchar [note: 'Priority ranking for vehicle inventory allocation to this territory. Lower numbers indicate higher priority. Used during supply constraints.']

  Note: 'Geographic sales territory assigned to a dealership. Defines primary area of responsibility (PAR), zip/postal code coverage, county or region boundaries, territory type (exclusive, shared, open), effective dates, and overlap rules. Used for vehicle allocation, market representation planning, and dealer performance benchmarking.'
}

Table dealer.certification {
  certification_id varchar [pk, note: 'Unique identifier for the dealer certification record. Primary key.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Dealer certifications are jurisdiction-specific (e.g., California ZEV mandate, federal NHTSA requirements). Compliance reporting requires linking certifications to the issuing jurisdiction for regulat']
  primary_dealer_dealership_id varchar [note: 'Reference to the dealership that holds this certification. Links to the dealer master record.']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: dealer_certification.issuing_body and issuing_body_type are denormalized representations of regulatory_body. OEM compliance teams track which regulatory body issued each dealer certification for renew']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Dealer certifications (EV, ADAS, CPO) are mandated by specific regulatory requirements. OEM compliance teams map dealer certifications to regulatory requirements for audit reporting and renewal tracki']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Dealer certifications (EV-certified, ADAS-certified) are scoped to specific product segments. OEM certification programs require linking each certification to the product segment it authorizes (e.g., ']
  allocation_eligibility_flag boolean [note: 'Indicates whether this certification makes the dealer eligible for preferential vehicle allocation (e.g., EV-certified dealers receive priority allocation of electric vehicles).']
  annual_maintenance_cost_amount decimal(15,2) [note: 'Estimated annual cost to maintain this certification, including renewal fees, ongoing training, and audit costs. Expressed in the OEM\'s reporting currency.']
  audit_outcome varchar [note: 'Result of the most recent audit (e.g., passed, passed with conditions, failed). Determines whether certification remains in good standing.']
  audit_required_flag boolean [note: 'Indicates whether the dealer must undergo periodic audits to maintain this certification.']
  audit_score decimal(5,2) [note: 'Numerical score or rating achieved in the most recent audit (e.g., 0-100 scale, or percentage). Reflects compliance quality and performance.']
  certification_number varchar [note: 'Unique alphanumeric identifier assigned by the issuing body for this certification. Externally-known business identifier.']
  certification_status varchar [note: 'Current lifecycle status of the certification. Determines whether the dealer is currently authorized under this certification program.']
  certification_type varchar [note: 'Category of certification awarded to the dealer. Defines the specialized capability or program enrollment (e.g., EV-certified dealer, ADAS service authorization, luxury brand certification).']
  cost_amount decimal(15,2) [note: 'Total cost incurred by the dealer to obtain this certification, including training, equipment, facility upgrades, and application fees. Expressed in the OEM\'s reporting currency.']
  created_timestamp timestamp [note: 'Timestamp when this certification record was first created in the system. Audit trail for data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this record (e.g., USD, EUR, JPY).']
  effective_date date [note: 'Date from which the certification becomes active and the dealer is authorized to operate under this certification. May differ from issue date if there is a grace period.']
  equipment_requirements varchar [note: 'Description of specialized tools, diagnostic equipment, or technology the dealer must possess for this certification (e.g., high-voltage battery diagnostic tools, ADAS radar calibration systems).']
  expiry_date date [note: 'Date when the certification expires and the dealer must renew to maintain authorization. Nullable for certifications with no expiration.']
  facility_requirements varchar [note: 'Description of physical facility requirements the dealer must meet for this certification (e.g., dedicated EV charging bays, ADAS calibration equipment, climate-controlled service area).']
  geographic_scope varchar [note: 'Geographic coverage level of this certification (e.g., global, regional, national, state/provincial, local). Defines where the certification is recognized.']
  home_delivery_certified_flag boolean [note: 'Whether the dealer is certified for home delivery operations.']
  incentive_eligibility_flag boolean [note: 'Indicates whether this certification qualifies the dealer for special incentive programs, rebates, or performance bonuses.']
  issue_date date [note: 'Date when the certification was originally issued to the dealer. Marks the start of the certification validity period.']
  last_audit_date date [note: 'Date of the most recent audit conducted for this certification. Used to track audit compliance and schedule next audit.']
  last_modified_timestamp timestamp [note: 'Timestamp when this certification record was most recently updated. Audit trail for data lineage and change tracking.']
  last_renewal_date date [note: 'Date of the most recent renewal or recertification event. Tracks ongoing compliance and re-qualification.']
  level varchar [note: 'Tier or grade of certification achieved by the dealer within a tiered program (e.g., Bronze, Silver, Gold, Platinum). Higher levels may unlock additional benefits.']
  minimum_certified_technicians varchar [note: 'Minimum number of technicians who must hold individual certification credentials for the dealer to maintain this certification.']
  name varchar [note: 'Full descriptive name of the certification program or credential (e.g., \'Electric Vehicle Sales and Service Certification\', \'Advanced Driver Assistance Systems Authorized Service Center\').']
  next_audit_due_date date [note: 'Date by which the next audit must be completed to maintain certification compliance.']
  next_renewal_due_date date [note: 'Date by which the dealer must complete renewal requirements to maintain active certification status. Used for proactive renewal management.']
  notes varchar [note: 'Free-text field for additional comments, special conditions, or contextual information about this certification record.']
  personnel_requirements varchar [note: 'Description of staffing requirements for this certification (e.g., minimum number of certified technicians, specific role qualifications, training credentials).']
  reinstatement_date date [note: 'Date when a previously suspended certification was reinstated to active status. Nullable if never suspended or not yet reinstated.']
  renewal_frequency_months varchar [note: 'Number of months between required renewal cycles for this certification (e.g., 12 for annual, 24 for biennial, 36 for triennial).']
  revocation_date date [note: 'Date when the certification was permanently revoked. Nullable if never revoked.']
  revocation_reason varchar [note: 'Explanation of why the certification was permanently revoked, if applicable (e.g., serious compliance violations, fraudulent activity, repeated failures). Nullable if never revoked.']
  suspension_date date [note: 'Date when the certification was suspended. Nullable if never suspended.']
  suspension_reason varchar [note: 'Explanation of why the certification was suspended, if applicable (e.g., failed audit, non-compliance with training requirements, facility deficiencies). Nullable if never suspended.']
  training_completion_date date [note: 'Date when the dealer completed the required training program for this certification. Nullable if training is not required or not yet completed.']
  training_required_flag boolean [note: 'Indicates whether dealer personnel must complete specific training programs to obtain or maintain this certification.']

  Note: 'Tracks OEM-issued certifications and program enrollments for a dealership, such as EV-certified dealer, ADAS service authorization, luxury brand certification, and IATF 16949 compliance status. Includes certification type, issuing body, issue date, expiry date, renewal requirements, and current status. Drives eligibility for vehicle allocation and incentive programs.'
}

Table dealer.vehicle_allocation {
  vehicle_allocation_id varchar [pk, note: 'Unique surrogate identifier for each vehicle allocation record linking a specific vehicle unit or allocation batch from OEM manufacturing output to a dealership inventory pipeline.']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Dealer allocation planning and OEM order management require knowing the exact vehicle configuration (trim, powertrain, market, color) being allocated. This drives incentive eligibility, allocation pri']
  fleet_contract_id varchar [note: 'Foreign key linking to sales.fleet_contract. Business justification: Fleet contract fulfillment tracking: OEMs allocate specific vehicles to satisfy fleet contract committed volumes. Linking vehicle_allocation to fleet_contract enables fleet delivery schedule tracking,']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: OEM vehicle allocation is plant-sourced: allocation teams assign dealer units from specific plants. Allocation reports, supply planning, and dealer-facing ETAs are all plant-keyed. \'production_plant_c']
  primary_vehicle_dealer_dealership_id varchar [note: 'Reference to the dealership receiving this vehicle allocation. Links to the dealer master record in the dealer network.']
  production_schedule_id varchar [note: 'Foreign key linking to manufacturing.production_schedule. Business justification: OEM allocation process is directly driven by production schedules: available units per model/variant per period are read from production_schedule to determine dealer allocation quantities. Allocation ']
  territory_id varchar [note: 'Foreign key linking to dealer.dealer_territory. Business justification: Vehicle allocations are distributed according to dealer territory assignments — vehicle_allocation.territory_code is a denormalized string reference to dealer_territory.territory_code. Replacing it wi']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: OEM allocation planning is organized by vehicle program — allocation teams assign units to dealers by program (model year, nameplate, platform). Linking vehicle_allocation to vehicle_program enables p']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Once a VIN is assigned to a dealer allocation, traceability from allocation decision to the specific registered VIN is required for recall management, warranty activation, delivery confirmation, and O']
  acceptance_deadline date [note: 'Date by which the dealer must formally accept or reject this allocation. Failure to respond by this date may result in automatic acceptance or reallocation per OEM dealer agreement terms.']
  acceptance_timestamp timestamp [note: 'Exact timestamp when the dealer formally accepted this vehicle allocation via the dealer portal or DMS integration. Provides precise audit trail for dealer commitment.']
  accepted_quantity varchar [note: 'Number of vehicle units formally accepted by the dealer from this allocation. May be less than allocated_quantity if the dealer partially accepts or rejects units.']
  actual_delivery_date date [note: 'Actual date the allocated vehicle(s) were physically delivered to and received by the dealership. Used for On-Time Delivery (OTD) performance measurement and dealer satisfaction tracking.']
  allocation_batch_number varchar [note: 'Identifier grouping multiple allocation records issued in the same OEM allocation run or production release cycle. Enables batch-level tracking, reporting, and dealer communication.']
  allocation_date date [note: 'The business event date on which the OEM formally allocated the vehicle unit(s) to the dealership. Represents the principal real-world event time for this transaction.']
  allocation_number varchar [note: 'Externally-known business identifier for this allocation transaction, used in dealer communications, DMS integration, and OEM-dealer correspondence. Format: ALLOC-{MY}-{sequence}.']
  allocation_rule_code varchar [note: 'Code identifying the specific allocation rule or algorithm applied to determine this dealer\'s vehicle entitlement (e.g., turn-and-earn, market share, historical sales, regional quota). Drives transparency and auditability of allocation decisions.']
  allocation_status varchar [note: 'Current lifecycle state of the vehicle allocation record. Tracks progression from OEM-initiated pending through dealer acceptance or rejection to final delivery confirmation.']
  allocation_type varchar [note: 'Classification of the allocation purpose: standard retail inventory, priority customer order fulfillment, constrained supply allocation, fleet customer, dealer demonstrator vehicle, or loaner vehicle program.']
  created_timestamp timestamp [note: 'Timestamp when this allocation record was first captured in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this allocation record (MSRP, dealer invoice price, incentive amounts). Supports multi-currency dealer networks in international markets.']
  dealer_invoice_price decimal(12,2) [note: 'The price at which the OEM invoices the dealer for the allocated vehicle, net of holdback and before dealer incentives. Represents the dealer\'s cost basis for inventory financing and margin calculation.']
  dms_reference_number varchar [note: 'The corresponding allocation or stock order reference number in the dealer\'s CDK Global Dealer Management System (DMS). Enables end-to-end reconciliation between OEM allocation records and dealer inventory systems.']
  estimated_delivery_date date [note: 'Estimated date the allocated vehicle(s) are expected to arrive at the dealership. Calculated based on production schedule, transport lead time, and PDI processing time. Communicated to dealers for inventory planning.']
  hold_code varchar [note: 'Code indicating any active hold placed on the allocated vehicle(s) preventing retail sale (e.g., safety recall hold, quality hold, regulatory compliance hold, stop-sale order). Null when no hold is active. [ENUM-REF-CANDIDATE: safety_recall|quality_hold|regulatory|stop_sale|tsb_hold|other — promote to reference product]']
  incentive_amount decimal(12,2) [note: 'Monetary value of the dealer incentive or bonus applicable to this specific allocation record. Represents the financial benefit to the dealer for accepting and retailing this vehicle.']
  incentive_program_code varchar [note: 'Code identifying the OEM dealer incentive program applicable to this allocation (e.g., volume bonus, stair-step program, conquest incentive). Links to the dealer incentive program master for payout calculation.']
  is_customer_order boolean [note: 'Indicates whether this allocation is fulfilling a specific retail customer order (sold order) rather than being allocated to dealer stock inventory. Drives order fulfillment priority and customer communication workflows.']
  last_mile_delivery_method varchar [note: 'Preferred last-mile delivery method for this allocation (truck, rail, self-drive).']
  msrp decimal(12,2) [note: 'Manufacturer Suggested Retail Price (MSRP) for the allocated vehicle unit in the base transaction currency. Used for dealer invoice calculation, incentive program application, and consumer pricing guidance.']
  notes varchar [note: 'Free-text field for additional operational notes, special handling instructions, or dealer-specific comments associated with this allocation record. Used by zone managers and dealer relations teams.']
  pdi_completed boolean [note: 'Indicates whether the Pre-Delivery Inspection (PDI) has been completed for the allocated vehicle(s) at the dealership. Required before vehicle can be retailed to a customer.']
  pdi_required boolean [note: 'Indicates whether a Pre-Delivery Inspection (PDI) is required for the allocated vehicle(s) before retail handover. Drives dealer service scheduling and PDI cost recovery processes.']
  port_of_entry_code varchar [note: 'Code identifying the port or processing compound through which imported or CKD/SKD vehicles pass before onward delivery to the dealer. Relevant for international allocation flows and customs compliance.']
  priority_tier varchar [note: 'Dealer priority tier assigned for this allocation cycle, determining precedence when vehicle supply is constrained. Tier 1 dealers receive first allocation rights based on performance metrics, sales volume, or strategic importance.']
  region_code varchar [note: 'OEM regional zone code (e.g., NORTHEAST, SOUTHEAST, CENTRAL, WEST) grouping territories for macro-level allocation planning, regional incentive programs, and zone manager oversight.']
  rejection_reason_code varchar [note: 'Standardized code indicating the dealer\'s reason for rejecting this allocation (e.g., excess inventory, wrong specification, cash flow constraints, market demand mismatch). Null when allocation is accepted. [ENUM-REF-CANDIDATE: excess_inventory|wrong_spec|cash_flow|demand_mismatch|facility_capacity|other — promote to reference product]']
  scheduled_production_date date [note: 'Planned date on which the allocated vehicle unit(s) are scheduled to enter the production line. Derived from the Start of Production (SOP) schedule and used for delivery window planning.']
  source_system_code varchar [note: 'Identifies the operational system of record that originated this allocation record. Supports data lineage, reconciliation, and multi-system integration auditing across SAP S/4HANA SD, CDK Global DMS, and Salesforce Automotive Cloud.']
  transport_mode varchar [note: 'Primary mode of transportation used to deliver the allocated vehicle(s) from the production plant or port of entry to the dealership. Drives logistics cost allocation and delivery lead time estimation.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this allocation record. Supports change tracking, audit compliance, and incremental data pipeline processing.']

  Note: 'Records the OEM\'s allocation of specific vehicle units (by VIN or allocation batch) to a dealership for a given model year and production period. Captures allocation quantity, nameplate, trim, powertrain type (ICE/HEV/PHEV/EV), allocation rule applied, priority tier, acceptance status, and delivery window. Core operational record linking manufacturing output to dealer inventory pipeline.'
}

Table dealer.dealer_inventory {
  dealer_inventory_id varchar [pk, note: 'Unique surrogate identifier for each dealer inventory record in the Silver Layer lakehouse. Primary key for this data product.']
  bom_header_id varchar [note: 'Foreign key linking to product.sku. Business justification: Inventory management report requires linking each dealer inventory record to the SKU definition for pricing, specs, warranty and compliance.']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Dealer lot inventory management, recall compliance, incentive eligibility, and window sticker accuracy all require the exact vehicle configuration. body_style, drivetrain, and transmission_type are de']
  primary_dealer_dealership_id varchar [note: 'Reference to the dealership that physically holds or is allocated this inventory unit. Sourced from CDK Global DMS dealer master.']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Dealers must hold and identify inventory vehicles affected by active recall campaigns before sale. recall_campaign_number is a denormalized reference. Linking dealer_inventory to recall_campaign suppo']
  service_campaign_id varchar [note: 'Foreign key linking to aftersales.service_campaign. Business justification: Dealer inventory vehicles on recall/service campaign hold must be tracked against the specific campaign for lot management, parts pre-ordering, and OEM compliance reporting. recall_campaign_number is ']
  vehicle_allocation_id varchar [note: 'Foreign key linking to dealer.vehicle_allocation. Business justification: Dealer inventory records are created when OEM-allocated vehicles arrive at the dealership. vehicle_allocation is the upstream record that triggers the creation of a dealer_inventory entry. Linking dea']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Needed for Vehicle Traceability report, connecting each inventory record to its exact build record for warranty and recall actions.']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Dealer inventory management report requires each inventory record to be linked to the VIN registry for warranty, recall, and compliance tracking.']
  acquisition_cost decimal(12,2) [note: 'The dealer\'s total landed cost for this vehicle unit, including invoice price, transportation/destination charges, PDI costs, and any dealer-installed accessories. Used for gross profit calculation and inventory valuation.']
  asking_price decimal(12,2) [note: 'The dealer\'s current advertised or asking retail price for this vehicle unit. May differ from MSRP due to market adjustments, dealer markups, or promotional discounts. Updated dynamically based on market conditions and days-on-lot.']
  certified_pre_owned boolean [note: 'Indicates whether this used vehicle unit has been certified under the OEM\'s Certified Pre-Owned (CPO) program, meeting specific age, mileage, inspection, and reconditioning standards. True = CPO certified; False = not CPO certified. CPO vehicles carry extended warranty coverage and premium pricing.']
  days_on_lot varchar [note: 'The number of calendar days this vehicle unit has been physically present on the dealer\'s lot since the received date. A key inventory aging metric used to trigger price adjustments, incentive programs, and wholesale decisions. Aged inventory (typically >60 days) incurs floor plan interest costs.']
  dms_record_reference varchar [note: 'The source system record identifier from CDK Global DMS for this inventory unit. Used for data lineage, reconciliation, and incremental load processing between the DMS source and the Silver Layer lakehouse.']
  dwell_time_days varchar [note: 'Number of days the vehicle has been in dealer inventory.']
  engine_description varchar [note: 'Descriptive label for the engine or powertrain configuration (e.g., \'2.5L 4-Cylinder\', \'3.5L V6 EcoBoost\', \'75 kWh Electric Motor\'). Supports customer consultation and technical service identification.']
  estimated_arrival_date date [note: 'The estimated date the vehicle unit is expected to arrive at the dealership from the OEM or transport carrier. Relevant for in-transit inventory. Used for customer pre-order management and lot planning.']
  exterior_color_code varchar [note: 'OEM-assigned paint/exterior color code for this vehicle unit (e.g., \'NH-883P\' for Sonic Gray Pearl). Used for inventory search, customer matching, and lot locator functions within CDK Global DMS.']
  exterior_color_name varchar [note: 'Human-readable marketing name of the exterior paint color (e.g., \'Sonic Gray Pearl\', \'Midnight Black Metallic\'). Used for customer-facing display and sales consultation.']
  floor_plan_date date [note: 'The date on which floor plan financing commenced for this vehicle unit. Used to calculate accrued floor plan interest costs and curtailment schedules. Null for vehicles not financed via floor plan.']
  floor_plan_lender varchar [note: 'Name of the financial institution providing floor plan (wholesale) financing for this vehicle unit (e.g., \'Ford Motor Credit\', \'Ally Financial\', \'Chase Auto Finance\'). Floor plan financing is the short-term credit line dealers use to fund vehicle inventory.']
  fuel_economy_city_mpg decimal(5,1) [note: 'EPA-rated city fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.']
  fuel_economy_highway_mpg decimal(5,1) [note: 'EPA-rated highway fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.']
  in_service_date date [note: 'The date the vehicle was placed into service (sold and delivered to a retail customer, or placed into demo/loaner service). Marks the start of the OEM warranty period. Null if the vehicle has not yet been placed in service.']
  interior_color_code varchar [note: 'OEM-assigned interior color/trim code for this vehicle unit (e.g., \'BK\' for Black). Used for inventory matching and customer preference alignment.']
  interior_color_name varchar [note: 'Human-readable marketing name of the interior color and material (e.g., \'Black Leather\', \'Sandstone Cloth\'). Used for customer-facing display and sales consultation.']
  inventory_status varchar [note: 'Current disposition status of the vehicle unit within the dealer inventory lifecycle. \'available\' = on-lot and saleable; \'sold\' = retail sale completed; \'demo\' = dealer demonstration unit; \'loaner\' = service loaner vehicle; \'in_transit\' = allocated but not yet physically received; \'reserved\' = held for a specific customer; \'wholesale\' = designated for wholesale/auction disposal. [ENUM-REF-CANDIDATE: available|sold|demo|loaner|in_transit|reserved|wholesale — promote to reference product]']
  inventory_type varchar [note: 'Classification of the vehicle unit by its condition and ownership history: \'new\' = new vehicle never titled; \'used\' = previously owned/titled vehicle; \'certified_pre_owned\' = OEM-certified used vehicle meeting specific age/mileage criteria; \'demo\' = dealer demonstration vehicle; \'loaner\' = service loaner vehicle. Governs applicable pricing, warranty, and financing programs.']
  invoice_price decimal(12,2) [note: 'The OEM invoice price charged to the dealer for this vehicle unit, representing the dealer\'s acquisition cost from the manufacturer before holdback, dealer cash, or other incentives. Confidential commercial pricing data.']
  last_price_update_date date [note: 'The date on which the asking price for this vehicle unit was most recently updated in the CDK Global DMS. Used to track pricing strategy cadence and ensure market-aligned pricing for aged inventory.']
  location_code varchar [note: 'The physical lot or storage location code within the dealership where this vehicle is parked (e.g., \'LOT-A-12\', \'SHOWROOM-3\', \'OVERFLOW-B\'). Used for lot management, vehicle locator, and PDI workflow routing within CDK Global DMS.']
  msrp decimal(12,2) [note: 'The Manufacturer Suggested Retail Price (MSRP) for this specific vehicle unit including all factory-installed options and packages, expressed in the local currency (USD). Established by the OEM and used as the baseline for dealer pricing and incentive calculations.']
  odometer_reading varchar [note: 'Current odometer reading of the vehicle in miles at the time of inventory check-in or last update. Critical for used, demo, and loaner vehicles to determine CPO eligibility, warranty coverage, and pricing. For new vehicles, reflects delivery mileage.']
  pdi_completed boolean [note: 'Indicates whether the Pre-Delivery Inspection (PDI) has been completed for this vehicle unit. PDI is a mandatory dealer quality check performed before vehicle delivery to a customer, verifying all systems, fluids, and accessories meet OEM standards. True = PDI completed; False = PDI pending.']
  pdi_completed_date date [note: 'The date on which the Pre-Delivery Inspection (PDI) was completed and signed off by the dealer\'s service technician. Null if PDI has not yet been performed.']
  recall_hold boolean [note: 'Indicates whether this vehicle unit is subject to an active NHTSA safety recall that prevents retail sale or delivery until the recall remedy has been performed. True = vehicle is on recall hold and cannot be sold; False = no active recall hold. Critical for regulatory compliance and consumer safety.']
  received_date date [note: 'The date the vehicle unit was physically received and checked into the dealer\'s inventory from the OEM transport carrier or trade-in. Marks the start of the days-on-lot aging clock and floor plan financing period.']
  record_created_timestamp timestamp [note: 'The timestamp when this dealer inventory record was first created in the Silver Layer lakehouse, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports audit trail and data lineage requirements.']
  record_updated_timestamp timestamp [note: 'The timestamp when this dealer inventory record was most recently updated in the Silver Layer lakehouse, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change tracking, incremental processing, and audit trail requirements.']
  source_type varchar [note: 'Indicates how the dealer acquired this vehicle unit: \'factory_order\' = ordered directly from OEM; \'dealer_trade\' = acquired via dealer-to-dealer trade; \'auction\' = purchased at wholesale auction; \'trade_in\' = accepted as customer trade-in; \'fleet_return\' = returned from fleet/rental program; \'lease_return\' = returned at end of lease term.']
  stock_number varchar [note: 'Dealer-assigned internal stock number used within the CDK Global DMS to identify and locate this vehicle on the lot. Unique within a dealership but not globally unique.']
  transport_status varchar [note: 'Current transportation status for vehicles in the delivery pipeline from OEM plant to dealership: \'not_shipped\' = awaiting dispatch from plant; \'in_transit\' = en route via carrier; \'delivered\' = arrived at dealer; \'rail\' = currently on rail transport; \'truck\' = currently on truck transport.']
  window_sticker_url varchar [note: 'URL link to the digital Monroney window sticker (required by the Automobile Information Disclosure Act) for this vehicle unit, hosted by the OEM or a third-party service. Contains MSRP, standard equipment, options, fuel economy ratings, and safety information.']
  yard_slot_code varchar [note: 'Yard slot code where the vehicle is parked at the dealership.']

  Note: 'Real-time inventory of vehicles physically on-hand or in-transit at a dealership. Tracks VIN, nameplate, model year, trim, exterior/interior color, powertrain, days-on-lot, acquisition cost, current asking price, inventory status (available, sold, demo, loaner, in-transit), and PDI (Pre-Delivery Inspection) completion flag. Sourced from CDK Global DMS inventory module.'
}

Table dealer.retail_sale {
  retail_sale_id varchar [pk, note: 'Unique surrogate identifier for each retail vehicle sale transaction record in the dealer domain. Primary key for the retail_sale data product.']
  campaign_id varchar [note: 'Foreign key linking to sales.campaign. Business justification: Campaign ROI and incentive program reporting: retail sales are driven by OEM incentive campaigns. Linking retail_sale to campaign enables campaign-to-sales conversion analytics, incentive spend vs. re']
  inventory_id varchar [note: 'Foreign key linking to dealer.dealer_inventory. Business justification: A retail sale is the transaction that converts a dealer inventory unit into a sold vehicle. retail_sale.stock_number is a denormalized string reference to dealer_inventory.stock_number — replacing it ']
  msrp_price_book_id varchar [note: 'Foreign key linking to product.msrp_price_book. Business justification: Consumer protection regulations and OEM audit requirements mandate recording which MSRP price book governed each retail sale. This enables price compliance audits, incentive reconciliation, and regula']
  opportunity_id varchar [note: 'Foreign key linking to sales.opportunity. Business justification: Retail sale conversion analysis links the final sale back to the originating sales opportunity for win‑loss tracking.']
  primary_retail_customer_party_id varchar [note: 'Reference to the retail customer (buyer) who purchased the vehicle. Links to the customer master record.']
  primary_retail_dealer_dealership_id varchar [note: 'Reference to the dealership that executed the retail sale transaction. Links to the dealer master record in the dealer domain.']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Program managers track retail sales performance against program-level volume and revenue targets (target_production_volume, target_cost_per_vehicle on vehicle_program). Linking retail_sale to vehicle_']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Retail sale reporting and warranty registration depend on linking the sold vehicle to its VIN registry entry.']
  apr decimal(6,4) [note: 'The Annual Percentage Rate (APR) on the retail installment contract as disclosed to the customer under Regulation Z. Expressed as a decimal (e.g., 0.0699 for 6.99%). Null for cash and lease deals.']
  back_end_gross decimal(12,2) [note: 'Gross profit earned from F&I products and dealer reserve on the financing (back-end), representing the total F&I department contribution to the deal. Key dealer profitability metric.']
  created_timestamp timestamp [note: 'The timestamp when the retail sale record was first created in the data platform (Silver Layer ingestion). Conforms to ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and data lineage.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this retail sale record (e.g., USD, CAD, EUR). Supports multi-market dealer network operations.']
  deal_number varchar [note: 'Externally-known alphanumeric deal reference number assigned by the CDK Global DMS F&I module at the time the deal is opened. Used for cross-referencing with dealer records, lender submissions, and OEM reporting.']
  deal_status varchar [note: 'Current lifecycle state of the retail sale deal. \'draft\' indicates deal is being structured; \'pending\' indicates awaiting lender funding approval; \'funded\' indicates lender has funded the deal; \'unwound\' indicates a previously funded deal that was reversed; \'cancelled\' indicates deal was voided before funding.']
  delivery_date date [note: 'The date the vehicle was physically delivered to the customer following Pre-Delivery Inspection (PDI). May differ from sale_date when delivery is deferred. Used for warranty start date determination and OEM retail reporting.']
  delivery_method varchar [note: 'Method of vehicle delivery to customer (dealer_pickup, home_delivery, compound_pickup).']
  discount_amount decimal(12,2) [note: 'Total discount applied to the vehicle sale, calculated as MSRP minus sale price. Includes dealer discounts, OEM incentive discounts, and employee pricing adjustments. Used for dealer margin analysis and OEM incentive reconciliation.']
  dms_deal_reference varchar [note: 'The native deal identifier assigned by the CDK Global DMS F&I module. Used for source system traceability, reconciliation, and integration with downstream OEM reporting and lender portals.']
  doc_fee decimal(10,2) [note: 'Dealer-charged documentation and processing fee included in the deal. Subject to state-level regulatory caps in many jurisdictions. Disclosed on the buyer\'s order.']
  down_payment decimal(12,2) [note: 'Cash down payment made by the customer at the time of sale, excluding trade-in allowance. Reduces the amount financed. Used for deal structure analysis and lender submission.']
  fi_product_revenue decimal(12,2) [note: 'Total gross revenue generated from Finance and Insurance (F&I) aftermarket products sold as part of the deal, including extended service contracts, GAP insurance, paint protection, tire and wheel protection, and credit life/disability insurance.']
  finance_amount decimal(12,2) [note: 'The total amount financed by the customer under the retail installment contract, including vehicle price, F&I products, taxes, and fees, less down payment and trade-in allowance. Null for cash deals.']
  financing_type varchar [note: 'The method by which the customer is financing the vehicle purchase. \'cash\' = outright purchase; \'retail_finance\' = retail installment contract through a lender; \'lease\' = closed-end consumer lease; \'balloon\' = balloon payment retail contract.']
  fleet_sale boolean [note: 'Indicates whether the vehicle was sold as part of a fleet or commercial account transaction rather than a retail consumer sale. Fleet sales are tracked separately for CAFE compliance, OEM fleet incentive programs, and sales mix reporting.']
  front_end_gross decimal(12,2) [note: 'Gross profit earned on the vehicle sale itself (front-end), calculated as sale price minus dealer invoice cost and pack. Excludes F&I product revenue. Key dealer profitability metric reported in DMS and OEM dealer scorecards.']
  lender_name varchar [note: 'Name of the financial institution (captive finance company, bank, credit union) that approved and funded the retail installment contract or lease. Null for cash deals. Used for lender mix reporting and dealer reserve analysis.']
  loan_term_months varchar [note: 'The contractual term of the retail installment contract expressed in months (e.g., 36, 48, 60, 72, 84). Used for lender mix analysis, payment affordability reporting, and portfolio risk assessment.']
  model_year varchar [note: 'The Model Year (MY) of the vehicle sold, as defined by the OEM and NHTSA. Used for CAFE compliance reporting, incentive program eligibility, and sales mix analytics.']
  monthly_payment decimal(10,2) [note: 'The customer\'s contracted monthly payment amount under the retail installment contract or lease agreement. Used for affordability analysis and customer financial profiling.']
  msrp_amount decimal(12,2) [note: 'The Manufacturer Suggested Retail Price (MSRP) of the vehicle as stickered, inclusive of all factory-installed options and destination charges. Expressed in the local currency (USD). Used as the baseline for discount calculation, incentive reporting, and dealer margin analysis.']
  oem_incentive_amount decimal(12,2) [note: 'Total value of OEM-funded customer incentives applied to the deal, including cash-back rebates, conquest bonuses, loyalty bonuses, and special program pricing. Sourced from OEM incentive program data and reconciled against dealer statements.']
  pdi_completed boolean [note: 'Indicates whether the Pre-Delivery Inspection (PDI) was completed and signed off by the dealer technician prior to vehicle delivery to the customer. PDI completion is required for warranty activation and OEM delivery standards compliance.']
  sale_date date [note: 'The calendar date on which the retail vehicle sale was consummated — i.e., the date the buyer signed the retail installment contract or cash purchase agreement. This is the principal business event date used for sales reporting, OEM incentive eligibility, and regulatory compliance.']
  sale_price decimal(12,2) [note: 'The agreed-upon selling price of the vehicle as negotiated between the dealer and the customer, before trade-in allowance, taxes, and fees. This is the gross capitalized cost for lease deals or the selling price for retail finance and cash deals.']
  sales_tax_amount decimal(12,2) [note: 'State and local sales tax assessed on the vehicle sale transaction. Calculated based on the taxable selling price and the applicable jurisdiction tax rate. Used for tax remittance reporting and deal cost reconciliation.']
  trade_in_allowance decimal(12,2) [note: 'The agreed trade-in value credited to the customer for a vehicle traded in as part of the deal. Reduces the amount financed or cash due. Null if no trade-in vehicle was involved in the transaction.']
  trade_in_payoff_amount decimal(12,2) [note: 'The outstanding loan or lease payoff balance on the customer\'s trade-in vehicle at the time of the deal. If payoff exceeds trade-in allowance, the difference (negative equity) is typically rolled into the new deal.']
  updated_timestamp timestamp [note: 'The timestamp when the retail sale record was last modified in the data platform, reflecting deal amendments, status changes, or corrections sourced from CDK Global DMS. Conforms to ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  vehicle_condition varchar [note: 'Condition classification of the vehicle at point of sale. \'new\' indicates a new, untitled vehicle; \'used\' indicates a previously titled vehicle; \'certified_pre_owned\' indicates a manufacturer-certified pre-owned vehicle meeting OEM CPO program standards.']

  Note: 'Records the retail sale of a new or used vehicle by a dealership to an end customer. Captures VIN, sale date, sale price, MSRP, discount amount, trade-in details, financing type (cash, retail finance, lease), F&I products sold, salesperson, and deal status. Sourced from CDK Global DMS F&I module. SSOT for dealer-level vehicle sales transactions.'
}

Table dealer.dealer_service_appointment {
  dealer_service_appointment_id varchar [pk, note: 'Unique identifier for the dealer_service_appointment data product (auto-inserted pre-linking).']
  aftersales_service_appointment_id varchar [note: 'Foreign key linking to aftersales.service_appointment. Business justification: Business process: Dealer DMS schedules service appointments; aftersales processes them. Linking ensures appointment sync for parts, labor, and warranty tracking.']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: Dealer service appointments belong to a dealership; add dealership_id FK to link to dealership and remove redundant dealer_id column.']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Service appointment scheduling needs to associate the customer (party) with the appointment for service history and follow‑up.']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Service appointment scheduling must reference the specific vehicle VIN to allocate resources and track service history.']
  appointment_date date [note: 'Date of the service appointment']
  appointment_number varchar
  appointment_status varchar [note: 'Status (scheduled, confirmed, in-progress, completed, cancelled, no-show)']
  appointment_time timestamp [note: 'Scheduled time of appointment']
  booking_channel varchar
  check_in_timestamp timestamp
  checked_in_at timestamp
  checked_in_timestamp timestamp
  completed_at timestamp
  created_timestamp timestamp
  customer_concern varchar [note: 'Customer-reported concern or issue']
  customer_concern_description varchar
  customer_name varchar [note: 'Name of the customer']
  customer_phone varchar [note: 'Customer phone number']
  drop_off_timestamp timestamp [note: 'Timestamp when vehicle was dropped off']
  estimated_cost decimal(18,2)
  estimated_cost_amount decimal(18,2)
  estimated_duration_hours decimal(4,2) [note: 'Estimated service duration in hours']
  estimated_duration_minutes varchar
  estimated_labor_hours decimal(6,2)
  home_service_flag boolean [note: 'Whether this appointment is for mobile/home service delivery.']
  loaner_requested_flag boolean
  loaner_required_flag boolean [note: 'Whether a loaner vehicle is needed']
  mileage_at_service varchar [note: 'Vehicle mileage at time of service']
  mileage_in varchar
  odometer_reading varchar
  pickup_timestamp timestamp [note: 'Timestamp when vehicle was picked up']
  scheduled_at timestamp
  scheduled_end_timestamp timestamp
  scheduled_start_timestamp timestamp
  scheduled_timestamp timestamp
  service_type varchar [note: 'Type of service (maintenance, repair, recall, warranty)']
  updated_timestamp timestamp

  Note: 'Scheduled service appointments at a dealership for vehicle maintenance, warranty repair, recall service, or customer-pay work. Tracks appointment date/time, customer, VIN, service type, advisor assigned, estimated duration, appointment status (scheduled, checked-in, in-progress, completed, no-show), and transportation option (loaner, shuttle, wait). Sourced from CDK Global DMS service scheduling module. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table dealer.dealer_repair_order {
  dealer_repair_order_id varchar [pk, note: 'Unique identifier for the dealer_repair_order data product (auto-inserted pre-linking).']
  aftersales_repair_order_id varchar [note: 'Foreign key linking to aftersales.repair_order. Business justification: Process: Dealer creates a repair order in DMS; it must reference the central aftersales repair order for warranty validation and labor costing.']
  dealer_service_appointment_id varchar [note: 'Foreign key linking to dealer.dealer_service_appointment. Business justification: A dealer repair order is the execution record that fulfills a scheduled service appointment. The appointment (dealer_service_appointment) is the parent scheduling event; the repair order (dealer_repai']
  dealership_id varchar [note: 'Foreign key linking to dealer.dealership. Business justification: A repair order is always performed at a specific dealership. dealer_repair_order currently has no in-domain FK to dealership (only cross-domain links to aftersales, customer, and vehicle domains exist']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Repair orders must be linked to the owning customer for warranty claim processing and regulatory reporting.']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Dealers perform recall remedy work tracked via repair orders. recall_campaign_number is denormalized. NHTSA recall completion rate reporting requires linking repair orders to specific recall campaigns']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Repair orders must be tied to the VIN registry to manage warranty repairs and parts usage per vehicle.']
  cause_description varchar [note: 'Diagnosed cause']
  close_date date [note: 'Date repair order was closed']
  closed_at timestamp
  closed_timestamp timestamp
  complaint_description varchar [note: 'Customer complaint description']
  correction_description varchar [note: 'Correction performed']
  created_timestamp timestamp
  labor_amount decimal(18,2) [note: 'Total labor charges']
  labor_hours decimal(9,2)
  mileage varchar [note: 'Vehicle mileage at time of repair']
  open_date date [note: 'Date repair order was opened']
  opened_at timestamp
  opened_timestamp timestamp
  parts_amount decimal(18,2) [note: 'Total parts charges']
  payment_type varchar [note: 'Payment type (customer pay, warranty, internal, insurance)']
  pickup_delivery_flag boolean [note: 'Whether vehicle pickup and delivery service is included.']
  repair_description varchar
  repair_order_number varchar
  repair_order_status varchar
  repair_status varchar
  ro_number varchar [note: 'Repair order number']
  ro_status varchar [note: 'Status (open, in-progress, parts-on-order, completed, invoiced)']
  total_amount decimal(18,2) [note: 'Total repair order amount']
  total_labor_amount decimal(18,2)
  total_parts_amount decimal(18,2)
  updated_timestamp timestamp
  warranty_flag boolean

  Note: 'Detailed repair order (RO) record for each vehicle service event at a dealership. Captures RO number, open/close dates, VIN, mileage-in, complaint/cause/correction (3C), labor operations, technician assignments, parts consumed, warranty vs customer-pay vs internal split, total labor hours, total parts cost, and RO status. Core operational record for dealer service operations sourced from CDK Global DMS. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table dealer.performance_scorecard {
  performance_scorecard_id varchar [pk, note: 'Unique identifier for the dealer performance scorecard record.']
  franchise_agreement_id varchar [note: 'Foreign key linking to dealer.franchise_agreement. Business justification: A performance scorecard evaluates a dealer\'s compliance against the terms defined in their franchise agreement — including minimum_sales_quota_annual, customer_satisfaction_target_score, minimum_servi']
  primary_performance_dealer_dealership_id varchar [note: 'Reference to the dealer being evaluated in this scorecard.']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: OEMs issue segment-specific performance scorecards (e.g., EV sales scorecard, truck segment scorecard) to dealers. Linking scorecard to product_segment enables segment-level dealer performance reporti']
  comments varchar [note: 'Additional notes or commentary from the OEM regarding the dealer\'s performance during this period.']
  composite_score decimal(5,2) [note: 'The overall weighted composite performance score combining all KPI categories (sales, service, parts, customer satisfaction, facility standards) used for franchise compliance and incentive eligibility.']
  composite_score_benchmark decimal(5,2) [note: 'The minimum composite score required for franchise compliance and incentive program eligibility.']
  created_timestamp timestamp [note: 'The timestamp when this scorecard record was first created in the system.']
  csi_benchmark decimal(5,2) [note: 'The target or industry benchmark CSI score the dealer is expected to meet or exceed.']
  csi_score decimal(5,2) [note: 'The Customer Satisfaction Index score measuring overall customer satisfaction with sales and service experience, typically on a scale of 0-100 or 0-1000 depending on OEM methodology.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code for all monetary amounts in this scorecard.']
  days_supply varchar [note: 'The average number of days of inventory on hand at the dealer based on current sales rate.']
  delivery_satisfaction_score decimal(5,2) [note: 'Customer satisfaction score for delivery operations.']
  dms_integration_source varchar [note: 'The Dealer Management System from which raw performance data was extracted for this scorecard.']
  facility_standards_score decimal(5,2) [note: 'The score measuring dealer compliance with OEM facility image and standards requirements (showroom, service bays, signage, etc.).']
  fiscal_quarter varchar [note: 'The fiscal quarter (1-4) to which this scorecard period belongs, if applicable.']
  fiscal_year varchar [note: 'The fiscal year to which this scorecard period belongs.']
  franchise_compliance_status varchar [note: 'The dealer\'s franchise agreement compliance status based on this scorecard\'s performance results.']
  incentive_eligibility_flag boolean [note: 'Indicates whether the dealer met the minimum performance thresholds to qualify for OEM incentive programs during this scorecard period.']
  inventory_turn_rate decimal(5,2) [note: 'The number of times the dealer\'s new vehicle inventory was sold and replaced during the scorecard period, calculated as sales divided by average inventory.']
  last_modified_timestamp timestamp [note: 'The timestamp when this scorecard record was last updated.']
  market_share_pct decimal(5,2) [note: 'The dealer\'s share of total new vehicle sales in their assigned territory or market area during the scorecard period.']
  new_vehicle_sales_actual varchar [note: 'The actual number of new vehicles sold by the dealer during the scorecard period.']
  new_vehicle_sales_attainment_pct decimal(5,2) [note: 'The percentage of the new vehicle sales objective achieved by the dealer (actual/objective * 100).']
  new_vehicle_sales_objective varchar [note: 'The target number of new vehicles the dealer was expected to sell during the scorecard period.']
  nps_benchmark decimal(5,2) [note: 'The target or industry benchmark NPS score the dealer is expected to meet or exceed.']
  nps_score decimal(5,2) [note: 'The Net Promoter Score measuring customer loyalty and likelihood to recommend the dealer, calculated as percentage of promoters minus percentage of detractors.']
  parts_fill_rate_pct decimal(5,2) [note: 'The percentage of parts orders fulfilled from dealer inventory without backorder during the scorecard period.']
  parts_revenue_actual decimal(15,2) [note: 'The actual parts department revenue generated during the scorecard period.']
  parts_revenue_objective decimal(15,2) [note: 'The target parts department revenue for the scorecard period.']
  performance_tier varchar [note: 'The performance tier classification assigned to the dealer based on composite score and key metrics.']
  period_type varchar [note: 'The frequency of the scorecard evaluation period.']
  published_date date [note: 'The date this scorecard was officially published and communicated to the dealer.']
  reviewer_name varchar [note: 'The name of the OEM regional manager or analyst who reviewed and approved this scorecard.']
  scorecard_period_end_date date [note: 'The last day of the evaluation period covered by this scorecard.']
  scorecard_period_start_date date [note: 'The first day of the evaluation period covered by this scorecard (monthly or quarterly).']
  scorecard_status varchar [note: 'The current status of this scorecard record in its lifecycle.']
  service_absorption_rate_pct decimal(5,2) [note: 'The percentage of fixed operations expenses covered by service and parts gross profit, a key profitability metric for dealer operations.']
  service_revenue_actual decimal(15,2) [note: 'The actual service department revenue generated during the scorecard period.']
  service_revenue_objective decimal(15,2) [note: 'The target service department revenue for the scorecard period.']
  training_compliance_pct decimal(5,2) [note: 'The percentage of required OEM training programs completed by dealer staff during the scorecard period.']
  used_vehicle_sales_actual varchar [note: 'The actual number of used vehicles sold by the dealer during the scorecard period.']
  used_vehicle_sales_attainment_pct decimal(5,2) [note: 'The percentage of the used vehicle sales objective achieved by the dealer.']
  used_vehicle_sales_objective varchar [note: 'The target number of used vehicles the dealer was expected to sell during the scorecard period.']
  warranty_claim_approval_rate_pct decimal(5,2) [note: 'The percentage of warranty claims submitted by the dealer that were approved by the OEM during the scorecard period.']

  Note: 'Periodic (monthly/quarterly) dealer performance scorecard capturing KPIs across sales, service, parts, customer satisfaction, and facility standards. Tracks new vehicle sales vs objective, used vehicle sales, service absorption rate, CSI (Customer Satisfaction Index) score, NPS (Net Promoter Score), parts fill rate, and overall composite score. Used for franchise compliance and incentive eligibility determination.'
}

Table aftersales.aftersales_repair_order {
  aftersales_repair_order_id varchar [pk, note: 'Unique identifier for the repair_order data product (auto-inserted pre-linking).']
  aftersales_service_appointment_id varchar [note: 'Foreign key linking to aftersales.aftersales_service_appointment. Business justification: A repair order is typically created from a service appointment. The aftersales_repair_order has appointment_arrival_timestamp, appointment_departure_timestamp, and appointment_scheduled_timestamp — al']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Repair order processing requires the vehicle\'s exact BOM configuration to perform automated TSB applicability checks, validate correct parts identification, and confirm warranty coverage against the b']
  fleet_account_id varchar [note: 'Foreign key linking to customer.customer_fleet_account. Business justification: Fleet billing consolidation requires all repair orders to be attributed to the fleet account for consolidated invoicing, contract compliance reporting, and annual spend tracking. Fleet managers run RO']
  primary_aftersales_customer_party_id varchar [note: 'Identifier of the customer who owns the vehicle.']
  primary_aftersales_dealer_dealership_id varchar [note: 'Identifier of the dealer/service center handling the repair.']
  recall_campaign_id varchar [note: 'Identifier of a recall campaign linked to this repair.']
  service_center_id varchar [note: 'Identifier of the physical service location.']
  technician_id varchar [note: 'Identifier of the primary technician assigned to perform the work.']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Warranty root-cause and repair order processing requires tracing the exact build record (rework_count, quality_gate_status, build timestamps) for a vehicle. Service advisors and warranty engineers use']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Required for warranty verification and recall tracking in the Repair Order processing workflow, linking each order to the vehicle\'s VIN registry record.']
  actual_completion_time timestamp [note: 'Actual date and time when the repair was completed.']
  aftersales_repair_order_status varchar [note: 'Current lifecycle status of the repair order.']
  appointment_arrival_timestamp timestamp [note: 'Timestamp when the vehicle arrived at the service center.']
  appointment_departure_timestamp timestamp [note: 'Timestamp when the vehicle left the service center.']
  appointment_scheduled_timestamp timestamp [note: 'Date and time when the service appointment was scheduled.']
  close_timestamp timestamp [note: 'Date and time when the repair order was closed.']
  created_timestamp timestamp [note: 'Timestamp when the repair order record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO currency code for monetary values.']
  customer_feedback_score varchar [note: 'Numeric rating (1-5) provided by the customer after service.']
  customer_signature_flag boolean [note: 'Indicates whether the customer signed off on the repair order.']
  diagnostic_code varchar [note: 'Standard OBD diagnostic code recorded during service.']
  discount_amount decimal(18,2) [note: 'Total discount applied to the repair order.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  is_estimate boolean [note: 'Indicates whether the record is an estimate prior to work being performed.']
  labor_rate_per_hour decimal(18,2) [note: 'Standard labor rate applied per hour.']
  labor_total_cost decimal(18,2) [note: 'Total cost of labor before taxes and discounts.']
  labor_total_hours decimal(5,2) [note: 'Total labor hours recorded for the repair order.']
  mileage_at_service date [note: 'Vehicle odometer reading at the time of service.']
  net_amount decimal(18,2) [note: 'Final amount after tax and discount.']
  obd_diagnostic_link_reference varchar [note: 'FK to the OBD diagnostic link that triggered this repair order']
  obd_live_data_link_reference varchar
  open_timestamp timestamp [note: 'Date and time when the repair order was opened.']
  parts_total_cost decimal(18,2) [note: 'Total cost of parts consumed before taxes and discounts.']
  payment_method varchar [note: 'Method used by the customer to settle the repair order.']
  payment_status varchar [note: 'Current status of the payment for the repair order.']
  promised_completion_time timestamp [note: 'Scheduled date and time promised to the customer for repair completion.']
  ro_number varchar [note: 'External repair order number assigned by the service center.']
  service_center_region varchar [note: 'Geographic region where the service center is located.']
  service_notes varchar [note: 'Free-text notes entered by service advisor describing work performed.']
  service_priority varchar [note: 'Priority level assigned to the repair order.']
  service_type varchar [note: 'Category of service performed.']
  tax_amount decimal(18,2) [note: 'Total tax applied to the repair order.']
  technician_notes varchar [note: 'Free-text notes entered by the technician during repair.']
  total_amount decimal(18,2) [note: 'Gross amount of the repair order before tax and discount.']
  triggered_by_telemetry_flag boolean
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the repair order record.']
  warranty_claim_number varchar [note: 'Reference number for the warranty claim associated with this repair.']
  warranty_flag boolean [note: 'Indicates whether the repair is covered under warranty.']
  warranty_type varchar [note: 'Type of warranty covering the repair.']

  Note: 'Core transactional record capturing a vehicle service or repair event at an authorized service center or dealership. Tracks RO number, vehicle VIN, customer, service advisor, open/close dates, labor operations performed, parts consumed, total labor cost, total parts cost, total RO value, payment method, warranty vs. customer pay vs. internal pay type, DMS source (CDK Global), mileage at write-up, promised completion time, actual completion time, technician assignments, and RO status lifecycle (open, in-progress, quality-check, closed, invoiced).. SSOT: canonical source is dealer.dealer_repair_order. This product is a domain-local reference. SUPERSEDED: Use dealer.dealer_repair_order as the single source of truth.'
}

Table aftersales.repair_order_line {
  repair_order_line_id varchar [pk, note: 'System-generated unique identifier for the repair order line.']
  aftersales_repair_order_id varchar [note: 'Identifier of the parent repair order header to which this line belongs.']
  aftersales_service_appointment_id varchar [note: 'Identifier of the service appointment linked to this line.']
  defect_record_id varchar [note: 'Foreign key linking to quality.defect_record. Business justification: Repair order line-level defect traceability: links the specific repair operation to the quality defect that triggered it, enabling part-level warranty cost allocation and quality feedback reporting — ']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: REQUIRED: Parts Traceability Report for warranty investigations needs to link each repair line to the inbound part record it originated from.']
  service_center_id varchar [note: 'Identifier of the authorized service center where work was performed.']
  service_part_id varchar [note: 'Foreign key linking to aftersales.service_part. Business justification: Repair order lines track parts consumed during service (part_quantity, part_price columns exist). The aftersales.service_part is the authoritative parts master for dealer service operations. Adding se']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: REQUIRED: Parts used in a repair order line must be tracked against the inventory SKU master for cost, stock deduction, and compliance reporting.']
  storage_location_id varchar [note: 'Foreign key linking to inventory.storage_location. Business justification: REQUIRED: Service parts are issued from a specific warehouse bin; linking to storage_location enables inventory location traceability for service.']
  technician_id varchar [note: 'Identifier of the technician who performed the labor.']
  tsb_id varchar [note: 'Foreign key linking to aftersales.tsb. Business justification: Each repair order line represents a specific labor operation or job. TSBs (Technical Service Bulletins) define the repair procedures for specific operations. Linking repair_order_line to tsb at the li']
  warranty_claim_id varchar [note: 'Identifier of the warranty claim associated with this line, if applicable.']
  actual_technician_hours decimal(5,2) [note: 'Actual labor hours logged by the technician for this line.']
  cause_complaint varchar [note: 'Narrative describing the customer complaint or issue that initiated the service.']
  correction varchar [note: 'Narrative describing the corrective action taken to resolve the complaint.']
  created_timestamp timestamp [note: 'Timestamp when the repair order line record was created in the system.']
  currency_code varchar [note: 'Three‑letter ISO 4217 currency code for monetary values on the line.']
  discount_amount decimal(18,2) [note: 'Monetary discount applied to this line, if any.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  labor_category varchar [note: 'Broad classification of the labor type performed.']
  labor_rate decimal(18,2) [note: 'Hourly labor rate applied to the technician for this operation.']
  labor_skill_level varchar [note: 'Skill level required for the technician to perform the operation.']
  labor_time_standard decimal(5,2) [note: 'Flat‑rate standard labor time in hours for the operation code.']
  line_sequence varchar [note: 'Sequential number of the line within the repair order for ordering.']
  line_status varchar [note: 'Current processing status of the repair order line.']
  line_total decimal(12,2) [note: 'Total monetary amount for the line (labor_rate * actual_technician_hours) before discounts and taxes.']
  notes varchar [note: 'Additional free‑form notes entered by the technician or service advisor.']
  operation_code varchar [note: 'Standard code representing the specific labor operation performed (e.g., oil change, brake inspection).']
  overtime_flag boolean [note: 'True if overtime rates were applied to this labor line.']
  overtime_multiplier decimal(3,2) [note: 'Multiplier applied to the labor_rate when overtime_flag is true (e.g., 1.5).']
  part_price decimal(18,2) [note: 'Standard price per unit of the part at the time of service.']
  part_quantity decimal(6,2) [note: 'Quantity of the part used for this line.']
  parts_used_flag boolean [note: 'Indicates whether any parts were consumed on this line.']
  service_date date [note: 'Date on which the service work was performed.']
  sublet_cost decimal(18,2) [note: 'Total cost charged by the sublet vendor for this line.']
  sublet_flag boolean [note: 'True if the work was performed by an external subcontractor.']
  tax_amount decimal(18,2) [note: 'Tax applied to the line total.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the repair order line record.']
  vehicle_vin varchar [note: 'Unique 17‑character identifier of the vehicle serviced.']
  warranty_flag boolean [note: 'Indicates whether the labor line is covered under warranty (true) or not (false).']

  Note: 'Individual labor operation or job line within a repair order. Captures operation code, labor time standard (flat-rate hours), actual technician hours, labor rate, line total, technician ID, cause/complaint/correction (3C) narrative, warranty flag, sublet flag, and line status. Supports granular cost analysis and technician productivity tracking per CDK Global DMS job line structure.'
}

Table aftersales.warranty_claim {
  warranty_claim_id varchar [pk, note: 'Unique identifier for the warranty_claim data product (auto-inserted pre-linking).']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Warranty adjudication requires validating that the claimed component is present in the vehicle\'s actual BOM configuration. Direct BOM reference on the warranty claim enables automated coverage validat']
  causal_inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: Warranty cost recovery and supplier quality escalation require linking the causal part to the supply catalog. causal_part_number is a plain-text denormalization of inbound_part. Automotive OEMs use th']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Warranty claims can be directly triggered by engineering changes (e.g., a design change that introduced a field failure). Goodwill and direct-submission claims exist independently of repair orders. Th']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: Warranty adjudication requires configuration-level data (market region, OTA tier, emissions cert, trim level) to validate claim eligibility and coverage scope. Claims processors and warranty analysts ']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Warranty claims carry a causal_part_number (denormalized). Linking to part_master enables warranty cost analysis by part, engineering feedback loops for high-failure-rate parts, supplier warranty cost']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Warranty batch defect analysis and recall investigations require linking claims to the originating production order to identify lot-level defects, production dates, and scrap/rework quantities. Qualit']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.compliance_recall_campaign. Business justification: Regulatory warranty claim reporting mandates associating claims arising from a recall campaign with that campaign for audit and reimbursement.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: TREAD Act (US) and EU Regulation 2019/2144 require OEMs to report warranty claims related to safety defects to regulators. Linking warranty claims to the specific regulatory requirement enables automa']
  service_campaign_id varchar [note: 'Identifier of the recall or service campaign linked to the claim.']
  service_center_id varchar [note: 'Identifier of the authorized service center performing the repair.']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Aggregating warranty claims by vehicle program is required for reliability analysis and program improvement decisions.']
  vehicle_warranty_id varchar [note: 'Foreign key linking to aftersales.vehicle_warranty. Business justification: A warranty claim is filed against a specific VIN-level vehicle warranty entitlement (vehicle_warranty). The aftersales_warranty_claim already has warranty_policy_id (policy definition) but lacks a dir']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Needed for claim eligibility validation against the vehicle\'s VIN registry during Warranty Claim adjudication.']
  warranty_aftersales_customer_party_id varchar [note: 'Identifier of the vehicle owner who is the warranty claimant.']
  warranty_aftersales_dealer_dealership_id varchar [note: 'Identifier of the dealer or service center submitting the claim.']
  warranty_aftersales_dealership_id varchar [note: 'Identifier of the dealer or service center submitting the claim.']
  warranty_aftersales_party_id varchar [note: 'Identifier of the vehicle owner who is the warranty claimant.']
  warranty_policy_id varchar [note: 'Foreign key linking to aftersales.warranty_policy. Business justification: A warranty claim is filed under a specific warranty policy; linking directly to warranty_policy provides direct access to policy terms without needing to traverse vehicle_warranty.']
  adjudication_outcome varchar [note: 'Result of the OEM\'s review of the claim.']
  adjusted_amount decimal(18,2) [note: 'Monetary amount of the adjustment applied to the claim.']
  approved_labor_cost decimal(18,2) [note: 'Monetary amount approved for labor services.']
  approved_labor_hours decimal(5,2) [note: 'Number of labor hours approved for reimbursement.']
  approved_parts_cost decimal(18,2) [note: 'Monetary amount approved for parts used in the repair.']
  cause_code varchar [note: 'Standardized code identifying the root cause of the defect']
  claim_adjusted_flag boolean [note: 'Indicates whether the claim amount was later adjusted.']
  claim_category varchar [note: 'High‑level classification of the claim type.']
  claim_created_by varchar [note: 'User identifier of the employee who entered the claim.']
  claim_number varchar [note: 'External claim identifier assigned by the OEM or dealer for tracking.']
  claim_status varchar [note: 'Current lifecycle status of the warranty claim.']
  claim_submission_timestamp timestamp [note: 'Exact timestamp when the warranty claim was submitted to the OEM.']
  correction_code varchar [note: 'Standardized code describing the corrective action taken']
  currency_code varchar [note: 'Three‑letter ISO currency code for the claim amounts.']
  customer_complaint_code varchar [note: 'Standardized code representing the customer complaint category']
  failure_date date [note: 'Date the vehicle failure that triggered the warranty claim occurred.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  goodwill_flag boolean [note: 'Indicates whether the claim is processed as goodwill (no reimbursement).']
  labor_hours_claimed decimal(5,2) [note: 'Total labor hours claimed by the technician for the warranty repair']
  labor_rate_per_hour decimal(18,2) [note: 'Standard labor rate used for calculating labor cost.']
  mileage_at_failure date [note: 'Vehicle odometer reading at time of reported failure in kilometers']
  notes varchar [note: 'Free‑form text notes entered by the service advisor or adjudicator.']
  parts_tax_amount decimal(18,2) [note: 'Tax amount applied to the approved parts cost.']
  record_created_timestamp timestamp [note: 'Timestamp when the claim record was first created in the system.']
  record_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the claim record.']
  rejection_reason_code varchar [note: 'Code indicating why a claim was rejected, if applicable.']
  repair_date date [note: 'Date the repair work was performed on the vehicle.']
  sublet_cost decimal(18,2) [note: 'Cost of any sublet or outsourced work included in the warranty claim']
  total_claim_amount decimal(18,2) [note: 'Total monetary value of the claim (labor + parts).']
  warranty_end_date date [note: 'Date when the vehicle\'s warranty coverage expires.']
  warranty_start_date date [note: 'Date when the vehicle\'s warranty coverage began.']
  warranty_type varchar [note: 'Category of warranty coverage applicable to the claim.']

  Note: 'Warranty claim submitted by a dealer or authorized service center to the OEM for reimbursement of warranty-covered repairs. Tracks claim number, VIN, repair order reference, failure date, repair date, claim submission date, claim status (submitted, approved, rejected, adjusted, paid), approved labor hours, approved parts cost, total claim amount, rejection reason code, goodwill flag, campaign/recall linkage, and OEM adjudication outcome. Integrates with SAP SD warranty module and CDK Global DMS.. SSOT: canonical source is dealer.dealer_warranty_claim. This product is a domain-local reference. SUPERSEDED: Use dealer.dealer_warranty_claim as the single source of truth.'
}

Table aftersales.warranty_policy {
  warranty_policy_id varchar [pk, note: 'System-generated unique identifier for the warranty policy record.']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Warranty policies are authored and administered at the vehicle model level in automotive OEM operations. Policy lookup during claim adjudication and customer warranty inquiries requires direct model b']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: Powertrain-specific warranty policies (EV battery 8yr/100k regulatory requirement, hybrid system coverage, ICE powertrain terms) require direct powertrain_variant binding for precise policy applicatio']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: Warranty policies are governed and enforced by specific regulatory bodies (NHTSA, FTC, European Commission). Linking to regulatory_body normalizes the plain-text regulatory_body column and enables com']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Warranty policies must comply with specific regulations (Magnuson-Moss Act, EU Directive 1999/44/EC). Compliance teams need to trace which regulatory requirement governs each warranty policy for audit']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Warranty policies are defined per vehicle program; the link supports cost forecasting and compliance tracking per program.']
  authorized_dealer_required_flag boolean [note: 'Indicates whether warranty service must be performed at an authorized dealer (true) or can be performed at any qualified service center (false).']
  claim_limit_per_year varchar [note: 'Maximum number of warranty claims allowed per vehicle per calendar year.']
  claim_limit_total decimal [note: 'Overall maximum number of warranty claims permitted during the policy term.']
  country_code varchar [note: 'ISO 3166‑1 alpha‑3 country code indicating the primary country of warranty applicability.']
  coverage_description varchar [note: 'Free‑text description of what components or systems are covered under the policy.']
  coverage_type varchar [note: 'Category of coverage provided by the warranty (e.g., basic, powertrain, corrosion, emissions, EV battery, ADAS).']
  created_timestamp timestamp [note: 'Date and time when the warranty policy record was first created in the system.']
  deductible_amount decimal(18,2) [note: 'Fixed monetary amount the customer must pay for each covered repair under the warranty.']
  duration_months varchar [note: 'Length of the warranty coverage expressed in calendar months.']
  effective_end_date date [note: 'Date and time when the warranty coverage expires (typically EOP or calculated from duration).']
  effective_start_date date [note: 'Date and time when the warranty coverage becomes effective (typically SOP).']
  eop_date date [note: 'The production end date of the vehicle model to which the warranty applies.']
  exclusions varchar [note: 'List of components, conditions, or events excluded from coverage.']
  extension_allowed_flag boolean [note: 'True if the warranty may be extended beyond the original term under defined conditions.']
  extension_terms varchar [note: 'Free‑text description of the conditions, cost, and duration for extending the warranty.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  inclusions varchar [note: 'List of components, systems, or services explicitly covered.']
  is_extended_warranty_flag boolean
  last_updated_timestamp timestamp [note: 'Date and time of the most recent modification to the warranty policy record.']
  market_region varchar [note: 'Geographic market or region where the warranty is offered (e.g., North America, EU).']
  mileage_limit varchar [note: 'Maximum distance the vehicle may travel while the warranty remains valid, expressed in miles.']
  notes varchar [note: 'Additional free‑form notes or remarks about the warranty policy.']
  policy_number varchar [note: 'External business identifier assigned to the warranty policy, used in contracts and customer communications.']
  policy_status varchar [note: 'Current lifecycle status of the warranty policy.']
  provider_type varchar
  renewal_allowed_flag boolean [note: 'Indicates whether the warranty can be renewed after expiration.']
  renewal_terms varchar [note: 'Details of renewal options, pricing, and eligibility.']
  service_center_network varchar [note: 'Identifier of the service‑center network eligible for warranty work (e.g., OEM network, third‑party network).']
  sop_date date [note: 'The production start date of the vehicle model to which the warranty applies.']
  transferable_flag boolean [note: 'Indicates whether the warranty can be transferred to a subsequent owner (true) or is non‑transferable (false).']

  Note: 'Master definition of warranty coverage terms applicable to a vehicle nameplate, model year, powertrain type, or market. Captures warranty type (basic/bumper-to-bumper, powertrain, corrosion, emissions, EV battery, ADAS), coverage duration in months, coverage distance in miles/km, deductible amount, transferability flag, market/region applicability, SOP and EOP dates, and governing regulatory body (NHTSA, EPA). Serves as the authoritative reference for warranty eligibility determination.'
}

Table aftersales.vehicle_warranty {
  vehicle_warranty_id varchar [pk, note: 'Unique surrogate key for the vehicle warranty record.']
  aftersales_warranty_policy_id varchar [note: 'Foreign key linking to aftersales.warranty_policy. Business justification: Vehicle warranty must reference the applicable warranty policy; adds inbound to warranty_policy and outbound from vehicle_warranty.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Vehicle warranty terms, minimum duration, and transferability rules are jurisdiction-specific (EU mandatory 2-year minimum, US state lemon laws). Linking vehicle_warranty to jurisdiction enables marke']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Warranty administration requires linking each warranty to the owning party for eligibility verification and regulatory compliance reporting.']
  primary_vehicle_dealer_dealership_id varchar [note: 'Identifier of the dealer that sold the vehicle or issued the warranty.']
  service_campaign_id varchar [note: 'Foreign key linking to aftersales.service_campaign. Business justification: Vehicle warranty records track recall eligibility (eligible_for_recall boolean exists) and warranty impact from campaigns (service_campaign.warranty_impact_flag). The vehicle_warranty already has vehi']
  service_center_id varchar [note: 'Identifier of the authorized service center handling warranty work.']
  vehicle_build_id varchar [note: 'Foreign key linking to manufacturing.vehicle_build. Business justification: Warranty activation and coverage determination depends on the actual build date, plant, and quality gate status from the build record. Warranty start dates are calculated from build completion timesta']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Connects warranty contracts to the VIN registry to validate coverage periods and claim eligibility.']
  claims_last_amount decimal(18,2) [note: 'Monetary amount of the most recent warranty claim.']
  claims_last_date date [note: 'Date of the most recent warranty claim.']
  coverage_area varchar [note: 'Geographic scope of the warranty coverage.']
  coverage_description varchar [note: 'Free‑text description of what components and services are covered.']
  coverage_end_mileage varchar [note: 'Maximum mileage at which warranty coverage ends.']
  coverage_start_mileage varchar [note: 'Mileage reading at which warranty coverage begins.']
  cpo_warranty_flag boolean [note: 'True if the warranty applies to a Certified Pre‑Owned vehicle.']
  created_timestamp timestamp [note: 'Timestamp when the warranty record was first created in the system.']
  duration_months varchar [note: 'Total length of the warranty in months.']
  eligible_for_recall boolean [note: 'Indicates whether the vehicle is eligible for a safety recall under this warranty.']
  end_date date [note: 'Date the warranty coverage ends.']
  exclusions varchar [note: 'Text describing items or conditions excluded from coverage.']
  extended_warranty_flag boolean [note: 'Indicates whether the warranty has been extended beyond the original terms.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  last_transfer_date date [note: 'Date of the most recent warranty transfer.']
  mileage_limit varchar [note: 'Maximum mileage allowed under the warranty.']
  original_purchase_date date [note: 'Date the vehicle was originally purchased by the first owner.']
  policy_code varchar [note: 'Internal code representing the warranty policy.']
  program_category varchar [note: 'Broad category of the warranty program.']
  program_name varchar [note: 'Name of the warranty program (e.g., New Vehicle, CPO, Extended).']
  remaining_mileage varchar [note: 'Mileage remaining before the warranty limit is reached.']
  remaining_months varchar [note: 'Number of months remaining before warranty expiration.']
  renewal_date date [note: 'Date on which the warranty was renewed or is scheduled to renew.']
  renewal_flag boolean [note: 'Indicates whether the warranty is eligible for renewal.']
  service_plan varchar [note: 'Name of the service plan associated with the warranty.']
  start_date date [note: 'Date the warranty coverage became effective (in‑service date).']
  status_reason varchar [note: 'Reason why the warranty is in its current status.']
  transfer_allowed boolean [note: 'True if the warranty may be transferred to a subsequent owner.']
  transfer_count varchar [note: 'Number of times the warranty has been transferred to a new owner.']
  transfer_fee decimal(10,2) [note: 'Fee charged for transferring the warranty to a new owner.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the warranty record.']
  vehicle_warranty_status varchar [note: 'Current lifecycle status of the warranty.']
  warranty_claims_amount decimal(18,2) [note: 'Cumulative monetary value of all warranty claims.']
  warranty_claims_count varchar [note: 'Total number of warranty claims filed to date.']
  warranty_document_url varchar [note: 'Link to the electronic copy of the warranty contract.']
  warranty_number varchar [note: 'External warranty contract number assigned by the manufacturer or dealer.']
  warranty_terms_version varchar [note: 'Version identifier of the warranty terms document.']
  warranty_type varchar [note: 'Category of coverage provided by the warranty.']

  Note: 'VIN-level warranty entitlement record linking a specific vehicle to its applicable warranty policies. Tracks warranty start date (in-service date), expiration date, remaining months, remaining mileage, warranty status (active, expired, voided), extended warranty flag, CPO (Certified Pre-Owned) warranty flag, and any warranty transfer history. This is the SSOT for whether a specific vehicle is under warranty at any point in time.'
}

Table aftersales.service_campaign {
  service_campaign_id varchar [pk, note: 'Unique surrogate key for the service campaign record.']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Service campaigns are frequently triggered by engineering change orders (ECOs) identifying field-risk issues. Linking service_campaign to the originating change supports campaign root cause documentat']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Service campaigns are scoped to specific jurisdictions (NHTSA-mandated US campaigns vs. UNECE EU campaigns). Regulatory reporting deadlines and compliance_status differ by jurisdiction. Linking to jur']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: Service campaigns (including safety recalls and customer satisfaction programs) are defined at the vehicle model level. Campaign VIN population identification, NHTSA regulatory reporting, and dealer n']
  ncap_test_result_id varchar [note: 'Foreign key linking to quality.ncap_test_result. Business justification: Safety-related service campaigns are directly triggered by NCAP test failures. Linking service_campaign to ncap_test_result enables regulatory traceability from safety test outcomes to field remediati']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Platform-wide service campaigns occur when shared architecture components are defective across multiple models (e.g., shared suspension, shared EV battery platform). Regulatory recall planning and aff']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: A safety_recall_flag or emissions_recall_flag on a service campaign indicates it was triggered by a formal recall. Linking service_campaign to recall_campaign enables OEMs to track operational remedy ']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Service campaigns with nhtsa_compliance_flag or unece_compliance_flag are mandated by specific regulatory requirements. Compliance teams must trace each campaign to the governing regulation for regula']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Service campaigns are planned per vehicle program; linking enables program‑level impact analysis and regulatory reporting.']
  affected_model_year_end varchar [note: 'Last model year in the range of vehicles covered.']
  affected_model_year_start varchar [note: 'First model year in the range of vehicles covered.']
  affected_vin_population varchar [note: 'Estimated count of VINs that fall within the campaign scope.']
  campaign_cost_estimate decimal(18,2) [note: 'Projected total cost to execute the campaign (currency assumed USD).']
  campaign_notes varchar [note: 'Free‑form notes or comments from campaign managers.']
  campaign_priority varchar [note: 'Priority level for resource allocation and scheduling.']
  campaign_region varchar [note: 'Primary geographic region(s) affected; uses ISO‑3 country codes.']
  campaign_status varchar [note: 'Current lifecycle status of the campaign.']
  campaign_type varchar [note: 'Classification of the campaign: safety recall, emissions recall, customer satisfaction program, or technical service bulletin action.']
  compliance_status varchar [note: 'Overall compliance status of the campaign with applicable regulations.']
  customer_satisfaction_flag boolean [note: 'True if the campaign is a voluntary customer‑satisfaction program.']
  effective_end_date date [note: 'Date when the campaign is closed or no longer applicable (nullable).']
  effective_start_date date [note: 'Date when the campaign becomes effective for affected vehicles.']
  emissions_recall_flag boolean [note: 'True if the campaign addresses emissions compliance.']
  estimated_repair_time_minutes varchar [note: 'Average time, in minutes, required to complete the repair per vehicle.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  nhtsa_compliance_flag boolean [note: 'Indicates whether the campaign meets NHTSA requirements.']
  parts_cost_estimate decimal(18,2) [note: 'Estimated cost of parts required for the campaign.']
  record_audit_created timestamp [note: 'Timestamp when the campaign record was first created in the data lake.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the campaign record.']
  regulatory_reporting_date date [note: 'Date on which the campaign was reported to the regulator.']
  regulatory_reporting_status varchar [note: 'Current status of the campaign\'s regulatory filing with NHTSA/UNECE.']
  remedy_description varchar [note: 'Detailed description of the repair or corrective action required.']
  safety_recall_flag boolean [note: 'True if the campaign is a safety‑related recall.']
  technical_service_bulletin_flag boolean [note: 'True if the campaign originates from a TSB.']
  unece_compliance_flag boolean [note: 'Indicates whether the campaign meets UNECE regulations.']
  warranty_impact_flag boolean [note: 'Indicates whether the campaign affects warranty coverage.']

  Note: 'Master record for a service campaign (recall or non-safety field action) issued by the OEM. Captures NHTSA recall number, campaign code, campaign type (safety recall, emissions recall, customer satisfaction program, technical service bulletin action), affected nameplate/model year range, affected VIN population count, remedy description, estimated repair time, parts required, campaign open date, campaign close date, regulatory reporting status, and NHTSA/UNECE compliance flags. Integrates with NHTSA recall database and SAP QM.'
}

Table aftersales.aftersales_service_appointment {
  aftersales_service_appointment_id varchar [pk, note: 'Unique identifier for the service_appointment data product (auto-inserted pre-linking).']
  primary_aftersales_customer_party_id varchar [note: 'Identifier of the vehicle owner or service requester.']
  primary_aftersales_dealer_dealership_id varchar [note: 'Identifier of the dealership or authorized service center hosting the appointment.']
  service_campaign_id varchar [note: 'Foreign key linking to aftersales.service_campaign. Business justification: Service appointments are frequently scheduled specifically to address a service campaign (recall or field action). The aftersales_service_appointment has a recall_flag boolean but no FK to the specifi']
  service_center_id varchar [note: 'Foreign key linking to aftersales.service_center. Business justification: Service appointments are scheduled at a specific service center — this is a fundamental business relationship. Reviewing existing FKs for aftersales_service_appointment: it has aftersales_dealer_deale']
  tsb_id varchar [note: 'Foreign key linking to aftersales.tsb. Business justification: Service appointments may be proactively scheduled to address a specific TSB (e.g., proactive_maintenance_trigger_flag is TRUE on the appointment). Linking aftersales_service_appointment to tsb enables']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: Ensures service appointment scheduling aligns with the correct vehicle record for service history and recall compliance.']
  actual_end_timestamp timestamp [note: 'Timestamp when the service work was completed.']
  actual_start_timestamp timestamp [note: 'Timestamp when the vehicle actually entered service.']
  aftersales_service_appointment_status varchar [note: 'Current lifecycle status of the appointment.']
  appointment_number varchar [note: 'Business identifier assigned to the service appointment, used in dealer and customer communications.']
  appointment_source varchar [note: 'Origin channel through which the appointment was booked.']
  bay_number varchar [note: 'Identifier of the service bay where the vehicle will be serviced.']
  booked_via_self_service_flag boolean
  booking_channel varchar [note: 'Channel through which appointment was booked: self_service_portal, phone, walk_in, proactive_alert']
  check_in_timestamp timestamp [note: 'Timestamp when the customer checked in at the service center.']
  confirmation_status varchar [note: 'Current confirmation state of the appointment.']
  created_timestamp timestamp [note: 'Timestamp when the appointment record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  customer_feedback_score varchar [note: 'Numeric rating (0‑10) provided by the customer after service.']
  estimated_duration_minutes varchar [note: 'Planned length of the service appointment in minutes.']
  estimated_gross_amount decimal(18,2) [note: 'Projected total charge before taxes and discounts.']
  estimated_net_amount decimal(18,2) [note: 'Projected total charge after taxes and discounts.']
  estimated_tax_amount decimal(18,2) [note: 'Projected tax component of the service charge.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  invoice_number varchar [note: 'Identifier of the invoice generated for the service appointment.']
  is_first_time_customer boolean [note: 'True if this is the customer\'s first service appointment with the dealer.']
  is_repeat_service boolean [note: 'True if the vehicle has previously received the same service type.']
  labor_time_actual_minutes varchar [note: 'Actual labor minutes recorded for the service.']
  no_show_flag boolean [note: 'Indicates whether the customer failed to appear for the scheduled appointment.']
  parts_actual_amount decimal(18,2) [note: 'Total cost of parts actually used during service.']
  proactive_maintenance_trigger_flag boolean
  recall_flag boolean [note: 'True if the appointment is part of a manufacturer recall campaign.']
  required_parts_flag boolean [note: 'Indicates whether specific parts must be ordered before the appointment.']
  scheduled_timestamp timestamp [note: 'Planned date and time when the service is to start.']
  self_service_portal_session_reference varchar
  self_service_session_reference varchar [note: 'FK to the self-service portal session that created this appointment']
  service_category varchar [note: 'Higher‑level grouping of the service (e.g., oil change, brake service, battery replacement).']
  service_notes varchar [note: 'Free‑form notes entered by the service advisor or technician.']
  service_priority varchar [note: 'Priority level assigned to the appointment for scheduling.']
  service_type varchar [note: 'Classification of the service (e.g., routine maintenance, warranty repair, recall, pre‑delivery inspection, customer‑pay).']
  total_actual_amount decimal(18,2) [note: 'Final charge for the appointment after labor, parts, taxes, and discounts.']
  transportation_option varchar [note: 'Customer transportation provision during service.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the appointment record.']
  vehicle_mileage varchar [note: 'Odometer reading at the time of service appointment.']
  warranty_flag boolean [note: 'True if the appointment is covered under a warranty agreement.']

  Note: 'Scheduled service appointment record for a vehicle at a dealership or authorized service center. Captures appointment date/time, customer contact, VIN, service type (maintenance, warranty repair, recall, PDI, customer pay), service advisor assigned, estimated duration, transportation option (loaner, shuttle, wait), appointment source (online, phone, DMS, mobile app), confirmation status, check-in time, and no-show flag. Sourced from CDK Global DMS scheduling module.. SSOT: canonical source is dealer.dealer_service_appointment. This product is a domain-local reference. SUPERSEDED: Use dealer.dealer_service_appointment as the single source of truth.'
}

Table aftersales.tsb {
  tsb_id varchar [pk, note: 'System-generated unique identifier for the Technical Service Bulletin record.']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: TSBs are issued to document field remedies for known engineering change impacts. Linking TSB to the originating engineering change order (ECO) supports change impact tracking, warranty cost recovery f']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Technical Service Bulletins are issued based on design specifications; the link provides traceability for compliance audits.']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: TSBs are frequently authored from FMEA findings — the root_cause and failure_mode fields on TSB trace directly to FMEA failure analysis. Regulatory audits and warranty root cause reports require this ']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: TSBs are issued for specific vehicle models; service advisors look up applicable TSBs by model during repair order creation. Regulatory TSB distribution tracking and OEM technical communications requi']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: TSBs are authored against specific engineering parts. Aftersales technicians and warranty analysts need to trace TSB → part_master for revision level, material type, and specification data. This suppo']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: TSBs for powertrain-specific issues (EV battery management software, transmission calibration, hybrid system faults) must be scoped to specific powertrain variants. Service technicians filter TSBs by ']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: TSB root-cause traceability to manufacturing: when a TSB is issued for a systemic defect, engineers must identify the originating production line (automation level, robot count, weld gun count) to imp']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall campaigns frequently generate associated TSBs that define the technical repair procedure for the remedy. Compliance teams and service engineers need direct traceability from a TSB to its govern']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: TSBs with regulatory_compliance_flag=true are issued to satisfy specific regulatory mandates (e.g., FMVSS compliance updates, EPA emissions repair procedures). Compliance teams need to link TSBs to th']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: TSBs apply to specific vehicle programs. Aftersales program managers filter all active TSBs by vehicle program for service planning, warranty cost forecasting, and regulatory reporting. The existing a']
  affected_model_year_end varchar [note: 'Last model year in the range affected by the bulletin.']
  affected_model_year_start varchar [note: 'First model year in the range affected by the bulletin.']
  affected_vin_end varchar [note: 'Ending VIN in the range covered by the bulletin.']
  affected_vin_start varchar [note: 'Starting VIN (Vehicle Identification Number) in the range covered by the bulletin.']
  attachment_url varchar [note: 'Link to the full PDF or digital document of the bulletin.']
  author_department varchar [note: 'Organizational department responsible for the bulletin (e.g., Powertrain, Body, Electronics).']
  author_engineer varchar [note: 'Name of the OEM engineer who authored the bulletin.']
  created_timestamp timestamp [note: 'Timestamp when the bulletin record was first created in the data lake.']
  distribution_status varchar [note: 'Current status of bulletin distribution to the dealer network.']
  effective_from date [note: 'Date from which the bulletin recommendations become applicable.']
  effective_until date [note: 'Date after which the bulletin is no longer applicable (nullable for open‑ended bulletins).']
  estimated_labor_hours decimal(5,2) [note: 'Estimated technician labor time required to complete the repair.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  is_ota_capable boolean [note: 'Indicates whether the fix can be delivered via Over‑The‑Air update.']
  issue_date date [note: 'Date the bulletin was officially issued by the OEM.']
  labor_rate_per_hour decimal(18,2) [note: 'Standard labor rate applied for cost estimation (currency assumed USD).']
  last_review_date date [note: 'Date when the bulletin was last reviewed for relevance or accuracy.']
  notes varchar [note: 'Free‑form field for any supplemental information or comments.']
  part_revision varchar [note: 'Revision identifier of the required part.']
  regulatory_compliance_flag boolean [note: 'True if the bulletin satisfies a regulatory requirement (e.g., NHTSA, EPA).']
  repair_procedure varchar [note: 'Step‑by‑step instructions for service technicians to resolve the issue.']
  required_parts varchar [note: 'Comma‑separated list of part numbers and revisions needed for the repair.']
  review_status varchar [note: 'Outcome of the most recent technical review.']
  severity_level varchar [note: 'Impact severity of the issue addressed by the bulletin.']
  superseded_by_tsb_number varchar [note: 'TSB number that supersedes this bulletin, if any.']
  symptom_description varchar [note: 'Narrative of the customer‑reported or observed symptom that triggers the bulletin.']
  title varchar [note: 'Short descriptive title of the bulletin.']
  total_estimated_cost decimal(18,2) [note: 'Combined estimated cost of parts and labor for the bulletin repair.']
  tsb_number varchar [note: 'OEM-assigned alphanumeric identifier for the bulletin (e.g., TSB-2023-001).']
  tsb_status varchar [note: 'Current lifecycle status of the bulletin.']
  tsb_type varchar [note: 'Category of the bulletin indicating its purpose.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the bulletin record.']
  vehicle_system_affected varchar [note: 'Specific vehicle subsystem (e.g., ECU, transmission) impacted by the issue.']
  version_number varchar [note: 'Incremental version of the bulletin content.']
  warranty_impact_flag boolean [note: 'Indicates whether the repair is covered under vehicle warranty.']

  Note: 'Technical Service Bulletin master record issued by OEM engineering to communicate repair procedures, diagnostic guidance, or part supersessions to the dealer service network. Captures TSB number, title, affected nameplate/model year/VIN range, symptom description, root cause, recommended repair procedure, required parts list, estimated labor time, issue date, supersession reference, and distribution status to dealer network. Integrates with PTC Windchill and CDK Global DMS.'
}

Table aftersales.service_part {
  service_part_id varchar [pk, note: 'Unique surrogate key for the service part record.']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: REQUIRED: Service Part Origin Traceability needed for regulatory compliance (NHTSA/UNECE) links service parts to their inbound part records.']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Required for parts traceability report linking service inventory to engineering part master specs, essential for compliance and quality analysis.']
  compliance_certification varchar [note: 'Regulatory certification(s) applicable to the part (e.g., EPA, DOT).']
  core_charge decimal(12,2) [note: 'Refundable deposit required for parts that are returned for reuse.']
  country_of_origin varchar [note: 'Three‑letter ISO country code indicating where the part was manufactured.']
  created_timestamp timestamp [note: 'Date‑time when the service part record was first created in the system.']
  dealer_net_price decimal(18,2) [note: 'Price offered to authorized dealers after standard discounts.']
  description varchar [note: 'Full textual description of the part, including fitment notes.']
  effective_end_date date [note: 'Date when the part is retired from the service catalog (null if open‑ended).']
  effective_start_date date [note: 'Date when the part becomes valid for use in service operations.']
  epa_hazardous_material_code varchar [note: 'EPA classification code for hazardous parts, if applicable.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  hazardous_classification varchar [note: 'Regulatory classification code for hazardous parts (e.g., UN number).']
  hazmat_flag boolean [note: 'Indicates whether the part is classified as hazardous material.']
  height_mm decimal(8,2) [note: 'Physical height of the part in millimetres.']
  inventory_status varchar [note: 'Current inventory availability status of the part.']
  last_used_timestamp timestamp [note: 'Date‑time when the part was last consumed in a service transaction.']
  length_mm decimal(8,2) [note: 'Physical length of the part in millimetres.']
  lifecycle_status varchar [note: 'Current lifecycle state of the part within the after‑sales catalog.']
  list_price decimal(18,2) [note: 'Manufacturer suggested retail price before any discounts.']
  manufacturer_name varchar [note: 'Name of the original equipment manufacturer that produces the part.']
  part_category varchar [note: 'High‑level classification of the part type.']
  part_name varchar [note: 'Human‑readable name or description of the part.']
  part_number varchar [note: 'Manufacturer-assigned part number used to uniquely identify the part across the enterprise.']
  part_revision varchar [note: 'Revision identifier for engineering changes to the part.']
  superseded_by_part_number varchar [note: 'Part number that replaces this part when it is superseded.']
  unit_of_measure varchar [note: 'Standard unit used for inventory and transaction quantities (e.g., EA, SET).']
  updated_timestamp timestamp [note: 'Date‑time of the most recent update to the service part record.']
  warranty_eligible_flag boolean [note: 'Indicates whether the part is covered under the standard warranty program.']
  warranty_period_months varchar [note: 'Number of months the part is covered by warranty from the date of installation.']
  weight_kg decimal(8,2) [note: 'Net weight of the part in kilograms.']
  width_mm decimal(8,2) [note: 'Physical width of the part in millimetres.']

  Note: 'Aftersales service parts master record for parts stocked and consumed in dealer service and repair operations. Captures OEM part number, supersession chain (current and all prior part numbers), part description, part category (mechanical, electrical, body, consumable, fluid, accessory), unit of measure, standard list price, dealer net price, core charge amount, weight, hazmat flag, country of origin, minimum order quantity, and lifecycle status (active, superseded, discontinued, obsolete). Serves as the aftersales-specific view of the parts catalog optimized for service ordering and warranty claims — distinct from the manufacturing BOM parts master in the engineering domain.'
}

Table aftersales.parts_order {
  parts_order_id varchar [pk, note: 'Unique identifier for the parts_order data product (auto-inserted pre-linking).']
  aftersales_repair_order_id varchar [note: 'Foreign key linking to aftersales.aftersales_repair_order. Business justification: Parts orders are frequently placed to fulfill a specific repair order (emergency parts procurement for an active RO). The aftersales_parts_order has no FK to the repair order that triggered it. Adding']
  inbound_part_id varchar [note: 'Foreign key linking to supply.inbound_part. Business justification: Aftersales parts ordering must reference the specific supply catalog part for lead time, pricing, customs compliance, and MOQ validation. Parts order fulfillment planning requires knowing which inboun']
  primary_aftersales_dealership_id varchar [note: 'Unique identifier of the dealer or service center that placed the parts order.']
  service_campaign_id varchar [note: 'Foreign key linking to aftersales.service_campaign. Business justification: Parts orders are placed to fulfill service campaign (recall/field action) parts requirements. The aftersales_parts_order has no FK to the service_campaign driving the order. Adding service_campaign_id']
  service_center_id varchar [note: 'Foreign key linking to aftersales.service_center. Business justification: Parts orders are placed by dealer service centers to replenish their parts inventory for service operations. Currently aftersales_parts_order only links to aftersales.dealership (primary_aftersales_dealer']
  warehouse_id varchar [note: 'Foreign key linking to inventory.warehouse. Business justification: Parts order fulfillment requires identifying the specific warehouse that will pick, pack, and ship parts to the service center. This FK enables warehouse-level fulfillment tracking, inventory reservat']
  actual_delivery_date date [note: 'Date the parts were actually received at the dealer.']
  backorder_flag boolean [note: 'Indicates whether any line items are on backorder.']
  created_timestamp timestamp [note: 'Timestamp when the parts order record was first created in the data lake.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency used for the order.']
  discount_amount decimal(18,2) [note: 'Total discount granted on the order.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  freight_cost decimal(18,2) [note: 'Cost of shipping the parts from the fulfillment location to the dealer.']
  freight_terms varchar [note: 'Terms governing freight cost responsibility.']
  net_total decimal(18,2) [note: 'Final amount payable after applying discounts, taxes, and freight.']
  order_number varchar [note: 'External business identifier assigned to the parts order by the dealer or OEM system.']
  order_status varchar [note: 'Current lifecycle state of the parts order (e.g., submitted, confirmed, picked, shipped, received, invoiced, cancelled). [ENUM-REF-CANDIDATE: submitted|confirmed|picked|shipped|received|invoiced|cancelled — promote to reference product]']
  order_timestamp timestamp [note: 'Date and time when the parts order was placed by the dealer.']
  order_type varchar [note: 'Classification of the order based on business need.']
  payment_terms varchar [note: 'Agreed payment condition for the order.']
  priority_flag boolean [note: 'Indicates if the order is marked as high priority.']
  requested_delivery_date date [note: 'Date requested by the dealer for parts to be delivered.']
  self_service_order_flag boolean [note: 'Whether this parts order was placed via the customer self-service portal']
  shipping_method varchar [note: 'Mode of transportation used to deliver the parts.']
  special_instructions varchar [note: 'Free‑text field for any additional handling or delivery instructions.']
  tax_amount decimal(18,2) [note: 'Total tax applied to the order.']
  total_order_value decimal(18,2) [note: 'Gross monetary value of the order before discounts, taxes, and freight.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the parts order record.']

  Note: 'Parts order placed by a dealer or service center to the OEM parts distribution center (PDC) or regional warehouse. Captures order number, ordering dealer code, PDC fulfillment location, order date, requested delivery date, order type (stock, emergency, campaign/recall, special), order status (submitted, confirmed, picked, shipped, received, invoiced), total order value, freight terms, and backorder flags. Integrates with SAP MM and dealer DMS parts ordering module.. SSOT: canonical source is dealer.dealer_parts_order. This product is a domain-local reference. SUPERSEDED: Use dealer.dealer_parts_order as the single source of truth.'
}

Table aftersales.service_center {
  service_center_id varchar [pk, note: 'Unique surrogate key for the service center record.']
  dealership_id varchar [note: 'Identifier of the dealer group to which the service center belongs.']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Service centers must hold jurisdiction-specific authorizations (EPA emissions testing, state safety inspection licenses, EU type-approval service network recognition). The regulatory_status field requ']
  adas_calibration_authorized boolean [note: 'Indicates whether the center can calibrate Advanced Driver Assistance Systems.']
  address_line1 varchar [note: 'Primary street address of the service center.']
  address_line2 varchar [note: 'Secondary address information (suite, floor, etc.).']
  authorization_level varchar [note: 'Combined classification of services the center is authorized to perform.']
  average_service_time_minutes decimal(5,2) [note: 'Mean duration from service order start to completion, expressed in minutes.']
  city varchar [note: 'City where the service center is located.']
  code varchar [note: 'External business code used to reference the service center in dealer and OEM systems.']
  collision_authorized boolean [note: 'Indicates whether the center is certified to perform collision repairs.']
  country varchar [note: 'Three‑letter ISO country code.']
  created_timestamp timestamp [note: 'Timestamp when the service center record was first created.']
  dsk_instance_code varchar [note: 'Identifier of the CDK Global DMS instance that manages this service center.']
  effective_end_date date [note: 'Date when the service center ceased operations (null if still active).']
  effective_start_date date [note: 'Date when the service center became active in the network.']
  ev_certified boolean [note: 'Indicates whether the center is qualified to service electric vehicles.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  iatf_certified boolean [note: 'Indicates compliance with IATF 16949 quality management standards.']
  is_primary_center boolean [note: 'Indicates if this center is the primary hub for its dealer group.']
  iso9001_certified boolean [note: 'Indicates compliance with ISO 9001 quality management standards.']
  last_audit_date date [note: 'Date when the most recent compliance audit was performed.']
  latitude double [note: 'Latitude coordinate of the service center location.']
  loaner_fleet_size varchar [note: 'Number of loaner vehicles maintained for customer use.']
  longitude double [note: 'Longitude coordinate of the service center location.']
  market varchar [note: 'Market segment served (e.g., premium, mass‑market, commercial).']
  name varchar [note: 'Human‑readable name of the authorized service center.']
  network_status varchar [note: 'Current participation status of the center in the OEM service network.']
  notes varchar [note: 'Free‑form field for any supplemental information about the service center.']
  operating_hours varchar [note: 'Standard weekly operating hours (e.g., Mon‑Fri 08:00‑18:00).']
  postal_code varchar [note: 'Postal or ZIP code.']
  recall_authorized boolean [note: 'Indicates whether the center can execute manufacturer recall campaigns.']
  region varchar [note: 'Regional grouping (e.g., North America, EMEA) used for reporting.']
  regulatory_status varchar [note: 'Current status of the center\'s compliance with automotive regulations.']
  service_bay_count varchar [note: 'Total count of service bays available for vehicle work.']
  service_center_type varchar [note: 'Category of the service center based on ownership and relationship to OEM.']
  service_orders_processed varchar [note: 'Cumulative count of service orders completed at the center.']
  state varchar [note: 'State or province abbreviation.']
  technician_headcount varchar [note: 'Number of technicians employed at the service center.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the service center record.']
  warranty_authorized boolean [note: 'Indicates whether the center can perform warranty repairs.']
  warranty_claims_processed varchar [note: 'Cumulative count of warranty claims handled by the center.']

  Note: 'Master record for authorized service centers and dealership service departments in the OEM aftersales network. Captures service center code, name, address, dealer group affiliation, authorization level (warranty, recall, certified collision, EV-certified, ADAS-calibration), service bay count, technician headcount, CDK Global DMS instance ID, operating hours, loaner fleet size, and network status (active, suspended, terminated). Distinct from the dealer domain\'s dealer profile — this is the service-operations-specific view.'
}

Table aftersales.technician {
  technician_id varchar [pk, note: 'System-generated unique identifier for the service technician.']
  service_center_id varchar [note: 'Identifier of the service center to which the technician is assigned.']
  availability_status varchar [note: 'Current availability of the technician for new assignments.']
  certification_expiry_date date [note: 'Date on which the technician\'s current certification expires.']
  certification_level varchar [note: 'Level of certification achieved by the technician.']
  certification_type varchar [note: 'Type of certification held by the technician (e.g., ASE, OEM, EV, ADAS).']
  created_timestamp timestamp [note: 'Timestamp when the technician record was first created.']
  current_active_ro_count varchar [note: 'Number of repair orders currently assigned to the technician.']
  email_address varchar [note: 'Primary email address used for communication with the technician.']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  field_services_eligible_flag boolean [note: 'Whether this technician is eligible for field service dispatching']
  flat_rate_efficiency_rating decimal(18,2) [note: 'Efficiency rating expressed as a percentage of flat‑rate labor productivity.']
  full_name varchar [note: 'Legal full name of the technician.']
  hire_date date [note: 'Date the technician was hired by the organization.']
  last_training_date date [note: 'Date of the most recent training session attended by the technician.']
  max_concurrent_ro varchar [note: 'Maximum number of repair orders the technician can handle simultaneously.']
  mobile_service_certification varchar [note: 'Certification level for mobile/field service operations']
  notes varchar [note: 'Free‑form notes about the technician (e.g., performance comments, special accommodations).']
  overtime_eligible boolean [note: 'Indicates whether the technician is eligible for overtime pay.']
  overtime_rate_multiplier decimal(18,2) [note: 'Multiplier applied to the base labor rate for overtime work.']
  phone_number varchar [note: 'Primary telephone number for the technician.']
  shift_type varchar [note: 'Work shift classification for the technician.']
  skill_level varchar [note: 'Skill tier of the technician based on experience and performance.']
  specialization varchar [note: 'Technical area of expertise for the technician.']
  technician_status varchar [note: 'Current employment status of the technician.']
  training_hours_completed varchar [note: 'Cumulative hours of formal training completed by the technician.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the technician record.']
  years_of_experience varchar [note: 'Total number of years the technician has worked in automotive service.']

  Note: 'Master record for service technicians employed at authorized service centers. Captures technician ID, name, service center assignment, certification level (ASE, OEM-certified, EV-certified, ADAS-certified), specialization (powertrain, electrical, body, diagnostics), flat-rate efficiency rating, current active RO count, hire date, and certification expiry dates. This is the aftersales-specific technician profile focused on service capacity and certification — distinct from the workforce domain\'s employee record.'
}

Table aftersales.campaign_parts_requirement {
  campaign_parts_requirement_id varchar [pk, note: 'Primary key for the campaign_parts_requirement association']
  service_campaign_id varchar [note: 'Foreign key linking to the service campaign (recall or field action) that requires this part.']
  service_part_id varchar [note: 'Foreign key linking to the service part required to perform the campaign remedy.']
  part_role_in_remedy varchar [note: 'Classifies the functional role of this part within the campaign remedy procedure. A campaign may require a primary replacement part, consumables (e.g., fluids, gaskets), and hardware (e.g., bolts, clips) — each with a distinct role. Belongs to the relationship, not to the part or campaign alone.']
  part_unit_cost_at_campaign decimal [note: 'The OEM transfer or standard cost of this part at the time the campaign was issued. Captured at the campaign level because part prices change over time and the campaign cost estimate must be locked to the issuance date. Distinct from the current dealer_net_price or list_price on service_part.']
  parts_required varchar [note: 'Comma‑separated list of part numbers needed to perform the remedy. [Moved from service_campaign: This comma-separated string of part numbers is a denormalized anti-pattern that attempts to capture what the campaign_parts_requirement association table properly models. Once the association table is created with one row per campaign-part pairing, this field becomes redundant and should be removed from service_campaign. The structured association records replace this field entirely.]']
  procurement_lead_time_days decimal [note: 'The number of calendar days required to procure sufficient stock of this part to support the campaign\'s affected VIN population. This is campaign-specific because lead times vary based on campaign volume, supplier capacity, and urgency — it is not a static attribute of the part itself.']
  quantity_required_per_vehicle decimal [note: 'The number of units of this part required to complete the remedy on a single affected vehicle. Belongs to the campaign-part relationship, not to either entity alone — the same part may be required in different quantities across different campaigns.']

  Note: 'This association product represents the Contract between service_campaign and service_part in OEM aftersales operations. It captures the formal remedy parts list — the specific parts required to execute a service campaign remedy, including quantity per vehicle, cost at campaign issuance, the part\'s role in the repair procedure, and procurement lead time. Each record links one service_campaign to one service_part with attributes that exist only in the context of this campaign-part pairing and are actively managed by parts planners and campaign managers to pre-position inventory at OEM distribution centers.. Existence Justification: In automotive aftersales, a service campaign (recall or field action) requires specific parts to perform the remedy, and a single campaign can require multiple distinct parts (e.g., a safety recall may need a replacement sensor, mounting hardware, and a sealing gasket). Conversely, a single service part can be required across multiple campaigns over its lifecycle (e.g., a brake caliper part number may be needed for both a safety recall and a customer satisfaction program). This is an operationally managed relationship — parts planners and campaign managers actively create, update, and close campaign-part requirements records to pre-position inventory at OEM distribution centers.'
}

Table compliance.homologation_record {
  homologation_record_id varchar [pk, note: 'Homologation Record Id']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Type approval / homologation is granted for a specific BOM configuration in automotive. Regulators approve the exact bill-of-materials variant. This FK enables traceability from homologation approval ']
  jurisdiction_id varchar [note: 'Jurisdiction Id']
  model_id varchar [note: 'Model Id']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: A homologation record is issued or recognized by a specific regulatory body (e.g., UNECE for international type approvals, EU national authorities for EU type approvals, Transport Canada). This FK lin']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: A homologation record certifies compliance with a specific regulatory requirement (e.g., UNECE Regulation 100, EU Whole Vehicle Type Approval). This FK normalizes the relationship between the homologa']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Type approval / homologation is obtained per vehicle program before market launch. Compliance teams must trace each homologation record to the engineering program that defines the vehicle configuratio']
  approval_date date [note: 'Approval Date']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  eu_taxonomy_activity_code varchar [note: 'EU Taxonomy economic activity code for this homologation']
  expiry_date date [note: 'Expiry Date']
  field_service_info varchar [note: 'Generic field service info placeholder']
  homologation_number varchar [note: 'Homologation Number']
  homologation_status varchar [note: 'Homologation Status']
  market_code varchar [note: 'Market Code']
  type_approval_category varchar [note: 'Type Approval Category']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Master record for vehicle type approval and homologation certifications across global markets. Captures UNECE type approval numbers, FMVSS homologation status, Euro NCAP ratings, WLTP certification references, and jurisdiction-specific approval details for each vehicle model and variant. Serves as the authoritative SSOT for all regulatory type approvals required before a vehicle can be sold in a given market.'
}

Table compliance.emissions_certification {
  emissions_certification_id varchar [pk, note: 'Compliance Emissions Certification Id']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Emissions certification (EPA, Euro 6, etc.) is granted for a specific powertrain/BOM configuration. Product engineers must know which BOM revision holds a valid emissions certificate before releasing ']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: EPA and CARB emissions certificates are issued for specific vehicle configurations. The model-level link is insufficient; compliance engineers must validate which exact configurations hold valid emiss']
  jurisdiction_id varchar [note: 'Jurisdiction Id']
  model_id varchar [note: 'Model Id']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: EPA/CARB emissions certifications are issued per engine family and powertrain variant. Regulatory submissions reference the specific powertrain tested. Compliance teams need this link to track which p']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: An emissions certification is issued by a specific certifying authority (EPA, CARB, EU type approval authority). The existing `certifying_authority` column is a denormalized text field capturing the a']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: An emissions certification is issued to certify compliance with a specific regulatory requirement (e.g., EPA Tier 3, Euro 6d, CARB LEV III). This FK links the certification to the governing standard i']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Emissions certifications are issued per vehicle program\'s powertrain and emission standard configuration. Regulatory reporting (e.g., EU CO2 fleet targets, EPA compliance) requires linking certified e']
  carbon_credit_eligible boolean [note: 'Whether certification qualifies for carbon credits']
  certificate_number varchar
  certification_date date [note: 'Certification Date']
  certification_number varchar [note: 'Certification Number']
  certification_status varchar [note: 'Certification Status']
  certified_co2_g_per_km decimal(8,2)
  co2_emissions_g_per_km decimal(8,2)
  co2_g_per_km decimal(6,2) [note: 'Co2 G Per Km']
  compliance_emissions_certification_description varchar [note: 'Description of the entity']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  emission_standard varchar [note: 'Emission Standard']
  esg_reporting_framework varchar [note: 'Applicable ESG framework (CSRD, EU Taxonomy)']
  eu_taxonomy_eligible_flag boolean [note: 'Whether this certification qualifies under EU Taxonomy']
  expiry_date date [note: 'Expiry Date']
  field_service_info varchar [note: 'Generic field service info placeholder']
  fuel_type varchar [note: 'Fuel Type']
  issue_date date
  nox_mg_per_km decimal(6,2) [note: 'Nox Mg Per Km']
  pm_mg_per_km decimal(6,3) [note: 'Pm Mg Per Km']
  powertrain_type varchar [note: 'Powertrain Type']
  test_cycle varchar [note: 'Test Cycle']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Master record for EPA, CARB, and Euro 6/7 emissions certifications issued for specific vehicle configurations and powertrain variants. Tracks certification number, applicable standard (EPA Tier 3, CARB LEV III, Euro 6d), test cycle (WLTP, FTP-75, US06), certification date, expiry, and compliance status. Covers ICE, HEV, PHEV, and EV powertrain types. Links to the specific engine family and vehicle model year program. SUPERSEDED: Use vehicle.vehicle_emissions_certification as the single source of truth.'
}

Table compliance.regulatory_submission {
  regulatory_submission_id varchar [pk, note: 'Regulatory Submission Id']
  jurisdiction_id varchar [note: 'Jurisdiction Id']
  milestone_id varchar [note: 'Foreign key linking to engineering.milestone. Business justification: Regulatory submissions have hard due dates tied to vehicle program milestones (e.g., SOP, Job 1, market launch gate). Linking regulatory_submission to the triggering engineering milestone enables prog']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: CAFE fuel economy compliance submissions, annual safety standard filings, and market authorization submissions are filed per vehicle model. Compliance teams need to link regulatory submissions to the ']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Regulatory submissions are frequently filed in the context of a recall campaign (e.g., NHTSA recall filings, amendments, status updates). Multiple submissions can be made for a single recall campaign ']
  regulatory_body_id varchar [note: 'Regulatory Body Id']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Regulatory submissions (type approval, homologation dossiers, emissions filings) are made per vehicle program for specific markets. Program managers and compliance teams need to track all submissions ']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  description varchar [note: 'Description']
  due_date date [note: 'Due Date']
  esg_submission_type varchar [note: 'Type of ESG regulatory submission']
  field_service_info varchar [note: 'Generic field service info placeholder']
  submission_date date [note: 'Submission Date']
  submission_number varchar [note: 'Submission Number']
  submission_status varchar [note: 'Submission Status']
  submission_type varchar [note: 'Submission Type']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Transactional record for each formal regulatory submission made to a governing body (NHTSA, EPA, CARB, UNECE, Euro NCAP, DOT). Captures submission type (type approval application, certificate of conformity, recall notice, CAFE report, safety standard compliance report), submission date, regulatory body, submission reference number, status (submitted, acknowledged, approved, rejected, under review), and responsible compliance officer. Central audit trail for all outbound regulatory filings.'
}

Table compliance.recall_campaign {
  recall_campaign_id varchar [pk, note: 'Recall Campaign Id']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: FMEA records are the primary engineering root-cause artifact for recall investigations. NHTSA and other regulators require OEMs to demonstrate that the failure mode, severity, and detection ratings fr']
  jurisdiction_id varchar [note: 'Foreign key linking to compliance.jurisdiction. Business justification: Recall campaigns are jurisdiction-specific regulatory actions — a US NHTSA recall is distinct from a European recall under EU regulations, and from a Canadian Transport Canada recall. This FK links th']
  model_id varchar [note: 'Foreign key linking to vehicle.model. Business justification: NHTSA and global recall campaigns are filed against specific vehicle models. Compliance teams must identify which model a recall applies to for remedy planning, affected unit count validation, and reg']
  regulatory_body_id varchar [note: 'Regulatory Body Id']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Recall campaigns affect vehicles produced under specific vehicle programs. Linking recall_campaign to vehicle_program enables engineering teams to assess program-level recall exposure, cost impact, an']
  affected_unit_count varchar
  affected_vehicles_count varchar [note: 'Affected Vehicles Count']
  campaign_code varchar
  campaign_description varchar
  campaign_number varchar
  campaign_status varchar
  campaign_title varchar
  completion_rate decimal(18,2)
  completion_rate_percent decimal(18,2) [note: 'Completion Rate Percent']
  completion_target_date date [note: 'Completion Target Date']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  defect_description varchar [note: 'Defect Description']
  description varchar [note: 'Description of the entity']
  environmental_impact_flag boolean [note: 'Whether the recall has environmental/emissions impact']
  estimated_cost decimal(18,2) [note: 'Estimated Cost']
  field_service_info varchar [note: 'Generic field service info placeholder']
  initiation_date date [note: 'Initiation Date']
  launch_date date
  nhtsa_campaign_number varchar [note: 'Nhtsa Campaign Number']
  recall_description varchar
  recall_number varchar [note: 'Recall Number']
  recall_status varchar [note: 'Recall Status']
  recall_title varchar [note: 'Recall Title']
  remedy_description varchar [note: 'Remedy Description']
  safety_risk_description varchar [note: 'Safety Risk Description']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Master record for NHTSA safety recall campaigns and OEM-initiated service campaigns. Captures NHTSA recall number, campaign type (safety recall, emissions recall, OEM voluntary service campaign), defect description, affected population (VIN range, model year, nameplate), remedy description, campaign open date, remedy availability date, and campaign closure status. Serves as the compliance SSOT for recall management, distinct from aftersales.recall_completion which tracks dealer-level execution.'
}

Table compliance.regulatory_requirement {
  regulatory_requirement_id varchar [pk, note: 'Regulatory Requirement Id']
  jurisdiction_id varchar [note: 'Jurisdiction Id']
  regulatory_body_id varchar [note: 'Regulatory Body Id']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  description varchar [note: 'Description']
  effective_date date [note: 'Effective Date']
  field_service_info varchar [note: 'Generic field service info placeholder']
  requirement_category varchar [note: 'Requirement Category']
  requirement_code varchar [note: 'Requirement Code']
  requirement_status varchar [note: 'Requirement Status']
  requirement_title varchar [note: 'Requirement Title']
  sunset_date date [note: 'Sunset Date']
  sustainability_relevance_flag boolean [note: 'Whether this requirement is relevant to sustainability/ESG reporting']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Reference master defining all applicable regulatory requirements and standards that Automotive must comply with across jurisdictions. Captures regulation name, issuing body (NHTSA, EPA, CARB, UNECE, IATF, ISO), regulation code (e.g., FMVSS 208, ECE R94, Euro 6d), effective date, applicability scope (market, vehicle category, powertrain type), compliance deadline, and current status (active, superseded, proposed). Serves as the regulatory obligation register.'
}

Table compliance.jurisdiction {
  jurisdiction_id varchar [pk, note: 'Jurisdiction Id']
  parent_jurisdiction_id varchar [note: 'Parent Jurisdiction Id']
  code varchar [note: 'Jurisdiction Code']
  country_code varchar [note: 'Country Code']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  esg_regulatory_framework varchar [note: 'Applicable ESG regulatory framework in this jurisdiction']
  field_service_info varchar [note: 'Generic field service info placeholder']
  jurisdiction_type varchar [note: 'Jurisdiction Type']
  name varchar [note: 'Jurisdiction Name']
  region varchar [note: 'Region']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Reference master for regulatory jurisdictions in which Automotive operates and sells vehicles. Captures jurisdiction name, jurisdiction type (federal, state, national, supranational), country or region code, primary regulatory body, applicable emissions standard tier, applicable safety standard framework, and market entry requirements. Used to map vehicles and certifications to the correct regulatory regime for each sales market.'
}

Table compliance.fmvss_certification {
  fmvss_certification_id varchar [pk, note: 'Fmvss Certification Id']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: FMVSS certification is issued for a specific vehicle configuration defined by its BOM. US regulatory compliance requires tracing which BOM configuration passed FMVSS testing. Without this FK, engineer']
  configuration_id varchar [note: 'Foreign key linking to vehicle.configuration. Business justification: FMVSS self-certification applies to specific vehicle configurations (e.g., FMVSS 208 airbag requirements vary by body style and powertrain). Compliance records must reference the certified configurati']
  model_id varchar [note: 'Model Id']
  regulatory_body_id varchar [note: 'Foreign key linking to compliance.regulatory_body. Business justification: FMVSS certifications, while self-certified by the OEM, are filed with and overseen by NHTSA. This FK links the FMVSS certification to the governing regulatory body (NHTSA) in the regulatory_body maste']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: FMVSS certifications are self-certifications against specific FMVSS standards defined in the regulatory_requirement master. This FK is CRITICAL for eliminating the fmvss_certification silo — without i']
  certification_date date [note: 'Certification Date']
  certification_status varchar [note: 'Certification Status']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  emissions_related_flag boolean [note: 'Whether this FMVSS certification has emissions implications']
  field_service_info varchar [note: 'Generic field service info placeholder']
  model_year varchar [note: 'Model Year']
  test_report_reference varchar [note: 'Test Report Reference']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Master record for Federal Motor Vehicle Safety Standard (FMVSS) self-certification records maintained by Automotive as required by NHTSA. Captures FMVSS standard number (e.g., FMVSS 208 Occupant Crash Protection, FMVSS 126 ESC, FMVSS 138 TPMS), vehicle model and model year, certification basis (self-certification), test evidence reference, certification date, and responsible certifying engineer. Supports NHTSA audit readiness and recall root-cause traceability.'
}

Table compliance.recall_defect_report {
  recall_defect_report_id varchar [pk, note: 'Recall Defect Report Id']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: Recall defect reports document the specific failure mode identified in field incidents. Linking to fmea_record provides the engineering root-cause analysis that substantiates the defect. failure_mode ']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Recall defect reports identify the specific component/part involved in the defect. Linking to part_master enables part-level recall traceability, supplier identification, and BOM impact analysis. comp']
  product_bom_line_id varchar [note: 'Foreign key linking to product.product_bom_line. Business justification: Recall defect reports identify the specific component/part that failed. \'component_affected\' is a free-text denormalization of the BOM line item. Replacing it with a FK to product_bom_line enables str']
  recall_campaign_id varchar [note: 'Recall Campaign Id']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  defect_category varchar [note: 'Defect Category']
  environmental_hazard_flag boolean [note: 'Whether the defect poses an environmental hazard']
  field_service_info varchar [note: 'Generic field service info placeholder']
  incidents_reported varchar [note: 'Incidents Reported']
  injuries_reported varchar [note: 'Injuries Reported']
  report_date date [note: 'Report Date']
  report_number varchar [note: 'Report Number']
  updated_timestamp timestamp [note: 'Updated Timestamp']

  Note: 'Transactional record for Early Warning Reporting (EWR) and defect investigation reports submitted to or received from NHTSA. Captures report type (EWR quarterly report, Part 579 defect report, consumer complaint aggregate, field report), reporting period, defect category (safety, emissions, structural), number of incidents reported, injury/fatality count, investigation status, and NHTSA investigation number if opened. Supports 49 CFR Part 579 Early Warning Reporting obligations.'
}

Table compliance.regulatory_body {
  regulatory_body_id varchar [pk, note: 'Regulatory Body Id']
  jurisdiction_id varchar [note: 'Jurisdiction Id']
  body_code varchar [note: 'Body Code']
  body_name varchar [note: 'Body Name']
  body_type varchar [note: 'Body Type']
  country_code varchar [note: 'Country Code']
  created_timestamp timestamp [note: 'Created Timestamp']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  esg_oversight_scope varchar [note: 'Scope of ESG oversight by this regulatory body']
  field_service_info varchar [note: 'Generic field service info placeholder']
  updated_timestamp timestamp [note: 'Updated Timestamp']
  website_url varchar [note: 'Website Url']

  Note: 'Master reference table for regulatory_body. Referenced by regulatory_body_id.'
}

