  code varchar [note: 'Unique plant code']
  commissioning_date date [note: 'Commissioning date']
  company_code varchar [note: 'Company code']
  cost_center_code varchar [note: 'Cost center code']
  country_code varchar [note: 'Country code']
  created_timestamp timestamp [note: 'Record creation timestamp']
  currency_code varchar [note: 'Currency code']
  daily_capacity_units varchar [note: 'Daily capacity in units']
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  eop_date date [note: 'End of production date']
  epa_facility_code varchar [note: 'EPA facility code']
  floor_area_sqm decimal(12,2) [note: 'Floor area in sqm']
