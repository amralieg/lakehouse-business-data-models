  iso_14001_certified boolean [note: 'ISO 14001 certified flag']
  iso_9001_certified boolean [note: 'ISO 9001 certified flag']
  latitude decimal(9,6) [note: 'Latitude']
  longitude decimal(9,6) [note: 'Longitude']
  manager varchar [note: 'Plant manager name']
  mes_plant_code varchar [note: 'MES plant code']
  model_year_current varchar [note: 'Current model year']
  name varchar [note: 'Plant name']
  nhtsa_facility_code varchar [note: 'NHTSA facility code']
  number_of_assembly_lines varchar [note: 'Number of assembly lines']
  number_of_shifts varchar [note: 'Number of shifts']
  operational_status varchar [note: 'Operational status']
  ota_capable boolean [note: 'OTA capable flag']
  phone_number varchar [note: 'Phone number']
  plant_type varchar [note: 'Type of plant']
  postal_code varchar [note: 'Postal code']
  powertrain_types_produced varchar [note: 'Powertrain types produced']
  region varchar [note: 'Region']
  renewable_energy_pct decimal(5,2) [note: 'Renewable energy percentage']
  scada_enabled boolean [note: 'SCADA enabled flag']
  short_name varchar [note: 'Short name']
  sop_date date [note: 'Start of production date']
  state_province varchar [note: 'State or province']
  takt_time_seconds varchar [note: 'Takt time in seconds']
  time_zone varchar [note: 'Time zone']
  union_represented boolean [note: 'Union represented flag']
  updated_timestamp timestamp [note: 'Record update timestamp']
  workforce_headcount varchar [note: 'Workforce headcount']

  Note: 'Manufacturing plant/facility master data including location, capacity, certifications and operational parameters'
}

Table manufacturing.production_line {
  production_line_id varchar [pk, note: 'Primary key']
  plant_id varchar [note: 'FK to plant']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: Production lines are physically certified and tooled for specific vehicle platforms (fixture geometry, weld schedules, conveyor dimensions). Platform assignment drives capital investment decisions, SO']
  sap_work_center_id varchar [note: 'FK to work center']
  vehicle_program_id varchar [note: 'FK to vehicle program']
