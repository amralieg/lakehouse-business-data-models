// DBML Schema for Business: Automotive
// Version: 2
// Generated on: 2026-06-23 06:00:06

Project {
  database_type: 'Databricks Unity Catalog'
  Note: 'Lakehouse data model for Automotive - Version 2'
}

Table vehicle.vin_registry {
  vin_registry_id varchar [pk]
  configuration_id varchar
  battery_capacity_kwh decimal(8,2)
  build_date date
  check_digit varchar
  connected_diagnostics_enabled_flag boolean [note: 'Whether connected diagnostics are enabled for this VIN']
  created_timestamp timestamp
  curb_weight_kg decimal(10,2)
  destination_market varchar
  emission_standard varchar
  eop_date date
  epa_combined_mpg decimal(6,2)
  extended_warranty_active_flag boolean [note: 'Whether an extended or third-party warranty is currently active']
  fuel_tank_capacity_liters decimal(8,2)
  gvwr_kg decimal(10,2)
  homologation_market varchar
  last_modified_timestamp timestamp
  line_off_timestamp timestamp
  model_year_decoded varchar
  msrp_currency_code varchar
  obd_diagnostic_link_code varchar
  obd_last_read_timestamp timestamp [note: 'Timestamp of last OBD-II data read from vehicle']
  obd_protocol varchar
  plant_code varchar
  production_sequence_number varchar
  recall_flag boolean
  safety_rating varchar
  self_service_portal_registered_flag boolean [note: 'Whether vehicle is registered on customer self-service portal']
  sop_date date
  telematics_enabled_flag boolean
  vds varchar
  vehicle_lifecycle_status varchar
  vin varchar
  vis varchar
  warranty_end_date date
  warranty_start_date date
  wltp_combined_consumption decimal(6,2)
  wmi varchar

  Note: 'SSOT for every physical vehicle instance identified by its 17-character VIN per ISO 3779. Captures decoded VIN structure (WMI, VDS, VIS), manufacturing plant code, production sequence number, build date, model year (MY), line-off timestamp, homologation market, and current lifecycle status (pre-production, in-production, in-transit, in-service, end-of-life). This is the enterprise anchor record — the single identity key — that every downstream domain (sales, aftersales, logistics, mobility, finance) references to identify a specific vehicle unit.'
}

Table vehicle.model {
  model_id varchar [pk]
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Vehicle models have a base-level engineering BOM header representing the model\'s standard component structure, used in product lifecycle management and engineering release processes. This model-level ']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: A model-level BOM defines the base vehicle structure before options and configurations. Engineering change impact analysis, standard cost rollup by model, and field service parts lookup require a dire']
  platform_id varchar
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Vehicle models are classified into product segments for CAFE fleet compliance reporting, portfolio strategy, and competitive benchmarking. Automotive product planners require this link to aggregate mo']
  vehicle_program_id varchar
  adas_features varchar
  battery_capacity_kwh decimal(6,2)
  body_style varchar
  brand_name varchar
  cargo_capacity_liters decimal(7,1)
  co2_emissions_g_per_km decimal(6,1)
  connectivity_features varchar
  created_timestamp timestamp
  curb_weight_kg decimal(7,1)
  description varchar
  drive_configuration varchar
  electric_range_miles decimal(6,1)
  emissions_standard varchar
  end_of_production_model_year varchar
  engine_code varchar
  eop_date date
  extended_warranty_eligible_flag boolean [note: 'Whether model is eligible for extended warranty programs']
  field_service_support_flag boolean
  fuel_economy_city_mpg decimal(5,2)
  fuel_economy_hwy_mpg decimal(5,2)
  fuel_type varchar
  height_mm decimal(7,1)
  homologation_status varchar
  launch_model_year varchar
  length_mm decimal(7,1)
  market_regions varchar
  mes_model_code varchar [note: 'Model code as registered in MES systems for production tracking.']
  model_status varchar
  msrp_usd decimal(10,2)
  name varchar
  ncap_safety_rating varchar
  obd_diagnostic_support_level varchar [note: 'Level of OBD-II diagnostic support (basic, enhanced, full)']
  ota_update_capable_flag boolean [note: 'Whether model supports OTA software updates']
  powertrain_type varchar
  primary_market varchar
  program_code varchar
  safety_standard varchar
  seating_capacity varchar
  segment varchar
  self_service_portal_eligible_flag boolean [note: 'Whether model is eligible for self-service portal features']
  sop_date date
  transmission_gears varchar
  transmission_type varchar
  updated_timestamp timestamp
  variant_count varchar
  vehicle_class varchar
  wheelbase_mm decimal(7,1)
  width_mm decimal(7,1)

  Note: 'Defines the commercial vehicle model (nameplate) as a business entity — e.g., F-150, Camry, Model 3. Captures model name, brand/marque, vehicle segment (sedan, SUV, pickup, commercial), body style, drive configuration (FWD, RWD, AWD, 4WD), primary market, launch MY, EOP MY, and program code. Serves as the top-level classification anchor for all vehicle configurations and trim hierarchies.'
}

Table vehicle.trim_level {
  trim_level_id varchar [pk]
  catalog_version_id varchar [note: 'Foreign key linking to product.catalog_version. Business justification: Trim levels are published within specific catalog versions for dealer ordering systems and consumer configurators. Automotive retail operations require this link to determine which trim levels are ord']
  model_id varchar
  base_msrp_amount decimal(12,2)
  base_msrp_usd decimal(12,2)
  connected_services_tier varchar [note: 'Connected services tier included with trim (basic, premium, ultimate)']
  created_timestamp timestamp
  effective_end_date date
  effective_start_date date
  extended_warranty_default_months varchar [note: 'Default extended warranty period in months for this trim']
  is_active boolean
  powertrain_options varchar
  standard_features varchar
  trim_code varchar
  trim_description varchar
  trim_name varchar
  trim_tier varchar

  Note: 'Defines the ordered hierarchy of trim grades within a model-MY combination (e.g., Base, XL, XLT, Lariat, Platinum, Limited). Captures trim code, trim name, market positioning tier, MSRP base price, standard feature set description, target market region, and active/inactive status. Trim levels are the primary commercial differentiation unit used in sales, dealer ordering, and MSRP pricing. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table vehicle.powertrain_variant {
  powertrain_variant_id varchar [pk]
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Powertrain variants have dedicated assembly BOMs used in manufacturing planning, supplier sourcing, and warranty cost analysis. Automotive engineers maintain powertrain-specific BOM headers to track e']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Powertrain variants must be traceable to governing design specifications for EPA/CARB regulatory compliance, engineering change impact assessment, and homologation. Emissions certification and OBD com']
  platform_id varchar [note: 'Foreign key linking to vehicle.platform. Business justification: powertrain_variant currently stores `vehicle_platform` as a STRING column, which is a denormalized reference to the platform entity. In automotive engineering, powertrain variants are designed and val']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Powertrain variants are developed and validated within a specific vehicle program. Engineering program managers track powertrain development cost, validation status, and emissions targets per program.']
  battery_capacity_kwh decimal(5,2)
  charging_standard varchar
  co2_emissions_g_per_km varchar
  combined_system_power_kw decimal(6,2)
  created_timestamp timestamp
  cylinder_count varchar
  description varchar
  drive_type varchar
  electric_motor_power_kw decimal(6,2)
  end_of_production_date date
  engine_displacement_cc varchar
  epa_fuel_economy_combined_mpg decimal(5,2)
  epa_range_miles varchar
  fuel_economy_city_mpg decimal(5,2)
  fuel_economy_combined_mpg decimal(5,2)
  fuel_economy_highway_mpg decimal(5,2)
  fuel_type varchar
  model_year varchar
  obd_pid_set varchar [note: 'Supported OBD-II PID set for this powertrain variant']
  ota_ecu_count varchar [note: 'Number of OTA-updatable ECUs in this powertrain variant']
  powertrain_type varchar
  powertrain_variant_status varchar
  range_km varchar
  record_audit_created timestamp
  record_audit_updated timestamp
  start_of_production_date date
  subscription_available_flag boolean
  transmission_type varchar
  variant_code varchar
  variant_name varchar
  wltp_fuel_economy_combined_mpg decimal(5,2)
  wltp_range_km varchar

  Note: 'Authoritative catalog of all powertrain configurations available across the vehicle lineup. Captures powertrain type (ICE, HEV, PHEV, BEV, FCEV), engine displacement, cylinder count, fuel type, electric motor peak power (kW), combined system power, transmission type, drive type, EPA/WLTP fuel economy or range rating, CO2 emissions (g/km), battery capacity (kWh for EV/PHEV), and charging standard (CCS, CHAdeMO, NACS). Used for homologation, CAFE compliance, and consumer-facing specifications.'
}

Table vehicle.platform {
  platform_id varchar [pk]
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Platform architecture is governed by master design specifications covering structural requirements, dimensional envelopes, and weight targets. Homologation, safety certification, and platform reuse de']
  vehicle_program_id varchar [note: 'Foreign key linking to engineering.vehicle_program. Business justification: Platform development is funded and governed under a vehicle program. Engineering program reporting, development cost allocation, and milestone tracking require knowing which vehicle program owns a pla']
  adaptive_cruise_control boolean
  adas_features varchar
  architecture varchar
  code varchar
  commodity_exposure_profile varchar
  compatible_powertrain_families varchar
  created_timestamp timestamp
  description varchar
  development_cost_usd decimal(18,2)
  diagnostic_connector_type varchar [note: 'Type of diagnostic connector (OBD-II Type A, Type B)']
  emissions_class varchar
  end_of_production_date date
  family varchar
  generation decimal(10,4)
  height_max_mm varchar
  height_min_mm varchar
  length_max_mm varchar
  length_min_mm varchar
  material_strategy decimal(10,4)
  max_gvw_kg varchar
  modular_score decimal(9,4)
  name varchar
  obd_architecture_version varchar [note: 'OBD architecture version supported by platform']
  ota_capability boolean
  ota_gateway_architecture varchar [note: 'OTA gateway architecture for the platform']
  owner_business_unit varchar
  platform_status varchar
  platform_type varchar
  regulatory_compliance varchar
  release_year varchar
  start_of_production_date date
  supplier_collaboration_tier varchar
  track_width_max_mm varchar
  track_width_min_mm varchar
  updated_timestamp timestamp
  version varchar
  weight_kg varchar
  wheelbase_max_mm varchar
  wheelbase_min_mm varchar
  width_max_mm varchar
  width_min_mm varchar

  Note: 'Defines the vehicle platform (architecture) that underpins one or more models. Captures platform code, platform name, architecture generation, wheelbase range, track width range, structural material strategy (steel, aluminum, mixed), compatible powertrain families, maximum GVW rating, and platform owner business unit. Platforms are shared across multiple nameplates and model years, making this a critical cross-model reference for engineering, manufacturing, and supply chain.'
}

Table vehicle.configuration {
  configuration_id varchar [pk]
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: Vehicle configurations must be traceable to their governing APQP plan for production release authorization and PPAP approval. Configuration-level APQP compliance is required before a configuration can']
  bom_header_id varchar [note: 'Foreign key linking to product.bom_header. Business justification: Vehicle configuration drives BOM header selection for production planning and standard costing. Manufacturing and engineering teams use this link to validate build feasibility and retrieve component l']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: A vehicle configuration maps directly to a specific engineering BOM for production planning, cost rollup, and engineering change impact assessment. Manufacturing execution systems require configuratio']
  catalog_version_id varchar [note: 'Foreign key linking to product.catalog_version. Business justification: Vehicle configurations are published in catalog versions to enable dealer ordering and online configurator availability. Automotive retail operations require this link to determine which configuration']
  design_specification_id varchar
  model_id varchar
  platform_id varchar
  powertrain_variant_id varchar
  production_plant_id varchar
  trim_level_id varchar [note: 'Foreign key linking to vehicle.vehicle_trim_level. Business justification: configuration defines a fully specified, buildable vehicle combining model, MY, trim, powertrain, and market. It currently stores trim as a STRING column (`trim_level`), which is denormalized. vehicle']
  adas_features varchar
  body_style varchar
  build_feasibility_status varchar
  co2_emissions_g_per_km varchar
  code decimal(10,4)
  created_timestamp timestamp
  destination_charge decimal(18,2)
  drivetrain varchar
  emissions_cert_status varchar
  end_of_production_date date
  ev_range_miles varchar
  extended_warranty_eligible_flag boolean [note: 'Whether this configuration is eligible for extended warranty']
  exterior_color varchar
  fuel_economy_city_mpg decimal(5,2)
  fuel_economy_hwy_mpg decimal(5,2)
  fuel_type varchar
  interior_material varchar
  market_country_code varchar
  market_region varchar
  model_year varchar
  msrp_amount decimal(18,2)
  obd_diagnostic_package varchar [note: 'OBD diagnostic package level for this configuration']
  optional_package_codes varchar
  ota_update_tier varchar [note: 'OTA update tier (safety_only, full, premium)']
  record_status varchar
  start_of_production_date date
  subscription_eligible_flag boolean
  total_price decimal(18,2)
  transmission_type varchar
  updated_timestamp timestamp
  vehicle_platform varchar
  warranty_miles varchar
  warranty_years varchar
  wheel_size_inch varchar

  Note: 'The fully specified, buildable vehicle configuration combining model, MY, trim, powertrain, and market. Each record represents a unique orderable specification (analogous to a manufacturing SKU or dealer order code). Captures configuration code, market region, build feasibility status, MSRP, destination charge, fuel economy label values, emissions certification status, and production plant assignment. This is the master configuration record that bridges product planning to manufacturing BOM explosion and dealer order management.'
}

Table vehicle.option_package {
  option_package_id varchar [pk]
  bom_id varchar
  configuration_id varchar
  connected_service_included_flag boolean [note: 'Whether connected vehicle services are included in this package']
  created_timestamp timestamp
  effective_end_date date
  effective_start_date date
  included_features varchar
  is_active boolean
  is_available boolean
  msrp_amount decimal(12,2)
  ota_feature_unlock_flag boolean [note: 'Whether this package can be unlocked via OTA']
  package_code varchar
  package_description varchar
  package_name varchar
  package_price_usd decimal(12,2)
  package_type varchar

  Note: 'Defines factory-installed option packages, standalone options, exterior colors, and interior trim selections available for vehicle configurations. Captures option code, option name, option type (package, standalone, accessory, exterior color, interior trim), MSRP uplift, content description, availability constraints (trim/market/powertrain restrictions), mutually exclusive options, and required prerequisite options. Drives dealer order configuration, window sticker (Monroney label) generation, and BOM explosion in manufacturing. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table vehicle.build_spec {
  build_spec_id varchar [pk]
  apqp_plan_id varchar [note: 'Foreign key linking to quality.apqp_plan. Business justification: Build specs must be traceable to their governing APQP plan for production release authorization. APQP gate compliance requires confirming that all build specs are covered by an approved APQP plan. Pro']
  bom_id varchar [note: 'Foreign key linking to engineering.bom. Business justification: Production traceability and recall management require knowing which exact engineering BOM revision was used to build a specific vehicle. Build spec is the physical build record; BOM is its engineering']
  build_bom_header_id varchar
  configuration_id varchar
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: Each build spec is governed by a specific inspection plan that defines acceptance criteria for that build. Production quality control requires knowing which inspection plan applies to a given build sp']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: build_spec records which production line a vehicle was built on — essential for quality traceability, recall investigations, and line-level defect rate analysis. production_line is a denormalized plai']
  vin_registry_id varchar [note: 'Foreign key linking to vehicle.vin_registry. Business justification: build_spec is the as-built specification record for a specific VIN. It currently stores the VIN as a raw STRING column, which is denormalized. Adding vin_registry_id as a FK to vin_registry.vin_regist']
  build_date date
  build_spec_status varchar
  co2_emissions_g_per_km varchar
  cpo_eligible_flag boolean
  created_timestamp timestamp
  diagnostic_trouble_code_initial varchar
  emissions_rating varchar
  fleet_spec_flag boolean
  fuel_efficiency_mpg decimal(4,2)
  modified_timestamp timestamp
  ncap_rating varchar
  ota_updatable_flag boolean
  plant_code varchar
  regulatory_approval_status varchar
  safety_feature_codes varchar
  sequence_number varchar
  software_version varchar
  special_order_flag boolean
  v2x_enabled_flag boolean
  vehicle_weight_kg decimal(6,2)
  warranty_end_date date
  warranty_mileage_limit varchar
  warranty_start_date date

  Note: 'The as-built specification record for a specific VIN, capturing the exact combination of configuration, options, colors, powertrain, and features installed on that vehicle unit as it rolled off the production line. Captures VIN reference, configuration code, exterior color, interior trim selection, all installed option codes, actual build date, plant code, production sequence number, and any deviation from standard specification (e.g., special order, fleet spec, running change). This is the definitive as-built record used by aftersales, warranty, recall population identification, and residual value analytics.'
}

Table vehicle.msrp_pricing {
  msrp_pricing_id varchar [pk]
  configuration_id varchar
  model_id varchar
  msrp_price_book_id varchar [note: 'Foreign key linking to product.msrp_price_book. Business justification: MSRP pricing records belong to a price book that governs pricing rules for a market/model year. Automotive pricing managers use price books to manage and publish pricing across dealer networks. This l']
  option_package_id varchar [note: 'Foreign key linking to vehicle.vehicle_option_package. Business justification: msrp_pricing stores `option_package_code` as a STRING column, which is a denormalized reference to the vehicle_option_package catalog. MSRP pricing includes pricing for factory-installed option packag']
  powertrain_variant_id varchar [note: 'Foreign key linking to vehicle.powertrain_variant. Business justification: msrp_pricing stores `powertrain_type` as a STRING column, which is a denormalized reference to the powertrain catalog. MSRP pricing in automotive is frequently differentiated by powertrain variant (e.']
  trim_level_id varchar [note: 'Foreign key linking to vehicle.vehicle_trim_level. Business justification: msrp_pricing manages the MSRP schedule for vehicle configurations and trim levels. It currently stores `trim_level` as a STRING column, which is denormalized. vehicle_trim_level is the authoritative t']
  connected_services_price_amount decimal(18,2) [note: 'Price of connected services subscription bundle']
  created_timestamp timestamp
  currency_code varchar
  destination_charge_amount decimal(18,2)
  destination_charge_flag boolean
  effective_end_date date
  effective_start_date date
  ev_tax_credit_amount decimal(18,2)
  ev_tax_credit_eligibility_flag decimal(18,2)
  extended_warranty_price_amount decimal(18,2) [note: 'Price of extended warranty option']
  gas_guzzler_tax_amount decimal(18,2)
  gas_guzzler_tax_flag decimal(18,2)
  market_country_code varchar
  market_region varchar
  model_year varchar
  msrp_pricing_status decimal(18,2)
  online_price_flag decimal(18,2)
  price_amount decimal(18,2)
  price_key decimal(18,2)
  price_label decimal(18,2)
  price_notes decimal(18,2)
  price_source_system decimal(18,2)
  price_type decimal(18,2)
  price_uplift_amount decimal(18,2)
  price_uplift_reason decimal(18,2)
  price_version decimal(18,2)
  record_audit_created timestamp
  record_audit_updated timestamp

  Note: 'Manages the MSRP (Manufacturer Suggested Retail Price) schedule for vehicle configurations, trim levels, and option packages by market and MY. Captures base MSRP, destination and delivery charge, gas guzzler tax (if applicable), federal EV tax credit eligibility, effective date, expiry date, currency, and market region. Provides the authoritative pricing reference for dealer ordering, window sticker generation, and sales analytics. Distinct from dealer invoice pricing (owned by billing domain).'
}

Table vehicle.lifecycle_event {
  lifecycle_event_id varchar [pk]
  compound_movement_id varchar [note: 'Foreign key linking to logistics.compound_movement. Business justification: Lifecycle events of type \'compound_arrival\', \'compound_departure\', or \'yard_move\' directly correspond to a compound_movement record. Yard management and PDI workflow systems require this link to corre']
  dealership_id varchar
  defect_record_id varchar [note: 'Foreign key linking to quality.defect_record. Business justification: Field service lifecycle events (warranty repair, recall remedy, roadside assistance) are triggered by or linked to specific defect records. Quality and warranty teams need to trace lifecycle events ba']
  party_id varchar [note: 'Foreign key linking to customer.party. Business justification: Customer journey analytics and service history reporting require knowing which customer party was involved in a lifecycle event (service visit, self-service portal action, recall acknowledgment). life']
  recall_campaign_id varchar [note: 'Foreign key linking to compliance.recall_campaign. Business justification: Recall remedy completion is recorded as a vehicle lifecycle event. Service operations log when a specific VIN completed a recall remedy appointment. This link enables recall completion rate tracking p']
  shipment_id varchar [note: 'Foreign key linking to logistics.shipment. Business justification: Vehicle lifecycle events of type \'vehicle_shipped\' or \'in_transit\' must reference the specific shipment record for OEM logistics traceability reporting and customer delivery status tracking. A domain ']
  vehicle_handover_id varchar [note: 'Foreign key linking to logistics.vehicle_handover. Business justification: Lifecycle events of type \'delivery\' or \'customer_handover\' directly correspond to a vehicle_handover record. This link enables end-to-end delivery traceability, OTD (on-time delivery) reporting, and c']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: Lifecycle events such as \'vehicle sold\' and \'vehicle delivered\' are directly triggered by vehicle_order completion. Linking lifecycle_event to vehicle_order enables end-to-end vehicle lifecycle tracea']
  vin_registry_id varchar
  created_timestamp timestamp
  digital_channel_flag boolean
  event_category varchar
  event_description varchar
  event_location_city varchar
  event_location_country varchar
  event_location_latitude double
  event_location_longitude double
  event_location_state varchar
  event_notes varchar
  event_sequence_number varchar
  event_source_module varchar
  event_source_reference varchar
  event_source_system varchar
  event_status varchar
  event_subtype varchar
  event_timestamp timestamp
  event_type varchar
  is_critical boolean
  obd_triggered_flag boolean [note: 'Whether this lifecycle event was triggered by OBD-II diagnostic data']
  odometer_reading_km varchar
  ota_related_flag boolean [note: 'Whether this lifecycle event is related to an OTA deployment']
  record_created_timestamp timestamp
  record_updated_timestamp timestamp
  self_service_initiated_flag boolean [note: 'Whether this event was initiated through customer self-service portal']
  triggering_system varchar

  Note: 'Transactional log of significant lifecycle state transitions for a specific VIN throughout its life. Captures event type (manufactured, PDI-completed, shipped-to-dealer, sold-retail, sold-fleet, exported, titled, re-acquired, scrapped, stolen, total-loss), event timestamp, event location, responsible party, odometer reading at event, and triggering system. Provides the complete lifecycle audit trail for a vehicle unit from production to end-of-life, supporting title history, recall tracking, and residual value analytics.'
}

Table vehicle.ownership {
  ownership_id varchar [pk]
  party_id varchar
  vehicle_handover_id varchar [note: 'Foreign key linking to logistics.vehicle_handover. Business justification: Ownership transfer is legally initiated by the vehicle handover event. Linking ownership to vehicle_handover enables title/registration audit trails, warranty start date reconciliation, and regulatory']
  vehicle_order_id varchar [note: 'Foreign key linking to sales.vehicle_order. Business justification: Vehicle ownership records for new vehicle acquisitions must trace back to the originating vehicle_order for warranty registration, title processing, and OEM customer relationship establishment. This F']
  vin_registry_id varchar
  acquisition_channel varchar
  acquisition_date date
  connected_services_active_flag boolean [note: 'Whether connected vehicle services are active for this ownership']
  disposition_date date
  disposition_reason varchar
  is_current_owner boolean
  lien_holder varchar
  odometer_at_acquisition varchar
  odometer_at_disposition varchar
  ownership_number varchar
  ownership_type varchar
  self_service_portal_enrolled_flag boolean [note: 'Whether owner is enrolled in self-service portal']
  title_state varchar

  Note: 'This association product represents the ownership relationship between a vehicle (vin_registry) and a party (customer). It captures acquisition and disposition dates, ownership type, and ownership number, tracking the history of which parties own which vehicles.. Existence Justification: A vehicle can be owned by multiple parties over its lifecycle (e.g., resale), and a party can own multiple vehicles simultaneously. The business actively records each ownership event with dates, type, and ownership number, and users query ownership history for warranty, service, recall, and resale analytics.'
}

Table product.bom_header {
  bom_header_id varchar [pk]
  bom_id varchar
  catalog_version_id varchar [note: 'Foreign key linking to product.catalog_version. Business justification: A BOM header represents a commercial product structure that is published and versioned through the catalog lifecycle. Each BOM header is associated with a specific catalog version that governs its com']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Engineering Change Management: when an ECO is approved, the product BOM header is revised. Change impact analysis, audit trails, and regulatory compliance reporting require direct traceability from a ']
  plant_id varchar [note: 'Foreign key linking to manufacturing.plant. Business justification: BOM headers in automotive are plant-specific — a product BOM is released to a specific manufacturing plant for production execution. Plant-specific BOM management is standard SAP PP practice; plant_co']
  segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: A BOM header represents a specific commercial vehicle product configuration that is positioned within a market segment (e.g., compact SUV, full-size truck, commercial van). The product_segment table i']
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: The product SKU (catalog-configured vehicle/part) must resolve to an inventory SKU master record to enable stock queries, MRP planning, and goods movements. Automotive operations require this link to ']
  adas_level varchar
  alternative_bom_group varchar
  approved_by varchar
  approved_timestamp timestamp
  base_unit_of_measure varchar
  bom_status varchar
  bom_type varchar
  bom_usage varchar
  configuration_profile varchar
  connectivity_package varchar
  created_timestamp timestamp
  data_governance_ref varchar
  effective_from_date date
  effective_to_date date
  emissions_standard varchar
  engineering_release_date date
  eop_date date
  homologation_status varchar
  is_configurable boolean
  lot_size_minimum varchar
  market_region varchar
  model_year varchar
  modified_timestamp timestamp
  msrp_base_amount decimal(18,2)
  nameplate_code varchar
  notes varchar
  online_configurator_linked_flag boolean
  powertrain_type varchar
  revision_level varchar
  safety_certification_level varchar
  sop_date date
  standard_cost_amount decimal(18,2)
  sustainability_score decimal(5,2)
  total_assembly_weight_kg decimal(10,3)
  total_component_count varchar
  variant_code varchar
  vin_pattern varchar
  warranty_program_code varchar

  Note: 'Product-level BOM (Bill of Materials) header record representing the commercial product structure for a given SKU or model year program. Captures BOM number, BOM type (commercial/engineering/service), effective date range, revision level, plant applicability, BOM status (active/superseded/obsolete), and total component count. This is the commercial BOM owned by the product domain — distinct from the engineering BOM managed in Teamcenter/Windchill, which is owned by the engineering domain. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.product_bom_line {
  product_bom_line_id varchar [pk]
  bom_header_id varchar
  part_master_id varchar
  sku_master_id varchar [note: 'Foreign key linking to inventory.sku_master. Business justification: BOM line components must map to inventory SKU master records for MRP explosion, procurement planning, and goods receipt processing. Automotive MRP systems explode BOM lines against sku_master to gener']
  component_code varchar
  component_description varchar
  component_quantity decimal(12,3)
  created_timestamp timestamp
  effective_date date
  effective_from_date date
  effective_to_date date
  expiration_date date
  is_critical boolean
  is_optional_flag boolean
  item_category varchar
  line_number varchar
  option_code varchar
  part_description varchar
  part_number varchar
  quantity decimal(12,4)
  quantity_per decimal(12,4)
  quantity_per_assembly decimal(12,4) [note: 'Quantity of the component required per parent assembly.']
  scrap_percentage decimal(5,2)
  unit_of_measure varchar
  updated_timestamp timestamp

  Note: 'Individual component line items within a product BOM (Bill of Materials). Captures BOM line number, part number, part description, part type (raw material/sub-assembly/purchased component/fastener), quantity per vehicle, unit of measure, effective date range, plant applicability, alternative item group, scrap factor percentage, and PPAP (Production Part Approval Process) status. Enables product cost rollup, MRP (Material Requirements Planning) explosion, and supply chain sourcing alignment. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.segment {
  segment_id varchar [pk]
  parent_segment_product_segment_id varchar
  adas_level_range varchar
  annual_sales_volume_target varchar
  body_style_category varchar
  cafe_fleet_category varchar
  cargo_volume_range_cu_ft varchar
  code varchar
  competitive_set_definition varchar
  connectivity_capability boolean
  created_by_user varchar
  created_timestamp timestamp
  data_governance_ref varchar
  description varchar
  effective_end_date date
  effective_start_date date
  emissions_standard_target varchar
  esg_segment_classification varchar
  hierarchy_level varchar
  homologation_regions varchar
  industry_classification_code varchar
  is_active boolean
  lifecycle_status varchar
  market_positioning_tier varchar
  market_share_target_pct decimal(10,4)
  modified_by_user varchar
  modified_timestamp timestamp
  name varchar
  ncap_rating_applicability varchar
  ota_update_capability boolean
  powertrain_category varchar
  price_range_max_usd decimal(18,2)
  price_range_min_usd decimal(18,2)
  primary_use_case varchar
  regulatory_category varchar
  sae_classification_code varchar
  seating_capacity_range varchar
  strategic_priority varchar
  subscription_eligible_flag boolean
  target_customer_profile varchar

  Note: 'Reference classification of vehicle market segments used to position nameplates competitively (e.g., Compact Car, Midsize SUV, Full-Size Pickup, Commercial Van, Luxury Sedan, Electric Crossover). Captures segment code, segment name, segment hierarchy level, parent segment, SAE/industry classification code, competitive set definition, and applicable regulatory category. Used in market planning, competitive benchmarking, CAFE fleet averaging, and sales reporting. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.catalog_publication {
  catalog_publication_id varchar [pk]
  catalog_version_id varchar
  regulatory_submission_id varchar [note: 'Foreign key linking to compliance.regulatory_submission. Business justification: Catalog publications (price lists, product specs) require regulatory filing in many markets (e.g., EU type approval publications, NHTSA filings). The three denormalized filing columns on catalog_publi']
  superseded_by_publication_catalog_publication_id varchar
  approval_timestamp timestamp
  approved_by_user_name varchar
  created_timestamp timestamp
  data_governance_ref varchar
  digital_storefront_flag boolean
  distribution_confirmation_flag boolean
  distribution_confirmation_timestamp timestamp
  distribution_method varchar
  distribution_retry_count varchar
  effective_end_date date
  effective_start_date date
  esg_disclosure_included_flag boolean
  file_checksum varchar
  file_name varchar
  file_size_bytes varchar
  language_code varchar
  last_distribution_error varchar
  last_modified_timestamp timestamp
  model_year varchar
  nameplate_count varchar
  priority_level varchar
  publication_date date
  publication_format varchar
  publication_notes varchar
  publication_number varchar
  publication_status varchar
  publication_type varchar
  published_by_user_name varchar
  recall_reason varchar
  recall_timestamp timestamp
  record_count varchar
  target_channel varchar
  target_country_code varchar
  target_region varchar
  target_system varchar
  trim_count varchar
  validation_error_count varchar
  validation_status varchar
  validation_warning_count varchar

  Note: 'Tracks the formal publication events of the commercial product catalog to downstream consumers — dealer ordering systems (DMS), consumer configurators, sales portals, and regulatory filings. Captures publication ID, catalog version, publication type (dealer/consumer/regulatory/internal), target system/channel, publication date, effective date range, published-by user, publication status (draft/approved/published/recalled), and distribution confirmation. Provides an audit trail of when and to whom catalog versions were released. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.package_availability {
  package_availability_id varchar [pk]
  catalog_publication_id varchar
  dealership_id varchar
  allocation_quantity varchar
  availability_status varchar
  created_timestamp timestamp
  discontinuation_date date
  end_date date
  is_orderable boolean
  launch_date date
  market_region varchar
  order_constraint varchar
  updated_timestamp timestamp

  Note: 'Associates an option package with a dealership, capturing the availability status and launch date for that package at the dealer. Each record links one option package to one dealership and stores attributes that belong only to this relationship.. Existence Justification: Dealerships actively manage which option packages they carry, setting an availability status and launch date for each package. Each option package can be offered by many dealerships, and each dealership can offer many option packages, creating a many‑to‑many relationship that carries its own attributes. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.catalog_version {
  catalog_version_id varchar [pk]
  msrp_price_book_id varchar
  previous_catalog_version_id varchar
  approval_status varchar
  approved_by varchar
