  currency_code varchar
  data_governance_ref varchar
  ecommerce_version_flag boolean
  effective_end_date date
  effective_start_date date
  esg_content_version varchar
  is_current boolean
  market_segment varchar
  region_coverage varchar
  release_notes varchar
  sku_structure_code varchar
  total_models varchar
  total_options varchar
  updated_by varchar
  updated_timestamp timestamp
  version_name varchar
  version_number varchar
  version_source_system varchar
  created_by varchar

  Note: 'Master reference table for catalog_version. Referenced by catalog_version_id. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table product.msrp_price_book {
  msrp_price_book_id varchar [pk, note: 'Primary key for msrp_price_book']
}

Table engineering.vehicle_program {
  vehicle_program_id varchar [pk]
  bom_version varchar
  budget_allocation decimal(15,2)
  cad_release_version varchar
  cae_release_version varchar
  created_timestamp timestamp
  currency_code varchar
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  description varchar
  digital_twin_enabled boolean
  drivetrain varchar
  emission_standard varchar
  end_date date
  engineering_change_order_count varchar
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  launch_date date
  model_year_end varchar
  model_year_start varchar
  notes varchar
  ota_update_capability boolean
  platform_architecture varchar
  powertrain_type varchar
  program_code varchar
  program_name varchar
  program_type varchar
  regulatory_approval_status varchar
  segment varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  start_date date
  target_cost_per_vehicle decimal(18,2)
  target_emissions_g_per_km decimal(6,2)
  target_fuel_efficiency_mpg decimal(5,2)
  target_market varchar
  target_production_volume varchar
  target_range_km varchar
  target_weight_kg decimal(8,2)
  total_simulation_result_count varchar [note: 'Total number of R&D simulation results associated with this vehicle program.']
  updated_timestamp timestamp
  vehicle_class varchar
  vehicle_program_status varchar

  Note: 'Master record for a vehicle development program (nameplate/platform program), capturing program code, program name, vehicle segment, platform architecture, SOP (Start of Production) target date, EOP (End of Production) date, MY (Model Year) scope, program phase (concept, development, validation, launch), program director, budget allocation, and program status. Serves as the top-level anchor for all engineering activities within a development cycle. Owned by Siemens Teamcenter PLM.'
}

Table engineering.bom {
  bom_id varchar [pk]
  change_id varchar
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: An engineering BOM is the physical realization of a design specification — the BOM is built to satisfy the requirements defined in the design spec. Linking bom to design_specification establishes whic']
  vehicle_program_id varchar
  bom_number varchar
  bom_status varchar
  bom_type varchar
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  effective_from_date date
  effective_to_date date
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  model_year varchar
  plant_code varchar
  revision_level varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  standard_cost_amount decimal(18,2)
  total_component_count varchar
  total_weight_kg decimal(10,3)
  updated_timestamp timestamp

  Note: 'Engineering Bill of Materials (eBOM) header record representing the complete structured parts list for a vehicle program or variant at a specific revision level. Captures BOM type (eBOM, mBOM, sBOM), program reference, model year, configuration context, effectivity dates, release status, BOM owner, and PLM system source. The eBOM is the authoritative design-intent parts structure managed in Siemens Teamcenter and ENOVIA before handoff to manufacturing BOM.'
}

Table engineering.engineering_bom_line {
  engineering_bom_line_id varchar [pk]
  bom_id varchar
  cad_model_id varchar [note: 'Foreign key linking to engineering.cad_model. Business justification: Each BOM line references a specific CAD model geometry asset. The existing cad_reference field on engineering_bom_line is a free-text string reference to a CAD file — this is a classic denormalization']
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: BOM line items are created or modified under specific engineering change orders. The existing change_number text field is a denormalized reference to the change record. Adding change_id FK normalizes ']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Each BOM line item (part-to-parent relationship) is governed by a design specification that defines the technical requirements for that part in context. Linking engineering_bom_line to design_specific']
  part_master_id varchar
  assembly_level varchar
  component_description varchar
  cost_target_amount decimal(18,2) [note: 'Cost target for this BOM line item']
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  description varchar [note: 'Description of the entity']
  effective_from_date date
  effective_to_date date
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  find_number varchar
  is_critical_path boolean
  line_number varchar
  line_status varchar
  make_buy_indicator varchar [note: 'Indicates whether component is made in-house or purchased']
  material_code varchar [note: 'Material specification code']
  quantity_per_assembly decimal(10,4)
  revision_level varchar [note: 'Current revision level of the component']
  scrap_factor_pct decimal(5,2)
  source_system_code varchar [note: 'Identifier of the originating system of record (e.g., PLM, SAP, MES)']
  supplier_nomination_status varchar [note: 'Status of supplier nomination for this component']
  tolerance_spec varchar [note: 'Dimensional tolerance specification']
  unit_of_measure varchar
  updated_timestamp timestamp
  validation_status varchar [note: 'Design validation status']
  weight_kg decimal(8,3) [note: 'Component weight in kilograms']

  Note: 'Individual line item within an engineering BOM, representing a single part-to-parent relationship in the BOM hierarchy. Captures parent assembly reference, child part number, find number, quantity, unit of measure, effectivity start/end dates, variant applicability, substitution flags, BOM level, and engineering change reference. Supports multi-level BOM explosion and where-used analysis. Sourced from Siemens Teamcenter BOM Management.'
}

Table engineering.part_master {
  part_master_id varchar [pk]
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: A part master record is designed to meet a governing design specification. While cad_model already links part_master → design_specification indirectly, many parts exist in the PLM system before a CAD ']
  vehicle_program_id varchar
  commodity_code varchar
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  drawing_number varchar
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  lifecycle_status varchar
  make_or_buy varchar
  material_type varchar
  part_description varchar
  part_name varchar
  part_number varchar
  part_status varchar
  part_type varchar
  revision_level varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  test_bench_validated_flag boolean [note: 'Whether this part has been validated on a physical test bench.']
  unit_of_measure varchar
  updated_timestamp timestamp
  weight_kg decimal(10,4)

  Note: 'Engineering part master record representing a unique part or component managed within the PLM system. Captures part number, part name, part classification, material type, weight, dimensions, drawing number, CAD model reference, lifecycle state (in-work, released, obsolete), revision level, owning engineer, supplier part number, REACH/RoHS compliance flag, and part family. Authoritative source for engineering part identity in Siemens Teamcenter / PTC Windchill.'
}

Table engineering.design_specification {
  design_specification_id varchar [pk]
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Design specifications in automotive are authored to satisfy specific regulatory requirements (e.g., FMVSS 208 drives airbag deployment specs). Requirements traceability coverage reporting (requirement']
  vehicle_program_id varchar
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data catalog entry for lineage and governance']
  description varchar
  document_url varchar
  effective_date date
  expiry_date date
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  requirements_traceability_coverage_pct decimal(5,2) [note: 'Percentage of requirements traced to this design specification.']
  revision_level varchar
  spec_name varchar
  spec_number varchar
  spec_status varchar
  spec_type varchar
  updated_timestamp timestamp

  Note: 'Engineering design specification document record capturing the technical requirements and design intent for a vehicle system, subsystem, or component. Includes specification number, title, specification type (system, subsystem, component, interface), applicable program, revision history, author, approval status, linked requirements, target performance values, and regulatory references (FMVSS, UNECE, NCAP). Managed in Teamcenter or ENOVIA document management.'
}

Table engineering.cad_model {
  cad_model_id varchar [pk]
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: CAD models are updated as part of engineering change orders. This FK links each CAD model revision to the ECO/ECN that authorized the change, enabling change-to-CAD traceability and ensuring CAD model']
  design_specification_id varchar
  part_master_id varchar
  cad_file_name varchar
  cad_system varchar
  checksum varchar
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data catalog entry for lineage and governance']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  file_format varchar
  file_size_bytes varchar
  model_status varchar
  revision_level varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  updated_timestamp timestamp
  created_by varchar

  Note: 'CAD (Computer-Aided Design) model record representing a 3D digital geometry asset created in CATIA or equivalent tool. Captures model file reference, part or assembly association, CAD tool version, coordinate system, model maturity level, digital mock-up (DMU) inclusion flag, last published date, file size, configuration context, and owning designer. Supports digital twin construction and downstream CAE simulation setup. Sourced from Dassault Systèmes CATIA and ENOVIA.'
}

Table engineering.change {
  change_id varchar [pk]
  milestone_id varchar [note: 'Foreign key linking to engineering.milestone. Business justification: Engineering changes (ECO/ECN) are often gated by program milestones — a change must be implemented and validated before a specific gate review (e.g., Design Freeze, Job 1). Linking change to milestone']
  part_master_id varchar [note: 'Foreign key linking to the part master record that is affected by this change']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Engineering change orders in automotive are frequently initiated by new or updated regulatory requirements (e.g., new emission limits, updated crash standards). Linking change to regulatory_requiremen']
  vehicle_program_id varchar
  affected_revision_level varchar [note: 'The specific revision level of the part that is targeted by this change. Belongs to the relationship because it identifies which version of the part is being modified, not a property of the part or the change in isolation.']
  approved_date date
  change_number varchar
  change_status varchar
  change_type varchar
  cost_impact_amount decimal(18,2)
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  description varchar
  effective_date date [note: 'The date on which this change becomes effective for this specific part. Belongs to the relationship because the effective date can differ across parts within the same ECO (e.g., phased rollout across production lines).']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  impact_assessment varchar
  impact_type varchar [note: 'Classifies the nature of how this specific change affects this specific part (e.g., design change, material change, drawing update). Belongs to the relationship because the same ECO can affect different parts in different ways.']
  implementation_date date
  implementation_status varchar [note: 'Per-part tracking of whether this change has been implemented for this specific part. Belongs to the relationship because different parts within the same ECO can be at different stages of implementation.']
  priority varchar
  reason_code varchar
  requested_date date
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  updated_timestamp timestamp

  Note: 'Engineering Change Order/Notice (ECO/ECN) record capturing a formal request to modify a part, assembly, design specification, or BOM. Includes change number, change type (ECR/ECO/ECN), title, reason for change (cost reduction, quality, regulatory, customer request), affected parts list, affected programs, initiator, approver chain, priority, implementation date, cost impact estimate, and change status (draft, under review, approved, implemented, rejected). Managed in Siemens Teamcenter Change Management.'
}

Table engineering.validation_test {
  validation_test_id varchar [pk]
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Engineering changes (ECO/ECN) require re-validation testing to confirm the change does not introduce new failure modes or degrade performance. Linking validation_test to change establishes which tests']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Validation tests are executed to verify compliance against a design specification. The test_standard field on validation_test is a free-text code, but a proper FK to design_specification normalizes th']
  fmea_record_id varchar [note: 'Foreign key linking to engineering.fmea_record. Business justification: Validation tests are frequently triggered by FMEA findings — when an FMEA identifies a failure mode with high RPN, a validation test is mandated to verify the recommended corrective action. Linking va']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: A validation test (NVH, FEA, CFD, physical prototype) is performed on a specific part or assembly. Linking validation_test to part_master establishes which part is under test, enabling traceability fr']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Automotive validation tests (FMVSS, ECE, Euro NCAP, OBD) are designed to demonstrate compliance with specific regulatory requirements. Engineering teams must trace each test to the requirement it sati']
  vehicle_program_id varchar
  actual_start_date date
  completion_date date
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  iot_data_collection_flag boolean [note: 'Whether IoT sensor data was collected during test']
  pass_fail_result varchar
  planned_start_date date
  regulatory_compliance_flag boolean
  requirements_coverage_pct decimal(5,2) [note: 'Percentage of linked requirements covered by this validation test.']
  sample_size varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  test_name varchar
  test_standard varchar
  test_status varchar
  test_type varchar
  updated_timestamp timestamp

  Note: 'Engineering validation test record capturing a physical or virtual test event performed on a prototype or production-intent part/vehicle. Includes test ID, test type (DVP — Design Verification Plan, PVP — Process Validation Plan, PPAP, durability, emissions, NCAP/WLTP, FMVSS), test name, test standard reference, test facility, test date, test engineer, test result (pass/fail/conditional), measured values vs. targets, and disposition. Supports DVP&R (Design Verification Plan and Report) tracking.'
}

Table engineering.test_result {
  test_result_id varchar [pk]
  validation_test_id varchar
  ambient_temperature_c decimal(5,1)
  approval_engineer_name varchar [note: 'Name of engineer who approved the result']
  confidence_level_pct decimal(5,2) [note: 'Statistical confidence level of the result']
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage and ownership tracking']
  deviation_from_target decimal(18,4) [note: 'Deviation from target value']
  engineering_test_result_description varchar [note: 'Description of the entity']
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  humidity_percent decimal(18,2) [note: 'Ambient humidity during test']
  measured_value decimal(18,2)
  notes varchar
  pass_fail_status varchar
  pass_flag boolean
  result_code varchar
  result_date date
  result_unit varchar
  result_value decimal(18,2)
  retest_required_flag boolean [note: 'Whether a retest is required']
  sensor_data_ref varchar [note: 'Reference to IoT sensor data used during test']
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  target_value decimal(18,2)
  test_date date
  test_duration_hours decimal(8,2) [note: 'Duration of the test in hours']
  test_engineer varchar
  test_facility varchar
  test_standard varchar [note: 'Test standard or protocol followed']
  test_status varchar
  test_type varchar [note: 'Type of test (durability, performance, safety, emissions)']
  updated_timestamp timestamp

  Note: 'Detailed test result record capturing individual measurement data points from a validation test event. Includes result ID, parent test reference, measurement parameter name, unit of measure, measured value, target value, tolerance band (min/max), pass/fail status, test condition description, channel or sensor ID, timestamp of measurement, and data file reference. Enables granular traceability of test outcomes against engineering targets and regulatory thresholds. This product is the single source of truth (SSOT) for its concept in the ECM Lakehouse.'
}

Table engineering.milestone {
  milestone_id varchar [pk]
  vehicle_program_id varchar
  actual_date date
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  deliverables varchar
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  gate_number varchar
  milestone_status varchar
  milestone_type varchar
  name varchar
  owner_name varchar
  planned_date date
  source_system_code varchar [note: 'Identifier of the originating system of record (e.g., PLM, SAP, MES)']
  updated_timestamp timestamp

  Note: 'Engineering program milestone record capturing key gate reviews and decision points in the vehicle development process. Includes milestone ID, milestone name (P0 concept freeze, P1 design freeze, P2 prototype release, P3 pilot build, SOP), program reference, planned date, actual date, milestone owner, gate review outcome (approved, conditional, deferred), open action items count, and sign-off authority. Supports APQP (Advanced Product Quality Planning) phase gate management.'
}

Table engineering.fmea_record {
  fmea_record_id varchar [pk]
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: FMEA findings with high RPN scores trigger engineering change orders. This FK links the FMEA record to the resulting ECO/ECN, enabling closed-loop corrective action tracking from risk identification t']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: FMEA (Failure Mode and Effects Analysis) is performed against specific design specifications to identify failure modes in the design intent. This FK links each FMEA record to the design spec it analyz']
  part_master_id varchar
  vehicle_program_id varchar
  action_status varchar
  created_timestamp timestamp
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  detection_rating varchar
  failure_cause varchar
  failure_effect varchar
  failure_mode varchar
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  fmea_type varchar
  occurrence_rating varchar
  recommended_action varchar
  rpn varchar
  severity_rating varchar
  source_system_code varchar [note: 'Identifier of the originating system of record (e.g., PLM, SAP, MES)']
  updated_timestamp timestamp

  Note: 'FMEA (Failure Mode and Effects Analysis) record capturing the systematic risk analysis of a design or process. Includes FMEA ID, FMEA type (DFMEA — Design FMEA, PFMEA — Process FMEA), associated part or process, failure mode description, potential effect of failure, severity rating, potential cause, occurrence rating, current controls, detection rating, RPN (Risk Priority Number), recommended actions, responsible engineer, and completion date. Managed per IATF 16949 and AIAG-VDA FMEA methodology.'
}

Table engineering.cost_target {
  cost_target_id decimal(18,2) [pk]
  change_id varchar [note: 'Foreign key linking to engineering.change. Business justification: Engineering changes have a cost_impact_amount field, and cost targets are directly affected by engineering changes. When an ECO/ECN is issued, cost targets for the affected parts or systems must be re']
  design_specification_id varchar [note: 'Foreign key linking to engineering.design_specification. Business justification: Cost targets in automotive engineering are set at the system or subsystem level, often tied directly to design specifications that define the functional requirements. A design-to-cost objective is mea']
  part_master_id varchar [note: 'Foreign key linking to engineering.part_master. Business justification: Cost targets are set at the part or system level within a vehicle program. This FK links each cost target to the specific part it governs, enabling part-level cost tracking and variance analysis again']
  vehicle_program_id varchar
  actual_amount decimal(18,2)
  cost_category decimal(18,2)
  created_timestamp timestamp
  currency_code varchar
  data_governance_ref varchar [note: 'Reference to data governance catalog entry for lineage tracking']
  effective_date date
  field_service_info varchar [note: 'Field service related information, consolidating field service concepts.']
  notes varchar
  source_system_code varchar [note: 'Identifies the source PLM/CAD system (e.g., Teamcenter, ENOVIA, Windchill)']
  target_amount decimal(18,2)
  target_status varchar
  updated_timestamp timestamp
  variance_amount decimal(18,2)

  Note: 'Engineering cost target record capturing the design-to-cost objectives assigned to vehicle systems, subsystems, or components during the development program. Includes target ID, program reference, system or component scope, target cost (material cost, manufacturing cost, total cost), current estimated cost, cost gap vs. target, cost reduction ideas count, responsible engineer, target freeze date, and approval status. Supports design-to-cost (DTC) and value engineering disciplines critical to program profitability.'
}

Table manufacturing.plant {
  plant_id varchar [pk, note: 'Primary key']
  jurisdiction_id varchar [note: 'FK to compliance jurisdiction']
  primary_segment_product_segment_id varchar [note: 'Foreign key linking to product.product_segment. Business justification: Each plant has a primary vehicle segment it produces (e.g., truck plant, EV plant). The plain attr primary_vehicle_segment is a denormalized reference to product_segment. This FK enables segment-level']
  address_line1 varchar [note: 'Address line 1']
  address_line2 varchar [note: 'Address line 2']
