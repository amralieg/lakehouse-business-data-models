    rdfs:comment 'The engine displacement in liters for ICE or hybrid powertrains. Null for pure electric vehicles.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:horsepower rdf:type rdf:Property ;
    rdfs:label 'Horsepower' ;
    rdfs:comment 'The maximum horsepower output of the competitor vehicle powertrain, used for performance comparison.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyFeatures rdf:type rdf:Property ;
