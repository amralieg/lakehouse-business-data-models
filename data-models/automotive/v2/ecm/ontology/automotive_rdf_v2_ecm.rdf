ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone by functional category: program_gate (strategic approval), design_gate (engineering freeze), quality_gate (PPAP/APQP), production_gate (SOP/EOP), regulatory_gate (homologation), commercial_gate (launch readiness).' ;
