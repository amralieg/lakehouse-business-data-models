    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcChartDescription rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Description' ;
    rdfs:comment 'Free-form description providing additional context for the chart.' ;
    rdfs:domain ind:SpcChart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocap rdf:type rdf:Property ;
