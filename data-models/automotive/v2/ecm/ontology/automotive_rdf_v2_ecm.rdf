    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the maintenance cost amount.' ;
