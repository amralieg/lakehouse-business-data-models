    rdfs:range xsd:integer .

ind:spcChartId rdf:type rdf:Property ;
    rdfs:label 'Spc Chart Id' ;
    rdfs:comment 'System-generated unique identifier for the SPC chart configuration record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpcChart .

ind:centerLine rdf:type rdf:Property ;
    rdfs:label 'Center Line' ;
    rdfs:comment 'Target center line (mean) for the SPC chart.' ;
