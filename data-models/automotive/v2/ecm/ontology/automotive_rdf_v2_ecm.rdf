ind:spcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Spc Employee Id' ;
    rdfs:comment 'Identifier of the operator who supervised or initiated the measurement.' ;
    rdfs:domain ind:SpcDataPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:spcOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Spc Operator Employee Id' ;
    rdfs:comment 'Identifier of the operator who supervised or initiated the measurement.' ;
    rdfs:domain ind:SpcDataPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calibrationDate rdf:type rdf:Property ;
