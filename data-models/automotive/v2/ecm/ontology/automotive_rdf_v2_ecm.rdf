    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossId rdf:type rdf:Property ;
    rdfs:label 'Win Loss Id' ;
    rdfs:comment 'Unique identifier for the win/loss analysis record. Primary key.' ;
