    rdfs:range ind:TelemetryEvent .

ind:vehicleOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Ownership Id' ;
    rdfs:comment 'Foreign key linking to customer.vehicle_ownership. Business justification: REQUIRED: Recall & warranty management needs to associate each defect record with the owning customer\'s vehicle record to trigger service actions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOwnership .

ind:correctiveAction rdf:type rdf:Property ;
