    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeMasterStatus rdf:type rdf:Property ;
    rdfs:label 'Gauge Master Status' ;
    rdfs:comment 'Current lifecycle state of the gauge within the quality system.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeNumber rdf:type rdf:Property ;
    rdfs:label 'Gauge Number' ;
    rdfs:comment 'Human-readable identifier printed on the gauge.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCapability rdf:type rdf:Property ;
    rdfs:label 'Inspection Capability' ;
    rdfs:comment 'Main type of measurement the gauge provides for quality inspections.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalGauge rdf:type rdf:Property ;
    rdfs:label 'Is Critical Gauge' ;
    rdfs:comment 'True when the gauge is used for measurements that affect product safety or regulatory compliance.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibratedBy rdf:type rdf:Property ;
    rdfs:label 'Last Calibrated By' ;
    rdfs:comment 'Identifier of the person or external lab that performed the most recent calibration.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line rdf:type rdf:Property ;
    rdfs:label 'Line' ;
    rdfs:comment 'Specific line or cell within the plant that uses the gauge.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'General area (e.g., warehouse, line, lab) where the gauge is stored or used.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that produced the gauge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model identifier for the gauge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Projected date for the next required calibration based on interval.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
