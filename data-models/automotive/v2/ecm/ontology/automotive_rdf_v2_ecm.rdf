    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'The channel through which the prospect or customer responded to the campaign (e.g., email click, web form submission, phone inquiry, dealer visit, mobile app, social media).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes or comments captured during the response or follow-up activities.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseScore rdf:type rdf:Property ;
    rdfs:label 'Response Score' ;
    rdfs:comment 'Numeric score representing the quality or likelihood of conversion for this campaign response, typically calculated by lead scoring algorithms.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the campaign response (e.g., new, contacted, qualified, converted to lead or opportunity, disqualified, closed).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The date and time when the prospect or customer responded to the campaign. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'The type or nature of the response action taken by the prospect or customer (e.g., inquiry, test drive request, quote request, brochure download, event registration, callback request).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeCubicFt rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cubic Ft' ;
    rdfs:comment 'The cargo volume capacity in cubic feet, used for utility and practicality comparison.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Classification of how this competitor vehicle positions against our portfolio: direct (head-to-head competitor), indirect (adjacent segment), or emerging (new market entrant).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorVehicleStatus rdf:type rdf:Property ;
    rdfs:label 'Competitor Vehicle Status' ;
    rdfs:comment 'The current status of the competitor vehicle in the market: active (currently available), discontinued (no longer produced), upcoming (announced but not yet available), or rumored (unconfirmed future model).' ;
    rdfs:domain ind:CompetitorVehicle ;
