    rdfs:range xsd:date .

ind:demoStatus rdf:type rdf:Property ;
    rdfs:label 'Demo Status' ;
    rdfs:comment 'Current lifecycle status of the demo vehicle program assignment.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoUsageType rdf:type rdf:Property ;
    rdfs:label 'Demo Usage Type' ;
    rdfs:comment 'Primary usage type for this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPlanInterestAmount rdf:type rdf:Property ;
