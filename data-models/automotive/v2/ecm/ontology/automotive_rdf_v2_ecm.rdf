ind:oeePerformancePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percentage' ;
    rdfs:comment 'Performance portion of OEE, measuring actual production speed against ideal speed.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percentage' ;
    rdfs:comment 'Quality portion of OEE, representing good units produced versus total units processed.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
