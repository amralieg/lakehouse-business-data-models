    rdfs:comment 'Primary channels used to deliver the campaign messaging.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the campaign used in reporting and UI.' ;
