    rdfs:range ind:ExtendedWarrantyProvider .

ind:cancellationRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Cancellation Refund Amount' ;
    rdfs:comment 'Pro-rated refund amount due to the customer upon contract cancellation, calculated per the provider\'s cancellation schedule.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimSubmissionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Deadline Days' ;
    rdfs:comment 'Maximum number of days after a covered repair is completed within which the repair facility must submit a claim to the warranty provider.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsPaidToDate rdf:type rdf:Property ;
    rdfs:label 'Claims Paid To Date' ;
    rdfs:comment 'Cumulative amount paid by the warranty provider against this contract to date, used to track remaining coverage capacity against the maximum claim limit.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractPrice rdf:type rdf:Property ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'Gross retail price charged to the customer for the warranty contract, expressed in the contract currency.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageMileageLimitKm rdf:type rdf:Property ;
    rdfs:label 'Coverage Mileage Limit Km' ;
    rdfs:comment 'Maximum odometer reading in kilometres up to which the warranty contract provides coverage. Claims submitted when odometer exceeds this value are rejected.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageTermMonths rdf:type rdf:Property ;
    rdfs:label 'Coverage Term Months' ;
    rdfs:comment 'Duration of the warranty contract coverage expressed in calendar months from the effective date.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerCost rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost' ;
    rdfs:comment 'Net cost paid by the dealership to the third-party warranty provider for the contract, used for dealer profitability and F&I (Finance and Insurance) reporting.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleType rdf:type rdf:Property ;
    rdfs:label 'Deductible Type' ;
    rdfs:comment 'Specifies how the deductible is applied: per repair visit, per failed component, disappearing (reduces over time), or no deductible.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeContractNumber rdf:type rdf:Property ;
    rdfs:label 'Finance Contract Number' ;
    rdfs:comment 'Reference to the vehicle finance/loan contract number when the warranty was financed as part of the vehicle purchase agreement.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumClaimLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Claim Limit' ;
    rdfs:comment 'Aggregate maximum monetary amount the warranty provider will pay across all claims for the life of this contract.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerAtSaleKm rdf:type rdf:Property ;
    rdfs:label 'Odometer At Sale Km' ;
    rdfs:comment 'Vehicle odometer reading in kilometres recorded at the time the warranty contract was sold, establishing the baseline for mileage-based coverage limits.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsCoverageType rdf:type rdf:Property ;
    rdfs:label 'Parts Coverage Type' ;
    rdfs:comment 'Specifies whether covered repairs must use OEM (Original Equipment Manufacturer) parts, or whether aftermarket parts are permitted.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerContractReference rdf:type rdf:Property ;
    rdfs:label 'Provider Contract Reference' ;
    rdfs:comment 'The warranty provider\'s own internal reference number for this contract, used for claims submission and reconciliation with the provider\'s system.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalReimbursementDailyLimit rdf:type rdf:Property ;
    rdfs:label 'Rental Reimbursement Daily Limit' ;
    rdfs:comment 'Maximum daily rental reimbursement amount payable under this contract. Null when rental reimbursement is not included.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalReimbursementIncluded rdf:type rdf:Property ;
    rdfs:label 'Rental Reimbursement Included' ;
    rdfs:comment 'Indicates whether rental car reimbursement during covered repairs is included in this warranty contract.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairFacilityRestriction rdf:type rdf:Property ;
    rdfs:label 'Repair Facility Restriction' ;
    rdfs:comment 'Specifies which repair facilities are authorized to perform covered repairs: any licensed facility, the provider\'s authorized network, or the selling dealer only.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadsideAssistanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Roadside Assistance Included' ;
    rdfs:comment 'Indicates whether 24/7 roadside assistance (towing, lockout, fuel delivery) is bundled within this warranty contract.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellingFiManagerName rdf:type rdf:Property ;
    rdfs:label 'Selling Fi Manager Name' ;
    rdfs:comment 'Name of the Finance and Insurance (F&I) manager at the dealership who sold this warranty contract, used for commission tracking and compliance audits.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Source Contract Number' ;
    rdfs:comment 'Native primary key of this warranty contract record in the originating DMS source system, used for lineage tracing and reconciliation.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleMake rdf:type rdf:Property ;
    rdfs:label 'Vehicle Make' ;
    rdfs:comment 'Manufacturer brand of the covered vehicle (e.g., Toyota, Ford, BMW), stored for claims eligibility checks and provider reporting.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of calendar days after the effective date during which claims are not eligible, as specified by the warranty provider to prevent pre-existing condition claims.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitingPeriodMileageKm rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Mileage Km' ;
    rdfs:comment 'Minimum additional kilometres the vehicle must be driven after contract sale before claims are eligible, complementing the day-based waiting period.' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentProviderId rdf:type rdf:Property ;
    rdfs:label 'Parent Provider Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent provider record for providers that are subsidiaries or regional entities of a larger warranty group. Enables hierarchical provider reporting and consolidated claims analysis.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExtendedWarrantyProvider .

ind:adasCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Adas Coverage Flag' ;
    rdfs:comment 'Indicates whether the provider\'s extended warranty products include coverage for Advanced Driver Assistance Systems (ADAS) components such as radar, lidar, cameras, and control modules.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationRefundPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Refund Policy' ;
    rdfs:comment 'Policy governing refund of extended warranty premiums upon early cancellation: pro_rata (refund proportional to unused term), flat_fee (fixed cancellation charge deducted), non_refundable, or tiered (schedule-based). Drives customer refund calculations.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsAuthorisationLimit rdf:type rdf:Property ;
    rdfs:label 'Claims Authorisation Limit' ;
    rdfs:comment 'Maximum monetary value (in contract currency) of a single warranty claim that the provider can authorise without requiring OEM or reinsurer pre-approval. Drives claims routing and escalation logic in the DMS.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claims Contact Email' ;
    rdfs:comment 'Dedicated email address for the provider\'s claims processing department. Used by dealers and service centres to submit warranty claims, request authorisations, and receive claim status updates.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claims Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which claims are settled and financial limits are denominated for this provider (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Claims Portal Url' ;
    rdfs:comment 'Web address of the provider\'s online claims submission and management portal. Integrated with dealer management systems (DMS) for electronic claims lodgement and real-time authorisation.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which the provider is legally incorporated. Determines applicable contract law, regulatory framework, and tax treaty treatment.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCategories rdf:type rdf:Property ;
    rdfs:label 'Coverage Categories' ;
    rdfs:comment 'Comma-separated list of vehicle system categories covered under extended warranty products offered by this provider (e.g., powertrain, electrical, infotainment, ADAS, EV_battery). Defines the scope of coverage available for product configuration.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement (DSA) is in place between the OEM and the extended warranty provider governing the exchange of vehicle telematics, claims, and customer data. Required for GDPR-compliant data processing.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Dealer Commission Rate' ;
    rdfs:comment 'Standard commission rate (expressed as a decimal fraction, e.g., 0.15 = 15%) paid to the selling dealer upon issuance of an extended warranty contract under this provider. Subject to individual dealer agreements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving claims disputes between the OEM/dealer and the extended warranty provider: arbitration, mediation, litigation, or referral to an industry ombudsman.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Ev Coverage Flag' ;
    rdfs:comment 'Indicates whether the provider offers extended warranty products specifically covering electric vehicle (EV) high-voltage battery systems and EV-specific components. True = EV coverage available; False = ICE/HEV only.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialRating rdf:type rdf:Property ;
    rdfs:label 'Financial Rating' ;
    rdfs:comment 'Credit or financial strength rating assigned by a recognised rating agency (e.g., AM Best, S&P, Moody\'s) to the provider or its underwriter. Used to assess counterparty risk and compliance with OEM supplier financial standards.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDpaReference rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Reference' ;
    rdfs:comment 'Reference number or identifier of the GDPR-compliant Data Processing Agreement (DPA) executed with this provider. Required where the provider processes personal data on behalf of the OEM as a data processor.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the master provider agreement and any disputes arising from it.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceLicenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Licence Expiry Date' ;
    rdfs:comment 'Date on which the provider\'s insurance or warranty administration licence expires. Triggers renewal workflow and suspension of new contract issuance if not renewed before this date.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Licence Number' ;
    rdfs:comment 'Regulatory licence or authorisation number issued by the financial services regulator (e.g., FCA, BaFin, NAIC) permitting the provider to underwrite or administer extended warranty / mechanical breakdown insurance products.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character ISO 17442 Legal Entity Identifier assigned by a GLEIF-accredited Local Operating Unit. Mandatory for financial regulatory reporting and cross-border contract compliance in applicable jurisdictions.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCoverageDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Max Coverage Duration Months' ;
    rdfs:comment 'Maximum number of months of extended warranty coverage that this provider can offer on a single contract, measured from the original vehicle in-service date. Used to validate warranty product configuration.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverageMileageKm rdf:type rdf:Property ;
    rdfs:label 'Max Coverage Mileage Km' ;
    rdfs:comment 'Maximum odometer reading in kilometres up to which extended warranty coverage is valid under contracts issued by this provider. Contracts expire at the earlier of duration or mileage limit.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingCountries rdf:type rdf:Property ;
    rdfs:label 'Operating Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes in which the provider is authorised to offer extended warranty products. Used to validate market eligibility when issuing new warranty contracts.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredProviderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Flag' ;
    rdfs:comment 'Indicates whether this provider has been designated as a preferred or recommended extended warranty partner by the OEM. Preferred providers may receive priority placement in dealer sales tools and incentive programmes.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Externally-known alphanumeric business code uniquely identifying the extended warranty provider across systems (e.g., SAP vendor code, DMS provider code). Used as the operational cross-system reference key.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerShortName rdf:type rdf:Property ;
    rdfs:label 'Provider Short Name' ;
    rdfs:comment 'Abbreviated or trading name of the provider used in UI displays, reports, and dealer-facing communications where the full legal name is impractical.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerStatus rdf:type rdf:Property ;
    rdfs:label 'Provider Status' ;
    rdfs:comment 'Current lifecycle status of the provider relationship. Controls whether new extended warranty contracts can be issued under this provider. Active = eligible for new business; Suspended = under review; Terminated = no new or renewal contracts permitted.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAgency rdf:type rdf:Property ;
    rdfs:label 'Rating Agency' ;
    rdfs:comment 'Name of the credit or financial strength rating agency that issued the financial_rating for this provider. [ENUM-REF-CANDIDATE: AM_Best|SP_Global|Moodys|Fitch|DBRS|internal — promote to reference product if additional agencies are required]' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCity rdf:type rdf:Property ;
    rdfs:label 'Registered Address City' ;
    rdfs:comment 'City or municipality of the provider\'s registered legal address. Used for regulatory jurisdiction determination and contract documentation.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the provider\'s registered legal address. Determines applicable legal jurisdiction for contract disputes and regulatory oversight.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the provider\'s registered legal address (street number and name). Required for contract documentation, regulatory filings, and legal correspondence.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the provider\'s registered legal address. Used for geographic routing, tax jurisdiction assignment, and regulatory reporting.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementModel rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Model' ;
    rdfs:comment 'Financial settlement model used for warranty claims: direct_pay (provider pays dealer directly), reimbursement (dealer pays then claims back), pooled_fund (OEM-managed reserve), or captive_reserve (self-insured OEM fund). Determines cash flow and accounting treatment.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadsideAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Roadside Assistance Flag' ;
    rdfs:comment 'Indicates whether roadside assistance (breakdown recovery, towing, emergency fuel) is bundled with the extended warranty products offered by this provider.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:solvencyRatioPercent rdf:type rdf:Property ;
    rdfs:label 'Solvency Ratio Percent' ;
    rdfs:comment 'Provider\'s solvency capital ratio expressed as a percentage, as reported under Solvency II or equivalent regulatory framework. Monitored to ensure the provider maintains adequate reserves to honour future claims.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Transferability Flag' ;
    rdfs:comment 'Indicates whether extended warranty contracts issued by this provider can be transferred to a subsequent vehicle owner upon private sale. True = transferable; False = non-transferable. Impacts used-vehicle residual value.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwriterName rdf:type rdf:Property ;
    rdfs:label 'Underwriter Name' ;
    rdfs:comment 'Name of the insurance underwriter or reinsurer that carries the financial risk for extended warranty claims administered by this provider. Relevant where the provider acts as administrator rather than risk carrier.' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSampleId rdf:type rdf:Property ;
    rdfs:label 'Test Sample Id' ;
    rdfs:comment 'Primary key for test_sample' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppapSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Id' ;
    rdfs:comment 'Reference to the PPAP submission for which this sample serves as evidence. Connects sample-level test data to the formal supplier approval process.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityPpapSubmission .

ind:testProgramId rdf:type rdf:Property ;
    rdfs:label 'Test Program Id' ;
    rdfs:comment 'Reference to the engineering test program or validation plan under which this sample is being evaluated. Links the sample to the broader test execution context.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleProgram .

ind:accreditationStandard rdf:type rdf:Property ;
    rdfs:label 'Accreditation Standard' ;
    rdfs:comment 'Accreditation standard under which the test facility is certified to perform tests on this sample (e.g., \'ISO/IEC 17025:2017\', \'A2LA\'). Required for regulatory submissions and customer-approved source testing.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adasRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Adas Related Flag' ;
    rdfs:comment 'Indicates whether this test sample is associated with an ADAS feature (e.g., radar sensor, camera module, LiDAR unit), triggering additional ISO 21448 SOTIF and ISO 26262 validation requirements.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyReference rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Reference' ;
    rdfs:comment 'Unique identifier for the chain-of-custody record tracking the sample\'s handling history from production through testing and final disposition. Required for legal and regulatory submissions.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Condition On Receipt' ;
    rdfs:comment 'Assessment of the sample\'s physical condition at the time of receipt at the test facility. Non-conforming or damaged samples are quarantined pending disposition decision.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Destruction Required Flag' ;
    rdfs:comment 'Indicates whether the sample must be destroyed as part of the test protocol (e.g., crash test, burst pressure test, fatigue-to-failure). Drives sample quantity planning and disposal procedures.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'UN hazardous material classification code if the sample contains regulated substances (e.g., lithium battery cells, fuel, refrigerants). Governs packaging, labeling, and transport requirements.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Homologation Required Flag' ;
    rdfs:comment 'Indicates whether test results from this sample are required as evidence for vehicle type approval or component homologation submissions to a regulatory authority.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the sample, required for import/export customs declarations when samples are shipped across international borders.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Plant Code' ;
    rdfs:comment 'Code identifying the manufacturing plant or facility where the test sample was produced. Used to correlate test results with production location for quality and process capability analysis.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecification rdf:type rdf:Property ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Material specification or grade code (e.g., \'SAE 1045\', \'AA6061-T6\', \'PA66-GF30\') defining the raw material composition of the test sample, used for material traceability and failure analysis.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Number' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) raised if the sample was found to be non-conforming on receipt or during testing. Links to the quality corrective action process.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Engineering department or cost center that owns and is accountable for this test sample (e.g., \'Chassis Engineering\', \'Powertrain NVH\', \'Body Structures\'). Used for resource allocation and cost tracking.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSvhcFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Flag' ;
    rdfs:comment 'Indicates whether the sample contains any Substance of Very High Concern (SVHC) as defined under EU REACH Regulation (EC) No 1907/2006. Triggers mandatory disclosure and potential substitution requirements.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name or employee ID of the lead engineer responsible for this test sample and its associated test activities. Used for accountability, escalation, and PLM workflow routing.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this sample is classified as a safety-critical component (e.g., braking, steering, airbag, fuel system) requiring enhanced traceability, witness testing, and regulatory sign-off.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the physical or virtual test sample, used in PLM systems such as Siemens Teamcenter and ENOVIA for traceability across engineering programs.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleName rdf:type rdf:Property ;
    rdfs:label 'Sample Name' ;
    rdfs:comment 'Human-readable descriptive name of the test sample, typically reflecting the component, assembly, or system under evaluation (e.g., \'Front Suspension Knuckle – Prototype A\').' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the test sample, tracking its progression from initial request through preparation, active testing, hold, completion, and final disposition or archival. [ENUM-REF-CANDIDATE: requested|prepared|in-test|on-hold|completed|disposed|archived — promote to reference product]' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample by its engineering maturity stage. Prototype samples are early-stage; production-intent samples mirror final manufacturing intent; reference samples are retained as benchmarks. [ENUM-REF-CANDIDATE: prototype|pre-production|production-intent|validation|reference|destructive — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'Primary engineering test discipline category applied to this sample. Drives test method selection, equipment requirements, and specialist assignment. [ENUM-REF-CANDIDATE: mechanical|thermal|NVH|EMC|corrosion|fatigue|chemical|dimensional|functional — promote to reference product]' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Test Facility Code' ;
    rdfs:comment 'Code identifying the internal or external test facility (laboratory, proving ground, or test rig) where the sample is being or will be tested. Supports capacity planning and accreditation tracking.' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPhase rdf:type rdf:Property ;
    rdfs:label 'Test Phase' ;
    rdfs:comment 'Engineering development phase during which this sample is being tested, aligned with the APQP (Advanced Product Quality Planning) gate structure. [ENUM-REF-CANDIDATE: concept|feasibility|design-validation|process-validation|production-validation|PPAP — promote to reference product]' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adasValidationCapable rdf:type rdf:Property ;
    rdfs:label 'Adas Validation Capable' ;
    rdfs:comment 'Indicates whether the test bench is configured to support Advanced Driver Assistance Systems (ADAS) validation, including sensor fusion, camera, radar, and LiDAR signal injection.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Hours' ;
    rdfs:comment 'Total planned available hours per year for the test bench after accounting for scheduled maintenance, calibration, and planned downtime. Used for capacity planning and program scheduling.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchCode rdf:type rdf:Property ;
    rdfs:label 'Bench Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the test bench within the engineering facility. Used in PLM systems (Siemens Teamcenter, ENOVIA) and test management systems to reference the physical or virtual bench.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchName rdf:type rdf:Property ;
    rdfs:label 'Bench Name' ;
    rdfs:comment 'Human-readable descriptive name of the test bench (e.g., \'NVH Chassis Dyno Bay 3\', \'Powertrain HIL Bench 12\'). Used in engineering reports and scheduling systems.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchStatus rdf:type rdf:Property ;
    rdfs:label 'Bench Status' ;
    rdfs:comment 'Current operational status of the test bench indicating whether it is available for scheduling, actively in use, undergoing maintenance or calibration, reserved for a specific program, or decommissioned.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchType rdf:type rdf:Property ;
    rdfs:label 'Bench Type' ;
    rdfs:comment 'Classification of the test bench by its primary testing capability. Examples include engine dynamometer, chassis dynamometer, Hardware-in-the-Loop (HIL), Software-in-the-Loop (SIL), NVH, EMI/EMC, climatic chamber, fatigue rig, crash sled, or endurance bench. [ENUM-REF-CANDIDATE: engine_dyno|chassis_dyno|hil|sil|mil|nvh|emi_emc|climatic|fatigue|crash|endurance|calibration|other — promote to reference product]' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Identifier of the specific building or laboratory block within the facility where the test bench is physically located. Supports asset management and maintenance routing.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCount rdf:type rdf:Property ;
    rdfs:label 'Channel Count' ;
    rdfs:comment 'Total number of measurement channels (sensor inputs) available on the test bench data acquisition system. Determines the number of simultaneous parameters that can be monitored during a test run.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlSystemType rdf:type rdf:Property ;
    rdfs:label 'Control System Type' ;
    rdfs:comment 'Type or brand of the automation and control system used to operate the test bench (e.g., AVL PUMA Open, Horiba STARS, National Instruments VeriStand, dSPACE ControlDesk). Used for software compatibility and integration planning.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coolantFlowRateLpm rdf:type rdf:Property ;
    rdfs:label 'Coolant Flow Rate Lpm' ;
    rdfs:comment 'Required coolant water flow rate in litres per minute for the test bench cooling system. Used for facility water usage tracking and ESG sustainability reporting.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataAcquisitionSystem rdf:type rdf:Property ;
    rdfs:label 'Data Acquisition System' ;
    rdfs:comment 'Name or type of the data acquisition system (DAS) integrated with the test bench for capturing measurement signals (e.g., HBK QuantumX, National Instruments cDAQ, AVL IndiCom). Relevant for data lineage and IoT sensor data flows.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsMeasurementCapable rdf:type rdf:Property ;
    rdfs:label 'Emissions Measurement Capable' ;
    rdfs:comment 'Indicates whether the test bench is equipped with a certified exhaust emissions measurement system (e.g., CVS dilution tunnel, FTIR analyser) for regulatory homologation testing.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityLocation rdf:type rdf:Property ;
    rdfs:label 'Facility Location' ;
    rdfs:comment 'Physical location or site where the test bench is installed (e.g., plant name, building, bay number). Used for resource scheduling and logistics planning.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hilCapable rdf:type rdf:Property ;
    rdfs:label 'Hil Capable' ;
    rdfs:comment 'Indicates whether the test bench supports Hardware-in-the-Loop (HIL) simulation, enabling ECU and embedded software validation against real-time vehicle models without a physical vehicle.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Iso Accreditation Number' ;
    rdfs:comment 'Accreditation number issued by the national accreditation body (e.g., DAkkS, UKAS, A2LA) confirming the test bench meets ISO 17025 requirements for measurement traceability. Required for regulatory homologation test results.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Max Speed Rpm' ;
    rdfs:comment 'Maximum rotational speed in revolutions per minute (RPM) that the test bench can accommodate. Constrains the test profiles and engine/motor configurations that can be tested.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkSegment rdf:type rdf:Property ;
    rdfs:label 'Network Segment' ;
    rdfs:comment 'IT/OT network segment or VLAN to which the test bench data acquisition and control systems are connected. Used for cybersecurity zoning and IoT edge computing data flow management.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next planned preventive maintenance activity on the test bench. Supports maintenance planning and minimizes unplanned downtime.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plmAssetCode rdf:type rdf:Property ;
    rdfs:label 'Plm Asset Code' ;
    rdfs:comment 'Identifier of the test bench record in the PLM system (e.g., Siemens Teamcenter, ENOVIA, PTC Windchill). Enables traceability between the physical asset and its digital representation in the product lifecycle management system.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Kw' ;
    rdfs:comment 'Rated electrical power consumption of the test bench in kilowatts under typical operating conditions. Used for energy management, ESG CO2 tracking, and facility capacity planning.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Automotive Safety Integrity Level (ASIL) classification of the test bench environment per ISO 26262, indicating the functional safety requirements applicable to tests conducted on this bench.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingRateHz rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate Hz' ;
    rdfs:comment 'Maximum data acquisition sampling rate in Hertz (samples per second) supported by the test bench instrumentation. Determines the resolution of time-series test data captured.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedFuelTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Fuel Types' ;
    rdfs:comment 'Comma-separated list of fuel or energy types the test bench is configured to support (e.g., gasoline, diesel, hydrogen, CNG, LPG, BEV/electric). Determines which powertrain programs can use this bench.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum ambient or controlled temperature in degrees Celsius that the test bench environment can achieve. Used to validate thermal performance and high-temperature durability.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum ambient or controlled temperature in degrees Celsius that the test bench environment can achieve. Relevant for climatic chambers and cold-start validation tests.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Pct' ;
    rdfs:comment 'Target utilization rate of the test bench expressed as a percentage of available capacity. Used as a KPI benchmark for engineering resource management.' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost' ;
    rdfs:comment 'Total annualized cost of maintaining the patent family across all active jurisdictions, including renewal fees, annuities, and agent fees. Used for IP portfolio cost management and ROI analysis.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookValue rdf:type rdf:Property ;
    rdfs:label 'Book Value' ;
    rdfs:comment 'Capitalized intangible asset value of the patent family as recorded on the balance sheet, net of accumulated amortization. Relevant for IFRS 38 intangible asset reporting.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:citationCountBackward rdf:type rdf:Property ;
    rdfs:label 'Citation Count Backward' ;
    rdfs:comment 'Number of prior art references cited by the patent family\'s applications (backward citations). Indicates the depth of prior art search and the novelty positioning of the invention.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:citationCountForward rdf:type rdf:Property ;
    rdfs:label 'Citation Count Forward' ;
    rdfs:comment 'Number of times patents in this family have been cited by subsequent patent applications (forward citations). A key indicator of the patent family\'s technological influence and value.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cnApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Cn Application Number' ;
    rdfs:comment 'Application number assigned by the China National Intellectual Property Administration (CNIPA) for the Chinese national phase or direct Chinese application within this family. China is a critical automotive market jurisdiction.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Cpc Classification Code' ;
    rdfs:comment 'Primary Cooperative Patent Classification code assigned by the USPTO or EPO, providing finer-grained technology categorization than IPC. Used for competitive landscape analysis and freedom-to-operate assessments.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeProsecutionCost rdf:type rdf:Property ;
    rdfs:label 'Cumulative Prosecution Cost' ;
    rdfs:comment 'Total accumulated cost of prosecuting the patent family from initial filing through current status, including attorney fees, filing fees, translation costs, and examination fees across all jurisdictions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'De Application Number' ;
    rdfs:comment 'Application number assigned by the German Patent and Trade Mark Office (DPMA) for the German national application within this family. Germany is the primary automotive manufacturing jurisdiction in Europe.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earliestFilingDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Filing Date' ;
    rdfs:comment 'The actual calendar date on which the first application in the family was filed with a patent office. May coincide with or differ from the priority date when provisional applications are involved.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestGrantDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Grant Date' ;
    rdfs:comment 'Date on which the first granted patent within the family was issued by a patent office. Marks the start of enforceable IP rights for the family.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earliestPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Earliest Publication Date' ;
    rdfs:comment 'Date on which the earliest member of the patent family was first published by a patent office, making the invention publicly disclosed. Relevant for prior-art and freedom-to-operate analyses.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecnReference rdf:type rdf:Property ;
    rdfs:label 'Ecn Reference' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that triggered or is associated with this patent family, linking IP protection to specific design changes.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Ep Application Number' ;
    rdfs:comment 'Application number assigned by the European Patent Office (EPO) for the European regional phase application within this family. Used for tracking EPO prosecution and validation in EPC member states.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Expiry Date' ;
    rdfs:comment 'Projected date on which the last surviving granted patent in the family will expire, calculated as 20 years from the earliest filing date (utility) or 15 years from grant (design), subject to patent term extensions. Used for IP portfolio lifecycle planning.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCounselFirm rdf:type rdf:Property ;
    rdfs:label 'External Counsel Firm' ;
    rdfs:comment 'Name of the external law firm or patent attorney firm responsible for prosecuting and maintaining this patent family. Used for outside counsel management and cost allocation.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyNumber rdf:type rdf:Property ;
    rdfs:label 'Family Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the patent family by the IP management system or patent office (e.g., INPADOC family number). Used for cross-referencing across jurisdictions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current lifecycle status of the patent family reflecting the overall prosecution and enforcement state across all member applications.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyTitle rdf:type rdf:Property ;
    rdfs:label 'Family Title' ;
    rdfs:comment 'Official title of the invention as filed, representing the primary human-readable label for the patent family. Typically derived from the earliest priority application.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'Classification of the patent family by the nature of the intellectual property protection sought. Utility covers functional inventions; design covers ornamental aspects; plant covers new plant varieties; utility_model covers petty patents in applicable jurisdictions; divisional covers child applications split from a parent.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frandDeclaredFlag rdf:type rdf:Property ;
    rdfs:label 'Frand Declared Flag' ;
    rdfs:comment 'Indicates whether a FRAND licensing commitment has been formally declared to a standards body for this patent family. Triggers specific licensing obligations and royalty rate constraints.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freedomToOperateStatus rdf:type rdf:Property ;
    rdfs:label 'Freedom To Operate Status' ;
    rdfs:comment 'Result of the most recent Freedom-to-Operate (FTO) analysis for the technology covered by this patent family, indicating whether the company can commercialize the invention without infringing third-party rights.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftoAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Fto Assessment Date' ;
    rdfs:comment 'Date on which the most recent Freedom-to-Operate assessment was completed. Used to determine whether the FTO analysis is current and requires refresh.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentClaimCount rdf:type rdf:Property ;
    rdfs:label 'Independent Claim Count' ;
    rdfs:comment 'Number of independent claims in the lead application, each defining a distinct scope of protection. Independent claims are the primary measure of patent breadth.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalIpCounselName rdf:type rdf:Property ;
    rdfs:label 'Internal Ip Counsel Name' ;
    rdfs:comment 'Full name of the internal IP attorney or patent engineer responsible for managing this patent family. Used for workload management and accountability tracking.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDisclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Invention Disclosure Number' ;
    rdfs:comment 'Internal reference number of the Invention Disclosure Record (IDR) submitted by the inventor(s) to the IP department, linking the patent family back to the original R&D disclosure. Enables traceability from invention to granted patent.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventorCount rdf:type rdf:Property ;
    rdfs:label 'Inventor Count' ;
    rdfs:comment 'Total number of named inventors across all applications in the patent family. Used for inventor recognition reporting and royalty distribution calculations.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipOwnerLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Ip Owner Legal Entity' ;
    rdfs:comment 'Legal name of the corporate entity that holds title to the patent family (assignee of record). May differ from the operating business unit when IP is held by a holding company or subsidiary.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipcClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Ipc Classification Code' ;
    rdfs:comment 'Primary International Patent Classification code assigned to the invention, structured per WIPO IPC hierarchy (Section/Class/Subclass/Group/Subgroup). Enables cross-jurisdictional technology benchmarking and prior-art searches.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jpApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Jp Application Number' ;
    rdfs:comment 'Application number assigned by the Japan Patent Office (JPO) for the Japanese national phase or direct Japanese application within this family.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCount rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Count' ;
    rdfs:comment 'Number of distinct national or regional jurisdictions in which patent protection has been sought or granted for this family. Indicates the geographic breadth of IP coverage.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadInventorName rdf:type rdf:Property ;
    rdfs:label 'Lead Inventor Name' ;
    rdfs:comment 'Full name of the primary inventor listed on the patent family\'s priority application. Used for inventor recognition programs, royalty sharing, and legal correspondence.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRevenueYtd rdf:type rdf:Property ;
    rdfs:label 'Licensing Revenue Ytd' ;
    rdfs:comment 'Cumulative licensing revenue received for this patent family in the current fiscal year, expressed in the reporting currency. Used for IP monetization performance tracking.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:litigationCaseReference rdf:type rdf:Property ;
    rdfs:label 'Litigation Case Reference' ;
    rdfs:comment 'Internal or court-assigned case reference number for active litigation involving this patent family. Populated only when litigation_flag is TRUE. Used for legal matter management and e-discovery.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether the patent family is currently involved in active litigation, including infringement suits, inter partes review (IPR), opposition proceedings, or invalidity challenges.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Name of the internal business unit or R&D division that owns the patent family and is responsible for its prosecution costs and commercialization strategy (e.g., Powertrain Engineering, ADAS Systems, Vehicle Safety).' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentPortfolioCategory rdf:type rdf:Property ;
    rdfs:label 'Patent Portfolio Category' ;
    rdfs:comment 'Strategic classification of the patent family within the company\'s IP portfolio. Core patents protect key product differentiators; standard_essential patents (SEPs) are essential to industry standards (e.g., V2X, LTE-V); defensive patents deter litigation; blocking patents prevent competitor entry; licensing and cross_license patents are managed for revenue or reciprocal access.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pctApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Pct Application Number' ;
    rdfs:comment 'Application number assigned under the WIPO Patent Cooperation Treaty (PCT) international phase, if the family includes a PCT filing. Enables tracking of the international phase prosecution and national phase entries.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plmDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Plm Document Code' ;
    rdfs:comment 'Reference identifier linking this patent family to the corresponding technical disclosure or design document in the PLM system (e.g., Siemens Teamcenter, ENOVIA, PTC Windchill). Enables traceability between IP assets and engineering design artifacts.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Priority Application Number' ;
    rdfs:comment 'Application number of the earliest priority filing (the root application) from which the family\'s priority date is derived. Establishes the legal priority date under the Paris Convention.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Product Relevance Flag' ;
    rdfs:comment 'Indicates whether the patent family is currently embodied in or relevant to a production vehicle or component. Distinguishes patents protecting current products from purely defensive or future-oriented filings.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prosecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Prosecution Status' ;
    rdfs:comment 'Detailed current stage in the patent prosecution workflow for the lead application in the family. Tracks progress through examination, allowance, grant, and post-grant proceedings.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardEssentialFlag rdf:type rdf:Property ;
    rdfs:label 'Standard Essential Flag' ;
    rdfs:comment 'Indicates whether the patent family has been declared as potentially essential to an industry standard (e.g., ISO 26262, SAE J3016, 3GPP V2X, IEEE 802.11p). SEPs carry FRAND licensing obligations.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicImportanceRating rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Rating' ;
    rdfs:comment 'Internal rating of the patent family\'s strategic importance to the company\'s product roadmap and competitive position. Used to prioritize prosecution investment and maintenance decisions.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyDomain rdf:type rdf:Property ;
    rdfs:label 'Technology Domain' ;
    rdfs:comment 'High-level technology area to which the invention belongs (e.g., powertrain, ADAS, battery management, chassis, infotainment, connectivity). Used for portfolio analytics and R&D investment reporting. [ENUM-REF-CANDIDATE: powertrain|adas|battery_management|chassis|infotainment|connectivity|body_electronics|safety_systems|manufacturing_process|software — promote to reference product]' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Us Application Number' ;
    rdfs:comment 'Application number assigned by the United States Patent and Trademark Office (USPTO) for the US national phase or direct US application within this family.' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLicenseCost rdf:type rdf:Property ;
    rdfs:label 'Annual License Cost' ;
    rdfs:comment 'Annual software licensing cost paid to the platform provider for this portal instance, in the default currency.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSpendLimit rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Limit' ;
    rdfs:comment 'Maximum total annual procurement spend authorized to be processed through this portal instance, used for budget governance.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL of the portal\'s REST or SOAP API endpoint used for system-to-system integration with SAP MM, ERP, and supplier systems.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auction Enabled Flag' ;
    rdfs:comment 'Indicates whether the portal supports reverse auction (e-auction) sourcing events for competitive bidding among suppliers.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Catalog Enabled Flag' ;
    rdfs:comment 'Indicates whether the portal supports hosted or punchout supplier catalogs for standardized item ordering.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Management Flag' ;
    rdfs:comment 'Indicates whether the portal includes contract lifecycle management (CLM) capabilities for supplier agreements and supply contracts.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCodesInScope rdf:type rdf:Property ;
    rdfs:label 'Country Codes In Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the countries where this portal is operationally active.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEncryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Data Encryption Standard' ;
    rdfs:comment 'Encryption standard applied to data in transit and at rest within the portal (e.g., AES-256, TLS 1.3).' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Planned or actual date on which the portal was or will be decommissioned and taken out of service.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used as the default transaction currency for this portal instance.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Default Language Code' ;
    rdfs:comment 'ISO 639-1 language code for the default user interface language of the portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentModel rdf:type rdf:Property ;
    rdfs:label 'Deployment Model' ;
    rdfs:comment 'Infrastructure deployment model for the portal: cloud SaaS, on-premise, hybrid, or private cloud.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'Identifier of the ERP system instance (e.g., SAP MM client/system ID) to which this portal is integrated for purchase order and goods receipt processing.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the portal has been assessed and confirmed as compliant with GDPR requirements for personal data processing.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date on which the eProcurement portal was first made available to end users in production.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:integrationStandard rdf:type rdf:Property ;
    rdfs:label 'Integration Standard' ;
    rdfs:comment 'Electronic data interchange or integration protocol used to connect the portal with ERP and supplier systems (e.g., cXML for Ariba, EDI X12, EDIFACT, REST API).' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAutomationFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Automation Flag' ;
    rdfs:comment 'Indicates whether the portal supports automated invoice processing, including electronic invoice submission, three-way matching, and straight-through processing.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentUsers rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Users' ;
    rdfs:comment 'Maximum number of simultaneous user sessions the portal is licensed and configured to support.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPoValue rdf:type rdf:Property ;
    rdfs:label 'Max Po Value' ;
    rdfs:comment 'Maximum monetary value of a single purchase order that can be processed through this portal, enforced as a procurement control threshold.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mfaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mfa Required Flag' ;
    rdfs:comment 'Indicates whether multi-factor authentication is mandatory for all users accessing this portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Owning Company Code' ;
    rdfs:comment 'SAP company code or legal entity identifier of the automotive business unit that owns and operates this eProcurement portal instance.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformProvider rdf:type rdf:Property ;
    rdfs:label 'Platform Provider' ;
    rdfs:comment 'Name of the third-party software vendor or platform provider hosting the eProcurement portal (e.g., SAP Ariba, Coupa, Jaggaer, Oracle Procurement Cloud, Ivalua).' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Version' ;
    rdfs:comment 'Version or release number of the eProcurement platform software currently deployed for this portal instance.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poApprovalThreshold rdf:type rdf:Property ;
    rdfs:label 'Po Approval Threshold' ;
    rdfs:comment 'Monetary threshold above which purchase orders require additional approval workflow steps within the portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portalCode rdf:type rdf:Property ;
    rdfs:label 'Portal Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the eProcurement portal, used in cross-system references and integration mappings (e.g., SAP Ariba, Coupa, Jaggaer).' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalName rdf:type rdf:Property ;
    rdfs:label 'Portal Name' ;
    rdfs:comment 'Human-readable name of the eProcurement portal instance (e.g., \'Global Direct Materials Portal\', \'EMEA Indirect Procurement Hub\').' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Portal Owner Email' ;
    rdfs:comment 'Email address of the internal business owner responsible for this portal. Classified as PII per GDPR.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalOwnerName rdf:type rdf:Property ;
    rdfs:label 'Portal Owner Name' ;
    rdfs:comment 'Name of the internal business owner or procurement manager responsible for the governance and operation of this portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalStatus rdf:type rdf:Property ;
    rdfs:label 'Portal Status' ;
    rdfs:comment 'Current operational lifecycle status of the eProcurement portal instance.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalType rdf:type rdf:Property ;
    rdfs:label 'Portal Type' ;
    rdfs:comment 'Classification of the portal by procurement category scope: direct materials (production parts), indirect materials (MRO, office), CapEx, services, or marketplace. [ENUM-REF-CANDIDATE: direct_materials|indirect_materials|capex|services|mro|marketplace — promote to reference product]' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Primary web address (URL) through which suppliers and internal users access the eProcurement portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchoutEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Punchout Enabled Flag' ;
    rdfs:comment 'Indicates whether the portal supports cXML PunchOut integration, allowing buyers to access supplier web catalogs directly from within the procurement portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'SAP purchasing organization code responsible for procurement activities conducted through this portal, defining the legal and contractual framework for purchasing.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Registered Supplier Count' ;
    rdfs:comment 'Total number of supplier organizations currently registered and active on this eProcurement portal.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfxEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfx Enabled Flag' ;
    rdfs:comment 'Indicates whether the portal supports RFI (Request for Information), RFP (Request for Proposal), and RFQ (Request for Quotation) sourcing events.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Spend Category Scope' ;
    rdfs:comment 'Indicates whether the portal handles direct spend (production materials), indirect spend (MRO, services), or both categories.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Sso Enabled Flag' ;
    rdfs:comment 'Indicates whether the portal supports Single Sign-On (SSO) authentication integration with the enterprise identity provider (e.g., Azure AD, Okta).' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierOnboardingFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Onboarding Flag' ;
    rdfs:comment 'Indicates whether the portal includes supplier registration, qualification, and onboarding workflow capabilities.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierPortalAccessModel rdf:type rdf:Property ;
    rdfs:label 'Supplier Portal Access Model' ;
    rdfs:comment 'Access control model governing how suppliers can register and gain access to the portal: open self-registration, invitation-only, or pre-approved supplier list.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes supported by the portal for transaction processing (e.g., \'EUR,USD,GBP,CNY,JPY\').' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedLanguages rdf:type rdf:Property ;
    rdfs:label 'Supported Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes supported by the portal user interface (e.g., \'en,de,fr,zh,ja,ko\').' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the IT or technical administrator responsible for portal integration and system maintenance. Classified as PII per GDPR.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeSlaPercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Percent' ;
    rdfs:comment 'Contractually agreed minimum uptime percentage for the portal (e.g., 99.9 for 99.9% availability), as defined in the platform provider SLA.' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coApplicantPartyId rdf:type rdf:Property ;
    rdfs:label 'Co Applicant Party Id' ;
    rdfs:comment 'Reference to the secondary applicant (co-borrower or co-lessee) on the F&I application, if applicable. Nullable when no co-applicant is present.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:financeProductId rdf:type rdf:Property ;
    rdfs:label 'Finance Product Id' ;
    rdfs:comment 'Reference to the specific finance product (rate plan, lease program, or loan product) offered by the lender and selected for this application.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceProduct .

ind:lenderId rdf:type rdf:Property ;
    rdfs:label 'Lender Id' ;
    rdfs:comment 'Reference to the financial institution, captive finance company (e.g., OEM captive), or bank that is providing the financing for this application.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lender .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Reference to the vehicle sales order associated with this F&I application, linking the financing request to the specific vehicle purchase transaction.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOrder .

ind:adverseActionNoticeSent rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Notice Sent' ;
    rdfs:comment 'Indicates whether a mandatory adverse action notice has been sent to the applicant following a credit decline or counter-offer, as required by ECOA and FCRA regulations.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualIncome rdf:type rdf:Property ;
    rdfs:label 'Annual Income' ;
    rdfs:comment 'Self-declared or verified gross annual income of the primary applicant in the application currency, used as a key input for debt-to-income ratio calculation and credit decisioning.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicantDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Applicant Date Of Birth' ;
    rdfs:comment 'Date of birth of the primary applicant, used for identity verification and credit eligibility assessment. Subject to GDPR/CCPA data protection requirements.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicantFirstName rdf:type rdf:Property ;
    rdfs:label 'Applicant First Name' ;
    rdfs:comment 'Legal first (given) name of the primary applicant as provided on the F&I application. Subject to GDPR/CCPA data protection requirements.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantLastName rdf:type rdf:Property ;
    rdfs:label 'Applicant Last Name' ;
    rdfs:comment 'Legal last (family) name of the primary applicant as provided on the F&I application. Subject to GDPR/CCPA data protection requirements.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantNationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'Applicant National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number in the US, National Insurance Number in the UK) of the primary applicant, used for credit bureau inquiry and identity verification. Must be masked in non-production environments.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantPhone rdf:type rdf:Property ;
    rdfs:label 'Applicant Phone' ;
    rdfs:comment 'Primary contact phone number of the applicant for application follow-up and verification purposes. Subject to GDPR/CCPA data protection requirements.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to the F&I application at origination, used across dealer management systems (DMS), lender portals, and customer communications.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the financing structure being applied for: retail installment sale, operating lease, balloon payment plan, fleet financing, or commercial loan. [ENUM-REF-CANDIDATE: retail_finance|lease|balloon|fleet_finance|commercial_loan|hire_purchase — promote to reference product]' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyRate rdf:type rdf:Property ;
    rdfs:label 'Buy Rate' ;
    rdfs:comment 'The base interest rate at which the lender offers financing to the dealer (wholesale rate), before the dealer marks it up to the customer sell rate. Confidential commercial data.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionsText rdf:type rdf:Property ;
    rdfs:label 'Conditions Text' ;
    rdfs:comment 'Free-text description of conditions that must be satisfied for a conditionally approved application to proceed to funding (e.g., proof of income, additional down payment, co-signer requirement).' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditBureauSource rdf:type rdf:Property ;
    rdfs:label 'Credit Bureau Source' ;
    rdfs:comment 'Name of the credit reporting agency from which the credit score and credit report were obtained for this application.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Credit bureau score (e.g., FICO score or equivalent) of the primary applicant at the time of application, used as the primary quantitative input for credit decisioning and interest rate determination.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'Lender-assigned decision code indicating the specific reason for approval, conditional approval, or decline of the application (e.g., A01 for standard approval, D03 for insufficient income). Codes vary by lender.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the lender or captive finance company issued the credit decision (approval, conditional approval, or decline) on the application.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Standardized reason description for application decline as required by ECOA adverse action notice regulations (e.g., insufficient income, poor credit history, excessive obligations). Populated only when application_status is declined.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Name of the primary applicant\'s current employer, used for income verification and credit assessment purposes.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiProductPremium rdf:type rdf:Property ;
    rdfs:label 'Fi Product Premium' ;
    rdfs:comment 'Total premium or cost of ancillary F&I products (GAP, extended warranty, etc.) included in the financed amount, contributing to the total amount financed.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Funding Timestamp' ;
    rdfs:comment 'Date and time when the approved F&I application was funded by the lender, marking the point at which the financial contract is activated and proceeds are disbursed to the dealer.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Flag' ;
    rdfs:comment 'Indicates whether all mandatory regulatory disclosures (e.g., TILA Truth-in-Lending disclosure, EU Consumer Credit Directive pre-contractual information) have been provided to the applicant prior to contract signing.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Total amount of financing requested by the applicant, representing the principal loan or lease amount before lender adjustments.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Application reference number or identifier from the originating source system (DMS, lender portal, or Salesforce Automotive Cloud), used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Vehicle Selling Price' ;
    rdfs:comment 'Agreed final selling price of the vehicle being financed, as negotiated between the dealer and customer. May differ from MSRP due to dealer discounts or incentives.' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Approval Turnaround Hours' ;
    rdfs:comment 'Average or contractual credit decision turnaround time in hours from application submission to approval/decline. Used for dealer SLA management and lender performance benchmarking.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRateType rdf:type rdf:Property ;
    rdfs:label 'Base Rate Type' ;
    rdfs:comment 'Type of base interest rate structure used by the lender. Fixed rates are locked at origination; variable rates float with a benchmark index (SOFR, Prime). Impacts F&I deal structuring and incentive subvention calculations.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captiveOemCode rdf:type rdf:Property ;
    rdfs:label 'Captive Oem Code' ;
    rdfs:comment 'OEM brand code identifying the automotive manufacturer that owns or exclusively partners with this captive finance company (e.g., \'FORD\' for Ford Motor Credit, \'BMW\' for BMW Financial Services). Null for third-party lenders.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialFleetFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Fleet Flag' ;
    rdfs:comment 'Indicates whether the lender supports commercial fleet financing programs for corporate, government, or rental fleet customers. Fleet lenders typically offer volume-based rate structures.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditTierSupported rdf:type rdf:Property ;
    rdfs:label 'Credit Tier Supported' ;
    rdfs:comment 'Credit quality tier(s) that the lender is approved to finance. Prime lenders target high-credit-score buyers; subprime lenders specialize in challenged credit. Drives dealer routing logic for financing applications.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Indicates whether the lender has provided consent for data sharing with the OEM for analytics, incentive reconciliation, and portfolio performance reporting under the data sharing agreement.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Dealer Portal Url' ;
    rdfs:comment 'URL of the lender\'s dealer-facing portal for submitting financing applications, accessing rate sheets, and managing floorplan accounts. Integrated with DMS and Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerReserveCapPct rdf:type rdf:Property ;
    rdfs:label 'Dealer Reserve Cap Pct' ;
    rdfs:comment 'Maximum dealer reserve markup (in percentage points above buy rate) that the lender permits dealers to add to the customer\'s contract rate. Regulated by CFPB fair lending guidelines to prevent discriminatory pricing.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Ev Financing Flag' ;
    rdfs:comment 'Indicates whether the lender has specific EV financing programs, including battery residual value guarantees, federal tax credit assignment (IRA Section 30D), and EV-specific underwriting criteria.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Funding Turnaround Hours' ;
    rdfs:comment 'Average or contractual time in hours from contract submission to dealer funding (disbursement of loan proceeds to the dealer). Critical for dealer cash flow management.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the lender\'s registered headquarters street address, used for legal correspondence and regulatory filings.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City of the lender\'s registered headquarters, used for geographic segmentation of lender coverage and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the lender\'s registered headquarters location. May differ from country_code if the lender operates across multiple markets.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the lender\'s registered headquarters address.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or region of the lender\'s registered headquarters. Determines applicable state-level lending regulations (e.g., usury laws, dealer reserve caps).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Lease Financing Flag' ;
    rdfs:comment 'Indicates whether the lender offers vehicle lease financing products (closed-end or open-end leases). Lease-capable lenders support residual value programs and money factor pricing.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lenderCategory rdf:type rdf:Property ;
    rdfs:label 'Lender Category' ;
    rdfs:comment 'Business category of financing products offered by the lender. Retail lenders support consumer vehicle purchase loans; wholesale lenders support dealer floorplan financing; fleet lenders support commercial fleet accounts.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderShortName rdf:type rdf:Property ;
    rdfs:label 'Lender Short Name' ;
    rdfs:comment 'Abbreviated or trade name of the lender used in dealer portals, sales reporting dashboards, and Salesforce Automotive Cloud opportunity records.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderStatus rdf:type rdf:Property ;
    rdfs:label 'Lender Status' ;
    rdfs:comment 'Current lifecycle status of the lender relationship. Active lenders are eligible to receive financing applications from dealers. Suspended lenders are temporarily blocked pending compliance review.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderType rdf:type rdf:Property ;
    rdfs:label 'Lender Type' ;
    rdfs:comment 'Classification of the lender by institutional type. Captive lenders are OEM-owned finance arms (e.g., GMAC, BMW Financial Services); banks and credit unions are third-party. [ENUM-REF-CANDIDATE: captive|bank|credit_union|independent_finance|leasing_company|government — promote to reference product]' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Max Loan Amount' ;
    rdfs:comment 'Maximum vehicle financing loan amount (in lender\'s primary currency) that the lender will approve per transaction. Caps deal size for risk management purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoanToValuePct rdf:type rdf:Property ;
    rdfs:label 'Max Loan To Value Pct' ;
    rdfs:comment 'Maximum loan-to-value ratio (expressed as a percentage) the lender will finance relative to the vehicle\'s MSRP or appraised value. A value of 110.00 means the lender will finance up to 110% of vehicle value (including negative equity).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTermMonths rdf:type rdf:Property ;
    rdfs:label 'Max Term Months' ;
    rdfs:comment 'Maximum financing term in months that the lender offers for vehicle purchase loans (e.g., 84 months). Longer terms reduce monthly payments but increase total interest cost.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVehicleAgeYears rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Age Years' ;
    rdfs:comment 'Maximum age of the vehicle (in years from model year) that the lender will finance. Older vehicles typically carry higher default risk and are excluded by prime lenders.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVehicleMileage rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Mileage' ;
    rdfs:comment 'Maximum odometer reading (in miles or kilometers per lender\'s market standard) of a used vehicle that the lender will finance. High-mileage vehicles are excluded from many prime lending programs.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Min Loan Amount' ;
    rdfs:comment 'Minimum vehicle financing loan amount (in lender\'s primary currency) that the lender will approve. Used to filter lender eligibility during deal structuring in the F&I (Finance and Insurance) office.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTermMonths rdf:type rdf:Property ;
    rdfs:label 'Min Term Months' ;
    rdfs:comment 'Minimum financing term in months that the lender offers for vehicle purchase loans (e.g., 12 months). Used to filter lender eligibility for short-term financing requests.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLenderId rdf:type rdf:Property ;
    rdfs:label 'Parent Lender Id' ;
    rdfs:comment 'Self-referencing identifier for the parent lender entity, enabling hierarchical lender group structures (e.g., a regional subsidiary referencing its national parent captive finance company).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLenderRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Lender Rank' ;
    rdfs:comment 'Numeric ranking (1 = highest preference) indicating the OEM\'s or dealer group\'s preferred routing order for financing applications. Lower rank lenders receive first-look submission priority in the dealer\'s F&I workflow.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date on which the lender\'s financing program agreement expires or is scheduled to terminate. Null for open-ended agreements. Triggers renewal workflow in Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Date on which the lender\'s financing program agreement with the OEM or dealer group became effective. Determines eligibility window for incentive subvention and preferred lender programs.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subventionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Subvention Eligible Flag' ;
    rdfs:comment 'Indicates whether the lender participates in OEM-sponsored rate subvention programs (e.g., 0% APR for 60 months). Subvention programs require the OEM to buy down the customer\'s interest rate by paying the lender a subsidy.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Vehicle Types' ;
    rdfs:comment 'Comma-separated list or description of vehicle types the lender finances (e.g., new, certified_pre_owned, used, commercial, electric_vehicle). Determines lender eligibility routing in F&I deal structuring. [ENUM-REF-CANDIDATE: new|certified_pre_owned|used|commercial|electric_vehicle|motorcycle — promote to reference product]' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'SWIFT/BIC code uniquely identifying the lender\'s financial institution for international wire transfers and cross-border automotive financing settlements.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'Federal or national tax identification number of the lender (e.g., EIN in the USA, VAT registration number in the EU). Used for 1099 reporting, withholding tax, and cross-border financing compliance.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementFee rdf:type rdf:Property ;
    rdfs:label 'Arrangement Fee' ;
    rdfs:comment 'Fixed fee charged to the customer at the inception of the finance agreement. Included in APR calculations and disclosed in pre-contractual information.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balloonPaymentPct rdf:type rdf:Property ;
    rdfs:label 'Balloon Payment Pct' ;
    rdfs:comment 'The guaranteed future value (GFV) or balloon payment expressed as a percentage of the vehicle\'s on-the-road price. Applicable to PCP (Personal Contract Purchase) and balloon finance products. Null for standard loans.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Index' ;
    rdfs:comment 'Reference rate index to which a variable rate product is linked (e.g., SOFR, EURIBOR, Bank of England Base Rate). Null for fixed-rate products.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlySettlementFee rdf:type rdf:Property ;
    rdfs:label 'Early Settlement Fee' ;
    rdfs:comment 'Fee charged to the customer for settling the finance agreement before the contracted end date. Subject to statutory rebate rules under the Consumer Credit Act.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleVehicleAgeMaxYears rdf:type rdf:Property ;
    rdfs:label 'Eligible Vehicle Age Max Years' ;
    rdfs:comment 'Maximum age of the vehicle in years at the time of finance origination. Used to restrict certain products to new or nearly-new vehicles and to manage residual value risk.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalProductId rdf:type rdf:Property ;
    rdfs:label 'External Product Id' ;
    rdfs:comment 'The identifier for this finance product in the originating source system (e.g., SAP SD material number, Salesforce product ID). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fcaProductCategory rdf:type rdf:Property ;
    rdfs:label 'Fca Product Category' ;
    rdfs:comment 'FCA-defined product category classification for regulated credit products (e.g., \'Hire Purchase\', \'Conditional Sale\', \'Personal Contract Purchase\', \'Finance Lease\'). Required for FCA regulatory reporting.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeChannel rdf:type rdf:Property ;
    rdfs:label 'Finance Channel' ;
    rdfs:comment 'The distribution channel through which this finance product is offered. Determines eligibility rules, commission structures, and regulatory disclosure requirements.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEvIncentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ev Incentive Eligible' ;
    rdfs:comment 'Indicates whether this finance product is eligible for government or manufacturer EV purchase incentives (e.g., Plug-in Car Grant, IRA EV tax credit). Used in incentive program eligibility logic.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Regulated' ;
    rdfs:comment 'Indicates whether this finance product is a regulated credit agreement subject to consumer credit legislation and conduct of business rules. Drives mandatory disclosure and affordability assessment requirements.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentFee rdf:type rdf:Property ;
    rdfs:label 'Late Payment Fee' ;
    rdfs:comment 'Fee charged per late payment event under this finance product. Must be disclosed in the pre-contractual information and is subject to FCA fairness rules.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDealerRateMarkupBps rdf:type rdf:Property ;
    rdfs:label 'Max Dealer Rate Markup Bps' ;
    rdfs:comment 'Maximum number of basis points by which a dealer is permitted to mark up the standard rate when quoting to a customer. Regulated under FCA DCA rules. Confidential commercial term.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDepositPct rdf:type rdf:Property ;
    rdfs:label 'Max Deposit Pct' ;
    rdfs:comment 'Maximum deposit percentage allowed under this finance product. Prevents over-capitalisation and ensures the product remains within its intended credit structure.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageUnit rdf:type rdf:Property ;
    rdfs:label 'Mileage Unit' ;
    rdfs:comment 'Unit of distance measurement used for mileage allowance and excess mileage charges. Varies by market (miles in UK/US, km in continental Europe).' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minDepositPct rdf:type rdf:Property ;
    rdfs:label 'Min Deposit Pct' ;
    rdfs:comment 'Minimum required deposit (down payment) as a percentage of the vehicle\'s on-the-road price, expressed as a decimal (e.g., 0.10 for 10%). Used in affordability and eligibility checks.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newUsedEligibility rdf:type rdf:Property ;
    rdfs:label 'New Used Eligibility' ;
    rdfs:comment 'Indicates whether this finance product is available for new vehicles, used/pre-owned vehicles, or both. Drives product filtering in dealer quoting systems.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalInterestRate rdf:type rdf:Property ;
    rdfs:label 'Nominal Interest Rate' ;
    rdfs:comment 'The stated annual nominal interest rate (flat rate) for this finance product, expressed as a decimal (e.g., 0.0699 for 6.99%). Used in payment schedule calculations.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentInAdvanceCount rdf:type rdf:Property ;
    rdfs:label 'Payment In Advance Count' ;
    rdfs:comment 'Number of rental payments collected in advance at the start of the agreement (e.g., 3 months in advance for a lease). Common in fleet and business lease products.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Business segment category for the finance product, distinguishing retail consumer finance from fleet, commercial, dealer stock, or wholesale financing arrangements.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable commercial name of the finance product (e.g., \'Standard Auto Loan\', \'Balloon Finance Plan\', \'Lease with Maintenance\'). Used in dealer-facing and customer-facing materials.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOwner rdf:type rdf:Property ;
    rdfs:label 'Product Owner' ;
    rdfs:comment 'Name or identifier of the business owner responsible for this finance product\'s commercial performance, pricing, and compliance. Used in governance and escalation workflows.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the finance product. Controls whether the product is available for new originations, under review, or retired from the product catalog.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the finance product by its fundamental structure. Determines the financial mechanics, regulatory treatment, and accounting classification. [ENUM-REF-CANDIDATE: loan|lease|balloon|hire_purchase|fleet_finance|subscription|pcp|pcm — promote to reference product]' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMarginBps rdf:type rdf:Property ;
    rdfs:label 'Rate Margin Bps' ;
    rdfs:comment 'The margin in basis points added to the benchmark rate index for variable-rate products. For example, a margin of 150 bps over EURIBOR. Null for fixed-rate products.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualValuePct rdf:type rdf:Property ;
    rdfs:label 'Residual Value Pct' ;
    rdfs:comment 'Estimated residual value of the vehicle at the end of the finance term, expressed as a percentage of the original vehicle price. Used in lease and PCP product pricing and risk modelling.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subsidyType rdf:type rdf:Property ;
    rdfs:label 'Subsidy Type' ;
    rdfs:comment 'Indicates whether the finance product is subsidised by the manufacturer (subvented rate), the dealer, or is unsubsidised. Subvented products are funded by the OEM to support vehicle sales incentives.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subventionRate rdf:type rdf:Property ;
    rdfs:label 'Subvention Rate' ;
    rdfs:comment 'The rate subsidy provided by the manufacturer or dealer to reduce the customer-facing APR below the standard market rate. Expressed as a decimal. Confidential commercial term.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVehicleSegment rdf:type rdf:Property ;
    rdfs:label 'Target Vehicle Segment' ;
    rdfs:comment 'The vehicle segment or nameplate category for which this finance product is designed (e.g., passenger car, SUV, commercial vehicle, EV). Used in product eligibility rules and marketing targeting.' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedingThirdPartyWarrantyContractId rdf:type rdf:Property ;
    rdfs:label 'Superseding Third Party Warranty Contract Id' ;
    rdfs:comment 'Self-referencing FK on third_party_warranty_contract (superseding_third_party_warranty_contract_id)' ;
    rdfs:domain ind:ThirdPartyWarrantyContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyWarrantyContract .

ind:parentExtendedWarrantyProviderId rdf:type rdf:Property ;
    rdfs:label 'Parent Extended Warranty Provider Id' ;
    rdfs:comment 'Self-referencing FK on extended_warranty_provider (parent_extended_warranty_provider_id)' ;
    rdfs:domain ind:ExtendedWarrantyProvider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExtendedWarrantyProvider .

ind:parentTestSampleId rdf:type rdf:Property ;
    rdfs:label 'Parent Test Sample Id' ;
    rdfs:comment 'Self-referencing FK on test_sample (parent_test_sample_id)' ;
    rdfs:domain ind:TestSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestSample .

ind:calibrationReferenceTestBenchId rdf:type rdf:Property ;
    rdfs:label 'Calibration Reference Test Bench Id' ;
    rdfs:comment 'Self-referencing FK on test_bench (calibration_reference_test_bench_id)' ;
    rdfs:domain ind:TestBench ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestBench .

ind:continuationPatentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Continuation Patent Family Id' ;
    rdfs:comment 'Self-referencing FK on patent_family (continuation_patent_family_id)' ;
    rdfs:domain ind:PatentFamily ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatentFamily .

ind:parentEprocurementPortalId rdf:type rdf:Property ;
    rdfs:label 'Parent Eprocurement Portal Id' ;
    rdfs:comment 'Self-referencing FK on eprocurement_portal (parent_eprocurement_portal_id)' ;
    rdfs:domain ind:EprocurementPortal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EprocurementPortal .

ind:supersededFiApplicationId rdf:type rdf:Property ;
    rdfs:label 'Superseded Fi Application Id' ;
    rdfs:comment 'Self-referencing FK on fi_application (superseded_fi_application_id)' ;
    rdfs:domain ind:FiApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiApplication .

ind:supersededFinanceProductId rdf:type rdf:Property ;
    rdfs:label 'Superseded Finance Product Id' ;
    rdfs:comment 'Self-referencing FK on finance_product (superseded_finance_product_id)' ;
    rdfs:domain ind:FinanceProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceProduct .
