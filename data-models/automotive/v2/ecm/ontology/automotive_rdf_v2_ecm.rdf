    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mileageOverageKm rdf:type rdf:Property ;
    rdfs:label 'Mileage Overage Km' ;
    rdfs:comment 'Calculated mileage overage in kilometers beyond the allowance, if any.' ;
