ind:recallDefectReportId rdf:type rdf:Property ;
    rdfs:label 'Recall Defect Report Id' ;
    rdfs:comment 'Foreign key linking to compliance.recall_defect_report. Business justification: Defect records that trigger a recall are linked to the recall defect report for regulatory tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
