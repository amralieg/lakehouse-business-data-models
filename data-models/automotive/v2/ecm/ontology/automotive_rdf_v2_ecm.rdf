ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Code or name of the manufacturing plant where the gauge resides.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Calendar date the gauge was acquired by the organization.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:station rdf:type rdf:Property ;
    rdfs:label 'Station' ;
    rdfs:comment 'Exact station or work-cell where the gauge is deployed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerance rdf:type rdf:Property ;
    rdfs:label 'Tolerance' ;
    rdfs:comment 'Acceptable deviation range for measurements taken with the gauge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty for the gauge ends.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppmRecordId rdf:type rdf:Property ;
    rdfs:label 'Ppm Record Id' ;
    rdfs:comment 'Unique identifier for the PPM defect rate record.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateId rdf:type rdf:Property ;
    rdfs:label 'Gate Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_gate. Business justification: PPM records are evaluated at quality gates; linking to quality_gate enables gate-level analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:recordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recorded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PPM records must capture who entered the data for auditability and data-quality checks.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:defectCategoryCount rdf:type rdf:Property ;
    rdfs:label 'Defect Category Count' ;
    rdfs:comment 'Number of defects attributed to the selected defect category.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOutlier rdf:type rdf:Property ;
    rdfs:label 'Is Outlier' ;
    rdfs:comment 'True if the PPM value is flagged as an outlier by statistical rules.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppmRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Ppm Record Status' ;
    rdfs:comment 'Lifecycle status of the PPM record.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmValue rdf:type rdf:Property ;
    rdfs:label 'Ppm Value' ;
    rdfs:comment 'Defects per million parts (PPM) for the reporting period.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppmVariance rdf:type rdf:Property ;
    rdfs:label 'Ppm Variance' ;
    rdfs:comment 'Actual PPM minus target PPM; positive indicates over-target.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityGatePassed rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Passed' ;
    rdfs:comment 'True if the part passed the defined quality gate for the period.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Month (YYYY-MM) or quarter (Qn-YYYY) for which the PPM is calculated.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDefectiveParts rdf:type rdf:Property ;
    rdfs:label 'Total Defective Parts' ;
    rdfs:comment 'Number of parts that failed quality inspection in the reporting period.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPartsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Parts Received' ;
    rdfs:comment 'Total number of parts received from the supplier or produced in-process during the reporting period.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendIndicator rdf:type rdf:Property ;
    rdfs:label 'Trend Indicator' ;
    rdfs:comment 'Indicates whether the PPM trend is improving, declining, or stable.' ;
    rdfs:domain ind:PpmRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGateAssociatedFmeaId rdf:type rdf:Property ;
    rdfs:label 'Primary Gate Associated Fmea Id' ;
    rdfs:comment 'Link to the Failure Mode and Effects Analysis that this gate supports.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:ObjectProperty ;
