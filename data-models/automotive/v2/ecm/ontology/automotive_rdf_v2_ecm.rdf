ind:odometerAtAssignmentKm rdf:type rdf:Property ;
    rdfs:label 'Odometer At Assignment Km' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date vehicle was returned from fleet' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Usage type (dedicated, pool, shared)' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityResolutionId rdf:type rdf:Property ;
    rdfs:label 'Identity Resolution Id' ;
    rdfs:comment 'System-generated unique identifier for each identity resolution event.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIdentityGoldenPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Identity Golden Party Id' ;
    rdfs:comment 'Identifier of the surviving (golden) party record after resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Confidence level (0-1) indicating how certain the match is, as calculated by the MDM engine.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'Technique used to determine the match: deterministic, probabilistic, or manual review.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchRuleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Match Rule Set Version' ;
    rdfs:comment 'Version identifier of the matching rule set used for this resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedAttributes rdf:type rdf:Property ;
    rdfs:label 'Matched Attributes' ;
    rdfs:comment 'JSON-encoded list of attribute names that were used to compute the match (e.g., ["email","phone","address"]).' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken after the match: merge (combine records), link (associate), suppress (deactivate duplicate), or review (manual investigation required).' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedBy rdf:type rdf:Property ;
    rdfs:label 'Resolved By' ;
    rdfs:comment 'User name or system identifier that performed the resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemA rdf:type rdf:Property ;
    rdfs:label 'Source System A' ;
    rdfs:comment 'Name or code of the first source system contributing the party record (e.g., Salesforce, SAP, CDK).' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemB rdf:type rdf:Property ;
    rdfs:label 'Source System B' ;
    rdfs:comment 'Name or code of the second source system contributing the party record.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Communication Subscription Id' ;
    rdfs:comment 'System-generated unique identifier for the communication subscription record.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Subscription Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Subscription Management Oversight tracks which employee manages a customer\'s communication subscription.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Preferred channel for delivering the communication.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSubscriptionCode rdf:type rdf:Property ;
    rdfs:label 'External Subscription Code' ;
    rdfs:comment 'External identifier used by third-party systems to reference this subscription.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTest rdf:type rdf:Property ;
    rdfs:label 'Is Test' ;
    rdfs:comment 'Indicates whether the subscription is for testing purposes only.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sent Timestamp' ;
    rdfs:comment 'Timestamp of the most recent communication sent under this subscription.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingCloudKey rdf:type rdf:Property ;
    rdfs:label 'Marketing Cloud Key' ;
    rdfs:comment 'Unique key used by Salesforce Marketing Cloud to identify the subscription.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledSend rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Send' ;
    rdfs:comment 'Planned timestamp for the next communication to be sent.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriptionDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Date' ;
    rdfs:comment 'Date when the subscription became effective.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unsubscribeDate rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Date' ;
    rdfs:comment 'Date when the subscription was terminated by the party.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unsubscribeReason rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Reason' ;
    rdfs:comment 'Reason provided by the party for unsubscribing, if any.' ;
    rdfs:domain ind:CommunicationSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Id' ;
    rdfs:comment 'Surrogate primary key for the party relationship record.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromPartyId rdf:type rdf:Property ;
    rdfs:label 'From Party Id' ;
    rdfs:comment 'Identifier of the source party in the relationship (e.g., parent company, household head, driver).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customer Relationship Owner tracking records the employee overseeing a specific party-to-party relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:toPartyId rdf:type rdf:Property ;
    rdfs:label 'To Party Id' ;
    rdfs:comment 'Identifier of the target party in the relationship (e.g., subsidiary, household member, authorized driver).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of authorization granted to the target party for actions on behalf of the source party.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Description' ;
    rdfs:comment 'Free-text notes or comments describing the nature of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseRole rdf:type rdf:Property ;
    rdfs:label 'Inverse Role' ;
    rdfs:comment 'Corresponding role of the target party from its perspective.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Is Legal Entity' ;
    rdfs:comment 'Flag indicating whether the relationship is recognized as a legal entity relationship (e.g., corporate ownership) rather than informal.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Role of the source party within this relationship (e.g., owner, contact, driver, guarantor).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Numeric rating (1-5) indicating the assessed strength or importance of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Categorizes the nature of the link (e.g., parent_company, subsidiary, household_member, authorized_driver, fleet_contact, dealer_contact, co_owner, guarantor, beneficiary, partner, vendor, customer, employee). [ENUM-REF-CANDIDATE: parent_company|subsidiary|household_member|authorized_driver|fleet_contact|dealer_contact|co_owner|guarantor|beneficiary|partner|vendor|customer|employee — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdiRecordId rdf:type rdf:Property ;
    rdfs:label 'Pdi Record Id' ;
    rdfs:comment 'Unique system-generated identifier for the PDI record.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Pdi Technician Id' ;
    rdfs:comment 'Identifier of the technician who performed the inspection.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:connectedServicesActivated rdf:type rdf:Property ;
    rdfs:label 'Connected Services Activated' ;
    rdfs:comment 'True if connected vehicle services (e.g., telematics) were activated at delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Date' ;
    rdfs:comment 'Date on which the customer signed the PDI acceptance form.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerWalkthroughCompleted rdf:type rdf:Property ;
    rdfs:label 'Customer Walkthrough Completed' ;
    rdfs:comment 'True if the dealer completed the customer walkthrough of vehicle features.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorMatCount rdf:type rdf:Property ;
    rdfs:label 'Floor Mat Count' ;
    rdfs:comment 'Count of floor mats provided with the vehicle.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Fuel level recorded at delivery expressed as a percentage of tank capacity.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionChecklistVersion rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Version' ;
    rdfs:comment 'Version of the PDI checklist used during the inspection.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionItemsJson rdf:type rdf:Property ;
    rdfs:label 'Inspection Items Json' ;
    rdfs:comment 'JSON string capturing individual checklist item results and comments.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyCount rdf:type rdf:Property ;
    rdfs:label 'Key Count' ;
    rdfs:comment 'Count of vehicle keys handed over to the customer.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Vehicle odometer reading at the time of delivery, in kilometers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaBaselineVersion rdf:type rdf:Property ;
    rdfs:label 'Ota Baseline Version' ;
    rdfs:comment 'Baseline over-the-air software version installed on the vehicle at delivery.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPass rdf:type rdf:Property ;
    rdfs:label 'Overall Pass' ;
    rdfs:comment 'Flag indicating whether the vehicle passed the overall PDI (true) or failed (false).' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

