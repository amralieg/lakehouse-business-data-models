    rdfs:comment 'Result of the interaction from the customer\'s perspective.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the client device for online interactions.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAssisted rdf:type rdf:Property ;
    rdfs:label 'Is Assisted' ;
    rdfs:comment 'Indicates whether the touchpoint involved human assistance (true) or was fully automated (false).' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the touchpoint took place, if location is applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'Three-letter ISO country code where the touchpoint occurred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationState rdf:type rdf:Property ;
    rdfs:label 'Location State' ;
    rdfs:comment 'State or province code for the touchpoint location.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty points used during the interaction.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingAttribution rdf:type rdf:Property ;
    rdfs:label 'Marketing Attribution' ;
    rdfs:comment 'Attribution source for the touchpoint (e.g., email, paid search, referral).' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaUpdateVersion rdf:type rdf:Property ;
    rdfs:label 'Ota Update Version' ;
    rdfs:comment 'Software version applied during an Over-The-Air update touchpoint.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repurchaseFlag rdf:type rdf:Property ;
    rdfs:label 'Repurchase Flag' ;
    rdfs:comment 'True if the touchpoint represents a repeat purchase by the customer.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionReference rdf:type rdf:Property ;
    rdfs:label 'Session Reference' ;
    rdfs:comment 'Unique identifier for the digital session associated with the touchpoint.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Exact date and time when the touchpoint occurred.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:touchpointType rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Type' ;
    rdfs:comment 'Category of the interaction event in the customer journey.' ;
    rdfs:domain ind:JourneyTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeInVehicleVin rdf:type rdf:Property ;
    rdfs:label 'Trade In Vehicle Vin' ;
    rdfs:comment 'VIN of the vehicle offered as a trade-in during the touchpoint.' ;
