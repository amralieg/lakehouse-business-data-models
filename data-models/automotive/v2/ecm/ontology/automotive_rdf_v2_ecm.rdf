    rdfs:comment 'Duration of the quality assessment audit in hours' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of corrective actions required' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerExperienceScore rdf:type rdf:Property ;
    rdfs:label 'Customer Experience Score' ;
    rdfs:comment 'Customer experience score' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Digital Readiness Score' ;
    rdfs:comment 'Score for digital/online capabilities assessment' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Score' ;
    rdfs:comment 'Score for environmental/sustainability compliance' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Ev Readiness Score' ;
    rdfs:comment 'Score for EV sales and service readiness' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityScore rdf:type rdf:Property ;
    rdfs:label 'Facility Score' ;
    rdfs:comment 'Facility condition score' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Due Date' ;
    rdfs:comment 'Due date for improvement plan' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Whether dealership is certified' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsScore rdf:type rdf:Property ;
    rdfs:label 'Parts Score' ;
    rdfs:comment 'Parts department score' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Previous Assessment Date' ;
    rdfs:comment 'Date of previous assessment' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processScore rdf:type rdf:Property ;
    rdfs:label 'Process Score' ;
    rdfs:comment 'Process adherence score' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesScore rdf:type rdf:Property ;
    rdfs:label 'Sales Score' ;
    rdfs:comment 'Sales department score' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScore rdf:type rdf:Property ;
    rdfs:label 'Service Score' ;
    rdfs:comment 'Service department score' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Training Compliance Score' ;
    rdfs:comment 'Score for staff training compliance' ;
    rdfs:domain ind:DealershipQualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureContentId rdf:type rdf:Property ;
    rdfs:label 'Feature Content Id' ;
    rdfs:comment 'Unique identifier for the feature content record. Primary key.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Indicates whether the feature is included as standard equipment, available as a standalone option, only available within a package, or not available for a given trim or market.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSourceCode rdf:type rdf:Property ;
    rdfs:label 'Content Source Code' ;
    rdfs:comment 'Unique identifier of this feature content record in the source system, used for traceability and data lineage.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Content Source System' ;
    rdfs:comment 'Name of the source system from which this feature content record originates, such as PLM (Product Lifecycle Management), PIM (Product Information Management), or marketing content management system.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDemandScore rdf:type rdf:Property ;
    rdfs:label 'Customer Demand Score' ;
    rdfs:comment 'Quantitative score (0-100) representing customer demand or take-rate for this feature based on market research, configurator analytics, and sales data. Used for product planning and inventory optimization.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost Impact Amount' ;
    rdfs:comment 'The incremental dealer invoice cost when this feature is included. Used for dealer margin calculations and incentive program design.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecuDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Ecu Dependency Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feature requires specific ECU (Electronic Control Unit) hardware or software configuration. Used for manufacturing planning and service diagnostics.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureCategory rdf:type rdf:Property ;
    rdfs:label 'Feature Category' ;
    rdfs:comment 'High-level classification of the feature grouping for marketing segmentation and consumer navigation. Categories align with consumer decision-making patterns.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescriptionLong rdf:type rdf:Property ;
    rdfs:label 'Feature Description Long' ;
    rdfs:comment 'Comprehensive consumer-facing description of the feature including benefits, technical highlights, and usage scenarios. Used in brochures, website detail pages, and dealer training materials.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescriptionShort rdf:type rdf:Property ;
    rdfs:label 'Feature Description Short' ;
    rdfs:comment 'Brief consumer-facing description of the feature, typically 50-100 characters, used in configurator tooltips and mobile applications.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Status' ;
    rdfs:comment 'Current lifecycle status of the feature content record. Active features are available for configuration; discontinued features are retained for historical reference; pending features are awaiting approval; under_review features are being evaluated for changes.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSubcategory rdf:type rdf:Property ;
    rdfs:label 'Feature Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the feature category for granular filtering and reporting (e.g., within safety: active safety, passive safety, driver assistance).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Impact Percent' ;
    rdfs:comment 'The estimated percentage impact on fuel economy (positive or negative) when this feature is included. Used for EPA fuel economy label calculations and CAFE compliance.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Installation Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to install this feature on the production line. Used for manufacturing capacity planning and line balancing in MES (Manufacturing Execution System).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdasFeature rdf:type rdf:Property ;
    rdfs:label 'Is Adas Feature' ;
    rdfs:comment 'Boolean flag indicating whether this feature is classified as an ADAS (Advanced Driver Assistance Systems) technology, such as adaptive cruise control, lane keeping assist, or automated emergency braking.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEvSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Ev Specific' ;
    rdfs:comment 'Boolean flag indicating whether this feature is specific to electric vehicle (EV) or plug-in hybrid electric vehicle (PHEV) powertrains, such as regenerative braking display, charging port, or battery thermal management.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHevSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Hev Specific' ;
    rdfs:comment 'Boolean flag indicating whether this feature is specific to hybrid electric vehicle (HEV) powertrains, such as hybrid system display, EV mode selector, or hybrid battery cooling.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Boolean flag indicating whether this feature is mandated by regulatory requirements such as NHTSA Federal Motor Vehicle Safety Standards (FMVSS), EPA emissions standards, or regional safety regulations (e.g., backup camera, tire pressure monitoring system).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Marketing Priority Rank' ;
    rdfs:comment 'Numerical ranking indicating the marketing priority of this feature for promotional campaigns and sales emphasis. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelYearDiscontinued rdf:type rdf:Property ;
    rdfs:label 'Model Year Discontinued' ;
    rdfs:comment 'The model year (MY) when this feature was discontinued or phased out. Null if the feature is still active in the current lineup.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelYearIntroduced rdf:type rdf:Property ;
    rdfs:label 'Model Year Introduced' ;
    rdfs:comment 'The model year (MY) when this feature was first introduced into the product lineup. Used for product evolution tracking and historical analysis.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Impact Amount' ;
    rdfs:comment 'The incremental MSRP (Manufacturer Suggested Retail Price) value added when this feature is included as an option. Zero for standard features. Used for pricing calculations and configurator display.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaUpdateableFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Updateable Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feature can be enabled, updated, or modified via OTA (Over-the-Air) software updates post-production.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Safety Rating Impact' ;
    rdfs:comment 'Indicates the level of impact this feature has on vehicle safety ratings such as NCAP (New Car Assessment Programme) star ratings or IIHS Top Safety Pick awards.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Level' ;
    rdfs:comment 'Classification of the feature\'s technology sophistication level, used for market positioning and trim-level differentiation strategies.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightImpactKg rdf:type rdf:Property ;
    rdfs:label 'Weight Impact Kg' ;
    rdfs:comment 'The incremental vehicle weight in kilograms added by this feature. Used for CAFE (Corporate Average Fuel Economy) calculations, performance modeling, and engineering analysis.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Program Milestone Id' ;
    rdfs:comment 'Unique identifier for the program milestone record. Primary key for the program milestone entity.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMilestoneProgramMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Program Milestone Id' ;
    rdfs:comment 'Reference to the immediately preceding milestone that must be achieved before this milestone can begin. Null for the first milestone in the program sequence. Enables critical path analysis.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramMilestone .

ind:programEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Employee Id' ;
    rdfs:comment 'Reference to the employee or program manager accountable for delivering this milestone. Links to workforce/employee master data.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programResponsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Responsible Person Employee Id' ;
    rdfs:comment 'Reference to the employee or program manager accountable for delivering this milestone. Links to workforce/employee master data.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date after program approval or re-baseline. Used as the official target for performance measurement and variance calculation.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Amount' ;
    rdfs:comment 'Estimated financial impact (in base currency) if this milestone is delayed. Used for prioritization and executive escalation. Null if no quantified impact.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Estimated percentage of work completed toward achieving this milestone (0.00 to 100.00). Updated during program reviews. 100.00 when milestone_status is achieved.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the program critical path. True if any delay to this milestone will delay the overall program SOP date. Used for prioritization and risk management.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Completed Count' ;
    rdfs:comment 'Number of deliverables that have been completed and approved. Used to calculate completion_percentage and assess readiness for gate review.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Number of formal deliverables (documents, approvals, test results) required to achieve this milestone. Used to track completion progress.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalDependencyDescription rdf:type rdf:Property ;
    rdfs:label 'External Dependency Description' ;
    rdfs:comment 'Description of external dependencies, including supplier names, partner organizations, or regulatory agencies. Null if external_dependency_flag is false.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'External Dependency Flag' ;
    rdfs:comment 'Indicates whether this milestone depends on external parties (suppliers, partners, regulatory agencies) for completion. True if external coordination required, false if fully internal.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current forecast date for milestone achievement based on latest program status. Updated regularly during program reviews. Null if milestone already achieved.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateReviewComments rdf:type rdf:Property ;
    rdfs:label 'Gate Review Comments' ;
    rdfs:comment 'Executive comments, conditions, or action items resulting from the gate review meeting. Captures key decisions and follow-up requirements.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Gate Review Date' ;
    rdfs:comment 'Date the formal gate review meeting was held. Null if gate_review_required is false or review not yet conducted.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Gate Review Outcome' ;
    rdfs:comment 'Result of the formal gate review meeting: approved (proceed to next phase), approved_with_conditions (proceed with action items), deferred (reschedule review), rejected (do not proceed). Null if gate_review_required is false or review not yet held.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Gate Review Required' ;
    rdfs:comment 'Indicates whether a formal gate review (executive approval meeting) is required before this milestone can be marked as achieved. True for major program gates (e.g., Program Approval, SOP), false for intermediate checkpoints.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Standardized code identifying the milestone type (e.g., PROG_APPR, DESIGN_FREEZE, PPAP_COMP, SOP, JOB1, EOP). Used for system integration and reporting.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'High-level program phase in which this milestone occurs: concept (initial planning), design (engineering), development (prototyping), validation (testing/PPAP), launch (SOP/Job 1), production (volume ramp), end_of_life (EOP). [ENUM-REF-CANDIDATE: concept|design|development|validation|launch|production|end_of_life — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this milestone is driven by regulatory or homologation requirements (e.g., NHTSA, EPA, Euro NCAP, WLTP certification). True for regulatory gates, false for internal program milestones.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed description of risks, issues, or blockers that may prevent timely achievement of this milestone. Updated during program status reviews.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of calendar days between baseline_date and actual_date. Positive values indicate delay, negative values indicate early completion. Null if milestone not yet achieved.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Reference to the executive who approved the milestone waiver. Links to workforce/employee master data. Null if milestone not waived.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date the milestone waiver was formally approved. Null if milestone not waived.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productEngineeringChangeId rdf:type rdf:Property ;
    rdfs:label 'Product Engineering Change Id' ;
    rdfs:comment 'Unique identifier for the product_engineering_change data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPartNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Part Numbers' ;
    rdfs:comment 'Part numbers affected by the change' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productEngineeringChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Product Engineering Change Description' ;
    rdfs:comment 'Description of the entity' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost Estimate' ;
    rdfs:comment 'Estimated cost to implement the engineering change across affected vehicles and service parts' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonForChange rdf:type rdf:Property ;
    rdfs:label 'Reason For Change' ;
    rdfs:comment 'Reason for the engineering change' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceImpact rdf:type rdf:Property ;
    rdfs:label 'Service Impact' ;
    rdfs:comment 'Impact on aftersales service operations' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productEngineeringChangeStatus rdf:type rdf:Property ;
    rdfs:label 'Product Engineering Change Status' ;
    rdfs:comment 'Status (proposed, approved, implemented, closed)' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededPartNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Part Number' ;
    rdfs:comment 'Part number being superseded' ;
    rdfs:domain ind:ProductEngineeringChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionConstraintId rdf:type rdf:Property ;
    rdfs:label 'Option Constraint Id' ;
    rdfs:comment 'Unique identifier for the option constraint rule. Primary key.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Primary Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that triggers this constraint rule. The \'if\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:targetOptionAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Target Option Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that is affected by this constraint rule. The \'then\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:targetOptionOptionPackageAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Target Option Option Package Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that is affected by this constraint rule. The \'then\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:appliesToFleet rdf:type rdf:Property ;
    rdfs:label 'Applies To Fleet' ;
    rdfs:comment 'Indicates whether this constraint applies to fleet orders. Some constraints are relaxed or different for high-volume fleet customers.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToRetail rdf:type rdf:Property ;
    rdfs:label 'Applies To Retail' ;
    rdfs:comment 'Indicates whether this constraint applies to retail customer orders through dealer networks.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomImpact rdf:type rdf:Property ;
    rdfs:label 'Bom Impact' ;
    rdfs:comment 'Indicates the severity of Bill of Materials changes triggered by this constraint. Critical impacts may require PPAP or APQP review.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Reference to the Engineering Change Request or Product Change Notice that authorized the creation or modification of this constraint.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configuratorDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Configurator Display Order' ;
    rdfs:comment 'Numeric sequence controlling the order in which constraint messages are displayed in consumer and dealer configurators.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Code' ;
    rdfs:comment 'Business-readable code identifying this constraint rule, often used in dealer ordering systems and configurators.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Detailed business explanation of why this constraint exists, including engineering, regulatory, or commercial rationale.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintPriority rdf:type rdf:Property ;
    rdfs:label 'Constraint Priority' ;
    rdfs:comment 'Numeric priority for resolving conflicts when multiple constraints apply to the same option combination. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintSource rdf:type rdf:Property ;
    rdfs:label 'Constraint Source' ;
    rdfs:comment 'The business function or domain that originated this constraint rule (e.g., engineering for technical incompatibility, regulatory for compliance, commercial for pricing strategy).' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the constraint rule. Active constraints are enforced in ordering systems; inactive/deprecated constraints are retained for historical reference.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Reference identifier to the FMEA document that analyzed the risk associated with this option constraint.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationRegion rdf:type rdf:Property ;
    rdfs:label 'Homologation Region' ;
    rdfs:comment 'Regulatory region code (e.g., EPA, CARB, EURO6, UNECE) for which this constraint is applicable. Some option combinations are prohibited or required by regional emissions or safety standards.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHardConstraint rdf:type rdf:Property ;
    rdfs:label 'Is Hard Constraint' ;
    rdfs:comment 'Indicates whether this is a hard constraint (cannot be violated under any circumstances) or a soft constraint (generates warning but can be overridden).' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Impact Days' ;
    rdfs:comment 'The number of additional production days required when this constraint is triggered, impacting On-Time Delivery (OTD) commitments.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Msrp Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the MSRP impact amount.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Override Approval Level' ;
    rdfs:comment 'The minimum authorization level required to override this constraint, if override_allowed is true.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConstraint rdf:type rdf:Property ;
    rdfs:label 'Supplier Constraint' ;
    rdfs:comment 'Indicates whether this constraint is driven by supplier capacity, tooling, or material availability limitations.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fleetSpecId rdf:type rdf:Property ;
    rdfs:label 'Fleet Spec Id' ;
    rdfs:comment 'Unique identifier for the fleet specification record. Primary key.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetAccountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Manager Employee Id' ;
    rdfs:comment 'Reference to the sales or account manager responsible for this fleet specification and customer relationship. Primary point of contact for commercial and operational matters.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fleetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fleet Employee Id' ;
    rdfs:comment 'Reference to the sales or account manager responsible for this fleet specification and customer relationship. Primary point of contact for commercial and operational matters.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCustomerFleetAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Fleet Account Id' ;
    rdfs:comment 'Reference to the fleet customer organization that this specification was negotiated for. Links to customer master data and account management.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerFleetAccount .

ind:actualVolumeYtd rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Ytd' ;
    rdfs:comment 'Actual number of units ordered or delivered under this fleet specification in the current fiscal year. Used to track performance against volume commitments.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedOptionPackages rdf:type rdf:Property ;
    rdfs:label 'Approved Option Packages' ;
    rdfs:comment 'Comma-separated list of option package codes that are pre-approved for inclusion in this fleet specification. May include safety, technology, or utility packages negotiated at fleet pricing.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTrimLevels rdf:type rdf:Property ;
    rdfs:label 'Approved Trim Levels' ;
    rdfs:comment 'Comma-separated list of trim level codes that are approved for this fleet specification. Defines the range of configurations available to the fleet customer.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSpecCode rdf:type rdf:Property ;
    rdfs:label 'Fleet Spec Code' ;
    rdfs:comment 'Business identifier for the fleet specification, used in contracts and ordering systems. Unique alphanumeric code assigned to each negotiated fleet configuration.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Committed lead time in days from order placement to vehicle delivery for this fleet specification. Service level commitment tied to production scheduling and logistics.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the primary delivery location or distribution center for vehicles under this fleet specification. May reference a fleet customer facility or a designated delivery hub.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'Code identifying the distribution channel through which vehicles under this fleet specification are sold. Fleet sales typically use a dedicated channel distinct from retail.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Fleet Customer Segment' ;
    rdfs:comment 'Classification of the fleet customer type. Determines applicable pricing structures, compliance requirements, and service level agreements.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Fleet Discount Percentage' ;
    rdfs:comment 'Negotiated discount percentage applied to the base MSRP for fleet orders. Confidential commercial term tied to volume commitments and customer segment.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetMsrpBase rdf:type rdf:Property ;
    rdfs:label 'Fleet Msrp Base' ;
    rdfs:comment 'Base MSRP for the fleet specification before discounts and volume adjustments. Represents the starting price point for fleet negotiations.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetNetPrice rdf:type rdf:Property ;
    rdfs:label 'Fleet Net Price' ;
    rdfs:comment 'Final negotiated net price per unit after all discounts and adjustments. Confidential commercial term used for fleet order processing.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Fleet Priority Rank' ;
    rdfs:comment 'Priority ranking for production scheduling and allocation when demand exceeds capacity. Higher priority fleet specs receive preferential treatment in build sequence planning.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or username of the person who last modified this fleet specification record. Audit trail for change accountability.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code identifying the negotiated payment terms for this fleet specification. Examples: Net 30, Net 60, progress billing, lease arrangement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all pricing fields in this fleet specification.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceContractIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Service Contract Included Flag' ;
    rdfs:comment 'Indicates whether a prepaid service or maintenance contract is included as part of this fleet specification. Common for government and corporate fleet agreements.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Approval Status' ;
    rdfs:comment 'Current lifecycle status of the fleet specification. Controls whether the spec can be used for order entry and production planning. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specNotes rdf:type rdf:Property ;
    rdfs:label 'Spec Notes' ;
    rdfs:comment 'Free-text field for additional notes, special instructions, or clarifications related to this fleet specification. May include operational guidance, customer preferences, or exception handling procedures.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Requirements' ;
    rdfs:comment 'Description of any special equipment, upfitting, or modifications required for this fleet specification beyond standard options. May include emergency lighting, cargo racks, communication systems, or specialized tooling.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the product lifecycle event record. Primary key for this entity.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityCode rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Code' ;
    rdfs:comment 'Business code or identifier of the affected entity (e.g., nameplate code, program code, SKU code) for human-readable reference and reporting.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'Identifier of the specific product entity affected by this event. References the primary key of the entity type specified in affected_entity_type.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of product entity affected by this lifecycle event (e.g., nameplate, model year program, SKU, trim level, platform, powertrain).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcementType rdf:type rdf:Property ;
    rdfs:label 'Announcement Type' ;
    rdfs:comment 'Classification of the event announcement scope: internal (company-only), public (press release), regulatory (mandatory filing), or confidential (restricted distribution).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether executive or board approval was required for this lifecycle event.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCommunicationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Communication Required Flag' ;
    rdfs:comment 'Indicates whether direct customer communication or notification is required for this lifecycle event (e.g., for recalls, service campaigns, or discontinuations affecting existing owners).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dealer Notification Date' ;
    rdfs:comment 'Date when dealers were notified of this lifecycle event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Notification Required Flag' ;
    rdfs:comment 'Indicates whether dealer network notification is required for this lifecycle event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Standardized code identifying the type of lifecycle event (e.g., PROG_APPR, DSGN_FRZ, SOP, JOB1, MCR_ANN, EOP, DISC).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the lifecycle event occurred or is scheduled to occur. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of this lifecycle event in the specified currency (e.g., CapEx investment for SOP, cost savings from EOP, write-off for discontinuation).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Business impact level of this lifecycle event on operations, supply chain, sales, and customer commitments.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The lifecycle state or phase of the affected entity after this event (e.g., approved, frozen, in-production, discontinued). Represents the state transition resulting from this event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseReference rdf:type rdf:Property ;
    rdfs:label 'Press Release Reference' ;
    rdfs:comment 'Reference number, URL, or document identifier for the associated press release or public announcement, if applicable.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'The lifecycle state or phase of the affected entity immediately before this event occurred (e.g., concept, development, pre-production, production, phase-out).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeImpact rdf:type rdf:Property ;
    rdfs:label 'Production Volume Impact' ;
    rdfs:comment 'Estimated change in production volume (units) resulting from this lifecycle event. Positive for ramp-up events, negative for phase-out or discontinuation.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier or key of this event record in the source system, used for traceability and reconciliation.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierImpactCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Impact Count' ;
    rdfs:comment 'Number of suppliers affected by this lifecycle event (e.g., new suppliers onboarded for SOP, suppliers phased out for EOP).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Triggering Authority' ;
    rdfs:comment 'Name or identifier of the person, role, or organizational unit that authorized or triggered this lifecycle event (e.g., Chief Product Officer, Program Manager, Executive Committee).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Authority Reference' ;
    rdfs:comment 'System identifier for the person or role that authorized this event, linking to employee or role master data.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aftersalesCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Customer Party Id' ;
    rdfs:comment 'Identifier of the customer who owns the vehicle.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:aftersalesDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealer/service center handling the repair.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:aftersalesDealershipId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Dealership Id' ;
    rdfs:comment 'Identifier of the dealer/service center handling the repair.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:aftersalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Employee Id' ;
    rdfs:comment 'Identifier of the service advisor who created the repair order.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aftersalesPartyId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Party Id' ;
    rdfs:comment 'Identifier of the customer who owns the vehicle.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:aftersalesServiceAdvisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Service Advisor Employee Id' ;
    rdfs:comment 'Identifier of the service advisor who created the repair order.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:mobilityDtcEventId rdf:type rdf:Property ;
    rdfs:label 'Mobility Dtc Event Id' ;
    rdfs:comment 'Unique identifier for the mobility_dtc_event data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MobilityDtcEvent .

ind:mobilityOtaDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Mobility Ota Deployment Id' ;
    rdfs:comment 'System-generated unique identifier for each OTA deployment record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MobilityOtaDeployment .

ind:otaServiceId rdf:type rdf:Property ;
    rdfs:label 'Ota Service Id' ;
    rdfs:comment 'FK to the OTA service event that triggered this repair order' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Identifier of the primary technician assigned to perform the work.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'Actual date and time when the repair was completed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aftersalesRepairOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Aftersales Repair Order Status' ;
    rdfs:comment 'Current lifecycle status of the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle arrived at the service center.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Departure Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle left the service center.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduled Timestamp' ;
    rdfs:comment 'Date and time when the service appointment was scheduled.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Date and time when the repair order was closed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Score' ;
    rdfs:comment 'Numeric rating (1-5) provided by the customer after service.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Flag' ;
    rdfs:comment 'Indicates whether the customer signed off on the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosticCode rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Code' ;
    rdfs:comment 'Standard OBD diagnostic code recorded during service.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEstimate rdf:type rdf:Property ;
    rdfs:label 'Is Estimate' ;
    rdfs:comment 'Indicates whether the record is an estimate prior to work being performed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborTotalCost rdf:type rdf:Property ;
    rdfs:label 'Labor Total Cost' ;
    rdfs:comment 'Total cost of labor before taxes and discounts.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTotalHours rdf:type rdf:Property ;
    rdfs:label 'Labor Total Hours' ;
    rdfs:comment 'Total labor hours recorded for the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obdDiagnosticLinkReference rdf:type rdf:Property ;
    rdfs:label 'Obd Diagnostic Link Reference' ;
    rdfs:comment 'FK to the OBD diagnostic link that triggered this repair order' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:obdLiveDataLinkReference rdf:type rdf:Property ;
    rdfs:label 'Obd Live Data Link Reference' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the repair order was opened.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partsTotalCost rdf:type rdf:Property ;
    rdfs:label 'Parts Total Cost' ;
    rdfs:comment 'Total cost of parts consumed before taxes and discounts.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Promised Completion Time' ;
    rdfs:comment 'Scheduled date and time promised to the customer for repair completion.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCenterRegion rdf:type rdf:Property ;
    rdfs:label 'Service Center Region' ;
    rdfs:comment 'Geographic region where the service center is located.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Free-text notes entered by service advisor describing work performed.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePriority rdf:type rdf:Property ;
    rdfs:label 'Service Priority' ;
    rdfs:comment 'Priority level assigned to the repair order.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text notes entered by the technician during repair.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByTelemetryFlag rdf:type rdf:Property ;
    rdfs:label 'Triggered By Telemetry Flag' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Repair Order Line Id' ;
    rdfs:comment 'System-generated unique identifier for the repair order line.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepairOrderLine .

ind:laborTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Labor Time Standard Id' ;
    rdfs:comment 'Foreign key linking to aftersales.labor_time_standard. Business justification: Repair order line should reference the standard labor time definition for the operation code.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborTimeStandard .

ind:servicePartId rdf:type rdf:Property ;
    rdfs:label 'Service Part Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_part. Business justification: Repair order lines track parts consumed during service (part_quantity, part_price columns exist). The aftersales.service_part is the authoritative parts master for dealer service operations. Adding se' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServicePart .

ind:subletVendorId rdf:type rdf:Property ;
    rdfs:label 'Sublet Vendor Id' ;
    rdfs:comment 'Identifier of the external vendor performing the sublet work.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualTechnicianHours rdf:type rdf:Property ;
    rdfs:label 'Actual Technician Hours' ;
    rdfs:comment 'Actual labor hours logged by the technician for this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:causeComplaint rdf:type rdf:Property ;
    rdfs:label 'Cause Complaint' ;
    rdfs:comment 'Narrative describing the customer complaint or issue that initiated the service.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correction rdf:type rdf:Property ;
    rdfs:label 'Correction' ;
    rdfs:comment 'Narrative describing the corrective action taken to resolve the complaint.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCategory rdf:type rdf:Property ;
    rdfs:label 'Labor Category' ;
    rdfs:comment 'Broad classification of the labor type performed.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Labor Skill Level' ;
    rdfs:comment 'Skill level required for the technician to perform the operation.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborTimeStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Time Standard' ;
    rdfs:comment 'Flat-rate standard labor time in hours for the operation code.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'True if overtime rates were applied to this labor line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to the labor_rate when overtime_flag is true (e.g., 1.5).' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partPrice rdf:type rdf:Property ;
    rdfs:label 'Part Price' ;
    rdfs:comment 'Standard price per unit of the part at the time of service.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partQuantity rdf:type rdf:Property ;
    rdfs:label 'Part Quantity' ;
    rdfs:comment 'Quantity of the part used for this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Used Flag' ;
    rdfs:comment 'Indicates whether any parts were consumed on this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subletCost rdf:type rdf:Property ;
    rdfs:label 'Sublet Cost' ;
    rdfs:comment 'Total cost charged by the sublet vendor for this line.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subletFlag rdf:type rdf:Property ;
    rdfs:label 'Sublet Flag' ;
    rdfs:comment 'True if the work was performed by an external subcontractor.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Claim Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Associates warranty claim creation with the responsible employee for accountability and claim processing KPI.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:remoteDiagnosticSessionId rdf:type rdf:Property ;
    rdfs:label 'Remote Diagnostic Session Id' ;
    rdfs:comment 'Foreign key linking to mobility.remote_diagnostic_session. Business justification: Warranty Claim Investigation often uses a remote diagnostic session to verify fault, linking claim to the session record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemoteDiagnosticSession .

ind:thirdPartyWarrantyContractId rdf:type rdf:Property ;
    rdfs:label 'Third Party Warranty Contract Id' ;
    rdfs:comment 'Primary key for third_party_warranty_contract' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyWarrantyContract .

ind:warrantyPolicyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Policy Id' ;
    rdfs:comment 'Foreign key linking to aftersales.warranty_policy. Business justification: A warranty claim is filed under a specific warranty policy; linking directly to warranty_policy provides direct access to policy terms without needing to traverse vehicle_warranty.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyPolicy .

ind:warrantyReserveId rdf:type rdf:Property ;
    rdfs:label 'Warranty Reserve Id' ;
    rdfs:comment 'Foreign key linking to finance.warranty_reserve. Business justification: Warranty claim settlements are charged against a warranty reserve record for IFRS warranty liability tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyReserve .

ind:adjudicationOutcome rdf:type rdf:Property ;
    rdfs:label 'Adjudication Outcome' ;
    rdfs:comment 'Result of the OEM\'s review of the claim.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Amount' ;
    rdfs:comment 'Monetary amount of the adjustment applied to the claim.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Approved Labor Cost' ;
    rdfs:comment 'Monetary amount approved for labor services.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Approved Labor Hours' ;
    rdfs:comment 'Number of labor hours approved for reimbursement.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedPartsCost rdf:type rdf:Property ;
    rdfs:label 'Approved Parts Cost' ;
    rdfs:comment 'Monetary amount approved for parts used in the repair.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAdjustedFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Adjusted Flag' ;
    rdfs:comment 'Indicates whether the claim amount was later adjusted.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'High-level classification of the claim type.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionCode rdf:type rdf:Property ;
    rdfs:label 'Correction Code' ;
    rdfs:comment 'Standardized code describing the corrective action taken' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintCode rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Code' ;
    rdfs:comment 'Standardized code representing the customer complaint category' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDate rdf:type rdf:Property ;
    rdfs:label 'Failure Date' ;
    rdfs:comment 'Date the vehicle failure that triggered the warranty claim occurred.' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodwillFlag rdf:type rdf:Property ;
    rdfs:label 'Goodwill Flag' ;
    rdfs:comment 'Indicates whether the claim is processed as goodwill (no reimbursement).' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHoursClaimed rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Claimed' ;
    rdfs:comment 'Total labor hours claimed by the technician for the warranty repair' ;
    rdfs:domain ind:AftersalesWarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Tax Amount' ;
    rdfs:comment 'Tax amount applied to the approved parts cost.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedDealerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Authorized Dealer Required Flag' ;
    rdfs:comment 'Indicates whether warranty service must be performed at an authorized dealer (true) or can be performed at any qualified service center (false).' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimLimitPerYear rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Per Year' ;
    rdfs:comment 'Maximum number of warranty claims allowed per vehicle per calendar year.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Total' ;
    rdfs:comment 'Overall maximum number of warranty claims permitted during the policy term.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageDescription rdf:type rdf:Property ;
    rdfs:label 'Coverage Description' ;
    rdfs:comment 'Free-text description of what components or systems are covered under the policy.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Fixed monetary amount the customer must pay for each covered repair under the warranty.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Length of the warranty coverage expressed in calendar months.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'List of components, conditions, or events excluded from coverage.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Allowed Flag' ;
    rdfs:comment 'True if the warranty may be extended beyond the original term under defined conditions.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionTerms rdf:type rdf:Property ;
    rdfs:label 'Extension Terms' ;
    rdfs:comment 'Free-text description of the conditions, cost, and duration for extending the warranty.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusions rdf:type rdf:Property ;
    rdfs:label 'Inclusions' ;
    rdfs:comment 'List of components, systems, or services explicitly covered.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExtendedWarrantyFlag rdf:type rdf:Property ;
    rdfs:label 'Is Extended Warranty Flag' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mileageLimit rdf:type rdf:Property ;
    rdfs:label 'Mileage Limit' ;
    rdfs:comment 'Maximum distance the vehicle may travel while the warranty remains valid, expressed in miles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the warranty policy.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the provider by operational model: OEM-captive (manufacturer-backed), third-party insurer, dealer-administered fund, reinsurer, or third-party administrator (TPA). Drives contract terms, claims routing, and regulatory treatment. [ENUM-REF-CANDIDATE: oem_captive|third_party_insurer|dealer_administered|reinsurer|administrator — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Identifier of the regulatory filing or certification linked to the warranty.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Allowed Flag' ;
    rdfs:comment 'Indicates whether the warranty can be renewed after expiration.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Details of renewal options, pricing, and eligibility.' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterNetwork rdf:type rdf:Property ;
    rdfs:label 'Service Center Network' ;
    rdfs:comment 'Identifier of the service-center network eligible for warranty work (e.g., OEM network, third-party network).' ;
    rdfs:domain ind:WarrantyPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the warranty can be transferred to a subsequent owner (true) or is non-transferable (false).' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleWarrantyId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Warranty Id' ;
    rdfs:comment 'Unique surrogate key for the vehicle warranty record.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aftersalesWarrantyPolicyId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Warranty Policy Id' ;
    rdfs:comment 'Foreign key linking to aftersales.warranty_policy. Business justification: Vehicle warranty must reference the applicable warranty policy; adds inbound to warranty_policy and outbound from vehicle_warranty.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyPolicy .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Identifier of the service contract linked to the warranty.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:vehicleRecallCampaignId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Recall Campaign Id' ;
    rdfs:comment 'Reference to a recall record that may affect the warranty.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCampaign .

ind:vehicleRecallRecallCampaignId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Recall Recall Campaign Id' ;
    rdfs:comment 'Reference to a recall record that may affect the warranty.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCampaign .

ind:claimsLastAmount rdf:type rdf:Property ;
    rdfs:label 'Claims Last Amount' ;
    rdfs:comment 'Monetary amount of the most recent warranty claim.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsLastDate rdf:type rdf:Property ;
    rdfs:label 'Claims Last Date' ;
    rdfs:comment 'Date of the most recent warranty claim.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageArea rdf:type rdf:Property ;
    rdfs:label 'Coverage Area' ;
    rdfs:comment 'Geographic scope of the warranty coverage.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndMileage rdf:type rdf:Property ;
    rdfs:label 'Coverage End Mileage' ;
    rdfs:comment 'Maximum mileage at which warranty coverage ends.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageStartMileage rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Mileage' ;
    rdfs:comment 'Mileage reading at which warranty coverage begins.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpoWarrantyFlag rdf:type rdf:Property ;
    rdfs:label 'Cpo Warranty Flag' ;
    rdfs:comment 'True if the warranty applies to a Certified Pre-Owned vehicle.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForRecall rdf:type rdf:Property ;
    rdfs:label 'Eligible For Recall' ;
    rdfs:comment 'Indicates whether the vehicle is eligible for a safety recall under this warranty.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransferDate rdf:type rdf:Property ;
    rdfs:label 'Last Transfer Date' ;
    rdfs:comment 'Date of the most recent warranty transfer.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Date' ;
    rdfs:comment 'Date the vehicle was originally purchased by the first owner.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingMileage rdf:type rdf:Property ;
    rdfs:label 'Remaining Mileage' ;
    rdfs:comment 'Mileage remaining before the warranty limit is reached.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingMonths rdf:type rdf:Property ;
    rdfs:label 'Remaining Months' ;
    rdfs:comment 'Number of months remaining before warranty expiration.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servicePlan rdf:type rdf:Property ;
    rdfs:label 'Service Plan' ;
    rdfs:comment 'Name of the service plan associated with the warranty.' ;
    rdfs:domain ind:VehicleWarranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferAllowed rdf:type rdf:Property ;
    rdfs:label 'Transfer Allowed' ;
    rdfs:comment 'True if the warranty may be transferred to a subsequent owner.' ;
