    rdfs:comment 'Count of distinct failure events recorded for the equipment during the reporting period.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeAvailabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percentage' ;
    rdfs:comment 'Availability portion of OEE, reflecting planned production time versus actual uptime.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
