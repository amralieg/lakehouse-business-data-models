    rdfs:comment 'Unique identifier of the primary supplier nominated in the event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementSupplier .

ind:spendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Spend Category Id' ;
    rdfs:comment 'Foreign key linking to procurement.spend_category. Business justification: Sourcing events are organized by commodity/spend category. The existing commodity_group (STRING) is a denormalized text field. Linking sourcing_event to spend_category enables structured sourcing pipe' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:awardAmount rdf:type rdf:Property ;
    rdfs:label 'Award Amount' ;
    rdfs:comment 'Final contract value awarded to the selected supplier.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Award Currency Code' ;
    rdfs:comment 'Currency of the award amount.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date on which the supplier award was formally decided.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardSupplierName rdf:type rdf:Property ;
    rdfs:label 'Award Supplier Name' ;
    rdfs:comment 'Legal name of the awarded supplier.' ;
