ind:equipmentReliabilityId rdf:type rdf:Property ;
    rdfs:label 'Equipment Reliability Id' ;
    rdfs:comment 'System-generated unique identifier for each equipment reliability record.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Percentage of scheduled production time that the equipment was available for operation (Uptime / (Uptime + Downtime)).' ;
