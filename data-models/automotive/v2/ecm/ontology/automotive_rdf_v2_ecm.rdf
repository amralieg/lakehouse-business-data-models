    rdfs:comment 'System-generated unique identifier for each approved vendor list record.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:infoRecordId rdf:type rdf:Property ;
    rdfs:label 'Info Record Id' ;
    rdfs:comment 'Foreign key linking to procurement.info_record. Business justification: The approved_vendor_list (AVL) authorizes a supplier-material combination, while the info_record stores the commercial terms (price, lead time, MOQ) for the same supplier-material pair. These are comp' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfoRecord .

ind:avlNumber rdf:type rdf:Property ;
    rdfs:label 'Avl Number' ;
    rdfs:comment 'Unique alphanumeric code assigned to the approved vendor list entry.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Supplier Flag' ;
    rdfs:comment 'True if the supplier serves as a backup source for the material.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date the AVL record was initially created in the system.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppapApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Approval Level' ;
    rdfs:comment 'Production Part Approval Process level achieved for the supplier-material combination.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'True if the supplier is designated as a preferred source for the material.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceCap rdf:type rdf:Property ;
    rdfs:label 'Price Cap' ;
    rdfs:comment 'Maximum unit price the supplier may charge for the material under this AVL.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRatingThreshold rdf:type rdf:Property ;
    rdfs:label 'Quality Rating Threshold' ;
    rdfs:comment 'Minimum quality rating percentage the supplier must maintain for this material.' ;
