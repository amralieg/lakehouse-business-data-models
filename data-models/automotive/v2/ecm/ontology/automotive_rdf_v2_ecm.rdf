    rdfs:range xsd:integer .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'Technique or standard employed to calibrate the gauge (e.g., laser interferometry, dead-weight).' ;
