ind:campaignPartyId rdf:type rdf:Property ;
    rdfs:label 'Campaign Party Id' ;
    rdfs:comment 'Reference to the existing customer who responded to the campaign, if the respondent is an existing customer.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:campaignRepId rdf:type rdf:Property ;
    rdfs:label 'Campaign Rep Id' ;
