ind:overallOeePercentage rdf:type rdf:Property ;
    rdfs:label 'Overall Oee Percentage' ;
    rdfs:comment 'Composite metric combining availability, performance, and quality percentages for the equipment.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordName rdf:type rdf:Property ;
