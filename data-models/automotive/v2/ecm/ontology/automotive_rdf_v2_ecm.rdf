    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Number' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Status' ;
    rdfs:comment 'Status of the fleet account (active, suspended, closed).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAccountType rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Type' ;
    rdfs:domain ind:CustomerFleetAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetType rdf:type rdf:Property ;
    rdfs:label 'Fleet Type' ;
    rdfs:comment 'Type of fleet (commercial, government, rental).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Broad industry segment in which the entity operates.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFleetVehicleAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Fleet Vehicle Assignment Id' ;
    rdfs:comment 'Unique identifier for the customer_fleet_vehicle_assignment data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:CustomerFleetVehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDriverName rdf:type rdf:Property ;
