    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rescheduledFromAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appointment Id' ;
    rdfs:comment 'Reference to the previous delivery appointment if this appointment is a rescheduled version.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryAppointment .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'Expected duration of the delivery appointment in minutes, including vehicle walkthrough, paperwork, and handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique appointment reference number used for customer communication and tracking. Format: DA-YYYYMMDD-sequence.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the delivery appointment. [ENUM-REF-CANDIDATE: scheduled|confirmed|in_progress|completed|cancelled|no_show|rescheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Arrival Timestamp' ;
    rdfs:comment 'Date and time when the customer arrived at the delivery location for their appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmation Status' ;
    rdfs:comment 'Status indicating whether the customer has confirmed their attendance at the scheduled delivery appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the customer confirmed the delivery appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for the delivery location if delivery is not at a standard dealership facility.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line (suite, apartment, building) for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'Classification of the delivery location where the vehicle will be handed over to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating for the delivery experience, typically on a scale of 1-10, collected immediately after delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery service level provided to the customer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalOwnerManualSent rdf:type rdf:Property ;
    rdfs:label 'Digital Owner Manual Sent' ;
    rdfs:comment 'Indicates whether the digital owner manual and vehicle information was sent to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingStatus rdf:type rdf:Property ;
    rdfs:label 'Financing Status' ;
    rdfs:comment 'Status of financing approval and funding for the vehicle purchase if applicable.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Handover Duration Minutes' ;
    rdfs:comment 'Actual duration of the vehicle handover process from customer arrival to departure.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Timestamp' ;
    rdfs:comment 'Date and time when the most recent appointment reminder was sent to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pdiCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed Timestamp' ;
    rdfs:comment 'Date and time when the Pre-Delivery Inspection was completed and the vehicle was cleared for delivery.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pdiStatus rdf:type rdf:Property ;
    rdfs:label 'Pdi Status' ;
    rdfs:comment 'Status of the Pre-Delivery Inspection process ensuring the vehicle meets quality standards before customer handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of appointment reminder notifications sent to the customer via email, SMS, or phone.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time' ;
    rdfs:comment 'The precise date and time when the customer is expected to arrive for vehicle handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeInStatus rdf:type rdf:Property ;
    rdfs:label 'Trade In Status' ;
    rdfs:comment 'Status of trade-in vehicle processing if the customer is trading in a vehicle as part of the transaction.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOrientationCompleted rdf:type rdf:Property ;
    rdfs:label 'Vehicle Orientation Completed' ;
    rdfs:comment 'Indicates whether the delivery specialist completed the vehicle features and controls orientation with the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehiclePreparationStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Preparation Status' ;
    rdfs:comment 'Status of vehicle preparation activities including cleaning, fueling, accessory installation, and final detailing before delivery.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePowertrainTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Powertrain Types' ;
    rdfs:comment 'Comma-separated list of powertrain types eligible for this channel (e.g., ICE, EV, HEV, PHEV, FCEV). Used for product eligibility and incentive program alignment.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle types that can be sold through this channel (e.g., sedan, SUV, truck, EV, HEV, PHEV, commercial). Used for channel eligibility rules in lead and opportunity management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Indicates whether the channel is direct (OEM-owned, no intermediary), indirect (dealer-mediated or third-party), or hybrid (combination of direct and indirect elements).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the sales channel: active (currently operational), inactive (temporarily not in use), suspended (on hold pending review), planned (future channel not yet launched), discontinued (permanently retired).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'High-level classification of the sales channel: retail (traditional dealer), direct (OEM direct-to-consumer), fleet (commercial/fleet sales), government (public sector contracts), export (international/CKD/SKD), online (digital configurator/e-commerce), cpo (certified pre-owned). [ENUM-REF-CANDIDATE: retail|direct|fleet|government|export|online|cpo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the sales channel (e.g., RETAIL_DEALER, DIRECT_CONSUMER, FLEET_COMM, GOVT, EXPORT_CKD, ONLINE_CONFIG, CPO). Used for operational reporting and system integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionModel rdf:type rdf:Property ;
    rdfs:label 'Commission Model' ;
    rdfs:comment 'Type of commission structure applied to this channel: fixed (flat fee per unit), percentage (percent of sale price), tiered (volume-based tiers), hybrid (combination), none (no commission, direct OEM).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this channel operates (e.g., USA, CAN, MEX, DEU, GBR, CHN, JPN). Used for geographic sales attribution and regulatory compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Crm Integration Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this channel is integrated with the CRM system (Salesforce Automotive Cloud) for lead and opportunity tracking (True) or operates independently (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Default Commission Rate' ;
    rdfs:comment 'Default commission rate percentage applied to sales through this channel (e.g., 3.50 for 3.5%). Null if commission model is fixed or none.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed textual description of the sales channel, including its purpose, target customer segments, operational model, and any special characteristics or restrictions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'SAP SD division code representing the product line or business unit served by this channel (e.g., passenger vehicles, commercial vehicles, parts and accessories).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this channel is integrated with the Dealer Management System (CDK Global DMS) for inventory and order management (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecommercePlatform rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Platform' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSalesChannelCode rdf:type rdf:Property ;
    rdfs:label 'Erp Sales Channel Code' ;
    rdfs:comment 'Corresponding sales channel code in the ERP system (SAP S/4HANA SD module). Used for order-to-cash integration and financial reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibility rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligibility' ;
    rdfs:comment 'Indicates whether sales through this channel are eligible for OEM incentive programs: eligible (fully eligible), ineligible (excluded from incentives), conditional (eligible under specific conditions).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDealerMediated rdf:type rdf:Property ;
    rdfs:label 'Is Dealer Mediated' ;
    rdfs:comment 'Boolean flag indicating whether this channel involves a dealer or distributor intermediary (True) or is a direct OEM channel (False). Used for dealer network analytics and commission calculations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDigital rdf:type rdf:Property ;
    rdfs:label 'Is Digital' ;
    rdfs:comment 'Whether this is a digital/online sales channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDirectOem rdf:type rdf:Property ;
    rdfs:label 'Is Direct Oem' ;
    rdfs:comment 'Boolean flag indicating whether this channel is a direct OEM-owned channel (True) or an indirect dealer-mediated channel (False). Used for revenue attribution and margin analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSourcePriority rdf:type rdf:Property ;
    rdfs:label 'Lead Source Priority' ;
    rdfs:comment 'Numeric priority ranking for lead routing to this channel (1 = highest priority). Used in lead assignment and opportunity allocation logic.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Full descriptive name of the sales channel (e.g., Retail Dealer Network, Direct-to-Consumer, Fleet and Commercial Sales, Government Sales, Export/CKD, Online Configurator, Certified Pre-Owned).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Pricing approach used in this channel: msrp (Manufacturer Suggested Retail Price with dealer negotiation), negotiated (fully negotiated pricing), fixed (no-haggle fixed price), dynamic (algorithm-driven pricing), auction (competitive bidding).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP SD sales organization code responsible for this channel. Links to the organizational hierarchy for revenue reporting and territory management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCpo rdf:type rdf:Property ;
    rdfs:label 'Supports Cpo' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsFinancing rdf:type rdf:Property ;
    rdfs:label 'Supports Financing' ;
    rdfs:comment 'Boolean flag indicating whether this channel offers financing options (True) or requires cash/external financing (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsFleetSales rdf:type rdf:Property ;
    rdfs:label 'Supports Fleet Sales' ;
    rdfs:comment 'Boolean flag indicating whether this channel supports fleet or commercial bulk sales (True) or is limited to individual retail sales (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLeasing rdf:type rdf:Property ;
    rdfs:label 'Supports Leasing' ;
    rdfs:comment 'Boolean flag indicating whether this channel offers leasing options (True) or does not support leasing (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOnlineConfiguration rdf:type rdf:Property ;
    rdfs:label 'Supports Online Configuration' ;
    rdfs:comment 'Boolean flag indicating whether this channel supports online vehicle configuration and ordering (True) or requires in-person interaction (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOnlineOrders rdf:type rdf:Property ;
    rdfs:label 'Supports Online Orders' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSubscriptions rdf:type rdf:Property ;
    rdfs:label 'Supports Subscriptions' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTradeIn rdf:type rdf:Property ;
    rdfs:label 'Supports Trade In' ;
    rdfs:comment 'Boolean flag indicating whether this channel accepts trade-in vehicles as part of the transaction (True) or does not support trade-ins (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Id' ;
    rdfs:comment 'Unique identifier for the price adjustment record. Primary key.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Price Customer Party Id' ;
    rdfs:comment 'Reference to the customer receiving the price adjustment.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:priceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Price Employee Id' ;
    rdfs:comment 'Reference to the manager or executive who authorized this price adjustment.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:pricePartyId rdf:type rdf:Property ;
    rdfs:label 'Price Party Id' ;
    rdfs:comment 'Reference to the customer receiving the price adjustment.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:priceVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Price Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration or unit to which this price adjustment applies.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:priceVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Price Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration or unit to which this price adjustment applies.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:primaryPriceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Employee Id' ;
    rdfs:comment 'Reference to the manager or executive who authorized this price adjustment.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustedPrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Price' ;
    rdfs:comment 'The resulting price after this adjustment is applied. May be further adjusted by subsequent adjustments in the pricing waterfall.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'The monetary value of the price adjustment in the transaction currency. Negative values represent discounts or reductions; positive values represent surcharges or premiums (rare but possible for special equipment or expedited delivery).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'High-level grouping of the adjustment type for reporting and analysis purposes. Distinguishes between manufacturer-funded incentives, dealer-funded discounts, and other adjustment sources. [ENUM-REF-CANDIDATE: manufacturer_incentive|dealer_discount|regional_program|customer_loyalty|fleet_commercial|employee_affiliate|promotional_campaign|competitive_response|inventory_management|executive_override — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Adjustment Method' ;
    rdfs:comment 'Method by which the adjustment is calculated: fixed dollar amount, percentage of MSRP or invoice, tiered based on volume or other criteria, or formula-based calculation.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Adjustment Percentage' ;
    rdfs:comment 'The percentage rate of the price adjustment when the adjustment method is percentage-based. Stored as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the price adjustment was actually applied to the quote or order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this price adjustment has been flagged for audit review due to unusual amount, authorization level, or other risk factors.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the audit review for this price adjustment, if audited.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'The original price (MSRP or invoice price) before this adjustment is applied, providing context for the adjustment magnitude.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center to which the financial impact of this price adjustment is allocated for internal accounting purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account code to which the price adjustment amount is posted for financial reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business rationale and supporting explanation for the price adjustment. Provides audit trail and context for non-standard pricing decisions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onlineExclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Online Exclusive Flag' ;
    rdfs:comment 'Whether price adjustment is exclusive to online orders' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the price adjustment request was rejected, if applicable.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stackingAllowed rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed' ;
    rdfs:comment 'Indicates whether this price adjustment can be combined (stacked) with other adjustments and incentives. Some programs are mutually exclusive.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittingUserCode rdf:type rdf:Property ;
    rdfs:label 'Submitting User Code' ;
    rdfs:comment 'Reference to the sales representative or dealer user who submitted the price adjustment request.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderStatusEventId rdf:type rdf:Property ;
    rdfs:label 'Order Status Event Id' ;
    rdfs:comment 'Unique identifier for the order status event record. Primary key.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Order Customer Party Id' ;
    rdfs:comment 'Reference to the customer who placed the order. Enables customer-specific order tracking and communication.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:orderPartyId rdf:type rdf:Property ;
    rdfs:label 'Order Party Id' ;
    rdfs:comment 'Reference to the customer who placed the order. Enables customer-specific order tracking and communication.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actualProductionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Completion Date' ;
    rdfs:comment 'The actual date when the vehicle completed assembly and exited the production line. Populated when the order transitions to built status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Start Date' ;
    rdfs:comment 'The actual date when the vehicle entered the production line. Populated when the order transitions to in_production status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayDays rdf:type rdf:Property ;
    rdfs:label 'Delay Days' ;
    rdfs:comment 'The number of days the order is delayed relative to the original schedule. Calculated when a status transition occurs later than planned.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Notification Sent Flag' ;
    rdfs:comment 'Whether digital notification was sent to customer for this status change' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this status event represents an exception or deviation from the normal order fulfillment process. True if exception, False otherwise.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The order status after this transition event. Captures the to-state in the order lifecycle. Enables end-to-end order tracking through the fulfillment pipeline. [ENUM-REF-CANDIDATE: confirmed|scheduled_for_production|in_production|built|quality_released|shipped|in_transit|at_dealer|delivered|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of the status change. Examples include email, SMS, mobile app push notification, customer portal, phone call.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification was sent for this status change event. True if notification sent, False otherwise.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The order status immediately before this transition event. Captures the from-state in the order lifecycle. [ENUM-REF-CANDIDATE: placed|confirmed|scheduled_for_production|in_production|built|quality_released|shipped — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Quality Release Date' ;
    rdfs:comment 'The date when the vehicle passed final quality inspection and was released for shipment. Populated when the order transitions to quality_released status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'The date when the vehicle was shipped from the manufacturing plant or distribution center. Populated when the order transitions to shipped status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringUserCode rdf:type rdf:Property ;
    rdfs:label 'Triggering User Code' ;
    rdfs:comment 'The user or system account that triggered the status change. May be a human user ID or a system service account identifier.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Campaign Employee Id' ;
    rdfs:comment 'Identifier of the sales representative or manager responsible for the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spent Amount' ;
    rdfs:comment 'Total amount actually spent on the campaign to date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpentCurrency rdf:type rdf:Property ;
    rdfs:label 'Actual Spent Currency' ;
    rdfs:comment 'ISO 4217 currency code for the actual spent amount.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 currency code for the budget amount.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Category of the campaign indicating its strategic purpose.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Code identifying the service campaign or recall.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerParticipationFlag rdf:type rdf:Property ;
