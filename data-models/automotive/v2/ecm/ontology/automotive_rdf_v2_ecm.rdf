ind:telemetryEventId rdf:type rdf:Property ;
    rdfs:label 'Telemetry Event Id' ;
    rdfs:comment 'Foreign key linking to mobility.telemetry_event. Business justification: Root cause analysis links each defect to the specific telemetry event that triggered it, required for the Defect Investigation Report.' ;
    rdfs:domain ind:Automotive ;
