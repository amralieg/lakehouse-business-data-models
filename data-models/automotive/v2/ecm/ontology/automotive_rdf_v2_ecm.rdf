    rdfs:comment 'Comma-separated list of key feature highlights and differentiators of the competitor vehicle used in competitive battle cards and sales coaching (e.g., adaptive cruise control, panoramic sunroof, premium audio system).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
