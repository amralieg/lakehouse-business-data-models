    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Date-time of the most recent modification to the notification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationNumber rdf:type rdf:Property ;
