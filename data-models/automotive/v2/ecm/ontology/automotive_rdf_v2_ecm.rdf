    rdfs:comment 'Cumulative count of redemption transactions performed by the member.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'System-generated unique identifier for the loyalty transaction record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Loyalty Points Accrual Audit tracks which employee processed each loyalty transaction at point-of-sale.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Identifier of the promotion or campaign that generated the points, if applicable.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'Number of loyalty points affected by the transaction (positive for earn, negative for redeem/expire).' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Running total of loyalty points for the membership after this transaction is applied.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Category of the transaction indicating points earned, redeemed, adjusted, expired, or transferred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Business event that caused the points transaction (e.g., vehicle purchase, service visit, referral, promotion, OTA enrollment, EV charge).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentId rdf:type rdf:Property ;
