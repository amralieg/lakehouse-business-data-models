    rdfs:comment 'Designated dock or bay where the supplier\'s goods are received at the plant.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'System-generated unique identifier for the sourcing event.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:eprocurementPortalId rdf:type rdf:Property ;
    rdfs:label 'Eprocurement Portal Id' ;
    rdfs:comment 'FK to the e-procurement portal through which this sourcing event was conducted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EprocurementPortal .

ind:primarySourcingProcurementSupplierId rdf:type rdf:Property ;
