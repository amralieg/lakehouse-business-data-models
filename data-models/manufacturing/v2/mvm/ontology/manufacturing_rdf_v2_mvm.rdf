ind:returnAddressId rdf:type rdf:Property ;
    rdfs:label 'Return Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Reverse logistics in manufacturing requires scheduling carrier pickup at the customer\'s validated return address. The return_address_id FK enables 3PL carrier booking, hazmat certification checks, and' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:actualReturnDate rdf:type rdf:Property ;
