    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationArea rdf:type rdf:Property ;
    rdfs:label 'Valuation Area' ;
    rdfs:comment 'Organizational area for inventory valuation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementDescription rdf:type rdf:Property ;
    rdfs:label 'Agreement Description' ;
    rdfs:comment 'Free-text description providing context or special notes about the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Status' ;
    rdfs:comment 'Current lifecycle state of the blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatusReason rdf:type rdf:Property ;
    rdfs:label 'Contract Status Reason' ;
    rdfs:comment 'Free-text explanation for the current status of the agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeReleasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Released Quantity' ;
    rdfs:comment 'Total quantity that has been released to the customer to date.' ;
