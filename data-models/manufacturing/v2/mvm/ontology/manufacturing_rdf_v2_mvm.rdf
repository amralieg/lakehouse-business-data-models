    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderRmaStatus rdf:type rdf:Property ;
    rdfs:label 'Order Rma Status' ;
    rdfs:comment 'Current lifecycle state of the RMA.' ;
