    rdfs:range xsd:string .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Primary key for goods_issue' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center responsible for the goods issue cost.' ;
