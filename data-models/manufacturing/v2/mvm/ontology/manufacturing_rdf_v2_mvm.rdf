ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: An invoice is issued to a billing account — billing_account is the SSOT for the financial relationship between the company and the customer in this domain. invoice currently has no FK to billing_accou' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Invoice billing address must reference the canonical customer address record for tax jurisdiction, VAT validation, and regulatory compliance reporting. Manufacturing invoices require verified ship-to/' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
