ind:restockStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Restock Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: RMA lines specify the exact inventory location where returned material is restocked; formalizing this as a FK to stock_location enables WMS-driven putaway, inventory balance updates, and restock accur' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
