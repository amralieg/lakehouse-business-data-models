ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether the goods issue was generated automatically by a system.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'External document number assigned to the goods issue.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
